Cell[CellGroupData[{

Cell["Clifford Quantum Circuits", "GuideTitle",
 CellID->1116505501,ExpressionUUID->"a0fd5f57-264a-4e63-b5d7-211c876cf211"],

Cell[TextData[{
 "The ",
 StyleBox["Gottesman-Knill theorem",
  FontSlant->"Italic"],
 " reveals that a ",
 StyleBox["Clifford circuit",
  FontSlant->"Italic"],
 ", i.e., a quantum circuit consisting of Clifford unitary gates (which are \
generated by CNOT, Hadamard, and quadrant phase gates) and Pauli measurements \
, may be simulated efficiently on a classical computer. See ",
 ButtonBox["Cleve and Gottesman (1997)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysreva.56.76"], None}],
 ", ",
 ButtonBox["Gottesman (1998)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.57.127"], None}],
 " and ",
 ButtonBox["Aaronson and Gottesman (2004)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/physreva.70.052328"], None}],
 "."
}], "GuideAbstract",
 CellID->772978536,ExpressionUUID->"124ac77c-1ffb-4dea-a890-cea9ae71cbd1"],

Cell[TextData[{
 "Random Clifford circuits are prototype models that exhibit the phenomenon \
of ",
 StyleBox["measurement-induced entanglement transition",
  FontSlant->"Italic"],
 ", a transition between two distinct phases with the entanglement entropy \
characterized by area- and volume-law scaling. See also ",
 ButtonBox["Li, Chen, and Fisher (2018)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysrevb.98.205136"], None}],
 ", ",
 ButtonBox["Skinner, Ruhman, and Nahum (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysrevx.9.031009"], None}],
 ", ",
 ButtonBox["Chan et. al. (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevB.99.224307"], None}],
 ", ",
 ButtonBox["Sang et al. (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PRXQuantum.2.030313"], None}],
 ", and ",
 ButtonBox["Weinstein, Bao, and Altman (2022)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevLett.129.080501"], None}],
 "."
}], "GuideAbstract",
 CellID->1181352387,ExpressionUUID->"6db736d9-2c3f-4417-94cc-bef9a98d1013"],

Cell["\<\
Q3 provides tools to efficiently simulate and analyze Clifford quantum \
circuits.\
\>", "GuideAbstract",
 CellID->1962485736,ExpressionUUID->"0ce953bf-ba16-4a90-a478-c83668fdecd7"],

Cell["\t", "GuideDelimiterSubsection",ExpressionUUID->"fa4ceee1-5f30-4551-8fe5-0feb213069d3"],

