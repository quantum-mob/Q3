    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"GuideAbstract"}]],ExpressionUUID->
  "987ce2a0-e287-4ec5-90fa-fc8eb13d49bf"],
 "."
}], "GuideAbstract",
 CellID->1308734266,ExpressionUUID->"77143d52-6ada-4044-9ec1-797c1a7ff675"],

