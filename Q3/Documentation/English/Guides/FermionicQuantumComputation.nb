Cell[CellGroupData[{

Cell["Fermionic Quantum Computation", "GuideTitle",
 CellID->1171114635,ExpressionUUID->"6b75fade-cce4-4ab8-8b18-f76d81e48070"],

Cell[TextData[{
 "Fermionic quantum computation is a model of quantum computation based on \
local fermionic modes. It was introduced by ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Bravyi and Kitaev in 2002"]], 
    "https://doi.org/10.1006/aphy.2002.6254"},
   "WebLink",
   BaseStyle->{"GuideAbstract"}]],ExpressionUUID->
  "681d31ee-c2c2-49df-b5a5-d765aa36cabb"],
 "."
}], "GuideAbstract",
 CellID->1236045690,ExpressionUUID->"00bf1635-0d0c-4378-81e9-5cf70c3b5d61"],

Cell[TextData[{
 "Q3 provides tools to efficiently simulate a subclass of fermionic quantum \
computation models called ",
 StyleBox["Bravyi circuits",
  FontSlant->"Italic"],
 ", where unitary gates are associated with quadratic Hamiltonian (describing \
non-interacting fermions) and interspersed complete von Neumann measurement \
in the computational basis (measurement outcome describing an empty or \
occupied fermionic mode), which is described in ",
 StyleBox[ButtonBox["Terhal",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.65.032325"], None}],
  IgnoreSpellCheck->True],
 ButtonBox[" and DiVincenzo (2002)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.65.032325"], None}],
 " and ",
 StyleBox[ButtonBox["Knill",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/quant-ph/0108033"], None}],
  IgnoreSpellCheck->True],
 ButtonBox[" (2001)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/quant-ph/0108033"], None}],
 "."
}], "GuideAbstract",
 CellID->114330397,ExpressionUUID->"9b7a4756-201e-463d-b1ea-94a0fe03ba4f"],

Cell[TextData[{
 "Random Bravyi circuits may be one of prototype quantum circuits that \
exhibit the phenomenon of ",
 StyleBox["measurement-induced entanglement transition",
  FontSlant->"Italic"],
 ", a transition between two distinct phases with the entanglement entropy \
characterized by area- and volume-law scaling. See also ",
 ButtonBox["Li, Chen, and Fisher (2018)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysrevb.98.205136"], None}],
 ", ",
 ButtonBox["Skinner, ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysrevx.9.031009"], None}],
 StyleBox[ButtonBox["Ruhman",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysrevx.9.031009"], None}],
  IgnoreSpellCheck->True],
 ButtonBox[", and Nahum (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysrevx.9.031009"], None}],
 ", ",
 ButtonBox["Chan et. al. (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevB.99.224307"], None}],
 ", ",
 ButtonBox["Sang et al. (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PRXQuantum.2.030313"], None}],
 ", and ",
 StyleBox[ButtonBox["Weinstein",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevLett.129.080501"], None}],
  IgnoreSpellCheck->True],
 ButtonBox[", ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevLett.129.080501"], None}],
 StyleBox[ButtonBox["Bao",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevLett.129.080501"], None}],
  IgnoreSpellCheck->True],
 ButtonBox[", and Altman (2022)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevLett.129.080501"], None}],
 "."
}], "GuideAbstract",
 CellID->1181352387,ExpressionUUID->"20448457-8183-49f4-87fb-8b28ac06d8ac"],

