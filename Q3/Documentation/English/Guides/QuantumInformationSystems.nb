Cell[CellGroupData[{

Cell["Quantum Information Systems", "GuideTitle",
 CellID->693790986,ExpressionUUID->"09c96f83-1f7f-4792-8df0-ddfe8b8a0151"],

Cell["\<\
Q3 provides various tools and utilities for symbolic and numerical \
calculations to simulate quantum computation and quantum information \
processing.\
\>", "GuideAbstract",
 CellID->1856382139,ExpressionUUID->"e8d9e4fe-c35d-489e-b4d6-9b553ed35cc2"],

Cell[TextData[{
 "Here listed are frequently used functions for each subject. The subjects \
are arranged in parallel with the chapters in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"GuideAbstract"}]],ExpressionUUID->
  "8a61bf13-466b-4070-96f2-0a79384d9950"],
 "."
}], "GuideAbstract",
 CellID->466746563,ExpressionUUID->"06118268-7d14-4055-80ce-72142d3555a3"],

Cell[TextData[{
