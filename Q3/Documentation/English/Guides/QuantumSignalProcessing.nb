Cell[CellGroupData[{

Cell["Quantum Signal Processing", "GuideTitle",
 CellID->1401120802,ExpressionUUID->"d71af815-641e-4393-9bcc-c63f848d7a88"],

Cell[TextData[{
 "The ",
 ButtonBox["quantum signal processing (QSP)",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumSignalProcessing"],
 " is a parameterized representation of a polynomial through a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Times]", "2"}], TraditionalForm]],ExpressionUUID->
  "19dac34c-4f30-4b1e-ba07-c16d83166cd4"],
 " unitary matrix."
}], "GuideAbstract",
 CellID->1149534814,ExpressionUUID->"2b0f9b33-b185-4f09-a38e-39c5f5b552ad"],

Cell[TextData[{
 "Quantum signal processing builds a foundation of ",
 StyleBox["quantum eigenvalue transform",
  FontSlant->"Italic"],
 ", ",
 StyleBox["quantum singular value transform",
  FontSlant->"Italic"],
 " and other related methods that provide a general approach to implement \
functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"F", "(", "A", ")"}], TraditionalForm]],ExpressionUUID->
  "a66a360c-90b7-4154-84c0-9181676215d1"],
 " of matrices ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "471141d1-e88d-4298-8287-ef39e0feb20b"],
 " on a quantum computer."
}], "GuideAbstract",
 CellID->806727323,ExpressionUUID->"bee81ded-b1be-49fe-976f-ae0abb6635c3"],

Cell["\t", "GuideDelimiterSubsection",ExpressionUUID->"3ad3caa9-50ad-46b3-aa93-6d1447383294"],

