Cell[CellGroupData[{

Cell["Q3: Symbolic Quantum Simulation", "GuideTitle",
 CellID->562037802,ExpressionUUID->"b8c45cd0-4145-4f25-9532-9d9662199a2d"],

Cell[TextData[{
 "Q3 is a symbolic quantum simulation framework written in the ",
 ButtonBox["Wolfram Language",
  BaseStyle->"Link",
  ButtonData->"paclet:guide/LanguageOverview"],
 " to help study ",
 StyleBox[ButtonBox["quantum information systems",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumInformationSystems"],
  FontSlant->"Italic"],
 ", ",
 StyleBox[ButtonBox["quantum many-body systems",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumManyBodySystems"],
  FontSlant->"Italic"],
 ", and ",
 StyleBox[ButtonBox["quantum spin systems",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumSpinSystems"],
  FontSlant->"Italic"],
 ". It provides various tools and utilities for symbolic calculations and \
numerical simulations on these representative quantum systems."
}], "GuideAbstract",
 CellID->1536258708,ExpressionUUID->"8cf42526-f98d-4699-9c65-bb3df8a3522c"],

Cell["\t", "GuideDelimiterSubsection",ExpressionUUID->"0f012b6f-dec4-4525-8340-9e8721838ecc"],

