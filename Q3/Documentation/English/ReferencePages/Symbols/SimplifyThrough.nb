Cell["\<\
Consider a matrix in the sparse array form with a complicated expression.\
\>", "ExampleText",
 CellID->1611286051,ExpressionUUID->"a62c713c-b062-4e3f-9be6-0578718e9a86"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{"SparseArray", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "1"}], "}"}], "->", "1"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"2", ",", "2"}], "}"}], "->", 
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"I", " ", 
            RowBox[{
             RowBox[{"Sqrt", "[", "2", "]"}], "/", 
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{"I", "/", 
                RowBox[{"Sqrt", "[", "2", "]"}]}]}], ")"}]}]}]}], ")"}]}]}]}],
       "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"mat", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->66761076,ExpressionUUID->"ef1a5aff-19af-43cd-a314-74b4feb4c1d9"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "0"},
     {"0", 
      FractionBox["1", 
       RowBox[{"1", "+", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", 
          SqrtBox["2"]}], 
         RowBox[{"1", "+", 
          FractionBox["\[ImaginaryI]", 
           SqrtBox["2"]]}]]}]]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {2, 2}, 0, {
     1, {{0, 1, 2}, {{1}, {2}}}, {
      1, (1 + Complex[0, 1] (2^Rational[1, 2]/(1 + 
          Complex[0, 1] 2^Rational[-1, 2])))^(-1)}}]]]]], "Output",
 CellLabel->"Out[1]//MatrixForm=",
 CellID->383470189,ExpressionUUID->"bab77c0b-2723-41e0-a4d9-6a15c06c1f13"]
}, Open  ]],

