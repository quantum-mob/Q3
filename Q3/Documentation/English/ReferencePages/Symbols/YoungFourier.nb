Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"e6645b70-ae5b-4278-8b73-d51d3ab8ef63"],
 " is the ",
 StyleBox["right regular basis",
  FontSlant->"Italic"],
 " of group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "e6f926b3-c3f6-46da-91d4-30ea719e436c"],
 ", i.e.,  the canonical basis of the vector space that carries the ",
 StyleBox["right regular representation",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "8684f2eb-d0bc-4840-b078-ba44b0cfe016"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "27921519-7fa2-44d6-9d66-e8060fb78c01"],
 ". For all elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "9b3e8323-6517-492e-94bb-045c7c4ae5c4"],
 " and ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "3f701807-cfc7-467b-9f6b-cca7d606491e"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "22e61e73-66d1-4382-9dba-91c429252dc0"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"h", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "cdc49aed-7da4-4f66-9b94-1e1a1d2ef40b"],
 " ."
}], "Notes",
 CellID->1048209744,ExpressionUUID->"9d4625aa-565d-49ed-bc95-0e002228622f"],

Cell[TextData[{
 "The ",
 StyleBox["right Fourier basis",
  FontSlant->"Italic"],
 " consists of vectors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "977e7d32-2413-422e-ba6a-a7d71d545dd9"],
 " defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]], 
     TemplateBox[{"g"},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "4d047173-8767-43d3-8047-e448d91f5639"],
 "\[LineSeparator]for each irreducible representation  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"0b528df7-6884-4227-bb5e-f50b838f0227"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "bcfe1362-d53c-4876-8ac2-96626a169190"],
 " and each index ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ",", 
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "ec4a4e4b-5e8e-45c1-bd94-fa71b98f27ae"],
 ". The basis change from the canonical to Fourier basis is called the ",
 StyleBox["quantum Fourier transform over group",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "87795d3a-d1d6-48ae-928d-ca8d7c8bc23a"],
 " or simply the ",
 StyleBox["generalized quantum Fourier transform",
  FontSlant->"Italic"],
 ". The inverse transform gives\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"g"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "=", "1"}]}], 
      SubscriptBox["d", "\[Lambda]"]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], " ", 
     SuperscriptBox[
      RowBox[{
       SqrtBox[
        FractionBox[
         SubscriptBox["d", "\[Lambda]"], 
         RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
        ")"}], "]"}], "*"]}]}], TraditionalForm]],ExpressionUUID->
  "37733450-5aee-45f1-94f3-45fadc17ef73"],
 " ,\nwhere the first summation is over all inequivalent irreducible \
representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "4016efe7-d4cc-4d88-ba96-d333302d5817"],
 ". Note that the dimension of an irreducible representation ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "c0971dd4-1785-4fff-9646-3eacd61c1bb6"],
 " of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "9dc305ef-9cd5-4600-ad64-9c093e361957"],
 " always divides the order of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5289e622-e564-4959-a300-2e5f41e01d13"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
     "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], "/", 
     RowBox[{"dim", "(", "\[Lambda]", ")"}]}], "\[Element]", 
    "\[DoubleStruckCapitalZ]"}], TraditionalForm]],ExpressionUUID->
  "06b925b0-1fe7-4d50-8e25-2534f471cde5"],
 "."
}], "Notes",
 CellID->1790577104,ExpressionUUID->"b06e4263-53ba-4b73-8905-0e154bca9a5c"],

Cell[TextData[{
 "Under the group action, the Fourier basis transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "014e7b8c-543c-4640-a6f6-491dd6185c8a"],
 "\[LineSeparator]with index ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "d15212a9-6805-430b-bae6-0ab4289115f4"],
 " labeling the multiplicity space. Note that every basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ab25b7d6-d6e8-41c3-b953-8af307bdbcf5"],
 " transforms in the same way regardless of index ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3c8ca24a-e1c8-496b-bc16-6922cec98f8e"],
 ". That is to say, in the Fourier basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "24467ca3-f3da-41ba-9bf4-10923881c357"],
 ", the right regular representation ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "61e89e2f-36be-48c4-b4d4-02729f35f3ce"],
 " is block-diagonal in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "g", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], "\[VeryThinSpace]", 
     RowBox[{
      SubscriptBox["I", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"023d5f10-99a5-4751-a438-51e0cb9ed280"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "25f7c3a6-a4b8-42c0-99d0-6f80e819945e"],
 " refers to the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "\[Lambda]"], "\[Times]", 
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "73003c80-17e8-4ee6-b086-a4e1af3f1d19"],
 " identity matrix in the multiplicity space."
}], "Notes",
 CellID->882427163,ExpressionUUID->"77d1b488-779c-45af-90e9-6a771ce41929"],

Cell[TextData[{
 "Setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FourierParameters"]], "paclet:ref/FourierParameters"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{"\"\<Right\>\"", ",", " ", "\"\<Right\>\""}], "}"}]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ee163cc3-10a3-470a-8552-284f8b710c20"],
 " (default) implements the above type of generalized quantum Fourier \
transform. The first ",
 Cell[BoxData["\"\<Right\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "abc02255-fe60-482c-8b71-5e345fa0ffc3"],
 " refers to the right regular representation and the second ",
 Cell[BoxData["\"\<Right\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "11e87221-4c5f-4b74-b79b-f6ce81dbddc6"],
 " indicates that the irreducible space is to the right of the multiplicity \
space."
}], "Notes",
 CellID->1151071605,ExpressionUUID->"f27c6be9-0acb-488b-a18d-d26bda8c5168"],

Cell[TextData[{
 "If the ",
 StyleBox["left regular representation",
  FontSlant->"Italic"],
 " is concerned, the canonical basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"9150ffcb-ad1d-4b32-ad82-3968d19ddf6d"],
 " transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"g", "\[VeryThinSpace]", "h"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "b87f9406-4343-417a-bd07-9613bb017cd8"],
 " .\[LineSeparator]In this case, the ",
 StyleBox["left Fourier basis",
  FontSlant->"Italic"],
 " vectors are defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]], 
     TemplateBox[{"g"},
      "Ket"], 
     SubscriptBox[
      RowBox[{
       SqrtBox[
        FractionBox[
         SubscriptBox["d", "\[Lambda]"], 
         RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], "[", 
       RowBox[{
        SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]], ")"}], "]"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"e3df4143-0dba-4634-8e8d-f9fe29ab0921"],
 " .\[LineSeparator]Here, notice the input argument  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "20fa1f33-bf2d-4024-9cff-2d83b72dc827"],
 " of matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SuperscriptBox["g", 
     RowBox[{"-", "1"}]], ")"}], TraditionalForm]],ExpressionUUID->
  "9ed12dfd-1494-41c5-873c-522cc202ca6a"],
 ". The inverse transform is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"g"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"j", "\[VeryThinSpace]", "i"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "3abaef91-f99d-4222-863b-fee3cb570fb9"],
 " .\[LineSeparator]Here, notice the reversed indices in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalGamma]", 
     RowBox[{"j", "\[VeryThinSpace]", "i"}], "\[Lambda]"], "(", "g", ")"}], 
   TraditionalForm]],ExpressionUUID->"af1d37ba-0f0b-4d0b-b4d5-1a3c36f805b0"],
 ". Under the group action, the left Fourier basis transforms as\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "5bac6e03-6c1c-4831-a85c-bb32b1117be1"],
 "\[LineSeparator]and hence, in the left Fourier basis,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"L", "(", "g", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], "\[VeryThinSpace]", 
     RowBox[{
      SubscriptBox["I", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"d1dec30e-42e0-4562-93e2-0c84831e3104"],
 " ."
}], "Notes",
 CellID->519159934,ExpressionUUID->"f8d149a7-a457-42ba-966c-f52de2c49d18"],

Cell[TextData[{
 "Setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FourierParameters"]], "paclet:ref/FourierParameters"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{"\"\<Left\>\"", ",", " ", "\"\<Right\>\""}], "}"}]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "487fc15e-03b7-4fd5-85c0-d5412353e054"],
 " implements the above type of generalized quantum Fourier transform."
}], "Notes",
 CellID->935160286,ExpressionUUID->"c4eebd53-ca06-4762-9578-8b84b4153439"],

