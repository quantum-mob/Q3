Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GivensFactor"]], "paclet:QuantumMob/Q3/ref/GivensFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "88b14d04-65ee-40fb-8044-6e0f49161434"],
 " is much more efficient than ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GrayGivensFactor"]], 
    "paclet:QuantumMob/Q3/ref/GrayGivensFactor", "QuantumMob Package Symbol"},
   
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cebe5a0b-4e3d-421b-9020-c274fc56cf20"],
 ", and the latter must be used only for heuristic purposes. See ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Nielsen and Chuang (2022)"]], 
    "https://doi.org/10.1017/CBO9780511976667"},
   "WebLink",
   BaseStyle->{"Notes", FontSlant -> "Plain"}]],ExpressionUUID->
  "421182a0-e39a-4d25-a3f8-11dcfa3064d6"],
 StyleBox[".",
  FontSlant->"Plain"]
}], "Notes",
 CellID->872497501,ExpressionUUID->"ee0fe238-7881-4476-8a11-5a2de5e9a7d0"],

Cell[TextData[{
 "While ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GrayGivensFactor"]], 
    "paclet:QuantumMob/Q3/ref/GrayGivensFactor", "QuantumMob Package Symbol"},
   
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0e24e2ec-0f8a-4ee3-8fe0-763399c6b689"],
 " follows rather naively the idea based on the Gray code as explained in \
Nielsen and Chuang (2011),  ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GivensFactor"]], "paclet:QuantumMob/Q3/ref/GivensFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "13cad728-ee81-4e68-b3f2-a3b13e1f1bd2"],
 " has minimized the number of required CNOT gates. See ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
     "Vartiainen, M\[ODoubleDot]tt\[ODoubleDot]nen, and Salomaa, (2004)"]], 
    "https://doi.org/10.1103/PhysRevLett.92.177902"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "c366ebbf-1b86-4fc3-857e-08186c0c5ac7"],
 "."
}], "Notes",
 CellID->25262995,ExpressionUUID->"9b5ac4b9-61ab-4909-82b2-03b9e825a3e1"]
}, Dynamic[CurrentValue[
