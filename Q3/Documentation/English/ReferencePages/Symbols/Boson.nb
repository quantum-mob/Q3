Cell[TextData[{
 "Bosonic operators obey canonical commutation relations, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["a", "i"], ",", 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "]"}], "=", 
    SubscriptBox["\[Delta]", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], TraditionalForm]],
  ExpressionUUID->"daef3ce9-3c52-42e8-a913-f12c28779048"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"[", 
      RowBox[{
       SubscriptBox["a", "i"], ",", 
       SubscriptBox["a", "j"]}], "]"}], "=", "[", 
     RowBox[{
      SubsuperscriptBox["a", "i", "\[Dagger]"], ",", 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "]"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"02b75723-1551-44e5-8db8-a1ada5ab560c"],
 ", and form a ",
 ButtonBox["Weyl algebra",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/WeylAlgebra"],
 "."
}], "Notes",
 CellID->1278248048,ExpressionUUID->"0199be7f-28be-4744-887d-2f7b885649a5"],

