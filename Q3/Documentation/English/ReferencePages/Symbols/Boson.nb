Cell["Bosons are declared as follows", "ExampleText",
 CellID->1455856776,ExpressionUUID->"ac567ce6-f868-4663-a72c-999478f972cd"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Boson", ",", "a", ",", "b"}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->156160314,ExpressionUUID->"225ca618-f0a0-498d-a603-715ffe0033ab"],

Cell["\<\
By the above declaration, a[i,j,...] are all bosonic annihilation operators, \
and Dagger[a[i,j,...]] are creation operators.\
\>", "ExampleText",
 CellID->361380764,ExpressionUUID->"49155ff5-30b4-4549-a11d-3aa74ffd59fc"],

