 CellLabel->"In[1]:=",
 CellID->156160314,ExpressionUUID->"b82c3447-b759-49cf-96c0-ba94343ae263"],

Cell["\<\
By the above declaration, a[i,j,...] are all bosonic annihilation operators, \
and Dagger[a[i,j,...]] are creation operators.\
\>", "ExampleText",
 CellID->361380764,ExpressionUUID->"f7289c6d-cba6-4ceb-9f55-00eecf17eb59"],

Cell["This form is equivalent to the above form.", "ExampleText",
 CellID->642746832,ExpressionUUID->"2674afcf-695c-4b2d-8edd-d81fce448ffc"],

