Cell["Bosons are declared as follows", "ExampleText",
 CellID->1455856776,ExpressionUUID->"941ea242-0d1b-4451-b184-7c4b52d53e36"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Boson", ",", "a", ",", "b"}], "]"}]], "Input",
