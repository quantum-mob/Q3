  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 54, 49.461563}", 
    "history" -> {"13", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {"stabilizer formalism", "stabilizer codes"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "GottesmanStandard[mat] converts mat consisting of rows of Gottesman \
vectors into the standard form and returns {xmat, zmat, perm}, where xmat and \
zmat are the X- and Z-part of the resulting matrix in the standard form and \
perm is the permutation of columns (i.e., qubits) used to bring mat into the \
standard form. GottesmanStandard[mat, vec] performs the Gaussian elimination \
for linear equation mat\\[CenterDot]w == vec, and returns {xmat, zmat, vec', \
perm}. GottesmanStandard[mat, off] performs the Gaussian elimination for \
linear equation mat\\[CenterDot]wmat == off, where mat, wmat and off are \
rectangular matrices of dimensions m*n, n*r and m*r, respectively, and \
returns {xmat, zmat, off', perm}.", "synonyms" -> {}, "tabletags" -> {}, 
    "title" -> "GottesmanStandard", "titlemodifier" -> "", "metadescription" -> 
    "", "windowtitle" -> "GottesmanStandard", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/GottesmanStandard"}},
