  "08dfdfe9-9a6a-40b2-b847-a1b7abd5bd8d"],
 " performs the Gaussian elimination for a linear equation of the form\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["x", "11"], 
         SubscriptBox["z", "11"], 
         SubscriptBox["x", "12"], 
         SubscriptBox["z", "12"], "\[CenterEllipsis]", 
         SubscriptBox["x", 
          RowBox[{"1", "n"}]], 
         SubscriptBox["z", 
          RowBox[{"1", "n"}]]},
        {
         SubscriptBox["x", "21"], 
         SubscriptBox["z", "21"], 
         SubscriptBox["x", "22"], 
         SubscriptBox["z", "22"], "\[CenterEllipsis]", 
         SubscriptBox["x", 
          RowBox[{"2", "n"}]], 
         SubscriptBox["z", 
          RowBox[{"2", "n"}]]},
        {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
         "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
         "\[VerticalEllipsis]", "\[VerticalEllipsis]"},
        {
         SubscriptBox["x", 
          RowBox[{"m", " ", "1"}]], 
         SubscriptBox["z", 
          RowBox[{"m", " ", "1"}]], 
         SubscriptBox["x", 
          RowBox[{"m", " ", "2"}]], 
         SubscriptBox["z", 
          RowBox[{"m", " ", "2"}]], "\[CenterEllipsis]", 
         SubscriptBox["x", 
          RowBox[{"m", " ", "n"}]], 
         SubscriptBox["z", 
          RowBox[{"m", " ", "n"}]]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["\[Omega]", "11"], 
         SubscriptBox["\[Omega]", "11"], "\[CenterEllipsis]", 
         SubscriptBox["\[Omega]", 
          RowBox[{"1", "p"}]]},
        {
         SubscriptBox["\[Omega]", "21"], 
         SubscriptBox["\[Omega]", "21"], "\[CenterEllipsis]", 
         SubscriptBox["\[Omega]", 
          RowBox[{"2", "p"}]]},
        {
         SubscriptBox["\[Omega]", "31"], 
         SubscriptBox["\[Omega]", "31"], "\[CenterEllipsis]", 
         SubscriptBox["\[Omega]", "31"]},
        {"\[VerticalEllipsis]", "\[VerticalEllipsis]", 
         "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
        {
         SubscriptBox["\[Omega]", 
          RowBox[{"n", " ", "1"}]], 
         SubscriptBox["\[Omega]", 
          RowBox[{"n", " ", "1"}]], "\[CenterEllipsis]", 
         SubscriptBox["\[Omega]", 
          RowBox[{"m", " ", "p"}]]}
       }], ")"}]}], "=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["o", "11"], 
        SubscriptBox["o", "11"], "\[CenterEllipsis]", 
        SubscriptBox["o", 
         RowBox[{"1", "p"}]]},
       {
        SubscriptBox["o", "21"], 
        SubscriptBox["o", "21"], "\[CenterEllipsis]", 
        SubscriptBox["o", 
         RowBox[{"2", "p"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]",
         "\[VerticalEllipsis]"},
       {
        SubscriptBox["o", 
         RowBox[{"m", " ", "1"}]], 
        SubscriptBox["o", 
         RowBox[{"m", " ", "1"}]], "\[CenterEllipsis]", 
        SubscriptBox["o", 
         RowBox[{"m", " ", "p"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "40101391-903e-4e7a-ac34-1a5c07121b9d"],
 "."
}], "Notes",
 CellID->152318947,ExpressionUUID->"7ac22b84-bac0-4b70-8d04-9e5fa5ea7b35"]
