Cell[BoxData[
 RowBox[{"Until", "[", 
  RowBox[{
   RowBox[{"rank", "<", "3"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"mat", "=", 
     RowBox[{"RandomChoice", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"$n", ",", 
         RowBox[{"2", "$n"}]}], "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    
    RowBox[{"xx", "=", 
     RowBox[{"First", "@", 
      RowBox[{"GottesmanSplit", "[", "mat", "]"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"rank", "=", 
     RowBox[{"MatrixRank", "[", 
      RowBox[{"xx", ",", 
       RowBox[{"Modulus", "->", "2"}]}], "]"}]}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
