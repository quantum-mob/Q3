Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "4acbf10c-fa1a-4b43-b1a4-ddeccbfdbf8a"],
 " a binary matrix consisting of rows of ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8bc50097-ad0c-4f46-8f9a-2bed03e46430"],
 " Gottesman vectors for ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8aacab41-24ee-4fa3-a0e8-1e000193c304"],
 " qubits ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{
    StyleBox["m", "TI"], "\[LessEqual]", 
    StyleBox["n", "TI"]}], ")"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f5fc9ea9-603e-4aab-9a64-bac56426bee1"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["x", "11"], 
        SubscriptBox["z", "11"], 
        SubscriptBox["x", "12"], 
        SubscriptBox["z", "12"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"1", "n"}]], 
        SubscriptBox["z", 
         RowBox[{"1", "n"}]]},
       {
        SubscriptBox["x", "21"], 
        SubscriptBox["z", "21"], 
        SubscriptBox["x", "22"], 
        SubscriptBox["z", "22"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"2", "n"}]], 
        SubscriptBox["z", 
         RowBox[{"2", "n"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", "\[VerticalEllipsis]",
         "\[VerticalEllipsis]"},
       {
        SubscriptBox["x", 
         RowBox[{"m", " ", "1"}]], 
        SubscriptBox["z", 
         RowBox[{"m", " ", "1"}]], 
        SubscriptBox["x", 
         RowBox[{"m", " ", "2"}]], 
        SubscriptBox["z", 
         RowBox[{"m", " ", "2"}]], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"m", " ", "n"}]], 
        SubscriptBox["z", 
         RowBox[{"m", " ", "n"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "ea9da937-0440-4eea-84c5-2f32cd553591"],
 ".\[LineSeparator]First, split ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "1d6a6907-339f-4ac8-9741-2b91ce6d24b3"],
 " into the X- and Z-part as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{GridBox[{
       {
        SubscriptBox["x", "11"], 
        SubscriptBox["x", "12"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"1", "n"}]]},
       {
        SubscriptBox["x", "21"], 
        SubscriptBox["x", "22"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"2", "n"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]",
         "\[VerticalEllipsis]"},
       {
        SubscriptBox["x", 
         RowBox[{"m", " ", "1"}]], 
        SubscriptBox["x", 
         RowBox[{"m", " ", "2"}]], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"m", "  ", "n"}]]}
      }], "|", GridBox[{
       {
        SubscriptBox["z", "11"], 
        SubscriptBox["z", "12"], "\[CenterEllipsis]", 
        SubscriptBox["z", 
         RowBox[{"1", "n"}]]},
       {
        SubscriptBox["z", "21"], 
        SubscriptBox["z", "22"], "\[CenterEllipsis]", 
        SubscriptBox["z", 
         RowBox[{"2", "n"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]",
         "\[VerticalEllipsis]"},
       {
        SubscriptBox["z", 
         RowBox[{"m", " ", "1"}]], 
        SubscriptBox["z", 
         RowBox[{"m", " ", "2"}]], "\[CenterEllipsis]", 
        SubscriptBox["z", 
         RowBox[{"m", " ", "n"}]]}
      }]}], ")"}], TraditionalForm]],ExpressionUUID->
  "15583e35-6129-46ae-a406-ca1ceaa7e61f"],
 ".\[LineSeparator]Then, by using Gaussian elimination on rows and \
permutations of qubits (i.e., simultaneous permutation of columns in the X- \
and Z-parts), one can put ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "79268618-2546-4f84-8fa7-c7a0ba5a9df1"],
 " into the standard form with a block structure as follows,\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{GridBox[{
       {
        SubscriptBox["I", 
         RowBox[{"r", "\[Times]", "r"}]], 
        SubsuperscriptBox["A", 
         RowBox[{"r", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}]}], 
         RowBox[{"(", "1", ")"}]], 
        SubsuperscriptBox["A", 
         RowBox[{"r", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m", "+", "s"}], ")"}]}], 
         RowBox[{"(", "2", ")"}]]},
       {
        SubscriptBox["0", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}], "\[Times]", "r"}]], 
        SubscriptBox["0", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}], "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}]}]], 
        SubscriptBox["0", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}], "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m", "+", "s"}], ")"}]}]]},
       {
        SubscriptBox["0", 
         RowBox[{"s", "\[Times]", "r"}]], 
        SubscriptBox["0", 
         RowBox[{"s", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}]}]], 
        SubscriptBox["0", 
         RowBox[{"s", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m", "+", "s"}], ")"}]}]]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}}], "|",
      GridBox[{
       {
        SubscriptBox["B", 
         RowBox[{"r", "\[Times]", "r"}]], 
        SubsuperscriptBox["C", 
         RowBox[{"r", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}]}], 
         RowBox[{"(", "1", ")"}]], 
        SubsuperscriptBox["C", 
         RowBox[{"r", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m", "+", "s"}], ")"}]}], 
         RowBox[{"(", "2", ")"}]]},
       {
        SubsuperscriptBox["D", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}], "\[Times]", "r"}], 
         RowBox[{"(", "1", ")"}]], 
        SubscriptBox["I", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}], "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}]}]], 
        SubscriptBox["E", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}], "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m", "+", "s"}], ")"}]}]]},
       {
        SubsuperscriptBox["D", 
         RowBox[{"s", "\[Times]", "r"}], 
         RowBox[{"(", "2", ")"}]], 
        SubscriptBox["0", 
         RowBox[{"s", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r", "-", "s"}], ")"}]}]], 
        SubscriptBox["0", 
         RowBox[{"s", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m", "+", "s"}], ")"}]}]]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}}]}], 
    ")"}], TraditionalForm]],ExpressionUUID->
  "c2cc47b9-93fa-4332-ba70-563535df0405"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  StyleBox["r", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a2547087-1ce5-4737-b931-79e4ea3cf8c0"],
 " is the rank of the X-part of the matrix. This form is called the ",
 StyleBox["standard form",
  FontSlant->"Italic"],
 " of the Gottesman matrix."
}], "Notes",
 CellID->791055099,ExpressionUUID->"0d5f97f2-6cb2-4603-b82d-23c2c79716d6"],

Cell[TextData[{
 "Usually, a Gottesman matrix describes a generating set of a stabilizer. \
Since the generators must commute with each other, ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["D", 
    RowBox[{"s", "\[Times]", "r"}], 
    RowBox[{"(", "2", ")"}]], TraditionalForm]],ExpressionUUID->
  "901dd488-97e3-4dfd-944f-c80dd8eeaf0d"],
 " must vanish for such a Gottesman matrix, which actually implies that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"s", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "6758e22e-2265-46ef-8ccf-fcdfa24d2422"],
 ". That is, any Gottesman matrix representing a generating set of stabilizer \
can be put in the following form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{GridBox[{
       {
        SubscriptBox["I", 
         RowBox[{"r", "\[Times]", "r"}]], 
        SubsuperscriptBox["A", 
         RowBox[{"r", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}]}], 
         RowBox[{"(", "1", ")"}]], 
        SubsuperscriptBox["A", 
         RowBox[{"r", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m"}], ")"}]}], 
         RowBox[{"(", "2", ")"}]]},
       {
        SubscriptBox["0", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}], "\[Times]", "r"}]], 
        SubscriptBox["0", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}], "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}]}]], 
        SubscriptBox["0", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}], "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m"}], ")"}]}]]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}}], "|",
      GridBox[{
       {
        SubscriptBox["B", 
         RowBox[{"r", "\[Times]", "r"}]], 
        SubsuperscriptBox["C", 
         RowBox[{"r", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}]}], 
         RowBox[{"(", "1", ")"}]], 
        SubsuperscriptBox["C", 
         RowBox[{"r", "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m"}], ")"}]}], 
         RowBox[{"(", "2", ")"}]]},
       {
        SubscriptBox["D", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}], "\[Times]", "r"}]], 
        SubscriptBox["I", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}], "\[Times]", 
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}]}]], 
        SubscriptBox["E", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "r"}], ")"}], "\[Times]", 
          RowBox[{"(", 
           RowBox[{"n", "-", "m"}], ")"}]}]]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}}]}], 
    ")"}], TraditionalForm]],ExpressionUUID->
  "7ff1d276-474f-4b1c-813f-f5d5514a3ea3"],
 "."
}], "Notes",
 CellID->1024541706,ExpressionUUID->"8d3e27e0-e108-4dc0-b0e4-eb7d0fe92696"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["GottesmanStandard"]], 
     "paclet:QuantumMob/Q3/ref/GottesmanStandard", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["mat", "TI"], ",", 
    StyleBox["vec", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3ff6ce86-c6fd-4994-b287-d07b6dc5fb79"],
 " performs the Gaussian elimination for a linear equation of the form\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["x", "11"], 
         SubscriptBox["z", "11"], 
         SubscriptBox["x", "12"], 
         SubscriptBox["z", "12"], "\[CenterEllipsis]", 
         SubscriptBox["x", 
          RowBox[{"1", "n"}]], 
         SubscriptBox["z", 
          RowBox[{"1", "n"}]]},
        {
         SubscriptBox["x", "21"], 
         SubscriptBox["z", "21"], 
         SubscriptBox["x", "22"], 
         SubscriptBox["z", "22"], "\[CenterEllipsis]", 
         SubscriptBox["x", 
          RowBox[{"2", "n"}]], 
         SubscriptBox["z", 
          RowBox[{"2", "n"}]]},
        {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
         "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
         "\[VerticalEllipsis]", "\[VerticalEllipsis]"},
        {
         SubscriptBox["x", 
          RowBox[{"m", " ", "1"}]], 
         SubscriptBox["z", 
          RowBox[{"m", " ", "1"}]], 
         SubscriptBox["x", 
          RowBox[{"m", " ", "2"}]], 
         SubscriptBox["z", 
          RowBox[{"m", " ", "2"}]], "\[CenterEllipsis]", 
         SubscriptBox["x", 
          RowBox[{"m", " ", "n"}]], 
         SubscriptBox["z", 
          RowBox[{"m", " ", "n"}]]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["\[Omega]", "1"]},
        {
         SubscriptBox["\[Omega]", "2"]},
        {
         SubscriptBox["\[Omega]", "3"]},
        {"\[VerticalEllipsis]"},
        {
         SubscriptBox["\[Omega]", "n"]}
       }], ")"}]}], "=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["v", "1"]},
       {
        SubscriptBox["v", "2"]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["v", "m"]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "9c3c73ff-06c2-4987-97ca-07ef4b35d5c4"],
 "."
}], "Notes",
 CellID->158748762,ExpressionUUID->"16a6bd02-6b55-4fea-bc99-ce7afea9ba46"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
