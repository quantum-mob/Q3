Cell["Tunneling over conserved channels", "ExampleText",
 CellID->1791062526,ExpressionUUID->"10ba15ee-dd33-46a1-99cb-9ae1b2b80af6"],

Cell[TextData[{
 "More often than not, some levels (such spin) at different site are \
conserved over the tunneling process. Such levels involving in conserved \
channels can be ",
 StyleBox["grouped",
  FontSlant->"Italic"],
 " by { }."
}], "ExampleText",
 CellID->1109594483,ExpressionUUID->"5ff4767d-3075-4a97-88d8-645c93e72dbb"],

