}, Open  ]],

Cell["Rewrite the ZZ interaction in an operator expression:", "ExampleText",
 CellID->912761031,ExpressionUUID->"bb6a0498-4a0a-4c53-9d52-7b8bcf6d96f4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Elaborate", "[", "op", "]"}], "//", "ExpToTrig"}], "//", 
  "Simplify"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->2025318320,ExpressionUUID->"3e5daa79-cd4f-4908-9fec-2acbeff81d4c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Cos", "[", "\[Phi]", "]"}], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        InterpretationBox[
         TemplateBox[{"S", 
           TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"Z\""}, "RowWithSeparators"]}, 
          "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
         $CellContext`S[1, 3]], 
        InterpretationBox[
         TemplateBox[{"S", 
           TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"Z\""}, "RowWithSeparators"]}, 
          "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
         $CellContext`S[2, 3]]}, "RowWithSeparators"]},
     "RowDefault"],
    QuantumMob`Q3`Multiply[
     $CellContext`S[1, 3], 
     $CellContext`S[2, 3]]], " ", 
   RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}]], "Output",
 CellLabel->"Out[5]=",
 CellID->1256505903,ExpressionUUID->"86375dc9-e8e7-46d6-9f00-de435820a389"]
}, Open  ]],

Cell["Calculate the matrix representation of the ZZ interaction:", \
"ExampleText",
 CellID->776732127,ExpressionUUID->"2d512a7d-83a1-4a40-af61-0ab76393d681"],

