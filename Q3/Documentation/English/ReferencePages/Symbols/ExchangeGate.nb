    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4453d84-4e45-4f44-b9db-696638225149"],
 "."
}], "Notes",
 CellID->669978790,ExpressionUUID->"7e2eac35-b128-421a-8393-bf0770702b60"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7f45afa5-0ae1-48c2-998e-840bf0122014"],
 " is a vector ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["x", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["y", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["z", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d2a90f5d-c357-4a46-93af-2bdc2ad1153a"],
 ", then the coupling between two qubits or spins ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "i"], TraditionalForm]],ExpressionUUID->
  "23987b60-30be-4062-82ec-af02d7d10ece"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "j"], TraditionalForm]],ExpressionUUID->
  "2158a97f-4734-4680-9c5f-5240a7100e2a"],
 " connected by a link gives the Hamiltonian term:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["g", "x"], 
      SubsuperscriptBox["S", "i", "X"], 
      SubsuperscriptBox["S", "j", "X"]}], "+", 
     RowBox[{
      SubscriptBox["g", "y"], 
      SubsuperscriptBox["S", "i", "Y"], 
      SubsuperscriptBox["S", "j", "Y"]}], "+", 
     RowBox[{
      SubscriptBox["g", "z"], 
      SubsuperscriptBox["S", "i", "Z"], 
      SubsuperscriptBox["S", "j", "Z"]}]}]}], TraditionalForm]],
  ExpressionUUID->"4f1959df-b08a-4dc0-8f46-77bccf99ee21"],
 " ."
}], "Notes",
 CellID->115471954,ExpressionUUID->"c137c482-cf51-4bb3-b8a5-beebe96265dc"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "78f4e77c-37da-475f-971e-1536cf3064a0"],
 " is a 3\[Times]3 matrix ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "5a5cb6bf-6635-4286-9018-6b0927951029"],
 ", then the coupling gives the term\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubscriptBox["g", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubsuperscriptBox["S", "i", "\[Mu]"], 
     SubsuperscriptBox["S", "j", "\[Nu]"]}]}], TraditionalForm]],
  ExpressionUUID->"b352f46e-f4b6-4e7d-906e-e133227219fe"],
 " ."
}], "Notes",
 CellID->906834529,ExpressionUUID->"82944478-1333-4a27-94c5-a35cb1e8f3f1"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

