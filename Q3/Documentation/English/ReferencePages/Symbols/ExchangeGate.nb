Cell[TextData[{
 "Consider a unitary gate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "H"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"42051e70-5b21-4845-a65d-cc0ffe62cca5"],
 " for an exchange coupling Hamiltonian ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "ed8a1c31-2563-41c2-998e-6830db88b8bd"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Exchange"]], "paclet:QuantumMob/Q3/ref/Exchange", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "37fb1609-2a39-489c-a204-5789f6944eb6"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ExchangeGate"]], "paclet:QuantumMob/Q3/ref/ExchangeGate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "287dc513-d1a7-4b35-8858-4ed8e5dfea92"],
 " describe ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "2675f870-f83c-429b-93e4-a0b5bd0541bc"],
 " and ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "3616dec4-4ebb-4f2f-a1fc-2e268d0b4855"],
 ", respectively."
}], "Notes",
 CellID->1432115322,ExpressionUUID->"81333642-5a04-4c76-8f36-58383ba5da30"],

Cell[TextData[{
 "For the connectivity of the coupling, see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Chain"]], "paclet:QuantumMob/Q3/ref/Chain", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
