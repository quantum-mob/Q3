Cell["\<\
Let us consider pair-wise ZZ interaction of neighboring qubits:\
\>", "ExampleText",
 CellID->204252008,ExpressionUUID->"50794fde-1b81-4fce-8f33-69845ff2ca71"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MapIndexed", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ExchangeGate", "[", 
        RowBox[{
         RowBox[{"a", "@", 
          RowBox[{"First", "@", "#2"}]}], ",", "#1"}], "]"}], "&"}], ",", 
      RowBox[{"Partition", "[", 
       RowBox[{"SS", ",", "2"}], "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"MapIndexed", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ExchangeGate", "[", 
        RowBox[{
         RowBox[{"a", "@", 
          RowBox[{"First", "@", "#2"}]}], ",", "#1"}], "]"}], "&"}], ",", 
      RowBox[{"Partition", "[", 
       RowBox[{
        RowBox[{"Rest", "@", "SS"}], ",", "2"}], "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->2124868822,ExpressionUUID->"94443bc8-795c-4d55-9895-ed54795ba55f"],

