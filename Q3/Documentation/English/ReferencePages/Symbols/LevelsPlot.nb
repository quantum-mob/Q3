Cell["Define a short-hand tool:", "ExampleText",
 CellID->1705536360,ExpressionUUID->"ce542e52-4022-4c0d-8d3e-69582f577096"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "energy", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"energy", "[", 
    RowBox[{"gv_", ",", "wv_"}], "]"}], ":=", 
   RowBox[{"Block", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"g", "=", "gv"}], ",", 
       RowBox[{"\[CapitalOmega]", "=", "wv"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Sort", "[", "val", "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->702439402,ExpressionUUID->"4bee1125-9438-4a30-abcf-c96f0ba1687b"],

Cell["\<\
Show how the level structure evolves at resonance as the photon-qubit \
coupling increases:\
\>", "ExampleText",
 CellID->1610974523,ExpressionUUID->"9f33ab60-40d2-4309-bea1-f295e1f381a7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"energy", "[", 
      RowBox[{"gv", ",", "1"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"gv", ",", "0", ",", "0.3", ",", "0.05"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"LevelsPlot", "[", 
  RowBox[{"data", ",", "\[IndentingNewLine]", 
   RowBox[{"\"\<DataStyles\>\"", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", "Blue", ",", "Brown"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", "\"\<Energy\>\""}], "}"}]}]}], "]"}]}], "Input",
