Cell["\<\
Construct the Rabi Hamiltonian. Note that the photon-qubit coupling includes \
the so-called counter-rotating terms. Note that the model is not exactly \
solvable (in fact, there exits a exact solution, but is not of simple form).\
\>", "ExampleText",
 CellID->1276888457,ExpressionUUID->"d369bf05-12e9-4c9f-b418-50e66525738f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ham", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Dagger", "[", "c", "]"}], "**", "c"}], "+", 
   RowBox[{"g", "*", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Dagger", "[", "c", "]"}], "+", "c"}], ")"}], "**", 
     RowBox[{"S", "[", "1", "]"}]}]}], "+", 
   RowBox[{
    RowBox[{"S", "[", "3", "]"}], "*", 
