 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"energy", "[", 
      RowBox[{"gv", ",", "1"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"gv", ",", "0", ",", "0.3", ",", "0.05"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"LevelsPlot", "[", 
  RowBox[{"data", ",", "\[IndentingNewLine]", 
   RowBox[{"\"\<DataStyles\>\"", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", "Blue", ",", "Brown"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
