  FormBox[
   RowBox[{
    SubscriptBox["p", "k"], ":=", 
    RowBox[{"Tr", "[", 
     RowBox[{
      SubscriptBox["l", "k"], "\[Rho]", " ", 
      SubsuperscriptBox["l", "k", "\[Dagger]"]}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"cce38ba2-95f6-408e-85e5-0539e20ea13d"],
