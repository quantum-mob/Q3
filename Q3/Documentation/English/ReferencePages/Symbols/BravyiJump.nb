  ExpressionUUID->"401ac1cb-152a-4379-8c00-28a51e548eda"],
 "    with probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "k"], ":=", 
    RowBox[{"Tr", "[", 
     RowBox[{
      SubscriptBox["l", "k"], "\[Rho]", " ", 
      SubsuperscriptBox["l", "k", "\[Dagger]"]}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"af5247c6-dfa5-43ea-a0f1-33a3fa1e0a95"],
