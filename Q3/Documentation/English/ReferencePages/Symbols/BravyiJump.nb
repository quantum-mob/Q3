Cell[TextData[{
 "Convert the measurement to the quantum jump operators describing the \
nonselective measurement process ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "i"], 
      SubscriptBox["p", "i"], "\[Rho]", " ", 
      SubscriptBox["p", "i"]}], "+", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "i"], "(", 
       RowBox[{"1", "-", 
        SubscriptBox["p", "i"]}], ")"}], 
      RowBox[{"\[Rho]", "(", 
       RowBox[{"1", "-", 
        SubscriptBox["p", "i"]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"abb52d8b-c079-4d47-84e7-2f1558fc13b6"],
 " , where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["d", "i", "\[Dagger]"], 
     SubscriptBox["d", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "4bc2bbda-ee1d-4802-82e7-697378f388ed"],
 " are the projection operators and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "i"], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "j"], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "9f6bf956-e062-43d4-b448-8e4fb0ba8e8c"],
 " are the dressed modes:"
}], "ExampleText",
 CellID->1269542183,ExpressionUUID->"b0675646-9fe3-4d91-8d21-438ae80e2e56"],

