Cell[BoxData[{
 RowBox[{
  RowBox[{"cff", "=", 
   RowBox[{
    RowBox[{"One", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], "]"}], "+", 
    RowBox[{"I", "*", 
     RowBox[{"One", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], ",", "1"}], 
      "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cff", "=", 
   RowBox[{"ArrayFlatten", "@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"cff", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "cff"}], "}"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{"NambuMeasurement", "[", "cff", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "=", 
