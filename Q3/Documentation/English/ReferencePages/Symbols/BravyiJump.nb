    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"0", "->", "Identity"}], ",", "\[IndentingNewLine]", 
      RowBox[{"1", "->", "Dagger"}], ",", "\[IndentingNewLine]", 
      RowBox[{"2", "->", 
       RowBox[{"(", 
