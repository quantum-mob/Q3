          RowBox[{"Dagger", "[", "#", "]"}], "**", "#"}], "&"}], ")"}]}], ",",
       "\[IndentingNewLine]", 
      RowBox[{"3", "->", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"#", "**", 
