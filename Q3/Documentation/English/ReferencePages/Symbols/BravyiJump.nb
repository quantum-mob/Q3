Cell[TextData[{
 "Convert the measurement to the quantum jump operators describing the \
nonselective measurement process ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "i"], 
      SubscriptBox["p", "i"], "\[Rho]", " ", 
      SubscriptBox["p", "i"]}], "+", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "i"], "(", 
       RowBox[{"1", "-", 
        SubscriptBox["p", "i"]}], ")"}], 
      RowBox[{"\[Rho]", "(", 
       RowBox[{"1", "-", 
        SubscriptBox["p", "i"]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"8a080d22-5eda-4213-bd09-7265d7720f6f"],
 " , where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["d", "i", "\[Dagger]"], 
     SubscriptBox["d", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "771958bf-65be-40dd-805e-bb3f39f6de51"],
 " are the projection operators and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "i"], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "j"], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "500d3b88-27af-430e-90dd-a0060609a1ef"],
 " are the dressed modes:"
}], "ExampleText",
 CellID->1269542183,ExpressionUUID->"32c96587-8af7-42cb-a9c2-e940e9a9fb01"],

