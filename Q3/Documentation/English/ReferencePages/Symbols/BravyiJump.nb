  RowBox[{"cff", "=", 
   RowBox[{"ArrayFlatten", "@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"cff", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "cff"}], "}"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{"NambuMeasurement", "[", "cff", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "//", "MatrixForm"}], "\[IndentingNewLine]", 
