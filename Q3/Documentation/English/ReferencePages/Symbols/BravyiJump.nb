Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4961b7fc-b5e4-47bf-9078-9ca3443594bf"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "27ce0067-e71b-4abd-8619-061ee07b42f1"],
 " and share the common data format. However, ",
