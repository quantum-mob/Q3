Cell["\<\
Consider a mixture two states, one with pairing correlation and the other \
without pairing correlation:\
\>", "ExampleText",
 CellID->404290162,ExpressionUUID->"2ff80f95-579c-47eb-856c-b4b7ac936c36"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Real", ",", "a"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"psi", "[", "1", "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Dagger", "[", 
        RowBox[{"f", "[", "1", "]"}], "]"}], "**", 
       RowBox[{"Dagger", "[", 
        RowBox[{"f", "[", "2", "]"}], "]"}], "**", 
       RowBox[{"Ket", "[", "]"}]}], "+", 
      RowBox[{"a", "*", 
       RowBox[{"Ket", "[", "]"}]}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", 
     RowBox[{"1", "+", 
      RowBox[{"a", "^", "2"}]}], "]"}]}], "//", "KetRegulate"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"psi", "[", "2", "]"}], "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Dagger", "[", 
      RowBox[{
       RowBox[{"a", "*", 
        RowBox[{"f", "[", "1", "]"}]}], "+", 
       RowBox[{"f", "[", "2", "]"}]}], "]"}], "**", 
     RowBox[{"Ket", "[", "]"}]}], ")"}], "/", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"1", "+", 
     RowBox[{"a", "^", "2"}]}], "]"}]}]}]}], "Input",
