Cell[TextData[{
 "For any Dirac fermion operator ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "bd7d306e-2768-4124-be4a-dbcb1c9884d0"],
 ", the (full) ",
 StyleBox["time reversal transform",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalT]", TraditionalForm]],ExpressionUUID->
  "6efe9db7-3439-4ab9-9bfd-8b36f13f2447"],
 " satisfies\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalT]", "\[VeryThinSpace]", "a", " ", 
     SuperscriptBox["\[ScriptCapitalT]", 
      RowBox[{"-", "1"}]]}], "=", "a"}], TraditionalForm]],ExpressionUUID->
  "88448d5b-c4ad-4162-80e6-6228e6aaaa17"],
 "   and   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalT]", "\[VeryThinSpace]", "\[ImaginaryI]", " ", 
     SuperscriptBox["\[ScriptCapitalT]", 
      RowBox[{"-", "1"}]]}], "=", 
    RowBox[{"-", "\[ImaginaryI]"}]}], TraditionalForm]],ExpressionUUID->
  "0288bad2-41d5-404f-9437-0f3347dbec57"],
 " .\[LineSeparator]It consists of two parts, unitary operation ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "90284479-e13c-4562-8538-1cc783446a17"],
 " and complex conjugation ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalK]", TraditionalForm]],ExpressionUUID->
  "7304760d-15a4-4e74-a566-777f7fa4b926"],
 ", that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"U", "\[VeryThinSpace]", "\[ScriptCapitalK]"}]}], 
   TraditionalForm]],ExpressionUUID->"2302dcb0-ca90-4ff4-a19e-7043dc498839"],
 ". On Majorana operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "19216c6c-1888-49a5-a39e-2f8528f1d412"],
 ", the unitary operator is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     UnderscriptBox["\[CapitalPi]", "k"], 
     SubscriptBox["c", 
      RowBox[{
       RowBox[{"2", "k"}], "-", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "7a5bdaf6-0da6-432b-851e-b0ae5e53b02d"],
 ". "
}], "Notes",
 CellID->1051453506,ExpressionUUID->"00e7d2f1-1a73-4a2c-8951-dc3909b06e75"],

Cell[TextData[{
 "The fermionic partial time reversal transform ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalT]", "A"], TraditionalForm]],ExpressionUUID->
  "23ce2b0b-5f3e-4768-aa34-da54feed726e"],
 " with respect to part ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "40eb1a70-865d-42e1-90d5-6e35870e07a9"],
 " is specified by defining the unitary part as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "A"], ":=", 
    RowBox[{
     UnderscriptBox["\[CapitalPi]", 
      RowBox[{"k", "\[Element]", "A"}]], 
     SubscriptBox["c", 
      RowBox[{
       RowBox[{"2", "k"}], "-", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "dc5a9867-1578-4fb9-8c7a-66fba1f6a9f6"],
 "."
}], "Notes",
 CellID->1020001615,ExpressionUUID->"6351e2f4-0047-48f6-8409-2b7cb82caf77"],

Cell[TextData[{
 StyleBox["N.B.",
  FontWeight->"Bold"],
 " As of Q3 v3.6.6, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FermionTimeReversal"]], 
    "paclet:QuantumMob/Q3/ref/FermionTimeReversal", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8fc5a9c7-2f33-4f63-9af6-7d185ee54329"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[ScriptCapitalT]", "A"], "(", "O", ")"}], ":=", 
    RowBox[{
     SubscriptBox["U", "A"], 
     SuperscriptBox["O", 
      SubscriptBox["T", "A"]], 
     SubsuperscriptBox["U", "A", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"bf55a6ff-a475-44c4-9fd9-4832cdbba710"],
 " (not as above)."
}], "Notes",
 CellID->1889516988,ExpressionUUID->"a77cfe32-360c-4fb5-b864-e9383700e368"]
