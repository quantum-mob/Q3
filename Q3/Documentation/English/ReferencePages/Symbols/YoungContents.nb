Cell[TextData[{
 "A ",
 StyleBox["composition",
  FontSlant->"Italic"],
 " of integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e1c181d3-a92c-4de7-96c4-426b1f0914fc"],
 " is an ordered sequence of nonnegative integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Tau]", "1"], ",", 
      SubscriptBox["\[Tau]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Tau]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"bf093565-0fcf-463a-bf09-30a68940b99c"],
 "\[LineSeparator]such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Tau]", "1"], "+", 
     SubscriptBox["\[Tau]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Tau]", "d"]}], ":=", "n"}], TraditionalForm]],
  ExpressionUUID->"f327d359-7cab-45b9-b76f-e3762b6a9543"],
 ".\[LineSeparator]The integers ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "k"], TraditionalForm]],ExpressionUUID->
  "1e03f2f2-afe0-4dbb-8f2b-9a1eba628389"],
 " are called the ",
 StyleBox["parts",
  FontSlant->"Italic"],
 " of the composition."
}], "Notes",
 CellID->1280405461,ExpressionUUID->"55aa65bd-e27b-4ce7-9756-45ffa8f26cea"],

Cell[TextData[{
 "A ",
 StyleBox["partition",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "65e7dee6-62c5-47a0-9f7e-43eb17e59fb8"],
 " is a ",
 StyleBox["weakly decreasing",
  FontSlant->"Italic"],
 " sequence of nonnegative integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"a3646513-ca84-45ca-9ab7-2149383ca422"],
 "\[LineSeparator]such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"d056baaa-9bf4-4be5-9d0e-2858383dfe02"],
 ". A partition is a composition, but a composition is not necessarily a \
partition."
}], "Notes",
 CellID->1209047982,ExpressionUUID->"2b2d5798-edf7-403f-86d1-0591db8d8307"],

Cell[TextData[{
 "Let ",
