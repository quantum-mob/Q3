Cell["\<\
When you have multiple subsystems of different dimensions, you can specify \
the partition of the subsystems. Here we consider a tensor-product space of \
three subspaces of dimensions 4, 3, and 2, respectively. Here we consider a \
special case where the vector is separable -- a tensor product of three \
vectors.\
\>", "ExampleText",
 CellID->1446658248,ExpressionUUID->"7860dee5-e191-4e4b-9421-d78d01721036"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vec1", "=", 
   RowBox[{"RandomVector", "[", "4", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vec2", "=", 
   RowBox[{"RandomVector", "[", "3", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vec3", "=", 
   RowBox[{"RandomVector", "[", "2", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"vec", "=", 
  RowBox[{"CircleTimes", "[", 
   RowBox[{"vec1", ",", "vec2", ",", "vec3"}], "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->175322802,ExpressionUUID->"2d6ec30e-94d1-41f7-a23a-9e2648b1da10"],

