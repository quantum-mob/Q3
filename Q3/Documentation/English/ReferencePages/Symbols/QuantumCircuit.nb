          $CellContext`S[3, 3]]}, "RowWithSeparators"]},
      "RowDefault"],
     QuantumMob`Q3`Multiply[
      $CellContext`S[1, 3], 
      $CellContext`S[2, 2], 
      $CellContext`S[3, 3]]]}], 
   RowBox[{"2", " ", 
