Cell["\<\
QuantumCircuit accepts almost all options for Graphics. In addition, it \
allows the following additional options.\
\>", "Notes",
 CellID->1067943069,ExpressionUUID->"2e647d64-389c-4f69-b222-03d0c4abf7a4"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "dfc09df2-bb40-4de6-ba23-f9351e4c4c4c"], "\"\<TargetShape\>\"", \
"\"\<Rectangle\>\"", Cell[TextData[{
     "specifies the function to render the gate on target qubits. Possible \
values include ",
     StyleBox["\"Dot\"", "Input"],
     ", ",
     StyleBox["\"Oval\"", "Input"],
     ", ",
     StyleBox["\"CircuitPlus\"", "Input"],
     ", ",
     StyleBox["\"Cross\"", "Input"],
     ", ",
     StyleBox["\"Measurement\"", "Input"],
     ", and ",
     StyleBox["\"Projector\"", "Input"],
     "."
    }], "TableText",ExpressionUUID->"6fb8a99d-efe9-4eea-b749-7dd009c697b1"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "947a7c15-ab74-4169-9139-fbac57db63e6"], "\"\<ControlShape\>\"", \
"\"\<Dot\>\"", Cell["\<\
specifies the function to render the gate on control qubits. It can take all \
values allowed to \"TargetShape\".\
\>", "TableText",ExpressionUUID->"b75a4c48-5ae4-4616-88a4-447105322f0e"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "88984af8-29f3-4fd7-8bfa-b8c251b5a8a3"], "\"\<UnitLength\>\"", "36", 
    Cell["\<\
The length in printer's points (one pp is approximately 1/72 inch) specifying \
the horizontal distance between gates and the vertical distance between qubit \
timelines in the display form.\
\>", "TableText",ExpressionUUID->"3266ea6c-4fd4-4683-be21-322d24ab9a24"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "571bfd3e-0b51-4a4e-a3cc-f9591a680c34"], "\"\<PortSize\>\"", "0.65", 
    Cell[TextData[{
     "The ",
     StyleBox["relative",
      FontSlant->"Italic"],
     " width of the place holders for the input and output ports. A single \
value indicates the same width for both input and output ports. ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{
        StyleBox["in", "TI"], ",", " ", 
        StyleBox["out", "TI"]}], "}"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "031384fb-0f79-4bf1-84b4-6435fc53ebcb"],
     " specifies the widths of the input and output port, respectively."
    }], "TableText",ExpressionUUID->"86f69a82-ca01-4d4e-a22c-a879f66a93ba"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "0a123024-bc1a-44b1-b7e4-fdbe224d5a85"], "\"\<LabelSize\>\"", "1", Cell[
    TextData[{
     "specifies the ",
     StyleBox["relative",
      FontSlant->"Italic"],
     " size of the label text for gates and input and output ports."
    }], "TableText",ExpressionUUID->"4e5d2128-41f5-468f-9c4d-c43289db5380"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "23780d39-be8f-4c1b-9a1b-8cfbff9cc03d"], "\"\<Label\>\"", 
    TemplateBox[{
      Cell[
       TextData["Automatic"]], "paclet:ref/Automatic"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], Cell["\<\
specifies the label text for gates and input and output ports.\
\>", "TableText",ExpressionUUID->"8085837d-337d-4e80-b5d9-ea066d0e0ee4"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "b63bb0f0-f3a2-4bfd-adfb-3e7b714f9db6"], "\"\<Visible\>\"", 
    RowBox[{"{", "}"}], Cell["\<\
specifies additional qubits to be displayed (time lines) even though no gate \
operation is found.\
\>", "TableText",ExpressionUUID->"a7b46caf-b7ae-4f98-bdbe-0ea20cf45133"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "78e27b83-33db-4f15-9888-6db5e2998bf8"], "\"\<Invisible\>\"", 
    RowBox[{"{", "}"}], Cell["\<\
specifies additional qubits that occupy the spaces but not displayed.\
\>", "TableText",ExpressionUUID->"39e0e466-7539-427b-9f99-e0e48cb56339"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "d84c334e-b087-4d33-b695-b018e6780a79"], "\"\<PostMeasurementDashes\>\"",
     "True", Cell["\<\
If True, the qubit lines after measurements are displayed in dashes; \
otherwise, all lines are rendered solid.\
\>", "TableText",ExpressionUUID->"50e7d375-06e9-4af8-b862-9ffa35839879"]}
