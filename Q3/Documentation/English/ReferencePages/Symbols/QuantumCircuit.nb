Cell[TextData[{
 "Consider a slightly different quantum circuit. Now, it has input specified. \
In the following quantum circuit, recall that ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:ref/Ket"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"S", "@", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e2badb52-b9f4-4980-975b-a433a16291e0"],
 " is equivalent to ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["KetRegulate"]], "paclet:QuantumMob/Q3/ref/KetRegulate", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Ket"]], "paclet:ref/Ket"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", "]"}], ",", 
    RowBox[{"S", "@", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cb773e39-034a-49e2-88f1-6335948bd37e"],
 ":"
}], "ExampleText",
 CellID->558449109,ExpressionUUID->"22424f3e-1193-4672-8169-e43941dd1301"],

