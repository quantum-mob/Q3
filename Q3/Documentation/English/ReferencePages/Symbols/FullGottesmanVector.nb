Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"8fe59a0f-9dfa-4da5-bc54-11a32d4673b5"],
 " be the full Pauli group on ",
 StyleBox["n",
  FontSlant->"Italic"],
 " qubits. The center of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"c080ea2f-bb36-4057-935f-69f1bfe56871"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalZ]", ":=", 
    RowBox[{"{", 
     RowBox[{"I", ",", " ", 
      RowBox[{"-", "I"}], ",", " ", 
      RowBox[{"\[ImaginaryI]", " ", "I"}], ",", " ", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "I"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"edc50589-9ad2-4c67-9268-970f1403b649"],
 ". The Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"489d05d4-47d9-45cc-a874-ef2f8217d871"],
 " is defined to be the quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], "/", 
     "\[ScriptCapitalZ]"}]}], TraditionalForm]],ExpressionUUID->
  "68d35516-63a9-42ad-9836-7b8653efa870"],
 ". The Pauli group is isomorphic to the Abelian group ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "c4949f14-d09e-4ffd-b059-54d364470621"],
 ", which can also be regarded as a vector space over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalZ]", "2"], TraditionalForm]],
  ExpressionUUID->"9ea557aa-86c1-4695-b371-f99d574ae30d"],
 "."
}], "Notes",
 CellID->447549871,ExpressionUUID->"408b028f-6542-4e91-8d89-7d59fed941fe"],

Cell[TextData[{
 "A Pauli operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"ae2efaff-52bb-44d1-a19c-b50da439ec42"],
 "\[LineSeparator]is completely specified by the corresponding Gottesman \
vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["x", "1"], ",", 
        SubscriptBox["z", "1"], ",", 
        SubscriptBox["x", "2"], ",", 
        SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["x", "n"], ",", 
        SubscriptBox["z", "n"]}], ")"}], "T"], "\[Element]", 
     SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
      RowBox[{"2", "n"}]]}]}], TraditionalForm]],ExpressionUUID->
  "1db150b7-68d1-400f-a845-78022f926d84"],
 "."
}], "Notes",
 CellID->1183077781,ExpressionUUID->"0ae8434e-02de-473b-9ac7-347aebaef969"],

Cell[TextData[{
 "Sometimes, the vector space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "3c95e86e-6242-475a-8bf4-2d0cb9302d00"],
 " is called the ",
 StyleBox["Gottesman vector space",
  FontSlant->"Italic"],
 " on ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c2c3aee1-7c7b-44b8-bc06-cbf01e539e2e"],
 " qubits to emphasize the aforementioned isomorphism."
}], "Notes",
 CellID->1010290685,ExpressionUUID->"7f2b7d8c-7ddb-4d40-9805-2bcc5142727b"],

Cell[TextData[{
 "A ",
 StyleBox["full Gottesman vector",
  FontSlant->"Italic"],
 " is a tuple of binary digits, two digits for each Pauli operator, plus an \
addition entry with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "a599f06f-3887-4194-a853-0b23f4dceefa"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], TraditionalForm]],
  ExpressionUUID->"4fce0fed-cebb-42a5-8487-46c3925775d4"],
 ". The correspondence between a pair of binary digits and Pauli operators \
are as follows:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}], "\[RightTeeArrow]", "I"}], 
   TraditionalForm]],ExpressionUUID->"0d64acf8-88ab-4a88-b4bd-25d4b33fbda2"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "0"}], "}"}], "\[RightTeeArrow]", "X"}], 
   TraditionalForm]],ExpressionUUID->"fe38b79f-2dcf-4ca6-a407-73d9d150ef82"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", "1"}], "}"}], "\[RightTeeArrow]", "Z"}], 
   TraditionalForm]],ExpressionUUID->"78908201-4f71-479a-9c38-044d176cfb9e"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "1"}], "}"}], "\[RightTeeArrow]", "Y"}], 
   TraditionalForm]],ExpressionUUID->"caf60a72-b9c0-4c88-9deb-34289f12be5b"],
 " (not ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"X", "\[VeryThinSpace]", "Z"}], "\[Congruent]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "Y"}]}], 
   TraditionalForm]],ExpressionUUID->"9d1fed19-31dd-42d8-85ef-6729b3be5f85"],
 ")."
}], "Notes",
 CellID->805863227,ExpressionUUID->"85335e76-cb2b-4f5a-a301-bd5affda7a08"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

