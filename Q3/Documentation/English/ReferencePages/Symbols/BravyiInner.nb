Cell[TextData[{
 "For two Bravyi states \[Rho] and \[Sigma] characterized by Majorana \
covariance matrices ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "\[Rho]"], TraditionalForm]],ExpressionUUID->
  "2c95f5b7-a2d9-4c3a-aafd-d08ddd9582a3"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "\[Sigma]"], TraditionalForm]],ExpressionUUID->
  "b7465932-afc4-4143-bd83-5e93aac8257d"],
 ", the Hilbert-Schmidt product of \[Rho] and \[Sigma] is given by\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"\[Rho]", ",", "\[Sigma]"}], "\[RightAngleBracket]"}], "HS"], ":=", 
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{
       SuperscriptBox["\[Rho]", "\[Dagger]"], "\[Sigma]"}], "]"}], "=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", "n"]], 
      RowBox[{"det", "(", 
       RowBox[{"I", "-", 
        RowBox[{
         SubscriptBox["V", "\[Rho]"], 
         SubscriptBox["V", "\[Sigma]"]}]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"67025556-aeb6-40fa-aaf9-31d63a329841"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "887b2cb3-ff0d-4584-aade-2ee882a48424"],
 " is the number of fermion modes (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "\[Rho]"], TraditionalForm]],ExpressionUUID->
  "c663f2a9-f0d0-4840-bc9a-0a12e1855007"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "\[Sigma]"], TraditionalForm]],ExpressionUUID->
  "627d6a6e-9848-4e88-8630-35c61545e2c2"],
 " are ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "70e8831a-72e3-4240-a8d9-f767b8f18eba"],
 " real anti-symmetric matices)."
}], "Notes",
 CellID->179134543,ExpressionUUID->"3f8269d6-b9b8-4b41-a2cd-b33f60d4474b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

