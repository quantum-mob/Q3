Cell[TextData[{
 "A Wick unitary gate represents the unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "H"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"31a9d6e2-9444-4c7f-adeb-dca0ab41d42d"],
 " for a quadratic Hamiltonian\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubsuperscriptBox["a", "i", "\[Dagger]"], 
     SubscriptBox["h", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["a", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "70b1ecad-ea75-48f0-b9c7-d1cf070998a2"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "2135c2a1-aee0-4af0-b173-e8134db63b4a"],
 " is an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "37509f44-3572-462f-9b81-cc049096a21c"],
 " Hermitian matrix and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "836c80d4-73b3-4813-a77d-d6af9d8f17df"],
 " is the number of fermion modes."
}], "Notes",
 CellID->1429475806,ExpressionUUID->"e5e2471b-7381-4692-b899-a597fe6039ec"],

Cell[TextData[{
 "Note that the unitary gate corresponds to the canonical transform\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubsuperscriptBox["a", "j", "\[Dagger]"], 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "=", "1"}], "n"], 
     SubsuperscriptBox["a", "i", "\[Dagger]"], 
     SubscriptBox["u", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"fa7393e1-8d07-4e77-a4be-666e2fa8f344"],
 " ,\nwhere the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "b7d803e2-cc8b-4c57-95aa-d1d8d18f896d"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["u", TraditionalForm]],ExpressionUUID->
  "2f37902b-a97b-48b2-a3fa-d7fa11b6d7af"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "h"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"b7ca972d-4af3-4de5-abe9-fe475d21c6e9"],
 " ."
}], "Notes",
 CellID->2063552999,ExpressionUUID->"01cf641c-5d80-4de7-801f-81d66bb678bf"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

