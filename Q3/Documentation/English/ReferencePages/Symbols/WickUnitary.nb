Cell[TextData[{
 "A Wick unitary gate represents the unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "H"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"c106aa50-710d-4a51-87cc-d499f6e804aa"],
 " for a quadratic Hamiltonian\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubsuperscriptBox["a", "i", "\[Dagger]"], 
     SubscriptBox["h", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["a", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "24fdd873-89d7-4bc4-ad15-888d7bf49790"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "6ce38b89-2e4e-4e34-9138-8a69bfd3e386"],
 " is an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "f0143415-330e-49d5-8a33-31ab82956d3e"],
 " Hermitian matrix and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "be14889e-08e9-436a-9abf-c54a0ae7b57f"],
 " is the number of fermion modes."
}], "Notes",
 CellID->1429475806,ExpressionUUID->"e8ea7075-3d04-4bcb-a32c-86afa514a164"],

Cell[TextData[{
 "Note that the unitary gate corresponds to the canonical transform\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubsuperscriptBox["a", "j", "\[Dagger]"], 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "=", "1"}], "n"], 
     SubsuperscriptBox["a", "i", "\[Dagger]"], 
     SubscriptBox["u", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"451e361a-7309-412d-8a6c-36f319955ac4"],
 " ,\nwhere the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "4b51cbde-8afa-4500-ad97-2c435c27fb30"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["u", TraditionalForm]],ExpressionUUID->
  "68641d0d-7273-479a-9b5d-da8eedbf1fc1"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "h"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"d966377d-8b70-4205-b3cf-a29afbb0886c"],
 " ."
}], "Notes",
 CellID->2063552999,ExpressionUUID->"3e673455-368f-4dcf-b603-0ceba38869d3"]
}, Closed]],

