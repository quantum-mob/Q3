Cell[TextData[{
 "A ",
 StyleBox[ButtonBox["Young tableau",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungTableaux"],
  FontSlant->"Italic"],
 " of shape \[Lambda] is an array of numbers filling the boxes of the ",
 ButtonBox["Young diagram",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungDiagram"],
 " of shape \[Lambda] (or replacing the dots of the Ferrers diagram)."
}], "Notes",
 CellID->526707167,ExpressionUUID->"321b59aa-35e7-4f97-ae4e-b1240bc22d54"],

Cell[TextData[{
 "A Young tableau is said to be ",
 StyleBox["standard",
  FontSlant->"Italic"],
 " if its entries are all distinct and strictly increase along each row and \
column of the underlying Young diagram."
}], "Notes",
 CellID->208732956,ExpressionUUID->"95e299f9-776c-47e4-b159-c3f0781b2fe4"],

Cell[TextData[{
 "A Young tableau is said to be ",
 StyleBox["semi-standard",
  FontSlant->"Italic"],
 " if its entries weakly increase along each row and strictly increase along \
each column. In semi-standard Young tableaux duplicate entries are allowed. \
Semi-standard Young tableaux are also called Weyl tableaux."
}], "Notes",
 CellID->1665931480,ExpressionUUID->"3c96f160-5aa2-4624-9b73-683ecc7c4c94"],

Cell[TextData[{
 "There is a one-to-one correspondence between ",
 StyleBox[ButtonBox["Gelfand patterns",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandPatterns"],
  FontSlant->"Italic"],
 " of order ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "73ba92d0-e4dd-4eb5-a03c-0d2038240000"],
 " and Weyl tableaux (semi-standard Young tableaux) of ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bd9c91ab-716d-4866-a435-7e53f3c77539"],
 " letters."
}], "Notes",
 CellID->649833363,ExpressionUUID->"f306e3be-93f0-4a0f-b2f5-e29ad5e403f4"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

