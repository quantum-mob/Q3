Cell[TextData[{
 "The Kostka numbers count ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["semistandard tableaux"]], 
    "https://en.wikipedia.org/wiki/Young_tableau#Tableaux"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "6b9864b4-7bbb-495a-a631-b16ae17dffbe"],
 " also known as ",
 StyleBox["Weyl tableaux",
  FontSlant->"Italic"],
 " (Sagan, 2001), and gives the multiplicities of ",
 StyleBox["Specht modules",
  FontSlant->"Italic"],
 " in ",
 StyleBox["permutation modules",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->888780933,ExpressionUUID->"263be7e2-bc9e-4c49-a143-2518dace4ccc"],

Cell[TextData[{
 "Let \[Lambda] be a ",
 StyleBox["partition",
  FontSlant->"Italic"],
 " of integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "714e21bb-6315-495f-9d58-52ac47bfc313"],
 ", and let \[Mu] be a ",
 StyleBox["composition",
  FontSlant->"Italic"],
 " (not necessarily a partition) of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "4f3fe9be-2486-4de1-9e11-d0dd96465c90"],
 ". The Kostka number ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"c7516c63-33e1-4308-bf02-391f95a08391"],
 " is the number of Weyl tableaux (or ",
 ButtonBox["semistandard tableaux",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Young_tableau#Tableaux"], None}],
 ") of ",
 ButtonBox["shape",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungShape"],
 " \[Lambda] and ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " (or type or weight) \[Mu]. "
}], "Notes",
 CellID->1330129050,ExpressionUUID->"73c071b5-cdb6-44a2-bd83-48b73c322525"],

Cell[TextData[{
 "According to ",
 StyleBox["Young's rule",
  FontSlant->"Italic"],
 " (Theorem 2.11.2 in Sagan, 2001), the Kostka number ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"92f7a911-5e74-4cc6-83b8-6806720f2706"],
 " gives the multiplicity of the Specht module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"0c721da0-62e6-4751-83a7-c6cbd4f67023"],
 " of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "edda983e-0248-4ee1-b64c-92b163bf84e9"],
 " in permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["M", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "4c5282bf-2722-4543-882c-1f54159c4130"],
 " of content ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "6abcb8d8-e37b-4dfb-bd22-3ec99b5448ea"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "\[TildeEqual]", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], 
      SubscriptBox["K", 
       RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"cbff8235-8672-40c0-b0e1-7eacb10096c9"],
 "\[LineSeparator]where the direct sum ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CirclePlus]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"469fac23-0026-45af-9d4b-1ed9f61d3a5f"],
 " is over all partitions ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "93712f68-13d9-457d-b8f1-3f7f11f3009e"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "51ccaae0-223a-4d62-b37b-7219a363e09e"],
 " that dominate ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "9434e22b-fe86-4016-90bd-cdad9991aa7f"],
 "."
}], "Notes",
 CellID->706612960,ExpressionUUID->"aaa417d7-3529-4189-8011-da07e9c35186"],

Cell[TextData[{
 "A simple but important property of Kostka numbers is that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"ad096219-2207-4746-8ef7-b830e52cd8d2"],
 " does not depend on the order of entries in \[Mu]. That is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["K", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], "=", 
    SubscriptBox["K", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Nu]"}]]}], TraditionalForm]],
  ExpressionUUID->"d35a3577-1e88-4ff4-9e47-a01370c4e494"],
 " for all compositions \[Mu] and \[Nu] with the same set of parts (only \
rearranged) and for any partition \[Lambda]. For example, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["K",
     FontSlant->"Italic"], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"3", ",", "2"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"1", ",", "1", ",", "2", ",", "1"}], ")"}]}]], "=", 
   SubscriptBox[
    StyleBox["K",
     FontSlant->"Italic"], 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"3", ",", "2"}], ")"}], 
     RowBox[{"(", 
      RowBox[{"2", ",", "1", ",", "1", ",", "1"}], ")"}]}]]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1b2630d2-c329-4d51-9bfe-7b910d0b2523"],
 "."
}], "Notes",
 CellID->2082045252,ExpressionUUID->"71017e9b-5f2d-4b4e-9ed3-c05fe3445d56"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["KostkaNumber"]], "paclet:QuantumMob/Q3/ref/KostkaNumber", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "827c098b-115f-4ea2-9d40-f8196f15a977"],
 " returns a matrix of Kostka numbers ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"5f415741-1dd8-4050-9a78-a42b3f2f7ccd"],
 " for all ",
 StyleBox["partitions",
  FontSlant->"Italic"],
 " \[Lambda] and \[Mu] of ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "58358511-a9b8-4d57-84e1-241fe3974311"],
 ". To get Kostka numbers ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"11b1dbff-5d7b-466e-8241-a70129f61f16"],
 " for non-partition contents \[Mu], simply sort \[Mu] into a weakly \
decreasing sequence."
}], "Notes",
 CellID->27997701,ExpressionUUID->"7b602a13-7bc9-48c6-83a0-4aeb0c197603"],

Cell[TextData[{
 ButtonBox["Kostka number",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/KostkaNumber"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["K", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], "\[NotEqual]", 
    "0"}], TraditionalForm]],ExpressionUUID->
  "926d3e29-8bb1-4b6f-9260-3093e4a52d77"],
 " if and only if \[Lambda] ",
 ButtonBox["dominates",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/DominatesQ"],
 " \[Mu]."
}], "Notes",
 CellID->1604389667,ExpressionUUID->"99b3b7e3-336e-4b6f-91ce-96cc0d61a696"],

Cell[TextData[{
 "Diagonal Kostka number ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["K", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Lambda]"}]], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"3b377ced-2472-4f39-abba-c04cb6002a98"],
 " for any partition ",
 Cell[BoxData[
