Cell[TextData[{
 "Conjugacy classes in the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "56a05fa1-3132-4b4c-a3ea-2a716345f026"],
 " are uniquely determined by cycle decomposition type of permutations, i.e. \
by the lengths of the disjoint cycles composing them, thus by a list of \
integers adding up to ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "d6971360-372c-4b40-bb26-73f6f1a09fcb"],
 ". Such a list of integers, conventionally listed in decreasing order, is \
called a partition of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "c678d8e9-a2c9-4442-bc22-e492dfe663e1"],
 ". Hence conjugacy classes of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "e7acfbbb-c128-4248-87b0-6289e376f36a"],
 " are in one to one correspondence to the partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "54ced5cc-6495-4b50-873b-bc154c5333f2"],
 "."
}], "Notes",
 CellID->50852389,ExpressionUUID->"0d2c757e-aff6-47e6-8de5-c5fac0eca42e"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

