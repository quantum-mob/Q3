Cell[TextData[{
 "The displacement operator for a boson or fermion mode ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]],ExpressionUUID->
  "82820d08-8f11-4095-ba77-fada1b05bad2"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"D", "(", "\[Xi]", ")"}], ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["c", "\[Dagger]"], "\[Xi]"}], "-", 
      RowBox[{
       SuperscriptBox["\[Xi]", "*"], "c"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"b410d0ee-1b29-4ad0-83eb-7d9ff9f72858"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"D", "(", "\[Xi]", ")"}], "c", " ", 
     RowBox[{
      SuperscriptBox["D", "\[Dagger]"], "(", "\[Xi]", ")"}]}], "=", 
    RowBox[{"c", "-", "\[Xi]"}]}], TraditionalForm]],ExpressionUUID->
  "1036afc8-6954-4758-82ab-2b9a48f94767"],
 " .\[LineSeparator]Here, the variable \[Xi] is a complex or Grassmann number \
for boson or fermion mode ",
 Cell[BoxData[
  StyleBox["c", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cde64b47-fc81-474b-afd6-9a054309360e"],
 ", respectively."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"aaae97a0-d668-4b0d-970d-407fcc4f4f4f"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

