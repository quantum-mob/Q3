Cell[TextData[{
 "For an open quantum system, the effective Hamiltonian ",
 StyleBox["H",
  FontSlant->"Italic"],
 " and the effective damping operator ",
 StyleBox["G",
  FontSlant->"Italic"],
 " form the non-Hermitian Hamiltonian, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["H",
     FontSlant->"Italic"], "non"], ":=", 
   RowBox[{
    StyleBox["H",
     FontSlant->"Italic"], "-", 
    StyleBox[
     RowBox[{"\[ImaginaryI]", 
      StyleBox["G",
       FontSlant->"Italic"]}]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aa549147-d8f8-4b5d-be86-a19d384782b4"],
 ", which physically describes the irreversible population loss."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"0abf0459-b54a-4ce5-8783-77d53369f2d4"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

