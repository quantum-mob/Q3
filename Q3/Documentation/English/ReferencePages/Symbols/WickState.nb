Cell[TextData[{
 "A Wick state represents a fermionic Gaussian pure state of the form\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[CapitalPi]", 
      RowBox[{"j", "=", "1"}], "n"], "(", 
     RowBox[{
      SubsuperscriptBox["\[CapitalSigma]", 
       RowBox[{"i", "=", "1"}], "m"], 
      SubsuperscriptBox["c", "i", "\[Dagger]"], 
      SubsuperscriptBox["U", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Dagger]"]}], ")"}], 
    TemplateBox[{"\[SpaceIndicator]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "1875652c-6d83-4910-a340-ffb1a611ee2a"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[SpaceIndicator]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ac65d0c5-98d4-455e-b51e-0ad42d5636a3"],
 " denotes the vacuum state, ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "0f73d098-b5e0-402f-ae0b-e43ff9bb5837"],
 " is the number of fermion modes, ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "165530a2-2f38-432c-8e8e-1ed0f66151a0"],
 " is the number of particles. The ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "m"}], TraditionalForm]],ExpressionUUID->
  "35103d5f-d867-4816-8495-e150bc831218"],
 " matrix ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "e9d1f6a1-abd1-44b0-b4f9-130b780427ce"],
 " is isometric, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "\[VeryThinSpace]", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    SubscriptBox["I", "n"]}], TraditionalForm]],ExpressionUUID->
  "2aa9f028-304a-48a6-bd46-1f502599c0d4"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["U", "\[Dagger]"], "U"}], "\[NotEqual]", 
    SubscriptBox["I", "m"]}], TraditionalForm]],ExpressionUUID->
  "7b349a33-e98e-4017-ba5e-8a13f86f8b77"],
 " in general."
}], "Notes",
 CellID->4290819,ExpressionUUID->"a876b635-64c3-4f9d-ba7b-cc3b44cf8aa4"],

Cell[TextData[{
 "The operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], "m"], 
     SubscriptBox["U", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "0c00d455-3eda-48d8-b184-7afccde9fc74"],
 " are associated with dressed fermion modes, and satisfy the commutation \
relations\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["d", "i"], ",", 
      SubsuperscriptBox["d", "j", "\[Dagger]"]}], "}"}], "=", 
    SubscriptBox["\[Delta]", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], TraditionalForm]],
  ExpressionUUID->"84822284-d111-4bca-b872-ca82f20827f2"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["d", "i"], ",", 
      SubscriptBox["d", "j"]}], "}"}], "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubsuperscriptBox["d", "i", "\[Dagger]"], ",", 
       SubsuperscriptBox["d", "j", "\[Dagger]"]}], "}"}], "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"558eb17f-52a0-4bdf-a400-ee51e7340409"],
 "."
}], "Notes",
 CellID->1334406494,ExpressionUUID->"15094850-56f7-4164-ac75-d294e7328fec"],

Cell[TextData[{
 "For general fermionic Gaussian pure states (with pairing correlation), see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e7e1b99c-4543-4409-8280-86d5d7f5a107"],
 "."
}], "Notes",
 CellID->2075823871,ExpressionUUID->"2ec69408-6898-4443-835b-03e24700679f"],

Cell[TextData[{
 "Since Q3 v4.5.14, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WickState"]], "paclet:QuantumMob/Q3/ref/WickState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "91fa12a1-531e-42e7-ab9f-411b513c0764"],
 " carries the global phase and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["WickState"]], "paclet:QuantumMob/Q3/ref/WickState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e8eead4f-b94d-454d-81be-a77c22d2c12e"],
 "  returns the native vector without canonicalization."
}], "Notes",
 CellID->1153194490,ExpressionUUID->"b19a8d75-04d6-4c84-a177-6bc24c1b5e95"]
}, Closed]],

