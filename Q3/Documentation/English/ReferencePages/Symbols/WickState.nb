Cell[TextData[{
 "A Wick state represents a fermionic Gaussian pure state of the form\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[CapitalPi]", 
      RowBox[{"j", "=", "1"}], "n"], "(", 
     RowBox[{
      SubsuperscriptBox["\[CapitalSigma]", 
       RowBox[{"i", "=", "1"}], "m"], 
      SubsuperscriptBox["c", "i", "\[Dagger]"], 
      SubsuperscriptBox["U", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Dagger]"]}], ")"}], 
    TemplateBox[{"\[SpaceIndicator]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "957d73cc-e449-4a68-bf39-295ac32ad613"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[SpaceIndicator]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "9b52b2ce-0ff5-4536-b871-e790895baae8"],
 " denotes the vacuum state, ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "afc14faa-7064-4add-81e5-f43a7d1009de"],
 " is the number of fermion modes, ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "8b83c3c4-e528-44de-9855-b273dd933a08"],
 " is the number of particles. The ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "m"}], TraditionalForm]],ExpressionUUID->
  "5c12f9bb-7b35-455b-ba58-48be0a81f296"],
 " matrix ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "47336811-4bdd-4768-b9e2-1a1d4f42bcc7"],
 " is isometric, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "\[VeryThinSpace]", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    SubscriptBox["I", "n"]}], TraditionalForm]],ExpressionUUID->
  "f6feb1cf-eaef-4f46-9eb2-70d76b82d7bc"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["U", "\[Dagger]"], "U"}], "\[NotEqual]", 
    SubscriptBox["I", "m"]}], TraditionalForm]],ExpressionUUID->
  "38baf2df-72f3-4c4b-b9f7-41364257d0dc"],
 " in general."
}], "Notes",
 CellID->4290819,ExpressionUUID->"ec10ae47-830c-485a-95e7-8a72cd8d6264"],

Cell[TextData[{
 "The operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], "m"], 
     SubscriptBox["U", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "c3e60072-4624-4417-af69-349ce9cd3039"],
 " are associated with dressed fermion modes, and satisfy the commutation \
relations\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["d", "i"], ",", 
