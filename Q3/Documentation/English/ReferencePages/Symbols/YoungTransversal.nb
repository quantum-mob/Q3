Cell[TextData[{
 "The transversal consists of the distinguished (minimal-length) left coset \
representatives of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalS]", "n"], "/", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}], TraditionalForm]],
  ExpressionUUID->"f810f2ef-aeb4-4dc0-99b0-a884ac106463"],
 ", equivalently the shuffles of ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "930ee3cf-1543-4efd-a547-3d11242d7be4"],
 " sorted sequences of lengths ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Mu]", "TR"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["\[Mu]", "TR"], 
    StyleBox["2", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"], ",", 
   SubscriptBox[
    StyleBox["\[Mu]", "TR"], 
    StyleBox["d", "TI"]]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9ea05d8d-917e-4518-876e-66c4a2db5700"],
 "."
}], "Notes",
 CellID->227406045,ExpressionUUID->"b93784ea-2e4b-429c-a38c-9282ddaf246b"],

Cell[TextData[{
 "Each element is returned as a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Cycles"]], "paclet:ref/Cycles"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "71b7e8a4-5a1b-44d4-b5ec-fc45418e5864"],
 " object. The number of elements equals the multinomial coefficient\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", GridBox[{
       {"n"},
       {
        RowBox[{
         SubscriptBox["\[Mu]", "1"], 
         SubscriptBox["\[Mu]", "2"], 
         SubscriptBox["\[Ellipsis]\[Mu]", "d"]}]}
      }], ")"}], "=", 
    FractionBox[
     RowBox[{"n", "!"}], 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "!"}], 
        RowBox[{
         SubscriptBox["\[Mu]", "2"], "!"}]}], "..."}], 
      RowBox[{
       SubscriptBox["\[Mu]", "d"], "!"}]}]]}], TraditionalForm]],
  ExpressionUUID->"6ca83fa3-a571-4c6b-a6eb-324ba6e38ae2"],
 "."
}], "Notes",
 CellID->1145237895,ExpressionUUID->"6b02e458-2402-4c52-9bca-875c3aa140da"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

