Cell["\<\
A Choi matrix returns a forth-rank tensor, but is typically called a 'matrix' \
regarding the first two and last two indexes as collective indices.\
\>", "Notes",
 CellID->1067943069,ExpressionUUID->"a9b0427e-0ad8-413a-9ee2-c53ccae99b83"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

