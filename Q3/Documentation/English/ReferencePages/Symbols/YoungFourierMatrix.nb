Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"2ae9ecd5-52b8-4256-bc2c-0e89be913f41"],
 " is the ",
 StyleBox["right regular basis",
  FontSlant->"Italic"],
 " of group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "c76ef964-7fe7-4dbd-82ea-ec1f686dbda1"],
 ", i.e.,  the canonical basis of the vector space that carries the ",
 StyleBox["right regular representation",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "5b94c4ab-3656-4245-929d-e46c50825d6c"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "139c6bf2-9306-4323-a45f-c20266c4949c"],
 ". For all elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "7b158e24-b107-4252-a9b9-fadd4a639104"],
 " and ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "366134fd-835f-4268-97a4-f4cd995f67b7"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "ef2acfc5-2960-4764-9aa3-b5c1c68d5fc5"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"h", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "dedf7f71-499a-4648-8dd0-e4280cabf9f2"],
 " ."
}], "Notes",
 CellID->1048209744,ExpressionUUID->"5415fc25-ce85-4211-8a8c-61c9b2173bd9"],

Cell[TextData[{
 "The ",
 StyleBox["right Fourier basis",
  FontSlant->"Italic"],
 " consists of vectors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3cb7bf45-f309-49fc-8ab0-840bb1aa8f11"],
 " defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]], 
     TemplateBox[{"g"},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c3272410-3f60-4eea-be82-5360ee992369"],
 "\[LineSeparator]for each irreducible representation  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"a333c303-2d88-4345-bd88-80761582d68d"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "ab94195a-f58d-4af2-a3d8-d65c8d3c3251"],
 " and each index ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ",", 
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "dd1298b7-b66f-4295-b768-cc2ec643ffb9"],
 ". The basis change from the canonical to Fourier basis is called the ",
 StyleBox["quantum Fourier transform over group",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "a33d88ab-6572-4c7d-8b2f-0e80daa0b776"],
 " or simply the ",
 StyleBox["generalized quantum Fourier transform",
  FontSlant->"Italic"],
 ". The inverse transform gives\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"g"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "=", "1"}]}], 
      SubscriptBox["d", "\[Lambda]"]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], " ", 
     SuperscriptBox[
      RowBox[{
       SqrtBox[
        FractionBox[
         SubscriptBox["d", "\[Lambda]"], 
         RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
        ")"}], "]"}], "*"]}]}], TraditionalForm]],ExpressionUUID->
  "60ef2ae0-8a08-44c3-bd64-a69ae6c7920f"],
 " ,\nwhere the first summation is over all inequivalent irreducible \
representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "d0e6b969-c2bc-45c6-b112-4a3cde2cf6d3"],
 ". Note that the dimension of an irreducible representation ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "eefff372-54a4-4f8f-b6d1-c50c49d2da25"],
 " of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "00264980-5eb8-4296-9706-7e4b751bb276"],
 " always divides the order of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "665ddfb8-d984-4f82-b18c-d847a45921c0"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
     "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], "/", 
     RowBox[{"dim", "(", "\[Lambda]", ")"}]}], "\[Element]", 
    "\[DoubleStruckCapitalZ]"}], TraditionalForm]],ExpressionUUID->
  "2cd99650-a521-4771-8c65-e842edcb4884"],
 "."
}], "Notes",
 CellID->1790577104,ExpressionUUID->"7d78177b-5adf-4f51-9919-7fe1d73e49ad"],

Cell[TextData[{
 "Under the group action, the Fourier basis transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "1705932a-d7c3-4713-b89d-5d863ff44fae"],
 "\[LineSeparator]with index ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "00a980d9-893f-4916-99d1-6eaceee2b26d"],
 " labeling the multiplicity space. Note that every basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "30372d50-e881-4c4a-9e38-a05ee8bfbb57"],
 " transforms in the same way regardless of index ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0b85b05d-c220-404f-9e7c-d4ed299a1b2a"],
 ". That is to say, in the Fourier basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "c17245c4-7e8b-419d-82a9-be952d18f569"],
 ", the right regular representation ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "43473973-af24-4dea-bb74-10909f9e4049"],
 " is block-diagonal in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "g", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], "\[VeryThinSpace]", 
     RowBox[{
      SubscriptBox["I", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"4339ef71-9d7b-4964-8a64-5366e17fd4ff"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "a31d785f-1e12-40bc-a249-e4d6b6d496d0"],
 " refers to the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "\[Lambda]"], "\[Times]", 
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "d90315c6-02be-4046-8678-251986554ae9"],
 " identity matrix in the multiplicity space."
}], "Notes",
 CellID->882427163,ExpressionUUID->"f84a369b-d19d-4126-8872-c08aa4ab832b"],

Cell[TextData[{
 "Setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FourierParameters"]], "paclet:ref/FourierParameters"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{"\"\<Right\>\"", ",", " ", "\"\<Right\>\""}], "}"}]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f6f4023e-f74f-4ed3-9274-d47f5988f727"],
 " (default) implements the above type of generalized quantum Fourier \
transform. The first ",
 Cell[BoxData["\"\<Right\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d59e24e2-ed27-45fb-9583-d1ad46d36c11"],
 " refers to the right regular representation and the second ",
 Cell[BoxData["\"\<Right\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9a39703e-88d5-4b56-9368-1a5c1ae97f11"],
 " indicates that the irreducible space is to the right of the multiplicity \
space."
}], "Notes",
 CellID->1151071605,ExpressionUUID->"dfc5bb04-c11e-4aed-b6fa-bef42674c438"],

Cell[TextData[{
 "If the ",
 StyleBox["left regular representation",
  FontSlant->"Italic"],
 " is concerned, the canonical basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"13cc68ad-0a52-42b5-bab9-1648187c77ab"],
 " transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"g", "\[VeryThinSpace]", "h"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "b2bd956e-a3b9-40b1-bc8d-998e87caf656"],
 " .\[LineSeparator]In this case, the ",
 StyleBox["left Fourier basis",
  FontSlant->"Italic"],
 " vectors are defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]], 
     TemplateBox[{"g"},
      "Ket"], 
     SubscriptBox[
      RowBox[{
       SqrtBox[
        FractionBox[
         SubscriptBox["d", "\[Lambda]"], 
         RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], "[", 
       RowBox[{
        SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]], ")"}], "]"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"aba81f79-65f8-4f06-ba8e-c88300ffd00c"],
 " .\[LineSeparator]Here, notice the input argument  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "63117fa3-aeef-4956-96af-5770ad9adddc"],
 " of matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SuperscriptBox["g", 
     RowBox[{"-", "1"}]], ")"}], TraditionalForm]],ExpressionUUID->
  "3f39cf75-7a41-48fe-9eea-96a7629e4f8a"],
 ". The inverse transform is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"g"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"j", "\[VeryThinSpace]", "i"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "b2853f55-0f5d-42f8-86d9-dbfd36cb246a"],
 " .\[LineSeparator]Here, notice the reversed indices in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalGamma]", 
     RowBox[{"j", "\[VeryThinSpace]", "i"}], "\[Lambda]"], "(", "g", ")"}], 
   TraditionalForm]],ExpressionUUID->"526a9822-e845-4f12-a909-3a7d3ffce0a3"],
 ". Under the group action, the left Fourier basis transforms as\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "50c950e4-2c97-4df1-8f59-69bfa88a4a2f"],
 "\[LineSeparator]and hence, in the left Fourier basis,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"L", "(", "g", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], "\[VeryThinSpace]", 
     RowBox[{
      SubscriptBox["I", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"f5bb2c6d-87ce-40bf-ba6e-189c8ff17283"],
 " ."
}], "Notes",
 CellID->519159934,ExpressionUUID->"54f1be8c-7aa1-4a6a-8bc4-66548f9a629c"],

Cell[TextData[{
 "When ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "c57b03d9-09f1-42f5-bbd3-e47d519d89dd"],
 " is the ",
 StyleBox["symmetric group",
  FontSlant->"Italic"],
 ", we call the regular basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{"g"},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "0fd6bdec-a682-4a59-b0dc-57e7d2734461"],
 " the ",
 StyleBox["Young regular basis",
  FontSlant->"Italic"],
 " and the Fourier basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "0153b779-0dd3-4ca2-b4aa-a6e84951f997"],
 " the ",
 StyleBox["Young-Fourier basis",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1744323879,ExpressionUUID->"c176750d-ea51-45de-aabe-f8b2b6c5fde0"],

Cell[TextData[{
 "Setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FourierParameters"]], "paclet:ref/FourierParameters"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{"\"\<Left\>\"", ",", " ", "\"\<Right\>\""}], "}"}]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "93e77ccf-c276-4232-b36e-e82245e4beb7"],
 " implements the above type of generalized quantum Fourier transform."
}], "Notes",
 CellID->935160286,ExpressionUUID->"59e634f3-092b-4fa7-92fe-ae47b467d2da"],

