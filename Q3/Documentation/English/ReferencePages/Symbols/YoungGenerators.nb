Cell[TextData[{
 "A ",
 StyleBox["composition",
  FontSlant->"Italic"],
 " of integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "6ecc21a1-cc53-4b96-bd02-3aa7fa402c32"],
 " is an ordered sequence of nonnegative integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Tau]", "1"], ",", 
      SubscriptBox["\[Tau]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Tau]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"b30b1c8f-f09f-4227-8456-61b2882521d2"],
 "\[LineSeparator]such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Tau]", "1"], "+", 
     SubscriptBox["\[Tau]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Tau]", "d"]}], ":=", "n"}], TraditionalForm]],
  ExpressionUUID->"d05a4a1b-25ab-4a70-b285-16cfc85a7008"],
 ".\[LineSeparator]The integers ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "k"], TraditionalForm]],ExpressionUUID->
  "b1c9aae4-1673-4804-96eb-c014dcdaa927"],
 " are called the ",
 StyleBox["parts",
  FontSlant->"Italic"],
 " of the composition."
}], "Notes",
 CellID->1280405461,ExpressionUUID->"34785cee-4f0b-48ec-b71b-4205673d03c5"],

Cell[TextData[{
 "A ",
 StyleBox["partition",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "47cbac7b-0c43-4216-b8f9-dcd36a714452"],
 " is a ",
 StyleBox["weakly decreasing",
  FontSlant->"Italic"],
 " sequence of nonnegative integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"389353a3-6977-4c59-bd6b-13bc7f0337bf"],
 "\[LineSeparator]such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"256c497a-2d78-4eda-a413-1bf02b199095"],
 ". A partition is a composition, but a composition is not necessarily a \
partition."
}], "Notes",
 CellID->1209047982,ExpressionUUID->"62d22b6d-b148-4d3a-afcf-cec9158b6383"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["i", "1"], ",", 
      SubscriptBox["i", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["i", "n"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "4f4b8fac-eb58-409d-b2b7-498d481b4044"],
 " be an ",
