  "04370ecc-1df5-4d19-abba-b50f0cf3872e"],
 ". The sequence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Tau]", "1"], ",", 
      RowBox[{
       SubscriptBox["\[Tau]", 
