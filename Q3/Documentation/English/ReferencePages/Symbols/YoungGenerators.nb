  FormBox[
   SubscriptBox["\[Tau]", "k"], TraditionalForm]],ExpressionUUID->
  "e8dbbdbe-6a73-4ea6-9c40-afa55e288b45"],
 " gives the number of times that letter ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[Element]", 
    RowBox[{"[", "d", "]"}]}], TraditionalForm]],ExpressionUUID->
  "a889383f-4626-4887-bc3a-ebb4f8e52c87"],
 " appears in the tuple ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "f32aad49-add1-4863-ab5c-4f8902acf3b5"],
 " is called the ",
 StyleBox["content",
  FontSlant->"Italic"],
 " or ",
 StyleBox["type",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "64271239-50e1-4d78-804d-b6b1ae176c45"],
 ". The content of any ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "89a6bb04-2047-4c30-820e-0ad28a6e3d5e"],
