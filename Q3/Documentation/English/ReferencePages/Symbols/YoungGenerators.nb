  "609935a3-9fcb-4fdc-8044-a78792a8f124"],
 ", in a Gelfand-pattern list ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox[
        RowBox[{
         StyleBox["d", "TI"], 
         StyleBox["1", "TR"]}],
        ZeroWidthTimes->True]], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox[
        RowBox[{
         StyleBox["d", "TI"], 
         StyleBox["2", "TR"]}],
        ZeroWidthTimes->True]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["dd", "TI"]]}], "}"}], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["21", "TR"]], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["22", "TR"]]}], "}"}], ",", 
