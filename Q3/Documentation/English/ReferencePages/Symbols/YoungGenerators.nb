  FormBox["n", TraditionalForm]],ExpressionUUID->
  "5f2c34f7-ff97-41db-80e7-7c4ffd193cd8"],
 "-tuple of ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "9969322a-dc7b-47f4-a609-f445fe33bc21"],
 " letters, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
