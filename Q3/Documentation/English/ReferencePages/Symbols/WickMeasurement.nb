  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "511b0e77-f149-436c-9b3c-da8e7f6a4732"],
 " separately. It does ",
 StyleBox["not",
  FontSlant->"Italic"],
