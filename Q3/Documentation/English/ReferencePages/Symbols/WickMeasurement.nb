Cell["\<\
Let us now verify the above result by means of conventional method. Set the \
bare fermion modes:\
\>", "ExampleText",
 CellID->1940098992,ExpressionUUID->"1401b31c-3fff-43cb-b366-f3eea4c69452"],

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Fermion", ",", "c"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"cc", "=", 
  RowBox[{"c", "[", 
   RowBox[{"Range", "@", "$n"}], "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->1654242487,ExpressionUUID->"1a0a7a25-0501-4a37-b6f7-289580655bcc"],

Cell["Construct the dressed modes to measure:", "ExampleText",
 CellID->2132876610,ExpressionUUID->"12782d8c-4f4d-4d52-ac05-4d547ca714ea"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"dd", "=", 
   RowBox[{
    RowBox[{"First", "[", "msr", "]"}], ".", "cc"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"qq", "=", 
   RowBox[{
    RowBox[{"Dagger", "[", "dd", "]"}], "**", "dd"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->540735181,ExpressionUUID->"c298661a-3888-443c-b69b-faacd1136334"],

Cell["\<\
Construct the projector corresponding to the measurement outcome:\
\>", "ExampleText",
 CellID->1557926104,ExpressionUUID->"0c264943-adcf-4d3f-8d91-bd0113126987"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"val", "*", "qq"}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "val"}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{"1", "-", "qq"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"Apply", "[", 
     RowBox[{"Multiply", ",", "prj"}], "]"}], "//", "Chop"}]}], 
  ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[9]:=",
 CellID->1701731404,ExpressionUUID->"86915bff-6ab2-47c3-a13d-065e19d5642a"],

Cell["\<\
