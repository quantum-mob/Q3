Cell["\<\
Construct the projector corresponding to the measurement outcome:\
\>", "ExampleText",
 CellID->1557926104,ExpressionUUID->"41a52899-308a-445a-a1cc-eee6583aae2a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"val", "*", "qq"}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "val"}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{"1", "-", "qq"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"Apply", "[", 
     RowBox[{"Multiply", ",", "prj"}], "]"}], "//", "Chop"}]}], 
  ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
 CellID->1701731404,ExpressionUUID->"c9dbd81a-bf46-448b-9a2c-6ebd3336164d"],

