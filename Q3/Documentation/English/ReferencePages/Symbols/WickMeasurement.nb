  "Metadata" -> {
   "built" -> "{2026, 5, 23, 21, 21, 24.537001}", 
    "history" -> {"14.3", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {
     "fermionic quantum computation", "fermionic Gaussian state"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "WickMeasurement[m] represents a sequence of measurement on the dressed \
fermion modes di := \\[CapitalSigma]_j = 1^n m i j aj, which are linear \
combinations of bare fermion modes ak. WickMeasurement[k] is a shortcut and \
returns a WickMeasurement object corresponding to the measurement of the \
occupation number on fermion mode k. WickMeasurement[{k1, k2, ...}, n] is a \
short cut and returns WickMeasurement object corresponding to a sequence of \
measurements on bare fermion modes {k1, k2, ...}. WickMeasurement[spec][ws] \
simulates the measurement on the input Wick state ws, and returns the \
post-measurement state.", "synonyms" -> {}, "tabletags" -> {}, "title" -> 
    "WickMeasurement", "titlemodifier" -> "", "metadescription" -> "", 
    "windowtitle" -> "WickMeasurement", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/WickMeasurement"}},
