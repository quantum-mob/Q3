Cell["\<\
Let us now verify the above result by means of conventional method. Set the \
bare fermion modes:\
\>", "ExampleText",
 CellID->1940098992,ExpressionUUID->"e2015ef9-3462-41c6-bf34-ac97b3a054b3"],

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Fermion", ",", "c"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"cc", "=", 
  RowBox[{"c", "[", 
   RowBox[{"Range", "@", "$n"}], "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->1654242487,ExpressionUUID->"059c0b7d-fcf4-4475-82e6-d72a48b31e44"],

Cell["Construct the dressed modes to measure:", "ExampleText",
 CellID->2132876610,ExpressionUUID->"6f4947db-1579-4893-975f-e47cc67fe001"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"dd", "=", 
   RowBox[{
    RowBox[{"First", "[", "msr", "]"}], ".", "cc"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"qq", "=", 
   RowBox[{
    RowBox[{"Dagger", "[", "dd", "]"}], "**", "dd"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->540735181,ExpressionUUID->"af454473-5c35-4116-b76e-1ba13539b23d"],

Cell["\<\
Construct the projector corresponding to the measurement outcome:\
\>", "ExampleText",
 CellID->1557926104,ExpressionUUID->"c58d1ab4-5e0a-4015-8836-67a97ecf252c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"val", "*", "qq"}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "val"}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{"1", "-", "qq"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"Apply", "[", 
     RowBox[{"Multiply", ",", "prj"}], "]"}], "//", "Chop"}]}], 
  ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[9]:=",
 CellID->1701731404,ExpressionUUID->"9251d794-4dad-45ca-a1e0-cce7d6b33e11"],

Cell["\<\
