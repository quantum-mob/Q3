Cell[TextData[{
 "For  a mixed state\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "1"}], "r"], 
     TemplateBox[{
       SubscriptBox["s", "k"]},
      "Ket"], 
     SubscriptBox["s", "k"], 
     TemplateBox[{
       SubscriptBox["s", "k"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "402f11f6-13d9-4573-ae0a-9914b403f0bc"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "6df0b9c4-e906-4562-ae66-89a9940b45f8"],
 " is the rank of \[Rho] and quantum states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["s", "k"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3c1e2df3-a2a2-40db-accd-3245e2dc0fc7"],
 " are orthonormal, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Purification"]], "paclet:QuantumMob/Q3/ref/Purification", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["\[Rho]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bff2112e-f603-400a-936b-328ff1080eeb"],
 " returns the purification of the form\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["s", "k"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"k"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "6c94e472-ba49-42fd-ac38-9e4eb142087d"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"k"},
        "Ket"], "|", "k"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     "r"}], "}"}], TraditionalForm]],ExpressionUUID->
  "62ab0b0a-28db-4591-a41b-8e56b6ea1fcd"],
 " is an arbitrary orthonormal set in another Hilbert space. "
}], "Notes",
 CellID->193298559,ExpressionUUID->"b2c1a9a1-90ea-4665-8043-1bfb23168be5"],

Cell[TextData[{
 "For a given density operator \[Rho], there exists unitary freedom to choose \
a purification leading to the same density operator \[Rho]. It is called the ",
 StyleBox["Gisin",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox["-",
  FontSlant->"Italic"],
 StyleBox["Hughston",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox["-Jozsa-",
  FontSlant->"Italic"],
 StyleBox["Wooters",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox[" (GHJW) theorem",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1715981318,ExpressionUUID->"49452fd9-317b-4ee6-b455-149cd0a6bad3"],

Cell[TextData[{
 "For any unitary operators ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "ec41c2ab-3d39-432e-b00d-5c1e079a0e52"],
 " and ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "8ce0c597-ce3a-4895-9045-cb6106e976a7"],
 ", the most general form of the purification of \[Rho] of dimension ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "4c669516-105e-4546-ae71-cafa01384f4c"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SqrtBox["\[Rho]"], "U"}], ")"}], "\[CircleTimes]", "V"}], ")"}], 
     TemplateBox[{"\[CapitalPhi]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "fe78dd0c-5a09-42bd-87ca-107a84f5f7c1"],
 ",\[LineSeparator]where\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPhi]"},
     "Ket"], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox["d"]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "1"}], "d"], 
     RowBox[{
      TemplateBox[{"k"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"k"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c2bc1055-f212-4da2-9f9c-f9e92d6c51af"],
 "."
}], "Notes",
 CellID->1791480633,ExpressionUUID->"7429bb8d-f30e-4e6d-869a-07bc4147d1d8"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

