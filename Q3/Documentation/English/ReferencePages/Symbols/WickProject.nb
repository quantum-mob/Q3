Cell[TextData[{
 "Note that the dressed-mode form internally uses the QR decomposition and \
the cost scales as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"m", " ", "M", " ", "N"}], ")"}], TraditionalForm]],
  ExpressionUUID->"a010b5dd-e83c-4e0d-972b-0f923353c49f"],
 ", where ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "51e3631d-116a-4bcf-b64b-565c68c0fbd8"],
 " is the number of measured dressed modes, ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "1b934933-44b6-4820-8023-812ede07d910"],
 " is the total number of bare modes and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "239d94b2-76d0-4ad9-bcb2-b1bbbff1dc8a"],
 " is the number of particles in the input state."
}], "Notes",
 CellID->1810872678,ExpressionUUID->"676d36f4-a46a-4272-b12c-a146481f7c45"]
}, Closed]],

