Cell[TextData[{
 "Note that the dressed-mode form internally uses the QR decomposition and \
the cost scales as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"m", " ", "M", " ", "N"}], ")"}], TraditionalForm]],
  ExpressionUUID->"e43e3bc3-8aa4-42e8-a259-fe581b1fa732"],
 ", where ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "303de0c8-6d5d-4464-940b-7e7be68c245b"],
 " is the number of measured dressed modes, ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "a64e9faf-a3a6-4b06-928a-75d43bd96987"],
 " is the total number of bare modes and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "1f9d9ab3-bded-4b55-9bfe-9e990611d2d4"],
 " is the number of particles in the input state."
}], "Notes",
 CellID->1810872678,ExpressionUUID->"19cf9958-84ff-4d02-8d3f-71ab0e12d321"]
}, Closed]],

