Cell[TextData[{
 "However, note that the latter form internally uses the QR decomposition and \
the cost scales as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"m", " ", "M", " ", "N"}], ")"}], TraditionalForm]],
  ExpressionUUID->"b7ee3e34-0cbb-4a69-955b-63a87ec3d993"],
 ", where ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "8efb9f0e-aa15-4d23-a9f1-4cf0e3cd0aba"],
 " is the number of measured dressed modes, ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "9352cf05-7b64-4711-9527-b204916cbf18"],
 " is the total number of bare modes and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "929bac17-93ff-4023-b114-7a3897ee013a"],
 " is the number of particles in the input state."
}], "ExampleText",
 CellID->550323129,ExpressionUUID->"34bb9071-734b-46c9-b87d-1783a7e0f4e3"]
}, Open  ]]
}, Open  ]],

