Cell[TextData[{
 "However, note that the latter form internally uses the QR decomposition and \
the cost scales as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"m", " ", "M", " ", "N"}], ")"}], TraditionalForm]],
  ExpressionUUID->"a3d3d5c3-aa2d-401e-ae56-8446b2514393"],
 ", where ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "5cc2a623-ad03-431e-bd52-b281eb52d6f0"],
 " is the number of measured dressed modes, ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "5b2b6ab2-b544-404a-a5ff-0f8d6af2687b"],
 " is the total number of bare modes and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "ef837de1-8799-4a09-bca2-9a7b05030712"],
 " is the number of particles in the input state."
}], "ExampleText",
 CellID->550323129,ExpressionUUID->"d45f8807-f865-4295-a838-79bd349164da"]
}, Open  ]]
}, Open  ]],

