Cell[TextData[{
 "The evaluation performance of a quantum circuit may vary significantly \
depending on how you evaluate it (that is, either using ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Evaluate"]], "paclet:QuantumMob/Q3/ref/Evaluate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5fa4a81a-e042-48bf-a581-31071245c3b2"],
 "/",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ExpressionFor"]], "paclet:QuantumMob/Q3/ref/ExpressionFor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "711ff1bb-d69b-4280-aa30-562334336af6"],
 " or ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "104a7c9f-e4b1-414c-ba7d-a0a7f3f1d7cb"],
 "), whether there is an input or not, or either directly working with \
high-level gates or elementary gates."
}], "ExampleText",
 CellID->1326551885,ExpressionUUID->"3906bb6e-c8a8-441b-859a-d1742440dcae"],

Cell[TextData[{
 "For example, consider the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QFT"]], "paclet:QuantumMob/Q3/ref/QFT", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7fed5b5a-8228-47f0-adc4-9b01c372c48f"],
 " gate, which is a high-level gate representing the quantum Fourier \
transform."
}], "ExampleText",
 CellID->1844377872,ExpressionUUID->"9556489e-0434-4503-970f-a8c0ea132d19"],

