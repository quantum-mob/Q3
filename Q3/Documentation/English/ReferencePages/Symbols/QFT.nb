         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"]}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "39d607bb-8a6b-4880-90ed-b18ae9f5decb"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
