     RowBox[{"2", "\[Pi]"}], 
     SuperscriptBox["2", "k"]]}], TraditionalForm]],ExpressionUUID->
  "eaa30390-f382-46a3-be42-c68fa2ef4c97"],
 "."
}], "Notes",
