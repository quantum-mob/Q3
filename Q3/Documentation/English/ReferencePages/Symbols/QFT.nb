Cell[TextData[{
 "Setting \
\[OpenCurlyDoubleQuote]ApproximationLevel\[CloseCurlyDoubleQuote]->m keeps \
only controlled-phase gates with phase angles ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Phi]", "k"], "=", 
    RowBox[{"2", 
     RowBox[{"\[Pi]", "/", 
      SuperscriptBox["2", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "3ccb6a6f-e37a-4d8f-a4f1-54b7671fface"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[LessEqual]", "m"}], TraditionalForm]],ExpressionUUID->
  "1d6aba28-8fa1-4be1-95a2-6ee73a55291b"],
 ":"
}], "ExampleText",
 CellID->780825452,ExpressionUUID->"58247688-b5ed-47ef-a2d8-ec2413274fd8"],

