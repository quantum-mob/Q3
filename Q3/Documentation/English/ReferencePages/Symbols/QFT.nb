Cell[TextData[{
 "For heuristic purposes, Q3 provides a handy way to generate the above \
quantum circuit of the QFT. Note that the tilde accent above the label of \
control qubits to emphasize the bit string is reversed; that is,  ",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      OverscriptBox["x", "~"], ":=", 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["x", 
          RowBox[{"k", "-", "1"}]], "\[Ellipsis]", "\[VeryThinSpace]", 
         SubscriptBox["x", "2"], 
         SubscriptBox["x", "1"]}], ")"}], "2"]}], TraditionalForm]],
    ExpressionUUID->"890f5cf5-b206-422f-afda-22f98ad94733"]],ExpressionUUID->
    "f953ebbc-94c9-4f30-8e88-5ad3e136c555"], TraditionalForm]],ExpressionUUID->
  "aa61d9c8-e2dd-47a6-abc7-ad6858402911"],
 " rather than ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["x", "1"], 
      SubscriptBox["x", "2"], "\[Ellipsis]", "\[VeryThinSpace]", 
      SubscriptBox["x", 
       RowBox[{"k", "-", "1"}]]}], ")"}], "2"], TraditionalForm]],
  ExpressionUUID->"3205f7d8-a0b2-45e1-b657-9b7d3d9a8efd"],
 ":"
}], "ExampleText",
 CellID->597410564,ExpressionUUID->"a2cf7430-0a72-46b4-803a-2e327d925a84"],

