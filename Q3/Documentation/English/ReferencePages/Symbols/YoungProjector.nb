Cell[TextData[{
 "For ",
 ButtonBox["Young subgroup",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungSubgroup"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "f2b93096-31af-429e-9a35-8d4fe3e7b730"],
 " associated with ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "01bbd743-edfa-4e40-a0b4-6270a1b2b04a"],
 ", the projection onto Young\[CloseCurlyQuote]s normal representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"ad195c42-98b3-4cf3-90e8-002257ee1a85"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["S", "\[Mu]"], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"|", 
       SubscriptBox["S", "\[Mu]"], "|"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["S", "\[Mu]"]}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"b8523d56-e714-4e17-a5c4-c29d0348c560"],
 " ."
}], "Notes",
 CellID->239884523,ExpressionUUID->"09ea4253-0f8a-40dd-9cba-cbe5599d9eae"],

Cell[TextData[{
 "It genuinely is an orthogonal projector:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"[", 
      RowBox[{
       SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
       SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], "]"}], "2"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], 
     SuperscriptBox[
      RowBox[{"=[", 
       RowBox[{
        SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
        SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], "]"}], 
      "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "a8e350ba-7a33-4b74-bbda-6a51fa753228"],
 "."
}], "Notes",
 CellID->1097240130,ExpressionUUID->"bc0f3fd6-4a66-4ee3-8369-e80c7f2372e8"],

Cell[TextData[{
 "In accordance with the decomposition of \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "\[Mu]"], ":=", 
    RowBox[{
     SubscriptBox["S", 
      SubscriptBox["A", "1"]], "\[Times]", 
     SubscriptBox["S", 
      SubscriptBox["A", "2"]], "\[Times]", "\[CenterEllipsis]", "\[Times]", 
     SubscriptBox["S", 
      SubscriptBox["A", "d"]]}]}], TraditionalForm]],ExpressionUUID->
  "b92f4e49-9bef-4969-b26f-f2f74dbf9f13"],
 " \[LineSeparator]into disjoint permutations with\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "k"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", "1"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", "2"}], ",", "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", 
       SubscriptBox["\[Mu]", "k"]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"eda9ac1f-f9ae-4d34-a661-87c804e1eb5b"],
 ",\[LineSeparator] ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"0fe5ffb2-1716-46a2-b9ff-fed488b1acbd"],
 " is decomposed as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["S", "\[Mu]"], ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "d"], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", 
       SubscriptBox["A", "k"]], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "b7db1e0f-72e3-494d-a7f7-faf1b99e96fa"],
 ",\nwhere\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["\[ScriptCapitalS]", 
      SubscriptBox["A", "k"]], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SubscriptBox["\[Mu]", "k"], "!"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["\[ScriptCapitalS]", 
        SubscriptBox["A", "k"]]}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"0f7a435f-e928-41d0-9bf8-ee2b07ee24fc"],
 " ."
}], "Notes",
 CellID->985473395,ExpressionUUID->"83137b7d-139c-402e-8919-70c5a7aa1441"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

