 " ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "70695473-e9c4-494c-aaa4-aecaf2eaaea8"],
 " of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "8b65770b-b12b-4037-ae39-c06468028a81"],
 " and ",
 ButtonBox["content",
