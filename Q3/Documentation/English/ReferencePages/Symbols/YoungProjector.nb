Cell[TextData[{
 "For ",
 ButtonBox["Young subgroup",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungSubgroup"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "832f823f-5637-45a9-abd2-e0899a92a289"],
 " associated with ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "2e73ada5-ad3a-4876-9716-50084b1ecb76"],
 ", the projection onto Young\[CloseCurlyQuote]s normal representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"2e6df59c-7987-4f66-b675-d52d4321f211"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["S", "\[Mu]"], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"|", 
       SubscriptBox["S", "\[Mu]"], "|"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["S", "\[Mu]"]}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"ff93283a-089e-46eb-a7b4-543be451ac0b"],
 " ."
}], "Notes",
 CellID->239884523,ExpressionUUID->"ff2721d9-88f0-408d-bccc-00de9fc6a6ec"],

Cell[TextData[{
 "It genuinely is an orthogonal projector:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"[", 
      RowBox[{
       SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
       SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], "]"}], "2"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], 
     SuperscriptBox[
      RowBox[{"=[", 
       RowBox[{
        SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
        SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], "]"}], 
      "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "d9b8b7e7-764d-47a0-9204-fb06f1f6e4eb"],
 "."
}], "Notes",
 CellID->1097240130,ExpressionUUID->"935f3ef1-1419-494b-be6b-973553e8b1b1"],

Cell[TextData[{
 "In accordance with the decomposition of \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "\[Mu]"], ":=", 
    RowBox[{
     SubscriptBox["S", 
      SubscriptBox["A", "1"]], "\[Times]", 
     SubscriptBox["S", 
      SubscriptBox["A", "2"]], "\[Times]", "\[CenterEllipsis]", "\[Times]", 
     SubscriptBox["S", 
      SubscriptBox["A", "d"]]}]}], TraditionalForm]],ExpressionUUID->
  "b921171a-131d-457f-bf50-5046a7376218"],
 " \[LineSeparator]into disjoint permutations with\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "k"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", "1"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", "2"}], ",", "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", 
       SubscriptBox["\[Mu]", "k"]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"93f7fc48-a0b6-44d1-a1b9-a86586693e19"],
 ",\[LineSeparator] ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"0d5216d5-9e53-4ce1-b46a-543fb4c54907"],
 " is decomposed as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["S", "\[Mu]"], ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "d"], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", 
       SubscriptBox["A", "k"]], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "523b9ba1-e70d-4413-817a-d4d9b1a43f46"],
 ",\nwhere\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["\[ScriptCapitalS]", 
      SubscriptBox["A", "k"]], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SubscriptBox["\[Mu]", "k"], "!"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["\[ScriptCapitalS]", 
        SubscriptBox["A", "k"]]}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"5b8513c6-1476-4e49-becf-aff4ddd4548e"],
 " ."
}], "Notes",
 CellID->985473395,ExpressionUUID->"aa5b63ef-bab6-4591-be6a-97c80463c3c5"],

Cell[TextData[{
 "In the ",
 ButtonBox["Specht basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
 " (i.e., Young\[CloseCurlyQuote]s orthogonal basis), ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"8c93c3f5-341a-41b2-bb10-47e5569dc2ad"],
 " is block-diagonal with respect to the ",
 ButtonBox["Gelfand-Tsetlin classes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandClasses"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", "Y"}]},
      "Bra"], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"Y", "'"}]}]},
      "Ket"]}], "=", 
    TagBox[GridBox[{
       {"\[Piecewise]", GridBox[{
          {
           RowBox[{
            TemplateBox[{
              RowBox[{"\[Lambda]", ",", "Y"}]},
             "Bra"], 
            SubscriptBox["\[CapitalPi]", "w"], 
            TemplateBox[{
              RowBox[{"\[Lambda]", ",", 
                RowBox[{"Y", "'"}]}]},
             "Ket"]}], 
           RowBox[{"Y", ",", 
            RowBox[{
             RowBox[{"Y", "'"}], "\[Element]", 
             RowBox[{"[", "w", "]"}]}]}]},
          {"0", "otherwise"}
         },
         AllowedDimensions->{2, Automatic},
         Editable->True,
         GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
         GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
         GridBoxSpacings->{"Columns" -> {
             Offset[0.27999999999999997`], {
              Offset[0.84]}, 
             Offset[0.27999999999999997`]}, "Rows" -> {
             Offset[0.2], {
              Offset[0.4]}, 
             Offset[0.2]}},
         Selectable->True]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
      GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.35]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}],
     "Piecewise",
     DeleteWithContents->True,
     Editable->False,
     SelectWithContents->True,
     Selectable->False,
     StripWrapperBoxes->True]}], TraditionalForm]],ExpressionUUID->
  "13e06341-01a0-4c75-aee7-a78fa9ff5281"],
 "\nwhere each block ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPi]", "w"], TraditionalForm]],ExpressionUUID->
  "9c03b526-7709-48ad-aad4-d1e741784de7"],
 " is a rank-1 projector and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", "w", "]"}], TraditionalForm]],ExpressionUUID->
  "c9b031bb-f2d9-4085-bacb-3e8c39b1f528"],
 " denotes the ",
 ButtonBox["Gelfand-Tsetlin class",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandClass"],
 " corresponding to the ",
