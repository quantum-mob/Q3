Cell[TextData[{
 "For ",
 ButtonBox["Young subgroup",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungSubgroup"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "533cdcad-45ee-44db-9881-d655fa47c2e2"],
 " associated with ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "900b95c1-e0fa-4d4c-95c8-cc9dd275cae6"],
 ", the Young subgroup projector onto Young\[CloseCurlyQuote]s normal \
representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"a4353eb0-1d1c-4713-8e72-7d34b413f073"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["S", "\[Mu]"], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"|", 
       SubscriptBox["S", "\[Mu]"], "|"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["S", "\[Mu]"]}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"54956ec3-921f-4b5a-a3a9-381bc91c519f"],
 " ."
}], "Notes",
 CellID->239884523,ExpressionUUID->"ff85d97f-7047-49b9-8dad-633b0bb40f18"],

Cell[TextData[{
 "It genuinely is an orthogonal projector:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"[", 
      RowBox[{
       SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
       SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], "]"}], "2"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], 
     SuperscriptBox[
      RowBox[{"=[", 
       RowBox[{
        SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
        SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], "]"}], 
      "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "86dada89-1cc0-4a45-a4db-fd0133f98689"],
 "."
}], "Notes",
 CellID->1097240130,ExpressionUUID->"185569d5-9690-47b6-808d-9a2471b2c249"],

Cell[TextData[{
 "In accordance with the decomposition of \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "\[Mu]"], ":=", 
    RowBox[{
     SubscriptBox["S", 
      SubscriptBox["A", "1"]], "\[Times]", 
     SubscriptBox["S", 
      SubscriptBox["A", "2"]], "\[Times]", "\[CenterEllipsis]", "\[Times]", 
     SubscriptBox["S", 
      SubscriptBox["A", "d"]]}]}], TraditionalForm]],ExpressionUUID->
  "820a5531-83c1-409f-a4c4-fb244533cf6b"],
 " \[LineSeparator]into disjoint permutations with\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "k"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", "1"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", "2"}], ",", "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", 
       SubscriptBox["\[Mu]", "k"]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"60f104fe-affa-4f60-9bec-99a65edcf00b"],
 ",\[LineSeparator] ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"56e0c968-4639-4f69-80a0-c094f4a2fb3c"],
 " is decomposed as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["S", "\[Mu]"], ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "d"], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", 
       SubscriptBox["A", "k"]], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "b9cae64a-0f72-4a0c-b3c4-1938d09bb829"],
 ",\nwhere\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["\[ScriptCapitalS]", 
      SubscriptBox["A", "k"]], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       SubscriptBox["\[Mu]", "k"], "!"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["\[ScriptCapitalS]", 
        SubscriptBox["A", "k"]]}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"33faaaa9-3646-40f4-8489-38248b68a38a"],
 " ."
}], "Notes",
 CellID->985473395,ExpressionUUID->"a31a1569-b699-4d45-9650-6c423b4aa79f"],

Cell[TextData[{
 "In the ",
 ButtonBox["Specht basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
 " (i.e., Young\[CloseCurlyQuote]s orthogonal basis), ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"4fefd990-ee85-461e-bbfa-978a0561fe27"],
 " is block-diagonal with respect to the ",
 ButtonBox["Gelfand-Tsetlin classes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandClasses"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", "Y"}]},
      "Bra"], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"Y", "'"}]}]},
      "Ket"]}], "=", 
    TagBox[GridBox[{
       {"\[Piecewise]", GridBox[{
          {
           RowBox[{
            TemplateBox[{
              RowBox[{"\[Lambda]", ",", "Y"}]},
             "Bra"], 
            SubscriptBox["\[CapitalPi]", "w"], 
            TemplateBox[{
              RowBox[{"\[Lambda]", ",", 
                RowBox[{"Y", "'"}]}]},
             "Ket"]}], 
           RowBox[{"Y", ",", 
            RowBox[{
             RowBox[{"Y", "'"}], "\[Element]", 
             RowBox[{"[", "w", "]"}]}]}]},
          {"0", "otherwise"}
         },
         AllowedDimensions->{2, Automatic},
         Editable->True,
         GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
         GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
         GridBoxSpacings->{"Columns" -> {
             Offset[0.27999999999999997`], {
              Offset[0.84]}, 
             Offset[0.27999999999999997`]}, "Rows" -> {
             Offset[0.2], {
              Offset[0.4]}, 
             Offset[0.2]}},
         Selectable->True]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
      GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.35]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}],
     "Piecewise",
     DeleteWithContents->True,
     Editable->False,
     SelectWithContents->True,
     Selectable->False,
     StripWrapperBoxes->True]}], TraditionalForm]],ExpressionUUID->
  "88171cc6-1b74-41df-8eaa-312c3ab1ba14"],
 "\nwhere each block ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPi]", "w"], TraditionalForm]],ExpressionUUID->
  "e5efe86f-4365-4a28-badd-ca3c7660dda2"],
 " is a rank-1 projector and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", "w", "]"}], TraditionalForm]],ExpressionUUID->
  "2b20977d-f1fd-4f5c-b23f-29e841abbd63"],
 " denotes the ",
 ButtonBox["Gelfand-Tsetlin class",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandClass"],
 " corresponding to the ",
