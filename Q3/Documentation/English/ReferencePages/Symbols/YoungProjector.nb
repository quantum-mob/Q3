Cell["\<\
Apply the projector on the basis vectors. Note that the Young subgroup \
projector is block-diagonal in the Specht basis, and that each block is a \
rank-1 projector. The basis vector spanning the one-dimensional subspace can \
be obtained by applying the Young subgroup projector to any vector belonging \
to the block:\
\>", "ExampleText",
 CellID->1807297157,ExpressionUUID->"bb54271c-a451-454f-a70d-6758d943139a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"out", "=", 
  RowBox[{"prj", "**", "bs"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[9]:=",
 CellID->355136307,ExpressionUUID->"cbbbd794-b098-4d32-b393-4f0e54a54567"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", 
   RowBox[{
    FractionBox[
     TemplateBox[{
       InterpretationBox[
        TagBox[
         GridBox[{{
            ItemBox["1", Frame -> True, StripOnInput -> False], 
            ItemBox["3", Frame -> True, StripOnInput -> False]}, {
            ItemBox["2", Frame -> True, StripOnInput -> False], ""}, {
            ItemBox["4", Frame -> True, StripOnInput -> False], ""}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
        QuantumMob`Q3`YoungTableau[{{1, 3}, {2}, {4}}]]},
      "Ket"], "3"], "+", 
    FractionBox[
     RowBox[{
      SqrtBox["2"], " ", 
      TemplateBox[{
        InterpretationBox[
         TagBox[
          GridBox[{{
             ItemBox["1", Frame -> True, StripOnInput -> False], 
             ItemBox["4", Frame -> True, StripOnInput -> False]}, {
             ItemBox["2", Frame -> True, StripOnInput -> False], ""}, {
             ItemBox["3", Frame -> True, StripOnInput -> False], ""}}, 
           AutoDelete -> False, 
           GridBoxItemSize -> {
            "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
         QuantumMob`Q3`YoungTableau[{{1, 4}, {2}, {3}}]]},
       "Ket"]}], "3"]}], ",", 
   RowBox[{
    FractionBox[
     RowBox[{
      SqrtBox["2"], " ", 
      TemplateBox[{
        InterpretationBox[
         TagBox[
          GridBox[{{
             ItemBox["1", Frame -> True, StripOnInput -> False], 
             ItemBox["3", Frame -> True, StripOnInput -> False]}, {
             ItemBox["2", Frame -> True, StripOnInput -> False], ""}, {
             ItemBox["4", Frame -> True, StripOnInput -> False], ""}}, 
           AutoDelete -> False, 
           GridBoxItemSize -> {
            "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
         QuantumMob`Q3`YoungTableau[{{1, 3}, {2}, {4}}]]},
       "Ket"]}], "3"], "+", 
    FractionBox[
     RowBox[{"2", " ", 
      TemplateBox[{
        InterpretationBox[
         TagBox[
          GridBox[{{
             ItemBox["1", Frame -> True, StripOnInput -> False], 
             ItemBox["4", Frame -> True, StripOnInput -> False]}, {
             ItemBox["2", Frame -> True, StripOnInput -> False], ""}, {
             ItemBox["3", Frame -> True, StripOnInput -> False], ""}}, 
           AutoDelete -> False, 
           GridBoxItemSize -> {
            "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
         QuantumMob`Q3`YoungTableau[{{1, 4}, {2}, {3}}]]},
       "Ket"]}], "3"]}]}], "}"}]], "Output",
 CellLabel->"Out[9]=",
 CellID->299237429,ExpressionUUID->"38ffa926-c86e-4759-9d74-ee0f7b360285"]
}, Open  ]],

Cell["\<\
Check, in the matrix form, that the Young subgroup projector is \
block-diagonal in the Specht basis:\
\>", "ExampleText",
 CellID->7400253,ExpressionUUID->"b1d4856e-6e7d-4af4-b33b-802d5195d3c3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{"YoungProjector", "[", 
    RowBox[{"shp", ",", "mu"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"mat", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
 CellID->1848697584,ExpressionUUID->"1c3d3b85-446d-4f2e-8974-b16581da098a"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", "0"},
     {"0", 
      FractionBox["1", "3"], 
      FractionBox[
       SqrtBox["2"], "3"]},
     {"0", 
      FractionBox[
       SqrtBox["2"], "3"], 
      FractionBox["2", "3"]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {3, 3}, 0, {
     1, {{0, 1, 3, 5}, {{1}, {2}, {3}, {3}, {2}}}, {
      0, Rational[1, 3], Rational[1, 3] 2^Rational[1, 2], Rational[2, 3], 
       Rational[1, 3] 2^Rational[1, 2]}}]]]]], "Output",
 CellLabel->"Out[10]//MatrixForm=",
 CellID->2024251576,ExpressionUUID->"cccd053d-3215-4ae5-b82f-7672b9937717"]
}, Open  ]]
