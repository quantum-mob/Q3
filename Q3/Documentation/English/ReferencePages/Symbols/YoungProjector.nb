 " ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "64d35742-97c1-4496-814b-aa018a73e901"],
 " of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "dea1c63c-fb4b-4628-9a59-95c91c47c0c5"],
 " and ",
