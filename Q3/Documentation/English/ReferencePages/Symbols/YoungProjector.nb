Cell["\<\
Apply the projector on the basis vectors. Note that the Young subgroup \
projector is block-diagonal in the Specht basis, and that each block is a \
rank-1 projector. The basis vector spanning the one-dimensional subspace can \
be obtained by applying the Young subgroup projector to any vector belonging \
to the block:\
\>", "ExampleText",
 CellID->1807297157,ExpressionUUID->"11dcf5c5-c2d1-44c6-90cb-f915c5bd09dc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"out", "=", 
  RowBox[{"prj", "**", "bs"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[9]:=",
 CellID->355136307,ExpressionUUID->"1a989874-f183-4505-95ee-69e5489b9dad"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", 
   RowBox[{
    FractionBox[
     TemplateBox[{
       InterpretationBox[
        TagBox[
         GridBox[{{
            ItemBox["1", Frame -> True, StripOnInput -> False], 
            ItemBox["3", Frame -> True, StripOnInput -> False]}, {
            ItemBox["2", Frame -> True, StripOnInput -> False], ""}, {
            ItemBox["4", Frame -> True, StripOnInput -> False], ""}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
        QuantumMob`Q3`YoungTableau[{{1, 3}, {2}, {4}}]]},
      "Ket"], "3"], "+", 
    FractionBox[
     RowBox[{
      SqrtBox["2"], " ", 
      TemplateBox[{
        InterpretationBox[
         TagBox[
          GridBox[{{
             ItemBox["1", Frame -> True, StripOnInput -> False], 
             ItemBox["4", Frame -> True, StripOnInput -> False]}, {
             ItemBox["2", Frame -> True, StripOnInput -> False], ""}, {
             ItemBox["3", Frame -> True, StripOnInput -> False], ""}}, 
           AutoDelete -> False, 
           GridBoxItemSize -> {
            "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
         QuantumMob`Q3`YoungTableau[{{1, 4}, {2}, {3}}]]},
       "Ket"]}], "3"]}], ",", 
   RowBox[{
    FractionBox[
     RowBox[{
      SqrtBox["2"], " ", 
      TemplateBox[{
        InterpretationBox[
         TagBox[
          GridBox[{{
             ItemBox["1", Frame -> True, StripOnInput -> False], 
             ItemBox["3", Frame -> True, StripOnInput -> False]}, {
             ItemBox["2", Frame -> True, StripOnInput -> False], ""}, {
             ItemBox["4", Frame -> True, StripOnInput -> False], ""}}, 
           AutoDelete -> False, 
           GridBoxItemSize -> {
            "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
         QuantumMob`Q3`YoungTableau[{{1, 3}, {2}, {4}}]]},
       "Ket"]}], "3"], "+", 
    FractionBox[
     RowBox[{"2", " ", 
      TemplateBox[{
        InterpretationBox[
         TagBox[
          GridBox[{{
             ItemBox["1", Frame -> True, StripOnInput -> False], 
             ItemBox["4", Frame -> True, StripOnInput -> False]}, {
             ItemBox["2", Frame -> True, StripOnInput -> False], ""}, {
             ItemBox["3", Frame -> True, StripOnInput -> False], ""}}, 
           AutoDelete -> False, 
           GridBoxItemSize -> {
            "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
         QuantumMob`Q3`YoungTableau[{{1, 4}, {2}, {3}}]]},
       "Ket"]}], "3"]}]}], "}"}]], "Output",
 CellLabel->"Out[9]=",
 CellID->299237429,ExpressionUUID->"35f5c418-0e4f-41d2-8e97-4ba043a259ab"]
}, Open  ]],

Cell["\<\
Check, in the matrix form, that the Young subgroup projector is \
block-diagonal in the Specht basis:\
\>", "ExampleText",
 CellID->7400253,ExpressionUUID->"994acadf-107e-422a-9dcc-83f7233220ee"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{"YoungProjector", "[", 
    RowBox[{"shp", ",", "mu"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"mat", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
 CellID->1848697584,ExpressionUUID->"fc8385ad-e552-441a-ad60-24195dfa41c2"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", "0"},
     {"0", 
      FractionBox["1", "3"], 
      FractionBox[
       SqrtBox["2"], "3"]},
     {"0", 
      FractionBox[
       SqrtBox["2"], "3"], 
      FractionBox["2", "3"]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {3, 3}, 0, {
     1, {{0, 1, 3, 5}, {{1}, {2}, {3}, {3}, {2}}}, {
      0, Rational[1, 3], Rational[1, 3] 2^Rational[1, 2], Rational[2, 3], 
       Rational[1, 3] 2^Rational[1, 2]}}]]]]], "Output",
 CellLabel->"Out[10]//MatrixForm=",
 CellID->2024251576,ExpressionUUID->"738c7cfd-730d-4c0b-8234-d6ccf2171597"]
}, Open  ]]
