Cell[TextData[{
 "For Young subgroup ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "a7a25b2f-185c-4ad7-ad56-6a75103b10f0"],
 " associated with content ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "51dc4f91-d525-440f-9402-8dafeabb3378"],
 ", the projection onto Young\[CloseCurlyQuote]s normal representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"7de0d206-b8eb-47e8-a35f-5ccf7420e376"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["P", "\[Mu]", "\[Lambda]"], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"|", 
       SubscriptBox["S", "\[Mu]"], "|"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["S", "\[Mu]"]}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"83ee2395-dfca-491b-8eca-9932f2ccfb8b"],
 " ."
}], "Notes",
 CellID->239884523,ExpressionUUID->"fdbbeccf-5e4b-46c0-a90c-7c1ba2bb9c43"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

