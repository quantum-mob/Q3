Cell[TextData[{
 "A ",
 StyleBox[ButtonBox["Young tableau",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungTableaux"],
  FontSlant->"Italic"],
 " of shape \[Lambda] is an array of numbers filling the boxes of the ",
 ButtonBox["Young diagram",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungDiagram"],
 " of shape \[Lambda] (or replacing the dots of the Ferrers diagram)."
}], "Notes",
 CellID->526707167,ExpressionUUID->"f7b8466a-b769-46cc-9fef-52aa67269e01"],

Cell[TextData[{
 "A Young tableau is said to be ",
 StyleBox["standard",
  FontSlant->"Italic"],
 " if its entries are all distinct and strictly increase along each row and \
column of the underlying Young diagram."
}], "Notes",
 CellID->208732956,ExpressionUUID->"b20fe33c-816d-46df-b30d-f8ba87e1e284"],

Cell[TextData[{
 "A Young tableau is said to be ",
 StyleBox["semi-standard",
  FontSlant->"Italic"],
 " if its entries weakly increase along each row and strictly increase along \
each column. In semi-standard Young tableaux duplicate entries are allowed. \
Semi-standard Young tableaux are also called Weyl tableaux."
}], "Notes",
 CellID->1665931480,ExpressionUUID->"a2a5bf23-6596-4f1e-9ad8-7b7635970cd9"],

Cell[TextData[{
 "The list resulting from ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungTableaux"]], "paclet:QuantumMob/Q3/ref/YoungTableaux", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["shape", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1edeee0e-1afc-47fe-b0f6-8ebf2d52b0c1"],
 " is not in ",
 ButtonBox["lexicographic order",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandOrder"],
 ". On the other hand, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["LegacyYoungTableaux"]], 
     "paclet:QuantumMob/Q3/ref/LegacyYoungTableaux", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["shape", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "96a6b93f-834c-415a-ae1b-21fb7efc9eed"],
 " returns a list in ",
 ButtonBox["lexicographic order",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandOrder"],
 "."
}], "Notes",
 CellID->288315490,ExpressionUUID->"22c8b3f9-aa98-4012-b6e9-f12404251a19"],

