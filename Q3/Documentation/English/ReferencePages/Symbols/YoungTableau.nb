  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "60c1a887-73e1-4427-861e-85c1d8fe9d90"],
 " and Weyl tableaux (semi-standard Young tableaux) of ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f8e4812f-1c24-4c53-972c-b66d0cea7b95"],
 " letters."
}], "Notes",
 CellID->649833363,ExpressionUUID->"b3362663-8bfc-46c2-aa7f-4998bed72acd"]
