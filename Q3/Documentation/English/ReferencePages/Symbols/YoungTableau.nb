Cell[TextData[{
 "A ",
 StyleBox[ButtonBox["Young tableau",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungTableaux"],
  FontSlant->"Italic"],
 " of shape \[Lambda] is an array of numbers filling the boxes of the ",
 ButtonBox["Young diagram",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungDiagram"],
 " of shape \[Lambda] (or replacing the dots of the Ferrers diagram)."
}], "Notes",
 CellID->526707167,ExpressionUUID->"2ca83dae-985f-41c4-ac32-b62fd4b19def"],

Cell[TextData[{
 "A Young tableau is said to be ",
 StyleBox["standard",
  FontSlant->"Italic"],
 " if its entries are all distinct and strictly increase along each row and \
column of the underlying Young diagram."
}], "Notes",
 CellID->208732956,ExpressionUUID->"9d30299d-f851-4624-b636-3d46c60df2f3"],

Cell[TextData[{
 "A Young tableau is said to be ",
 StyleBox["semi-standard",
  FontSlant->"Italic"],
 " if its entries weakly increase along each row and strictly increase along \
each column. In semi-standard Young tableaux duplicate entries are allowed. \
Semi-standard Young tableaux are also called ",
 StyleBox["Weyl tableaux",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1665931480,ExpressionUUID->"6fd8f7c4-d0c7-4a38-b2b6-45f6883be1b4"],

Cell[TextData[{
 "There is a one-to-one correspondence between ",
 StyleBox[ButtonBox["Gelfand patterns",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandPatterns"],
  FontSlant->"Italic"],
 " of order ",
