Cell[TextData[{
 "A ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "7ff91fe6-b710-4e1c-a445-555b5c066548"],
 " is completely specified (up to a global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"\[ImaginaryI]", " ", "m", " ", 
     RowBox[{"\[Pi]", " ", "/", "4"}]}]], TraditionalForm]],ExpressionUUID->
  "3f0f819b-8dbd-4216-b835-01af1e8fda08"],
 ") by the transformation of ",
 ButtonBox["Pauli operators",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "7f161910-fd18-4297-8238-ff0fb5da579d"],
 ":\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["X", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["p", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["a", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["b", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "14a85978-b4b4-40ca-8063-3703243c2885"],
 "\nand\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["Z", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["q", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["c", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["d", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "9f87dd7a-bc54-4c61-b5c0-aee696ec7651"],
 "."
}], "Notes",
 CellID->1417856937,ExpressionUUID->"d318c50f-6320-4ec1-9586-35a51f57a2f5"],

Cell[TextData[{
 "The Gottesman matrix of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "8d55a00d-1dbb-4693-b8c8-44b2d90782cf"],
 " is then defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "U", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["a", "11"], 
        SubscriptBox["c", "11"], 
        SubscriptBox["a", "12"], 
        SubscriptBox["c", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "11"], 
        SubscriptBox["d", "11"], 
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["a", "21"], 
        SubscriptBox["c", "21"], 
        SubscriptBox["a", "22"], 
        SubscriptBox["c", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "21"], 
        SubscriptBox["b", "22"], 
        SubscriptBox["d", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "4385d43a-26c8-4004-977b-a38c7216c172"]
}], "Notes",
 CellID->1647214467,ExpressionUUID->"784a3c33-4c4c-449a-a182-5f2304237cdc"],

Cell[TextData[{
 "The Gottesman matrix of a ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " is a binary symplectic matrix. Recall that the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"7a42c80a-01f3-41eb-96df-9a63f6a7e61b"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "2adbb6da-d957-41c9-bdb9-529d519e4891"],
 "qubits is equivalent to the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"bd3f2613-e4eb-4b8a-b03f-4311d302ec75"],
 " up to the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"5c4e9fb6-081f-4654-88d7-65a3a29a3dac"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], "\[Congruent]", 
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"be959728-1975-453b-a6b8-02a40a4df134"],
 "."
}], "Notes",
 CellID->17963594,ExpressionUUID->"1f32a4ed-f462-4ae2-97d4-a710699620a8"],

Cell[TextData[{
 "Recall that a Pauli operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"efa1a595-67b2-4d4a-ad5d-9341af02bb8a"],
 "\[LineSeparator]is completely specified (up to a global phase factor) by \
the corresponding Gottesman vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["z", "1"], ",", 
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["x", "n"], ",", 
       SubscriptBox["z", "n"]}], ")"}], "T"]}], TraditionalForm]],
  ExpressionUUID->"5940f7c6-28ce-4513-84bf-6b5e3541f09b"],
 "."
}], "Notes",
 CellID->1441760612,ExpressionUUID->"2f326f65-f4b8-4173-8d6b-00d251620d64"],

Cell[TextData[{
 "Under conjugation by a Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "0f484ad2-a2cd-461a-b299-cdb7cb567468"],
 ", the Gottesman vector transforms as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", 
     RowBox[{"U", " ", "P", " ", 
      SuperscriptBox["U", "\[Dagger]"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"v", "(", "P", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "f514d4d6-4d02-449f-ac8d-76cf43e5e500"],
 "."
}], "Notes",
 CellID->1746253034,ExpressionUUID->"3c7b4b7f-c81d-46bc-afbd-05ceeda7ff9d"],

Cell[TextData[{
 "Furthermore, a series of consecutive conjugations by Clifford operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ",", " ", "V", ",", " ", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"775d9b27-e67f-4df7-ae94-37a5b54032aa"],
 " is described by the multiplications of corresponding Gottesman matrices,\
\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], "\[Ellipsis]"}]}], TraditionalForm]],
  ExpressionUUID->"b57bdc77-d410-494b-9558-33388349a5cc"],
 ". \[LineSeparator]That is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]", " ", "P"}], " ", "..."}], " ", 
     SuperscriptBox["V", "\[Dagger]"], 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
     SuperscriptBox[
      RowBox[{"P", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "\[Dagger]"]}]}], 
   TraditionalForm]],ExpressionUUID->"10074307-a100-42c4-a964-fc66b6a5de74"],
 "\[LineSeparator]leads to\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"v", "(", "P", ")"}], "\[RightTeeArrow]", 
     RowBox[{
      RowBox[{"S", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
      RowBox[{"v", "(", "P", ")"}]}]}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], 
     RowBox[{"\[Ellipsis]v", "(", "P", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"9ec60b52-1699-44d3-912f-5e4fe2c5a124"],
 "."
}], "Notes",
 CellID->863527665,ExpressionUUID->"9cab0795-9fcc-480d-bfd6-65119fa61545"],

Cell[TextData[{
 "For technical reasons, however,  ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanMatrix"]], "paclet:QuantumMob/Q3/ref/GottesmanMatrix",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d93ae5b8-c88e-42fd-b98b-3663d3f5fea2"],
 " returns the transposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["S", "T"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"254e5a0d-cabf-4d33-ab1f-8ddcef5ea348"],
 " rather than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "(", "U", ")"}], TraditionalForm]],ExpressionUUID->
  "41db5687-d33a-467f-84cd-a781705234c7"],
 " itself. ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FromGottesmanMatrix"]], 
    "paclet:QuantumMob/Q3/ref/FromGottesmanMatrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "40a99057-6b5d-4ede-80b9-f8d10e0b0d91"],
 " also recovers Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "2a9b00ef-9680-40b5-96bf-255ec6d8944e"],
 " by assuming that the input matrix is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["S", "T"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"872f0a85-6178-42f5-8de9-2a8fb3de424d"],
 "."
}], "Notes",
 CellID->327820378,ExpressionUUID->"e177353e-52e2-4b27-8725-2bb06005d33f"],

Cell[TextData[{
 "Each row of a ",
 StyleBox["full",
  FontSlant->"Italic"],
 " Gottesman matrix is a ",
 ButtonBox["full Gottesman vector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullGottesmanVector"],
 "."
}], "Notes",
 CellID->309725214,ExpressionUUID->"d7c186fc-bfc3-4004-91b5-d1bc3ad36bb9"]
