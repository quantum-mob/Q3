Cell[TextData[{
 "Each unitary layer describes unitary evolution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      StyleBox["ham",
       FontSlant->"Italic"], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"eee8c2fa-e915-40b4-a588-c63fd45534ae"],
 " with random evolution time \[Tau] governed by the distribution function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[Tau]", ")"}], "\[Proportional]", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"d2edbb46-a0ff-45c9-ad55-6ce19c2cf16a"],
 ", and in each measurement layer, each fermion mode is measured with \
probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"1", "/", "n"}]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b8ac2f5a-0940-49b7-8cfe-ee0e49404832"],
 "."
}], "ExampleText",
 CellID->1259663973,ExpressionUUID->"75e50feb-c64a-473f-a58b-e39dfdddfc1b"],

