Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickScramblingCircuit"]], 
         "paclet:QuantumMob/Q3/ref/WickScramblingCircuit", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["a", "TI"], ",", 
        StyleBox["spec", "TI"], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "cfb24a62-ee79-43d4-ae60-004e4534e2d9"],
     "\[LineSeparator]generate the ",
     ButtonBox["Wick circuit",
      BaseStyle->"Link",
      ButtonData->"paclet:QuantumMob/Q3/ref/WickCircuit"],
     " (i.e., quantum circuits of fermionic Gaussian gates) realization of ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        RowBox[{"a", "(", "t", ")"}], ":=", 
        RowBox[{
         RowBox[{
          SuperscriptBox["u", "\[Dagger]"], "(", "t", ")"}], "a", " ", 
         RowBox[{"u", "(", "t", ")"}]}]}], TraditionalForm]],ExpressionUUID->
      "5095aa28-cc1e-4078-9a74-f944706c126c"],
     " for the study quantum information scrambling, where ",
     Cell[BoxData[
      StyleBox["a", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "b220f110-1691-4c0f-8c5b-fa7bf6a4b8f4"],
     " is a local ",
     ButtonBox["Wick unitary",
      BaseStyle->"Link",
      ButtonData->"paclet:QuantumMob/Q3/ref/WickUnitary"],
     " operator and ",
     Cell[BoxData[
      FormBox[
       RowBox[{"u", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
      "1bfaaa4e-e3c6-4c42-aa56-d03973548ff4"],
     " is the time-evolution operator. For the remaining arguments ",
     Cell[BoxData[
      RowBox[{
       StyleBox["spec", "TI"], ",", 
       StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "91e2cce7-b72c-4ab2-8d7e-cb3c903e86a8"],
     ", see ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["RandomWickCircuit"]], 
        "paclet:QuantumMob/Q3/ref/RandomWickCircuit", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8594648b-ce6e-4f66-9e9c-cc238e1a1b11"],
     ". "
    }],ExpressionUUID->"d4b0371a-ad59-4c2b-9608-a89faefcbaf2"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickScramblingCircuit"]], 
         "paclet:QuantumMob/Q3/ref/WickScramblingCircuit", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["k", "TI"], ",", 
        StyleBox["spec", "TI"], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "5368ca89-c701-4dd7-9ea9-d39dceb0762d"],
     " \[LineSeparator]assumes ",
     Cell[BoxData[
      FormBox[
       RowBox[{"a", ":=", 
        RowBox[{"exp", "[", 
         RowBox[{
          FractionBox["\[Pi]", "2"], 
          RowBox[{"(", 
           RowBox[{
