      FontFamily->"Source Sans Pro",ExpressionUUID->
      "eb7201ec-8256-48ba-9399-a0f438753eb0"],
     "\[LineSeparator]generate the ",
     ButtonBox["Wick circuit",
      BaseStyle->"Link",
      ButtonData->"paclet:QuantumMob/Q3/ref/WickCircuit"],
     " (i.e., quantum circuits of fermionic Gaussian gates) realization of ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        RowBox[{"a", "(", "t", ")"}], ":=", 
        RowBox[{
         RowBox[{
          SuperscriptBox["u", "\[Dagger]"], "(", "t", ")"}], "a", " ", 
         RowBox[{"u", "(", "t", ")"}]}]}], TraditionalForm]],ExpressionUUID->
      "b8c69268-39d3-483d-95fe-5738a69f7039"],
     " for the study quantum information scrambling, where ",
     Cell[BoxData[
      StyleBox["a", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "fd6c8d84-5418-4bc5-9a01-f4a9be1ec185"],
     " is a local ",
     ButtonBox["Wick unitary",
      BaseStyle->"Link",
      ButtonData->"paclet:QuantumMob/Q3/ref/WickUnitary"],
     " operator and ",
     Cell[BoxData[
      FormBox[
       RowBox[{"u", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
      "89f4bc3f-bc29-4082-9cf2-73312c0365c2"],
     " is the time-evolution operator. For the remaining arguments ",
     Cell[BoxData[
      RowBox[{
       StyleBox["spec", "TI"], ",", 
       StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8f1ccd30-0bcf-4c0c-8447-2d56b6f7099d"],
     ", see ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["RandomWickCircuit"]], 
        "paclet:QuantumMob/Q3/ref/RandomWickCircuit", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "bca56086-17b6-4428-8eaa-55894cda1ba3"],
     ". "
    }],ExpressionUUID->"e8de5303-52e9-42ea-9fa5-9f69c08bab62"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickScramblingCircuit"]], 
         "paclet:QuantumMob/Q3/ref/WickScramblingCircuit", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["k", "TI"], ",", 
        StyleBox["spec", "TI"], ",", 
