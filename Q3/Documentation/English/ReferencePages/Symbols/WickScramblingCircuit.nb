Cell[TextData[{
 "Each unitary layer describes unitary evolution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      StyleBox["ham",
       FontSlant->"Italic"], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"ce3d0287-e6ec-4255-bcc5-52855c559c73"],
 " with random evolution time \[Tau] governed by the distribution function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[Tau]", ")"}], "\[Proportional]", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"fd41d13c-d845-4a32-a72f-680b96f24643"],
 ", and in each measurement layer, each fermion mode is measured with \
probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"1", "/", "n"}]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "647ed70e-3a3c-438e-92eb-56aa62f760db"],
 "."
}], "ExampleText",
 CellID->1259663973,ExpressionUUID->"a659ad4d-e951-4136-a30c-bf300dc3bf79"],

