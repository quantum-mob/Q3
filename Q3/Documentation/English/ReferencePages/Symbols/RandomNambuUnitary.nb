Cell[TextData[{
 "Reconstruct the full unitary matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["U", "_"], ":=", 
    RowBox[{"(", GridBox[{
       {"U", "V"},
       {
        SuperscriptBox["V", "*"], 
        SuperscriptBox["U", "*"]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "42bb9b1c-aef2-4114-b2e8-9654f1292956"],
 " from the two independent blocks ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "cf09059b-28a3-4c85-ace2-be456cb8f38c"],
 " and ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "48824a5b-635d-4367-a4eb-5f13eeedab26"],
 " in the above representation."
}], "ExampleText",
 CellID->1047012077,ExpressionUUID->"3d25c7f7-baa3-4b58-8fbc-1718403bf5b5"],

