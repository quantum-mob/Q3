Cell[TextData[{
 "A ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "4aa48542-630a-447f-89bb-35522d58fb55"],
 " matrix in the ",
 StyleBox["Nambu space",
  FontSlant->"Italic"],
 " has only two ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "29f66168-1769-4f15-8648-a1780d2b9751"],
 " independent blocks out of four. Conventionally, the upper-left and \
upper-right blocks are chosen to be independent, and if necessary, the other \
two blocks are reconstructed from them. The actually reconstruction depends \
on the type of the Nambu-space matrix."
}], "Notes",
 CellID->1103304822,ExpressionUUID->"482234c6-5f0f-47dd-af55-5356be45fc55"]
}, Dynamic[CurrentValue[
