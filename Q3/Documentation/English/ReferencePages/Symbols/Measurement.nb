Cell["\<\
Note that Pauli operators include tensor products of the single-qubit Pauli \
operators.\
\>", "Notes",
 CellID->2092045182,ExpressionUUID->"457b3cc3-a21f-47b6-8f32-6a86158aea69"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Measurement"]], "paclet:QuantumMob/Q3/ref/Measurement", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["op", "TI"], "]"}], "[", 
   StyleBox["vec", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0c962133-23a5-4a08-836b-ee8403880c3d"],
 " gives outcomes 0 or 1, corresponding to eigenvalues \[PlusMinus]1, \
respectively, of ",
 Cell[BoxData[
  StyleBox["op", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fb3db0ad-bafd-40a8-8102-59a0a18ea616"],
 ". Recall that any Pauli operator has eigenvalue \[PlusMinus]1."
}], "Notes",
 CellID->330064636,ExpressionUUID->"77ad2b46-cbed-4bc5-8258-05ba86360e6d"],

Cell[TextData[{
 "If the input vector is symbolic, then the post-measurement vectors are ",
 StyleBox["not",
  FontSlant->"Italic"],
 " normalized."
}], "Notes",
 CellID->833201793,ExpressionUUID->"c10c4ea8-fa20-415f-9f81-578c939d9bfc"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"Measurement", "[", 
     StyleBox["op", "TI"], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "be360a99-c28d-455c-8f60-de52acb83486"],
 " is equivalent to ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Measurement"]], "paclet:QuantumMob/Q3/ref/Measurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["op", "TI"], ",", " ", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["s", "TI"], 
        StyleBox["1", "TR"]], ",", 
       SubscriptBox[
        StyleBox["s", "TI"], 
        StyleBox["2", "TR"]], ",", 
       StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cabbcd62-f93f-47c2-af44-75986166986f"],
 "; hence, the result is not really a matrix."
}], "Notes",
 CellID->1336201431,ExpressionUUID->"b1a3eec5-2233-41ae-bd6a-7d2fd31324f5"]
}, Dynamic[CurrentValue[
