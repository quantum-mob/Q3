Cell["\<\
Sometimes, the calculation using matrix representation is faster. In such \
cases, the post-measurement state is returned in the column vector form, and \
to check the measurement outcome, one has to use the matrix representation of \
the observables.\
\>", "ExampleText",
 CellID->2061919267,ExpressionUUID->"dfcf86ad-8b3c-4d5a-bf0d-39b49de4d9d0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Table", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Matrix", "[", "qc", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"mm", "=", 
     RowBox[{"Matrix", "[", 
      RowBox[{
       RowBox[{"Measurements", "@", "qc"}], ",", 
       RowBox[{"Qubits", "@", "qc"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Readout", "[", "mm", "]"}]}], ",", "\[IndentingNewLine]", "10"}],
   "]"}]], "Input",
