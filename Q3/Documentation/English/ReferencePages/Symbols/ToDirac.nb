Cell[TextData[{
 "The transformation rules between Dirac fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "8dd1f6a7-5515-4c98-bc0e-59dc5b0b5612"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["a", "k", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "b24d8328-a28d-4be6-b700-3dcaf4605eed"],
 " and the Majorana fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "543f8ed3-d3b7-4007-843d-4f57f7213a64"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{"n", "+", "k"}]], TraditionalForm]],ExpressionUUID->
  "02d8e377-a09d-4470-9633-e2c034be7ea4"],
 " are given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "k"], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "+", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"8f83c4c0-852c-4e4a-9e5c-2f4fa284eecb"],
 ", \[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubscriptBox["c", 
      RowBox[{"n", "+", "k"}]]}], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "-", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"091ec35c-c496-432e-b870-bc9f9c1956c0"],
 ".\[LineSeparator]Note that the Majorana operators are normalized as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["c", "i"], ",", 
      SubscriptBox["c", "j"]}], "}"}], "=", 
    RowBox[{"2", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"87c254e9-9264-4e4f-9733-44913774aacc"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["c", "i", "2"], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"737e2a97-aeef-4216-81cf-d0db3effeda9"],
 "."
}], "Notes",
