Cell[TextData[{
 StyleBox["NOTE",
  FontWeight->"Bold"],
 ": Since Q3 v3.4.4, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliQ"]], "paclet:QuantumMob/Q3/ref/PauliQ", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2b347a42-5a2b-4a91-a938-d4cc98af4f11"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliMatrixQ"]], "paclet:QuantumMob/Q3/ref/PauliMatrixQ", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a69db475-b610-4561-8cc9-01ba55171b59"],
 " have been separated. ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliQ"]], "paclet:QuantumMob/Q3/ref/PauliQ", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "59c205ad-53d6-4371-97fd-646f683e1685"],
 " does not rely on ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliMatrixQ"]], "paclet:QuantumMob/Q3/ref/PauliMatrixQ", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2ab39bb1-e462-49b3-abe4-1e753320ec1c"],
 " and is much faster than ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliMatrixQ"]], "paclet:QuantumMob/Q3/ref/PauliMatrixQ", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "01e4e5e6-5db3-4ba5-9812-61da1686f578"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliMatrixQ"]], "paclet:QuantumMob/Q3/ref/PauliMatrixQ", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d5fdebb5-8cf9-423c-80f1-aada8836305b"],
 " is computationally expensive for large matrices."
}], "Notes",
 CellID->518872311,ExpressionUUID->"936e3c34-9d5d-4667-a348-f08cd4945cd6"]
