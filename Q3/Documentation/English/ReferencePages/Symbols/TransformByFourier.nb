Cell["The following two expressions are equivalent.", "ExampleText",
 CellID->1123253791,ExpressionUUID->"43d39f4a-def2-497e-862c-2b5ea5317d73"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"rules1", "=", 
  RowBox[{"TransformByFourier", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"c", "[", 
       RowBox[{"jj", ",", "Up"}], "]"}], ",", 
      RowBox[{"c", "[", 
       RowBox[{"jj", ",", "Down"}], "]"}]}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"d", "[", 
       RowBox[{"jj", ",", "Up"}], "]"}], ",", 
      RowBox[{"d", "[", 
       RowBox[{"jj", ",", "Down"}], "]"}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"rules2", "=", 
  RowBox[{"TransformByFourier", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"c", "[", 
      RowBox[{"jj", ",", "Up"}], "]"}], "\[Rule]", 
     RowBox[{"d", "[", 
      RowBox[{"jj", ",", "Up"}], "]"}]}], ",", 
    RowBox[{
     RowBox[{"c", "[", 
      RowBox[{"jj", ",", "Down"}], "]"}], "\[Rule]", 
     RowBox[{"d", "[", 
      RowBox[{"jj", ",", "Down"}], "]"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"rules1", "\[Equal]", "rules2"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->2145208207,ExpressionUUID->"276fb568-cc56-494f-89e9-4b0a02cba8ea"],

