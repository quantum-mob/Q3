Cell[TextData[{
 "The transformation rules between Dirac fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "7b06a7da-d9d6-48b3-9fe1-2e6983acd1ee"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["a", "k", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "8edfd1a7-3b2e-490c-9a0d-9aa540a21c58"],
 " and the Majorana fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     RowBox[{"2", "k"}], "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "7fb3308d-546b-4ce6-ad60-3669a8d17acb"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{"2", "k"}]], TraditionalForm]],ExpressionUUID->
  "3d36d1f0-6536-46d4-bf26-dd3c5dc33f0d"],
 " are given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", 
     RowBox[{
      RowBox[{"2", "k"}], "-", "1"}]], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "+", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"20839544-524a-46ec-b60a-799b5b7a9983"],
 ", \[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubscriptBox["c", 
      RowBox[{"2", "k"}]]}], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "-", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"08210a5f-2d0b-40a2-9e57-4539905f634d"],
 ".\[LineSeparator]Note that the Majorana operators are normalized as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["a", "i"], ",", 
      SubscriptBox["a", "j"]}], "}"}], "=", 
    RowBox[{"2", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"1ec1c908-9ff1-4711-9423-190036c497ed"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "i", "2"], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"bb277090-105d-468e-8752-d3d5d0c35c4b"],
 "."
}], "Notes",
 CellID->307824357,ExpressionUUID->"9e770756-0a67-46c0-9c00-300bbf93832d"],

