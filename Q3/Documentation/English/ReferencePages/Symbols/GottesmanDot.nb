Cell[TextData[{
 "For two Gottesman vectors  ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "48869257-0360-42b1-b49d-2f753b6aa084"],
 " and ",
 Cell[BoxData[
  StyleBox["w", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bd380ca1-438f-4cd0-99fe-c8df92e9075f"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["GottesmanDot"]], "paclet:QuantumMob/Q3/ref/GottesmanDot", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["v", "TI"], ",", 
    StyleBox["w", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "099f2008-7517-45a2-9050-64c1b0f5abfc"],
 " returns the Gottesman inner product ",
 Cell[BoxData[
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox["v",
     FontSlant->"Italic"], ",", 
    StyleBox["w",
     FontSlant->"Italic"]}], "\[RightAngleBracket]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "17ac4245-ef94-4aa4-a13f-99f09ce7ac26"],
 ", a ",
 StyleBox["symplectic inner produc",
  FontSlant->"Italic"],
 "t in the Gottesman vector space ",
 Cell[BoxData[
  SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
   RowBox[{"2", 
    StyleBox["n", "TI"]}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "77caa25f-41bc-4dd6-81a9-602cc48a2d27"],
 " on ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d0035f59-f5b8-42e4-ac2e-756412ebf132"],
 " qubits."
}], "Notes",
 CellID->757993885,ExpressionUUID->"8d678aef-6f91-4fb9-8daa-ada1c107a805"],

Cell[TextData[{
 "For two Gottesman vectors ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ed6f6504-0c84-48b6-b946-a774279f3a24"],
 " and ",
 Cell[BoxData[
  StyleBox["w", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ec800da4-7342-4af1-aec2-efb31c6bf4e9"],
 " on ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0ad8456c-ed0c-4a91-9c72-d18ad7555e95"],
 " qubits such that ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["v", "TI"], "T"], "=", 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["1", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["2", "TR"], 
        StyleBox["n", "TI"]}],
       ZeroWidthTimes->True]]}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2bb25b94-4162-4687-a65c-8cdfb427bc54"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox[
    StyleBox["w", "TI"], "T"], "=", 
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      StyleBox["w", "TI"], 
      StyleBox["1", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["w", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["2", "TR"], 
        StyleBox["n", "TI"]}],
       ZeroWidthTimes->True]]}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "16dad56b-2eb2-493b-893c-99db9eb79d89"],
 ", the Gottesman inner product ",
 Cell[BoxData[
  RowBox[{"\[LeftAngleBracket]", 
   RowBox[{
    StyleBox["v",
     FontSlant->"Italic"], ",", 
    StyleBox["w",
     FontSlant->"Italic"]}], "\[RightAngleBracket]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "19df61da-9f12-43cc-a84b-9a64db7a6c39"],
 " is defined as follows.\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"v", ",", "w"}], "\[RightAngleBracket]"}], ":=", 
    RowBox[{
     SuperscriptBox["v", "T"], "J", "\[VeryThinSpace] ", "w"}]}], 
   TraditionalForm]],ExpressionUUID->"05e9e4ae-278f-47c2-b77a-269d4aeba8b8"],
 " ,\[LineSeparator]where\[LineSeparator]        ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", ":=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"0", "1"},
        {
         RowBox[{"-", "1"}], "0"}
       }], ")"}], "\[CirclePlus]", 
     RowBox[{"(", GridBox[{
        {"0", "1"},
        {
         RowBox[{"-", "1"}], "0"}
       }], ")"}], "\[CirclePlus]", "\[Ellipsis]"}]}], TraditionalForm]],
  ExpressionUUID->"6e145794-493b-4602-8319-d93fd0d3a11e"],
 " .\[LineSeparator]Since all calculations are in module 2, the matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", "\[VeryThinSpace]"}], TraditionalForm]],ExpressionUUID->
  "71b264e3-a150-4f0f-a596-9c1517b7f3dd"],
 " may be regarded as\[LineSeparator]        ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", ":=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"0", "1"},
        {"1", "0"}
       }], ")"}], "\[CirclePlus]", 
     RowBox[{"(", GridBox[{
        {"0", "1"},
        {"1", "0"}
       }], ")"}], "\[CirclePlus]", "\[Ellipsis]"}]}], TraditionalForm]],
  ExpressionUUID->"2a344f1b-b4f3-4daa-b84e-25642ec404cc"],
 " ."
}], "Notes",
 CellID->1734075231,ExpressionUUID->"84914c55-64df-4e10-ba9b-e56dbbd17e56"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "5b3312c6-c888-4bae-ae28-ebbef281ac0f"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "fa240ad8-be09-4166-8672-bcc5ab766fbe"],
 " be Pauli operators and ",
 Cell[BoxData[
  FormBox["v", TraditionalForm]],ExpressionUUID->
  "b90c100b-6f23-4811-a332-82fe0bb4a164"],
 " and ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "dda968f6-89a6-4275-8df7-a8732aa2ebc2"],
 " be their respective Gottesman vectors. ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "3f21a24d-1409-48b9-a7e9-3270d03a8248"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "1b7a1945-5763-4f29-8232-15e8fefb9320"],
 " commute with each other if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"v", ",", "w"}], "\[RightAngleBracket]"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"a0506bf7-eb57-484f-b5a8-3ec86ea42fc1"],
 "; and anti-commute with each other if and only if  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"v", ",", "w"}], "\[RightAngleBracket]"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"c3bfa3d1-36be-4aab-8473-e4702ad3dcf7"],
 "."
}], "Notes",
 CellID->1148572183,ExpressionUUID->"50744ce7-d52d-4342-843d-7dae68cde358"],

Cell[TextData[{
 "For two matrices ",
