    SuperscriptBox["w", "T"]}], TraditionalForm]],ExpressionUUID->
  "682276de-31fb-4be2-8958-ee92c8740b26"],
 "."
}], "Notes",
 CellID->1758702416,ExpressionUUID->"0a4f3631-e172-4561-bc94-1cee8843b89c"],

Cell[TextData[{
 "For two matrices ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b5d90f9d-fa5f-46b0-a594-33a33b40d1c4"],
 " and ",
