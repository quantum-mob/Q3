Cell[TextData[{
 "The canonical coding in the dual-standard ordered generating system (OGS) \
for the symmetric group of degree ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "d63ac377-82cc-4ae3-9fd3-c0c62f569d0d"],
 " is a map ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[Element]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalS]", "n"], "\[RightTeeArrow]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["m", "2"], ",", 
       SubscriptBox["m", "3"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["m", "n"]}], ")"}]}], "\[Element]", 
    RowBox[{
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"], "\[Times]", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"], "\[Times]", "\[Ellipsis]", 
     "\[Times]", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "n"]}]}], TraditionalForm]],
  ExpressionUUID->"3d7852d1-5c33-4dfd-80d9-e8f3210aa8fd"],
 " such that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "=", 
    RowBox[{
     SubsuperscriptBox["c", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", ",", "2"}]}], "}"}], 
      SubscriptBox["m", "2"]], 
     SubsuperscriptBox["c", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", ",", "2", ",", "3"}]}], "}"}], 
      SubscriptBox["m", "3"]], "\[VeryThinSpace]", "\[Ellipsis]", "\[VeryThinSpace]\[VeryThinSpace]", 
     SubsuperscriptBox["c", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", "n"}]}], "}"}], 
      SubscriptBox["m", "n"]]}]}], TraditionalForm]],ExpressionUUID->
  "a7e4ec55-92e8-4314-8e80-c9ead2413644"],
 " ."
}], "Notes",
 CellID->846140678,ExpressionUUID->"416be652-d423-4eb6-b405-c5127ac22f4d"],

Cell[TextData[{
 "Given ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[Element]", 
    SubscriptBox["\[ScriptCapitalS]", "n"]}], TraditionalForm]],
  ExpressionUUID->"f35726aa-15ec-47fc-bac1-fd80cfd74866"],
 " and corresponding sequence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["m", "2"], ",", 
     SubscriptBox["m", "3"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["m", "n"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "ef72c6a1-3190-4379-946d-df3e81700437"],
 ", define a number ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "3558455c-2ac0-4efb-958d-709bc87c76fc"],
 " by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "2"}], "n"], 
     SubscriptBox["m", "k"], " ", 
     FractionBox[
      RowBox[{"n", "!"}], 
      RowBox[{"k", "!"}]], " "}]}], TraditionalForm]],ExpressionUUID->
  "045f40b9-1689-403a-bdb5-9d07d7a024f3"],
 ".\[LineSeparator]This establishes a one-to-one correspondence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "\[RightTeeArrow]", "m"}], "\[Element]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{"n", "!"}], "-", "1"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"97b92469-0cfc-432d-a410-9e75453087fc"],
 "."
}], "Notes",
 CellID->824630816,ExpressionUUID->"6d911cca-441f-400c-84e6-44a1498193a0"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

