Cell["\<\
MeasurementFunction[1/2 - Multiply[S[1, 1], S[3, 3]]/2 + S[1, 1]/2 + 
  S[3, 3]/2, 1/2 - Multiply[S[1, 3], S[2, 3]]/2 + S[1, 3]/2 + S[2, 3]/2, 
 Measurement[{S[2, 3], S[3, 3]}], (S[2, 1] + S[2, 3])/Sqrt[2], 
 1/2 - Multiply[S[2, 3], S[3, 1]]/2 + S[2, 3]/2 + S[3, 1]/2, 
 1/2 - Multiply[S[1, 3], S[2, 1]]/2 + S[1, 3]/2 + S[2, 1]/2, 
 (S[1, 1] + S[1, 3])/Sqrt[2]]\
\>", "Output",
