       TemplateBox[{"1", "2", "3"}, "RowDefault"]]},
     "RowDefault"], "+", 
    TemplateBox[{
      SubscriptBox["\[Pi]", 
       TemplateBox[{"1", "3", "2"}, "RowDefault"]]},
     "RowDefault"], "+", 
    SubscriptBox["\[Pi]", "0"]}], ")"}]}]], "Output",
 CellLabel->"Out[3]=",
 CellID->1031108162,ExpressionUUID->"6def17e8-212f-41f7-9f71-cec2b6019233"]
}, Open  ]],

