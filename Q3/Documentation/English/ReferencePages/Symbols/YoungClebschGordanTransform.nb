Cell[TextData[{
 "The input vector ",
 Cell[BoxData[
  StyleBox["vec", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0da2add9-3503-46c8-b215-04df6f7b0933"],
 " should be a superposition of products of two ",
 ButtonBox["Specht basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
 " vectors,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
    UnderscriptBox["\[CapitalSigma]", 
     RowBox[{
      SuperscriptBox["y", "\[Mu]"], "\[Element]", "\[Mu]"}]], 
    UnderscriptBox["\[CapitalSigma]", "\[Nu]"], 
    UnderscriptBox["\[CapitalSigma]", 
     RowBox[{
      SuperscriptBox["y", "\[Nu]"], "\[Element]", "\[Nu]"}]], 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         SuperscriptBox["y", "\[Mu]"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"\[Nu]", ",", 
         SuperscriptBox["y", "\[Nu]"]}]},
      "Ket"]}], 
    SubscriptBox["c", 
     RowBox[{
      SuperscriptBox["y", "\[Mu]"], 
      SuperscriptBox["y", "\[Nu]"]}]]}], TraditionalForm]],ExpressionUUID->
  "7ce8c52c-7ef9-47bd-a43d-0774b9070835"],
 " ."
}], "Notes",
 CellID->171127868,ExpressionUUID->"3c50f18d-48b8-4989-bb15-b1ba0de326fb"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungClebschGordanTransform"]], 
    "paclet:QuantumMob/Q3/ref/YoungClebschGordanTransform", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "05d591b2-54d0-4722-811e-4a45cc91da32"],
 " maps each product vector into another vector of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         SuperscriptBox["y", "\[Mu]"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"\[Nu]", ",", 
         SuperscriptBox["y", "\[Nu]"]}]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{
       SuperscriptBox["y", "\[Lambda]"], "\[Element]", "\[Lambda]"}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Lambda]", ",", 
          SuperscriptBox["y", "\[Lambda]"]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{
          SubsuperscriptBox["C", "\[Lambda]", "\[Mu]\[Nu]"], "(", 
          RowBox[{
            RowBox[{
              SuperscriptBox["y", "\[Lambda]"], ";", 
              SuperscriptBox["y", "\[Mu]"]}], ",", 
            SuperscriptBox["y", "\[Nu]"]}], ")"}]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "5686b5a3-b057-4103-975d-7bc1abbc3de7"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubsuperscriptBox["C", "\[Lambda]", "\[Mu]\[Nu]"], "(", 
       RowBox[{
         RowBox[{
           SuperscriptBox["y", "\[Lambda]"], ";", 
           SuperscriptBox["y", "\[Mu]"]}], ",", 
         SuperscriptBox["y", "\[Nu]"]}], ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "7c8712cf-ac83-4b21-9f4c-a1ee28c2519e"],
 " refers to the vector in the multiplicity space."
}], "Notes",
 CellID->1442479249,ExpressionUUID->"5852aca1-cfcb-40e4-a255-2e7b01ea84df"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

