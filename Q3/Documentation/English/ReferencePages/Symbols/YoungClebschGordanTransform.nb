Cell[TextData[{
 "The following is another way to achieve the Clebsch-Gordan transform by ",
 StyleBox["explicitly",
  FontSlant->"Italic"],
 " performing the controlled-\[CapitalGamma] gate and quantum Fourier \
transform. (Be warned, this takes significantly longer. It should be used \
only for heuristic purposes.)"
}], "ExampleText",
 CellID->1017508556,ExpressionUUID->"20846c58-b699-49d2-9b0e-86dc4dbb23c5"],

