Cell[TextData[{
 "Recall that these Young tableaux labels the elements in the ",
 ButtonBox["Specht basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Mu]", ",", 
       SuperscriptBox["y", "\[Mu]"]}]},
