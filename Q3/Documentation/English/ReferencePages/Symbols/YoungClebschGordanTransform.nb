Cell["\<\
Construct the projection operator into the invariant subspace:\
\>", "ExampleText",
 CellID->1118514248,ExpressionUUID->"21f3a462-d577-4fc7-9050-7a734cca1f02"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"op", "=", 
   RowBox[{
    RowBox[{"Total", "[", 
     RowBox[{"GroupElements", "@", 
      RowBox[{"SymmetricGroup", "@", "$n"}]}], "]"}], "/", 
    RowBox[{"GroupOrder", "[", 
     RowBox[{"SymmetricGroup", "@", "$n"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"op", "//", "PermutationForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->887646055,ExpressionUUID->"e4d02ace-52f8-47b3-b886-96f57dd321a7"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "6"], " ", 
  RowBox[{"(", 
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Pi]", 
       TemplateBox[{"1", "2"}, "RowDefault"]]},
     "RowDefault"], "+", 
    TemplateBox[{
      SubscriptBox["\[Pi]", 
       TemplateBox[{"1", "3"}, "RowDefault"]]},
     "RowDefault"], "+", 
