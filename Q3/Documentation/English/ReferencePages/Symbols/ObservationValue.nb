Cell[TextData[{
 "The second input argument ",
 Cell[BoxData[
  StyleBox["spec", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "09d6041e-2768-462c-ad04-e7c1d969ce52"],
 " is expressed in terms of species appearing in ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:ref/Ket"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"<|", 
    StyleBox["\[Ellipsis]", "TR"], "|>"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d18c29d8-b1e1-4240-ae9e-a942bd41a4cd"],
 " in ",
 Cell[BoxData[
  StyleBox["state", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0432632c-1cd4-4bef-a5a9-6b877e04a4f6"],
 ". Sometimes, to prevent it from being evaluated, one has to wrap the \
expression in ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Inactive"]], "paclet:ref/Inactive"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "20644dca-4860-4c50-9e41-1ce098e3a36c"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hold"]], "paclet:ref/Hold"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bf6083e1-a4bf-4815-9b8d-4717b8829f0f"],
 " or ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["HoldForm"]], "paclet:ref/HoldForm"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dbe409dd-aab5-4caf-9ccf-740168ad0e6e"],
 " may also be used, but then ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["RealseHold"]], "paclet:QuantumMob/Q3/ref/RealseHold", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "31b2a3b1-86de-4b57-955b-452f3088df5e"],
 " must be applied manually; furthermore, this method may be disturbed inside \
",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Multiply"]], "paclet:QuantumMob/Q3/ref/Multiply", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c404f507-565f-4086-8fc5-177118a1f32f"],
