Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Z\"\>", "\[CircleTimes]", "\<\"Y\"\>", 
   "\[CircleTimes]", "\<\"I\"\>"}],
  QuantumMob`Q3`Pauli[{3, 2, 0}]]], "Output",
 CellLabel->"Out[2]=",
