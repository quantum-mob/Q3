Cell["\<\
Consider a register of three qubits. A typical quantum state looks as follows.\
\>", "ExampleText",
 CellID->1064855273,ExpressionUUID->"c1709a6f-8286-4bf0-b29a-fdaa473b000b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"in", "=", 
  RowBox[{
   RowBox[{"Ket", "[", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "1"}], "}"}], "]"}], "-", 
   RowBox[{"I", "*", 
    RowBox[{"Ket", "[", 
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0"}], "}"}], "]"}]}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->845571990,ExpressionUUID->"e7c1dc76-2e25-4ea1-a0dc-06c11861772b"],

Cell[BoxData[
 RowBox[{
  TemplateBox[{
    RowBox[{"0", ",", "1", ",", "1"}]},
   "Ket"], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   TemplateBox[{
     RowBox[{"1", ",", "0", ",", "0"}]},
    "Ket"]}]}]], "Output",
 CellLabel->"Out[1]=",
 CellID->459904931,ExpressionUUID->"9a08f33c-88ec-46e8-969e-6ad4025e5b34"]
}, Open  ]],

Cell["We want to operate a string of Pauli operators.", "ExampleText",
