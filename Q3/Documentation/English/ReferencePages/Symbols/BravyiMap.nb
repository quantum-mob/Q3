         SubscriptBox[
          StyleBox["\[CapitalSigma]", "TR"], 
          StyleBox["i", "TI"]], "\[VeryThinSpace]", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SubscriptBox[
            StyleBox["p", "TI"], 
            StyleBox["i", "TI"]]}], "\[VeryThinSpace]", ")"}], 
         StyleBox["\[Rho]", "TR"], 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SubscriptBox[
            StyleBox["p", "TI"], 
            StyleBox["i", "TI"]]}], ")"}]}]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1c31a5c4-9b08-4424-aa1b-86be3aa2f9a4"],
     "); or ",
     Cell[BoxData[
      RowBox[{
       StyleBox["v", "TI"], "\[Rule]", "2"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1111b501-3d2f-457e-80d1-220985cb2682"],
     " otherwise."
    }],ExpressionUUID->"fdcb67f3-cc29-47f9-b99a-f4cef4c00eaa"]}
  }]], "Usage",
 CellID->40386902,ExpressionUUID->"99d4f29c-8cf8-4680-9569-bf067f89a11e"]
}, Open  ]],

