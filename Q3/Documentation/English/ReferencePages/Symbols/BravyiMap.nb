      FontFamily->"Source Sans Pro",ExpressionUUID->
      "05c2530d-8a60-4bac-bdb0-97dd1e5ab765"],
     " with each Gaussian element ",
     Cell[BoxData[
      RowBox[{"\[VeryThinSpace]", 
       RowBox[{
        SubscriptBox[
         StyleBox["l", "TI"], 
         StyleBox["i", "TI"]], "**", 
        StyleBox["\[Rho]", "TR"], "**", 
        SubsuperscriptBox[
