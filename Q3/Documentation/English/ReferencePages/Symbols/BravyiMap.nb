      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f173aa38-8082-4461-b1ae-bcf7ad38cdbc"],
     "\[LineSeparator]represents a fermionic Gaussian supermap ",
     Cell[BoxData[
      RowBox[{
       StyleBox["\[Rho]", "TR"], "\[RightTeeArrow]", 
       RowBox[{
        SubscriptBox[
         StyleBox["\[CapitalSigma]", "TR"], 
         StyleBox["i", "TI"]], "\[VeryThinSpace]", 
        RowBox[{
         SubscriptBox[
          StyleBox["l", "TI"], 
          StyleBox["i", "TI"]], "**", 
         StyleBox["\[Rho]", "TR"], "**", 
         SubsuperscriptBox[
          StyleBox["l", "TI"], 
          StyleBox["i", "TI"], "\[Dagger]"]}]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "26ea3581-1eb9-4cfb-ace9-71df2ec22b84"],
     " with each Gaussian element ",
     Cell[BoxData[
      RowBox[{"\[VeryThinSpace]", 
       RowBox[{
        SubscriptBox[
         StyleBox["l", "TI"], 
         StyleBox["i", "TI"]], "**", 
        StyleBox["\[Rho]", "TR"], "**", 
        SubsuperscriptBox[
         StyleBox["l", "TI"], 
         StyleBox["i", "TI"], "\[Dagger]"]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1a6b2801-f9b9-4fd4-a2ba-97e82e64ee29"],
     " specified by ",
     Cell[BoxData[
      SubscriptBox[
       StyleBox["spec", "TI"], 
       StyleBox["i", "TI"]]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "5d31feaf-6e86-4fb7-a8cf-dc8e8d6f0e69"],
     ". The specification ",
     Cell[BoxData[
      SubscriptBox[
       StyleBox["spec", "TI"], 
       StyleBox["i", "TI"]]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8987af0f-883b-4aae-9e95-9b7f38372228"],
     " of the form ",
     Cell[BoxData[
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["b", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["d", "TI"], 
          StyleBox["i", "TI"]]}], "}"}], "\[Rule]", 
       SubscriptBox[
        StyleBox["f", "TI"], 
        StyleBox["i", "TI"]]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e6be6140-dbb3-4b74-a528-91a6a57a6807"],
     " means the action kernel of the block form ",
     Cell[BoxData[
      FormBox[
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           SubscriptBox["a", "i"], ",", 
           SubscriptBox["b", "i"]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", 
            SubsuperscriptBox["b", "i", "T"]}], ",", 
           SubscriptBox["d", "i"]}], "}"}]}], "}"}], TraditionalForm]],
      ExpressionUUID->"81bb15bd-644b-42fa-885c-13bb94a51587"],
     " and prefactor ",
     Cell[BoxData[
      SubscriptBox[
       StyleBox["f", "TI"], 
       StyleBox["i", "TI"]]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1a2044b3-de5b-4701-a1e1-6713ccf2d197"],
     ". The specification spec$i of the form ",
     Cell[BoxData[
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["b", "TI"], 
          StyleBox["i", "TI"]]}], "}"}], "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
          StyleBox["sgn", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["f", "TI"], 
          StyleBox["i", "TI"]]}], "}"}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "980c86ad-4aab-422c-97cb-660193f835f4"],
     " is equivalent to ",
     Cell[BoxData[
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["b", "TI"], 
          StyleBox["i", "TI"]], ",", 
         RowBox[{
          SubscriptBox[
           StyleBox["sgn", "TI"], 
