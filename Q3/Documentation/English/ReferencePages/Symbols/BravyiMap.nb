         SubscriptBox[
          StyleBox["\[CapitalSigma]", "TR"], 
          StyleBox["i", "TI"]], "\[VeryThinSpace]", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SubscriptBox[
            StyleBox["p", "TI"], 
            StyleBox["i", "TI"]]}], "\[VeryThinSpace]", ")"}], 
         StyleBox["\[Rho]", "TR"], 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SubscriptBox[
            StyleBox["p", "TI"], 
            StyleBox["i", "TI"]]}], ")"}]}]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "64ac7414-652e-4e15-9d90-1fc00eb27aa2"],
     "); or ",
     Cell[BoxData[
      RowBox[{
       StyleBox["v", "TI"], "\[Rule]", "2"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4d8dd708-202f-4443-832c-fe05329d4e98"],
     " otherwise."
    }],ExpressionUUID->"f41ab1b9-cbd4-47c9-9edf-56a33d3f8114"]}
  }]], "Usage",
 CellID->40386902,ExpressionUUID->"7c1010c3-97fe-449f-979b-3fb64af930cb"]
}, Open  ]],

