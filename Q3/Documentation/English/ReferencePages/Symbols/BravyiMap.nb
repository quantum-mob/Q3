      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a295f764-0da4-4e8b-bca4-9630ebf3839e"],
     ". The specification ",
     Cell[BoxData[
      SubscriptBox[
       StyleBox["spec", "TI"], 
       StyleBox["i", "TI"]]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "b3797dca-e50a-411e-897d-78fda47e0b54"],
     " of the form ",
     Cell[BoxData[
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["b", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["d", "TI"], 
          StyleBox["i", "TI"]]}], "}"}], "\[Rule]", 
       SubscriptBox[
        StyleBox["f", "TI"], 
        StyleBox["i", "TI"]]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f18dc752-5d26-4243-9e8e-7b33c4adcc12"],
     " means the action kernel of the block form ",
     Cell[BoxData[
      FormBox[
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           SubscriptBox["a", "i"], ",", 
           SubscriptBox["b", "i"]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", 
            SubsuperscriptBox["b", "i", "T"]}], ",", 
           SubscriptBox["d", "i"]}], "}"}]}], "}"}], TraditionalForm]],
      ExpressionUUID->"bd317fde-45b8-46d6-aed4-3d344d109db3"],
     " and prefactor ",
     Cell[BoxData[
      SubscriptBox[
       StyleBox["f", "TI"], 
       StyleBox["i", "TI"]]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "0eba669d-b3e0-422a-b821-5cf6d5ac9504"],
     ". The specification spec$i of the form ",
     Cell[BoxData[
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["b", "TI"], 
          StyleBox["i", "TI"]]}], "}"}], "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
          StyleBox["sgn", "TI"], 
          StyleBox["i", "TI"]], ",", 
         SubscriptBox[
          StyleBox["f", "TI"], 
          StyleBox["i", "TI"]]}], "}"}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e9d488ca-d0e3-4b5f-b30c-4db731ef5df1"],
     " is equivalent to ",
     Cell[BoxData[
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
