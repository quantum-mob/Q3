Cell[TextData[{
 "For \[Rho] given in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "307dfb7b-4f15-42fa-a7f7-e50976407f45"],
 " form and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData[
       RowBox[{
         StyleBox["msr", "TI"], ":=", "BravyiMeasurement"}]]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bf90b596-a616-45b9-9a61-f58a7455e2b1"],
 ", ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["msr", "TI"], "]"}], "[", 
   StyleBox["\[Rho]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f62f6a12-af2f-4c78-8010-7ad4c26394b6"],
 " or ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["msr", "TI"], ",", 
     TemplateBox[{
       Cell[
        TextData["False"]], "paclet:ref/False"},
      "RefLink",
      BaseStyle->{"InlineFormula"}]}], "]"}], "[", 
   StyleBox["\[Rho]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "246e5bff-c918-4b86-b658-440e9351ecc8"],
 " simulates the projective quantum operation, and returns the normalized \
Bravyi state corresponding to a single term  ",
 Cell[BoxData[
  RowBox[{"\[VeryThinSpace]", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "**", 
    StyleBox["\[Rho]", "TR"], "**", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9946a4cb-703c-414c-b19d-959e72914589"],
 " or ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SubscriptBox[
      StyleBox["p", "TI"], 
      StyleBox["i", "TI"]]}], ")"}], "**", 
   StyleBox["\[Rho]", "TR"], "**", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SubscriptBox[
      StyleBox["p", "TI"], 
      StyleBox["i", "TI"]]}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f4337330-155b-4784-806a-9232bec4b98b"],
 "."
}], "Notes",
 CellID->177829462,ExpressionUUID->"0701fe69-f194-4150-b10c-dc6829bae0ab"],

Cell[TextData[{
 "Similarly, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["msr", "TI"], ",", 
     TemplateBox[{
       Cell[
        TextData["True"]], "paclet:ref/True"},
      "RefLink",
      BaseStyle->{"InlineFormula"}]}], "]"}], "[", 
   StyleBox["\[Rho]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "af1b7e0a-feca-4caa-98cb-e46ff1924c35"],
 " simulates the projective quantum operation, and returns the normalized \
Bravyi state corresponding to a single term  ",
 Cell[BoxData[
  RowBox[{"\[VeryThinSpace]", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "**", 
    StyleBox["\[Rho]", "TR"], "**", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8e1da12b-a813-4556-ac2e-f7fc9e10c6eb"],
 "."
}], "Notes",
 CellID->397520239,ExpressionUUID->"671daf7a-6fca-42e4-ac45-d9add251bb07"],

Cell[TextData[{
 "Like ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData[
       RowBox[{
         StyleBox["msr", "TI"], ":=", "BravyiMeasurement"}]]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6aa78e43-2b3b-403c-be62-866647e68f16"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["msr", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7c23c77a-c6f0-4eac-aaaa-182c713e5ed1"],
 " handles the individual dressed ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " modes associated with different rows of matrix ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "248bd391-3719-4bf8-805c-3be7ac4882a9"],
 " separately. It does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " require different dressed modes to be orthogonal to each other. \
Nevertheless, each row ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "56b86373-a00e-4056-a275-c8320966dd13"],
 " must satisfy the condition ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Re"]], "paclet:ref/Re"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     TemplateBox[{
       Cell[
        TextData["v"]], "paclet:QuantumMob/Q3/ref/v"},
      "RefLink",
      BaseStyle->{"InlineFormula", "TI"}], "]"}], "\[CenterDot]", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Im"]], "paclet:ref/Im"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     TemplateBox[{
       Cell[
        TextData["v"]], "paclet:QuantumMob/Q3/ref/v"},
      "RefLink",
      BaseStyle->{"InlineFormula", "TI"}], "]"}]}], "==", "0"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "56580be1-1b72-4180-89fe-aae18b209bdd"],
 " to construct a proper dressed ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " mode ",
 Cell[BoxData[
  RowBox[{
   StyleBox["b", "TI"], ":=", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalSigma]", "TR"], 
     StyleBox["j", "TI"]], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["v", "TI"], 
     StyleBox["j", "TI"]], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["j", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cdbe3615-8d2e-4c5b-8bd1-992c5b9563b5"],
 " consisting of bare ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " modes ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c", "TI"], 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f5c1c4ca-8c7f-4ae4-b781-92d16e11c62f"],
 " and satisfy the fundamental anti-commutation relations ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", 
      SuperscriptBox["b", "\[Dagger]"]}], "}"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"b986f675-56cc-44b0-be83-d7efa2975924"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", "b"}], "}"}], "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox["b", "\[Dagger]"], ",", 
       SuperscriptBox["b", "\[Dagger]"]}], "}"}], "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"acab6256-6e35-42ce-b135-62db6595003c"],
 ". See the \"Details and Options\" section of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fd96e14c-ede3-4977-b4ea-2d72bae9c018"],
 " for more details."
}], "Notes",
 CellID->457815461,ExpressionUUID->"60e2baab-3bc4-4118-aec6-33d51e190c72"],

Cell[TextData[{
 "When applied to a Bravyi state (fermionic Gaussian state) \[Rho], ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMeasurement"]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8b21a22d-f044-48c2-a35a-cd9a3fb6065e"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["data", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "915c9234-8d89-4a7b-b8ee-cba5876763ac"],
 " from the same object  behave very differently. While ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2453198c-aaa5-4218-9c71-1e579c4712dd"],
 " performs a sequence of measurements ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TR"], "\[RightTeeArrow]", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalPi]", "TR"], 
     StyleBox["i", "TI"]], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "\[VeryThinSpace]", 
    StyleBox["\[Rho]", "TR"], "\[VeryThinSpace]\[ThinSpace]", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fc042aef-5277-43d8-a77a-f2d405c78479"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3b0b18b6-92a9-474d-af5b-2f6e9d234fd2"],
 " induces a single random collapse ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TR"], "\[RightTeeArrow]", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "\[VeryThinSpace]", 
    StyleBox["\[Rho]", "TR"], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cf8b3ab5-51f8-486b-bef8-9378b8e83efa"],
 " or ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TR"], "\[RightTeeArrow]", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SubscriptBox[
       StyleBox["p", "TI"], 
       StyleBox["i", "TI"]]}], "\[VeryThinSpace]", ")"}], 
    StyleBox["\[Rho]", "TR"], "\[ThinSpace]", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SubscriptBox[
       StyleBox["p", "TI"], 
       StyleBox["i", "TI"]]}], ")"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e88ef783-3c5e-4dfe-8db0-c82e2731637c"],
 " with probability ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tr"]], "paclet:ref/Tr"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "\[VeryThinSpace]", 
    StyleBox["\[Rho]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f7bbd641-79ef-4beb-8de7-5aaa750f6e01"],
 " or ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tr"]], "paclet:ref/Tr"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SubscriptBox[
       StyleBox["p", "TI"], 
       StyleBox["i", "TI"]]}], ")"}], "\[VeryThinSpace]", 
    StyleBox["\[Rho]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b65c2b6d-f933-4d1a-99fe-98ef08702f17"],
 "."
}], "Notes",
 CellID->1555979462,ExpressionUUID->"c14af7b4-c90c-49ab-8c21-7ccff1ed5980"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9ff5a5eb-6207-4d9e-a0b7-f51dfe1a2dba"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a6035297-5bf7-452b-9318-8bd093645749"],
 " are essentially equivalent and give the identical result. However, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "39e4bb3d-aa1a-47f4-8748-68b6d5079b73"],
 " is more efficient when one has to apply the same BravyiJump object many \
times."
}], "Notes",
 CellID->791728996,ExpressionUUID->"d21b287d-9cfa-4de1-8986-26b555e48ec2"],

Cell["The following options can be given: ", "Notes",
 CellID->788779930,ExpressionUUID->"cd2d5af7-06e6-46bc-b225-e1a0e2826c49"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "bf02dcf1-bb6c-493b-bffe-f4fd6b5368ed"], "\"\<Completion\>\"", 
    TemplateBox[{
      Cell[
       TextData["True"]], "paclet:ref/True"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], Cell[TextData[{
     "If True, the each row ",
     Cell[BoxData[
      StyleBox["v", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e7b290fb-3992-43e2-bf80-f91b1c39c389"],
     " in the measurement object is converted to converted to ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         StyleBox["v", "TI"], "\[Rule]", "2"}], ",", 
        RowBox[{
         StyleBox["v", "TI"], "\[Rule]", "3"}]}], "}"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "617eb867-ed8c-458e-b72d-86544be44f18"],
     " (corresponding to the nonselective measurement); or ",
     Cell[BoxData[
      RowBox[{
       StyleBox["v", "TI"], "\[Rule]", "2"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "96b992fb-5939-4cb1-b429-d6e005fa824c"],
     " otherwise. Effective only for the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"3ColumnTableMod"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "68347e83-58ac-4c85-a19f-b7238ba12882"],
     "-",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"3ColumnTableMod"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "5a91b21b-47a4-4283-9ac8-b24c30e52252"],
     " conversion."
    }], "TableText",ExpressionUUID->"78e7e246-8939-403d-8cb5-91777b67b21c"]}
  }]], "3ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{"Columns" -> {{None}}, "Rows" -> {{None}}},
 GridBoxDividers->{"Rows" -> {{True, True}}}},
 CellID->607730579,ExpressionUUID->"3046c990-a9b0-470c-876e-9b7ea3c6547c"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

Cell["", "PageDelimiter",ExpressionUUID->"b930c323-dfb3-4378-b3a3-234e2d553506"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  DynamicBox[ToBoxes[
    If[
     MatchQ[
      CurrentValue[
       EvaluationNotebook[], {
       TaggingRules, "Openers", "PrimaryExamplesSection"}, Open], 
      Alternatives[True, Open]], 
     Style[
      Graphics[{
        Thickness[0.18], 
        RGBColor[0.8509803921568627, 0.396078431372549, 0], 
        Line[{{-1.8, 0.5}, {0, 0}, {1.8, 0.5}}]}, AspectRatio -> 1, 
       PlotRange -> {{-3, 4}, {-1, 1}}, ImageSize -> 20], Magnification -> 
      0.68 Inherited], 
     Rotate[
      Style[
       Graphics[{
         Thickness[0.18], 
         RGBColor[0.8509803921568627, 0.396078431372549, 0], 
