      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d611f69f-cd9c-4140-ac61-f306e33d8824"],
     "."
    }],ExpressionUUID->"7ec4f6eb-432a-48de-8206-dfc182190040"]},
