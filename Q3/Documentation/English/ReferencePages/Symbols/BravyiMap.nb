Cell[TextData[{
 "For \[Rho] given in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5685b852-21fe-4333-baea-38deed0fc7e5"],
 " form and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData[
       RowBox[{
         StyleBox["msr", "TI"], ":=", "BravyiMeasurement"}]]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "032d377c-27c6-41bc-83be-c7d02ce739fe"],
 ", ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["msr", "TI"], "]"}], "[", 
   StyleBox["\[Rho]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9fe86aaf-db49-49df-998a-2e69f5de219a"],
 " or ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["msr", "TI"], ",", 
     TemplateBox[{
       Cell[
        TextData["False"]], "paclet:ref/False"},
      "RefLink",
      BaseStyle->{"InlineFormula"}]}], "]"}], "[", 
   StyleBox["\[Rho]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6463d9db-f453-45d0-9df6-84d003cc2a6d"],
 " simulates the projective quantum operation, and returns the normalized \
Bravyi state corresponding to a single term  ",
 Cell[BoxData[
  RowBox[{"\[VeryThinSpace]", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "**", 
    StyleBox["\[Rho]", "TR"], "**", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "072d9379-8a89-4dde-9a82-945409ab50db"],
 " or ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SubscriptBox[
      StyleBox["p", "TI"], 
      StyleBox["i", "TI"]]}], ")"}], "**", 
   StyleBox["\[Rho]", "TR"], "**", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SubscriptBox[
      StyleBox["p", "TI"], 
      StyleBox["i", "TI"]]}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "439d83bd-e7df-4bd2-9add-d5d3ec7ace4d"],
 "."
}], "Notes",
 CellID->177829462,ExpressionUUID->"5d262381-86e0-49f0-ba81-10160ede8804"],

Cell[TextData[{
 "Similarly, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["msr", "TI"], ",", 
     TemplateBox[{
       Cell[
        TextData["True"]], "paclet:ref/True"},
      "RefLink",
      BaseStyle->{"InlineFormula"}]}], "]"}], "[", 
   StyleBox["\[Rho]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1ce2b497-7a4d-4dde-95a9-b3c6a6a6ab32"],
 " simulates the projective quantum operation, and returns the normalized \
Bravyi state corresponding to a single term  ",
 Cell[BoxData[
  RowBox[{"\[VeryThinSpace]", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "**", 
    StyleBox["\[Rho]", "TR"], "**", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0d3ad367-caf7-44d6-880b-b260e21adf63"],
 "."
}], "Notes",
 CellID->397520239,ExpressionUUID->"d1f0b7be-4b78-4b8d-bf77-cb9f427227b8"],

Cell[TextData[{
 "Like ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData[
       RowBox[{
         StyleBox["msr", "TI"], ":=", "BravyiMeasurement"}]]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "762db11c-ca5a-4b87-8451-65a384554225"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["msr", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3ee1c3be-ceaa-43d9-967a-16016d1a83fd"],
 " handles the individual dressed ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " modes associated with different rows of matrix ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "326f0ed3-cd4d-4e79-b7d7-cbbde725871b"],
 " separately. It does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " require different dressed modes to be orthogonal to each other. \
Nevertheless, each row ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7bb6acf2-c206-44d8-859b-6ec0359dc660"],
 " must satisfy the condition ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Re"]], "paclet:ref/Re"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     TemplateBox[{
       Cell[
        TextData["v"]], "paclet:QuantumMob/Q3/ref/v"},
      "RefLink",
      BaseStyle->{"InlineFormula", "TI"}], "]"}], "\[CenterDot]", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Im"]], "paclet:ref/Im"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     TemplateBox[{
       Cell[
        TextData["v"]], "paclet:QuantumMob/Q3/ref/v"},
      "RefLink",
      BaseStyle->{"InlineFormula", "TI"}], "]"}]}], "==", "0"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3dafd217-4f5b-46f9-af19-1c876889283e"],
 " to construct a proper dressed ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " mode ",
 Cell[BoxData[
  RowBox[{
   StyleBox["b", "TI"], ":=", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalSigma]", "TR"], 
     StyleBox["j", "TI"]], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["v", "TI"], 
     StyleBox["j", "TI"]], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["j", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b9ac8e71-f50b-41a5-8ba7-1af40e7e3d66"],
 " consisting of bare ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " modes ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c", "TI"], 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ab383bd6-cae3-400d-86bd-655291653ff6"],
 " and satisfy the fundamental anti-commutation relations ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", 
      SuperscriptBox["b", "\[Dagger]"]}], "}"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"a42083d9-72c0-43e9-be51-c2b65774ad95"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", "b"}], "}"}], "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox["b", "\[Dagger]"], ",", 
       SuperscriptBox["b", "\[Dagger]"]}], "}"}], "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"65b572f5-4ab0-4e18-b333-4b76fdbf7564"],
 ". See the \"Details and Options\" section of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0a4f2705-b004-48ff-b05d-3bdbbc4152eb"],
 " for more details."
}], "Notes",
 CellID->457815461,ExpressionUUID->"0b5915de-737f-4754-b71e-48e15c441e5e"],

Cell[TextData[{
 "When applied to a Bravyi state (fermionic Gaussian state) \[Rho], ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMeasurement"]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cd74e96a-07f1-4700-97aa-4815915cf588"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["data", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1a44def2-3213-4c75-bdd9-d5e527b84348"],
 " from the same object  behave very differently. While ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2279fe58-0ad3-4554-bd0e-bfaf56e62128"],
 " performs a sequence of measurements ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TR"], "\[RightTeeArrow]", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalPi]", "TR"], 
     StyleBox["i", "TI"]], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "\[VeryThinSpace]", 
    StyleBox["\[Rho]", "TR"], "\[VeryThinSpace]\[ThinSpace]", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "27c0d056-ae0f-4568-be4c-7d2a8f4f503c"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a31b6261-501e-4317-bfc2-ef33fd87d4c1"],
 " induces a single random collapse ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TR"], "\[RightTeeArrow]", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "\[VeryThinSpace]", 
    StyleBox["\[Rho]", "TR"], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "74dd816b-7a4a-4ad7-afa1-24be6d7bb081"],
 " or ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TR"], "\[RightTeeArrow]", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SubscriptBox[
       StyleBox["p", "TI"], 
       StyleBox["i", "TI"]]}], "\[VeryThinSpace]", ")"}], 
    StyleBox["\[Rho]", "TR"], "\[ThinSpace]", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SubscriptBox[
       StyleBox["p", "TI"], 
       StyleBox["i", "TI"]]}], ")"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fb9f56ab-b159-492b-b6e9-63abebe8a9fa"],
 " with probability ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tr"]], "paclet:ref/Tr"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["i", "TI"]], "\[VeryThinSpace]", 
    StyleBox["\[Rho]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d078b4f2-e2e5-49dc-8c48-be841043d69c"],
 " or ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tr"]], "paclet:ref/Tr"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      SubscriptBox[
       StyleBox["p", "TI"], 
       StyleBox["i", "TI"]]}], ")"}], "\[VeryThinSpace]", 
    StyleBox["\[Rho]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "66dca204-3d61-41bf-9f8c-a11155b39132"],
 "."
}], "Notes",
 CellID->1555979462,ExpressionUUID->"5ea385d0-3b45-4bcf-b4c6-14c9917520bc"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "40314343-98ed-4c7d-b0f2-ea598c666ef4"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4a91bbba-bce2-42a6-b633-8287d7490805"],
 " are essentially equivalent and give the identical result. However, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "022baf74-8a03-46fe-934f-9c469d335e73"],
 " is more efficient when one has to apply the same BravyiJump object many \
times."
}], "Notes",
 CellID->791728996,ExpressionUUID->"ab33d9bf-c093-4df1-9399-02b892989398"],

Cell["The following options can be given: ", "Notes",
 CellID->788779930,ExpressionUUID->"c5690bc5-513c-4c7a-967c-6687e2cc8901"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "b40f81ad-ed61-467b-9c34-e4187e864407"], "\"\<Completion\>\"", 
    TemplateBox[{
      Cell[
       TextData["True"]], "paclet:ref/True"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], Cell[TextData[{
     "If True, the each row ",
     Cell[BoxData[
      StyleBox["v", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "7cf4943b-ec76-4b0f-9ea1-ea5b494a34a3"],
     " in the measurement object is converted to converted to ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         StyleBox["v", "TI"], "\[Rule]", "2"}], ",", 
        RowBox[{
         StyleBox["v", "TI"], "\[Rule]", "3"}]}], "}"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "b8baa3f0-7f46-4a52-929a-ec026eccf74f"],
     " (corresponding to the nonselective measurement); or ",
     Cell[BoxData[
      RowBox[{
       StyleBox["v", "TI"], "\[Rule]", "2"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f9e2d327-1950-47fa-b9cb-11b313b8aac3"],
     " otherwise. Effective only for the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"3ColumnTableMod"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6cca34e3-366e-4e9e-880b-c8aab670236a"],
     "-",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMap"]], "paclet:QuantumMob/Q3/ref/BravyiMap", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"3ColumnTableMod"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f274db61-30f2-4cca-837b-f18ba52a2b5e"],
     " conversion."
    }], "TableText",ExpressionUUID->"edf9a545-cafe-4f2a-9f97-f86c29246ba6"]}
  }]], "3ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{"Columns" -> {{None}}, "Rows" -> {{None}}},
 GridBoxDividers->{"Rows" -> {{True, True}}}},
 CellID->607730579,ExpressionUUID->"19ef2230-c120-458c-8182-830f80392377"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

Cell["", "PageDelimiter",ExpressionUUID->"170dfca3-c306-422b-ab72-5ef9be4e1c2a"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  DynamicBox[ToBoxes[
    If[
     MatchQ[
      CurrentValue[
       EvaluationNotebook[], {
       TaggingRules, "Openers", "PrimaryExamplesSection"}, Open], 
      Alternatives[True, Open]], 
     Style[
      Graphics[{
        Thickness[0.18], 
        RGBColor[0.8509803921568627, 0.396078431372549, 0], 
        Line[{{-1.8, 0.5}, {0, 0}, {1.8, 0.5}}]}, AspectRatio -> 1, 
       PlotRange -> {{-3, 4}, {-1, 1}}, ImageSize -> 20], Magnification -> 
      0.68 Inherited], 
     Rotate[
      Style[
       Graphics[{
         Thickness[0.18], 
         RGBColor[0.8509803921568627, 0.396078431372549, 0], 
         Line[{{-1.8, 0.5}, {0, 0}, {1.8, 0.5}}]}, AspectRatio -> 1, 
