Cell[TextData[{
 "Since Q3 v3.5.11, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CliffordFactor"]], "paclet:QuantumMob/Q3/ref/CliffordFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aeb146ea-299e-4235-80ea-9e48996c26b3"],
 " is based on the algorithm in ",
 ButtonBox["van den Berg (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1109/qce52317.2021.00021"], None}],
 ". Previously, it was based on Gottesman's theorem in ",
 ButtonBox["Gottesman (1998)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.57.127"], None}],
 "; see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["LegacyCliffordFactor"]], 
    "paclet:QuantumMob/Q3/ref/LegacyCliffordFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5a6f9731-2a4f-4471-8754-9d636fe0ce25"],
 ". While the latter provides a more compact set of (a bit higher-level) \
gates, the former is faster and easier to trace the changes in the sign of \
Pauli strings."
}], "Notes",
 CellID->982671809,ExpressionUUID->"60e99744-48eb-48d3-9d16-3deb871960d6"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

