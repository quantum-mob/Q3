Cell[TextData[{
 "The cross-entropy between two probability distributions ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "16c9164f-8be1-4c8b-8138-8bc326906081"],
 " and ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["q", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["q", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "eb5b3076-069a-4bc3-bf7f-fe4daa0c0a06"],
 " are defined by ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["ShannonLog"]], "paclet:QuantumMob/Q3/ref/ShannonLog", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["p", "TI"], 
        StyleBox["1", "TR"]], ",", 
       SubscriptBox[
        StyleBox["p", "TI"], 
        StyleBox["2", "TR"]], ",", 
       StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["q", "TI"], 
        StyleBox["1", "TR"]], ",", 
       SubscriptBox[
        StyleBox["q", "TI"], 
        StyleBox["2", "TR"]], ",", 
       StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"-", 
     SubscriptBox[
      StyleBox["\[CapitalSigma]", "TR"], 
      StyleBox["k", "TI"]]}], " ", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["k", "TI"]], " ", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Log"]], "paclet:ref/Log"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     SubscriptBox[
      StyleBox["q", "TI"], 
      StyleBox["k", "TI"]], "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "18688608-2903-47ef-857b-a44757c88fe3"],
 "."
}], "Notes",
 CellID->1795503136,ExpressionUUID->"042f6bec-43a7-4b50-b567-259dc9fc6178"],

Cell[TextData[{
 "The quantum cross-entropy between two density operators \[Rho] and \[Sigma] \
is defined by ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["QuantumLog"]], "paclet:QuantumMob/Q3/ref/QuantumLog", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["\[Rho]", "TR"], ",", 
     StyleBox["\[Sigma]", "TR"]}], "]"}], ":=", 
   RowBox[{"-", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Tr"]], "paclet:ref/Tr"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     RowBox[{
      StyleBox["\[Rho]", "TR"], " ", 
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["Log"]], "paclet:ref/Log"},
        "RefLink",
        BaseStyle->{"InlineFormula"}], "[", 
       StyleBox["\[Sigma]", "TR"], "]"}]}], "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "58c7bce3-6a85-4ddf-9211-8aa583c18edc"],
 "."
}], "Notes",
 CellID->909720298,ExpressionUUID->"69f7f3c0-fd83-433e-aecf-45f0fda75f90"],

Cell[TextData[{
 "The cross entropy measures the difference between two probability \
distributions or quantum states; see also the classical and quantum ",
 StyleBox["relative entropies",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1795278045,ExpressionUUID->"da83a502-aef8-4b77-8c87-842d406776fb"],

Cell[TextData[{
 "More specifically, in classical information theory, it measures the average \
number of bits required to identify an event drawn from the set when the \
coding scheme used for the set is optimized for an estimated probability \
distribution ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["q", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["q", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "91b4f35e-22bf-4a5a-ad54-08aa953b6aa4"],
 ", rather than the true distribution ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "77cf524a-75dd-4dbb-9a98-29e77c5fa30a"],
 "."
}], "Notes",
 CellID->229615705,ExpressionUUID->"6b1afa8f-3e26-4dbe-81c3-0c41e6be848f"],

Cell[TextData[{
 "The quantum cross entropy is frequently used for the cross entropy \
benchmarking (XEB); see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Arute et al. (2019)"]], 
    "https://doi.org/10.1038/s41586-019-1666-5"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "7fc0c1ad-4225-4d93-8017-64e352b2bf0d"],
 "."
}], "Notes",
 CellID->975159217,ExpressionUUID->"2119c513-7ec0-4a4f-880d-3f117decaf22"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

