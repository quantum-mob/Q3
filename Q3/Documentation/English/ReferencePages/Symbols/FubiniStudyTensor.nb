Cell["\<\
The quantum geometric tensor (QGT) is a complex-valued tensor that \
characterizes the local geometry of quantum states in parameter space. It \
encodes both the distance and phase structure of quantum states, providing a \
unified framework for understanding quantum geometry and topology.\
\>", "Notes",
 CellID->1984473323,ExpressionUUID->"13f7b81e-f055-4ec9-aad4-d29c4bd250c2"],

Cell[TextData[{
 "The QGT is defined as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["\[PartialD]", "\[Mu]"], "\[Psi]"}]},
       "Bra"], "(", 
      RowBox[{"I", "-", 
       RowBox[{
        TemplateBox[{"\[Psi]"},
         "Ket"], 
        TemplateBox[{"\[Psi]"},
         "Bra"]}]}], ")"}], 
     TemplateBox[{
       RowBox[{
         SubscriptBox["\[PartialD]", "\[Nu]"], "\[Psi]"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "6d3b6ab8-612d-49d8-8baf-c0d217f57f4c"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "9e00730d-24e7-4971-8992-57cfdea66ae7"],
 " is the quantum state and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "04a667a3-7325-4f78-8e46-64307a3a664d"],
 " denotes the derivative with respect to parameter ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "b64de5a5-2c3e-4ae2-98de-ce37044c19d9"],
 ". Note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "-", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], 
     TemplateBox[{"\[Psi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "bc8cbb12-fdc4-4d02-a724-9e8c0d25cedb"],
 " projects onto the subspace orthogonal to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "caa785b4-1db2-4d07-a7ae-aef329e2b2d9"],
 "."
}], "Notes",
 CellID->677884236,ExpressionUUID->"69865a5b-1d4b-4299-a653-82eab1be3a0a"],

Cell[TextData[{
 "The real part, i.e., the symmetric part, of the QGP, is called the ",
 StyleBox["Fubini-Study metric",
  FontSlant->"Italic"],
 " and measures the distance between nearby quantum states."
}], "Notes",
 CellID->1501045863,ExpressionUUID->"a6e9a815-40e4-478d-a571-630e1a828fcb"],

Cell[TextData[{
 "The imaginary part, i.e., the anti-symmetric part, of the QGT, corresponds \
to the ",
 StyleBox["Berry curvature",
  FontSlant->"Italic"],
 " and encodes topological properties such as geometric phases and Chern \
numbers."
}], "Notes",
 CellID->1170758950,ExpressionUUID->"344f3933-0fd7-4389-896d-83e38513a46c"],

Cell["\<\
The QGT provides complete information about the geometry of quantum states: \
The Fubini-Study metric quantifies how \[OpenCurlyDoubleQuote]far apart\
\[CloseCurlyDoubleQuote] quantum states are in parameter space whereas the \
Berry curvature reveals the topological nature of quantum systems, \
influencing transport properties and phase transitions.\
\>", "Notes",
 CellID->1347478979,ExpressionUUID->"370710b0-781e-4efd-83e3-452922e8c2d6"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["g", "TI"]]}], "}"}], ",", 
    StyleBox["vec", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d9bccd84-38e2-47b6-8baf-a029756fbf72"],
 " calculates the Fubini-Study metric tensor under a special condition as \
follows (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Stokes et al., 2020"]], 
    "https://doi.org/10.22331/q-2020-05-25-269"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "4dada870-d33e-47d8-a3ba-7f402152426c"],
 "): Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"V", "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "af9b952c-2507-42af-a528-7e3e5bbe87f7"],
 ". There exists a Hermitian generator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "0f245f98-722f-44f2-9e05-260bc1a662a0"],
 " such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], "V"}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", "\[Mu]"], "V"}]}], TraditionalForm]],ExpressionUUID->
  "5d06ab87-d720-447e-9eac-47a4b293f35d"],
 " .\[LineSeparator]The crucial assumption is that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], 
     SubscriptBox["H", "\[Nu]"]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"b73200a0-b30b-43c5-9fc1-bc99c9e36fd4"],
 ". This in turn implies that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], ",", 
      SubscriptBox["H", "\[Nu]"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"965d3a9e-be93-44ce-afe0-65bee2408171"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "\[Nu]"}], TraditionalForm]],
  ExpressionUUID->"7436d379-8503-4907-82d4-3e0c18604745"],
 ". Then, the QGT is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}], "-", 
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"], 
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "22bd0faa-198d-4ff6-815f-a24cfe1cb944"],
 ".\[LineSeparator]Since the generators are commuting with each other, the \
Fubini-Study metric tensor is identical to the QGT in this case."
}], "Notes",
 CellID->1393278909,ExpressionUUID->"8c604763-7e09-4670-964f-c42f386a1bc4"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["11", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["12", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["21", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["22", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["l", "TI"]]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7c4667bc-fcb2-453f-86fc-907dd6eb4a35"],
 " gives an block-diagonal approximation of the Fubini-Study tensor. It \
assumes the parametrized quantum state of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "9690c242-dc03-4cf9-b6df-889c5911dbeb"],
 ",\[LineSeparator]where the overall unitary gate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "L"], TraditionalForm]],ExpressionUUID->
  "0a4c8657-464e-4818-aa5c-8af6e27ee2d1"],
 " is composed of ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "641a6d03-fb9e-4003-a503-8b0fed71a29d"],
 " layers in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"k", "=", "1"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "6d18492d-ca28-4c64-ac05-9e8cf8babd54"],
 " .\[LineSeparator]Each layer has two parts (or sub-layers), the \
parametrization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "8b4e08dc-3701-4078-9c6b-568cacdbdd95"],
 " with parameters\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "k"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "1"}]], ",", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]"}], ")"}], 
     "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", 
      SubscriptBox["g", "k"]]}]}], TraditionalForm]],ExpressionUUID->
  "02ea6f58-d347-4c0e-ace8-7646782e5d04"],
 "\nand the non-parametrization part ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["W", "k"], TraditionalForm]],ExpressionUUID->
  "10614517-7fb8-416a-98fc-46038a0e5329"],
 " containing parameters.\[LineSeparator]Naturally, the overall parameters ",
 Cell[BoxData[
  FormBox["\[Theta]", TraditionalForm]],ExpressionUUID->
  "bcb6848a-a344-4166-adb8-2b7544ee2e3c"],
 " consist of\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Theta]", "1"], "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "2"], "\[CirclePlus]", "\[CenterEllipsis]", "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "L"]}], "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"fba75ee7-37c6-4312-a199-ba7671cfa678"],
 "\[LineSeparator] with  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Congruent]", 
    RowBox[{"L", "\[VeryThinSpace]", "g"}]}], TraditionalForm]],
  ExpressionUUID->"5a874654-8240-4398-99db-bdfb83f59cb3"],
 ". The parameterization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "978be41e-5124-49b4-ad3a-d81df8d26f90"],
 " of each layer is characterized by a set of Hermitian generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["H", 
        RowBox[{"k", ",", "\[Mu]"}]], ":", "\[Mu]"}], "=", "1"}], ",", "2", ",",
      "\[Ellipsis]", ",", "g"}], "}"}], TraditionalForm]],ExpressionUUID->
  "17aa2432-5916-40fa-a501-6bfc3e8e66cc"],
 " such that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", ",", "\[Mu]"}]]}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", 
      RowBox[{"k", ",", "\[Mu]"}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"6fdbe5a3-5d67-48b7-8810-e511f1e425f7"],
 " .\[LineSeparator]The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "89b0256e-f6bb-4ddd-a5a8-6a6558985f92"],
 " bock of the approximate Fubini-Study tensor is calculated at state vector\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox["\[Psi]", "k"], "(", 
        SubscriptBox["\[Theta]", "k"], ")"}]},
     "Ket"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"l", "=", "k"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"], 
      TemplateBox[{
        SubscriptBox["\[Psi]", "0"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "04af88df-c24b-43e4-b85d-7a8823350246"],
 " .\[LineSeparator]The overall block-diagonal tensor is regarded as an \
approximation at the final state vector ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["v", "TI"], 
   StyleBox["l", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6b9de454-de78-4e63-a326-fa2c75fd6b05"],
 "."
}], "Notes",
 CellID->2055687195,ExpressionUUID->"f7c2e960-53c9-4321-b4cd-3fcb23a707b1"],

Cell[TextData[{
 "Each state vector is supposed to be normalized, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "59654f6b-190a-44e6-a6d5-50e3ffb10652"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->362091143,ExpressionUUID->"2a0776f9-0a60-40d5-a9d2-905e2fddc97a"],

Cell[TextData[{
 "Each generator is supposed to be a Hermitian matrix, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "32f3a589-1bd8-4700-ad10-3ecba3224b80"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->18454412,ExpressionUUID->"ae8a7d2b-694c-4590-bff2-09b70549e595"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

