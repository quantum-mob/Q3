Cell["\<\
The quantum geometric tensor (QGT) is a complex-valued tensor that \
characterizes the local geometry of quantum states in parameter space. It \
encodes both the distance and phase structure of quantum states, providing a \
unified framework for understanding quantum geometry and topology.\
\>", "Notes",
 CellID->1984473323,ExpressionUUID->"3e83c7d3-e463-41a1-b155-e26a6c60ed61"],

Cell[TextData[{
 "The QGT is defined as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["\[PartialD]", "\[Mu]"], "\[Psi]"}]},
       "Bra"], "(", 
      RowBox[{"I", "-", 
       RowBox[{
        TemplateBox[{"\[Psi]"},
         "Ket"], 
        TemplateBox[{"\[Psi]"},
         "Bra"]}]}], ")"}], 
     TemplateBox[{
       RowBox[{
         SubscriptBox["\[PartialD]", "\[Nu]"], "\[Psi]"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "c4a0a82f-48fb-4560-a879-14caff71067c"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b2763fb7-618a-4466-be07-2a94912298d4"],
 " is the quantum state and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "22fd5045-f92f-4034-83fe-005cc2c11c2b"],
 " denotes the derivative with respect to parameter ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "778102d1-5d33-4b29-9ae3-787bfe4c634a"],
 ". Note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "-", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], 
     TemplateBox[{"\[Psi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "5f488800-2fac-40b1-a68e-ac06c31d7a18"],
 " projects onto the subspace orthogonal to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "05c50b99-edc9-489e-9f2b-3a650f9b06c6"],
 "."
}], "Notes",
 CellID->677884236,ExpressionUUID->"95fe93db-db2f-4cc7-950c-552bdf9d89d3"],

Cell[TextData[{
 "The real part, i.e., the symmetric part, of the QGP, is called the ",
 StyleBox["Fubini-Study metric",
  FontSlant->"Italic"],
 " and measures the distance between nearby quantum states."
}], "Notes",
 CellID->1501045863,ExpressionUUID->"cd382db2-c3ce-4b5b-bd6d-2e91a723e3d8"],

Cell[TextData[{
 "The imaginary part, i.e., the anti-symmetric part, of the QGT, corresponds \
to the ",
 StyleBox["Berry curvature",
  FontSlant->"Italic"],
 " and encodes topological properties such as geometric phases and Chern \
numbers."
}], "Notes",
 CellID->1170758950,ExpressionUUID->"4e930aa6-61c8-4352-8cf0-385b1576e89a"],

Cell["\<\
The QGT provides complete information about the geometry of quantum states: \
The Fubini-Study metric quantifies how \[OpenCurlyDoubleQuote]far apart\
\[CloseCurlyDoubleQuote] quantum states are in parameter space whereas the \
Berry curvature reveals the topological nature of quantum systems, \
influencing transport properties and phase transitions.\
\>", "Notes",
 CellID->1347478979,ExpressionUUID->"ab797af2-b42f-47c5-88bc-aab80504ce9d"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["g", "TI"]]}], "}"}], ",", 
    StyleBox["vec", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4a4489b2-1340-4132-bb9d-d28ce036d838"],
 " calculates the Fubini-Study metric tensor under a special condition as \
follows (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Stokes et al., 2020"]], 
    "https://doi.org/10.22331/q-2020-05-25-269"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "f13b1b14-7aa1-4f87-b34c-15cb98278e59"],
 "): Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"V", "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "42b09688-ece9-4f72-be80-242130d6e059"],
 ". There exists a Hermitian generator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "dd3c69ed-cc5a-4569-9ca0-f92411341759"],
 " such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], "V"}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", "\[Mu]"], "V"}]}], TraditionalForm]],ExpressionUUID->
  "6e9e3819-9d89-47e4-9774-7b54bc674678"],
 " .\[LineSeparator]The crucial assumption is that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], 
     SubscriptBox["H", "\[Nu]"]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"4aab107d-c9d9-4fea-99af-c3eab87e7c11"],
 ". This in turn implies that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], ",", 
      SubscriptBox["H", "\[Nu]"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"5dba2555-eda6-4a07-94bf-4a8897e4ac6d"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "\[Nu]"}], TraditionalForm]],
  ExpressionUUID->"56b01e91-caf0-43b0-97d6-a0a3a329692b"],
 ". Then, the QGT is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}], "-", 
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"], 
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c5ea33d0-2494-412b-802e-c2543d661069"],
 ".\[LineSeparator]Since the generators are commuting with each other, the \
Fubini-Study metric tensor is identical to the QGT in this case."
}], "Notes",
 CellID->1393278909,ExpressionUUID->"c7ce2c0d-7fbe-4ed0-bbb7-25940f4255fd"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["11", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["12", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["21", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["22", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["l", "TI"]]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e2f1194c-62d7-4ad3-9daa-91264fa72415"],
 " gives an block-diagonal approximation of the Fubini-Study tensor. It \
assumes the parametrized quantum state of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "1246eae2-5481-4bf8-bcdf-4ff5f03bea4c"],
 ",\[LineSeparator]where the overall unitary gate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "L"], TraditionalForm]],ExpressionUUID->
  "0e840799-718d-49bc-8cfd-f8b91b384b1b"],
 " is composed of ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "2918d3ae-10de-4ef7-b422-005e067b0d6b"],
 " layers in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"k", "=", "1"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "54050bc7-1857-4398-9d44-8d725224a48d"],
 " .\[LineSeparator]Each layer has two parts (or sub-layers), the \
parametrization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "12fe9c83-9a01-44dc-bfef-50afdf9477e2"],
 " with parameters\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "k"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "1"}]], ",", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]"}], ")"}], 
     "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", 
      SubscriptBox["g", "k"]]}]}], TraditionalForm]],ExpressionUUID->
  "5b428b73-2a69-4335-98bf-5fa7cda9b0ab"],
 "\nand the non-parametrization part ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["W", "k"], TraditionalForm]],ExpressionUUID->
  "ed722ed9-ded1-412c-b2d6-74728f9e1d2c"],
 " containing parameters.\[LineSeparator]Naturally, the overall parameters ",
 Cell[BoxData[
  FormBox["\[Theta]", TraditionalForm]],ExpressionUUID->
  "469f1018-c382-47ec-996e-f8b6fdac0145"],
 " consist of\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Theta]", "1"], "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "2"], "\[CirclePlus]", "\[CenterEllipsis]", "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "L"]}], "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"427da609-d148-4e31-895f-1c357c52fdd0"],
 "\[LineSeparator] with  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Congruent]", 
    RowBox[{"L", "\[VeryThinSpace]", "g"}]}], TraditionalForm]],
  ExpressionUUID->"cff90ae8-d722-4048-bc87-e54c8facc208"],
 ". The parameterization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "f63f8eaf-fd18-43bf-9e8c-8dceb1d77139"],
 " of each layer is characterized by a set of Hermitian generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["H", 
        RowBox[{"k", ",", "\[Mu]"}]], ":", "\[Mu]"}], "=", "1"}], ",", "2", ",",
      "\[Ellipsis]", ",", "g"}], "}"}], TraditionalForm]],ExpressionUUID->
  "617391bc-ccd0-42e7-8375-9e2f5cdacb9c"],
 " such that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", ",", "\[Mu]"}]]}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", 
      RowBox[{"k", ",", "\[Mu]"}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"d6c4bcb0-0492-442e-9e99-8dde4d664293"],
 " .\[LineSeparator]The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "842bfdde-a059-4d3e-a7b5-617fe26fb60a"],
 " bock of the approximate Fubini-Study tensor is calculated at state vector\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox["\[Psi]", "k"], "(", 
        SubscriptBox["\[Theta]", "k"], ")"}]},
     "Ket"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"l", "=", "k"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"], 
      TemplateBox[{
        SubscriptBox["\[Psi]", "0"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "5925dad4-a339-4568-80f8-6370226e22b8"],
 " .\[LineSeparator]The overall block-diagonal tensor is regarded as an \
approximation at the final state vector ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["v", "TI"], 
   StyleBox["l", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c2dc51f6-5504-4a34-9744-9bea9557dedd"],
 "."
}], "Notes",
 CellID->2055687195,ExpressionUUID->"fd3ae047-47b8-4daa-9632-ebcbf164cf29"],

Cell[TextData[{
 "Each state vector is supposed to be normalized, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "49a557ba-babe-464a-9988-d7d7763b0c05"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->362091143,ExpressionUUID->"94aefddc-08a5-48d9-b7e5-008e1bc912aa"],

Cell[TextData[{
 "Each generator is supposed to be a Hermitian matrix, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fa0c7533-c5bc-43ff-b355-02716cb872f9"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->18454412,ExpressionUUID->"522eebcd-47e4-4740-833f-aa630570c65b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

