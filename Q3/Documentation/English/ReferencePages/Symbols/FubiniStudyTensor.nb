Cell["Take a set of parameters:", "ExampleText",
 CellID->1241174127,ExpressionUUID->"e7e5a88e-4b6f-4d47-a893-88b198fbdf9c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Real", ",", "x"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"xx", "=", 
  RowBox[{"x", "[", "kk", "]"}]}]}], "Input",
