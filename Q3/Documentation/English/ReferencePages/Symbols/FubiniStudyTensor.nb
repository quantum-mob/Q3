Cell["Take a set of parameters:", "ExampleText",
 CellID->1241174127,ExpressionUUID->"1efe6ebd-2af9-483f-a461-9b031d1a5908"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Real", ",", "x"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"xx", "=", 
