   "built" -> "{2026, 2, 25, 11, 8, 24.064859}", 
    "history" -> {"14.2", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {"quantum natural gradient"}, "specialkeywords" -> {}, 
    "tutorialcollectionlinks" -> {}, "index" -> True, "label" -> 
    "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> "QuantumMob/Q3",
     "status" -> "None", "summary" -> 
    "FubiniStudyTensor[vec, {x1, x2, ...}] returns an expression of the \
Fubini-Study metric tensor at the state vector vec parametrized with \
parameters {x1, x2, ...}. FubiniStudyTensor[vec, {x1, x2, ...}, {a1, a2, \
...}] returns the Fubini-Study metric tensor at state vector vec (a1, a2, \
...) at the parameter values x1 = a1, x2 = a2, ..... FubiniStudyTensor[{m1, \
m2, ..., mg}, vec] is identical to QuantumGeometricTensor[{m1, m2, ..., mg}, \
vec]. FubiniStudyTensor[{m1, m2, ..., mg}, {v1, v2, ..., vl}] is identical to \
QuantumGeometricTensor[{m1, m2, ..., mg}, {v1, v2, ..., vl}]. \
FubiniStudyTensor[{{m11, m12, ...}, {m21, m22, ...}, ...}, {v1, v2, ..., vl}] \
is identical to QuantumGeometricTensor[{{m11, m12, ...}, {m21, m22, ...}, \
...}, {v1, v2, ..., vl}].", "synonyms" -> {}, "tabletags" -> {}, "title" -> 
    "FubiniStudyTensor", "titlemodifier" -> "", "metadescription" -> "", 
    "windowtitle" -> "FubiniStudyTensor", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/FubiniStudyTensor"}},
