Cell[TextData[{
 "One can test if a given matrix is a Pauli matrix using ",
 ButtonBox["PauliCoefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliCoefficients"],
 ". However, it is too slow for a large number of qubits (8 or more qubits)."
}], "ExampleText",
 CellID->1185061341,ExpressionUUID->"599a6f14-af06-4563-b5d0-a38380033f3b"],

