Cell[TextData[{
 "Here, we compare the performances of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["DualSchurBasis"]], "paclet:QuantumMob/Q3/ref/DualSchurBasis", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f334e4bf-c023-4fc7-ba43-1bed82638dd4"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["SchurBasis"]], "paclet:QuantumMob/Q3/ref/SchurBasis", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a2d85a36-785c-48c7-81fd-89e096dee741"],
 ". Since ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["DualSchurBasis"]], "paclet:QuantumMob/Q3/ref/DualSchurBasis", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "03c8f910-f42b-4c70-a1cf-5a369fd85103"],
 " is entirely based on sparse arrays, it is faster than ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["SchurBasis"]], "paclet:QuantumMob/Q3/ref/SchurBasis", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6bce55de-4557-4971-9f59-ca0c57eab1fa"],
 " (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["SchurBasis"]], "paclet:QuantumMob/Q3/ref/SchurBasis", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7399e2fd-b5b4-4d35-b123-cb39e07726f7"],
 " to be reimplemented based sparse array as well.)"
}], "ExampleText",
 CellID->1103060693,ExpressionUUID->"e93acc04-ca51-4f5f-bb4c-b951d6007087"],

