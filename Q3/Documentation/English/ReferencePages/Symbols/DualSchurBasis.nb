Cell["\<\
Calculate the Schur basis by means of the quantum Schur transform (BCH \
algorithm). Currently, the implementation of this method does not actively \
use sparse array, and is slower:\
\>", "ExampleText",
 CellID->1314857165,ExpressionUUID->"6e0497b9-59f3-4010-ac7f-56965c616dae"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"sbs", "=", 
    RowBox[{"SchurBasis", "[", "AA", "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sbs", "=", 
   RowBox[{"KeyMap", "[", 
    RowBox[{
     RowBox[{"Map", "[", "YoungTableau", "]"}], ",", "sbs"}], "]"}]}], 
  ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1511710137,ExpressionUUID->"5514210a-f861-4ae1-bc92-c621122e7405"],

Cell[BoxData["13.596025`"], "EchoTiming",
 CellID->1079987203,ExpressionUUID->"4b9d84ae-c74c-4789-818e-1be8f6077e56"]
}, Open  ]],

