      FontFamily->"Source Sans Pro",ExpressionUUID->
      "65f06954-e230-4f29-81af-f6dea05b3e0e"],
     " particles each associated with a ",
     Cell[BoxData[
      StyleBox["d", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c1569b63-98df-40e1-a60c-8c25a64f8c7e"],
     "-dimensional Hilbert space, i.e., ",
     Cell[BoxData[
      SuperscriptBox[
       RowBox[{"(", 
        SuperscriptBox["\[DoubleStruckCapitalC]", 
         StyleBox["d",
          FontSlant->"Italic"]], ")"}], 
       RowBox[{"\[CircleTimes]", 
        StyleBox["n",
         FontSlant->"Italic"]}]]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ad739c6d-879e-4218-b411-9d0838f3477c"],
     "."
    }],ExpressionUUID->"e40721b3-0ab9-4b54-abdd-e4d25dc30e35"]},
