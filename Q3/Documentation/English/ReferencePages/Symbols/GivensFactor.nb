Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GivensFactor"]], "paclet:QuantumMob/Q3/ref/GivensFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "32140071-4d56-4d0f-8efe-d01b33e59a6a"],
 " is much more efficient than ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GrayGivensFactor"]], 
    "paclet:QuantumMob/Q3/ref/GrayGivensFactor", "QuantumMob Package Symbol"},
   
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "096f8eee-43b5-44ce-9e17-288fd4fb8457"],
 ", and the latter must be used only for heuristic purposes. See ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Nielsen and Chuang (2022)"]], 
    "https://doi.org/10.1017/CBO9780511976667"},
   "WebLink",
   BaseStyle->{"Notes", FontSlant -> "Plain"}]],ExpressionUUID->
  "a669bf06-e6a2-4c59-bc87-89f0ca4f18ac"],
 StyleBox[".",
  FontSlant->"Plain"]
}], "Notes",
 CellID->872497501,ExpressionUUID->"e2189e7f-3311-475a-90e2-d8dbb957ebed"],

Cell[TextData[{
 "While ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GrayGivensFactor"]], 
    "paclet:QuantumMob/Q3/ref/GrayGivensFactor", "QuantumMob Package Symbol"},
   
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "570da557-db7f-4236-9132-1c60019cab2d"],
 " follows rather naively the idea based on the Gray code as explained in \
Nielsen and Chuang (2011),  ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GivensFactor"]], "paclet:QuantumMob/Q3/ref/GivensFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d48cd0ce-66e6-408d-9eb5-2cc5f8aa4e59"],
 " has minimized the number of required CNOT gates. See ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
     "Vartiainen, M\[ODoubleDot]tt\[ODoubleDot]nen, and Salomaa, (2004)"]], 
    "https://doi.org/10.1103/PhysRevLett.92.177902"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "8540f7b9-0587-446f-a78a-9b3135fd7a33"],
 "."
}], "Notes",
 CellID->25262995,ExpressionUUID->"0dac4c5e-f561-4e2b-966c-16e134685769"]
}, Dynamic[CurrentValue[
