Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", "2"], "+", 
     FractionBox["\[ImaginaryI]", "2"]}], ")"}], " ", 
   InterpretationBox["\<\"I\"\>",
    Q3`Pauli[{0}]]}], "+", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", "2"], "-", 
     FractionBox["\[ImaginaryI]", "2"]}], ")"}], " ", 
   InterpretationBox["\<\"Z\"\>",
