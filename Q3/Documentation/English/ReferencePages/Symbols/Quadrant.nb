Cell[TextData[{
 "The quadrant phase gate is import in that the quadrant, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3aa62622-aa1a-404f-ae44-48c95204556e"],
 ", and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CNOT"]], "paclet:QuantumMob/Q3/ref/CNOT", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5b0f48a3-a99d-4e69-9763-873412fbd718"],
 " gates generate the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 "."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"dfcee3d4-d63a-48b3-adc5-8c3e2bfc6b50"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Quadrant"]], "paclet:QuantumMob/Q3/ref/Quadrant", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["k", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["k", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d99b96ea-04c9-4568-844f-1bb973f47cea"],
 " for integers ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["k", "TI"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["k", "TI"], 
    StyleBox["2", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "703f7c4c-9fee-4293-a7e9-69162c7f082c"],
 " represents the tensor-product of quadrant gates on qubits ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["k", "TI"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["k", "TI"], 
    StyleBox["2", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "26dbc480-0aca-465d-a0b2-5eeff56229f8"],
 ". It is handled efficiently when operating on a ",
 ButtonBox["full Gottesman vector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullGottesmanVector"],
 " or on ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CliffordState"]], "paclet:QuantumMob/Q3/ref/CliffordState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fb345c5a-4242-4fc9-95d6-a7b59c239f77"],
 " in ",
 ButtonBox["Clifford quantum circuits",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/CliffordQuantumCircuits"],
 ". See the ",
 ButtonBox["Interactive Examples",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Quadrant#942260787"],
 " section."
}], "Notes",
 CellID->662698285,ExpressionUUID->"789405e7-feda-4b6c-9616-191434673bf0"],

