Cell[TextData[{
 "The quadrant phase gate is import in that the quadrant, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9fb730b6-e950-4eb0-94ee-e64f3cec60d9"],
 ", and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CNOT"]], "paclet:QuantumMob/Q3/ref/CNOT", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "70c0e9cc-ec37-4b98-a6ee-45abbd86f768"],
 " gates generate the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 "."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"b540e764-7c5b-4f96-8f43-27b9eccec37e"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Quadrant"]], "paclet:QuantumMob/Q3/ref/Quadrant", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["k", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["k", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b0405ffc-040a-4161-bda1-7ec1412d4495"],
 " for integers ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["k", "TI"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["k", "TI"], 
    StyleBox["2", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "685884c4-a8a6-4274-8949-818c8bd0b3d9"],
 " represents the tensor-product of quadrant gates on qubits ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["k", "TI"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["k", "TI"], 
    StyleBox["2", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e50c9baa-d20d-4b2c-b9bd-c1ef6b85c1ff"],
 ". It is handled efficiently when operating on a ",
 ButtonBox["full Gottesman vector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullGottesmanVector"],
 " or on ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CliffordState"]], "paclet:QuantumMob/Q3/ref/CliffordState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "70a76829-408e-4877-b18d-e3112b026979"],
 " in ",
 ButtonBox["Clifford quantum circuits",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/CliffordQuantumCircuits"],
 ". See the ",
 ButtonBox["Interactive Examples",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Quadrant#942260787"],
 " section."
}], "Notes",
 CellID->662698285,ExpressionUUID->"facf0a30-3ed5-42f9-9402-a6568e78e48c"],

