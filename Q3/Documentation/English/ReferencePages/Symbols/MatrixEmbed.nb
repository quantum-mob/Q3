TaggingRules->{
 "ModificationHighlight" -> False, "ColorType" -> "", "LinkTrails" -> "", 
  "ExampleCounter" -> 1, 
  "Openers" -> {
   "PrimaryExamplesSection" -> Open, "ExampleSection" -> {"0" -> Open}, 
    "AllOptsTable" -> Closed}, "NewStyles" -> True, 
  "CitationPopupData" -> $Failed, "ShowCitation" -> False, "HasOptions" -> 
  True, "RootCaptions" -> "", "HeaderCoreAreaLink" -> {}, 
  "Metadata" -> {
   "built" -> "{2026, 7, 9, 11, 47, 42.333395}", 
    "history" -> {"13.2", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {"linear algebra", "matrix manipulation"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "MatrixEmbed[mat, {s1, s2, ...}, {t1, t2, ...}] returns the \
fully-expanded form of matrix mat that acts on the entire Hilbert space of \
species {t1, t2, ...}, where mat represents a linear operator on the Hilbert \
space of species {s1, s2, ...} \\[Subset] {t1, t2, ...}. MatrixEmbed[mat, \
{k1, k2, ...}, {dim1, dim2, ...}] assumes that mat represents a linear \
operator on the Hilbert space of dimensions dim Subscript[k, 1], dim \
Subscript[k, 2], .... MatrixEmbed[mat, {k1, k2, ...}, n -> d] is equivalent \
to MatrixEmbed[mat, {k1, k2, ...}, Table[d, n]]. MatrixEmbed[mat, {k1, k2, \
...}, n] is equivalent to MatrixEmbed[mat, {k1, k2, ...}, {2, 2, ...}]. \
MatrixEmbed[{s1, s2, ...}, {t1, t2, ...}] and MatrixEmbed[{k1, k2, ...}, \
{dim1, dim2, ...}] represent operator forms of MatrixEmbed.", 
    "synonyms" -> {}, "tabletags" -> {}, "title" -> "MatrixEmbed", 
    "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "MatrixEmbed", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/MatrixEmbed"}},
