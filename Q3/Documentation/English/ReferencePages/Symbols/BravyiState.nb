Cell[TextData[{
 "Any fermionic Gaussian state of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "be995a2b-7995-4470-a829-8b1ce968d38a"],
 " fermion modes can be written as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     FractionBox["\[ScriptCapitalN]", 
      SuperscriptBox["2", "n"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "n"]}]}], TraditionalForm]],ExpressionUUID->
  "e6cfb6da-9f7d-4056-97c0-8602e72808f7"],
 "(1+\[ImaginaryI]\[VeryThinSpace]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "k"], 
     SubscriptBox["c", 
      RowBox[{
       RowBox[{"2", "k"}], "-", "1"}]], 
     SubscriptBox["c", 
      RowBox[{"2", "k"}]]}], ")"}], TraditionalForm]],ExpressionUUID->
  "dd8edfe8-67cd-484f-8bf2-4a2feb705403"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "a965e7c3-8419-451d-a23d-79e3cefedd72"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"2", "n"}]}], TraditionalForm]],ExpressionUUID->
  "2d30a4ae-96bb-4838-9a87-131fb81f5024"],
 ") are Majorana fermion operators corresponding to the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "fdd85cd1-8797-467a-aa05-8ef559859d97"],
 " Dirac fermion modes, ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalN]", TraditionalForm]],ExpressionUUID->
  "a41a85a6-e6ed-4e1a-ae35-eb28662184f1"],
 " is the norm square of the state (i.e., note that some quantum channels do \
not preserve the trace of the state and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "\[VeryThinSpace]", "\[Rho]"}], "=", "\[ScriptCapitalN]"}], 
   TraditionalForm]],ExpressionUUID->"7bee7c2d-d03b-445f-8815-348c87ca1f9d"],
 "), and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "9364888f-02f8-47b4-8fac-03415ddbbaad"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "k"], "\[Element]", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "1"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"e30f7efe-fdb7-40a0-b41a-9870dc754355"],
 ") are eigenvalues of the ",
 StyleBox["covariance matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "c1ae9829-a4c8-4fbc-a61c-bbbbf8e78c9f"],
 ", which is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "79bd6a37-b2ee-460d-963b-0aae4abb3e9c"],
 " real anti-symmetric matrix (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["V", "T"], "=", 
    RowBox[{"-", "V"}]}], TraditionalForm]],ExpressionUUID->
  "f94cbf0b-0b6f-40af-9569-6d8259a7b194"],
 ") in the Majorana spinor space [",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
      StyleBox[{
        StyleBox["Bravyi", IgnoreSpellCheck -> True], " (2005)"}]]], 
    "https://dl.acm.org/doi/abs/10.5555/2011637.2011640"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "c98d726e-34ad-4bb4-afd5-bee6f78df14e"],
 "]."
}], "Notes",
 CellID->52239125,ExpressionUUID->"06442c1e-3358-4db9-893e-1d573ac685ca"],

Cell[TextData[{
 "Introducing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n"}], TraditionalForm]],ExpressionUUID->
  "ac6cafdb-d1f5-42e6-849f-977760b72b18"],
 " ",
 ButtonBox["Grassmann variables",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Grassmann"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "i"], TraditionalForm]],ExpressionUUID->
  "eb113dc2-f1f9-47b0-a28b-4021bc792626"],
 " respectively corresponding to the Majorana modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "ae9eaf8b-ead9-4ee4-91ee-85070d539e1a"],
 ", the fermionic Gaussian state reads as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[DotEqual]", 
    RowBox[{
     FractionBox["\[ScriptCapitalN]", 
      SuperscriptBox["2", "n"]], 
     RowBox[{"exp", "(", 
      RowBox[{
       FractionBox["\[ImaginaryI]", "2"], 
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"i", ",", 
         RowBox[{"j", "=", "1"}]}], 
        RowBox[{"2", "n"}]], 
       SubscriptBox["x", "i"], 
       SubscriptBox["V", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["x", "j"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "47851bdb-cbce-4e7d-9148-5f01c82abdb6"],
 " ,\[LineSeparator]expressed directly in terms of the covariance matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "eebaa3ae-ae82-434b-9ebb-d9dfedf15afd"],
 " [",
 StyleBox[ButtonBox["Bravyi",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dl.acm.org/doi/abs/10.5555/2011637.2011640"], None}],
  IgnoreSpellCheck->True],
 ButtonBox[" (2005)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dl.acm.org/doi/abs/10.5555/2011637.2011640"], None}],
 "]."
}], "Notes",
 CellID->1331370085,ExpressionUUID->"fe95ce8d-2392-4160-8850-74cb373d079e"],

Cell[TextData[{
 "The ",
 StyleBox["covariance matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "572827f4-1a13-49c9-b4e0-417fc16e4eda"],
 " is related the matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "ef6d730b-220f-433c-8d79-729c95c48b54"],
 " of ",
 ButtonBox["Green\[CloseCurlyQuote]s functions",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiGreen"],
 " by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"I", "-", 
     RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "V"}]}], "=", 
    RowBox[{"M", "\[VeryThinSpace]", "G", "\[VeryThinSpace]", 
     SuperscriptBox["M", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "f988ee4b-2da5-41e4-a3c3-e75d3dffc31c"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "17ede6d0-a133-445c-ac6a-536db7b8cf14"],
 " is the matrix describing the ",
 ButtonBox["canonical transformation from Dirac to Majorana fermion modes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ToMajoranaMatrix"],
 ". Recall that the Green\[CloseCurlyQuote]s functions matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "60f44a69-9818-41c4-bae6-a6feb42bdb1c"],
 " is in the ",
 ButtonBox["block form",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/NambuGreen"],
 "\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{"(", GridBox[{
       {"g", "f"},
       {
        SuperscriptBox["f", "\[Dagger]"], 
        RowBox[{"I", "-", 
         SuperscriptBox["g", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "2ec4e836-ad6d-42cc-bc41-d1c84ad71de0"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"c9e6b878-b7a3-43f4-9f24-82df387d9f00"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubscriptBox["a", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"c8650585-82f4-48a3-a967-d1add4e17083"],
 " ."
}], "Notes",
 CellID->1077220984,ExpressionUUID->"14214b5b-1452-4e1c-a16d-92ff19f28fdd"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["NormSquare"]], "paclet:QuantumMob/Q3/ref/NormSquare", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"BravyiState", "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "13a66e1a-5d85-4875-ad4f-3cc3f1b4bbd3"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Norm"]], "paclet:ref/Norm"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"BravyiState", "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8105bd7f-9115-4e17-8824-df8af8d3f516"],
 " return the norm square and norm, respectively, of the Bravyi state."
}], "Notes",
 CellID->319878651,ExpressionUUID->"73eb47b3-8928-42fb-9314-3cd67a77a99c"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
       "QuantumMob Package Symbol"},
      "PackageLink",
      BaseStyle->"InlineFormula"], "[", 
     StyleBox["\[Ellipsis]", "TR"], "]"}], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9763572b-e42f-4d7c-bef7-8848fedaf228"],
 " returns the vector (pure state) or matrix (mixed state) representation. It \
may take long for large systems, and is intended for elementary tests."
}], "Notes",
 CellID->2107647019,ExpressionUUID->"7f5d53b6-221e-40de-9e3b-67fdb5f3cade"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ExpressionForm"]], "paclet:QuantumMob/Q3/ref/ExpressionForm", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
       "QuantumMob Package Symbol"},
      "PackageLink",
      BaseStyle->"InlineFormula"], "[", 
     StyleBox["\[Ellipsis]", "TR"], "]"}], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "37a48fcf-9719-44fe-9ce8-86d79a787d59"],
 " returns the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Ket", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3d0b712b-a25b-4134-8f8c-e7d29d42aec7"],
 " (pure state) or ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Dyad"]], "paclet:QuantumMob/Q3/ref/Dyad", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a770aee4-5d4b-4ad3-a4da-88b1f7c7982f"],
 " (mixed state) expression. It may take long for large systems, and is \
intended for elementary tests."
}], "Notes",
 CellID->909824622,ExpressionUUID->"384a6162-72b2-445e-bff2-03a63c2445af"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiGreen"]], "paclet:QuantumMob/Q3/ref/BravyiGreen", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "887da55f-e7d1-4236-b491-8681c556aeaf"],
 " returns the Green's functions of fermion modes. Similarly, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiEntanglementEntropy"]], 
    "paclet:QuantumMob/Q3/ref/BravyiEntanglementEntropy", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "863c9a51-d2d1-4fa7-b7c8-ca3981a2a3ab"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiLogarithmicNegativity"]], 
    "paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cf0f038f-1b9d-4f8b-b111-d29bf45cca28"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMutualInformation"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMutualInformation", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9f38dbee-0068-4a75-a357-de2f20c452d2"],
 ", etc. are supported as well."
}], "Notes",
 CellID->993218105,ExpressionUUID->"a5cee966-3b41-4730-b461-8ed8b8721f81"],

Cell[TextData[{
 "A ",
 StyleBox["convex linear combination",
  FontSlant->"Italic"],
 " (",
 StyleBox["not ",
  FontSlant->"Italic"],
 "coherent superposition) \[LineSeparator]\t",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TR"], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["w", "TI"], 
      StyleBox["1", "TR"]], "*", 
     RowBox[{
      TemplateBox[{
        Cell[
         TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"], "[", 
      SubscriptBox[
       StyleBox["spec", "TI"], 
       StyleBox["1", "TR"]], "]"}]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["w", "TI"], 
      StyleBox["2", "TR"]], "*", 
     RowBox[{
      TemplateBox[{
        Cell[
         TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"], "[", 
      SubscriptBox[
       StyleBox["spec", "TI"], 
       StyleBox["2", "TR"]], "]"}]}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8196f7df-699c-45d0-83fd-7cd540a60fd0"],
 "\[LineSeparator]of two normalized Bravyi states ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TR"], 
    StyleBox["1", "TR"]], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    SubscriptBox[
     StyleBox["spec", "TI"], 
     StyleBox["1", "TR"]], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8b999453-dede-430b-b511-e3c58e21cf7f"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TR"], 
    StyleBox["2", "TR"]], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    SubscriptBox[
     StyleBox["spec", "TI"], 
     StyleBox["2", "TR"]], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "29a616b7-3978-43df-97a6-f13c2c70a846"],
 " is supported for ",
 StyleBox["non-negative",
  FontSlant->"Italic"],
 " numbers ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["w", "TI"], 
   StyleBox["1", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3eadaf36-418d-447e-9f14-3371cd33a1ab"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["w", "TI"], 
   StyleBox["2", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3a00d511-4f80-4cd1-a6bc-5c90178b0e0f"],
 ", and is understood as \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["w", "1"], "+", 
       SubscriptBox["w", "2"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        FractionBox[
         SubscriptBox["w", "1"], 
         RowBox[{
          SubscriptBox["w", "1"], "+", 
          SubscriptBox["w", "2"]}]], 
        SubscriptBox["\[Rho]", "1"]}], "+", 
       RowBox[{
        FractionBox[
         SubscriptBox["w", "2"], 
         RowBox[{
          SubscriptBox["w", "1"], "+", 
          SubscriptBox["w", "2"]}]], 
        SubscriptBox["\[Rho]", "2"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"176645ac-6363-4aa8-a72a-8563ab54d700"],
 ". \[LineSeparator]Here, it is important to note that the resulting state ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TR"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6333d0ad-2e43-48db-bc2e-057f985c8817"],
 "  is a ",
 StyleBox["mixed state",
  FontSlant->"Italic"],
 " even when both ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   SubscriptBox[
    StyleBox["spec", "TI"], 
    StyleBox["1", "TR"]], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "60d01d79-060c-4835-9b99-0d9adaef33b5"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   SubscriptBox[
    StyleBox["spec", "TI"], 
    StyleBox["2", "TR"]], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9c4fb0b0-0159-406e-b135-3099e56a9ec9"],
 " represent pure states, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", "1"], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "1"]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "1"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "b6a8032c-4906-45f1-9e66-fda4ea14ccc9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", "2"], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "2"]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "2"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "6863f840-0581-42da-9973-7d6de63aff6a"],
 "; it should ",
 StyleBox["not",
  FontSlant->"Italic"],
 " be confused with the ",
 StyleBox["coherent superposition",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "1"]},
      "Ket"], 
     SubscriptBox["w", "1"]}], "+", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "2"]},
      "Ket"], 
     SubscriptBox["w", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "8c1e4250-cd90-4be0-9d29-11cd890737cc"],
 ". Note also that the norm square of \[Rho] is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", "1"], "+", 
    SubscriptBox["w", "2"]}], TraditionalForm]],ExpressionUUID->
  "afd7eb18-202e-493a-a8ed-96b91daf9d1f"],
 " assuming that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TR"], 
   StyleBox["1", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6b81fb26-428d-4925-acea-544df71d40f0"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TR"], 
   StyleBox["2", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54540a28-0b93-493c-8f50-eae322fec5b5"],
 " are properly normalized (Q3 does not check the normalization)."
}], "Notes",
 CellID->1320442067,ExpressionUUID->"5db62825-5681-4b88-bdca-c47b26eb582a"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

