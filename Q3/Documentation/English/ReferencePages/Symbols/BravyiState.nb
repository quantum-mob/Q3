Cell[TextData[{
 "Any fermionic Gaussian state of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "207e2643-79b7-425d-be6a-43579a782f57"],
 " fermion modes can be written as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     FractionBox["\[ScriptCapitalN]", 
      SuperscriptBox["2", "n"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "n"]}]}], TraditionalForm]],ExpressionUUID->
  "a0d32dc7-e450-4b3e-b9a3-3847819fd6b6"],
 "(1+\[ImaginaryI]\[VeryThinSpace]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "k"], 
     SubscriptBox["c", 
      RowBox[{
       RowBox[{"2", "k"}], "-", "1"}]], 
     SubscriptBox["c", 
      RowBox[{"2", "k"}]]}], ")"}], TraditionalForm]],ExpressionUUID->
  "df4bc4ab-5ad9-4d13-bea2-f85b26827fa4"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "89d88469-18d5-4b4f-8ebb-a2b119c7e636"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"2", "n"}]}], TraditionalForm]],ExpressionUUID->
  "e1db2c2b-ce6e-4815-9fc1-55ff71db50d2"],
 ") are Majorana fermion operators corresponding to the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "390441d5-3ef7-43f3-95ca-6dcf9ad597c0"],
 " Dirac fermion modes, ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalN]", TraditionalForm]],ExpressionUUID->
  "fb285778-f566-4869-a576-2f05830ea70e"],
 " is the norm square of the state (i.e., note that some quantum channels do \
not preserve the trace of the state and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "\[VeryThinSpace]", "\[Rho]"}], "=", "\[ScriptCapitalN]"}], 
   TraditionalForm]],ExpressionUUID->"36d6493d-261d-4c9d-b05b-1ae6df2b000d"],
 "), and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "1045a26b-0e8a-40ff-b23a-f409653454f2"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "k"], "\[Element]", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "1"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"9bbfb34a-04fd-408c-a121-ca0ee065194c"],
 ") are eigenvalues of the ",
 StyleBox["covariance matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "7f4d7e32-b27d-4a1f-8313-60b4eaba88c7"],
 ", which is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "d5749d79-7488-4208-8ebe-64ea8f39b36e"],
 " real anti-symmetric matrix (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["V", "T"], "=", 
    RowBox[{"-", "V"}]}], TraditionalForm]],ExpressionUUID->
  "dd31d561-a21a-44c0-997f-9c1fa1d17ab4"],
 ") in the Majorana spinor space [",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
      StyleBox[{
        StyleBox["Bravyi", IgnoreSpellCheck -> True], " (2005)"}]]], 
    "https://dl.acm.org/doi/abs/10.5555/2011637.2011640"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "7513cb9e-cb0b-4c38-ae5f-675af2fb0074"],
 "]."
}], "Notes",
 CellID->52239125,ExpressionUUID->"3c29c000-ce56-4de4-8275-82e9361ba620"],

Cell[TextData[{
 "Introducing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n"}], TraditionalForm]],ExpressionUUID->
  "7f7f327c-6511-4b52-9374-4d0d3356eb40"],
 " ",
 ButtonBox["Grassmann variables",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Grassmann"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "i"], TraditionalForm]],ExpressionUUID->
  "d56ada8f-ad27-400c-93ee-058e5b10530b"],
 " respectively corresponding to the Majorana modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "270016e3-faab-45e0-9400-9abc5bddd198"],
 ", the fermionic Gaussian state reads as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[DotEqual]", 
    RowBox[{
     FractionBox["\[ScriptCapitalN]", 
      SuperscriptBox["2", "n"]], 
     RowBox[{"exp", "(", 
      RowBox[{
       FractionBox["\[ImaginaryI]", "2"], 
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"i", ",", 
         RowBox[{"j", "=", "1"}]}], 
        RowBox[{"2", "n"}]], 
       SubscriptBox["x", "i"], 
       SubscriptBox["V", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["x", "j"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "f6028842-3d43-4f78-90fe-60095649878c"],
 " ,\[LineSeparator]expressed directly in terms of the covariance matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "fd37169a-f8d3-4707-a4d1-f7f87629d6af"],
 " [",
 StyleBox[ButtonBox["Bravyi",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dl.acm.org/doi/abs/10.5555/2011637.2011640"], None}],
  IgnoreSpellCheck->True],
 ButtonBox[" (2005)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dl.acm.org/doi/abs/10.5555/2011637.2011640"], None}],
 "]."
}], "Notes",
 CellID->1331370085,ExpressionUUID->"20423543-14d3-4e6d-be99-0f78abfb0e10"],

Cell[TextData[{
 "The ",
 StyleBox["covariance matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "60c4921c-82b9-4b25-8044-4324fa74cc7d"],
 " is related the matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "8c3467e5-dd34-4ce7-8a20-45e759d48c90"],
 " of ",
 ButtonBox["Green\[CloseCurlyQuote]s functions",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiGreen"],
 " by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"I", "-", 
     RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "V"}]}], "=", 
    RowBox[{"M", "\[VeryThinSpace]", "G", "\[VeryThinSpace]", 
     SuperscriptBox["M", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "6a033dec-dca5-432e-8bf6-fbccb29dddff"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "084e51e0-81be-4afd-94d6-a75c7894dd09"],
 " is the matrix describing the ",
 ButtonBox["canonical transformation from Dirac to Majorana fermion modes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ToMajoranaMatrix"],
 ". Recall that the Green\[CloseCurlyQuote]s functions matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "fd691347-41b6-413a-a682-0a24407f55aa"],
 " is in the ",
 ButtonBox["block form",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/NambuGreen"],
 "\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{"(", GridBox[{
       {"g", "f"},
       {
        SuperscriptBox["f", "\[Dagger]"], 
        RowBox[{"I", "-", 
         SuperscriptBox["g", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "f2b92760-4cea-4990-8955-b9a63150f5b7"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"508d9bef-27eb-494d-8ff7-e1d13536268e"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubscriptBox["a", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"a6c1efb3-3f11-4d69-8dd4-bcaea5c2ae9c"],
 " ."
}], "Notes",
 CellID->1077220984,ExpressionUUID->"1e556494-5eb5-48e8-86dd-6f20a0bd2b39"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["NormSquare"]], "paclet:QuantumMob/Q3/ref/NormSquare", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"BravyiState", "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bf0420c3-2a97-4c03-9b7e-d653ad277dfa"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Norm"]], "paclet:ref/Norm"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"BravyiState", "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "34f59a18-4760-4d65-b23e-d3fc6744d818"],
 " return the norm square and norm, respectively, of the Bravyi state."
}], "Notes",
 CellID->319878651,ExpressionUUID->"7101de79-535a-4240-bfef-6b3fcadbdfc7"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
       "QuantumMob Package Symbol"},
      "PackageLink",
      BaseStyle->"InlineFormula"], "[", 
     StyleBox["\[Ellipsis]", "TR"], "]"}], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d1976ead-5b36-417f-9b41-62b9e8d93c02"],
 " returns the vector (pure state) or matrix (mixed state) representation. It \
may take long for large systems, and is intended for elementary tests."
}], "Notes",
 CellID->2107647019,ExpressionUUID->"3cf39f8d-8dcb-4135-a928-14f5b8aa3007"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ExpressionForm"]], "paclet:QuantumMob/Q3/ref/ExpressionForm", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
       "QuantumMob Package Symbol"},
      "PackageLink",
      BaseStyle->"InlineFormula"], "[", 
     StyleBox["\[Ellipsis]", "TR"], "]"}], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4cbbcaac-b133-4c0c-8a7d-e124afa681fc"],
 " returns the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Ket", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a6bf5a21-db41-403c-a542-978c4e368279"],
 " (pure state) or ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Dyad"]], "paclet:QuantumMob/Q3/ref/Dyad", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6a7b375e-213e-4992-a7c9-a0f436225870"],
 " (mixed state) expression. It may take long for large systems, and is \
intended for elementary tests."
}], "Notes",
 CellID->909824622,ExpressionUUID->"7063231d-ea60-4818-b230-1480ad6d3801"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiGreen"]], "paclet:QuantumMob/Q3/ref/BravyiGreen", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f9858d5e-258a-4d60-9a97-28e51d825fe8"],
 " returns the Green's functions of fermion modes. Similarly, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiEntanglementEntropy"]], 
    "paclet:QuantumMob/Q3/ref/BravyiEntanglementEntropy", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9d940d11-3e1f-4796-9f76-bf46fdc620df"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiLogarithmicNegativity"]], 
    "paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ffabc313-0d2b-4614-b065-fc327e8cbba8"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMutualInformation"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMutualInformation", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3e1e96c7-6cf9-40a2-b84e-8d7e66a8dbd3"],
 ", etc. are supported as well."
}], "Notes",
 CellID->993218105,ExpressionUUID->"39361192-e373-43c3-a2ec-6240b88deef9"],

Cell[TextData[{
 "A ",
 StyleBox["convex linear combination",
  FontSlant->"Italic"],
 " (",
 StyleBox["not ",
  FontSlant->"Italic"],
 "coherent superposition) \[LineSeparator]\t",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Rho]", "TR"], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox[
      StyleBox["w", "TI"], 
      StyleBox["1", "TR"]], "*", 
     RowBox[{
      TemplateBox[{
        Cell[
         TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"], "[", 
      SubscriptBox[
       StyleBox["spec", "TI"], 
       StyleBox["1", "TR"]], "]"}]}], "+", 
    RowBox[{
     SubscriptBox[
      StyleBox["w", "TI"], 
      StyleBox["2", "TR"]], "*", 
     RowBox[{
      TemplateBox[{
        Cell[
         TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"], "[", 
      SubscriptBox[
       StyleBox["spec", "TI"], 
       StyleBox["2", "TR"]], "]"}]}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1cf1d6b2-d4ff-454d-a713-96d308bfe84b"],
 "\[LineSeparator]of two normalized Bravyi states ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TR"], 
    StyleBox["1", "TR"]], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    SubscriptBox[
     StyleBox["spec", "TI"], 
     StyleBox["1", "TR"]], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5736e86d-1c4f-4397-86a7-3b3f9a3ec04f"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["\[Rho]", "TR"], 
    StyleBox["2", "TR"]], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    SubscriptBox[
     StyleBox["spec", "TI"], 
     StyleBox["2", "TR"]], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "04f567f8-2a98-41c4-bcb3-0bbd276482ac"],
 " is supported for ",
 StyleBox["non-negative",
  FontSlant->"Italic"],
 " numbers ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["w", "TI"], 
   StyleBox["1", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "055dc852-92dc-42d8-aea9-0cd6ad2e0737"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["w", "TI"], 
   StyleBox["2", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b31f48cf-275b-446e-bac1-b16793146d0e"],
 ", and is understood as \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["w", "1"], "+", 
       SubscriptBox["w", "2"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        FractionBox[
         SubscriptBox["w", "1"], 
         RowBox[{
          SubscriptBox["w", "1"], "+", 
          SubscriptBox["w", "2"]}]], 
        SubscriptBox["\[Rho]", "1"]}], "+", 
       RowBox[{
        FractionBox[
         SubscriptBox["w", "2"], 
         RowBox[{
          SubscriptBox["w", "1"], "+", 
          SubscriptBox["w", "2"]}]], 
        SubscriptBox["\[Rho]", "2"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"698577da-cdf1-4e90-a5e1-bc26e5b1603c"],
 ". \[LineSeparator]Here, it is important to note that the resulting state ",
 Cell[BoxData[
  StyleBox["\[Rho]", "TR"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ce9c050a-5451-454f-bcaa-684f141f84e5"],
 "  is a ",
 StyleBox["mixed state",
  FontSlant->"Italic"],
 " even when both ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   SubscriptBox[
    StyleBox["spec", "TI"], 
    StyleBox["1", "TR"]], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e91ec985-5190-4727-866e-141d19215bb3"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   SubscriptBox[
    StyleBox["spec", "TI"], 
    StyleBox["2", "TR"]], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ad935aaf-9075-489d-9d84-156a746e5b46"],
 " represent pure states, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", "1"], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "1"]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "1"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "3d86adea-2e55-45a8-9a75-47a16e69ed1c"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", "2"], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "2"]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "2"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "dff91d50-7d37-4ca5-ac4e-5aeebc0f8da0"],
 "; it should ",
 StyleBox["not",
  FontSlant->"Italic"],
 " be confused with the ",
 StyleBox["coherent superposition",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "1"]},
      "Ket"], 
     SubscriptBox["w", "1"]}], "+", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "2"]},
      "Ket"], 
     SubscriptBox["w", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "3c3e5724-a023-456c-a0e6-093add36920a"],
 ". Note also that the norm square of \[Rho] is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["w", "1"], "+", 
    SubscriptBox["w", "2"]}], TraditionalForm]],ExpressionUUID->
  "e57230e4-3585-4398-a0b2-a217e1664f32"],
 " assuming that ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TR"], 
   StyleBox["1", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "62a9b71c-6145-436c-86c4-e0d15da07593"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Rho]", "TR"], 
   StyleBox["2", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9b303100-2965-492b-add5-4f31fb251cef"],
 " are properly normalized (Q3 does not check the normalization)."
}], "Notes",
 CellID->1320442067,ExpressionUUID->"27e4d3ec-b70a-4e40-af88-76e5e0c0d4b1"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

