Cell[TextData[{
 "Usually, a ",
 ButtonBox["Bravyi state",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiState"],
 " may be  generated through ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiUnitary"]], "paclet:QuantumMob/Q3/ref/BravyiUnitary", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "326ea866-3365-4d97-836b-1f83152be2e6"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiNonunitary"]], 
    "paclet:QuantumMob/Q3/ref/BravyiNonunitary", "QuantumMob Package Symbol"},
   
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ded77dea-33c9-477b-a531-544b90881545"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "86525281-282a-4153-bd63-1c3df632f571"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9f768d93-701b-4dcb-b5c2-fa29332a46ca"],
 ", etc. However, one needs to prepare an initial state in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "22f91e4f-2446-4ad7-9699-b8f6353180bc"],
 " form. There are several ways to do it."
}], "ExampleText",
 CellID->1020093317,ExpressionUUID->"519270fe-8961-4ce1-8969-370a499b2392"],

