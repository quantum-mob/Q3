Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Sequence", "@@", 
    RowBox[{"ReleaseHold", "@", 
     RowBox[{"Thread", "[", 
      RowBox[{
       RowBox[{"Hold", "[", "CNOT", "]"}], "[", 
       RowBox[{
        RowBox[{"S", "@", 
         RowBox[{"Most", "@", "kk"}]}], ",", 
        RowBox[{"T", "@", 
         RowBox[{"Most", "@", "kk"}]}]}], "]"}], "]"}]}]}], ",", 
   "\[IndentingNewLine]", "\"\<Spacer\>\"", ",", 
   RowBox[{"CNOT", "[", 
    RowBox[{
     RowBox[{"S", "[", "$n", "]"}], ",", 
     RowBox[{"T", "[", "$n", "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Mark", "[", 
    RowBox[{"\"\<\[DescendingEllipsis]\>\"", ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", " ", "3"}], "}"}]}], "]"}], ",", 
   RowBox[{"Mark", "[", 
    RowBox[{"\"\<\[DescendingEllipsis]\>\"", ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", " ", "8"}], "}"}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"\"\<Invisible\>\"", "->", 
    RowBox[{"Append", "[", 
     RowBox[{
      RowBox[{"S", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"$n", "-", 
          RowBox[{"1", "/", "2"}]}], ",", 
         RowBox[{"$n", "+", 
          RowBox[{"1", "/", "2"}]}]}], "}"}]}], ",", 
      RowBox[{"T", "[", 
       RowBox[{"$n", "-", 
        RowBox[{"1", "/", "2"}]}], "]"}]}], "]"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1575350369,ExpressionUUID->"ac7c7743-c038-48e8-86ea-64e7a6093d31"],

