  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0bd68751-906f-43b2-952d-7292784711ca"],
 " gives ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["c", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], ",", 
            StyleBox["u", "TI"], ";", 
            StyleBox["j", "TI"], ",", 
            StyleBox["v", "TI"]}]], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          RowBox[{
            StyleBox["k", "TI"], ",", 
            StyleBox["l", "TI"]}], LimitsPositioning -> True], 
         SubscriptBox[
          StyleBox["a", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], ",", 
            StyleBox["k", "TI"], ";", 
            StyleBox["j", "TI"], ",", 
            StyleBox["l", "TI"]}]], 
         SubscriptBox[
          StyleBox["b", "TI"], 
