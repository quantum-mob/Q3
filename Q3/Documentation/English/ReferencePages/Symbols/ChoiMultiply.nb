  FontFamily->"Source Sans Pro",ExpressionUUID->
  "409137b3-220a-49e1-b2bb-c67c1c6a7ac8"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ChoiMultiply"]], "paclet:QuantumMob/Q3/ref/ChoiMultiply", 
