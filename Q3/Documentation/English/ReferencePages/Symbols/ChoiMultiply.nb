            StyleBox["k", "TI"], ",", 
            StyleBox["u", "TI"], ";", 
            StyleBox["l", "TI"], ",", 
            StyleBox["v", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "c_{i,u;j,v}=\\sum_{k,l}a_{i,k;j,l}b_{k,u;l,v}", "state" -> 
