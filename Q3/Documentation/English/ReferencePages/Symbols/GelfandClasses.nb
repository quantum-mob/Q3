Cell[TextData[{
 " The keys of the returned association are semistandard Young tableaux of \
the specified ",
 Cell[BoxData[
  StyleBox["shape", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "328189a7-12c7-4779-9f1b-7e09557fa768"],
 " and ",
 Cell[BoxData[
  StyleBox["content", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "51d939b4-8982-43ad-b3cd-7a384220ef3f"],
 ", each labeling one Gelfand-Tsetlin class. The values are lists of standard \
Young tableaux belonging to the corresponding class. "
}], "Notes",
 CellID->299380352,ExpressionUUID->"bfcb1eb4-24f4-4324-951f-79cf8ad803f7"],

Cell[TextData[{
 "The number of classes equals the ",
 ButtonBox["Kostka number",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/KostkaNumber"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"42772313-fce8-44f3-a0ca-54fb4a33b8cc"],
 " of shape \[Lambda] and  content \[Mu], and only admissible classes (whose \
keys are valid semistandard tableaux) are included."
}], "Notes",
 CellID->307895492,ExpressionUUID->"26677ca4-9fed-4c84-bf96-05486e039cde"]
