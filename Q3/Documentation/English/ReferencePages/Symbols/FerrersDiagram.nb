Cell[TextData[{
 "A ",
 StyleBox[ButtonBox["Young diagram",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungDiagram"],
  FontSlant->"Italic"],
 " is a finite collection of boxes (or cells) arranged in left-justified \
rows, with the row lengths in non-increasing order. Listing the number of \
boxes in each row gives a ",
 StyleBox["partition",
  FontSlant->"Italic"],
 " \[Lambda] of a non-negative integer ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", the total number of boxes of the diagram. That is, for a Young diagram of \
",
 StyleBox["d",
  FontSlant->"Italic"],
 " rows, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"a619e70d-6fb2-4f4f-b164-d4f4e9b0d282"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "2"], "\[GreaterEqual]", "\[Ellipsis]", "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "d"], ">", "0"}], TraditionalForm]],
  ExpressionUUID->"15e6ca82-9c62-4e79-b6c7-339808506898"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"7fe32534-fe4f-4e17-ab7b-60e0fbb5c412"],
 ". Then the Young diagram is said to be of shape \[Lambda], and it carries \
the same information as that partition."
}], "Notes",
 CellID->392025427,ExpressionUUID->"18ae9006-3ae7-4b68-bad0-6e6dd14583e0"],

Cell[TextData[{
 "A Young diagram is also called a ",
 StyleBox[ButtonBox["Ferrers diagram",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FerrersDiagram"],
  FontSlant->"Italic"],
 ", particularly when represented using dots."
}], "Notes",
 CellID->1267055172,ExpressionUUID->"3c1bb6f6-c2d8-4f5a-92bc-f7edc58d392b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

