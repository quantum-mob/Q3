Cell[TextData[{
 "It converts supermatrix ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["M", "TI"], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], ",", 
              StyleBox["k", "TI"]}], ")"}], ",", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], ",", 
              StyleBox["l", "TI"]}], ")"}]}]], TraditionalForm], 
     "errors" -> {}, "input" -> "M_{(i,k),(j,l)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "94910a90-cd18-46f2-8cb5-91e621a96b81"],
 " to Choi matrix ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["C", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], ",", 
          StyleBox["j", "TI"], ";", 
          StyleBox["k", "TI"], ",", 
          StyleBox["l", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "C_{i,j;k,l}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3b808287-8707-4064-a8cd-ac3bc7ed5720"],
 "."
}], "Notes",
 CellID->2144837231,ExpressionUUID->"a0ce6df9-7748-4d14-9983-3074eb35f348"],

Cell[TextData[{
 "The Choi matrix of supermap ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", ":", 
    RowBox[{
     RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], "\[RightArrow]", 
     RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalW]", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"bfa92482-ec8d-483c-8734-084f75c610da"],
 " defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{"A", "\[VeryThinSpace]", "\[Rho]", "\[VeryThinSpace]", 
     SuperscriptBox["B", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "a0034872-d238-4b08-8585-99e0e3ece6fa"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ",", 
    RowBox[{"B", "\[Element]", 
     RowBox[{"\[ScriptCapitalL]", "(", 
      RowBox[{"\[ScriptCapitalV]", ",", "\[ScriptCapitalW]"}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"44ce9014-9dcf-485c-8d5e-9390c1572fbc"],
 ", is given by \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", 
     RowBox[{
      RowBox[{"i", "\[VeryThinSpace]", "k"}], ";", 
      RowBox[{"j", "\[VeryThinSpace]", "l"}]}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["A", 
       RowBox[{"i", "\[VeryThinSpace]", "\[Kappa]"}]], 
      SubsuperscriptBox["B", 
       RowBox[{"j", "\[VeryThinSpace]", "l"}], "*"]}], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"A", "\[CircleTimes]", 
        SuperscriptBox["B", "*"]}], ")"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"i", ",", "j"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"k", ",", "l"}], ")"}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"f5b6f3ca-38de-411d-86b9-2d9d85c63a31"],
 " . \[LineSeparator]The corresponding ",
 StyleBox["super-matrix",
  FontSlant->"Italic"],
 " is given by \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"i", ",", "j"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"k", ",", "l"}], ")"}]}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["A", 
       RowBox[{"i", "\[VeryThinSpace]", "k"}]], 
      SubsuperscriptBox["B", 
       RowBox[{"j", "\[VeryThinSpace]", "l"}], "*"]}], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"A", "\[CircleTimes]", 
        SuperscriptBox["B", "*"]}], ")"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"i", ",", "j"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"k", ",", "l"}], ")"}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"1b4a7d8c-68f9-43a9-99d9-570e31c112de"],
 "; \[LineSeparator]that is, \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"i", ",", "j"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"k", ",", "l"}], ")"}]}]], "=", 
    SubscriptBox["C", 
     RowBox[{
      RowBox[{"i", "\[VeryThinSpace]", "k"}], ";", 
      RowBox[{"j", "\[VeryThinSpace]", "l"}]}]]}], TraditionalForm]],
  ExpressionUUID->"518b8597-db0d-4976-b4c5-a222688bee60"],
 " ."
}], "Notes",
 CellID->544097144,ExpressionUUID->"80e7e32f-d3ee-4108-9733-b41ce5766c9e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", ":", 
    RowBox[{"\[Rho]", "\[RightTeeArrow]", "\[Sigma]"}]}], TraditionalForm]],
  ExpressionUUID->"7da94e42-ea3d-4395-9fe8-71afea6141ae"],
 " be a supermap, and ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "79b43102-fca4-42dc-87a7-e5228dbba76f"],
 " its Choi matrix. Then, the components of \[Rho] and \[Sigma] are related \
by the transformation\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Sigma]", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]], 
      SubscriptBox["C", 
       RowBox[{
        RowBox[{"i", "\[VeryThinSpace]", "k"}], ";", 
        RowBox[{"j", "\[VeryThinSpace]", "l"}]}]], 
      SubscriptBox["\[Rho]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]], 
      SubscriptBox["M", 
       RowBox[{
        RowBox[{"i", "\[VeryThinSpace]", "j"}], ";", 
        RowBox[{"k", "\[VeryThinSpace]", "l"}]}]], 
      SubscriptBox["\[Rho]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"248b22ef-91fc-4de0-a908-f76b3ab251b1"],
 " ."
}], "Notes",
 CellID->688867986,ExpressionUUID->"9c3fbdce-cec6-49ea-a15e-270df2e68793"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

