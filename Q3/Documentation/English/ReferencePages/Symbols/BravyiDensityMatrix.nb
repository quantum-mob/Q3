  RowBox[{"ham", "=", 
   RowBox[{"RandomNambuHermitian", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ham", "=", 
   RowBox[{
    RowBox[{"MultiplyDot", "[", 
     RowBox[{
      RowBox[{"Dagger", "@", "ccdd"}], ",", 
      RowBox[{
       RowBox[{"Normal", "[", "ham", "]"}], ".", "ccdd"}]}], "]"}], "/", 
    "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rho", "=", 
   RowBox[{"MatrixExp", "[", 
    RowBox[{"Matrix", "[", 
     RowBox[{"ham", ",", "cc"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"rho", "/=", 
  RowBox[{"Tr", "[", "rho", "]"}]}]}], "Input",
