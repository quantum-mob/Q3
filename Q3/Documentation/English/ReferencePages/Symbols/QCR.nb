Cell[TextData[{
 "The QCR maps the state as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"x"},
     "Ket"], "\[RightTeeArrow]", 
    TemplateBox[{
      RowBox[{"N", "-", "x"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "baea3bb2-cfd2-4825-976b-d4a6d2ba0a0a"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"N", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "a22fafd2-d5fb-4d88-a3fd-e37d208edd2b"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"x"},
     "Ket"], ":=", 
    TemplateBox[{
      RowBox[{
        SubscriptBox["x", "1"], 
        SubscriptBox["x", "2"], "\[Ellipsis]", "\[VeryThinSpace]", 
        SubscriptBox["x", "n"]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "1e5ce223-0fb6-48aa-beb0-c99f81ff0665"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], 
       SubscriptBox["x", "2"], "\[Ellipsis]", "\[VeryThinSpace]", 
       SubscriptBox["x", "n"]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"43ea445a-5600-4400-8fb9-6193e7a00a85"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", ":=", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "c3558652-cd3f-47d1-909d-6c9b1462341c"],
 " for ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "62848226-36a4-4cfa-895c-5224e3b6f2f5"],
 " qubits.  A periodic boundary condition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], "\[Congruent]", 
    TemplateBox[{"N"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "8824bf8c-f384-4090-97eb-fe8ad51372d1"],
 " is assumed; hence the name."
}], "Notes",
 CellID->1939604470,ExpressionUUID->"a8fb3186-1857-4906-bf94-8b1e888efae5"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

