Cell[TextData[{
 "The (normal) Green\[CloseCurlyQuote]s function of fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "e7ffd968-b8a3-418f-a917-7ef36a2b58d6"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubsuperscriptBox["c", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"7b264fea-4444-40dd-84ab-729822fc41df"],
 ". The matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "915d5b4a-001a-4c5f-ba8b-35421add0f98"],
 " is Hermitian, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", "\[Dagger]"], "=", "G"}], TraditionalForm]],
  ExpressionUUID->"256a5089-1feb-4ddc-b5e9-e1965956dd92"],
 ". The ",
 StyleBox["correlation matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubsuperscriptBox["c", "i", "\[Dagger]"], 
       SubscriptBox["c", "j"]}], "\[RightAngleBracket]"}], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"I", "-", 
        SuperscriptBox["G", "T"]}], ")"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"0f6097c8-4597-4485-af6b-39f7a817df5e"],
 " has equivalent information and is also frequently used."
}], "Notes",
 CellID->348061621,ExpressionUUID->"e3452063-2827-4d6c-bf09-4ed07082e96e"],

Cell[TextData[{
 "The anomalous Green\[CloseCurlyQuote]s function of fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "6020c441-b302-4db4-bb7c-0faf9d77f2d4"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubscriptBox["c", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"3e534d20-4590-4f11-b226-c1cd908b8de4"],
 ". The matrix ",
 Cell[BoxData[
  FormBox["F", TraditionalForm]],ExpressionUUID->
  "02c97424-657d-4160-bd44-e0d25df9e7b4"],
 " is skew-symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", "T"], "=", 
    RowBox[{"-", "F"}]}], TraditionalForm]],ExpressionUUID->
  "1df5d67b-ce56-473d-b9cc-af1bfa746101"],
 "."
}], "Notes",
 CellID->1383491325,ExpressionUUID->"c5c70a66-d30b-4ee8-9006-9eb1db511075"],

Cell[TextData[{
 "In the Nambu notation, the full single-particle Green\[CloseCurlyQuote]s \
function is defined to be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["G", "_"], ":=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       UnderscriptBox["c", "_"], 
       SuperscriptBox[
        UnderscriptBox["c", "_"], "\[Dagger]"]}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      RowBox[{"(", GridBox[{
         {"G", "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], 
          RowBox[{"I", "-", 
           SuperscriptBox["G", "T"]}]}
        }], ")"}], "=", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"I", "-", 
           SuperscriptBox["C", "T"]}], "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], "C"}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "1079390f-7471-43af-91d3-e6239639d9ed"],
 ", where  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     UnderscriptBox["c", "_"], "\[Dagger]"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["c", "1", "\[Dagger]"], ",", "\[Ellipsis]", ",", 
      SubsuperscriptBox["c", "n", "\[Dagger]"], ",", 
      SubscriptBox["c", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["c", "n"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "09c228b6-e653-4155-ad47-b0f23d351d24"],
 " is the Nambu spinor of the fermion modes."
}], "Notes",
 CellID->795234925,ExpressionUUID->"0e72d142-731c-43d2-ab03-df513aeca434"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Normal"]], "paclet:ref/Normal"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"NambuGreen", "[", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["G", "TI"], ",", 
      StyleBox["F", "TI"]}], "}"}], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9c1e1bd6-7616-46fa-bd51-8070d6901775"],
 " is equivalent to ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      TemplateBox[{
        Cell[
         TextData["ArrayFlatten"]], "paclet:ref/ArrayFlatten"},
       "RefLink",
       BaseStyle->{"InlineFormula"}], "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           StyleBox["G", "TI"], ",", 
           StyleBox["F", "TI"]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           TemplateBox[{
             Cell[
              TextData["Topple"]], "paclet:QuantumMob/Q3/ref/Topple", 
             "QuantumMob Package Symbol"},
            "PackageLink",
            BaseStyle->"InlineFormula"], "[", 
           StyleBox["F", "TI"]}]}]}], "}"}], ",", 
       RowBox[{
        StyleBox["I", "TI"], "-", 
        RowBox[{
         TemplateBox[{
           Cell[
            TextData["Transpose"]], "paclet:ref/Transpose"},
          "RefLink",
          BaseStyle->{"InlineFormula"}], "[", 
         StyleBox["G", "TI"], "]"}]}]}]}], "}"}], "}"}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "60dff75b-7217-4db6-a3c3-fb76b43f3ba8"],
 "; that is,",
 "\n",
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"G", ",", "F"}], "}"}], "\[RightTeeArrow]", 
     UnderscriptBox["G", "_"]}], ":=", 
    RowBox[{"(", GridBox[{
       {"G", "F"},
       {
        SuperscriptBox["F", "\[Dagger]"], 
        RowBox[{"I", "-", 
         SuperscriptBox["G", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "0a2e31e2-d277-40c5-bd1c-3ae9f221b588"],
 " assuming that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", "\[Dagger]"], "=", "G"}], TraditionalForm]],
  ExpressionUUID->"6e65d108-6a0a-4ca3-a689-bcf3799d9846"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", "T"], "=", 
    RowBox[{"-", "F"}]}], TraditionalForm]],ExpressionUUID->
  "d7001050-0d8f-4a7f-8de6-07617fc81003"],
 "."
}], "Notes",
 CellID->292545916,ExpressionUUID->"9017c89a-ee4f-440d-92b8-04322b24842d"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

Cell[CellGroupData[{

