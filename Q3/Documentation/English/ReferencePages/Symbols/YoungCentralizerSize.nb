Cell[TextData[{
 "A ",
 StyleBox["cycle decomposition",
  FontSlant->"Italic"],
 " of a permutation is an expression of the permutation as a product of \
disjoint cycles, where each cycle represents a cyclic rearrangement of \
elements. This decomposition is unique up to the order of the cycles and \
cyclic rotations within each cycle."
}], "Notes",
 CellID->442409035,ExpressionUUID->"166d8272-9485-4b3e-92e7-ac87317f45fc"],

Cell[TextData[{
 "The ",
 StyleBox["cycle decomposition type",
  FontSlant->"Italic"],
 " of a permutation of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "6df85564-f2f9-4ec8-93f1-8f2aff0b1f67"],
 " elements is a list of the lengths of the cycles in its cycle \
decomposition. By convention, a cycle decomposition type is arranged in \
decreasing order, and is a partition of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "da47ecd1-e79c-4075-b20b-38d218b2a853"],
 "."
}], "Notes",
 CellID->827090356,ExpressionUUID->"5eaa568a-e608-4ddc-a6b4-1084c0b19ed3"],

Cell[TextData[{
 StyleBox["Conjugacy classes",
  FontSlant->"Italic"],
 " in the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "222f1e24-3028-4936-a131-d6504df44185"],
 " are uniquely determined by the ",
 StyleBox["cycle decomposition type",
  FontSlant->"Italic"],
 " of permutations. Hence, like irreducible representations of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "50e48b1b-f7d2-4248-a8b1-824e1b786c64"],
 ", conjugacy classes in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "04e35925-db1a-4a41-88ef-e4e76ab21ce6"],
 " are in one-to-one correspondence to partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "d9303e7d-9adc-4f0e-9c68-06abf89d0ebc"],
 "."
}], "Notes",
 CellID->285452206,ExpressionUUID->"23250023-105d-4a97-8a3c-bb3a4184b68d"],

Cell[TextData[{
 "For any finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "d54ba8fc-18da-4760-a71a-3ed27d487522"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"\[ScriptCapitalZ]", "(", "g", ")"}], "\[RightBracketingBar]"}], 
    "\[VeryThinSpace]", "=", 
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{"\[ScriptCapitalZ]", "(", "h", ")"}], 
     "\[RightBracketingBar]"}]}], TraditionalForm]],ExpressionUUID->
  "5b4e9af5-56d3-45ef-8019-413fef150c0b"],
 " if and only if group elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "cd56a278-e3ff-407f-96ae-2d9f9d96dea9"],
 " and ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "7ab6098b-5a54-4283-942d-b4d1cdba7769"],
 " belong to the same conjugacy class of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "6837c6ae-0820-4fc5-955a-767182033f5d"],
 " (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Sagan, 2001"]], "https://doi.org/10.1007/978-1-4757-6804-6"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "5c0b8f1e-f9bf-4f99-8636-385e052f6b74"],
 ")."
}], "Notes",
 CellID->1114159165,ExpressionUUID->"7dbbf3a0-26b3-454e-b91d-53d545998f64"],

Cell[TextData[{
 "For any finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "7029a81f-c7b3-4f0b-8de9-bc5b62b02181"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"\[ScriptCapitalZ]", "(", "g", ")"}], "\[RightBracketingBar]"}],
      "\[VeryThinSpace]", "\[CenterDot]", 
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"\[ScriptCapitalC]", "(", "g", ")"}], 
      "\[RightBracketingBar]"}]}], "=", 
    RowBox[{
    "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}]}], 
   TraditionalForm]],ExpressionUUID->"f19bcdf6-7a76-4929-9dce-970ce00e4b0c"],
 ". Hence, the inverse of ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungClassSize"]], "paclet:QuantumMob/Q3/ref/YoungClassSize", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["class", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f9bdebc0-c5cb-40c8-a92b-cba024e58bad"],
 "coincides with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungCentralizerSize"]], 
     "paclet:QuantumMob/Q3/ref/YoungCentralizerSize", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["class", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "50d3b59e-9546-4df4-933c-4d50cb6ae237"],
 " up to a factor of the group order (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Sagan, 2001"]], "https://doi.org/10.1007/978-1-4757-6804-6"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "da34016e-d43a-406c-a455-cab34d595075"],
 ")."
}], "Notes",
 CellID->1946686439,ExpressionUUID->"35e6a659-00db-4c76-9574-10b3f1f20275"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

