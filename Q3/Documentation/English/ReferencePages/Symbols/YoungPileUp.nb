Cell[TextData[{
 "Physically, the above procedure corresponds to take a tensor-product \
representation ",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["\[ScriptCapitalW]", 
    RowBox[{"(", "1", ")"}]], "\[CircleTimes]", 
   SubscriptBox["\[ScriptCapitalV]", 
    StyleBox["d",
     FontSlant->"Italic"]]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "47f9d505-194b-4226-9415-1e64ec5f1093"],
 " of the existing irreducible representation ",
 Cell[BoxData[
  SuperscriptBox["\[ScriptCapitalW]", 
   RowBox[{"(", "1", ")"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2084dde2-3804-4352-b275-5e102d7d6f34"],
 " and the native representation ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[ScriptCapitalV]", 
    StyleBox["d",
     FontSlant->"Italic"]], "\[Congruent]", 
   SuperscriptBox["\[ScriptCapitalW]", 
    RowBox[{"(", "1", ")"}]]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8fc8331f-4dbe-4ddb-8ca6-371c08070d40"],
 " of unitary group ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ffea8f2e-af46-4b96-8174-6e01ebbf5cae"],
 "."
}], "ExampleText",
 CellID->981712212,ExpressionUUID->"97e1f06f-8ddb-46a2-8dd9-5a766b1d7df0"],

