Cell[TextData[{
 "In the above example, one can see that the same shape ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{"2", ",", "1"}], ")"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7874f5ec-8471-4c82-b1d0-01caa1e86d0e"],
 " arises both from ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"2", ",", "0"}], ")"}], "\[CircleTimes]", 
   RowBox[{"(", "1", ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "22251473-1b2c-4de3-bfa8-62f784e1a61b"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", ",", "1"}], ")"}], "\[CircleTimes]", 
   RowBox[{"(", "1", ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9bb0275a-9ab8-41d2-abf7-84b27958fb55"],
 ". In order to label different irreducible representations arising from \
different tensor products, one thus need to keep track of the history of the \
resulting Young diagram. This can be achieved most conveniently in terms of \
standard Young tableaux, or technically, in terms of the corresponding \
Gelfand-Young patterns. "
}], "ExampleText",
 CellID->1225172054,ExpressionUUID->"e894fec0-7bc9-4b5e-920d-89dbaa52cc73"],

