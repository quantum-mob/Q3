Cell[TextData[{
 "The unitary matrix ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "57bb2d27-4bf0-474a-94a2-1d77dc25df9e"],
 ", denoted by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", 
    RowBox[{"m", "\[Times]", "m"}]], TraditionalForm]],ExpressionUUID->
  "f74454e3-94e2-498a-8b79-b62f9e03893f"],
 ", describes a canonical transformation from one set of ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "111fdcaa-0fda-46d3-b9b1-8e5fb665c77b"],
 " bosonic modes ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["a", "TI"], 
