Cell[TextData[{
 "Unlike the usual SWAP gate, \[ImaginaryI]SWAP gate is universal as ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Schuch and Siewert (2003)"]], 
    "https://doi.org/10.1103/PhysRevA.67.032301"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "ab15a6fa-f8cb-4df8-9a8d-4722a1d61bc7"],
 " showed by constructing CNOT with single-qubit gates and \[ImaginaryI]SWAP \
gate."
}], "Notes",
 CellID->567322007,ExpressionUUID->"62c7db7f-65f0-4a58-828b-0a1e513420d6"],

Cell[TextData[{
 "Note that the CNOT gate can also be achieved using the",
 Cell[BoxData[
  FormBox[
   SqrtBox["\[ImaginaryI]SWAP"], TraditionalForm]],ExpressionUUID->
  "d1eff0fa-8e86-4120-ada3-f5bfaad34d91"],
 " gate (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Imamoglu et al., 1999"]], 
    "https://doi.org/10.1103/PhysRevLett.83.4204"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "377def47-4f9a-4e84-83af-97cf11308cd6"],
 "). However, this method is not enough to prove that \[ImaginaryI]SWAP \
itself (rather than ",
 Cell[BoxData[
  FormBox[
   SqrtBox["\[ImaginaryI]SWAP"], TraditionalForm]],ExpressionUUID->
  "851f3b92-d401-4d7a-9abf-ed1be3499df5"],
 ") is universal."
}], "Notes",
 CellID->1097930025,ExpressionUUID->"317c6612-e67c-44f2-b3be-3e055981b8da"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

