Cell[TextData[{
 "Here, we demonstrate that \[ImaginaryI]SWAP gate is universal, which was \
first proved by ",
 ButtonBox["Echtenach et al. (2001)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dl.acm.org/doi/10.5555/2016994.2017010"], None}],
 ", by  following ",
 ButtonBox["Schuch and Siewert (2003)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.67.032301"], None}],
 ". This implies that the \[ImaginaryI]SWAP gate is universal (together with \
single-qubit rotations)."
}], "ExampleText",
 CellID->824034105,ExpressionUUID->"1f49e099-8528-4a12-a7a2-91123129d832"],

