Cell[TextData[{
 "Chebyshev points are also known as ",
 StyleBox["Chebyshev nodes",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->535143365,ExpressionUUID->"5010dcdf-5a51-4a52-94da-c19be6cc3b32"],

Cell[TextData[{
 "The Chebyshev points of the first kind are given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "k"], ":=", 
    RowBox[{"cos", "(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"k", "-", 
        RowBox[{"1", "/", "2"}]}], ")"}], 
      RowBox[{"\[Pi]", "/", "n"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"c927f2e9-bafe-4655-b180-545d0f59a154"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "\[Ellipsis]", ",", 
    RowBox[{"n", "."}]}], TraditionalForm]],ExpressionUUID->
  "4262a8a8-caa8-4ac2-85eb-dc49070eac16"]
}], "Notes",
 CellID->1867607051,ExpressionUUID->"b007fda0-a95a-470d-bd84-0d3d0a50c4d3"],

Cell[TextData[{
 "The Chebyshev points of the second kind are given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "k"], ":=", 
    RowBox[{"cos", "(", "\[VeryThinSpace]", 
     RowBox[{"k", "\[VeryThinSpace]", 
      RowBox[{"\[Pi]", "/", 
       RowBox[{"(", 
        RowBox[{"n", "-", "1"}], ")"}]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"0a901dc3-bb73-45a8-a586-aaa961f84e71"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", 
    RowBox[{"n", "-", "1."}]}], TraditionalForm]],ExpressionUUID->
  "19b974ff-6c78-4bf2-8050-792200753a3e"]
}], "Notes",
 CellID->1060991321,ExpressionUUID->"6133f331-37c3-4aab-a19a-4d3f15af5c18"],

Cell[TextData[{
 "Chebyshev points are the projection of equally spaced points along the \
circumference of the unit circle onto the interval ",
 Cell[BoxData[
  RowBox[{"[", 
   RowBox[{
    RowBox[{"-", "1"}], ",", "1"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2e8ca44c-0454-4200-a847-330629320cc2"],
 "."
}], "Notes",
 CellID->1627716796,ExpressionUUID->"3762ae5b-4927-4096-b8d0-edd9ec5c2673"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

