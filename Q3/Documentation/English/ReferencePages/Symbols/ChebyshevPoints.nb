Cell[TextData[{
 "Chebyshev points are also known as ",
 StyleBox["Chebyshev nodes",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->535143365,ExpressionUUID->"642a24b0-6105-4822-8421-0f642cb6c065"],

Cell[TextData[{
 "The Chebyshev points of the first kind are given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "k"], ":=", 
    RowBox[{"cos", "(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"k", "-", 
        RowBox[{"1", "/", "2"}]}], ")"}], 
      RowBox[{"\[Pi]", "/", "n"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ea2dc0d8-8371-4b33-a4a4-a80f9dd720ec"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "\[Ellipsis]", ",", 
    RowBox[{"n", "."}]}], TraditionalForm]],ExpressionUUID->
  "706b9eee-30a7-4abc-82f1-df7cbf60dbb1"]
}], "Notes",
 CellID->1867607051,ExpressionUUID->"7d9b55df-28ff-4593-bb0e-ad9cb8e021d1"],

Cell[TextData[{
 "The Chebyshev points of the second kind are given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "k"], ":=", 
    RowBox[{"cos", "(", "\[VeryThinSpace]", 
     RowBox[{"k", "\[VeryThinSpace]", 
      RowBox[{"\[Pi]", "/", 
       RowBox[{"(", 
        RowBox[{"n", "-", "1"}], ")"}]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"a76cb4fa-bce8-4c7a-86a9-b0b49f77de61"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", 
    RowBox[{"n", "-", "1."}]}], TraditionalForm]],ExpressionUUID->
  "c1c2b3ba-3200-4ddc-886b-c39acd667edf"]
}], "Notes",
 CellID->1060991321,ExpressionUUID->"aa3dd13d-e0e9-49b5-837d-80bc385e5b3e"],

Cell[TextData[{
 "Chebyshev points are the projection of equally spaced points along the \
circumference of the unit circle onto the interval ",
 Cell[BoxData[
  RowBox[{"[", 
   RowBox[{
    RowBox[{"-", "1"}], ",", "1"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b48fb693-7282-4e3c-9956-0dfaa3289074"],
 "."
}], "Notes",
 CellID->1627716796,ExpressionUUID->"e17d01c5-3e3b-435f-9b01-261050e3c1db"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

