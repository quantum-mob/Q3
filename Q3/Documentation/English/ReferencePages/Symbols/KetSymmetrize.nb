  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 55, 27.330337}", 
    "history" -> {"12", "12", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {"symmetric group"}, "specialkeywords" -> {}, 
    "tutorialcollectionlinks" -> {}, "index" -> True, "label" -> 
    "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> "QuantumMob/Q3",
     "status" -> "None", "summary" -> 
    "KetSymmetrize[expr, {s1, s2, ...}, tbl] symmetrizes every Ket[<|...|>] \
appearing in expr according to the poly-tabloid specified by standard Young \
tableau tbl. KetSymmetrize[expr, {s1, s2, ..., sn}] or KetSymmetrize[expr, \
{s1, s2, ..., sn}, 1] is equivalent to KetSymmetrize[expr, {s1, s2, ..., sn}, \
{{1, 2, ..., n}}] and returns a totally symmetric state vector. \
KetSymmetrize[expr, {s1, s2, ..., sn}, -1] is equivalent to \
KetSymmetrize[expr, {s1, s2, ..., sn}, {{1}, {2}, ..., {n}}] and returns a \
totally anti-symmetric state vector. KetSymmetrize[expr, tbl] applies to \
Ket[m1, m2, ...] in expr. This form is for unlabeled qubits.", 
    "synonyms" -> {}, "tabletags" -> {}, "title" -> "KetSymmetrize", 
    "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "KetSymmetrize", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/KetSymmetrize"}},
