Cell["Construct measurement on dressed fermion modes:", "ExampleText",
 CellID->131487747,ExpressionUUID->"eab28fdb-b189-4829-a8de-db8a93a268aa"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{
    RowBox[{"One", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], "]"}], "+", 
    RowBox[{"I", "*", 
     RowBox[{"One", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], ",", "1"}], 
      "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{"WickMeasurement", "@", 
    RowBox[{"Join", "[", 
     RowBox[{"msr", ",", 
      RowBox[{"Conjugate", "@", "msr"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{"Canonicalize", "[", "msr", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->983658100,ExpressionUUID->"b00f04d3-3c63-4905-b2b9-b8393278ecc9"],

