 CellID->131487747,ExpressionUUID->"180e7a8f-1c84-422a-88fe-88ab4147b214"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{
    RowBox[{"One", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], "]"}], "+", 
    RowBox[{"I", "*", 
     RowBox[{"One", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], ",", "1"}], 
      "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{"WickMeasurement", "@", 
    RowBox[{"Join", "[", 
     RowBox[{"msr", ",", 
      RowBox[{"Conjugate", "@", "msr"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{"Canonicalize", "[", "msr", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->983658100,ExpressionUUID->"32e579b1-e536-42fe-a673-861386ee34e4"],

