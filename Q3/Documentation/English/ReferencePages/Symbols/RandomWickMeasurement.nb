    "history" -> {"14.3", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {
     "fermionic quantum computation", "fermionic Gaussian state"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "RandomWickMeasurement[{k, n}] randomly generates a WickMeaurement on k \
dressed fermion modes composed of n bare fermion modes. \
RandomWickMeasurement[n] randomly selects k from {1, 2, ..., n}. \
RandomWickMeasurement[p -> n] picks some of n bare fermion modes with \
probability p and returns WickMeasurement on them. RandomWickMeasurement[p -> \
WickMeasurement[{v1, v2, ...}]] picks some of dressed fermion modes dk \
described by vk and returns WickMeasurement on them. \
RandomWickMeasurement[{p1, p2, ...} -> WickMeasurement[{v1, v2, ...}]] \
applies different probabilities pk for different dressed modes dk.", 
    "synonyms" -> {}, "tabletags" -> {}, "title" -> "RandomWickMeasurement", 
    "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "RandomWickMeasurement", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/RandomWickMeasurement"}},
