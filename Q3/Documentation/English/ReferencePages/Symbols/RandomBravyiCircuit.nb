Cell[TextData[{
 "Each unitary layer describes unitary evolution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      StyleBox["ham",
       FontSlant->"Italic"], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"3db81986-1dd3-4a67-b2b3-4034d2c34ded"],
 " with random evolution time \[Tau] governed by the distribution function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[Tau]", ")"}], "\[Proportional]", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"8db532d6-812e-4889-979d-eb3d5b3153f1"],
 ", and in each measurement layer, each fermion mode is measured with \
probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"1", "/", "n"}]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a2b81af2-4ab8-48f4-9d91-db0453e19267"],
 "."
}], "ExampleText",
 CellID->1259663973,ExpressionUUID->"e6e8729c-d1eb-40b0-bfeb-0fb13db30d05"],

