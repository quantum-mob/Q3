Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["RandomBravyiCircuit"]], 
         "paclet:QuantumMob/Q3/ref/RandomBravyiCircuit", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          StyleBox["uni", "TI"], ",", 
          StyleBox["p", "TI"]}], 
         StyleBox["}", "TI"]}], ",", 
        StyleBox["dep", "TI"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "bf20d35d-b4d5-4b5b-acdd-3f9a4026c557"],
     "\[LineSeparator]generate a random quantum circuit on non-interacting \
fermion modes, where layers of fixed unitary gate ",
     Cell[BoxData[
      StyleBox["uni", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a5b07312-7e48-44b1-ae82-ad5d40ee7619"],
     " (either ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiUnitary"]], 
         "paclet:QuantumMob/Q3/ref/BravyiUnitary", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       StyleBox["\[Ellipsis]", "TR"], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "82d867a2-bf25-46eb-8001-7b701f4ceccf"],
     " or ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["NambuUnitary"]], "paclet:QuantumMob/Q3/ref/NambuUnitary", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       StyleBox["\[Ellipsis]", "TR"], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ba128733-c991-4603-922e-293e127bb9c2"],
     ") alternate with layers of measurements (",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "b12b9c1a-0a35-418d-9511-c6baf8d40db6"],
     ") on fermion modes selected randomly with probability ",
     Cell[BoxData[
      StyleBox["p", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "28a20450-001f-4fb6-a41b-eeae7ec9686c"],
     " to form an overall depth ",
     Cell[BoxData[
      StyleBox["dep", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "97924993-419d-4ba2-ab8a-c89a82121a23"],
     "."
    }],ExpressionUUID->"633205c7-540a-4bd1-967e-31c58acdac48"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["RandomBravyiCircuit"]], 
         "paclet:QuantumMob/Q3/ref/RandomBravyiCircuit", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          StyleBox["ham", "TI"], ",", 
          StyleBox["pdf", "TI"], ",", 
          StyleBox["p", "TI"]}], "}"}], ",", 
        StyleBox["dep", "TI"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c4b12515-c069-42ce-8081-a5828a64e88f"],
     "\[LineSeparator]constructs unitary layers of random unitary gate ",
     Cell[BoxData[
      RowBox[{
       StyleBox["uni", "TI"], "=", 
       RowBox[{
        TemplateBox[{
          Cell[
           TextData["Exp"]], "paclet:ref/Exp"},
         "RefLink",
         BaseStyle->{"InlineFormula"}], "[", 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", 
         StyleBox["ham", "TI"], " ", 
         StyleBox["\[Tau]", "TR"]}], "]"}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a8b10668-d059-4ff5-9e10-3c749da39d68"],
     " with single-particle Hamiltonian ",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "54501e96-0efb-4831-92ff-700eb5261803"],
     " (either ",
     Cell[BoxData[
      RowBox[{
       StyleBox["n", "TI"], "\[Times]", 
       StyleBox["n", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3052308c-a504-453a-ab64-8a80d49ec4fb"],
     " Hermitian matrix or ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["NambuHermitian"]], 
         "paclet:QuantumMob/Q3/ref/NambuHermitian", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       StyleBox["\[Ellipsis]", "TR"], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "dd3b86c5-ec18-47df-85a1-cc193bbf759f"],
     ") and the random evolution time \[Tau] distributed according to the \
probability distribution function ",
     Cell[BoxData[
      StyleBox["pdf", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "bf763c9a-fd07-4839-b144-feb8d8d1560b"],
     "."
    }],ExpressionUUID->"1820817b-c9c2-45ba-9c2c-629a2b06bc63"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["RandomBravyiCircuit"]], 
         "paclet:QuantumMob/Q3/ref/RandomBravyiCircuit", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          StyleBox["ham", "TI"], ",", 
          StyleBox["p", "TI"]}], "}"}], ",", 
        StyleBox["dep", "TI"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "64afb206-f75e-4d80-8c92-6df1c341b610"],
     "\[LineSeparator]assumes that the evolution time is uniformly \
distributed over the interval ",
     Cell[BoxData[
      FormBox[
       RowBox[{"[", 
        RowBox[{"0", ",", 
         RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
          RowBox[{"n", "/", "max"}]}]}], "]"}], TraditionalForm]],
      ExpressionUUID->"8f5ab720-5628-439a-8a5d-13edcdf26a36"],
     ", where ",
     Cell[BoxData[
      StyleBox["max", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "bd934e3b-f892-42ac-8cde-d5dd41e52a57"],
     " is the maximum of the absolute values of the entries of ",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "21ff6e7a-fb0f-4140-90cd-2236f79cde4a"],
     "."
    }],ExpressionUUID->"5b6e0b10-1039-4bfe-ab1e-19630bc0a19c"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["RandomBravyiCircuit"]], 
         "paclet:QuantumMob/Q3/ref/RandomBravyiCircuit", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["ham", "TI"], ",", 
        StyleBox["dep", "TI"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "edc9ad97-6953-4238-8d46-8d63a067427a"],
     "\[LineSeparator]generates a circuit for ",
     Cell[BoxData[
      StyleBox["n", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c3ffe7bc-e0db-43ef-8d6e-aeef36b6b8db"],
     " fermion modes where each unitary layer corresponds to time evolution ",
     
     Cell[BoxData[
      FormBox[
       RowBox[{"U", "=", 
        RowBox[{"exp", "[", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "H", "\[VeryThinSpace]",
           "\[Tau]"}], "]"}]}], TraditionalForm]],ExpressionUUID->
      "9914ecb3-87f6-40d7-a36d-a61fb96abe23"],
     " (",
     Cell[BoxData[
      RowBox[{
       StyleBox["H", "TI"], "=", 
       StyleBox["ham", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "2efe9c2b-b8b5-473d-84e3-ad702045d4bb"],
     ") with the evolution time ",
     Cell[BoxData[
      FormBox["\[Tau]", TraditionalForm]],ExpressionUUID->
      "2a5b24dc-efe7-4a0c-9076-74b8bffbb75c"],
     " distributed by ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        RowBox[{"P", "(", "\[Tau]", ")"}], "\[Proportional]", 
        RowBox[{"exp", "[", 
         RowBox[{
          RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Tau]"}], "]"}]}], 
       TraditionalForm]],ExpressionUUID->
      "e74759ea-6896-44f4-bd81-740898df4dc1"],
     " and each measurement layer measures a fermion mode with probability ",
     Cell[BoxData[
      FormBox[
       RowBox[{"p", "=", 
        RowBox[{"1", "/", "n", "\[VeryThinSpace]"}]}], TraditionalForm]],
      ExpressionUUID->"ea59a802-cbeb-41ee-bb7d-14a9f1a0c7a9"],
     "."
    }],ExpressionUUID->"24ddfb24-004b-477d-841f-7835041fb67a"]}
  }]], "Usage",
 CellID->2053903446,ExpressionUUID->"5656387c-ab4f-43df-b9c3-b1015b6ca7fa"]
}, Open  ]],

