Cell[TextData[{
 "Note that the resulting matrix is intended to operate on a ",
 StyleBox["row vector",
  FontSlant->"Italic"],
 " from the ",
 StyleBox["right",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->493597777,ExpressionUUID->"6f59a72b-29e9-436f-bfb8-f5d6e2ff8620"],

Cell[TextData[{
 "When the rows of matrix ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a9c47b5a-0ff2-4d03-bb10-1090a99de512"],
 " are orthogonal, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["m", "TI"], ".", 
   StyleBox["h", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "818b0957-c6ed-492e-8947-98f5ea6abde3"],
 " is diagonal, where ",
 Cell[BoxData[
  RowBox[{
   StyleBox["h", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["HouseholderMatrix"]], 
      "paclet:QuantumMob/Q3/ref/HouseholderMatrix", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "02dd3481-a37d-4654-84e8-9931f0204cd9"],
 ". In particular, when the rows of ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d8a9a112-b70a-4e9b-9f9a-b8d355345256"],
 " are both orthogonal and normalized, all diagonal elements of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["m", "TI"], ".", 
   StyleBox["h", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0be72cf7-3efc-4fea-9995-935247a7ffb2"],
 " are equal to 1. Therefore, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["HouseholderMatrix"]], 
     "paclet:QuantumMob/Q3/ref/HouseholderMatrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "06135bad-d7bd-4e6d-b2d1-1b4eb3804046"],
 " can be used to find the unitary transformation that transforms the \
orthogonal complex vectors ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["v", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["v", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "35fd6d66-54c4-4e67-9e5c-685623645336"],
 " to canonical axes, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0", ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "0", ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ac40571b-0745-42a6-bcee-a693432aa35f"],
 "."
}], "Notes",
 CellID->1277815136,ExpressionUUID->"87b72a3f-8bc8-454e-a434-513ad3445dfe"],

Cell[TextData[{
 "The ",
 StyleBox["Householder reflection",
  FontSlant->"Italic"],
 " associated with a ",
 StyleBox["d",
  FontSlant->"Italic"],
 "-dimensional complex vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalC]", "d"]}], TraditionalForm]],
  ExpressionUUID->"4a459069-998a-4138-a767-f3b56d0fccb6"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", "w"], ":=", 
    RowBox[{"I", "-", 
     RowBox[{"2", 
      FractionBox[
       RowBox[{"w", "\[CenterDot]", 
        SuperscriptBox["w", "\[Dagger]"]}], 
       SuperscriptBox[
        RowBox[{
        "\[LeftDoubleBracketingBar]", "w", "\[RightDoubleBracketingBar]"}], 
        "2"]]}]}]}], TraditionalForm]],ExpressionUUID->
  "43d95f34-3f60-4293-b2e9-b6faef268af6"],
 " (to operate on a ",
 StyleBox["column vector",
  FontSlant->"Italic"],
 " from the ",
 StyleBox["left",
  FontSlant->"Italic"],
 "),\[LineSeparator]represents a reflection in the hyper plane perpendicular \
to ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "bce134f9-60a2-45a1-a7c7-e08baef6c191"],
 ". Note that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", "w"], TraditionalForm]],ExpressionUUID->
  "94e42b9c-ceba-4d5d-ab59-5c4715f43f47"],
 " can be obtained using the built-in function ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ReflectionMatrix"]], "paclet:ref/ReflectionMatrix"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8d7e8794-5151-438d-8703-68044fe9bb3c"],
 ", ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["R", "TI"], 
    StyleBox["w", "TI"]], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["ReflectionMatrix"]], "paclet:ref/ReflectionMatrix"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["w", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8fe43073-bf93-46fb-a63c-263e1d282421"],
 "."
}], "Notes",
 CellID->1246574096,ExpressionUUID->"46994200-76a4-400d-938a-a6642dbf5743"],

Cell[TextData[{
 "Note that the transformation\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "w"], ":=", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["R", "w"]}], "=", 
     RowBox[{
      RowBox[{"2", 
       FractionBox[
        RowBox[{"w", "\[CenterDot]", 
         SuperscriptBox["w", "\[Dagger]"]}], 
        SuperscriptBox[
         RowBox[{
         "\[LeftDoubleBracketingBar]", "w", "\[RightDoubleBracketingBar]"}], 
         "2"]]}], "-", "I"}]}]}], TraditionalForm]],ExpressionUUID->
  "1233142c-7eea-4513-aa02-489053baff7f"],
 "\[LineSeparator]represents a reflection in the line along ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "2d1eabd7-5a30-4eec-b4f0-2fb83660e09d"],
 "."
}], "Notes",
 CellID->1614960333,ExpressionUUID->"8f193b8d-5abc-4b8e-ac47-95fdb8899b6a"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

