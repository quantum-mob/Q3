Cell[TextData[{
 "Note that the resulting matrix is intended to operate on a ",
 StyleBox["row vector",
  FontSlant->"Italic"],
 " from the ",
 StyleBox["right",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->493597777,ExpressionUUID->"f44e8292-605e-4f97-bba0-afb3f9b251aa"],

Cell[TextData[{
 "When the rows of matrix ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0488afa8-a114-4cf2-8a9d-07fd4d27b017"],
 " are orthogonal, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["m", "TI"], ".", 
   StyleBox["h", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4723689-f035-472f-a358-e2414dd92911"],
 " is diagonal, where ",
 Cell[BoxData[
  RowBox[{
   StyleBox["h", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["HouseholderMatrix"]], 
      "paclet:QuantumMob/Q3/ref/HouseholderMatrix", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "db5909d3-4a1a-4667-8810-a9ca71ed870f"],
 ". In particular, when the rows of ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1d1c2370-b132-466e-92ec-0918c43b1cf3"],
 " are both orthogonal and normalized, all diagonal elements of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["m", "TI"], ".", 
   StyleBox["h", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "236ca875-ea8e-4730-8094-d7f4966a9a40"],
 " are equal to 1. Therefore, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["HouseholderMatrix"]], 
     "paclet:QuantumMob/Q3/ref/HouseholderMatrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f1caded2-6523-485d-ad2a-b481c0be6658"],
 " can be used to find the unitary transformation that transforms the \
orthogonal complex vectors ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["v", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["v", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ec14c244-a0b7-44f9-b2fa-76d0cf1bb8f2"],
 " to canonical axes, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0", ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "0", ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e120f55c-fe2e-4478-83b5-79b6c88dbdcc"],
 "."
}], "Notes",
 CellID->1277815136,ExpressionUUID->"f3625cdd-492b-4f5c-8032-9eb7a610d118"],

Cell[TextData[{
 "The ",
 StyleBox["Householder reflection",
  FontSlant->"Italic"],
 " associated with a ",
 StyleBox["d",
  FontSlant->"Italic"],
 "-dimensional complex vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalC]", "d"]}], TraditionalForm]],
  ExpressionUUID->"ab2651f5-c9c5-408b-abe6-82dac174fd9f"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", "w"], ":=", 
    RowBox[{"I", "-", 
     RowBox[{"2", 
      FractionBox[
       RowBox[{"w", "\[CenterDot]", 
        SuperscriptBox["w", "\[Dagger]"]}], 
       SuperscriptBox[
        RowBox[{
        "\[LeftDoubleBracketingBar]", "w", "\[RightDoubleBracketingBar]"}], 
        "2"]]}]}]}], TraditionalForm]],ExpressionUUID->
  "9237ed69-1106-4637-b5f4-810c3b826fae"],
 " (to operate on a ",
 StyleBox["column vector",
  FontSlant->"Italic"],
 " from the ",
 StyleBox["left",
  FontSlant->"Italic"],
 "),\[LineSeparator]represents a reflection in the hyper plane perpendicular \
to ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "65a7db97-5966-4ce5-b5c0-701b38109278"],
 ". Note that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", "w"], TraditionalForm]],ExpressionUUID->
  "4b3fa51d-3b57-4532-b2dc-9d2ece839ee1"],
 " can be obtained using the built-in function ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ReflectionMatrix"]], "paclet:ref/ReflectionMatrix"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "71724d2b-6e44-4d1a-8f6a-c171bd9e8548"],
 ", ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["R", "TI"], 
    StyleBox["w", "TI"]], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["ReflectionMatrix"]], "paclet:ref/ReflectionMatrix"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["w", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "819fdc5c-9500-401a-aab5-91bb072a2253"],
 "."
}], "Notes",
 CellID->1246574096,ExpressionUUID->"837997a1-69fc-4d41-8323-2ac13f0457d5"],

Cell[TextData[{
 "Note that the transformation\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "w"], ":=", 
    RowBox[{
     RowBox[{"-", 
      SubscriptBox["R", "w"]}], "=", 
     RowBox[{
      RowBox[{"2", 
       FractionBox[
        RowBox[{"w", "\[CenterDot]", 
         SuperscriptBox["w", "\[Dagger]"]}], 
        SuperscriptBox[
         RowBox[{
         "\[LeftDoubleBracketingBar]", "w", "\[RightDoubleBracketingBar]"}], 
         "2"]]}], "-", "I"}]}]}], TraditionalForm]],ExpressionUUID->
  "7e358a2a-c807-4c0b-bbf1-c1312deb30bf"],
 "\[LineSeparator]represents a reflection in the line along ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "15c3ce4b-3775-4f11-916f-36a2f9c4edb9"],
 "."
}], "Notes",
 CellID->1614960333,ExpressionUUID->"9165ac20-1ade-4ae9-96c1-385cc3251107"]
}, Closed]],

