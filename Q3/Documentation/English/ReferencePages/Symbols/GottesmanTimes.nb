Cell[TextData[{
 "If ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d8bc41f3-79d6-408c-8d20-80142840d494"],
 " and ",
 Cell[BoxData[
  StyleBox["b", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1faa0aed-677e-4658-87e1-c99a0223ed2d"],
 " are full Gottesman vectors, then it corresponds to the group \
multiplication in the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 "; that is, the phase factors \[PlusMinus]1 and \[PlusMinus]\[ImaginaryI] \
are kept and a full Gottesman vector is returned. Otherwise, it corresponds \
to the group multiplication in the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 "."
}], "Notes",
 CellID->1725353614,ExpressionUUID->"6ecfb893-8ac9-467b-b548-b787f0cc12fd"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

