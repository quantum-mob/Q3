Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "otoc", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"progress", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ProgressIndicator", "@", 
  RowBox[{"Dynamic", "[", "progress", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$k", "=", "5"}], ";", 
  RowBox[{"p", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"otoc", "[", "$k", "]"}], "=", 
  RowBox[{
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"progress", "=", 
       RowBox[{
        RowBox[{"++", "p"}], "/", "$T"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"CliffordScramblingSimulate", "[", 
       RowBox[{"$k", ",", 
        RowBox[{"{", 
         RowBox[{"$n", ",", "t"}], "}"}], ",", "0"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "$T"}], "}"}]}], "\[IndentingNewLine]", 
    "]"}], "//", "Chop"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
