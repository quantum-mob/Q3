Cell[BoxData[{
 RowBox[{
  RowBox[{"tmp", "=", 
   RowBox[{"First", "@", 
    RowBox[{"RandomBravyiMeasurement", "[", 
     RowBox[{"{", 
      RowBox[{"$k", ",", "$n"}], "}"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmp", "=", 
   RowBox[{
    RowBox[{"Re", "[", 
     RowBox[{"RandomVector", "[", "$k", "]"}], "]"}], "*", "tmp"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "=", 
  RowBox[{"BravyiMeasurement", "[", "tmp", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"NormSquare", "/@", 
  RowBox[{"First", "[", "msr", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"new", "=", 
  RowBox[{"Canonicalize", "[", "msr", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"NormSquare", "/@", 
  RowBox[{"First", "[", "new", "]"}]}]}], "Input",
