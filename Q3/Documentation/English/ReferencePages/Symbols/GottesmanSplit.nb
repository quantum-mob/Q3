Cell[TextData[{
 "For a matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "ff33b4c2-a1f5-4456-90be-f368bf97c3ec"],
 " consisting of rows of ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d2a8ecc6-b468-4650-bf49-722d74386b2f"],
 " Gottesman vectors,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["x", "11"], 
        SubscriptBox["z", "11"], 
        SubscriptBox["x", "12"], 
        SubscriptBox["z", "12"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"1", "n"}]], 
        SubscriptBox["z", 
         RowBox[{"1", "n"}]]},
       {
        SubscriptBox["x", "21"], 
        SubscriptBox["z", "21"], 
        SubscriptBox["x", "22"], 
        SubscriptBox["z", "22"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"2", "n"}]], 
        SubscriptBox["z", 
         RowBox[{"2", "n"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", "\[VerticalEllipsis]",
         "\[VerticalEllipsis]"},
       {
        SubscriptBox["x", "k1"], 
        SubscriptBox["z", "k1"], 
        SubscriptBox["x", "k2"], 
        SubscriptBox["z", "k2"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"k", " ", "n"}]], 
        SubscriptBox["z", 
         RowBox[{"k", " ", "n"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "da348a8e-b909-4ca4-af94-1bb457adc575"],
 ",\[LineSeparator]",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanSplit"]], "paclet:QuantumMob/Q3/ref/GottesmanSplit", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0b29f37d-3664-48b2-9909-e1ba61be339c"],
 " gives a list of the X- and Z-part, that is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{GridBox[{
       {
        SubscriptBox["x", "11"], 
        SubscriptBox["x", "12"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"1", "n"}]]},
       {
        SubscriptBox["x", "21"], 
        SubscriptBox["x", "22"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"2", "n"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]",
         "\[VerticalEllipsis]"},
       {
        SubscriptBox["x", "k1"], 
        SubscriptBox["x", "k2"], "\[CenterEllipsis]", 
        SubscriptBox["x", 
         RowBox[{"k", " ", "n"}]]}
      }], "|", GridBox[{
       {
        SubscriptBox["z", "11"], 
        SubscriptBox["z", "12"], "\[CenterEllipsis]", 
        SubscriptBox["z", 
         RowBox[{"1", "n"}]]},
       {
        SubscriptBox["z", "21"], 
        SubscriptBox["z", "22"], "\[CenterEllipsis]", 
        SubscriptBox["z", 
         RowBox[{"2", "n"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]",
         "\[VerticalEllipsis]"},
       {
        SubscriptBox["z", "k1"], 
        SubscriptBox["z", "k2"], "\[CenterEllipsis]", 
        SubscriptBox["z", 
         RowBox[{"k", " ", "n"}]]}
      }]}], ")"}], TraditionalForm]],ExpressionUUID->
  "b7d52d2b-5b9f-4477-9485-fa095996acce"],
 "."
}], "Notes",
