Cell[TextData[{
 "The (normal) Green\[CloseCurlyQuote]s function of fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "d9be99b1-3a56-4be8-876f-2b1d72f2c848"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubsuperscriptBox["c", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"3d13ae02-c343-4c40-a031-e393d4d88921"],
 ". The matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "72ee455f-3cba-4c5e-ac2d-ea7eacb3f88e"],
 " is Hermitian, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", "\[Dagger]"], "=", "G"}], TraditionalForm]],
  ExpressionUUID->"44cf3b25-a3a9-4be5-a0a2-bec004693171"],
 ". The ",
 StyleBox["correlation matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubsuperscriptBox["c", "i", "\[Dagger]"], 
       SubscriptBox["c", "j"]}], "\[RightAngleBracket]"}], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"I", "-", 
        SuperscriptBox["G", "T"]}], ")"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"41778e1e-bdc5-4564-b769-26db28fa94f0"],
 " has equivalent information and is also frequently used."
}], "Notes",
 CellID->348061621,ExpressionUUID->"29c5c7c5-223a-41e3-9e0c-68c6b4d4222c"],

Cell[TextData[{
 "The anomalous Green\[CloseCurlyQuote]s function of fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "c84d172b-0ff2-4900-a986-e700d614efb5"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubscriptBox["c", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"537167de-360e-4a77-9242-1cc374afdeb8"],
 ". The matrix ",
 Cell[BoxData[
  FormBox["F", TraditionalForm]],ExpressionUUID->
  "05c91b06-d525-425b-8a4b-48f960dd10be"],
 " is skew-symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", "T"], "=", 
    RowBox[{"-", "F"}]}], TraditionalForm]],ExpressionUUID->
  "0f2733a8-c99b-4648-91a4-6ef585707198"],
 "."
}], "Notes",
 CellID->1383491325,ExpressionUUID->"8628796a-f06a-414d-99f5-44b791476d40"],

Cell[TextData[{
 "In the Nambu notation, the full Green\[CloseCurlyQuote]s function is \
defined to be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["G", "_"], ":=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       UnderscriptBox["c", "_"], 
       SuperscriptBox[
        UnderscriptBox["c", "_"], "\[Dagger]"]}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      RowBox[{"(", GridBox[{
         {"G", "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], 
          RowBox[{"I", "-", 
           SuperscriptBox["G", "T"]}]}
        }], ")"}], "=", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"I", "-", 
           SuperscriptBox["C", "T"]}], "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], "C"}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "bc87d477-331b-43d2-9f38-cd9677224652"],
 ", where  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     UnderscriptBox["c", "_"], "\[Dagger]"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["c", "1", "\[Dagger]"], ",", "\[Ellipsis]", ",", 
      SubsuperscriptBox["c", "n", "\[Dagger]"], ",", 
      SubscriptBox["c", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["c", "n"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "49f51c40-a023-4cf5-8477-0419d51791f2"],
 "."
}], "Notes",
 CellID->795234925,ExpressionUUID->"393305de-bbb5-4c05-bc5b-6428a6bf3b2b"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiTimeReversalMoment"]], 
     "paclet:QuantumMob/Q3/ref/BravyiTimeReversalMoment", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["\[Ellipsis]", "TR"], ",", 
    RowBox[{"\"\<Epsilon\>\"", "\[Rule]", 
     StyleBox["\[Epsilon]", "TR"]}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f0b28cef-6f63-49d9-b34c-c2b401015879"],
 " shifts ",
 Cell[BoxData[
  RowBox[{
   StyleBox["G", "TI"], "\[RightArrow]", 
   RowBox[{
    StyleBox["G", "TI"], "+", 
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     StyleBox["\[Epsilon]", "TR"]}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "88db521d-c47f-4c2d-b036-47f8c906c619"],
 " to tame some singular matrices. The default setting is ",
 Cell[BoxData[
  RowBox[{"\"\<Epsilon\>\"", "\[Rule]", "0"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2eda23bc-f6e0-412f-9e64-91090db77fa1"],
 ". This option may be unnecessary when the program code is updated to better \
handle trivial Green's functions."
}], "Notes",
 CellID->522646582,ExpressionUUID->"bd677c48-0b66-4caf-b854-efa4448105a7"]
}, Dynamic[CurrentValue[
