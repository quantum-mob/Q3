Cell[TextData[{
 "Any fermionic Gaussian state of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "27446791-6eb9-4e4f-99ba-ee74986de0b9"],
 " fermion modes can be written as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     FractionBox["\[ScriptCapitalN]", 
      SuperscriptBox["2", "n"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "n"]}]}], TraditionalForm]],ExpressionUUID->
  "386db199-992f-4704-9462-fb510e886c7e"],
 "(1+\[ImaginaryI]\[VeryThinSpace]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "k"], 
     SubscriptBox["c", 
      RowBox[{
       RowBox[{"2", "k"}], "-", "1"}]], 
     SubscriptBox["c", 
      RowBox[{"2", "k"}]]}], ")"}], TraditionalForm]],ExpressionUUID->
  "6f5de959-f5ef-4ed9-ae34-694ba002ef45"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "5cc77d7b-0bab-4f3b-b566-2d0b458917b8"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"2", "n"}]}], TraditionalForm]],ExpressionUUID->
  "2f2b7403-7484-4259-a5f5-92d0ebb7a25b"],
 ") are Majorana fermion operators corresponding to the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "2df8329c-5d03-4c18-bd5a-24626d9521e1"],
 " Dirac fermion modes, ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalN]", TraditionalForm]],ExpressionUUID->
  "c473dac7-f10b-4c6c-a402-61f7814582fa"],
 " is the norm square of the state (i.e., note that some quantum channels do \
not preserve the trace of the state and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "\[VeryThinSpace]", "\[Rho]"}], "=", "\[ScriptCapitalN]"}], 
   TraditionalForm]],ExpressionUUID->"7b07a975-4eb9-4265-afcf-d04d94ab7bc6"],
 "), and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "672ee104-deef-4ed5-822e-83b5e3b4b694"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "k"], "\[Element]", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "1"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"8bda6092-ea25-407a-819d-6713da93eddd"],
 ") are eigenvalues of the ",
 StyleBox["covariance matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "27c68a8a-a014-4b90-ac07-a1b542ab5849"],
 ", which is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "28c169bb-5df8-4bb1-bf36-8dd0e3cb315e"],
 " real anti-symmetric matrix (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["V", "T"], "=", 
    RowBox[{"-", "V"}]}], TraditionalForm]],ExpressionUUID->
  "de3661da-8574-4016-a9c6-830d39ceb21f"],
 ") in the Majorana spinor space [",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
      StyleBox[{
        StyleBox["Bravyi", IgnoreSpellCheck -> True], " (2005)"}]]], 
    "https://dl.acm.org/doi/abs/10.5555/2011637.2011640"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "b13fbbd3-8c96-4672-98f2-edeae25bf38c"],
 "]."
}], "Notes",
 CellID->52239125,ExpressionUUID->"a00ea5d6-00fe-48aa-acc4-c596238ba9a0"],

Cell[TextData[{
 "Introducing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n"}], TraditionalForm]],ExpressionUUID->
  "1067c89a-39a7-4824-9d7d-680f6e353535"],
 " ",
 ButtonBox["Grassmann variables",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Grassmann"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "i"], TraditionalForm]],ExpressionUUID->
  "e8ab3b8e-c78a-433e-9ecb-b88947ac4707"],
 " respectively corresponding to the Majorana modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "15b6defa-b781-40b3-bda8-ab28aaa17a0a"],
 ", the fermionic Gaussian state reads as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[DotEqual]", 
    RowBox[{
     FractionBox["\[ScriptCapitalN]", 
      SuperscriptBox["2", "n"]], 
     RowBox[{"exp", "(", 
      RowBox[{
       FractionBox["\[ImaginaryI]", "2"], 
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"i", ",", 
         RowBox[{"j", "=", "1"}]}], 
        RowBox[{"2", "n"}]], 
       SubscriptBox["x", "i"], 
       SubscriptBox["V", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["x", "j"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "bab9e03d-cd61-4004-bedc-347a7b341916"],
 " ,\[LineSeparator]expressed directly in terms of the covariance matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "b9e25bbf-78ac-4f25-a8b7-4e78e85f91b9"],
 " [",
 StyleBox[ButtonBox["Bravyi",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dl.acm.org/doi/abs/10.5555/2011637.2011640"], None}],
  IgnoreSpellCheck->True],
 ButtonBox[" (2005)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://dl.acm.org/doi/abs/10.5555/2011637.2011640"], None}],
 "]."
}], "Notes",
 CellID->1331370085,ExpressionUUID->"0bfdb9d5-27e2-491a-86e3-e2a6298f5c3f"],

Cell[TextData[{
 "The ",
 StyleBox["covariance matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "d6b33df1-9673-4da5-ba55-59ff92e5c2dc"],
 " is related the matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "fc991d5d-dca0-4066-a12f-7223b3b81045"],
 " of ",
 ButtonBox["Green\[CloseCurlyQuote]s functions",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiGreen"],
 " by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"C", "\[Congruent]", 
     RowBox[{"I", "-", 
      RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "V"}]}]}], "=", 
    RowBox[{"M", "\[VeryThinSpace]", "G", "\[VeryThinSpace]", 
     SuperscriptBox["M", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "f4390ae4-bf83-4a28-a494-6512fb5a13c8"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubscriptBox["c", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"2baebb4c-65f2-4151-8a1e-f0496a5beb85"],
 "\t(",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ",", 
    RowBox[{"j", "=", "1"}], ",", "2", ",", "...", ",", 
    RowBox[{"2", "n"}]}], TraditionalForm]],ExpressionUUID->
  "07de52bc-c7bb-4160-8f40-a2c53d15e1da"],
 "),\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "c6c0d286-1268-4c62-a521-d315a4eb9710"],
 " is the matrix describing the ",
 ButtonBox["canonical transformation from Dirac to Majorana fermion modes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ToMajoranaMatrix"],
 ". Recall that the Green\[CloseCurlyQuote]s functions matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "1c4f0ce8-34b6-45c6-922a-dbd92fb57aff"],
 " is in the ",
 ButtonBox["block form",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/NambuGreen"],
 "\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{"(", GridBox[{
       {"g", "f"},
       {
        SuperscriptBox["f", "\[Dagger]"], 
        RowBox[{"I", "-", 
         SuperscriptBox["g", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "db15efb0-f3d2-4818-a250-4c276aab9a71"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"1ed88f79-5451-44f8-ac44-5ff4db2c7286"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubscriptBox["a", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"3581594b-5bff-4c60-8c80-e28640657b6d"],
 " ."
}], "Notes",
 CellID->1077220984,ExpressionUUID->"db490bae-dd9e-485e-b7b5-25278715a610"],

Cell[TextData[{
 "More explicitly,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{
     RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
      RowBox[{"M", "(", 
       RowBox[{"G", "-", 
        RowBox[{
         FractionBox["1", "2"], "I"}]}], ")"}], 
      SuperscriptBox["M", "\[Dagger]"]}], "=", 
     RowBox[{
      RowBox[{"\[ImaginaryI]", "(", GridBox[{
         {"1", "1"},
         {
          RowBox[{"-", "\[ImaginaryI]", "\[VeryThinSpace]"}], 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]"}]}
        }], ")"}], 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"g", "-", 
           FractionBox["1", "2"]}], "f"},
         {
          SuperscriptBox["f", "\[Dagger]"], 
          RowBox[{
           FractionBox["1", "2"], "-", 
           SuperscriptBox["g", "T"]}]}
        }], ")"}], 
      RowBox[{"(", GridBox[{
         {"1", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]"}]},
         {"1", 
          RowBox[{"-", "\[ImaginaryI]", "\[VeryThinSpace]"}]}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "77d76aa6-34b4-4d09-86a4-1d3aba06f51f"],
 "."
}], "Notes",
 CellID->2045961203,ExpressionUUID->"5749d9ca-b49f-4169-9d23-f16a063152b3"]
