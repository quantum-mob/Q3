Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickSimulate"]], "paclet:QuantumMobQ3/ref/WickSimulate", 
         "QuantumMobQ3 Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["jmp", "TI"], ",", 
        StyleBox["in", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4061a402-fd01-4084-990b-bbaeb1142441"],
     "\[LineSeparator]solves the quantum master equation for a \
non-interacting dissipative fermionic many-body system by using the Monte \
Carlo simulation method (also known as the quantum jump approach or quantum \
trajectory method). The model is specified by the single-particle Hamiltonian \
",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "0640151f-9b3a-45e2-83c8-eb0c732b8513"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickHermitian"]], "paclet:QuantumMob/Q3/ref/WickHermitian",
         "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "03e43b54-a751-4675-baf0-0c5f2b05238c"],
     " form and the quantum jump operators are specified by ",
     Cell[BoxData[
      StyleBox["jmp", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f77361f0-39f8-4c13-ab38-6701268b7dda"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickJump"]], "paclet:QuantumMob/Q3/ref/WickJump", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "43433188-a00a-431e-9a09-a47d5799feaa"],
     " form. The simulation starts from the initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "fa119285-325f-449e-ba5c-05db09d48c1a"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickState"]], "paclet:QuantumMob/Q3/ref/WickState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4278ae95-fead-48b8-bc4e-f52749f9a263"],
     "  form at time 0 and runs to time \[Tau] in steps of size ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "497917ea-34e6-4081-9a42-29db2ce3f2b4"],
     "."
    }],ExpressionUUID->"6e082431-d4b6-43ed-9566-dbeea47d184c"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickSimulate"]], "paclet:QuantumMob/Q3/ref/WickSimulate", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["spec", "TI"], ",", 
        StyleBox["\[Ellipsis]", "TR"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d50b353c-23c1-41d6-beaa-8ae37a1cdd49"],
     "\[LineSeparator]collects states in steps of ",
     Cell[BoxData[
      RowBox[{
       StyleBox["k", "TI"], "\[Times]", 
       StyleBox["dt", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "708b17aa-4a63-44d0-b4b3-1987d71bc7ca"],
     " (rather than ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f22794e7-cdf0-4d5d-a6e8-ee8105b8d5af"],
     "), where ",
     Cell[BoxData[
      StyleBox["k", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "2665a9d1-a53a-45e1-a780-4da06f06c69d"],
     " must be an integer or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["All"]], "paclet:ref/All"},
       "RefLink",
       BaseStyle->{"InlineFormula"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "aa2ab7d8-182d-4e60-93b2-28d0f26cc1c2"],
     "."
    }],ExpressionUUID->"582ad9ae-fa68-4a2f-938b-3a7099463d48"]}
  }]], "Usage",
 CellID->1033173795,ExpressionUUID->"05fc95fd-8da0-4f73-b6bf-0bdecfbd576b"]
}, Open  ]],

