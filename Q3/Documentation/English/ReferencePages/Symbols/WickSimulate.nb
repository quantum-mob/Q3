Cell[TextData[{
 "Construct approximate density matrices, and calculate the ",
 ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity"],
 " (LN) between the subsystem and the rest."
}], "ExampleText",
 CellID->1198129299,ExpressionUUID->"996fcc9e-121d-4bff-9418-d2ffe270e9fb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"grn", "=", 
    RowBox[{"Mean", "@", 
     RowBox[{"WickGreen", "[", "data", "]"}]}]}], ";", "\[IndentingNewLine]", 
   
   RowBox[{"negRho", "=", 
    RowBox[{"WickLogarithmicNegativity", "[", 
     RowBox[{"grn", ",", "sub"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[12]:=",
 CellID->2147101928,ExpressionUUID->"bb200c66-7d2a-4184-90ab-ffb11c7629ec"],

