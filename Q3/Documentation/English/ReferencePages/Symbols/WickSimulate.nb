Cell[TextData[{
 "Construct approximate density matrices, and calculate the ",
 ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity"],
 " (LN) between the subsystem and the rest."
}], "ExampleText",
 CellID->317670364,ExpressionUUID->"81d29de3-a4ef-4e66-8649-83b7b478517f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"grn", "=", 
    RowBox[{"Mean", "@", 
     RowBox[{"WickGreen", "[", "data", "]"}]}]}], ";", "\[IndentingNewLine]", 
   
   RowBox[{"negRho", "=", 
    RowBox[{"WickLogarithmicNegativity", "[", 
     RowBox[{"grn", ",", "sub"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[12]:=",
 CellID->441461306,ExpressionUUID->"a56f066a-344b-43e7-a607-908672baedb1"],

Cell[BoxData["0.75909`"], "EchoTiming",
 CellID->1742560700,ExpressionUUID->"9cbde5e4-f4f4-4647-8fb6-5323eb0203ac"]
}, Open  ]],

