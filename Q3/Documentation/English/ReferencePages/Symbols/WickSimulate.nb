Cell["\<\
Note that the quantum jump operators are now projectors. Nevertheless, check \
that the model indeed gives the non-Hermitian Hatano-Nelson Hamiltonian:\
\>", "ExampleText",
 CellID->1104551032,ExpressionUUID->"4b958e2a-0e88-44e6-8299-5fd982efc914"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"dmp", ",", "gmm"}], "}"}], "=", 
   RowBox[{"WickDampingOperator", "[", "jmp", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eff", "=", 
   RowBox[{"ham", "-", 
    RowBox[{"I", "*", "dmp"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eff", "//", "Chop"}], "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1340550156,ExpressionUUID->"9059e9e5-2e23-4beb-9a75-84c28d79be79"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", 
      RowBox[{"-", "1.5`"}], "0", "0", "0", "0"},
     {
      RowBox[{"-", "2.5`"}], "0", 
      RowBox[{"-", "1.5`"}], "0", "0", "0"},
     {"0", 
      RowBox[{"-", "2.5`"}], "0", 
      RowBox[{"-", "1.5`"}], "0", "0"},
     {"0", "0", 
      RowBox[{"-", "2.5`"}], "0", 
      RowBox[{"-", "1.5`"}], "0"},
     {"0", "0", "0", 
      RowBox[{"-", "2.5`"}], "0", 
      RowBox[{"-", "1.5`"}]},
     {"0", "0", "0", "0", 
      RowBox[{"-", "2.5`"}], "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {6, 6}, 0, {
     1, {{0, 1, 3, 5, 7, 9, 10}, {{2}, {1}, {3}, {2}, {4}, {3}, {5}, {4}, {
       6}, {5}}}, {-1.5, -2.5, -1.5, -2.5, -1.5, -2.5, -1.5, -2.5, -1.5, \
-2.5}}]]]]], "Output",
 CellLabel->"Out[4]//MatrixForm=",
 CellID->1433868584,ExpressionUUID->"ec0aa9af-c95e-40fe-bac0-343544a622e3"]
}, Open  ]],

Cell["Pick an initial state with half-filling:", "ExampleText",
