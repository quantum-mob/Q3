Cell["Set the simulation parameters:", "ExampleText",
 CellID->45438647,ExpressionUUID->"2c626f92-636c-4ac8-a764-32c312826805"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$T", "=", "4"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"final", " ", "time"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$dt", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$N", "=", "100"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"sample", " ", "size"}], "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1152631756,ExpressionUUID->"4c31fafa-d770-40b4-a80f-892e87464350"],

Cell["Do the Monte Carlo simulation:", "ExampleText",
 CellID->1692815605,ExpressionUUID->"c800138a-cf14-41c6-a03a-e305a191ae8a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "452", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->1288517779,ExpressionUUID->"389a067d-2a43-40ae-93e8-b292ec7a346c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"WickSimulate", "[", 
     RowBox[{"in", ",", "ham", ",", "jmp", ",", 
      RowBox[{"{", 
       RowBox[{"$T", ",", "$dt"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<Samples\>\"", "->", "$N"}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "data", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->387314370,ExpressionUUID->"195ba6ba-11a4-4955-8c64-bbbb55435f3a"],

