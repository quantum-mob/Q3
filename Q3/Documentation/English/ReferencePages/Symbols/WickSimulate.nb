Cell["\<\
Now, we consider a projective model for the Hatano-Nelson Hamiltonian.\
\>", "ExampleText",
 CellID->1226856810,ExpressionUUID->"4a0c308b-a4ee-490d-9ad0-fe2801d7c794"],

Cell[TextData[{
 "Construct the dissipative model for the Hatano-Nelson model. Here, ",
 StyleBox["L",
  FontSlant->"Italic"],
 " is the number of fermion modes (lattice sites), \[Gamma] is the damping \
constant and ",
 StyleBox["J",
  FontSlant->"Italic"],
 " is the hopping amplitude:"
}], "ExampleText",
 CellID->1981503329,ExpressionUUID->"145f5ec6-15c7-46b6-b902-fbba695db92b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$L", "=", "6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$\[Gamma]", "=", "0.5"}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$J", "=", 
    RowBox[{"1", "/", "$\[Gamma]"}]}], ";"}], " "}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->2097536474,ExpressionUUID->"37d128b6-dea9-4c7f-82e0-a6fe7c64604b"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "HatanoNelsonModel", "]"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{
   RowBox[{"HatanoNelsonModel", "[", 
    RowBox[{"L_", ",", "J_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ham", ",", "cff", ",", "jmp"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ham", "=", 
       RowBox[{"PlusTopple", "[", 
        RowBox[{
         RowBox[{"-", "J"}], "*", 
         RowBox[{"One", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"L", ",", "L"}], "}"}], ",", "1"}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"ham", "=", 
       RowBox[{"WickHermitian", "[", "ham", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cff", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"One", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], "]"}], "+", 
          RowBox[{"I", "*", 
           RowBox[{"One", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], ",", "1"}], 
            "]"}]}]}], ")"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"jmp", "=", 
       RowBox[{"WickJump", "@", 
        RowBox[{"Join", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Thread", "[", 
           RowBox[{"cff", "->", "2"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Conjugate", "[", "cff", "]"}], "->", "3"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"ham", ",", "jmp"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->203969366,ExpressionUUID->"8a7f3889-9abd-4a7e-a59b-b033352f3268"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{"ham", ",", "jmp"}], "}"}], "=", 
  RowBox[{"HatanoNelsonModel", "[", 
   RowBox[{"$L", ",", "$J"}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->729233750,ExpressionUUID->"bffabac2-987c-4256-843e-b88957cc79c5"],

