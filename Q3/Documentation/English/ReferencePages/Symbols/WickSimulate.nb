Cell[TextData[{
 "Solve the quantum master equation. Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WickLindbladSolve"]], 
    "paclet:QuantumMob/Q3/ref/WickLindbladSolve", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d233e82d-cc24-4d4c-b361-4419df9b5232"],
 " returns a list of single-particle Green's function matrices describing the \
mixed state:"
}], "ExampleText",
 CellID->416938607,ExpressionUUID->"35cda25b-d7ba-4816-b19e-fc9793a8ce8a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"WickLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "$T", ",", 
       RowBox[{"2", "*", "$dt"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->18391959,ExpressionUUID->"2f8b0256-6cff-4ae6-a989-f7588b531942"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"201", ",", "6", ",", "6"}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->979285891,ExpressionUUID->"d184e57c-41b2-4b43-a1b6-fa41fdbc219b"]
}, Open  ]],

Cell["Calculate the logarithmic negativity:", "ExampleText",
 CellID->614337906,ExpressionUUID->"64686392-c8cb-4e18-aaf8-cc5f1c394722"],

Cell[BoxData[
 RowBox[{
  RowBox[{"negSol", "=", 
   RowBox[{"WickLogarithmicNegativity", "[", 
    RowBox[{"sol", ",", "sub"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->349499065,ExpressionUUID->"15d2c965-aff2-4079-8b9e-9adf1ef892fe"],

Cell["Compare the two results:", "ExampleText",
 CellID->271527599,ExpressionUUID->"baf5bec2-1d35-4780-905a-254c336c4cff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", 
    RowBox[{"{", 
     RowBox[{"negSol", ",", "negRho"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", "Automatic"}], "}"}]}], ",", "\[IndentingNewLine]", 
   
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma] t\>\"", ",", "\"\<LN(L, L/2)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
