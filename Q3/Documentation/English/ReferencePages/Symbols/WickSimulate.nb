Cell[TextData[{
 "Solve the quantum master equation. Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WickLindbladSolve"]], 
    "paclet:QuantumMob/Q3/ref/WickLindbladSolve", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a230aec3-99e3-41be-8221-e99df5145ba6"],
 " returns a list of single-particle Green's function matrices describing the \
mixed state:"
}], "ExampleText",
 CellID->906212940,ExpressionUUID->"b09522e1-4aea-40e4-8bf6-a950f4b2e3c9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"WickLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "$T", ",", 
       RowBox[{"2", "*", "$dt"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->766858056,ExpressionUUID->"f2ff5258-2836-4bac-a078-993f1e079435"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"201", ",", "6", ",", "6"}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->393435040,ExpressionUUID->"cc3f25b5-3742-49e7-9782-11d69c5945ce"]
}, Open  ]],

Cell["Calculate the logarithmic negativity:", "ExampleText",
 CellID->1086644580,ExpressionUUID->"07f4268c-42ae-4d37-a55f-c18ad52fa783"],

Cell[BoxData[
 RowBox[{
  RowBox[{"negSol", "=", 
   RowBox[{"WickLogarithmicNegativity", "[", 
    RowBox[{"sol", ",", "sub"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1034521972,ExpressionUUID->"0ba1b6b3-8ccb-44a8-bc54-90c8acf12c01"],

Cell["Compare the two results:", "ExampleText",
 CellID->1183177292,ExpressionUUID->"40fc7b90-9ce3-46eb-bc65-9b1ad920e950"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", 
    RowBox[{"{", 
     RowBox[{"negSol", ",", "negRho"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", "Automatic"}], "}"}]}], ",", "\[IndentingNewLine]", 
   
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma] t\>\"", ",", "\"\<LN(L, L/2)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
