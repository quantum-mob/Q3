Cell[TextData[{
 "Construct approximate density matrices, and calculate the ",
 ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity"],
 " (LN) between the subsystem and the rest."
}], "ExampleText",
 CellID->317670364,ExpressionUUID->"cb2d959e-8c2d-4e34-b267-3290d57fe7ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"grn", "=", 
    RowBox[{"Mean", "@", 
     RowBox[{"WickGreen", "[", "data", "]"}]}]}], ";", "\[IndentingNewLine]", 
   
   RowBox[{"negRho", "=", 
    RowBox[{"WickLogarithmicNegativity", "[", 
     RowBox[{"grn", ",", "sub"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[12]:=",
 CellID->441461306,ExpressionUUID->"635a69aa-3745-42dd-abd1-825c394aef2e"],

Cell[BoxData["0.75909`"], "EchoTiming",
 CellID->1742560700,ExpressionUUID->"4962381a-f0e1-4ab9-8fad-284f41732cef"]
}, Open  ]],

