Cell["\<\
Calculate the average entanglement entropy between the subsystem and the rest:\
\>", "ExampleText",
 CellID->740050627,ExpressionUUID->"4ec3e2bc-b3b5-4ad9-9308-57b59fdead93"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ent", "=", 
   RowBox[{"Mean", "@", 
    RowBox[{"WickEntanglementEntropy", "[", 
     RowBox[{"data", ",", "sub"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ent", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
 CellID->1763639067,ExpressionUUID->"ac74564c-12e5-48d4-ad33-a61a0482d3f3"],

Cell[BoxData[
 RowBox[{"{", "401", "}"}]], "Output",
 CellLabel->"Out[10]=",
