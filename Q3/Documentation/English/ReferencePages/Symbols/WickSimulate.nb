Cell[TextData[{
 "Solve the quantum master equation. Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WickLindbladSolve"]], 
    "paclet:QuantumMob/Q3/ref/WickLindbladSolve", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f5bc5b08-79eb-42d5-9f61-08eedc21a229"],
 " returns a list of single-particle Green's function matrices describing the \
mixed state:"
}], "ExampleText",
 CellID->906212940,ExpressionUUID->"8854e378-7e2d-45e4-adc9-5dc66f349808"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"WickLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "$T", ",", 
       RowBox[{"2", "*", "$dt"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->766858056,ExpressionUUID->"32a2174d-f745-4b2f-a91e-fc6d7d1694d2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"201", ",", "6", ",", "6"}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->393435040,ExpressionUUID->"73442d76-b8e8-49d6-92a5-da70e81050a4"]
}, Open  ]],

Cell["Calculate the logarithmic negativity:", "ExampleText",
 CellID->1086644580,ExpressionUUID->"ca389d56-e4e5-4491-8fdb-dc5687eb0feb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"negSol", "=", 
   RowBox[{"WickLogarithmicNegativity", "[", 
    RowBox[{"sol", ",", "sub"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1034521972,ExpressionUUID->"39a6b24b-2f05-4068-84fd-eb8c431fcce5"],

Cell["Compare the two results:", "ExampleText",
 CellID->1183177292,ExpressionUUID->"427b97cc-33f8-4c7b-be09-8d5151fc942d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", 
    RowBox[{"{", 
     RowBox[{"negSol", ",", "negRho"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", "Automatic"}], "}"}]}], ",", "\[IndentingNewLine]", 
   
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma] t\>\"", ",", "\"\<LN(L, L/2)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
