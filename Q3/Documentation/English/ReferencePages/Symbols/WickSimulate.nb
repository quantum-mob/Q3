Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickSimulate"]], "paclet:QuantumMobQ3/ref/WickSimulate", 
         "QuantumMobQ3 Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["jmp", "TI"], ",", 
        StyleBox["in", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "047c6314-24ce-45bf-a42c-3c54568c6c1e"],
     "\[LineSeparator]solves the quantum master equation for a \
non-interacting dissipative fermionic many-body system by using the Monte \
Carlo simulation method (also known as the quantum jump approach or quantum \
trajectory method). The model is specified by the single-particle Hamiltonian \
",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4cc5c3b2-ee8b-4c63-8858-48de847e7d0f"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickHermitian"]], "paclet:QuantumMob/Q3/ref/WickHermitian",
         "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "80c51fe1-dd07-4048-bc92-892588b5ba1d"],
     " form and the quantum jump operators are specified by ",
     Cell[BoxData[
      StyleBox["jmp", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3fd82edc-7b29-44f9-883f-ac9f3c0edbfc"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickJump"]], "paclet:QuantumMob/Q3/ref/WickJump", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "53fc1034-e36d-454d-bd8c-dffc7fb016db"],
     " form. The simulation starts from the initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e09ea3e9-6825-4ece-ab3d-01661abda2de"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickState"]], "paclet:QuantumMob/Q3/ref/WickState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "075b64a1-a19b-4e78-a7fe-501b1fbf9a68"],
     "  form at time 0 and runs to time \[Tau] in steps of size ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8e35945e-c673-4dfe-a373-4d94cca1dcbc"],
     "."
    }],ExpressionUUID->"f52c7aee-0999-4dd9-a4f7-f7ff56330f37"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickSimulate"]], "paclet:QuantumMob/Q3/ref/WickSimulate", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["spec", "TI"], ",", 
        StyleBox["\[Ellipsis]", "TR"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "fa206e84-bba4-4241-81c2-32a5ebb35be2"],
     "\[LineSeparator]collects states in steps of ",
     Cell[BoxData[
      RowBox[{
       StyleBox["k", "TI"], "\[Times]", 
       StyleBox["dt", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "97b7ef38-85d3-486c-bb30-724db5d29fa4"],
     " (rather than ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8b48f416-9b78-41e4-8c44-f9b8e0cb34ce"],
     "), where ",
     Cell[BoxData[
      StyleBox["k", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4d598604-e2c3-405f-88f0-70d488f72021"],
     " must be an integer or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["All"]], "paclet:ref/All"},
       "RefLink",
       BaseStyle->{"InlineFormula"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e1dbea23-4f61-4698-bccd-e17678cef737"],
     "."
    }],ExpressionUUID->"651e4b8a-e663-4b95-af3f-7dc67a88fb63"]}
  }]], "Usage",
 CellID->1033173795,ExpressionUUID->"ef896ef4-6451-4e95-9afb-f06186fd9999"]
}, Open  ]],

