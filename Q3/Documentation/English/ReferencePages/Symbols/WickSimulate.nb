Cell["\<\
Note that the quantum jump operators are now projectors. Nevertheless, check \
that the model indeed gives the non-Hermitian Hatano-Nelson Hamiltonian:\
\>", "ExampleText",
 CellID->1104551032,ExpressionUUID->"4635c0a1-ce24-4733-a0f2-23dee22fe421"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"dmp", ",", "gmm"}], "}"}], "=", 
   RowBox[{"WickDampingOperator", "[", "jmp", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eff", "=", 
   RowBox[{"ham", "-", 
    RowBox[{"I", "*", "dmp"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eff", "//", "Chop"}], "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1340550156,ExpressionUUID->"f46d5e39-39c3-4f66-9a40-23638d0d2c8d"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", 
      RowBox[{"-", "1.5`"}], "0", "0", "0", "0"},
     {
      RowBox[{"-", "2.5`"}], "0", 
      RowBox[{"-", "1.5`"}], "0", "0", "0"},
     {"0", 
      RowBox[{"-", "2.5`"}], "0", 
      RowBox[{"-", "1.5`"}], "0", "0"},
     {"0", "0", 
      RowBox[{"-", "2.5`"}], "0", 
      RowBox[{"-", "1.5`"}], "0"},
     {"0", "0", "0", 
      RowBox[{"-", "2.5`"}], "0", 
      RowBox[{"-", "1.5`"}]},
     {"0", "0", "0", "0", 
      RowBox[{"-", "2.5`"}], "0"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
