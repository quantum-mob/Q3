        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {6, 6}, 0, {
     1, {{0, 1, 3, 5, 7, 9, 10}, {{2}, {1}, {3}, {2}, {4}, {3}, {5}, {4}, {
       6}, {5}}}, {-1.5, -2.5, -1.5, -2.5, -1.5, -2.5, -1.5, -2.5, -1.5, \
-2.5}}]]]]], "Output",
