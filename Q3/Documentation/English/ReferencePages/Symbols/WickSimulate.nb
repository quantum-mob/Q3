Cell["\<\
Calculate the average entanglement entropy between the subsystem and the rest:\
\>", "ExampleText",
 CellID->740050627,ExpressionUUID->"83558ac0-e948-4ebf-a121-21b1893a4620"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ent", "=", 
   RowBox[{"Mean", "@", 
    RowBox[{"WickEntanglementEntropy", "[", 
     RowBox[{"data", ",", "sub"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ent", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
 CellID->1763639067,ExpressionUUID->"a6e6e206-810c-4f06-b1ac-86459090697c"],

Cell[BoxData[
 RowBox[{"{", "401", "}"}]], "Output",
 CellLabel->"Out[10]=",
