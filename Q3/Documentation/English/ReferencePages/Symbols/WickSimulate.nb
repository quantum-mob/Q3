Cell["Set the simulation parameters:", "ExampleText",
 CellID->45438647,ExpressionUUID->"9ebbdf62-2485-440e-8243-c7c4e177af56"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$T", "=", "4"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"final", " ", "time"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$dt", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$N", "=", "100"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"sample", " ", "size"}], "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1152631756,ExpressionUUID->"ceab20e3-fd61-4e16-8c3b-f234e0d769ad"],

Cell["Do the Monte Carlo simulation:", "ExampleText",
 CellID->1692815605,ExpressionUUID->"6bbd337c-afb8-4b19-a61b-9a31dca47103"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "452", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->1288517779,ExpressionUUID->"bd93cafe-73dd-4f75-9b09-1537a4726ee7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"WickSimulate", "[", 
     RowBox[{"in", ",", "ham", ",", "jmp", ",", 
      RowBox[{"{", 
       RowBox[{"$T", ",", "$dt"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<Samples\>\"", "->", "$N"}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "data", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->387314370,ExpressionUUID->"aa0a6b07-5b95-4701-a499-1189c562675c"],

