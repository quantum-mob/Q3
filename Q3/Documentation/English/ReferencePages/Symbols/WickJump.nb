Cell[TextData[{
 "Convert the measurement to the quantum jump operators describing the \
nonselective measurement process ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "i"], 
      SubscriptBox["p", "i"], "\[Rho]", " ", 
      SubscriptBox["p", "i"]}], "+", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "i"], "(", 
       RowBox[{"1", "-", 
        SubscriptBox["p", "i"]}], ")"}], 
      RowBox[{"\[Rho]", "(", 
       RowBox[{"1", "-", 
        SubscriptBox["p", "i"]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"0f24a40c-1b5e-4dde-8f2d-7fec00e95e04"],
 " , where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["d", "i", "\[Dagger]"], 
     SubscriptBox["d", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "b0ee2acc-e01c-4544-b0dc-e203ff707a68"],
 " are the projection operators and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "i"], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "j"], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "9361c500-c127-42b6-8729-a17ba4468d5f"],
 " are the dressed modes:"
}], "ExampleText",
 CellID->1269542183,ExpressionUUID->"06b63573-a225-426d-80be-ab0fd245d7fb"],

