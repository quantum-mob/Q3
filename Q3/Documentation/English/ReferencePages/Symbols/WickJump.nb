Cell[TextData[{
 "Convert the measurement to the quantum jump operators describing the \
nonselective measurement process ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "i"], 
      SubscriptBox["p", "i"], "\[Rho]", " ", 
      SubscriptBox["p", "i"]}], "+", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "i"], "(", 
       RowBox[{"1", "-", 
        SubscriptBox["p", "i"]}], ")"}], 
      RowBox[{"\[Rho]", "(", 
       RowBox[{"1", "-", 
        SubscriptBox["p", "i"]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"62ee6b22-8dc7-4846-a907-ed855ba23bf7"],
 " , where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["d", "i", "\[Dagger]"], 
     SubscriptBox["d", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "a584e7fa-2186-432f-a897-2d7d2f74f015"],
 " are the projection operators and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "i"], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "j"], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "7adfad56-58e7-4702-a8ad-5e72840008c8"],
 " are the dressed modes:"
}], "ExampleText",
 CellID->1269542183,ExpressionUUID->"7d0b936b-d426-4f2e-ab90-66689b4f9798"],

