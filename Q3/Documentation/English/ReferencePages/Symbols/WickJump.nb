    SubsuperscriptBox["d", "2", "\[Dagger]"]}], TraditionalForm]],
  ExpressionUUID->"b65bf226-1580-4bc2-9744-0aede1f62fa5"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "3"], ":=", 
    RowBox[{
     SubscriptBox["d", "1"], 
     SubsuperscriptBox["d", "1", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"27273bb2-7b7b-448f-8cc4-33779412817d"],
 " , where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "1"], ":=", 
    RowBox[{
     SubscriptBox["c", "1"], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      SubscriptBox["c", "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "45736450-cfd7-425b-b54a-6c4453e4a2b8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "2"], ":=", 
    RowBox[{
     SubscriptBox["c", "2"], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      SubscriptBox["c", "3"]}]}]}], TraditionalForm]],ExpressionUUID->
  "ee88a670-326b-4526-a53c-2f185f2da9d4"],
 ":"
}], "ExampleText",
 CellID->932077114,ExpressionUUID->"a71cf876-0945-4528-87f9-4ec8ca0a9847"],

