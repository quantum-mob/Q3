    SubsuperscriptBox["d", "2", "\[Dagger]"]}], TraditionalForm]],
  ExpressionUUID->"3f54c406-575e-4d47-84fa-70a028264fb4"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "3"], ":=", 
    RowBox[{
     SubscriptBox["d", "1"], 
     SubsuperscriptBox["d", "1", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"0f4ef9cc-d87e-4ced-a571-724af276c99a"],
 " , where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "1"], ":=", 
    RowBox[{
     SubscriptBox["c", "1"], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      SubscriptBox["c", "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "eb2fc1cd-b2e8-4e97-b6b4-934d4d2d8ee7"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "2"], ":=", 
    RowBox[{
     SubscriptBox["c", "2"], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      SubscriptBox["c", "3"]}]}]}], TraditionalForm]],ExpressionUUID->
  "643d9547-faee-4473-b4af-9c688e2490ad"],
 ":"
}], "ExampleText",
 CellID->932077114,ExpressionUUID->"6eae8d6d-900d-456f-88cb-646a8e30d4cb"],

