    "AllOptsTable" -> Closed, "NotesSection" -> Closed, 
    "ExampleSubsection" -> {"0" -> Closed, "1" -> Closed, "2" -> Closed}}, 
  "NewStyles" -> True, "CitationPopupData" -> $Failed, "ShowCitation" -> 
  False, "HasOptions" -> True, "RootCaptions" -> "", 
  "HeaderCoreAreaLink" -> {}, 
  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 58, 51.296346}", 
    "history" -> {"14.3", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {
     "fermionic quantum computation", "fermionic Gaussian state"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "WickJump[v -> 0] represents the fermionic Gaussian supermap \\[Rho] \
\\[RightTeeArrow] d \\[Rho] d^\\[Dagger] with rate \
\\[LeftDoubleBracketingBar]v\\[RightDoubleBracketingBar] 2, where d := \
\\[CapitalSigma]i vi ai is a (unnormalized) dressed mode and ai are bare \
fermion modes. WickJump[v -> 1] represents the fermionic Gaussian supermap \
\\[Rho] \\[RightTeeArrow] d^\\[Dagger] \\[Rho] d. WickJump[v -> 2] represents \
the fermionic Gaussian supermap \\[Rho] \\[RightTeeArrow] (d^\\[Dagger] d) \
\\[Rho] (d^\\[Dagger] d) with rate \
\\[LeftDoubleBracketingBar]v\\[RightDoubleBracketingBar] 4. WickJump[v -> 3] \
represents the fermionic Gaussian supermap \\[Rho] \\[RightTeeArrow] (d \
d^\\[Dagger]) \\[Rho] (d d^\\[Dagger]). WickJump[{..., vi -> si, ...}] \
represents the fermionic Gaussian supermap \\[Rho] \\[RightTeeArrow] \
\\[CapitalSigma]i Fi \\[Rho] F_i^\\[Dagger], where the Kraus operator Fi is \
specified by vi -> si. WickJump[msr] converts WickMeasurement object msr to \
WickJump object. With the option Completion -> True, each row v in msr are \
converted to {v -> 2, v -> 3} (corresponding to the nonselective \
measurement); or v -> 2 otherwise.", "synonyms" -> {}, "tabletags" -> {}, 
    "title" -> "WickJump", "titlemodifier" -> "", "metadescription" -> "", 
    "windowtitle" -> "WickJump", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/WickJump"}},
