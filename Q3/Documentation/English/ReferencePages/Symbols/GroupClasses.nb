Cell[TextData[{
 "For the symmetric group, an association is returned. Conjugacy classes in \
the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "2c2f5f0d-a2ae-4e45-ad05-9ca29756f081"],
 " are uniquely determined by ",
 ButtonBox["cycle decomposition type",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CycleDecompositionType"],
 " of permutations, i.e. by the lengths of the disjoint cycles composing \
them, thus by a list of integers adding up to ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e52f3e59-eae7-4747-99c8-53983c6d8b0d"],
 ". Such a list of integers, conventionally listed in decreasing order, is \
called a partition of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "8dcb2090-deda-42c7-9a29-940c0682a88d"],
 ". Hence, conjugacy classes of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "d6f90e58-6c87-4bb4-8bc9-9379c60fa6a4"],
 " are in one to one correspondence to the partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "22cd7a2a-cb54-4f66-8409-12ee6c1bcb31"],
 "."
}], "ExampleText",
 CellID->1468925870,ExpressionUUID->"a8741a75-23b8-47a7-9dea-d633c7cd280f"],

Cell["Convert the indexes to the group elements:", "ExampleText",
 CellID->646792383,ExpressionUUID->"01bd1e9b-8e8e-4e44-a8ec-399155d55d72"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"elm", "=", 
   RowBox[{"GroupElements", "[", "grp", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"alt", "=", 
   RowBox[{"cls", "/.", 
    RowBox[{"Thread", "[", 
     RowBox[{
      RowBox[{"Range", "[", 
       RowBox[{"GroupOrder", "@", "grp"}], "]"}], "->", "elm"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"alt", "//", "PermutationForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->843282497,ExpressionUUID->"7163fb45-cd96-4edd-9e7e-6ffb3eae8df1"],

