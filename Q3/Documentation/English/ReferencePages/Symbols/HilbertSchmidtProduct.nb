Cell[TextData[{
 "For matrices ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "36e6f76d-4bf5-41b3-be59-d6c3732907de"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "e1229419-d257-4554-8c4b-c7d58d0ae924"],
 ", it is equivalent to the ",
 ButtonBox["Frobenius inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FrobeniusProduct"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"A", ",", "B"}], "\[RightAngleBracket]"}], "HS"], ":=", 
    RowBox[{"Tr", "[", 
     RowBox[{
      SuperscriptBox["A", "\[Dagger]"], "B"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"b1767cd4-01f2-4699-8066-647efbfdd783"],
 " ."
}], "Notes",
