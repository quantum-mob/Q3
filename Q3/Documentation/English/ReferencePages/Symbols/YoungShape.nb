Cell[TextData[{
 "A ",
 StyleBox["composition",
  FontSlant->"Italic"],
 " of integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e5669024-57ec-4927-9af9-711b3d72ef70"],
 " is an ordered sequence of nonnegative integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Tau]", "1"], ",", 
      SubscriptBox["\[Tau]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Tau]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"12686a8f-9400-44a6-96e5-80bc0b5e3319"],
 "\[LineSeparator]such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Tau]", "1"], "+", 
     SubscriptBox["\[Tau]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Tau]", "d"]}], ":=", "n"}], TraditionalForm]],
  ExpressionUUID->"aded9894-87b2-4be7-98b8-65c301f86060"],
 ".\[LineSeparator]The integers ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "k"], TraditionalForm]],ExpressionUUID->
  "61953806-1801-430a-8ebe-9ad80209c70f"],
 " are called the ",
 StyleBox["parts",
  FontSlant->"Italic"],
 " of the composition."
}], "Notes",
 CellID->1280405461,ExpressionUUID->"98a7ac5e-2804-40ad-bcfe-ae1fa15c2bce"],

Cell[TextData[{
 "A ",
 StyleBox["partition",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f15d59ed-afe3-4071-90b5-cb58e10bf6c5"],
 " is a ",
 StyleBox["weakly decreasing",
  FontSlant->"Italic"],
 " sequence of nonnegative integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"9d6881a8-6f66-42ce-8afe-b66ad081ef08"],
 "\[LineSeparator]such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"08111766-82a5-4eff-bcbf-b41dbb99d7ab"],
 ". A partition is a composition, but a composition is not necessarily a \
partition."
}], "Notes",
 CellID->1209047982,ExpressionUUID->"52775988-d8e8-4e04-a87b-968100598fb3"],

