Cell[TextData[{
 "For a system of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "8b854470-f67b-4953-b043-ea712215b5d6"],
 " qubits, the Dicke state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["D", 
      RowBox[{"n", ",", "k"}]]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f82fcef3-b22f-41df-983c-8ce70950a619"],
 " with ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "e35764d9-d19e-4d38-81e6-e06919634255"],
 " excitations is a symmetric state\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["D", 
       RowBox[{"n", ",", "k"}]]},
     "Ket"], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "\[Pi]"], "\[Pi]", 
     TemplateBox[{
       OverscriptBox[
        OverscriptBox[
         RowBox[{
          "0", "\[VeryThinSpace]", "0", "\[VeryThinSpace]\[VeryThinSpace]", 
           "\[Ellipsis]", "\[VeryThinSpace]\[VeryThinSpace]", "0", 
           " \[VeryThinSpace]", 
           UnderscriptBox[
            UnderscriptBox[
             
             RowBox[{"1", "\[VeryThinSpace]", "\[Ellipsis]", 
               "\[VeryThinSpace]", "1"}], "\[UnderBrace]"], "k"], 
           "\[VeryThinSpace]"}], "\[OverBrace]"], "n"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "0f7c4c8e-dd85-4da2-b79c-d82f333a4949"],
 ",\[LineSeparator]where the summation is over all permutations."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"90397575-83bf-4915-8450-0921195755af"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

