Cell[TextData[{
 "The basis is symplectic with respect to the Gottesman inner product (see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanDot"]], "paclet:QuantumMob/Q3/ref/GottesmanDot", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cb63a8d0-d37a-4b17-bb4c-6f8fbaef3ffa"],
 ")."
}], "Notes",
 CellID->611882111,ExpressionUUID->"d86d6410-e9df-4e36-9e21-f7fdf53563d6"],

Cell[TextData[{
 "A basis is said to be symplectic with respect to an inner product \
\[LeftAngleBracket]\[CenterDot],\[CenterDot]\[RightAngleBracket] when it \
satisfies that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["i", "TI"]], ",", 
     SubscriptBox[
      StyleBox["w", "TI"], 
      StyleBox["j", "TI"]]}], "\[RightAngleBracket]"}], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TR"], 
    StyleBox["ij", "TI"]]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "57206fb2-02d2-405b-9f08-d1d61a6ad0ed"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["i", "TI"]], ",", 
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["j", "TI"]]}], "\[RightAngleBracket]"}], "=", 
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox[
       StyleBox["w", "TI"], 
       StyleBox["i", "TI"]], ",", 
      SubscriptBox[
       StyleBox["w", "TI"], 
       StyleBox["j", "TI"]]}], "\[RightAngleBracket]"}], "=", "0"}]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "429deb13-c54e-478d-9372-d4731c92d824"],
 "."
}], "Notes",
 CellID->1441802225,ExpressionUUID->"94ed6c0c-a907-4488-8586-f313b8698588"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

