Cell[TextData[{
 "The ",
 StyleBox["binary representation",
  FontSlant->"Italic"],
 " of a partition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "m"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"1eef265c-7405-4bc3-816e-558db759f379"],
 " is given by the binary sequence\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox[
     UnderscriptBox[
      RowBox[{"1", "\[VeryThinSpace]", "1", "\[Ellipsis]1"}], 
      "\[UnderBrace]"], 
     SubscriptBox["\[Lambda]", "m"]], "0", " ", 
    UnderscriptBox[
     UnderscriptBox[
      RowBox[{"1", "\[VeryThinSpace]", "1", "\[Ellipsis]1"}], 
      "\[UnderBrace]"], 
     RowBox[{
      SubscriptBox["\[Lambda]", 
       RowBox[{"m", "-", "1"}]], "-", 
      SubscriptBox["\[Lambda]", "m"]}]], "  ", "0", 
    UnderscriptBox[
     UnderscriptBox[
      RowBox[{"1", "\[VeryThinSpace]", "1", "\[Ellipsis]1"}], 
      "\[UnderBrace]"], 
     RowBox[{
      SubscriptBox["\[Lambda]", 
       RowBox[{"m", "-", "2"}]], "-", 
      SubscriptBox["\[Lambda]", 
       RowBox[{"m", "-", "1"}]]}]], " ", "0", "\[VeryThinSpace]", "1", "\[VeryThinSpace]",
     "1", "\[Ellipsis]1", " ", "0", " ", 
    UnderscriptBox[
     UnderscriptBox[
      RowBox[{"1", "\[VeryThinSpace]", "1", "\[Ellipsis]1"}], 
      "\[UnderBrace]"], 
     RowBox[{
      SubscriptBox["\[Lambda]", "2"], "-", 
      SubscriptBox["\[Lambda]", "1"]}]], " ", "0"}], TraditionalForm]],
  ExpressionUUID->"9b1d19ed-7d61-45a0-877a-10ac2d33d364"],
 " .\[LineSeparator]Graphically, the binary representation is a walk along \
the borderline of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "cabe2605-d424-4b18-99b2-79e36472b3fb"],
 ", coming from the south on the vertical line, going along the border and \
leaving on the horizontal line eastwards, recording each vertical step by a 0 \
and each horizontal step by a 1."
}], "Notes",
 CellID->1827576936,ExpressionUUID->"6ca6b7f1-1c87-492d-9a32-905d46bccaee"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

