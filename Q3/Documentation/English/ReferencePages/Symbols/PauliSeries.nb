Cell[TextData[{
 "The set of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", "n"], "\[CircleTimes]", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "21c5dcea-9f1d-49be-acb8-e9fc9e04586c"],
 " complex matrices may be regarded as a vector space, and the set of Pauli \
strings of length ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "105a4514-2ca1-4c50-91ef-a38c20ba9119"],
 " is an orthogonal basis of it. That is, any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", "n"], "\[CircleTimes]", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "2de74474-1491-43df-bfdf-2b82962c66f0"],
 " complex matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "691e4e97-69fc-4dcf-8736-0497b395dec0"],
 " may be expanded in the tensor products of Pauli matrices ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "2df9515f-cd2e-4c73-9a74-0b47c921ecbb"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["\[Mu]", "1"], "=", "0"}], "3"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["\[Mu]", "2"], "=", "0"}], "3"], "\[Ellipsis]", 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["\[Mu]", "n"], "=", "0"}], "3"], 
     SubscriptBox["c", 
      RowBox[{
       SubscriptBox["\[Mu]", "1"], 
       SubscriptBox["\[Mu]", "2"], 
       SubscriptBox["\[Ellipsis]\[Mu]", "n"]}]], 
     RowBox[{
      SubscriptBox["P", 
       SubscriptBox["\[Mu]", "1"]], "\[CircleTimes]", 
      SubscriptBox["P", 
       SubscriptBox["\[Mu]", "2"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
      SubscriptBox["P", 
       SubscriptBox["\[Mu]", "n"]]}]}]}], TraditionalForm]],ExpressionUUID->
  "055ee988-86e2-4424-9887-3e0da346e9cf"],
 " ,\[LineSeparator]where the complex coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     SubscriptBox["\[Mu]", "1"], 
     SubscriptBox["\[Mu]", "2"], 
     SubscriptBox["\[Ellipsis]\[Mu]", "n"]}]], TraditionalForm]],
  ExpressionUUID->"3b315530-c0aa-4310-b07e-42ba817f9254"],
 " may be determined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], 
      SubscriptBox["\[Mu]", "2"], 
      SubscriptBox["\[Ellipsis]\[Mu]", "n"]}]], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", "n"]], 
     RowBox[{"Tr", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["P", 
          SubscriptBox["\[Mu]", "1"]], "\[CircleTimes]", 
         SubscriptBox["P", 
          SubscriptBox["\[Mu]", "2"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
         SubscriptBox["P", 
          SubscriptBox["\[Mu]", "n"]]}], ")"}], "M"}], "]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"1bea7ba9-0380-4573-a313-dec25c830243"],
 " ."
}], "Notes",
 CellID->770489137,ExpressionUUID->"4e479265-01a8-42e8-8444-4eeec7386936"],

Cell[TextData[{
 "It is an inverse of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PauliCoefficients"]], 
    "paclet:QuantumMob/Q3/ref/PauliCoefficients", "QuantumMob Package Symbol"},
   "PackageLink",
