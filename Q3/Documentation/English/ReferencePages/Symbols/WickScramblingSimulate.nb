Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "otoc", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$k", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"otoc", "[", "$k", "]"}], "=", 
    RowBox[{"WickScramblingSimulate", "[", 
     RowBox[{"in", ",", "$k", ",", " ", 
      RowBox[{"{", 
       RowBox[{"non", ",", "0"}], "}"}], ",", "$T", ",", 
      RowBox[{"\"\<Samples\>\"", "->", "1"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"otoc", "[", "$k", "]"}], "//", "Dimensions"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$k", "=", "9"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
