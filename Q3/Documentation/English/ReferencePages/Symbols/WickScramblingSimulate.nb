Cell[TextData[{
 "Simulate the scrambling and evaluate the OTOC between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ":=", 
    RowBox[{
     SubscriptBox["f", "k"], "+", 
     SubsuperscriptBox["f", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"d98d1798-43f7-4e9b-8971-095cb0a09b12"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", ":=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      SubsuperscriptBox["f", "1", "\[Dagger]"], 
      SubscriptBox["f", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "2d07c8c6-408d-4847-a4b9-d738801c3c12"],
 " (without decoherence):"
}], "ExampleText",
 CellID->1987172350,ExpressionUUID->"bb38dc54-4aa8-40d3-8bb3-7f6ab8cb80f3"],

