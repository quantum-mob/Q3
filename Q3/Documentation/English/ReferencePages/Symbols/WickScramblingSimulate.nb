Cell[TextData[{
 "Simulate the scrambling and evaluate the OTOC between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ":=", 
    RowBox[{
     SubscriptBox["f", "k"], "+", 
     SubsuperscriptBox["f", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"8aa0c85c-f2b5-436b-b447-4746c282d9df"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", ":=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      SubsuperscriptBox["f", "1", "\[Dagger]"], 
      SubscriptBox["f", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "dd5aee7a-67d5-4164-a694-b109e82251f5"],
 " (without decoherence):"
}], "ExampleText",
 CellID->1987172350,ExpressionUUID->"551c4060-25ce-4cb9-b31b-14f3136fae07"],

