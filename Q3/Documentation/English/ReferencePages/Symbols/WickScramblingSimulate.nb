Cell[TextData[{
 "Now, simulate the scrambling and evaluate the OTOC between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ":=", 
    RowBox[{"exp", "[", 
     RowBox[{
      FractionBox["\[Pi]", "2"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubsuperscriptBox["f", "i", "\[Dagger]"], 
         SubscriptBox["f", 
          RowBox[{"i", "+", "1"}]]}], "-", 
        RowBox[{
         SubsuperscriptBox["f", 
          RowBox[{"i", "+", "1"}], "\[Dagger]"], 
         SubscriptBox["f", "i"]}]}], ")"}]}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"2050ca3c-1fc3-4c39-bdb4-9f5797ee3e66"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", ":=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      SubsuperscriptBox["f", "j", "\[Dagger]"], 
      SubscriptBox["f", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "a9307fa1-9b00-4b6c-9260-388f93606b2d"],
 " in the presence of quantum decoherence, which is modeled by random \
measurement of fermionic modes:"
}], "ExampleText",
 CellID->1439151282,ExpressionUUID->"fdc72b04-1cf0-4a19-b175-ffae46f3d8fc"],

