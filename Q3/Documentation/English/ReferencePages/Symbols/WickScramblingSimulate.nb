Cell[TextData[{
 "Now, simulate the scrambling and evaluate the OTOC between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ":=", 
    RowBox[{"exp", "[", 
     RowBox[{
      FractionBox["\[Pi]", "2"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubsuperscriptBox["f", "i", "\[Dagger]"], 
         SubscriptBox["f", 
          RowBox[{"i", "+", "1"}]]}], "-", 
        RowBox[{
         SubsuperscriptBox["f", 
          RowBox[{"i", "+", "1"}], "\[Dagger]"], 
         SubscriptBox["f", "i"]}]}], ")"}]}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"44e6036b-8d5d-4f5d-8b9f-acc45a2714c9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", ":=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      SubsuperscriptBox["f", "j", "\[Dagger]"], 
      SubscriptBox["f", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "a5af9135-3659-485e-bfdf-8f2797e4e314"],
 " in the presence of quantum decoherence, which is modeled by random \
measurement of fermionic modes:"
}], "ExampleText",
 CellID->1439151282,ExpressionUUID->"6aecf008-766d-4b7d-b3aa-39c817919edf"],

