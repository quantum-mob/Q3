 "."
}], "Notes",
 CellID->669978790,ExpressionUUID->"2862936f-8820-4686-813c-cbefa4e4e3a0"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bac82e09-6c29-4c61-abe7-9e48d34cd523"],
 " is a vector ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["x", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["y", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["z", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a1d7c9e9-d9c2-4e7a-9fd3-e46aeff94583"],
 ", then the coupling between two qubits or spins ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "i"], TraditionalForm]],ExpressionUUID->
  "bffbea97-fae9-4241-8a62-eb835ac05c83"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "j"], TraditionalForm]],ExpressionUUID->
  "49cbf7ec-0e37-480d-bfb1-e3129d50905d"],
 " connected by a link gives the Hamiltonian term:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["g", "x"], 
      SubsuperscriptBox["S", "i", "X"], 
      SubsuperscriptBox["S", "j", "X"]}], "+", 
     RowBox[{
      SubscriptBox["g", "y"], 
      SubsuperscriptBox["S", "i", "Y"], 
      SubsuperscriptBox["S", "j", "Y"]}], "+", 
     RowBox[{
      SubscriptBox["g", "z"], 
      SubsuperscriptBox["S", "i", "Z"], 
      SubsuperscriptBox["S", "j", "Z"]}]}]}], TraditionalForm]],
  ExpressionUUID->"69363a6f-c4da-46f7-946e-c474e0f3ae6c"],
 " ."
}], "Notes",
 CellID->115471954,ExpressionUUID->"1259d1ce-7697-444a-a642-d505103c58e2"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "08ca93eb-f63a-4af2-ada6-f720d8499a8a"],
 " is a 3\[Times]3 matrix ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "3db3ccd5-3969-4be6-9530-ae818fd813ff"],
 ", then the coupling gives the term\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubscriptBox["g", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubsuperscriptBox["S", "i", "\[Mu]"], 
     SubsuperscriptBox["S", "j", "\[Nu]"]}]}], TraditionalForm]],
  ExpressionUUID->"bbefe310-dff3-4779-be9c-c150ac0cef63"],
 " ."
}], "Notes",
 CellID->906834529,ExpressionUUID->"685af391-7889-4d3d-872b-fdaf76cbf240"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

