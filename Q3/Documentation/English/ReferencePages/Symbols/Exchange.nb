Cell[TextData[{
 "Consider a unitary gate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "H"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"a93808cb-8df4-4289-823e-e6e8cfe2f7da"],
 " for an exchange coupling Hamiltonian ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "c7dba2f8-c114-413a-8fbb-aa7b3fb6a975"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Exchange"]], "paclet:QuantumMob/Q3/ref/Exchange", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "57c18121-7a97-4c10-a21c-cadd0af6bbd2"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ExchangeExp"]], "paclet:QuantumMob/Q3/ref/ExchangeExp", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "01bd970d-33b5-4578-846b-8d43dced8f34"],
 " describe ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "69c734c0-fc38-4d44-98c0-ef76cb0760ad"],
 " and ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "e48e57b9-7107-4c61-a41a-38c8dac7d8ff"],
 ", respectively."
}], "Notes",
 CellID->1432115322,ExpressionUUID->"2d27566a-0b2e-4253-9289-6d4ecc2afb8e"],

Cell[TextData[{
 "For the connectivity of the coupling, see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Chain"]], "paclet:QuantumMob/Q3/ref/Chain", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3e163750-8db4-4e13-91c3-730e92ce7667"],
 " or ",
 Cell[BoxData[
  TemplateBox[{
