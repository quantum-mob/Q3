Cell[TextData[{
 "Consider a unitary gate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "H"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"c684f20b-1fd4-4260-813b-06ffa4450757"],
 " for an exchange coupling Hamiltonian ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "c5deff9c-e344-4eac-9450-ab508aeb9288"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Exchange"]], "paclet:QuantumMob/Q3/ref/Exchange", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c44abed4-1221-4f63-a686-27115963dc1a"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ExchangeGate"]], "paclet:QuantumMob/Q3/ref/ExchangeGate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "14e4aca7-4996-479b-8966-0814a25498bf"],
 " describe ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "fb72ebf2-1898-4c6e-bb37-067956191ae0"],
 " and ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "c9b437ba-6565-4002-b0ef-d18ea96cbab7"],
 ", respectively."
}], "Notes",
 CellID->1432115322,ExpressionUUID->"11cb605b-b157-4095-bf2e-5fc2eab7a617"],

Cell[TextData[{
 "For the connectivity of the coupling, see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Chain"]], "paclet:QuantumMob/Q3/ref/Chain", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6e76a85b-9fb3-489b-b27d-5209a8810e08"],
 " or ",
 Cell[BoxData[
  TemplateBox[{
