     TextData["ChainBy"]], "paclet:QuantumMob/Q3/ref/ChainBy", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5ae15e01-2068-46f0-84d7-40f8bb476422"],
 "."
}], "Notes",
 CellID->669978790,ExpressionUUID->"61eaf759-6e72-4688-b4cd-93b993aa9502"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5fc7abb1-8a59-48ff-9cc9-0cbfdab12d32"],
 " is a vector ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["x", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["y", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["z", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "701b0bca-72f4-4ab7-9e56-73b4262e4cc9"],
 ", then the coupling between two qubits or spins ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "i"], TraditionalForm]],ExpressionUUID->
  "0911b981-85ca-46e9-a284-21f699eb848d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "j"], TraditionalForm]],ExpressionUUID->
  "1f28d42d-303f-47f1-8b1d-859ef9dd570d"],
 " connected by a link gives the Hamiltonian term:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["g", "x"], 
      SubsuperscriptBox["S", "i", "X"], 
      SubsuperscriptBox["S", "j", "X"]}], "+", 
     RowBox[{
      SubscriptBox["g", "y"], 
      SubsuperscriptBox["S", "i", "Y"], 
      SubsuperscriptBox["S", "j", "Y"]}], "+", 
     RowBox[{
      SubscriptBox["g", "z"], 
      SubsuperscriptBox["S", "i", "Z"], 
      SubsuperscriptBox["S", "j", "Z"]}]}]}], TraditionalForm]],
  ExpressionUUID->"68b1d311-191f-4c22-829f-924109379874"],
 " ."
}], "Notes",
 CellID->115471954,ExpressionUUID->"ed7924eb-2797-4dfd-a8b1-ebefa8040571"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d6655bca-fac0-43d0-b5b7-6f2196881339"],
 " is a 3\[Times]3 matrix ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "f9bc5600-da3d-4a77-b783-649facb89d33"],
 ", then the coupling gives the term\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubscriptBox["g", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubsuperscriptBox["S", "i", "\[Mu]"], 
     SubsuperscriptBox["S", "j", "\[Nu]"]}]}], TraditionalForm]],
  ExpressionUUID->"8ed22c2b-3934-44d1-a513-ca64eaa41c6d"],
 " ."
}], "Notes",
 CellID->906834529,ExpressionUUID->"74e96caf-e1fa-4927-aaab-697a9e1779d9"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

