Cell[TextData[{
 "According to the Murnaghan-Nakayama rule, the character ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Chi]", "\[Lambda]"], "(", "\[Mu]", ")"}], 
   TraditionalForm]],ExpressionUUID->"e995e2f6-0f4b-4e33-af86-32ae9ae36f8a"],
 " is given by the sum of the signatures of the leg lengths of rim hooks \
along the paths, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "\[CenterDot]", 
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "\[CenterDot]", "1", "\[CenterDot]", "1", "\[CenterDot]",
       "1"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "\[CenterDot]", "1", "\[CenterDot]", "1", "\[CenterDot]",
       "1", "\[CenterDot]", "1"}], "+", "0"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"259bf51d-8406-47cc-9ec3-7696df0d71c6"],
 ":"
}], "ExampleText",
 CellID->1756031418,ExpressionUUID->"939c08fc-dabb-4873-ad85-f6cde944dd6b"],

Cell[CellGroupData[{

Cell[BoxData[
