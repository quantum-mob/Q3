Cell[TextData[{
 "This function is just for heuristic purposes to illustrate the \
Murnaghan-Nakayama rule for computing the characters of the symmetric group. \
See ",
 ButtonBox["Bernstein (2004)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1016/j.jsc.2003.11.001"], None}],
 " and Section 4.10 in ",
 ButtonBox["Sagan (2001)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-1-4757-6804-6"], None}],
 "."
}], "Notes",
 CellID->138154776,ExpressionUUID->"2cbcccda-817b-4308-b5b0-98a7a237d147"],

Cell[TextData[{
 "A ",
 StyleBox["rim hook",
  FontSlant->"Italic"],
 " (or ",
 StyleBox["skew hook",
  FontSlant->"Italic"],
 ") ",
 Cell[BoxData[
  FormBox["\[Xi]", TraditionalForm]],ExpressionUUID->
  "813fbd64-54f4-47d2-9d43-e10df2917d71"],
 " of partition (or shape) ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "d65a7ef3-9316-42c8-bec1-ad719ec666a3"],
 " of integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "02570a7d-2723-41ed-944e-628d162f893e"],
 " is a skew diagram obtained by taking all cells on a finite lattice path \
with steps one unit northward or eastward. Graphically, a rim hook can be \
obtained by projecting a regular hook along diagonal onto the boundary of a \
shape. "
}], "Notes",
 CellID->1128605021,ExpressionUUID->"431a2fe2-60dc-4b68-b8fa-110804e2a3ec"],

Cell[TextData[{
 "The ",
 StyleBox["leg length",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"ll", "(", "\[Xi]", ")"}], TraditionalForm]],ExpressionUUID->
  "d6762b4e-a0ae-414d-af3b-290aa41009c3"],
 " of ",
 Cell[BoxData[
  FormBox["\[Xi]", TraditionalForm]],ExpressionUUID->
  "4406760a-ffa6-45e0-92de-9de4b7523d45"],
 " is defined to be the number of rows of ",
 Cell[BoxData[
  FormBox["\[Xi]", TraditionalForm]],ExpressionUUID->
  "4e219bc0-6556-4247-9b50-91daa228c157"],
 " minus 1. "
}], "Notes",
 CellID->1593692084,ExpressionUUID->"f10dac9a-1d44-44e9-a745-b593340443ea"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Xi]", "=", 
    RowBox[{"\[Lambda]", "/", "\[Mu]"}]}], TraditionalForm]],ExpressionUUID->
  "16000ccc-0d42-4411-8b43-27dff0b12605"],
 " for a partition ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "1e4cad69-b689-48d6-b5f2-b1ebc5f9bbd3"],
 ", then we write ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"\[Lambda]", "\\", "\[Xi]"}]}], TraditionalForm]],ExpressionUUID->
  "96977e0e-a466-410e-adc2-64b85f465ac1"],
 "."
}], "Notes",
 CellID->200024385,ExpressionUUID->"616d70c9-5d3c-44bc-bf6a-1b48bbca25aa"],

Cell[TextData[{
 "For a partition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "k"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "97690dc8-9688-405f-897e-4beb64821fc2"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "bc5e9e83-84f8-43e1-bce1-9405d79f566a"],
 ", we also write ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Mu]", "\\", 
     SubscriptBox["\[Mu]", "1"]}], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "k"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "3085f4ec-618d-4c1b-9ce1-e9dce551cc9c"],
 ", but it must not be confused with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\\", "\[Xi]"}], TraditionalForm]],ExpressionUUID->
  "a5c27fec-671e-465a-b29e-4b73de612de2"],
 " with respect to a rim hook ",
 Cell[BoxData[
  FormBox["\[Xi]", TraditionalForm]],ExpressionUUID->
  "32fec7bf-f299-4be4-86e6-2109b4ddb452"],
 " of ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "e27638be-1a39-403f-a8bb-a3fe397af5af"],
 ". "
}], "Notes",
 CellID->1536251775,ExpressionUUID->"076c194c-6e67-4bb0-a98e-741cd84fad88"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "dc99a73d-ac22-4458-a413-4eda3b7740e1"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "k"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "65ea5b1e-d929-4f3d-82b2-cc8867392a09"],
 " be partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cb87d556-2749-45e3-9216-ac9747411377"],
 ". The Murnaghan-Nakayama rule for the character ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Chi]", "\[Lambda]"], "(", "\[Mu]", ")"}], 
   TraditionalForm]],ExpressionUUID->"68de4776-56c3-45c8-b4af-7c1b458873a6"],
 " of conjugacy class of type ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "142af733-ec4a-46a7-a1b7-5bc341688f3e"],
 " in irreducible representation of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "b2430ae5-1703-4b74-ba17-149596ca850c"],
 " gives\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Chi]", "\[Lambda]"], "(", "\[Mu]", ")"}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Xi]"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"ll", "(", "\[Xi]", ")"}]], 
     RowBox[{
      SuperscriptBox["\[Chi]", 
       RowBox[{"\[Lambda]", "\\", "\[Xi]"}]], "(", 
      RowBox[{"\[Mu]", "\\", 
       SubscriptBox["\[Mu]", "1"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"6c9afdf1-b2f7-41cc-aa93-6a6f65b68d25"],
 " ,\[LineSeparator]where the sum runs over all rim hooks ",
 Cell[BoxData[
  FormBox["\[Xi]", TraditionalForm]],ExpressionUUID->
  "c7910094-3669-4814-8fc3-6ad65182e1c3"],
 " of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "a7846d17-1378-420c-b421-485e3dd970db"],
 " having ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "1"], TraditionalForm]],ExpressionUUID->
  "0de679e0-07a8-4d0e-b185-e20af9de7284"],
 " cells."
}], "Notes",
 CellID->1521657348,ExpressionUUID->"653984cd-d1bc-429f-bc12-23670faf89e4"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["RimHookGraph"]], "paclet:QuantumMob/Q3/ref/RimHookGraph", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["\[Lambda]", "TR"], ",", 
    StyleBox["\[Mu]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9853f1e9-6453-47b4-bc6f-00dfd0a7cad2"],
 " constructs a graph with weighted edges from ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "fbb52f30-6a06-4063-b5b9-dc09ae7f80bd"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "/", "\[Xi]"}], TraditionalForm]],ExpressionUUID->
  "fff026d8-e8f2-4c9c-8462-d25eff5246b9"],
 " and similar edges appearing in a recursive computation of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Chi]", "\[Lambda]"], "(", "\[Mu]", ")"}], 
   TraditionalForm]],ExpressionUUID->"ad1cc70c-7dcd-4414-961d-82c75cc82dd2"],
 " based on the Murnaghan-Nakayama rule. The edges are weight by the \
signature of the rim hooks ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"-", "1"}], ")"}], 
    RowBox[{"ll", "(", "\[Xi]", ")"}]], TraditionalForm]],ExpressionUUID->
  "bb1c3e2c-9080-4903-beb6-4892ad97ad25"],
 "."
}], "Notes",
 CellID->1625981311,ExpressionUUID->"b0791602-93f7-42f5-b466-4b1a33e7ec85"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["RimHookGraph"]], "paclet:QuantumMob/Q3/ref/RimHookGraph", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bc4a50c5-c332-4094-869a-6ebd4c7e8c8e"],
