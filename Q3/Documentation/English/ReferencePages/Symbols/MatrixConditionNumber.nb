}, Open  ]],

Cell["\<\
If the matrix is expressed in inexact numbers, the returned condition number \
depends on the tolerance:\
\>", "ExampleText",
 CellID->2059707428,ExpressionUUID->"10c789cf-075c-4c1d-934c-ede25ed68fa7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixConditionNumber", "[", 
  RowBox[{
   RowBox[{"N", "@", "mat"}], ",", 
   RowBox[{"Tolerance", "->", "0"}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1977528674,ExpressionUUID->"1dfdf5f0-8ec5-4d4f-bf1f-3e31937485e9"],

Cell[BoxData["2.9360208385588452`*^16"], "Output",
 CellLabel->"Out[3]=",
 CellID->915894617,ExpressionUUID->"8cb5cb4c-cf18-4d3d-a54f-89b755cec73d"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixConditionNumber", "[", 
  RowBox[{
   RowBox[{"N", "@", "mat"}], ",", 
   RowBox[{"Tolerance", "->", "1.0*^-10"}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1375601302,ExpressionUUID->"9fb8befd-bf7e-4c4c-bf4c-8e59fbdfd43a"],

Cell[BoxData["\[Infinity]"], "Output",
 CellLabel->"Out[4]=",
 CellID->278046223,ExpressionUUID->"bf0e59da-628d-4e0a-8acd-128bcf19150f"]
}, Open  ]],

Cell["\<\
This is because there are only two non-zero singular values within the \
tolerance:\
