Cell["\<\
The condition number of a matrix is a measure of how sensitive the solution \
of a linear system is to small changes in the input data. It quantifies the \
numerical stability of matrix operations and is defined as the ratio of the \
largest to the smallest singular value of the matrix.\
\>", "Notes",
 CellID->2095288529,ExpressionUUID->"e6bb7efb-d29f-4444-b49f-3f68d9f5f911"],

Cell[TextData[{
 "Implementation note: ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["MatrixConditionNumber"]], 
    "paclet:QuantumMob/Q3/ref/MatrixConditionNumber", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "092992e3-48f6-41bd-b2a0-1ca83e313539"],
 " is based on ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["SingularValueList"]], "paclet:ref/SingularValueList"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fb15b495-b62e-4d23-83df-106e703c1793"],
 ", and gives the 2-norm condition number."
}], "Notes",
 CellID->806001884,ExpressionUUID->"60a2ddbf-d43a-4be0-b6ff-a97024c63855"],

Cell[TextData[{
 "For a large approximate numerical matrix, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["LUDecomposition"]], "paclet:ref/LUDecomposition"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["mat", "TI"], "]"}], "[", 
   RowBox[{"[", "3", "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "70f13b6b-ad3c-4061-a3f9-4ba8221cbf63"],
 " may calculate an estimate of the condition number give about 3 times \
faster than the current implementation. However, remember that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["LUDecomposition"]], "paclet:ref/LUDecomposition"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["mat", "TI"], "]"}], "[", 
   RowBox[{"[", "3", "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "23b7d0ea-f79b-4144-9957-aeed703c7f07"],
 "  always gives 0 for a matrix in exact numbers and returns the \
\[Infinity]-norm condition number."
}], "Notes",
 CellID->79380119,ExpressionUUID->"4c83e7dd-fb54-4900-96bb-57e3ad0fe947"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tolerance"]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b4bd67c3-1e11-4256-a54b-db9fc46f7d0a"],
 ", singular values that are smaller than ",
 Cell[BoxData[
  StyleBox["t", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d0fe0166-ffad-4051-9497-17c6262b4dfc"],
 " times the largest singular value are regarded zero. That is, the ratio ",
 Cell[BoxData[
  RowBox[{
   StyleBox["min", "TI"], "/", 
   StyleBox["max", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e0d9b1df-1d11-4321-abc8-b82459a5331c"],
 " of the smallest to largest singular values is regarded zero (the condition \
number is \[Infinity])."
}], "Notes",
 CellID->1260834000,ExpressionUUID->"8b4ff475-e16f-432a-94f1-6ea2637b2892"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

