Cell["\<\
Now, adjust the parameter to a value 5 times larger than the previous one.\
\>", "ExampleText",
 CellID->296624125,ExpressionUUID->"c3b7e279-ec8c-4d7f-a68c-0f8de00223aa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "411", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1052124188,ExpressionUUID->"a0367ca1-b119-4d7d-bbcc-cea247fe0390"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$BravyiMinorSteps", "=", "50"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->670878318,ExpressionUUID->"7554b25a-8ebf-4cac-8cfb-a41c1ad901ee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"BravyiSimulate", "[", 
     RowBox[{"in", ",", "ham", ",", "jmp", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"$T", "=", "0.5"}], ",", 
        RowBox[{"dt", "=", "0.01"}]}], "}"}], ",", 
      RowBox[{"\"\<Samples\>\"", "->", "100"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1162743876,ExpressionUUID->"35f39ca9-8d48-4d26-88e1-4bf648bfb2dd"],

Cell[BoxData["38.256967`"], "EchoTiming",
 CellID->750242089,ExpressionUUID->"6de89e52-6c1d-4591-b4d9-514a4bf55db1"]
}, Open  ]],

Cell["\<\
Let us now examine various entanglement properties. Take the first half of \
the fermion modes as a subsystem.\
\>", "ExampleText",
 CellID->1344436345,ExpressionUUID->"f2b14c40-23b5-4b98-bd9e-60e1b7a693b4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"kk", "=", 
  RowBox[{"Range", "[", 
   RowBox[{"$n", "/", "2"}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->118716681,ExpressionUUID->"d730492d-8779-4161-be33-e5f4db4afc63"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "2"}], "}"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->1442298286,ExpressionUUID->"38d67685-c9e5-4f84-bc61-9cea2043e087"]
}, Open  ]],

Cell[TextData[{
 "Calculate the ",
 StyleBox["entanglement entropy",
  FontSlant->"Italic"],
 " (EE) between the subsystem and the rest."
}], "ExampleText",
 CellID->1362444906,ExpressionUUID->"57a24a87-fb5e-40ad-a0ab-b9be8a2ef8a8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"ee", "=", 
    RowBox[{"BravyiEntanglementEntropy", "[", 
     RowBox[{"data", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->2140890828,ExpressionUUID->"8230fea6-34de-4d0a-9034-daa486f33c9b"],

Cell[BoxData["0.624959`"], "EchoTiming",
 CellID->822743492,ExpressionUUID->"13916403-7ce4-406d-85ab-f78843733074"]
}, Open  ]],

Cell["\<\
Plot the entanglement entropy averaged over the quantum trajectories. Here, \
\[Gamma] refers to the damping rate, which equals to 1 in our unit system.\
\>", "ExampleText",
 CellID->367459704,ExpressionUUID->"269a0686-ffcc-4c20-8c86-f7596477c233"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Mean", "[", "ee", "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", "12"}], "}"}]}], ",", 
