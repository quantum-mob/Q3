Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{"CommonEigensystem", "[", 
       RowBox[{"{", 
        RowBox[{
         SubscriptBox[
          StyleBox["m", "TI"], 
          StyleBox["1", "TR"]], ",", " ", 
         SubscriptBox[
          StyleBox["m", "TI"], 
          StyleBox["2", "TR"]], ",", "  ", 
         StyleBox["\[Ellipsis]", "TR"]}], "}"}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "422c28d8-1f0d-4c5a-84dd-747d388ec41f"],
     "\[LineSeparator]finds the simultaneous eigenvectors and corresponding \
eigenvalues of the mutually commuting square matrices ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["m", "TI"], 
         StyleBox["1", "TR"]], ",", 
        SubscriptBox[
         StyleBox["m", "TI"], 
         StyleBox["2", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "230ed720-e3c6-46c2-8bdf-255c389a99a7"],
     ". It returns a list of the form ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{
        StyleBox["values", "TI"], ",", 
        StyleBox["vectors", "TI"]}], "}"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "5c9d4b51-98e1-480f-a4ec-b27832644ec3"],
     ". Each row of ",
     Cell[BoxData[
      StyleBox["values", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8ece6b79-a3a9-453a-8df5-391bbf1b9442"],
     " gives the eigenvalues of ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["m", "TI"], 
         StyleBox["1", "TR"]], ",", 
        SubscriptBox[
         StyleBox["m", "TI"], 
         StyleBox["2", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d9629f6a-4f72-489e-b4c6-7d0be452c949"],
     " for the corresponding eigenvector in ",
     Cell[BoxData[
      StyleBox["vectors", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "13eb9095-49d0-48e2-a6b4-18e35850d3ca"],
     ". "
    }],ExpressionUUID->"6df15c93-fdc2-433b-9073-4486d2b7f88d"]}
  }]], "Usage",ExpressionUUID->"2bf569fa-62ef-4885-8cad-89f7bdc2d72e"]
