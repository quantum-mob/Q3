Cell[TextData[{
 "If the input matrix ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "35b276ad-f4c6-44cd-b46d-1cae9fe0dacf"],
 " consists of a reduced Gottesman vectors, each row is padded with 1 before \
the row-reduction."
}], "Notes",
 CellID->1976315452,ExpressionUUID->"cf260f4a-3530-46be-9940-70f001b47685"],

Cell[TextData[{
 "For the pattern ",
 Cell[BoxData[
  StyleBox["upper", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e5b85cfc-5415-4711-a382-521b7a50c060"],
