  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7c728864-2169-43fb-9a51-3e6afcf419aa"],
 " for the Z or Y operators."
}], "Notes",
 CellID->2134757657,ExpressionUUID->"36e66420-8128-4d7e-abc4-e3cae721da24"],

Cell[TextData[{
 "For the pattern ",
 Cell[BoxData[
  StyleBox["lower", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e2c82d39-19aa-45e1-adad-f974d9122007"],
