Cell[TextData[{
 "For a given stabilizer subgroup, the choice of generating set is not \
unique. For ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "df59d5c6-eec2-4feb-bc04-dfd7b19c0ef1"],
 " consisting of stabilizer generators, the resulting form is the standard \
form which refers to a unique generating set of the given stabilizer \
subgroup. See Garc\[IAcute]a, Markov and Corss (",
 ButtonBox["2012",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://arxiv.org/abs/1210.6646"], None}],
 ", ",
 ButtonBox["2014",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.26421/QIC14.7-8-9"], None}],
 ")."
}], "Notes",
 CellID->191413625,ExpressionUUID->"f07550e4-beef-42a7-afb3-a44237e9c2ee"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

