Cell[TextData[{
 "To test a pure state, ",
 Cell[BoxData[
  StyleBox["state", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "29d3f441-9131-48aa-b845-629ae68bb813"],
 " may be a vector in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     SuperscriptBox["\[DoubleStruckCapitalC]", "2"], ")"}], 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "2e188bb6-8b4f-40d6-83f5-28ffb0236831"],
 " or expressed in terms of ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Pauli", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", "\[Ellipsis]", "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6a9ba5fb-2834-427a-b856-780476669d59"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Pauli", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"\[LeftAssociation]", "\[Ellipsis]", "\[RightAssociation]"}], 
   "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bda88567-fd41-456c-813d-f825ac940fb0"],
 "."
}], "Notes",
 CellID->716346422,ExpressionUUID->"a4d2b9bd-4f2f-4f17-9c28-a2b204e35bef"],

Cell[TextData[{
 "To test a mixed state, ",
 Cell[BoxData[
  StyleBox["state", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "58e0fbff-3e9e-4bea-ac53-587b89355e42"],
 " may be a matrix in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     SuperscriptBox["\[DoubleStruckCapitalC]", "2"], ")"}], 
    RowBox[{"n", "\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "d61c83f9-eabc-4326-b1b8-a4603256f749"],
 " or expressed in terms of ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Pauli"]], "paclet:QuantumMob/Q3/ref/Pauli", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    StyleBox["\[Ellipsis]", "TR"], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fadd0a6e-8fbe-4197-9a8d-5b5985c64a7f"],
 " or Pauli operators (such as ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["S", "TI"], "[", 
    RowBox[{"1", ",", "2"}], "]"}], "**", 
   RowBox[{
    StyleBox["S", "TI"], "[", 
    RowBox[{"2", ",", "3"}], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5392d3e9-d021-48c4-aa6d-77bd125a0008"],
 " for qubits ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["S", "TI"], 
   StyleBox["1", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "735b6996-9a35-4b27-a3c9-1df37bccdeb1"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["S", "TI"], 
   StyleBox["2", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "05a11f1e-7405-47c1-95c9-e76ed0517e77"],
 ")."
}], "Notes",
 CellID->941849189,ExpressionUUID->"495e9411-de28-4ef0-8c35-dd4e5ff80e15"],

Cell[TextData[{
 "A state is called a ",
 StyleBox["stabilizer state",
  FontSlant->"Italic"],
 " if it can be stabilized by a non-trivial subgroup of the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 ". A state is a stabilizer state if and only if it can be generated from ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"0", ",", "0", ",", "\[Ellipsis]", ",", "0"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "263d6c36-12fd-45c8-aedc-432e3e6bda40"],
 " by applying a ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/PauliAndCliffordGroups"],
 "."
}], "Notes",
 CellID->356871505,ExpressionUUID->"5ccf708a-f1df-4073-8eab-c01b77344d10"],

Cell[TextData[{
 "The density operator of a stabilizer state that is stabilized by stabilizer \
subgroup ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "051c6215-162d-4fe8-9345-6c7730826d8f"],
 " of the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " can be expressed as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalS]", 
        "\[RightBracketingBar]"}]]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalS]"}]], "g"}]}], 
   TraditionalForm]],ExpressionUUID->"5cf97aea-8ca8-4f87-8f36-849c8a7f074f"],
 " .\[LineSeparator]If the order ",
 Cell[BoxData[
  FormBox[
   RowBox[{
   "\[LeftBracketingBar]", "\[ScriptCapitalS]", "\[RightBracketingBar]"}], 
   TraditionalForm]],ExpressionUUID->"955075a8-b52f-480a-a09e-feec2a8b6fab"],
 " is equal to the number of qubits, then \[Rho] is a pure state; otherwise, \
\[Rho] is a mixed state."
}], "Notes",
 CellID->1115602955,ExpressionUUID->"fca4c552-6712-410b-afce-6de2bde02043"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

