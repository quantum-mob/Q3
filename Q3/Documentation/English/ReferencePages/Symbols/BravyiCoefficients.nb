Cell[TextData[{
 "This two step calculation can be achieved by a single step by putting Dirac \
fermion modes in the second argument. It is important to note that the result \
is ",
 StyleBox["not",
  FontSlant->"Italic"],
 " the coefficients of Dirac fermion operators but of Majorana fermion \
operators."
}], "ExampleText",
 CellID->654431046,ExpressionUUID->"0ab43b36-eded-4b2a-97e0-fbc9ac1efad9"],

