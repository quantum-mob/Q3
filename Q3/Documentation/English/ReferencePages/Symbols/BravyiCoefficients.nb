Cell[TextData[{
 "In both cases, returned is the complex matrix ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5f39b5ff-0db3-41e5-a5be-f86b0be118cc"],
 " specifying the linear combinations of ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " operators. This is useful because while the ",
 StyleBox[ButtonBox["fermionic quantum computation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/FermionicQuantumComputation"],
  FontSlant->"Italic"],
 " is simulated based on the ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " representation, sometimes the ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " representation is more intuitive."
}], "Notes",
 CellID->2109920175,ExpressionUUID->"b2ce4518-8ef1-40ef-b4fd-9e66f9b8068b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

