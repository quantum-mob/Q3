Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData["Vacuum"], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "61c33f96-3152-4ae2-bbba-a6ad9cab382c"],
     "\[LineSeparator]is an option to ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["Let"]], "paclet:QuantumMob/Q3/ref/Let", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        TemplateBox[{
          Cell[
           TextData["Fermion"]], "paclet:QuantumMob/Q3/ref/Fermion", 
          "QuantumMob Package Symbol"},
         "PackageLink",
         BaseStyle->"InlineFormula"], ",", " ", "..."}], "]"}]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "84072076-2c23-4ca4-96b3-fdf3996b1d8d"],
     ". Its value should be either ",
     StyleBox["\"Void\"", "Input"],
     " or ",
     StyleBox["\"Sea\"", "Input"],
     ". ",
     StyleBox["\"Void\"", "Input"],
     " (",
     StyleBox["\"Sea\"", "Input"],
     ") declares that the vacuum state for the Fermion operator is the \
completely empty state (Fermi sea with all levels below the Fermi level \
filled up). The vacuum state determines how the fermionic operators are \
reordered."
    }],ExpressionUUID->"1f9c08e6-961b-4f6b-af59-172e37006947"]},
   {"", Cell[TextData[{
