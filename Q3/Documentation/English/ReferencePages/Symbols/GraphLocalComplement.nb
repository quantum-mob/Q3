Cell[TextData[{
 "The ",
 StyleBox["local complement",
  FontSlant->"Italic"],
 " of a graph ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a7bff1c8-3e44-4b6a-b72d-56ecb28f1c97"],
 " according to vertex ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "34c0f275-ceb4-4dae-8f44-5850a0662e2f"],
 ", denoted by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["g", "TI"], "*", 
   StyleBox["v", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "849ca21f-4d14-4436-a622-a1d441f676bc"],
 ", is a graph that has the same vertices as ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d7c12a77-5b4d-4e09-9eba-c2b716f22478"],
 ", but all the neighbors of of ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f2543179-5835-4f3b-b9fa-f71b4e21e914"],
 " are connected if and only if they are not connected in ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f3d8309f-2251-42fc-bb25-1309cb0c8aaa"],
 "."
}], "Notes",
