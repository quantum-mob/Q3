Cell[TextData[{
 "The group element ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d50df15a-040f-4a26-847e-28cc0b3faed0"],
 " can be specified differently depending on the group. For a symmetric group \
",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["S", "n"],
   FontSlant->"Italic"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fb4d0228-db88-4793-a81a-8abb065ee51d"],
 " as an example, it can be specified by an partition of ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "60e26dc2-ba24-4a4e-9206-25b34c3eb1a7"],
 ", which determines the conjugacy class that the element belongs to."
}], "Notes",
 CellID->394586610,ExpressionUUID->"7eaa7f32-f6b5-4d92-9972-2e6f2a735bb1"],

Cell[TextData[{
 "The inverse of the GroupClassSize[class] coincides, up to a factor of the \
group order, with the size of the class: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[ScriptCapitalZ]", 
    RowBox[{"(", "g", ")"}]}], "=", 
   RowBox[{"|", "\[ScriptCapitalG]", "|", 
    RowBox[{"/", 
     RowBox[{"|", 
      RowBox[{"\[ScriptCapitalC]", 
       RowBox[{"(", "g", ")"}]}], "|"}]}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5fc73348-d3d7-4d2f-8d2b-5fe572f03389"],
 ", where \[ScriptCapitalZ](g) is the centralizer of the element ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7310a175-9926-4242-aaca-15e8c139601e"],
 ", and \[ScriptCapitalC](g) is the conjugacy class containing ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "16aefc83-af4d-487c-af66-577c96bb1855"],
 ". See Eq.(1) in Sagan (2001)."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"7ba35be8-a5ff-4191-9e33-64ab1bbba164"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

