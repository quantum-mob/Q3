Cell[TextData[{
 "The canonical form of expression ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       SubscriptBox["v", "1"]},
      "Ket"], 
     SubscriptBox["c", "1"]}], "+", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["v", "2"]},
      "Ket"], 
     SubscriptBox["c", "2"]}], "+", "\[Ellipsis]", "+", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["v", "n"]},
      "Ket"], 
     SubscriptBox["c", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "a8f16d81-d297-4173-8d40-23f312503cf0"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["v", "1"]},
     "Ket"], "+", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["v", "2"]},
      "Ket"], 
     FractionBox[
      SubscriptBox["c", "2"], 
      SubscriptBox["c", "1"]]}], "+", "\[Ellipsis]", "+", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["v", "n"]},
      "Ket"], 
     FractionBox[
      SubscriptBox["c", "n"], 
      SubscriptBox["c", "1"]]}]}], TraditionalForm]],ExpressionUUID->
  "092d3036-4fa1-471c-8489-3c69fadcf342"],
 " when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["v", "1"]},
      "Ket"], ",", 
     TemplateBox[{
       SubscriptBox["v", "2"]},
      "Ket"], ",", "\[Ellipsis]", ",", 
     TemplateBox[{
       SubscriptBox["v", "n"]},
      "Ket"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "394a8781-3abc-4eda-b823-bac00434eef0"],
 " is in the canonical order."
}], "Notes",
 CellID->790452317,ExpressionUUID->"fbcff168-e3da-48cf-8f4d-f083455004fd"],

