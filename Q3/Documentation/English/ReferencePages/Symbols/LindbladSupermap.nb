Cell["\<\
Mathematically, Lindblad supermap is a generator of a dynamical semi-group.\
\>", "Notes",
 CellID->486125778,ExpressionUUID->"0d094f50-575e-4052-a447-a0046bb58b1a"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{"LindbladSupermap", "[", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["a", "TI"], ",", 
      SubscriptBox[
       StyleBox["b", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["b", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], 
     StyleBox["}", "TR"]}], "]"}], "[", 
