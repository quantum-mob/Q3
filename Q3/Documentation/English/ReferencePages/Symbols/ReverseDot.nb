Cell["Set the number of qubits in the quantum register:", "ExampleText",
 CellID->1980210141,ExpressionUUID->"f9f6175f-9c00-4cf9-a11e-f55659fde45c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$N", "=", 
   RowBox[{"Power", "[", 
    RowBox[{"2", ",", "$n"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$T", "=", "50"}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->733396944,ExpressionUUID->"1094bc4a-4d2a-4ac2-ad51-3d0e55e52261"],

Cell["Pick a initial vector:", "ExampleText",
 CellID->422585472,ExpressionUUID->"3c4c676b-4dd1-426f-bb62-33e2dde9064e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "381", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1793787675,ExpressionUUID->"80b53bda-79d8-4a5f-bbb9-acf93d524b28"],

Cell[BoxData[
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{"RandomVector", "[", "$N", "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1814017139,ExpressionUUID->"6b90b08f-2d6e-437f-a674-51616d5c5303"],

Cell["Consider some unitary matrices (representing some gates):", \
"ExampleText",
 CellID->613549589,ExpressionUUID->"5321e6b1-7b56-4343-868d-4228a082d7c6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"uu", "=", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{
     RowBox[{"RandomUnitary", "[", "$N", "]"}], ",", "$T"}], "]"}]}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->360718714,ExpressionUUID->"846a35f6-1558-4b21-88b4-637fe84dd03b"],

Cell["\<\
This is a list of quantum circuit elements that usually you get from a \
quantum circuit:\
\>", "ExampleText",
 CellID->253090717,ExpressionUUID->"5a4427b8-4eca-4f4f-ac6e-646cea12cc4a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"all", "=", 
   RowBox[{"Prepend", "[", 
    RowBox[{"uu", ",", "in"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1678059559,ExpressionUUID->"83f84616-0449-4e79-b6a5-fb1300da6348"],

Cell[TextData[{
 "Now, calculate the output in the standard way. Notice the function ",
 StyleBox["Reverse", "Input"],
 " applied to the set of quantum circuit elements because the time flows from \
the left to right in a quantum circuit:"
}], "ExampleText",
 CellID->244272062,ExpressionUUID->"13b29739-751e-4952-892a-14667ca47282"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", 
   RowBox[{"out", "=", 
    RowBox[{"Apply", "[", 
     RowBox[{"Dot", ",", 
      RowBox[{"Reverse", "@", "all"}]}], "]"}]}], "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1639296617,ExpressionUUID->"a73b1c77-5003-4910-810d-81310b8f8fd8"],

Cell[BoxData["4.948567`"], "EchoTiming",
 CellID->38140304,ExpressionUUID->"2221d8aa-4a32-443f-bd79-c1e01c221ba0"]
}, Open  ]],

Cell["\<\
However, multiplying a matrix to the input vector and subsequent matrices to \
the resulting vectors is faster.\
\>", "ExampleText",
 CellID->237844836,ExpressionUUID->"7dee7ef6-5037-46a7-adfe-5fe5f4e4d070"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", 
   RowBox[{"new", "=", 
    RowBox[{"ReverseDot", "@@", "all"}]}], "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->991091585,ExpressionUUID->"fe6634d6-ffd6-43d1-8037-26603810fea0"],

Cell[BoxData["0.461599`"], "EchoTiming",
 CellID->1073962522,ExpressionUUID->"287dc1cb-328c-4942-b50a-19926e01ca85"]
}, Open  ]],

Cell["\<\
Here are another ways to get matrices multiplied to vectors. However, in this \
case, it costs time to take the Hermitian conjugates or transpositions of the \
matrix and vector elements, and is even slower than the first method.\
\>", "ExampleText",
 CellID->2014779547,ExpressionUUID->"2e424114-9f61-4daa-ae66-97235f538e15"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", 
   RowBox[{"mint", "=", 
    RowBox[{"Apply", "[", 
     RowBox[{"Dot", ",", 
      RowBox[{"Transpose", "/@", "all"}]}], "]"}]}], "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->2057152656,ExpressionUUID->"359f27e0-6778-41d3-a5df-7680df5dbdee"],

Cell[BoxData["4.637686`"], "EchoTiming",
 CellID->488054219,ExpressionUUID->"ad79baa4-2858-47eb-9bba-afc40a15eb76"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", 
   RowBox[{"more", "=", 
    RowBox[{"Conjugate", "@", 
     RowBox[{"Apply", "[", 
      RowBox[{"Dot", ",", 
       RowBox[{"ConjugateTranspose", "/@", "all"}]}], "]"}]}]}], "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[9]:=",
 CellID->877700533,ExpressionUUID->"bb9d8ae5-8577-470e-a220-91adedb4d6b3"],

Cell[BoxData["8.472577`"], "EchoTiming",
 CellID->1487210840,ExpressionUUID->"c725d606-3e45-402b-9527-f0aee39826db"]
}, Open  ]],

Cell["Of course, all these results are the same.", "ExampleText",
 CellID->1638311175,ExpressionUUID->"43d5ffa3-e070-42b9-bf5c-9a360c1cc7c8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"out", "-", "new"}], "//", "ArrayZeroQ"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "-", "mint"}], "//", "ArrayZeroQ"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "-", "more"}], "//", "ArrayZeroQ"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
 CellID->60596391,ExpressionUUID->"164e1507-5e25-46c2-8871-ac63a07982cd"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[10]=",
 CellID->990420447,ExpressionUUID->"5fa887d0-0c35-43e2-8a60-a48a2da6b4b8"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[10]=",
 CellID->850704832,ExpressionUUID->"12409c71-fbb2-482c-b250-37ee92a5bbba"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[10]=",
 CellID->1997473345,ExpressionUUID->"2e4cf272-3503-471e-8ca8-19ac5a07a114"]
}, Open  ]]
