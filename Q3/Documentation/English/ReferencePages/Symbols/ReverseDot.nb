Cell[TextData[{
 "The built-in function ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Dot"]], "paclet:ref/Dot"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1f163e20-baaf-4818-9eca-edff63d7deae"],
 " calculates ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Dot"]], "paclet:ref/Dot"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["0", "TR"]], ",", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9722ad50-d288-447d-a561-05766cdea2dc"],
 " effectively as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Dot"]], "paclet:ref/Dot"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Dot"]], "paclet:ref/Dot"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     RowBox[{
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["Dot"]], "paclet:ref/Dot"},
        "RefLink",
        BaseStyle->{"InlineFormula"}], "[", 
       RowBox[{
        SubscriptBox[
         StyleBox["m", "TI"], 
         StyleBox["0", "TR"]], ",", 
        SubscriptBox[
         StyleBox["m", "TI"], 
         StyleBox["1", "TR"]]}], "]"}], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["2", "TR"]]}], "]"}], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0e050ca5-9f02-4785-a538-78fd898c1700"],
 ". Therefore, if the first argument ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m", "TI"], 
   StyleBox["0", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c3fb345b-6c71-4abf-95d7-715342c43c98"],
 " is a vector, it will be much faster than, for example, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Dot"]], "paclet:ref/Dot"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["0", "TR"]], ",", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Dot"]], "paclet:ref/Dot"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "]"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8fe6c7c2-036f-4037-9146-57f50b9c3b23"],
 ". "
}], "Notes",
 CellID->2082096187,ExpressionUUID->"937744b4-117a-4537-8f17-a60386133a5f"],

Cell[TextData[{
 "Note that, for example, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuit"]], "paclet:QuantumMob/Q3/ref/QuantumCircuit", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54e7cb31-7e76-4975-96c6-531692319e70"],
 " often has a list of the form ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    StyleBox["vec", "TI"], ",", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a7ef4932-1c1e-449a-97e0-bff49668aa66"],
 " with vector ",
 Cell[BoxData[
  StyleBox["vec", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "be2e93a8-4e78-4b0e-a128-7bb4f7d45a2b"],
 " appearing as the first element, but needs to calculate matrix product of \
the form ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Dot"]], "paclet:ref/Dot"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["2", "TR"]], ",", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["1", "TR"]], ",", 
    TemplateBox[{
      Cell[
       TextData["vec"]], "paclet:QuantumMob/Q3/ref/vec"},
     "RefLink",
     BaseStyle->{"InlineFormula", "TI"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "063839be-be54-492f-ae27-d5d4cd92617d"],
 " because the time flows by convention from the left to right in a quantum \
circuit. Since the vector appears at the end, it will be faster to do the \
calculation as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Dot"]], "paclet:ref/Dot"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    StyleBox["\[Ellipsis]", "TR"], ",", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Dot"]], "paclet:ref/Dot"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["2", "TR"]], ",", 
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["Dot"]], "paclet:ref/Dot"},
        "RefLink",
        BaseStyle->{"InlineFormula"}], "[", 
       RowBox[{
        SubscriptBox[
         StyleBox["m", "TI"], 
         StyleBox["1", "TR"]], ",", 
        TemplateBox[{
          Cell[
           TextData["vec"]], "paclet:QuantumMob/Q3/ref/vec"},
         "RefLink",
         BaseStyle->{"InlineFormula", "TI"}]}], "]"}]}], "]"}]}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b1bb0b2d-7bdd-4897-a46c-cd84b8010a8a"],
 ". This is exactly what ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ReverseDot"]], "paclet:QuantumMob/Q3/ref/ReverseDot", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["vec", "TI"], ",", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "962bb0a3-85f5-4529-8cbe-cbce664a77b8"],
 " does."
}], "Notes",
 CellID->1612641696,ExpressionUUID->"854efa48-8046-4d23-b9c3-e743302bda4b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

