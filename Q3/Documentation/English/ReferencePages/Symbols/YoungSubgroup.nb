 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
