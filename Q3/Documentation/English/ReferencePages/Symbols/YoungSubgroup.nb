   SubscriptBox["A", "k"], TraditionalForm]],ExpressionUUID->
  "2449cf7f-323a-4d15-8348-cd7a1d02d298"],
 " is a set of consecutive integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "k"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", "1"}], ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"k", "-", "1"}]]}], ")"}], "+", "2"}], ",", "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
