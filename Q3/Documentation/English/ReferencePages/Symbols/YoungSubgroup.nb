Cell[TextData[{
 "The Young subgroup ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"05ab8188-869c-4f96-8ae1-f36471ba7f6a"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "82057b05-aafc-4f3c-a9dc-840d5d7d6cc6"],
 " associated with ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "d"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "9f7bc1dd-9660-4f3d-b722-67d5c6fe612e"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f31afda6-c27e-4031-b769-9fd703816be2"],
 ", is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ":=", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalS]", 
      RowBox[{"{", 
       RowBox[{"1", ",", "\[Ellipsis]", ",", 
        SubscriptBox["\[Mu]", "1"]}], "}"}]], "\[Times]", 
     SubscriptBox["\[ScriptCapitalS]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "1"}], ",", "\[Ellipsis]", ",", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", 
         SubscriptBox["\[Mu]", "2"]}]}], "}"}]], "\[Times]", "\[Ellipsis]", "\[Times]", 
     SubscriptBox["\[ScriptCapitalS]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"d", "-", "1"}]], "+", "1"}], ",", "\[Ellipsis]", ",", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], "+", "\[Ellipsis]", "+", 
         SubscriptBox["\[Mu]", 
          RowBox[{"d", "-", "1"}]], "+", 
         SubscriptBox["\[Mu]", "d"]}]}], "}"}]]}]}], TraditionalForm]],
  ExpressionUUID->"252dc865-b7c9-4a3a-a3a1-cd2575255284"],
 " .\[LineSeparator]It is isomorphic to\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], "\[TildeEqual]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalS]", 
      SubscriptBox["\[Mu]", "1"]], "\[Times]", 
     SubscriptBox["\[ScriptCapitalS]", 
      SubscriptBox["\[Mu]", "2"]], "\[Times]", "\[Ellipsis]", "\[Times]", 
     SubscriptBox["\[ScriptCapitalS]", 
      SubscriptBox["\[Mu]", "d"]]}]}], TraditionalForm]],ExpressionUUID->
  "d4c13e75-d242-4413-a65f-55bd66b13b00"],
 " ."
}], "Notes",
 CellID->2041374786,ExpressionUUID->"e24bf12c-3ce1-41a8-9833-20fe630d3427"]
}, Dynamic[CurrentValue[
