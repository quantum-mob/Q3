  FormBox[
   RowBox[{
    SubscriptBox["S", "\[Mu]"], ":=", 
    RowBox[{
     SubscriptBox["S", 
      SubscriptBox["A", "1"]], "\[Times]", 
     SubscriptBox["S", 
      SubscriptBox["A", "2"]], "\[Times]", "\[CenterEllipsis]", "\[Times]", 
