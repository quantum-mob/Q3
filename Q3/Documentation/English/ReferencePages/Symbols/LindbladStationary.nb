Cell["\<\
To check it, let solve the Lindblad equation explicitly. Consider a \
particular initial state. The stationary state does not depend on the initial \
state.\
\>", "ExampleText",
 CellID->10779775,ExpressionUUID->"bc49ab01-ddeb-438a-a4b8-dd9957bc89aa"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Real", ",", "x"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"init", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Pauli", "[", "0", "]"}], "/", "2"}], "+", 
   RowBox[{"Dot", "[", 
    RowBox[{
     RowBox[{"x", "@", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], ",", 
     RowBox[{"Pauli", "/@", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"init", "//", "Matrix"}], "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->383286299,ExpressionUUID->"a6e385d4-5503-489b-8755-9f5103741738"],

