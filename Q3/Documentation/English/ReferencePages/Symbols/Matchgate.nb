  FormBox[
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["v", "11"], 
       SubscriptBox["v", "12"]},
      {
       SubscriptBox["v", "21"], 
       SubscriptBox["v", "22"]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "f02664d2-6858-4622-ad4f-64b48f959160"],
 " correspond to Euler angles ",
