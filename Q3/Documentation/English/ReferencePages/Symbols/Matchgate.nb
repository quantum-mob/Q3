Cell[TextData[{
 "A matchgate has the matrix representation of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["u", "11"], "0", "0", 
       SubscriptBox["u", "12"]},
      {"0", 
       SubscriptBox["v", "11"], 
       SubscriptBox["v", "12"], "0"},
      {"0", 
       SubscriptBox["v", "21"], 
       SubscriptBox["v", "22"], "0"},
      {
       SubscriptBox["u", "21"], "0", "0", 
       SubscriptBox["u", "22"]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "c6d828b5-e7c1-4a54-8076-ca12899cd3c8"],
 ","
}], "Notes",
 CellID->1618646770,ExpressionUUID->"26bdf5a1-6685-4ae5-b8bc-504f52711eff"],

Cell[TextData[{
 "where the submatrices ",
