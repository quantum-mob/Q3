Cell[BoxData[
 RowBox[{"op", "=", 
  RowBox[{"Matchgate", "[", 
   RowBox[{
    RowBox[{"Pi", "*", 
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{"1", "/", "2"}], ",", "1"}], "}"}]}], ",", 
    RowBox[{"Pi", 
     RowBox[{"{", 
      RowBox[{"1", ",", 
       RowBox[{"2", "/", "3"}], ",", "1"}], "}"}]}], ",", 
