Cell[TextData[{
 "A matchgate has the matrix representation of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["u", "11"], "0", "0", 
       SubscriptBox["u", "12"]},
      {"0", 
       SubscriptBox["v", "11"], 
       SubscriptBox["v", "12"], "0"},
      {"0", 
       SubscriptBox["v", "21"], 
       SubscriptBox["v", "22"], "0"},
      {
       SubscriptBox["u", "21"], "0", "0", 
       SubscriptBox["u", "22"]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "b09cea8d-ae6d-4631-b46d-b38c058480a5"],
 ","
}], "Notes",
 CellID->1618646770,ExpressionUUID->"b4d5fe6f-199d-40eb-86c6-91bda19d916c"],

Cell[TextData[{
 "where the submatrices ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["u", "11"], 
       SubscriptBox["u", "12"]},
      {
       SubscriptBox["u", "21"], 
       SubscriptBox["u", "22"]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "5e25fb4b-765d-4135-9f26-285b83c95d6e"],
 " and ",
