Cell[TextData[{
 "This is optimized for fermionic Gaussian processes without pairing \
correlation. For the general case, see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMonitor"]], "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
