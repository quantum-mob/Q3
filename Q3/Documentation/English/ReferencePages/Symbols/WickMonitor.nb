Cell["\<\
Calculate the logarithmic negativity (LN) between the subsystem and the rest:\
\
\>", "ExampleText",
 CellID->1308958114,ExpressionUUID->"9efc9cbc-a0a2-4983-bd63-78062b1105de"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"Mean", "@", 
     RowBox[{"WickLogarithmicNegativity", "[", 
      RowBox[{"data", ",", "sub"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
