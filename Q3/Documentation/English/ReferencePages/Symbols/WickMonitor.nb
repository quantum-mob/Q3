   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\[VeryThinSpace]\[ThinSpace]t\>\"", 
      ",", "\"\<LN (L, L/2)\>\""}], "}"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
