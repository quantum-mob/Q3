Cell[TextData[{
 "Construct approximate density matrices, and calculate the ",
 ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity"],
 " (LN) between the subsystem and the rest."
}], "ExampleText",
 CellID->1198129299,ExpressionUUID->"67c83d08-4a9c-4591-9439-07bb50b0f358"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"Mean", "@", 
      RowBox[{"WickGreen", "[", "data", "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"neg", "=", 
