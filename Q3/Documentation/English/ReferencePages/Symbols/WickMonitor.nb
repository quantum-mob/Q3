Cell[BoxData[{
 RowBox[{
  RowBox[{"ham", "=", 
   RowBox[{"PlusTopple", "[", 
    RowBox[{
     RowBox[{"-", "$J"}], "*", 
     RowBox[{"One", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"$n", ",", "$n"}], "}"}], ",", "1"}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ham", "=", 
  RowBox[{"WickHermitian", "[", "ham", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ham", "//", "ArrayShort"}]}], "Input",
