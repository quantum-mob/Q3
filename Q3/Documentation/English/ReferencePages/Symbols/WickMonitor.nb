Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickMonitor"]], "paclet:QuantumMobQ3/ref/WickMonitor", 
         "QuantumMobQ3 Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1c5922e5-2d6e-4cb9-b7cc-5a5a0e92b34f"],
     "\[LineSeparator]solves the problem of continuous monitoring of a \
non-interacting many-fermion system by using the Monte Carlo simulation \
method. The model is specified by the single-particle Hamiltonian ",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ba9087c4-996d-4850-8e44-e1e4cc710211"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickHermitian"]], "paclet:QuantumMob/Q3/ref/WickHermitian",
         "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "205c968f-c7a5-4b50-b741-2f1b05acca46"],
     " form, and the dressed fermion modes the occupation numbers of which to \
be monitored are specified by measurement ",
     Cell[BoxData[
      StyleBox["msr", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f8691b05-669a-42d6-b97b-df2d5e6fc705"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/WickMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "b364294b-c3b6-47d7-b3d3-614fc000c52f"],
     " form. The simulation starts from the initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ae2303dc-c19a-45df-9169-655048beb51b"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickState"]], "paclet:QuantumMob/Q3/ref/WickState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "349b2fcd-7ce6-4137-b85c-9be0848841ce"],
     " form at time 0 and runs until time",
     Cell[BoxData[
      RowBox[{" ", 
       StyleBox["\[Tau]", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "dcc3806d-5586-4ea9-8bcf-8f5d01318fd8"],
     " in steps of size ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8ad9488b-9408-4220-b067-9feb651e91ba"],
     "."
    }],ExpressionUUID->"0849c7e6-0617-4ce2-a1be-1e719a849105"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickMonitor"]], "paclet:QuantumMob/Q3/ref/WickMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "2bd6dff4-4dd7-49a6-bd1e-e23aab775c3a"],
     "\[LineSeparator]continuously monitors all fermion modes, i.e., it is \
equivalent to ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickMonitor"]], "paclet:QuantumMob/Q3/ref/WickMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f86967df-d546-44fc-9d0b-b7b3589a40ec"],
     ", where ",
     Cell[BoxData[
      RowBox[{
       StyleBox["msr", "TI"], ":=", 
       RowBox[{
        TemplateBox[{
          Cell[
           TextData["WickMeasurement"]], 
          "paclet:QuantumMob/Q3/ref/WickMeasurement", 
          "QuantumMob Package Symbol"},
         "PackageLink",
         BaseStyle->"InlineFormula"], "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2", ",", 
           StyleBox["\[Ellipsis]", "TR"], ",", 
           StyleBox["n", "TI"]}], "}"}], ",", 
         StyleBox["n", "TI"]}], "]"}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6caa0849-eb91-4256-a309-62577b508d97"],
     "."
    }],ExpressionUUID->"424ea1e2-6326-4666-a19e-175b660d6e25"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickMonitor"]], "paclet:QuantumMob/Q3/ref/WickMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f5addf25-52ae-4799-9e1d-01d1c9b22965"],
     "\[LineSeparator]collects states in steps of ",
     Cell[BoxData[
      RowBox[{
       StyleBox["k", "TI"], "\[Times]", 
       StyleBox["dt", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "21772590-f6fa-4d27-a9f0-b297a4c16b8d"],
     " (rather than ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "54f5ff8b-d49a-464a-aaa1-4d9720d84101"],
     "), where ",
     Cell[BoxData[
      StyleBox["k", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a7ff5db4-a809-46ff-a31d-4e7505b60135"],
     " must be an integer or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["All"]], "paclet:ref/All"},
       "RefLink",
       BaseStyle->{"InlineFormula"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "af95410f-a3f2-404e-af4d-4cf34823e7d2"],
     "."
    }],ExpressionUUID->"438700a4-9105-45b6-bef3-ed57b92a2d17"]}
  }]], "Usage",
 CellID->1507093480,ExpressionUUID->"40c9b294-52fa-48e2-876d-989052045dc8"]
}, Open  ]],

