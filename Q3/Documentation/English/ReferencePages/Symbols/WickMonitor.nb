Cell[TextData[{
 "Solve the quantum master equation. Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WickLindbladSolve"]], 
    "paclet:QuantumMob/Q3/ref/WickLindbladSolve", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f78cb5ee-9260-48ba-b0e7-8bf5b3e8110f"],
 " returns a list of single-particle Green's function matrices describing the \
mixed state:"
}], "ExampleText",
 CellID->1236412438,ExpressionUUID->"95397e91-e7cf-474c-b3d9-d0fb2e0d675c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$dt", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"sol", "=", 
    RowBox[{"WickLindbladSolve", "[", 
     RowBox[{"ham", ",", 
      RowBox[{"WickJump", "@", "msr"}], ",", "in", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "$T", ",", "$dt"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->761185406,ExpressionUUID->"fa1016f8-935d-4f50-90a5-fa60ce4216e1"],

Cell[BoxData["0.103561`"], "EchoTiming",
 CellID->831750781,ExpressionUUID->"01691f70-c55c-4689-b53e-9443b324ca95"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"101", ",", "6", ",", "6"}], "}"}]], "Output",
 CellLabel->"Out[2]=",
 CellID->1264317944,ExpressionUUID->"c8a13916-6a11-4a28-9801-d0b127a9a550"]
}, Open  ]],

Cell["Calculate the logarithmic negativity from the solution:", "ExampleText",
 CellID->1298967641,ExpressionUUID->"61a6ce34-d622-46b5-9bac-32295cd24866"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"negSol", "=", 
    RowBox[{"WickLogarithmicNegativity", "[", 
     RowBox[{"sol", ",", "sub"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"negSol", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->2059064136,ExpressionUUID->"72f3ecd8-6e2a-4331-aff2-4c2a7431fe12"],

Cell[BoxData["0.006643`"], "EchoTiming",
 CellID->1854299561,ExpressionUUID->"8e657112-d947-47d5-af86-125765e68855"],

Cell[BoxData[
 RowBox[{"{", "101", "}"}]], "Output",
 CellLabel->"Out[3]=",
 CellID->930036463,ExpressionUUID->"0dc0cadd-079a-43be-9dd8-28c3a4e3ff31"]
}, Open  ]],

Cell["Plot it as a function of time:", "ExampleText",
