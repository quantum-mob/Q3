Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickMonitor"]], "paclet:QuantumMobQ3/ref/WickMonitor", 
         "QuantumMobQ3 Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6f8b9477-69bd-4e6d-82aa-d6e324e0edb0"],
     "\[LineSeparator]solves the problem of continuous monitoring of a \
non-interacting many-fermion system by using the Monte Carlo simulation \
method. The model is specified by the single-particle Hamiltonian ",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "b08ca455-9c47-47c4-804f-714637ca6b08"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickHermitian"]], "paclet:QuantumMob/Q3/ref/WickHermitian",
         "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "7c8ca0dd-d905-42b4-8e34-9b6a3d8a58f7"],
     " form, and the dressed fermion modes the occupation numbers of which to \
be monitored are specified by measurement ",
     Cell[BoxData[
      StyleBox["msr", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a2be8cf9-df70-4f10-ac0c-7bab94a8f2af"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/WickMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a898bd4f-0827-4f89-a14a-356fb2b1dcf1"],
     " form. The simulation starts from the initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "301e523c-9bb8-4759-b0d3-048acd94800d"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["WickState"]], "paclet:QuantumMob/Q3/ref/WickState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "7a7b2804-fcbc-4c89-b977-cdfe6cce3b74"],
     " form at time 0 and runs until time",
     Cell[BoxData[
      RowBox[{" ", 
       StyleBox["\[Tau]", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "68fff24d-7b6b-4535-a096-6647d740f8f4"],
     " in steps of size ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c93f817c-1d67-4eae-801b-b10ef83d22d1"],
     "."
    }],ExpressionUUID->"f1ac2658-4f13-4505-941b-0c92eedde7ba"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickMonitor"]], "paclet:QuantumMob/Q3/ref/WickMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "752991cc-da2d-4600-8589-3dc4d0685178"],
     "\[LineSeparator]continuously monitors all fermion modes, i.e., it is \
equivalent to ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickMonitor"]], "paclet:QuantumMob/Q3/ref/WickMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9ba705af-bcf5-411a-baef-2c5bd70cb3b6"],
     ", where ",
     Cell[BoxData[
      RowBox[{
       StyleBox["msr", "TI"], ":=", 
       RowBox[{
        TemplateBox[{
          Cell[
           TextData["WickMeasurement"]], 
          "paclet:QuantumMob/Q3/ref/WickMeasurement", 
          "QuantumMob Package Symbol"},
         "PackageLink",
         BaseStyle->"InlineFormula"], "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "2", ",", 
           StyleBox["\[Ellipsis]", "TR"], ",", 
           StyleBox["n", "TI"]}], "}"}], ",", 
         StyleBox["n", "TI"]}], "]"}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ce0c25eb-991d-4caf-8d25-99c5bb3c53d8"],
     "."
    }],ExpressionUUID->"4d56f505-8b5e-4e77-991c-7b11d8a0865e"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickMonitor"]], "paclet:QuantumMob/Q3/ref/WickMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8e411ce4-c69c-4ef8-9e98-75f8860ac94f"],
     "\[LineSeparator]collects states in steps of ",
     Cell[BoxData[
      RowBox[{
       StyleBox["k", "TI"], "\[Times]", 
       StyleBox["dt", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "2e91f7b1-5fdf-4e6d-97cf-e79a66b926cf"],
     " (rather than ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ea695fc7-b07e-4ac1-bea4-235880d26de7"],
     "), where ",
     Cell[BoxData[
      StyleBox["k", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c4bd3ff9-2e19-42c1-904e-9ff600eb757d"],
     " must be an integer or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["All"]], "paclet:ref/All"},
       "RefLink",
       BaseStyle->{"InlineFormula"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e7f2f3cd-d144-4f53-af40-730b19b0c227"],
     "."
    }],ExpressionUUID->"4a7e460e-9561-4a04-9de7-71607dc62509"]}
  }]], "Usage",
 CellID->1507093480,ExpressionUUID->"8a2581a0-be00-4a73-b844-a57272b49449"]
}, Open  ]],

