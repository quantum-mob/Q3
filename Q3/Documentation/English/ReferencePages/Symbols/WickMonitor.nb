Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$\[Gamma]", "=", "0.1"}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"monitoring", " ", "strength"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$g1", "=", 
   RowBox[{"1", "/", "$\[Gamma]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"$g2", "=", 
   RowBox[{"10.", "/", "$\[Gamma]"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->357294015,ExpressionUUID->"48652b35-e174-4a44-81a5-a528175a4b42"],

Cell["Construct the model:", "ExampleText",
 CellID->816451691,ExpressionUUID->"ea9ce291-61af-4b1e-9cfe-1849d2cf4ab3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SSH", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"g1_", ",", "g2_"}], "}"}], ",", "L_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", "ham", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ham", "=", 
      RowBox[{"PadRight", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"$g1", ",", "$g2"}], "}"}], ",", 
        RowBox[{"$L", "-", "1"}], ",", 
        RowBox[{"{", 
         RowBox[{"$g1", ",", "$g2"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ham", "=", 
      RowBox[{"PlusTopple", "@", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{
         RowBox[{"-", "ham"}], ",", "1"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"WickHermitian", "[", "ham", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->402231671,ExpressionUUID->"ad6c041c-3458-43a1-a8d7-198ed3dcad65"],

