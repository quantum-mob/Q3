                    ColumnSpacings -> 1, RowAlignments -> Baseline, 
                    ColumnAlignments -> Center], "\[NoBreak]", ")"}], 
                   Function[BoxForm`e$, 
                    MatrixForm[
                    SparseArray[
                    Automatic, {5, 5}, 0, {
                    1, {{0, 2, 4, 6, 8, 13}, {{1}, {5}, {2}, {5}, {3}, {5}, {
                    4}, {5}, {1}, {2}, {3}, {4}, {5}}}, {
                    1, "\[Ellipsis]", 1, "\[Ellipsis]", 1, "\[Ellipsis]", 1, 
