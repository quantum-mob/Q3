Cell["\<\
Do the simulation. Without specifying the measurement explicitly, all local \
fermion modes are monitored, and the monitoring rate \[Gamma] sets the unit \
of time:\
\>", "ExampleText",
 CellID->292350208,ExpressionUUID->"e833c4bc-05a5-40da-8f07-ed44e71eb686"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "377", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->576055336,ExpressionUUID->"f8a1a302-3bae-4c0b-84b5-4e4304777942"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$T", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$dt", "=", "0.001"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$ds", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$N", "=", "500"}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->1221011070,ExpressionUUID->"d9d4191f-9db8-4085-86db-198595578d65"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"WickMonitor", "[", 
     RowBox[{"in", ",", "ham", ",", 
      RowBox[{"{", 
       RowBox[{"$T", ",", "$dt", ",", "$ds"}], "}"}], ",", 
      RowBox[{"\"\<Samples\>\"", "->", "$N"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"data", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->1864141556,ExpressionUUID->"8031c9da-7e48-482d-9992-dbcb948ab6bb"],

Cell[BoxData["9.371858`"], "EchoTiming",
 CellID->941987902,ExpressionUUID->"56cfd0c7-f099-4a8e-b862-99548b89c92a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"500", ",", "101"}], "}"}]], "Output",
 CellLabel->"Out[8]=",
 CellID->741223230,ExpressionUUID->"7402addc-ce92-4216-a2b2-5ff2f152a8d7"]
}, Open  ]],

