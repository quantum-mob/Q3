Cell["\<\
Construct approximate density matrices by taking averages of the covariance \
matrices in different trajectories, and calculate the logarithmic negativity \
(LN) between the subsystem and the rest in the \[LineSeparator]density \
matrices:\
\>", "ExampleText",
 CellID->1243375267,ExpressionUUID->"e0ec7147-61ca-4f20-94f0-c56911cc7901"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"grn", "=", 
     RowBox[{"Mean", "@", 
      RowBox[{"WickGreen", "[", "data", "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"WickLogarithmicNegativity", "[", 
      RowBox[{"grn", ",", "sub"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->244743512,ExpressionUUID->"6b8ddbaf-5f92-45cf-be84-8ae232c0f3b7"],

Cell[BoxData["0.568849`"], "EchoTiming",
 CellID->1329076020,ExpressionUUID->"0150c5ed-cc45-4a60-8026-8f4f2506d738"]
}, Open  ]],

Cell["Check the logarithmic negativity as a function of time:", "ExampleText",
 CellID->495790548,ExpressionUUID->"8593e94b-6a6a-4149-8534-795d5b19e0c6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", "negRho"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
