Cell[BoxData[{
 RowBox[{
  RowBox[{"cff", "=", 
   RowBox[{
    RowBox[{"One", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], "]"}], "+", 
    RowBox[{"I", "*", 
     RowBox[{"One", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], ",", "1"}], 
      "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{"WickMeasurement", "@", 
    RowBox[{"Join", "[", 
     RowBox[{"cff", ",", 
      RowBox[{"Conjugate", "@", "cff"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "=", 
  RowBox[{"Normalize", "[", "msr", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"msr", "//", "MatrixForm"}]}], "Input",
