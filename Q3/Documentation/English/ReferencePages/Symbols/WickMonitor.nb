Cell[TextData[{
 "Solve the quantum master equation. Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WickLindbladSolve"]], 
    "paclet:QuantumMob/Q3/ref/WickLindbladSolve", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7fea400f-fa00-47c1-8c3f-2fb807dc4a3b"],
 " returns a list of single-particle Green's function matrices describing the \
mixed state:"
}], "ExampleText",
 CellID->1236412438,ExpressionUUID->"da2fa435-e3ff-4abd-8d8b-58f4f6478743"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$dt", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"sol", "=", 
    RowBox[{"WickLindbladSolve", "[", 
     RowBox[{"ham", ",", 
      RowBox[{"WickJump", "@", "msr"}], ",", "in", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "$T", ",", "$dt"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->761185406,ExpressionUUID->"dabecd34-c35d-4f0d-a27a-4d78f4b2098b"],

Cell[BoxData["0.103561`"], "EchoTiming",
 CellID->831750781,ExpressionUUID->"f25ab05e-788e-41df-9c8d-114f05188211"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"101", ",", "6", ",", "6"}], "}"}]], "Output",
 CellLabel->"Out[2]=",
 CellID->1264317944,ExpressionUUID->"aacd7130-e933-4480-8825-571866541712"]
}, Open  ]],

Cell["Calculate the logarithmic negativity from the solution:", "ExampleText",
 CellID->1298967641,ExpressionUUID->"9cf84479-ab7e-41eb-bc43-39d5990caf4d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"negSol", "=", 
    RowBox[{"WickLogarithmicNegativity", "[", 
     RowBox[{"sol", ",", "sub"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"negSol", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->2059064136,ExpressionUUID->"3270651d-f32b-4803-851c-aa878a0255c0"],

Cell[BoxData["0.006643`"], "EchoTiming",
 CellID->1854299561,ExpressionUUID->"4efe06b1-b4e3-4579-8e06-213c695b4663"],

Cell[BoxData[
 RowBox[{"{", "101", "}"}]], "Output",
 CellLabel->"Out[3]=",
 CellID->930036463,ExpressionUUID->"62b996c7-c68f-43c4-815b-7195b983fee8"]
}, Open  ]],

Cell["Plot it as a function of time:", "ExampleText",
 CellID->1705053772,ExpressionUUID->"e5ece01d-2942-40a3-84e5-90c5f4ed4bc1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", "negSol"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
