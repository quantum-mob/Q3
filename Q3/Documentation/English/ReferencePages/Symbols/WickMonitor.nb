Cell["\<\
Do the simulation. Without specifying the measurement explicitly, all local \
fermion modes are monitored, and the monitoring rate \[Gamma] sets the unit \
of time:\
\>", "ExampleText",
 CellID->292350208,ExpressionUUID->"4d1e7668-8325-4e49-8704-0ba003275c64"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "377", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->576055336,ExpressionUUID->"ad47fb12-8410-4e79-811b-b853b37d7e02"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$T", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$dt", "=", "0.001"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$ds", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$N", "=", "500"}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->1221011070,ExpressionUUID->"2115cc25-2657-429c-b5e4-6c3dd2bf9d6c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"WickMonitor", "[", 
     RowBox[{"in", ",", "ham", ",", 
      RowBox[{"{", 
       RowBox[{"$T", ",", "$dt", ",", "$ds"}], "}"}], ",", 
      RowBox[{"\"\<Samples\>\"", "->", "$N"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"data", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->1864141556,ExpressionUUID->"b2d327ad-5169-40ba-8014-1c971525929a"],

Cell[BoxData["9.371858`"], "EchoTiming",
 CellID->941987902,ExpressionUUID->"4d2a82a5-0a67-478a-87bd-7a779ca0633f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"500", ",", "101"}], "}"}]], "Output",
 CellLabel->"Out[8]=",
 CellID->741223230,ExpressionUUID->"609bd7ed-e397-481e-9376-cae89b4617e3"]
}, Open  ]],

