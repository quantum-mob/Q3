Cell[TextData[{
 "Solve the quantum master equation. Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WickLindbladSolve"]], 
    "paclet:QuantumMob/Q3/ref/WickLindbladSolve", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4394c2e4-5854-4786-ab77-0924a8e129b0"],
 " returns a list of single-particle Green's function matrices describing the \
mixed state:"
}], "ExampleText",
 CellID->945164349,ExpressionUUID->"98897752-b6b3-485d-9b4e-d52ad87d57fd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$dt", "=", "0.01"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"sol", "=", 
    RowBox[{"WickLindbladSolve", "[", 
     RowBox[{"ham", ",", "jmp", ",", "in", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "$T", ",", "$dt"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
