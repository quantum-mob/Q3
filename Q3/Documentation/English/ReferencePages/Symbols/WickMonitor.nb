Cell[TextData[{
 "Construct approximate density matrices, and calculate the ",
 ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity"],
 " (LN) between the subsystem and the rest."
}], "ExampleText",
 CellID->1198129299,ExpressionUUID->"927451a9-2b4b-4bb6-969b-5409e8fc7866"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"Mean", "@", 
      RowBox[{"WickGreen", "[", "data", "]"}]}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"neg", "=", 
     RowBox[{"WickLogarithmicNegativity", "[", 
      RowBox[{"avg", ",", "kk"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "neg", "]"}]}], "Input",
