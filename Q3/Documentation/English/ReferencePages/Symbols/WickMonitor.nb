Cell[TextData[{
 "Construct the quantum jump operators. (Note that we choose a unit system \
such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "874d3aee-012c-4031-ad0d-5411cf5d061b"],
 ". Note that the given coefficients are in the Dirac spinor space, i.e., \
they are the coefficients of Dirac fermion annihilation and creation \
operators. Make sure to normalize the measurement so that the monitoring rate \
\[Gamma] sets the unit of time:"
}], "ExampleText",
 CellID->1892269276,ExpressionUUID->"764d3763-28b7-4212-859c-956516d0222f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cff", "=", 
   RowBox[{
    RowBox[{"One", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], "]"}], "+", 
    RowBox[{"I", "*", 
     RowBox[{"One", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], ",", "1"}], 
      "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"msr", "=", 
   RowBox[{"WickMeasurement", "@", 
    RowBox[{"Join", "[", 
     RowBox[{"cff", ",", 
      RowBox[{"Conjugate", "@", "cff"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "=", 
  RowBox[{"Normalize", "[", "msr", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"msr", "//", "MatrixForm"}]}], "Input",
