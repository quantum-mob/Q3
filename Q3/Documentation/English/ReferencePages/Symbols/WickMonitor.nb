Cell["\<\
Calculate the logarithmic negativity (LN) between the subsystem and the rest:\
\
\>", "ExampleText",
 CellID->1308958114,ExpressionUUID->"1900225c-7f34-44ec-a27e-6ba47cd6a6e9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"Mean", "@", 
     RowBox[{"WickLogarithmicNegativity", "[", 
      RowBox[{"data", ",", "sub"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
