Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$\[Gamma]", "=", "0.1"}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"monitoring", " ", "strength"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$g1", "=", 
   RowBox[{"1", "/", "$\[Gamma]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"$g2", "=", 
   RowBox[{"10.", "/", "$\[Gamma]"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->357294015,ExpressionUUID->"0c3820df-9370-4d77-ae60-7d2b6e09f709"],

Cell["Construct the model:", "ExampleText",
 CellID->816451691,ExpressionUUID->"383cc890-98a4-4ae3-b2c7-bb7e9ae4f75b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SSH", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"g1_", ",", "g2_"}], "}"}], ",", "L_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", "ham", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ham", "=", 
      RowBox[{"PadRight", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"$g1", ",", "$g2"}], "}"}], ",", 
        RowBox[{"$L", "-", "1"}], ",", 
        RowBox[{"{", 
         RowBox[{"$g1", ",", "$g2"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ham", "=", 
      RowBox[{"PlusTopple", "@", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{
         RowBox[{"-", "ham"}], ",", "1"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"WickHermitian", "[", "ham", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->402231671,ExpressionUUID->"553296fb-b9a2-4581-bdcf-9410f76a433a"],

