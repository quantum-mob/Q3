Cell["\<\
Note that if the number of independent stabilizer generators is strictly \
smaller than the number of qubits, then the stabilizer state is a mixed state.\
\>", "Notes",
 CellID->1972900666,ExpressionUUID->"b0bd77cb-5e75-4fd0-a862-3264b91618e6"]
