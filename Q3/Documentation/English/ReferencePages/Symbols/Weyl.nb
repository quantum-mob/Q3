Cell[TextData[{
 "Consider  a system of ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "88515c86-f3e5-4448-9083-1ce28467ade7"],
 "-level quantum system (i.e., a ",
 ButtonBox["qudit",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Qudit"],
 "). The canonical basis of its Hilbert space is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], ",", 
     TemplateBox[{"1"},
      "Ket"], ",", 
     TemplateBox[{"2"},
      "Ket"], ",", "\[Ellipsis]", ",", 
     TemplateBox[{
       RowBox[{"d", "-", "1"}]},
      "Ket"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "2bc58cee-75a9-4730-9fd9-8c2125d423db"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":", 
    RowBox[{
     TemplateBox[{"z"},
      "Ket"], "\[RightTeeArrow]", 
     RowBox[{
      TemplateBox[{"z"},
       "Ket"], 
      SuperscriptBox["\[Omega]", "z"]}]}]}], TraditionalForm]],ExpressionUUID->
  "e25785f9-cf92-4eee-b430-139ec3840ccb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", ":", 
    RowBox[{
     TemplateBox[{"z"},
      "Ket"], "\[RightTeeArrow]", 
     TemplateBox[{
       RowBox[{"z", "+", "1"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "02d9f1b1-3d75-4c2e-8e44-edee145478f9"],
 " be the ",
 StyleBox["generalized Pauli operators",
  FontSlant->"Italic"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"z", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"d", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "3cc61c4d-82f9-46ff-a2a5-24d4f23973f8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{"2", "\[Pi]", " ", 
      RowBox[{"\[ImaginaryI]", "/", "d"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ae63f117-814f-443a-b6ab-561b65996c39"],
 ". Then, the ",
 StyleBox["Weyl-Heisenberg basis",
  FontSlant->"Italic"],
 " is the generating set of the ",
 StyleBox["generalized Pauli group",
  FontSlant->"Italic"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalP]", "d"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Omega]", "c"], " ", 
       SuperscriptBox["X", "a"], 
       RowBox[{
        SuperscriptBox["Z", "b"], ":", "a"}]}], ",", "b", ",", 
      RowBox[{"c", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{"d", "-", "1"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "e413618f-6f85-4cf4-aca0-9263bb28b20d"],
 "."
}], "Notes",
 CellID->1882381721,ExpressionUUID->"fb71b5c1-181f-43c1-8eee-7b399d2329e2"],

Cell[TextData[{
 "Note that the generalized Pauli operators ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "23e1b991-8271-4d2b-9476-337715b665d9"],
 " and ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "da70cd60-6f2c-4d2e-b4f7-d7999a00ae56"],
 " satisfy the Wey-Heisenberg commutation relation\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Z", " ", "X"}], "=", 
    RowBox[{"\[Omega]", " ", "X", " ", "Z"}]}], TraditionalForm]],
  ExpressionUUID->"35a8be2d-dd3f-4d55-b5af-7f610450237e"],
 "."
}], "Notes",
 CellID->770267794,ExpressionUUID->"f9c4ac93-dacf-4af9-ac4b-b461c2001601"],

Cell[TextData[{
 "The ",
 StyleBox["Weyl-Heisenberg group",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "of odd degree",
 " ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dcdbff79-c73c-49a1-99b0-ac1d7536ae74"],
 " coincides with the generalized Pauli group, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalH]", "d"], ":=", 
    SubscriptBox["\[ScriptCapitalP]", "d"]}], TraditionalForm]],
  ExpressionUUID->"32208cc4-da91-4e33-88c1-e44f8da7c716"],
 "."
}], "Notes",
 CellID->1802696894,ExpressionUUID->"ae87f4ab-6e8d-4552-904e-bbd45b1f4c5a"],

Cell[TextData[{
 "The ",
 StyleBox["Weyl-Heisenberg group ",
  FontSlant->"Italic"],
 "of even degree",
 StyleBox[" ",
  FontSlant->"Italic"],
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f3fde02a-85d4-4fbf-b9af-8c077ab98ca1"],
 " is achieved by doubling the generalized Pauli group, that is,\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalH]", "d"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Tau]", "c"], 
       SuperscriptBox["X", "a"], 
       RowBox[{
        SuperscriptBox["Z", "b"], ":", "a"}]}], ",", "b", ",", 
      RowBox[{"c", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{"d", "-", "1"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "460bc3a0-72a2-4f57-a2c5-31500b3198c6"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", ":=", 
    RowBox[{
     RowBox[{"-", 
      SqrtBox["\[Omega]"]}], "=", 
     RowBox[{"-", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Pi]", " ", 
        RowBox[{"\[ImaginaryI]", "/", "d"}]}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"163dd1e2-e2a1-4801-acea-f2526e55f06d"],
 "."
}], "Notes",
 CellID->1542982260,ExpressionUUID->"25da9654-fcf4-40b9-b396-cdf83c812fe1"],

Cell[TextData[{
 "The ",
 StyleBox["Clifford group",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalC]", "d"], TraditionalForm]],ExpressionUUID->
  "a5d9b97f-e239-4b87-b244-3b80aac8e0da"],
 " is the normalizer of the Weyl-Heisenberg group in the unitary group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalU]", "(", "d", ")"}], TraditionalForm]],
  ExpressionUUID->"beae89ed-4ee4-41d1-80f8-22d80ea1b09d"],
 ". The doubling in the above definition of Weyl-Heisenberg group is required \
because additional phase factors emerge in the Clifford group."
}], "Notes",
 CellID->976052040,ExpressionUUID->"8fe96d5c-3b33-4f65-82f8-a1ac13426d36"],

Cell[TextData[{
 "The Weyl-Heisenberg basis satisfies the following convention:\
\[LineSeparator]- It is ",
 StyleBox["orthonormal",
  FontSlant->"Italic"],
 " (normalized to ",
 StyleBox["d",
  FontSlant->"Italic"],
 ") with respect to the ",
 ButtonBox["Hilbert-Schmidt inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/HilbertSchmidtProduct"],
 " or ",
 ButtonBox["Frobenius inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FrobeniusProduct"],
 ".\[LineSeparator]- The first element is identical to the identity matrix. \
The rest are all ",
 StyleBox["traceless",
  FontSlant->"Italic"],
 ".\[LineSeparator]- All elements are ",
 StyleBox["unitary",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1752261046,ExpressionUUID->"314a06f7-5bd8-4373-8ed0-d647bd9b6b55"],

Cell["\<\
For more properties of the Weyl-Heisenberg basis, see Gottesman, Kitaev, and \
Preskill (2001), Wolf (2003), and Tolar (2018).\
\>", "Notes",
 CellID->1900252760,ExpressionUUID->"15c8b1ee-5fb8-4c95-a320-b6391e4c1cba"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
