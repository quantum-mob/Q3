Cell[TextData[{
 "The Lyapunov differential equation \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "X"}], 
     RowBox[{"d", " ", "t"}]], "=", 
    RowBox[{
     RowBox[{"A", "\[VeryThinSpace]", "X"}], "+", 
     RowBox[{"X", "\[VeryThinSpace]", 
      SuperscriptBox["A", "\[Dagger]"]}], "+", "C"}]}], TraditionalForm]],
  ExpressionUUID->"8eee31a3-3edb-4144-8991-81e672426073"],
 " ,\[LineSeparator]has the solution of the form\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"X", "(", "t", ")"}], "=", 
    RowBox[{
     SubscriptBox["X", "s"], "+", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"A", "\[VeryThinSpace]", "t"}]], "[", 
       RowBox[{
        RowBox[{"X", "(", "0", ")"}], "-", 
        SubscriptBox["X", "s"]}], "]"}], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        SuperscriptBox["A", "\[Dagger]"], "t"}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"9edff163-8cf6-4eb2-a940-f98e83db1c31"],
 ", \nwhere ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["X", "s"], TraditionalForm]],ExpressionUUID->
  "e1abc275-d2c2-446d-8c11-f3461069634a"],
 " is the solution of the Lyapunov equation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"A", " ", 
      SubscriptBox["X", "s"]}], "+", 
     RowBox[{
      SubscriptBox["X", "s"], 
      SuperscriptBox["A", "\[Dagger]"]}], "+", "C"}], "==", "0"}], 
   TraditionalForm]],ExpressionUUID->"ee5e430f-8503-4beb-aa21-b118ae123a88"],
 "."
}], "Notes",
 CellID->810483824,ExpressionUUID->"7436052b-8062-4bcd-8171-bd2f40bde26e"],

