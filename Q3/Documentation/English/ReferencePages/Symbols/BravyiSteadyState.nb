Cell["\<\
Let us check the above result by solving the Lindblad equation and taking the \
long-time limit.\
\>", "ExampleText",
 CellID->1177689872,ExpressionUUID->"b616299e-3911-4332-9919-4d544e5fad22"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$T", "=", "10"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1518350056,ExpressionUUID->"13b62253-6cbe-4966-8ed2-7627c3359ca5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"BravyiLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "$T", ",", 
       RowBox[{"$T", "/", "200."}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1775080869,ExpressionUUID->"9aab42b8-2f35-4fe1-a0d1-36932b3eddf5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cvrList", "=", 
   RowBox[{"BravyiCovariance", "/@", "out"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1785864684,ExpressionUUID->"064c5463-e623-4ee2-bf57-6e9475bba925"],

Cell[BoxData[
 RowBox[{
  RowBox[{"currentList", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", "@", 
       RowBox[{"Diagonal", "[", 
        RowBox[{
         RowBox[{"First", "@", "#"}], ",", 
         RowBox[{"-", "2"}]}], "]"}]}], "&"}], ",", "cvrList"}], "]"}]}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1796293516,ExpressionUUID->"008e21c7-fe65-44a0-a769-3cf0099586b7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListPlot", "[", 
  RowBox[{"currentList", ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma] t\>\"", ",", "\"\<current\>\""}], "}"}]}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
