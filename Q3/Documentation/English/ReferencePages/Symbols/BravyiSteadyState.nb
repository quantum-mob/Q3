Cell["\<\
Let us check the above result by solving the Lindblad equation and taking the \
long-time limit.\
\>", "ExampleText",
 CellID->653092669,ExpressionUUID->"a98048a9-fe34-4236-a2c3-0d5f2de563d2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$T", "=", "20"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->739568066,ExpressionUUID->"4f7fd94a-2171-4ff8-86a1-802f141c8b11"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"out", "=", 
    RowBox[{"BravyiLindbladSolve", "[", 
     RowBox[{"ham", ",", "msr", ",", "in", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "$T", ",", 
        RowBox[{"$T", "/", "400."}]}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->285136426,ExpressionUUID->"9d4a9593-0a34-4b3e-a7bc-6656b63e85b6"],

Cell[BoxData["5.035502`"], "EchoTiming",
 CellID->1717289262,ExpressionUUID->"5d6049c5-621a-44f8-a2f8-3f2106a347f9"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"cvrList", "=", 
   RowBox[{"BravyiCovariance", "/@", "out"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1251895325,ExpressionUUID->"f36201f9-da46-469c-b0b0-f59cd18f388e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"currentList", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", "@", 
       RowBox[{"Diagonal", "[", 
        RowBox[{
         RowBox[{"First", "@", "#"}], ",", 
         RowBox[{"-", "2"}]}], "]"}]}], "&"}], ",", "cvrList"}], "]"}]}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1707437616,ExpressionUUID->"3be38d3c-0612-44d6-bb35-5a4ae093986a"],

