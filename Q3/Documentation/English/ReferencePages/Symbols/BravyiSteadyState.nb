Cell["Calculate the current in the steady state:", "ExampleText",
 CellID->1563410190,ExpressionUUID->"b76dcf92-d035-4de0-a79a-8b8ac39eefc5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"current", "=", 
  RowBox[{"Total", "@", 
   RowBox[{"Diagonal", "[", 
    RowBox[{
     RowBox[{"First", "@", "cvr"}], ",", 
     RowBox[{"-", "2"}]}], "]"}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->446542628,ExpressionUUID->"fe1b7fd7-819d-4f50-a009-eac91854bf8e"],

Cell[BoxData["8.160684549844218`"], "Output",
 CellLabel->"Out[8]=",
 CellID->1262755050,ExpressionUUID->"59cce4af-c949-4c2a-b19d-0e3bcbf0c850"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "\t", "ExampleDelimiter",ExpressionUUID->
   "e7c103bd-147e-4474-ac51-cad2601bd297"],
  $Line = 0; Null]], "ExampleDelimiter",
