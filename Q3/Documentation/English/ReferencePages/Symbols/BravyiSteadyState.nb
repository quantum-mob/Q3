Cell["\<\
Let us check the above result by solving the Lindblad equation and taking the \
long-time limit.\
\>", "ExampleText",
 CellID->1510680719,ExpressionUUID->"744a80a7-178c-4d4c-833e-23bf6903a44d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"BravyiLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"$T", "=", "5"}], ",", "0.01"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->767105126,ExpressionUUID->"cb1a150b-296f-4688-9d25-92e2d1d5d916"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cvr", "=", 
   RowBox[{"BravyiCovariance", "/@", "out"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->348553424,ExpressionUUID->"c742651d-47d0-499b-8fc0-6b44371935b0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"current", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", "@", 
       RowBox[{"Diagonal", "[", 
        RowBox[{
         RowBox[{"First", "@", "#"}], ",", 
         RowBox[{"-", "2"}]}], "]"}]}], "&"}], ",", "cvr"}], "]"}]}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1656351262,ExpressionUUID->"5b00b8d9-f332-46fa-b71f-2f36ed878120"],

Cell[CellGroupData[{

