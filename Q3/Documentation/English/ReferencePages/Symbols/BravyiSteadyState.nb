Cell["Calculate the current:", "ExampleText",
 CellID->1999936812,ExpressionUUID->"2ff90660-4905-4c40-be9a-f9b7c08eafee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Total", "@", 
  RowBox[{"Diagonal", "[", 
   RowBox[{
    RowBox[{"First", "@", 
     RowBox[{"BravyiCovariance", "@", "steady"}]}], ",", 
    RowBox[{"-", "2"}]}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->1486245403,ExpressionUUID->"d2635e3f-8f1e-434e-b52b-63942e898df4"],

Cell[BoxData[
 RowBox[{"-", "0.5217265596841825`"}]], "Output",
 CellLabel->"Out[7]=",
