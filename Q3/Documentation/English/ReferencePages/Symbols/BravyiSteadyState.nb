Cell["Calculate the current in the steady state:", "ExampleText",
 CellID->1250227089,ExpressionUUID->"d9cb8061-43a4-407f-adec-533329306fde"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"current", "=", 
  RowBox[{
   RowBox[{"Total", "@", 
    RowBox[{"Diagonal", "[", 
     RowBox[{
      RowBox[{"First", "@", "cvr"}], ",", 
      RowBox[{"-", "2"}]}], "]"}]}], "//", "Chop"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->1586682575,ExpressionUUID->"940781bf-07bd-4e8a-a2e9-36a8f119d000"],

