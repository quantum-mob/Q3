Cell[BoxData[
 RowBox[{
  RowBox[{"$L", "=", "12"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->171829249,ExpressionUUID->"2bb493c3-e975-4310-b781-b7bfd3e19ea8"],

Cell[TextData[{
 "Define the ",
 StyleBox["Hatano",
  IgnoreSpellCheck->True],
 "-Nelson model:"
}], "ExampleText",
 CellID->1651747518,ExpressionUUID->"a3cb7612-73be-4b39-a11c-c94301348582"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "HatanoNelsonModel", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"HatanoNelsonModel", "[", 
   RowBox[{"J_", ",", "\[Gamma]_", ",", "L_Integer"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ham", ",", "cff", ",", "jmp"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ham", "=", 
      RowBox[{"PlusTopple", "[", 
       RowBox[{
        RowBox[{"-", "J"}], "*", 
        RowBox[{"One", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"L", ",", "L"}], "}"}], ",", "1"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ham", "=", 
      RowBox[{"BravyiHermitian", "[", 
       RowBox[{"NambuHermitian", "@", 
        RowBox[{"{", 
         RowBox[{"ham", ",", "0"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"cff", "=", 
      RowBox[{
       RowBox[{"One", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], "]"}], "+", 
       RowBox[{"I", "*", 
        RowBox[{"One", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], ",", "1"}], 
         "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"cff", "=", 
      RowBox[{"ArrayFlatten", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"cff", ",", "0"}], "}"}], ",", 
