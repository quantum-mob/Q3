Cell[TextData[{
 "It merely provides a shortcut tool for convenience as most calculations in \
fermionic quantum computing are based on ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " operators for efficiency while sometimes the ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " representation is more intuitive."
}], "Notes",
 CellID->1899870126,ExpressionUUID->"f5ac788e-ffc3-4cec-b3bb-a89a6b8bf748"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["NambuMeasurement"]], 
     "paclet:QuantumMob/Q3/ref/NambuMeasurement", "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "655ef135-795f-47f5-9565-4011e551be6d"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMeasurement"]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["alt", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5e89972f-423a-48f7-8f08-f4294165b731"],
 " are equivalent if the two matrices ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4dc73196-87ab-432d-9b1e-4306c851cd22"],
 " and ",
 Cell[BoxData[
  StyleBox["alt", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "120c75a5-4a0c-4819-9a68-025e3d5d5057"],
 " are related to each other by the row-wise transformation ",
 Cell[BoxData[
  RowBox[{
   StyleBox["alt", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Map"]], "paclet:ref/Map"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["ToMajorana"]], "paclet:QuantumMob/Q3/ref/ToMajorana", 
       "QuantumMob Package Symbol"},
      "PackageLink",
      BaseStyle->"InlineFormula"], ",", 
     StyleBox["mat", "TI"]}], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8c6b62bc-c4ea-4fb3-b5fa-742316bc4d56"],
 "."
}], "Notes",
 CellID->549666525,ExpressionUUID->"584e13e7-8fb6-4d31-8c48-b76eda7ce0f3"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Normalize"]], "paclet:ref/Normalize"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"NambuMeasurement", "[", 
    TemplateBox[{
      Cell[
       TextData["m"]], "paclet:QuantumMob/Q3/ref/m"},
     "RefLink",
     BaseStyle->{"InlineFormula", "TI"}], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "946ff9b5-6a6a-4051-84de-d81c8f1c400e"],
 " normalizes each row ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["m", "TI"], 
    StyleBox["i", "TI"]], ":=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["u", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["1", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["u", "TI"], 
      StyleBox["in", "TI"]], ",", 
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["1", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["in", "TI"]]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "133d2a91-6368-47b6-86e9-717b399b04a4"],
 " of matrix ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "71c3fc31-796d-473c-a846-f35e16ccdf37"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"], "=", 
    "1"}], TraditionalForm]],ExpressionUUID->
  "bd9a8cb2-eaa5-4b50-9e78-d81f140c5aaa"],
 ", so that the corresponding dressed Dirac fermion mode\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "=", "1"}], "n"], "(", 
     RowBox[{
      RowBox[{
       SubscriptBox["u", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["a", "i"]}], "+", 
      RowBox[{
       SubscriptBox["v", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubsuperscriptBox["a", "j", "\[Dagger]"]}]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"11e49376-822c-4321-8102-6bbc175702d8"],
 " \[LineSeparator]is properly normalized normalized, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["b", "i"], ",", 
      SubsuperscriptBox["b", "i", "\[Dagger]"]}], "}"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"8fcfa967-a135-4292-9799-346dd53e7afc"],
 "."
}], "Notes",
 CellID->954089641,ExpressionUUID->"e94a416d-bd84-43ea-a6dd-1b9bb5c92ddd"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

