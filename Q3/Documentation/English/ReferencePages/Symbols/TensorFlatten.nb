Cell[TextData[{
 "Let us first consider the case with an odd number of sub-dimensions. ",
 Cell[BoxData["TensorFlatten"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ff97b674-f8af-46f4-880d-6acce4740916"],
 " flattens out the tensor to get a matrix. In the process, the tensor \
structure is lost."
}], "ExampleText",
 CellID->1245097396,ExpressionUUID->"ba0ab300-58ab-4e8d-9afd-4deda5e76a12"],

