Cell[TextData[{
 "The canonical coding in the standard ordered generating system (OGS) for \
the symmetric group of degree ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "876151f1-5d23-4fda-9f0d-eba6b22d14a1"],
 " is a map ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[Element]", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalS]", "n"], "\[RightTeeArrow]", 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["m", "2"], ",", 
       SubscriptBox["m", "3"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["m", "n"]}], ")"}]}], "\[Element]", 
    RowBox[{
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"], "\[Times]", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"], "\[Times]", "\[Ellipsis]", 
     "\[Times]", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "n"]}]}], TraditionalForm]],
  ExpressionUUID->"a3eee237-8667-453a-9eab-ff7a51b76082"],
 " such that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "=", 
    RowBox[{
     SubsuperscriptBox["c", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", "n"}]}], "}"}], 
      SubscriptBox["m", "n"]], 
     SubsuperscriptBox["\[Ellipsis]c", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", ",", "2", ",", "3"}]}], "}"}], 
      SubscriptBox["m", "3"]], 
     SubsuperscriptBox["c", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", ",", "2"}]}], "}"}], 
      SubscriptBox["m", "2"]]}]}], TraditionalForm]],ExpressionUUID->
  "582fa5f5-b1df-4e50-a422-8a9be8f06ebe"],
 " ."
}], "Notes",
 CellID->846140678,ExpressionUUID->"7cbcc5d4-3c3d-41ef-986c-b3d7f184140d"],

Cell[TextData[{
 "Given ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[Element]", 
    SubscriptBox["\[ScriptCapitalS]", "n"]}], TraditionalForm]],
  ExpressionUUID->"bed75e7d-9805-4a9c-8b06-b4ac3b060af9"],
 " and corresponding sequence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["m", "2"], ",", 
     SubscriptBox["m", "3"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["m", "n"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "5d4a27fe-b101-48cb-8f83-0ccaad8c61db"],
 ", define a number ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "1fd48304-ddb2-4baa-a284-d7007cc72bac"],
 " by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "2"}], "n"], 
     SubscriptBox["m", "k"], " ", 
     FractionBox[
      RowBox[{"n", "!"}], 
      RowBox[{"k", "!"}]], " "}]}], TraditionalForm]],ExpressionUUID->
  "58dbb866-47d3-4ef0-942f-0215b7535b13"],
 ".\[LineSeparator]This establishes a one-to-one correspondence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "\[RightTeeArrow]", "m"}], "\[Element]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{"n", "!"}], "-", "1"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"52148033-06ad-4f63-9768-44b3486bfc7f"],
 "."
}], "Notes",
 CellID->824630816,ExpressionUUID->"816878ac-0ad4-4bb5-b9af-be804f502ef3"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

