Cell["Here is a similar example for a multi-qubit operator.", "ExampleText",
 CellID->650491824,ExpressionUUID->"7b9aeae0-c6b7-42cb-bcd8-5d6ce074c152"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"op", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pauli", "[", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3"}], "}"}], "]"}], "+", 
      RowBox[{"I", "*", 
       RowBox[{"Pauli", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0"}], "}"}], "]"}]}], "-", 
      RowBox[{"Pauli", "[", 
       RowBox[{"{", 
        RowBox[{"3", ",", "1"}], "}"}], "]"}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}], "//", "Garner"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1989428997,ExpressionUUID->"9c5ebee8-1f34-4486-8803-3e9030258845"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{"\<\"X\"\>", "\[CircleTimes]", "\<\"I\"\>"}],
     QuantumMob`Q3`Pauli[{1, 0}]]}], 
   SqrtBox["2"]], "+", 
  FractionBox[
   InterpretationBox[
    RowBox[{"\<\"Y\"\>", "\[CircleTimes]", "\<\"Z\"\>"}],
    QuantumMob`Q3`Pauli[{2, 3}]], 
   SqrtBox["2"]], "-", 
