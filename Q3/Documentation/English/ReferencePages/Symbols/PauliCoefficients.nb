Cell[TextData[{
 "The set of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", "n"], "\[CircleTimes]", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "95801c26-b814-4732-ba92-78dc61c550c6"],
 " complex matrices may be regarded as a vector space, and the set of Pauli \
strings of length ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "1db13ba2-5428-4e1a-8a3e-3990fb226758"],
 " is an orthogonal basis of it. That is, any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", "n"], "\[CircleTimes]", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "4c7918d2-cea1-4dd0-a43d-e38dd4cbea48"],
 " complex matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "75465327-e478-4d86-9dd3-73e98b10f74a"],
 " may be expanded in the tensor products of Pauli matrices ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "e43788cd-3b77-4845-ac77-c9759a269b5e"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["\[Mu]", "1"], "=", "0"}], "3"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["\[Mu]", "2"], "=", "0"}], "3"], "\[Ellipsis]", 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["\[Mu]", "n"], "=", "0"}], "3"], 
     SubscriptBox["c", 
      RowBox[{
       SubscriptBox["\[Mu]", "1"], 
       SubscriptBox["\[Mu]", "2"], 
       SubscriptBox["\[Ellipsis]\[Mu]", "n"]}]], 
     RowBox[{
      SubscriptBox["P", 
       SubscriptBox["\[Mu]", "1"]], "\[CircleTimes]", 
      SubscriptBox["P", 
       SubscriptBox["\[Mu]", "2"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
      SubscriptBox["P", 
       SubscriptBox["\[Mu]", "n"]]}]}]}], TraditionalForm]],ExpressionUUID->
  "261e8104-3e3b-435b-b61b-87d8ec7ec7c3"],
 " ,\[LineSeparator]where the complex coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     SubscriptBox["\[Mu]", "1"], 
     SubscriptBox["\[Mu]", "2"], 
     SubscriptBox["\[Ellipsis]\[Mu]", "n"]}]], TraditionalForm]],
  ExpressionUUID->"b7ab0e44-fee5-48e9-938e-e9555a4b2f53"],
 " may be determined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], 
      SubscriptBox["\[Mu]", "2"], 
      SubscriptBox["\[Ellipsis]\[Mu]", "n"]}]], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", "n"]], 
     RowBox[{"Tr", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["P", 
          SubscriptBox["\[Mu]", "1"]], "\[CircleTimes]", 
         SubscriptBox["P", 
          SubscriptBox["\[Mu]", "2"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
         SubscriptBox["P", 
          SubscriptBox["\[Mu]", "n"]]}], ")"}], "M"}], "]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"ad9b448d-ea93-4c04-bf55-34a1dc6aba73"],
 " ."
}], "Notes",
 CellID->770489137,ExpressionUUID->"74147274-c697-484e-b881-f6d3d06dcc7c"],

