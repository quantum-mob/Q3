Cell[TextData[{
 "The ",
 StyleBox["Jordan-Wigner transform",
  FontSlant->"Italic"],
 " maps spin operators onto Fermionic operators and vice versa."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"e98f5293-17ec-4a54-b876-c5060de4c325"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["JordanWignerTransform"]], 
     "paclet:QuantumMob/Q3/ref/JordanWignerTransform", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5a360e20-f961-476f-a635-2040c7305029"],
 " returns the list of matrices corresponding to the Jordan-Wigner transform:\
\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "k"], "\[RightArrow]", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"k", "-", "1"}]], 
     RowBox[{
      SubsuperscriptBox["\[Sigma]", "i", "z"], " ", 
      SubsuperscriptBox["\[Sigma]", "k", "+"]}]}]}], TraditionalForm]],
  ExpressionUUID->"0ffca0b7-e231-44d5-835a-99848c9258f4"],
 " ,\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["c", "k", "\[Dagger]"], 
     SubscriptBox["c", "k"]}], "\[RightTeeArrow]", 
    RowBox[{
     FractionBox["1", "2"], "-", 
     SubsuperscriptBox["\[Sigma]", "k", "z"]}]}], TraditionalForm]],
  ExpressionUUID->"23bdc0d9-d55d-4774-b137-38d1bed86d15"],
 " ."
}], "Notes",
 CellID->1037583909,ExpressionUUID->"e878c3f2-0afb-4a57-ae50-acb89f0ba723"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

