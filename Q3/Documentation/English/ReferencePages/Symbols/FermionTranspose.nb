  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Dagger", "[", 
        RowBox[{"f", "[", "1", "]"}], "]"}], "**", 
       RowBox[{"Dagger", "[", 
        RowBox[{"f", "[", "2", "]"}], "]"}], "**", 
       RowBox[{"Ket", "[", "]"}]}], "+", 
      RowBox[{"a", "*", 
       RowBox[{"Ket", "[", "]"}]}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", 
