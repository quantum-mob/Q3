Cell[TextData[{
 "Suppose that the system consists of two parts ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "c1f37ae2-6fde-4af4-8b32-5d5f02a8e4c3"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "56dd505d-e8e0-46d1-bc00-c2be578227c8"],
 ". The ",
 StyleBox["fermionic partial transposition",
  FontSlant->"Italic"],
 " with respect to part ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b0ba3b1a-345d-44aa-8691-eaad57cc60a0"],
 " is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["c", 
     SubscriptBox["T", "A"]], ":=", 
    TagBox[GridBox[{
       {"\[Piecewise]", GridBox[{
          {
           RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "c"}], 
           RowBox[{"c", "\[Element]", "A"}]},
          {"c", 
           RowBox[{"c", "\[NotElement]", "A"}]}
         },
         AllowedDimensions->{2, Automatic},
         Editable->True,
         GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
         GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
         GridBoxSpacings->{"Columns" -> {
             Offset[0.27999999999999997`], {
              Offset[0.84]}, 
             Offset[0.27999999999999997`]}, "Rows" -> {
             Offset[0.2], {
              Offset[0.4]}, 
             Offset[0.2]}},
         Selectable->True]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
      GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.35]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}],
     "Piecewise",
     DeleteWithContents->True,
     Editable->False,
     SelectWithContents->True,
     Selectable->False,
     StripWrapperBoxes->True]}], TraditionalForm]],ExpressionUUID->
  "52ad6356-2b51-4696-9ca0-fb05174fb392"],
 " \[LineSeparator]on Majorana operator ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]],ExpressionUUID->
  "47963928-0353-418c-b231-2c64e2da50d6"],
 "."
}], "Notes",
 CellID->2052893415,ExpressionUUID->"af820a89-b574-4ff7-87de-c3c2065ec022"],

Cell[TextData[{
 "For two arbitrary operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "1"], TraditionalForm]],ExpressionUUID->
  "d422a37f-1ea8-43ad-9924-08fc1bafa870"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "2"], TraditionalForm]],ExpressionUUID->
  "392fc1bf-52e7-4818-b674-e4a272247508"],
 " on the Hilbert space ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "8032d48c-457f-4a84-a65f-ae32426c5553"],
 ", \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["O", "1"], 
       SubscriptBox["O", "2"]}], ")"}], 
     SubscriptBox["T", "A"]], ":=", 
    RowBox[{
     SubsuperscriptBox["O", "1", 
      SubscriptBox["T", "A"]], 
     SubsuperscriptBox["O", "2", 
      SubscriptBox["T", "A"]]}]}], TraditionalForm]],ExpressionUUID->
  "9299d308-4856-4a70-bcf2-75e22a84f622"],
 ".\[LineSeparator]Note that unlike matrix transpose, there is ",
 StyleBox["no",
  FontSlant->"Italic"],
 " reversed ordering."
}], "Notes",
