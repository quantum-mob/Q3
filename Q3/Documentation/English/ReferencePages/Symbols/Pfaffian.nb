     "a09341ac-2bd1-4deb-bae9-d47ff424605b"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "e758868a-799c-46ad-9dc1-c76324b8c4fd"], 
    TemplateBox[{
