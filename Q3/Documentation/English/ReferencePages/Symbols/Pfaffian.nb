Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "2ef82795-5a2b-4969-9e8b-20b6e5f9adf8"],
 " and ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "93ce2973-c5c3-4b0f-99bd-0c3bed227967"],
 " be ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "6e41ca11-f056-43c2-806f-1de784eb55ed"],
 " anti-symmetric matrices, and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "afc907f6-2442-43c5-81a8-8f65d444d4ea"],
 " be an arbitrary ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "7ebf3abe-4ff9-42aa-bc00-67e573b9d7b1"],
 " matrix. Consider a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "04a0aca9-9836-4580-b6f4-ef993bacb5f2"],
 " block matrix of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", ":=", 
    RowBox[{"(", GridBox[{
       {"A", "B"},
       {
        RowBox[{"-", 
         SuperscriptBox["B", "T"]}], "D"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8dfa37f8-cca4-44da-b40e-2e9a6aee42df"],
 ".\[LineSeparator]If ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "8bf47841-bdc2-4bd4-830f-d3c21a8384bc"],
 " is invertible, then\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "\[VeryThinSpace]", "(", "M", ")"}], "=", 
    RowBox[{
     RowBox[{"Pf", "(", "A", ")"}], 
     RowBox[{"Pf", "(", 
      RowBox[{"D", "+", 
       RowBox[{
        SuperscriptBox["B", "T"], 
        SuperscriptBox["A", 
         RowBox[{"-", "1"}]], "B"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"0677f290-ed9a-401d-8b2a-5117efa9dde1"],
 ".\[LineSeparator]If ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "11dea51c-8f5a-4312-b109-624b4fdc8e39"],
 " is invertible, then\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", "M", ")"}], "=", 
    RowBox[{
     RowBox[{"Pf", "(", "D", ")"}], 
     RowBox[{"Pf", "(", 
      RowBox[{"A", "+", 
       RowBox[{"B", "\[ThinSpace]", 
        SuperscriptBox["D", 
         RowBox[{"-", "1"}]], 
        SuperscriptBox["B", "T"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"77064f31-8c66-46bf-8e04-a23e24f2666b"],
 ".\[LineSeparator]These formulae are reminiscent of the determinant formulae \
of block matrices\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"det", "(", GridBox[{
       {"A", "B"},
       {"C", "D"}
      }], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"det", "(", "A", ")"}], 
      RowBox[{"det", "(", 
       RowBox[{"D", "-", 
        RowBox[{"C", "\[VeryThinSpace]", 
         SuperscriptBox["A", 
          RowBox[{"-", "1"}]], "B"}]}], ")"}]}], "=", 
     RowBox[{
      RowBox[{"det", "(", "D", ")"}], 
      RowBox[{"det", "(", 
       RowBox[{"A", "-", 
        RowBox[{"B", "\[VeryThinSpace]", 
         SuperscriptBox["D", 
          RowBox[{"-", "1"}]], "C"}]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"5c50c667-1c8d-451f-9aa2-240b30f8518c"],
 ". "
}], "Notes",
 CellID->359201534,ExpressionUUID->"421073f1-f9e1-4eea-ab68-f3e1cf6d5b9c"],

Cell[TextData[{
 "For an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "7d690b33-e56c-4eef-a310-27e0ab8f0874"],
 " matrix ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "dbadf2dd-e516-4575-a6ff-1a4184f05a36"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
