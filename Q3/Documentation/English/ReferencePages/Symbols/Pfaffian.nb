 "."
}], "Notes",
 CellID->154752662,ExpressionUUID->"d45e2563-9269-4fc3-b445-e1e4f10757f1"],

Cell[TextData[{
 "For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "72508934-6404-42fc-84f2-71fba4714fae"],
 " skew symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "d2c4403f-5b8f-44ed-b302-45dd882ab106"],
 " and arbitrary ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "32295881-f413-48c7-b3d0-89d653f3a40e"],
 " matrix ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "fbd8283e-5864-4982-b797-72922e51a7d8"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", 
     RowBox[{"B", "\[VeryThinSpace]", "A", "\[VeryThinSpace]", 
      SuperscriptBox["B", "T"]}], ")"}], "=", 
