Cell["\<\
The term Pfaffian was named after Johann Friedrich Pfaff by Arthur Cayley in \
1852.\
\>", "Notes",
 CellID->1465095834,ExpressionUUID->"b9832b82-c159-44b1-9622-8f1026bac317"],

Cell[TextData[{
 "For a skew-symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "101089e2-f375-462c-b3f2-3d140e0de11c"],
 " of odd dimension, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", "A", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"6f062817-bc23-4b26-ab68-ec6ce812b7b2"],
 "."
}], "Notes",
 CellID->108077630,ExpressionUUID->"99bc4670-cc71-4807-a117-d8e32948a568"],

Cell[TextData[{
 "For a skew-symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "79c0ec10-af45-445e-81a6-cfb59bc76b54"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"Pf", "(", "A", ")"}], "2"], "=", 
    RowBox[{"det", "(", "A", ")"}]}], TraditionalForm]],ExpressionUUID->
  "2da832f1-c70a-4854-b168-94db58f08714"],
 "."
}], "Notes",
 CellID->818154030,ExpressionUUID->"0462444b-5455-465a-81f3-02dbc21aea2f"],

Cell[TextData[{
 "For a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "d48b116e-6eee-4969-b4b1-15c1d743e10d"],
 " skew-symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "7f6c0949-35c2-4b44-9194-bf4d0f25f060"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", "A", ")"}], " ", "=", " ", 
    RowBox[{
     SubscriptBox["\[Sum]", "k"], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "k"], 
      SubscriptBox["A", 
       RowBox[{"1", "k"}]], 
      RowBox[{"Pf", "(", 
       SubscriptBox["A", 
        RowBox[{
         OverscriptBox["1", "^"], 
         OverscriptBox["k", "^"]}]], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"fce3c68f-e678-4fd4-b2be-ee7d0e9c08cd"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", 
    RowBox[{
     OverscriptBox["i", "^"], 
     OverscriptBox["j", "^"]}]], TraditionalForm]],ExpressionUUID->
  "59a46984-67b1-4487-8d77-e850b2a5d25c"],
 "denotes the matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "4a408db2-a85d-47f1-aea5-1602eaf0da80"],
 " with the ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "91861f01-4265-44e3-8682-6c97f212222a"],
 "th row and column and the ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "cdf25d1b-ee03-41d3-927f-6a1ecd79ef09"],
 "th row and column removed."
}], "Notes",
 CellID->190812649,ExpressionUUID->"c7cf4853-6912-45a8-884b-aed2f415849c"],

