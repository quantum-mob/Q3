        TextData["$MachineEpsilon"]], "paclet:ref/$MachineEpsilon"},
      "RefLink",
      BaseStyle->{"3ColumnTableMod"}]}], Cell["\<\
Matrix elements smaller than tolerance are taken to be zero. Currently, this \
option only affects the \"Parlett-Reid\" method.\
\>", "TableText",ExpressionUUID->"5f9af492-1df1-48f1-806d-dbdd58e60ae3"]}
  }]], "3ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{"Columns" -> {{None}}, "Rows" -> {None, {None}}},
 GridBoxDividers->{"Rows" -> {{True, True, True}}}},
 CellID->1977157692,ExpressionUUID->"7e115b24-8e9b-4d04-9fe1-88fadc562ffb"],

Cell[TextData[{
 "The default setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Method"]], "paclet:ref/Method"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   TemplateBox[{
     Cell[
      TextData["Automatic"]], "paclet:ref/Automatic"},
    "RefLink",
    BaseStyle->{"InlineFormula"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aaf7ff98-70f1-4400-8703-a6664fcdff96"],
 "  uses the ",
 StyleBox["Hessenberg decomposition",
  FontSlant->"Italic"],
 " (\"Hessenberg\") for real matrices (note that it converts any exact number \
to a finite-precision number, and hence the returned value is always an \
inexact number) and the ",
 StyleBox["Parlett-Reid tridiagonalization",
  FontSlant->"Italic"],
 " for complex matrices. Other settings include: "
}], "Notes",
 CellID->1347491459,ExpressionUUID->"adbc9ceb-091c-4719-b174-3a37d6d21b4e"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "17e30bc5-70dc-4e0e-9727-8aa9db7b0317"], Cell[
    "\"Parlett-Reid\"", "TableText",ExpressionUUID->
     "5f37a3c0-63cb-43b6-9fff-dadd112256fa"], Cell[
    "Uses the Parlett-Reid tridiagonalization.", "TableText",ExpressionUUID->
     "92579097-ccd0-47f7-be91-ce8a35a8b723"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "44e3d0fd-63f4-48bf-8177-65c49ec6a384"], Cell[
    "\"Householder\"", "TableText",ExpressionUUID->
     "1936268e-54e4-40bc-b61e-83a8a9d49a16"], Cell["\<\
Uses the Householder tridiagonalization, and is the default choice for \
complex matrices.\
\>", "TableText",ExpressionUUID->"c98df826-7813-483a-87e0-28879f7500f0"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "655fcf13-c213-4130-a47f-84fee9f31616"], Cell[
    "\"Hessenberg\"", "TableText",ExpressionUUID->
     "ecb0d964-29de-4a86-a35b-90df8bee8396"], Cell[TextData[{
     "Uses the Hessenberg decomposition, is usually the fastest for ",
     StyleBox["real",
      FontSlant->"Italic"],
     " matrices, and hence is the default choice for ",
     StyleBox["real",
      FontSlant->"Italic"],
     " matrices. However, it works only for finite-preision matrices. For \
infinite-precision real matrices, use \"Householder\"."
    }], "TableText",ExpressionUUID->"8a0d2d5e-1315-49d9-8666-66c23e851f29"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "6527f653-5e6e-4d26-a2da-d91fbcd3cb34"], Cell[
    "\"Heuristic\"", "TableText",ExpressionUUID->
     "e343be5d-9a3c-4a8e-98c5-48bef25a944d"], Cell["\<\
Uses the heuristic recursive method. This method is very slow for large \
matrices.\
\>", "TableText",ExpressionUUID->"f958676a-f92c-4eac-95fc-60316a8c25f7"]}
  }]], "2ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{
  "Columns" -> {{None}}, "Rows" -> {None, None, None, {None}}},
 GridBoxDividers->{"Rows" -> {{True, True, True, True, True}}}},
 CellID->487478069,ExpressionUUID->"3ccf60a9-6d3f-4756-9d57-77448db97022"],

Cell[TextData[{
 "The option ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Method"]], "paclet:ref/Method"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", "\"\<Hessenberg\>\""}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "27559ff0-352d-4b85-863c-82b6259d725d"],
 " uses the the ",
 StyleBox["Hessenberg decomposition",
  FontSlant->"Italic"],
 ". Recall that the Hessenberg decomposition is applicable only for ",
 StyleBox["real",
  FontSlant->"Italic"],
 " matrices. Since the Hessenberg decomposition is implemented natively in \
Mathematica, this approach is usually fastest for ",
 StyleBox["real",
  FontSlant->"Italic"],
 " matrices."
}], "Notes",
 CellID->188511912,ExpressionUUID->"72ecff9f-f981-43c0-83c6-89be8e25a297"],

Cell[TextData[{
 "The option ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tolerance"]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   StyleBox["tol", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c0360a28-7141-4f9b-9656-2c024fcf7eab"],
 " indicates that matrix entries ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m", "TI"], 
   StyleBox["ij", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "57d18952-e2c0-4d32-b803-e36c537e6cd1"],
 " such that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Abs"]], "paclet:ref/Abs"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["ij", "TI"]], "]"}], "<", 
   StyleBox["tol", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b0073baa-865e-4c85-9322-53149438d869"],
 " are taken to be zero. With the default setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tolerance"]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"8", " ", 
    TemplateBox[{
      Cell[
       TextData["$MachineEpsilon"]], "paclet:ref/$MachineEpsilon"},
     "RefLink",
     BaseStyle->{"InlineFormula"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9469b5bf-92d1-4ff1-b876-2ccd6009e8a5"],
 ", the comparison is done except for the last 3 bits. See, e.g., the help \
pages of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["SymmetricMatrixQ"]], "paclet:ref/SymmetricMatrixQ"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2c942d2d-d4b5-48c7-b146-bed1dc3c1b60"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["AntisymmetricMatrixQ"]], "paclet:ref/AntisymmetricMatrixQ"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "75658d3c-683a-4e8b-9ea0-c3abff854121"],
 " for more details."
}], "Notes",
 CellID->725492533,ExpressionUUID->"48cea8c5-56bc-4121-86dc-3500996d7241"]
}, Closed]],

