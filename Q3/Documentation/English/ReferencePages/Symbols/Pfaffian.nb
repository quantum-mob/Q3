  "e44aaaa1-3f84-4436-8778-2cc157eba3af"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "A"}], ")"}], "=", 
    RowBox[{
     SuperscriptBox["\[Lambda]", "n"], 
     RowBox[{"Pf", "(", "A", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "5e22c9ab-aef1-41a5-a8b2-8f7920f3fa10"],
 "."
}], "Notes",
 CellID->913484140,ExpressionUUID->"cf6d1c0a-8e8f-45dd-8314-31bc3f42692f"],

Cell[TextData[{
 "For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "f94d3c38-4d2b-4197-abc2-4706dced2e79"],
 " ",
 StyleBox["invertible",
  FontSlant->"Italic"],
 " skew symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "c226f778-5ba6-4b53-9293-766d5f04ae55"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", 
     SuperscriptBox["A", 
      RowBox[{"-", "1"}]], ")"}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "n"], "/", 
