     RowBox[{"Pf", "(", "A", ")"}], 
     RowBox[{"Det", "(", "B", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "1e501322-ab10-42c2-9109-7fc0084a98b6"],
 "."
}], "Notes",
 CellID->1638344201,ExpressionUUID->"6b1b980a-89af-48b6-b5ba-3009ed0e396f"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "f0ad4a2c-0ac5-4cb7-b14f-5b7749727eae"],
 " and ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "c5dc0f0c-7841-460e-b3da-5c3115979cc5"],
 " be ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "6e4c9d8f-8b02-4b8b-b1ba-727609b57e87"],
 " anti-symmetric matrices, and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "f3f05b48-fdf1-4349-b81a-c283d7fdcb7c"],
 " be an arbitrary ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "1df1262b-1db5-426d-91f7-897fb667dd60"],
 " matrix. Consider a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "6a7e63fe-39d2-441a-8724-36970336e6e8"],
 " block matrix of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", ":=", 
    RowBox[{"(", GridBox[{
       {"A", "B"},
       {
        RowBox[{"-", 
         SuperscriptBox["B", "T"]}], "D"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "ba97abaa-6425-49fb-a961-323a8de2c26e"],
 ".\[LineSeparator]If ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b1a2140f-fcaa-42fc-ad23-e6900444d91e"],
 " is invertible, then\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "\[VeryThinSpace]", "(", "M", ")"}], "=", 
    RowBox[{
     RowBox[{"Pf", "(", "A", ")"}], 
     RowBox[{"Pf", "(", 
      RowBox[{"D", "+", 
       RowBox[{
        SuperscriptBox["B", "T"], 
        SuperscriptBox["A", 
         RowBox[{"-", "1"}]], "B"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"4ba025c4-e31d-405d-afc5-e41dd721ceef"],
 ".\[LineSeparator]If ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "ac153e0a-6681-4454-925d-dbb9d1f0e09a"],
 " is invertible, then\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", "M", ")"}], "=", 
    RowBox[{
     RowBox[{"Pf", "(", "D", ")"}], 
     RowBox[{"Pf", "(", 
      RowBox[{"A", "+", 
       RowBox[{"B", "\[ThinSpace]", 
        SuperscriptBox["D", 
         RowBox[{"-", "1"}]], 
        SuperscriptBox["B", "T"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"67019ed1-9181-4989-be6b-453e57b3e4b2"],
 ".\[LineSeparator]These formulae are reminiscent of the determinant formulae \
of block matrices\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"det", "(", GridBox[{
       {"A", "B"},
       {"C", "D"}
      }], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"det", "(", "A", ")"}], 
      RowBox[{"det", "(", 
       RowBox[{"D", "-", 
        RowBox[{"C", "\[VeryThinSpace]", 
         SuperscriptBox["A", 
          RowBox[{"-", "1"}]], "B"}]}], ")"}]}], "=", 
     RowBox[{
      RowBox[{"det", "(", "D", ")"}], 
      RowBox[{"det", "(", 
       RowBox[{"A", "-", 
        RowBox[{"B", "\[VeryThinSpace]", 
         SuperscriptBox["D", 
          RowBox[{"-", "1"}]], "C"}]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"3e22c6b5-7dee-45a3-81e9-f0a19426f397"],
 ". "
}], "Notes",
 CellID->359201534,ExpressionUUID->"c9c270b3-76b3-4070-a51a-44cd843acc10"],

