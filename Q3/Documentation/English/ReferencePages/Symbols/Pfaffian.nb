       {"0", "B"},
       {
        RowBox[{"-", 
         SuperscriptBox["B", "T"]}], "0"}
      }], ")"}], "=", 
    RowBox[{"det", "(", "B", ")"}]}], TraditionalForm]],ExpressionUUID->
  "b930d71b-8c9b-4cd9-baee-c08d6bb0b004"],
 "."
}], "Notes",
 CellID->667190290,ExpressionUUID->"dc63c148-7d31-437a-b17b-a90d58cea803"],

Cell["The following options can be given:", "Notes",
 CellID->646241201,ExpressionUUID->"1f35aa49-5dbc-4d0c-80b0-6fd7fab47424"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "5b7b4aec-cce8-48d0-9fa5-a667f8b90108"], 
    TemplateBox[{
      Cell[
       TextData["Method"]], "paclet:ref/Method"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], 
    TemplateBox[{
      Cell[
       TextData["Automatic"]], "paclet:ref/Automatic"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], Cell[
    "The method to use", "TableText",ExpressionUUID->
     "dbf2ed15-5bf6-48f0-8559-e4aefbbbaa63"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "10a71e36-cb0f-4544-8211-03f508a93fe7"], 
    TemplateBox[{
      Cell[
       TextData["Tolerance"]], "paclet:ref/Tolerance"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], 
    RowBox[{"8", " ", 
     TemplateBox[{
       Cell[
        TextData["$MachineEpsilon"]], "paclet:ref/$MachineEpsilon"},
      "RefLink",
      BaseStyle->{"3ColumnTableMod"}]}], Cell["\<\
Matrix elements smaller than tolerance are taken to be zero. Currently, this \
option only affects the \"Parlett-Reid\" method.\
\>", "TableText",ExpressionUUID->"a62d3bfe-4eb0-43c3-a6bb-c930d5cd0304"]}
  }]], "3ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{"Columns" -> {{None}}, "Rows" -> {None, {None}}},
 GridBoxDividers->{"Rows" -> {{True, True, True}}}},
 CellID->1977157692,ExpressionUUID->"45fd2a1e-135d-44a4-96d1-f090fa320521"],

Cell[TextData[{
 "The default setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Method"]], "paclet:ref/Method"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   TemplateBox[{
     Cell[
      TextData["Automatic"]], "paclet:ref/Automatic"},
    "RefLink",
    BaseStyle->{"InlineFormula"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e057faff-811c-4b02-adaf-832499061702"],
 "  uses the ",
 StyleBox["Hessenberg decomposition",
  FontSlant->"Italic"],
 " (\"Hessenberg\") for real matrices (note that it converts any exact number \
to a finite-precision number, and hence the returned value is always an \
inexact number) and the ",
 StyleBox["Parlett-Reid tridiagonalization",
  FontSlant->"Italic"],
 " for complex matrices. Other settings include: "
}], "Notes",
 CellID->1347491459,ExpressionUUID->"67066424-ea60-4bab-84d8-9d3322fa377a"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "949e9ef2-078a-4463-89a8-f83016faa58e"], Cell[
    "\"Parlett-Reid\"", "TableText",ExpressionUUID->
     "d470c982-70d4-4479-8b5d-39fe1b6709db"], Cell[
    "Uses the Parlett-Reid tridiagonalization.", "TableText",ExpressionUUID->
     "6f9864da-57d5-411e-a03e-b44fdaf5ce89"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "86f6c40e-fec4-4c49-9352-8815bef42fb1"], Cell[
    "\"Householder\"", "TableText",ExpressionUUID->
     "4c0b5d9a-37f3-4ab7-a964-8d1a74e0844a"], Cell["\<\
Uses the Householder tridiagonalization, and is the default choice for \
complex matrices.\
\>", "TableText",ExpressionUUID->"c765010b-715c-4eeb-a6da-c993f154a974"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "2b17c4b1-f932-4d0d-b8e3-98821e8df4ea"], Cell[
    "\"Hessenberg\"", "TableText",ExpressionUUID->
     "56fdd054-e888-48c0-afa7-47ec23d78470"], Cell[TextData[{
     "Uses the Hessenberg decomposition, is usually the fastest for ",
     StyleBox["real",
      FontSlant->"Italic"],
     " matrices, and hence is the default choice for ",
     StyleBox["real",
      FontSlant->"Italic"],
     " matrices. However, it works only for finite-preision matrices. For \
infinite-precision real matrices, use \"Householder\"."
    }], "TableText",ExpressionUUID->"85034883-38b1-4589-a7f2-a429933202ad"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "0be6840e-0fde-45f8-b9b3-e9822f97f888"], Cell[
    "\"Heuristic\"", "TableText",ExpressionUUID->
     "3e231885-0994-460e-8a38-bb5dd1f1da3e"], Cell["\<\
Uses the heuristic recursive method. This method is very slow for large \
matrices.\
\>", "TableText",ExpressionUUID->"b1383a8d-39f2-4fc9-ad0a-f50111b59618"]}
  }]], "2ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{
  "Columns" -> {{None}}, "Rows" -> {None, None, None, {None}}},
 GridBoxDividers->{"Rows" -> {{True, True, True, True, True}}}},
 CellID->487478069,ExpressionUUID->"e1fa6081-d3d2-4eca-97c1-e1e73bdd05fc"],

Cell[TextData[{
 "The option ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Method"]], "paclet:ref/Method"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", "\"\<Hessenberg\>\""}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a05988e8-55f2-4508-919c-e96374c44bd9"],
 " uses the the ",
 StyleBox["Hessenberg decomposition",
  FontSlant->"Italic"],
 ". Recall that the Hessenberg decomposition is applicable only for ",
 StyleBox["real",
  FontSlant->"Italic"],
 " matrices. Since the Hessenberg decomposition is implemented natively in \
Mathematica, this approach is usually fastest for ",
 StyleBox["real",
  FontSlant->"Italic"],
 " matrices."
}], "Notes",
 CellID->188511912,ExpressionUUID->"7dd74d7b-fe44-4f56-8a5d-6ed32565204b"],

Cell[TextData[{
 "The option ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tolerance"]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   StyleBox["tol", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1a602c2e-86f6-46bc-a248-67167968d749"],
 " indicates that matrix entries ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m", "TI"], 
   StyleBox["ij", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "31cf025e-94ba-4ec2-81cc-e7684f2b2e47"],
 " such that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Abs"]], "paclet:ref/Abs"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["ij", "TI"]], "]"}], "<", 
   StyleBox["tol", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f2ae9a3e-90ab-43bf-a2a4-adba73f55792"],
 " are taken to be zero. With the default setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tolerance"]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"8", " ", 
    TemplateBox[{
      Cell[
       TextData["$MachineEpsilon"]], "paclet:ref/$MachineEpsilon"},
     "RefLink",
     BaseStyle->{"InlineFormula"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "088053bf-5e08-48d2-8654-1bd94027ca2d"],
 ", the comparison is done except for the last 3 bits. See, e.g., the help \
pages of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["SymmetricMatrixQ"]], "paclet:ref/SymmetricMatrixQ"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a23d80bd-7aac-4a7b-808e-06409229bec1"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["AntisymmetricMatrixQ"]], "paclet:ref/AntisymmetricMatrixQ"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4d06d71-c575-45de-aef7-c98f15864586"],
 " for more details."
}], "Notes",
 CellID->725492533,ExpressionUUID->"fa421464-904d-47a7-ac8a-76a6a96784a2"]
