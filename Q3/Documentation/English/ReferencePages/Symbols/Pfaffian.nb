Cell["\<\
The term Pfaffian was named after Johann Friedrich Pfaff by Arthur Cayley in \
1852.\
\>", "Notes",
 CellID->1465095834,ExpressionUUID->"660e63de-a813-4c49-a712-acfc516d1734"],

Cell[TextData[{
 "For a skew-symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "03a5c5b0-0f7f-41b7-b10f-ab62d0c145ec"],
 " of odd dimension, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", "A", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"cb25a314-8368-4273-8be1-44382c43c0e5"],
 "."
}], "Notes",
 CellID->108077630,ExpressionUUID->"c62cafd9-48f3-4194-b748-78915a187f30"],

Cell[TextData[{
 "For a skew-symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "4c2243c1-033a-45a0-9453-78e0b553c989"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"Pf", "(", "A", ")"}], "2"], "=", 
    RowBox[{"det", "(", "A", ")"}]}], TraditionalForm]],ExpressionUUID->
  "20eea1fe-2f6e-4b98-9b87-6653b2a994d9"],
 "."
}], "Notes",
 CellID->818154030,ExpressionUUID->"08df634d-743a-4f5c-a24e-7da0f916877d"],

Cell[TextData[{
 "For a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "16165386-d7ee-42e5-865e-a680157fa147"],
 " skew-symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "4520763e-59cf-4402-89fc-a22b08237602"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", "A", ")"}], " ", "=", " ", 
    RowBox[{
     SubscriptBox["\[Sum]", "k"], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], "k"], 
      SubscriptBox["A", 
       RowBox[{"1", "k"}]], 
      RowBox[{"Pf", "(", 
       SubscriptBox["A", 
        RowBox[{
         OverscriptBox["1", "^"], 
         OverscriptBox["k", "^"]}]], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"7e1477aa-a013-4a78-b61a-7bd897a1f0bd"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", 
    RowBox[{
     OverscriptBox["i", "^"], 
     OverscriptBox["j", "^"]}]], TraditionalForm]],ExpressionUUID->
  "11dd5b07-55af-44c1-ae39-ffc0ebff69bf"],
 "denotes the matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "af3f3b56-fa58-4fd2-884f-6c8d5f167282"],
 " with the ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "e84054ff-946f-404d-9f96-465d0dc7a9f2"],
 "th row and column and the ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "676c98bb-2183-4d43-b5b2-9bad5407e8a5"],
 "th row and column removed."
}], "Notes",
 CellID->190812649,ExpressionUUID->"e2a3fe02-1efa-45dc-b509-9e55ab7266bd"],

Cell[TextData[{
 "For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "b584a9f3-4e64-4fde-a248-a875403fbb19"],
 " skew symmetric matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "54ab93de-929c-4fa6-8f02-98cc4970d3e1"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Pf", "(", 
     SuperscriptBox["A", "T"], ")"}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "n"], 
