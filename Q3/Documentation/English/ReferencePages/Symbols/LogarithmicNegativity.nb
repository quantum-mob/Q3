Cell[TextData[{
 "The ",
 StyleBox["logarithmic negativity",
  FontSlant->"Italic"],
 " is an entanglement monotone for quantum states (whether pure or mixed), \
quantitatively measuring quantum entanglement."
}], "Notes",
 CellID->1614280326,ExpressionUUID->"0f8ecab3-1368-47aa-8d6b-d33314b2e560"],

Cell[TextData[{
 "For a mixed state \[Rho] of a bipartite system consisting of subsystems A \
and B, the logarithmic negativity is defined by ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["log", "2"], 
   SubscriptBox[
    RowBox[{"\[LeftDoubleBracketingBar]", 
     SuperscriptBox["\[Rho]", 
      StyleBox[
       SubscriptBox["T", "B"],
       FontSlant->"Italic"]], "\[RightDoubleBracketingBar]"}], "tr"]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "abacaa06-5538-4a39-8509-373421e1db24"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Rho]", 
    SubscriptBox["T", "B"]], TraditionalForm]],ExpressionUUID->
  "a7f39167-ff5e-4f6c-bf5c-a71422249e4b"],
 " denotes the partial transpose with respect to subsystem ",
 StyleBox["B",
  FontSlant->"Italic"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{
   "\[LeftDoubleBracketingBar]", "\[CenterEllipsis]", 
    "\[RightDoubleBracketingBar]"}], "tr"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f8267868-6c44-4612-9316-0efb9e668346"],
 " indicates the ",
 ButtonBox["trace norm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/TraceNorm"],
 " of operators or matrices."
}], "Notes",
 CellID->453625225,ExpressionUUID->"32a4021c-c334-406e-9d1d-56dd758d7d27"],

Cell[TextData[{
 "Unlike the ",
 StyleBox["negativity",
  FontSlant->"Italic"],
 ", the logarithmic negativity is additive; unfortunately, however, it  is ",
 StyleBox["not",
  FontSlant->"Italic"],
 " convex (Plenio and Virmani, 2007)."
}], "Notes",
 CellID->2012233872,ExpressionUUID->"c48cc705-bd08-412e-aea9-74b712613bd9"],

Cell[TextData[{
 "The logarithmic negativity does not reduce to the ",
 StyleBox["entropy of entanglement",
  FontSlant->"Italic"],
 " on all pure states."
}], "Notes",
 CellID->731060821,ExpressionUUID->"c8a165f0-2593-4646-9152-cf9170aba24e"],

Cell[TextData[{
 "The logarithmic negativity is the upper bound to the ",
 StyleBox["distillable entanglement",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1416565903,ExpressionUUID->"4ff59449-c2a1-4dfc-8ab2-f600da7be0f3"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

