Cell["\<\
A Choi matrix returns a forth-rank tensor, but is typically called a 'matrix' \
regarding the first two and last two indexes as collective indices.\
\>", "Notes",
 CellID->1067943069,ExpressionUUID->"e28c05c8-2c2f-4234-bcd8-ddc66b36f402"],

Cell[TextData[{
 "A supermatrix ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["M", "TI"], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], ",", 
              StyleBox["k", "TI"]}], ")"}], ",", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], ",", 
              StyleBox["l", "TI"]}], ")"}]}]], TraditionalForm], 
     "errors" -> {}, "input" -> "M_{(i,k),(j,l)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "28347165-35f3-47b3-a92a-bb7be25aae59"],
 " is a conversion of Choi matrix  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["C", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], ",", 
          StyleBox["j", "TI"], ";", 
          StyleBox["k", "TI"], ",", 
          StyleBox["l", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "C_{i,j;k,l}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "811847a6-6505-4a62-8eb1-1c7b0497bc30"],
 "."
}], "Notes",
 CellID->2144837231,ExpressionUUID->"80d9461d-d569-42b1-8b69-eae1bee38ea5"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", ":", 
    RowBox[{"\[Rho]", "\[RightTeeArrow]", "\[Sigma]"}]}], TraditionalForm]],
  ExpressionUUID->"9dac2f2b-a89c-4fca-acf7-82a865d2a558"],
 " be a supermap, and ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "d60ff924-48b0-4865-b368-fff961eb3609"],
 " its Choi matrix. Then, the components of \[Rho] and \[Sigma] are related \
by the transformation\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Sigma]", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]], 
      SubscriptBox["C", 
       RowBox[{
        RowBox[{"i", "\[VeryThinSpace]", "k"}], ";", 
        RowBox[{"j", "\[VeryThinSpace]", "l"}]}]], 
      SubscriptBox["\[Rho]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]], 
      SubscriptBox["M", 
       RowBox[{
        RowBox[{"i", "\[VeryThinSpace]", "j"}], ";", 
        RowBox[{"k", "\[VeryThinSpace]", "l"}]}]], 
      SubscriptBox["\[Rho]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"c3ec9aac-a665-48e4-be63-d81e52d249ca"],
 " ."
}], "Notes",
 CellID->688867986,ExpressionUUID->"41ebeadf-67f3-4562-adf6-b162a0129a32"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

