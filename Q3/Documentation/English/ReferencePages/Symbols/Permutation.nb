Cell[TextData[{
 "You can convert ",
 StyleBox["Permutation[\[Ellipsis]]", "Input"],
 " to an ordinary operator expression by using ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Elaborate"]], "paclet:QuantumMob/Q3/ref/Elaborate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7d5333ab-3504-43e0-8e53-6e221914c2c6"],
 ". However, it is much faster operating directly ",
 StyleBox["Permutation[\[Ellipsis]]", "Input"],
 " on ",
 ButtonBox["Ket",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Ket"],
 ", ",
 ButtonBox["Bra",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Bra"],
 ", and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Dyad"]], "paclet:QuantumMob/Q3/ref/Dyad", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e4e25abf-04c0-478d-aa5a-7b5fdcce78ab"],
 " than first converting it to an ordinary operator expression and then \
operating the resulting expression on those objects. Here is an \
illustration."
}], "ExampleText",
 CellID->1300177241,ExpressionUUID->"5e73033b-0684-4b57-975b-08845adc9994"],

Cell[TextData[{
 "Consider a system of ",
 StyleBox["$n", "Input"],
 " qubits. NOTE: A large value of ",
 StyleBox["$n", "Input"],
 " has been chosen for a vivid demonstration. For a quick test, choose a \
smaller value."
}], "ExampleText",
 CellID->217693379,ExpressionUUID->"8d8877d2-46d6-4a44-a3af-5a8bbb3721a6"],

