Cell[TextData[{
 "A ",
 StyleBox["Bogoliubov-de Gennes transformation",
  FontSlant->"Italic"],
 " is defined by (notice the factor of 1/2)\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      UnderscriptBox["c", "_"], "\[Dagger]"], "\[RightTeeArrow]", 
     RowBox[{
      RowBox[{"exp", "(", 
       RowBox[{
        RowBox[{"-", 
         FractionBox["\[ImaginaryI]", "2"]}], "\[VeryThinSpace]", 
        SuperscriptBox[
         UnderscriptBox["c", "_"], "\[Dagger]"], 
        UnderscriptBox["H", "_"], 
        UnderscriptBox[
         RowBox[{"\[VeryThinSpace]", "c"}], "_"]}], ")"}], 
      SuperscriptBox[
       UnderscriptBox["c", "_"], "\[Dagger]"], 
      RowBox[{"exp", "(", 
       RowBox[{
        FractionBox["\[ImaginaryI]", "2"], "\[VeryThinSpace]", 
        SuperscriptBox[
         UnderscriptBox["c", "_"], "\[Dagger]"], 
        UnderscriptBox["H", "_"], 
        UnderscriptBox[
         RowBox[{"\[VeryThinSpace]", "c"}], "_"]}], ")"}]}]}], "=", 
    RowBox[{
     SuperscriptBox[
      UnderscriptBox["c", "_"], "\[Dagger]"], 
     UnderscriptBox["U", "_"]}]}], TraditionalForm]],ExpressionUUID->
  "a6b292dd-78f9-4076-aa47-d8fff7fd8aa9"],
 "\[LineSeparator]or, equivalently,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["c", "_"], " ", "\[RightTeeArrow]", 
     RowBox[{
      RowBox[{"exp", "(", 
       RowBox[{
        FractionBox["\[ImaginaryI]", "2"], "\[VeryThinSpace]", 
        SuperscriptBox[
         UnderscriptBox["c", "_"], "\[Dagger]"], 
        UnderscriptBox["H", "_"], 
        UnderscriptBox[
         RowBox[{"\[VeryThinSpace]", "c"}], "_"]}], ")"}], 
      UnderscriptBox["c", "_"], 
      RowBox[{"exp", "(", 
       RowBox[{
        RowBox[{"-", 
         FractionBox["\[ImaginaryI]", "2"]}], "\[VeryThinSpace]", 
        SuperscriptBox[
         UnderscriptBox["c", "_"], "\[Dagger]"], 
        UnderscriptBox["H", "_"], 
        UnderscriptBox[
         RowBox[{"\[VeryThinSpace]", "c"}], "_"]}], ")"}]}]}], "=", 
    RowBox[{
     UnderscriptBox["U", "_"], 
     UnderscriptBox["c", "_"]}]}], TraditionalForm]],ExpressionUUID->
  "4478de48-b09b-4e6c-8ad9-7e403196d198"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     UnderscriptBox["c", "_"], "\[Dagger]"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["c", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["c", "n"], ",", 
      SubsuperscriptBox["c", "1", "\[Dagger]"], ",", "\[Ellipsis]", ",", 
      SubsuperscriptBox["c", "n", "\[Dagger]"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"c0e94649-31eb-4b52-94f5-623efeb4b697"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["U", "_"], ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      UnderscriptBox["H", "_"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "b794f5a1-41d3-4dd0-aea2-9a8772e7286b"],
 "  (without the factor of 1/2)."
}], "Notes",
 CellID->796757408,ExpressionUUID->"ed6a56c2-cdca-4371-90cf-c2345108da1c"],

Cell[TextData[{
 "It is important to keep the proper block structure for any unitary matrix \
",
 Cell[BoxData[
  FormBox[
   UnderscriptBox["U", "_"], TraditionalForm]],ExpressionUUID->
  "d2ef5388-f3d7-451f-91f0-9f0d44cb6ba8"],
 " in the Nambu space: The Bogoliubov-de Gennes Hamiltonian matrix ",
 Cell[BoxData[
  FormBox[
   UnderscriptBox["H", "_"], TraditionalForm]],ExpressionUUID->
  "19e35de5-e46a-4266-8676-eca503f8eb2b"],
 " has the block structure \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["H", "_"], ":=", 
    RowBox[{"(", GridBox[{
       {"H", "\[CapitalDelta]"},
       {
        SuperscriptBox["\[CapitalDelta]", "\[Dagger]"], 
        RowBox[{"-", 
         SuperscriptBox["H", "*"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "24cbd5e2-4f1b-495d-a9c8-3c501b5f0061"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["H", "\[Dagger]"], "=", "H"}], TraditionalForm]],
  ExpressionUUID->"b5d3b128-ddbb-4372-990e-53e596a1d66d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalDelta]", "T"], "=", 
    RowBox[{"-", "\[CapitalDelta]"}]}], TraditionalForm]],ExpressionUUID->
  "9de17e34-4bad-48af-9a04-d1b3838084b1"],
 ", \[LineSeparator]and it implies the block structure of \[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["U", "_"], ":=", 
    RowBox[{
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
       UnderscriptBox["H", "_"]}], ")"}], "=", 
     RowBox[{"(", GridBox[{
        {"U", "V"},
        {
         SuperscriptBox["V", "*"], 
         SuperscriptBox["U", "*"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "11a4461c-21a0-4089-b286-035735a865fd"],
 " \[LineSeparator]in the Bogoliubov-de Gennes transformation matrix."
}], "Notes",
 CellID->1053759868,ExpressionUUID->"dd6e63a7-2afe-4918-ae5a-b0e6db441d77"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["NambuUnitary"]], "paclet:QuantumMob/Q3/ref/NambuUnitary", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["mat", "TI"], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f079dba6-690c-4e79-947a-3c75e98305fc"],
 " does not check whether ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8e3de635-ee4d-42d9-b5cd-c5150aa1e9f3"],
 " is a proper ",
 StyleBox["Bogoliubov-de Gennes transformation matrix",
  FontSlant->"Italic"],
 " or not. It simply takes the upper-left and upper-right blocks, assuming \
the redundancy."
}], "Notes",
 CellID->553348904,ExpressionUUID->"cf573059-ebe6-44a7-af2a-7be51e8ea5ab"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Normal"]], "paclet:ref/Normal"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["NambuUnitary"]], "paclet:QuantumMob/Q3/ref/NambuUnitary", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       StyleBox["U", "TI"], ",", 
       StyleBox["V", "TI"]}], "}"}], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "585f8005-8575-4355-a7d0-96f2ba59185f"],
 "  returns the full ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f67bbd65-7a27-43e6-95e2-148356f08363"],
 " unitary matrix in the ",
 StyleBox["Nambu space",
  FontSlant->"Italic"],
 "; that is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"U", ",", "V"}], "}"}], "\[RightTeeArrow]", 
     UnderscriptBox["U", "_"]}], ":=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"U", "V"},
        {
         SuperscriptBox["V", "*"], 
         SuperscriptBox["U", "*"]}
       }], ")"}], "=", 
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
       UnderscriptBox["H", "_"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"ef0947fc-5dfc-462c-a5fa-676633041736"],
 "."
}], "Notes",
 CellID->1591199108,ExpressionUUID->"7b21fe90-fc40-42c9-ac02-ad0d796c184f"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
