    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a50e5dd1-079d-4716-81d0-cd5ba59cf9ef"],
 " returns the matrix representation of the many-body unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"exp", "(", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["\[ImaginaryI]", "2"]}], "\[VeryThinSpace]", 
     SuperscriptBox[
      UnderscriptBox["c", "_"], "\[Dagger]"], 
     UnderscriptBox["H", "_"], 
     UnderscriptBox[
      RowBox[{"\[VeryThinSpace]", "c"}], "_"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"cb669ed2-4767-41c6-8d9c-4e46460cfe33"],
 " in the ",
 StyleBox["Fock space",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1164815049,ExpressionUUID->"1acc487b-6727-472a-b6a2-5583b4a51e9c"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["z", "TI"], 
     StyleBox["1", "TR"]], "*", 
    RowBox[{"NambuUnitary", "[", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["u", "TI"], 
        StyleBox["1", "TR"]], ",", 
       SubscriptBox[
        StyleBox["v", "TI"], 
        StyleBox["1", "TR"]]}], "}"}], "]"}]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["z", "TI"], 
     StyleBox["2", "TR"]], "*", 
    RowBox[{"NambuUnitary", "[", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["u", "TI"], 
        StyleBox["2", "TR"]], ",", 
       SubscriptBox[
        StyleBox["v", "TI"], 
        StyleBox["2", "TR"]]}], "}"}], "]"}], " "}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2a9a7c5d-fd9c-4514-987f-b01d15cc40ae"],
 "and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    SubscriptBox[
     StyleBox["z", "TI"], 
     StyleBox["1", "TR"]], "*", 
    RowBox[{"NambuUnitary", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["u", "TI"], 
         StyleBox["1", "TR"]], ",", 
        SubscriptBox[
         StyleBox["v", "TI"], 
         StyleBox["1", "TR"]]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["c", "TI"], 
         StyleBox["1", "TR"]], ",", 
        SubscriptBox[
         StyleBox["c", "TI"], 
         StyleBox["2", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}]}], "+", 
   RowBox[{
    SubscriptBox[
     StyleBox["z", "TI"], 
     StyleBox["2", "TR"]], "*", 
    RowBox[{"NambuUnitary", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["u", "TI"], 
         StyleBox["2", "TR"]], ",", 
        SubscriptBox[
         StyleBox["v", "TI"], 
         StyleBox["2", "TR"]]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
