Cell[TextData[{
 "It converts Choi matrix ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["C", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], ",", 
          StyleBox["j", "TI"], ";", 
          StyleBox["k", "TI"], ",", 
          StyleBox["l", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "C_{i,j;k,l}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5dbb56f8-fef4-4fad-b364-2925be29b5a0"],
 " to supermatrix ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["M", "TI"], 
        RowBox[{
          RowBox[{"(", 
            RowBox[{
              StyleBox["i", "TI"], ",", 
              StyleBox["k", "TI"]}], ")"}], ",", 
          RowBox[{"(", 
            RowBox[{
              StyleBox["j", "TI"], ",", 
              StyleBox["l", "TI"]}], ")"}]}]], TraditionalForm], 
     "errors" -> {}, "input" -> "M_{(i,k),(j,l)}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "beb7111a-3e93-427d-817c-5e6043b58a0a"],
 "."
}], "Notes",
 CellID->2144837231,ExpressionUUID->"97fc64d8-da50-4b76-91e2-83dbdf9826e7"],

Cell[TextData[{
 "The Choi matrix of supermap ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", ":", 
    RowBox[{
     RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], "\[RightArrow]", 
     RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalW]", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"6354d4e8-4714-4a2d-89d4-cf092b3a030e"],
 " defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{"A", "\[VeryThinSpace]", "\[Rho]", "\[VeryThinSpace]", 
     SuperscriptBox["B", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "27c8a012-3f85-47bb-90be-3a90ebd7a19d"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ",", 
    RowBox[{"B", "\[Element]", 
     RowBox[{"\[ScriptCapitalL]", "(", 
      RowBox[{"\[ScriptCapitalV]", ",", "\[ScriptCapitalW]"}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"5fc1fdca-86c8-4ccc-aa86-7bb5ddf50e6e"],
 ", is given by \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", 
     RowBox[{
      RowBox[{"i", "\[VeryThinSpace]", "k"}], ";", 
      RowBox[{"j", "\[VeryThinSpace]", "l"}]}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["A", 
       RowBox[{"i", "\[VeryThinSpace]", "\[Kappa]"}]], 
      SubsuperscriptBox["B", 
       RowBox[{"j", "\[VeryThinSpace]", "l"}], "*"]}], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"A", "\[CircleTimes]", 
        SuperscriptBox["B", "*"]}], ")"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"i", ",", "j"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"k", ",", "l"}], ")"}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"dd079ace-bef6-44d0-979a-fa79306c8a96"],
 " . \[LineSeparator]The corresponding ",
 StyleBox["super-matrix",
  FontSlant->"Italic"],
 " is given by \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"i", ",", "j"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"k", ",", "l"}], ")"}]}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["A", 
       RowBox[{"i", "\[VeryThinSpace]", "k"}]], 
      SubsuperscriptBox["B", 
       RowBox[{"j", "\[VeryThinSpace]", "l"}], "*"]}], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"A", "\[CircleTimes]", 
        SuperscriptBox["B", "*"]}], ")"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"i", ",", "j"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"k", ",", "l"}], ")"}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"9a0b3974-59d7-449f-9cbe-f93ca435e06c"],
 "; \[LineSeparator]that is, \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"i", ",", "j"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"k", ",", "l"}], ")"}]}]], "=", 
    SubscriptBox["C", 
     RowBox[{
      RowBox[{"i", "\[VeryThinSpace]", "k"}], ";", 
      RowBox[{"j", "\[VeryThinSpace]", "l"}]}]]}], TraditionalForm]],
  ExpressionUUID->"74483166-eb6f-40de-a18c-bdb8b7d9e99b"],
 " ."
}], "Notes",
 CellID->544097144,ExpressionUUID->"5fd475c7-4511-4e96-b605-b59a415d074e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", ":", 
    RowBox[{"\[Rho]", "\[RightTeeArrow]", "\[Sigma]"}]}], TraditionalForm]],
  ExpressionUUID->"5c5b5c6f-54c8-4395-9a81-87f1224c702a"],
 " be a supermap, and ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "0c7086ff-c716-4185-8fa1-87454d263b9d"],
 " its Choi matrix. Then, the components of \[Rho] and \[Sigma] are related \
by the transformation\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Sigma]", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]], 
      SubscriptBox["C", 
       RowBox[{
        RowBox[{"i", "\[VeryThinSpace]", "k"}], ";", 
        RowBox[{"j", "\[VeryThinSpace]", "l"}]}]], 
      SubscriptBox["\[Rho]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]], 
      SubscriptBox["M", 
       RowBox[{
        RowBox[{"i", "\[VeryThinSpace]", "j"}], ";", 
        RowBox[{"k", "\[VeryThinSpace]", "l"}]}]], 
      SubscriptBox["\[Rho]", 
       RowBox[{"k", "\[VeryThinSpace]", "l"}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"b1f3d71d-d58f-4202-b139-1bb46c2ac5cb"],
 " ."
}], "Notes",
 CellID->688867986,ExpressionUUID->"cc39aaa1-dd79-4399-a666-414cd0b29992"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

