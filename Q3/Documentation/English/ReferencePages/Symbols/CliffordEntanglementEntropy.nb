Cell[TextData[{
 "Note that entanglement entropy is a proper entanglement measure only for \
pure states, i.e., the number of independent stabilizer generators must be \
equal to the number of qubits. Otherwise, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["CliffordEntanglementEntropy"]], 
     "paclet:QuantumMob/Q3/ref/CliffordEntanglementEntropy", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["cs", "TI"], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["k", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["k", "TI"], 
       StyleBox["2", "TR"]], ",", "\[Ellipsis]"}], "}"}]}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c559f309-ccbe-4c2c-83bb-f4ff992887aa"],
 " is merely the ",
 StyleBox["von Neumann entropy",
  FontSlant->"Italic"],
 " of the reduced density matrix of qubits ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["k", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["k", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6be6f117-cb54-4e71-8f8a-1f463ba56e8f"],
 " (after tracing out the other qubits)."
}], "Notes",
 CellID->161483801,ExpressionUUID->"4e0ea05d-9e1e-4485-8650-af3ab2bc108f"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

