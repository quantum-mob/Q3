Cell[TextData[{
 "There is an important difference between ",
 Cell[BoxData[
  RowBox[{"Dyad", "[", 
   RowBox[{
    StyleBox["a", "TI"], ",", 
    StyleBox["b", "TI"], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["q", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["q", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "162fa87c-9054-4f06-9122-6e9b58f7693c"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Ket"]], "paclet:ref/Ket"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["a", "TI"], "]"}], "**", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Bra"]], "paclet:ref/Bra"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["b", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "410b151e-0b93-4761-8654-1bc9cd3d8ec5"],
 ": While ",
 Cell[BoxData[
  RowBox[{"Dyad", "[", 
   RowBox[{
    StyleBox["a", "TI"], ",", 
    StyleBox["b", "TI"], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["q", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["q", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "48088e59-071c-49d3-8113-fed1b7fe3332"],
 " operates only on ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["q", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["q", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2631a470-68ee-4a1e-9f6a-72b18bfc3379"],
 ", ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Ket"]], "paclet:ref/Ket"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["a", "TI"], "]"}], "**", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Bra"]], "paclet:ref/Bra"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["b", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6462efd7-a7d5-4291-a550-5f0be7781ec7"],
 " acts on any systems."
}], "ExampleText",
 CellID->1792993793,ExpressionUUID->"218f3a03-fd3b-4651-b33e-367058429ec2"],

