Dyad[<|S[1, $] -> 0, S[2, $] -> 1|>, <|S[1, $] -> 0, S[2, $] -> 1|>] - 
 I*Dyad[<|S[1, $] -> 0, S[2, $] -> 1|>, <|S[1, $] -> 1, S[2, $] -> 0|>] + 
 I*Dyad[<|S[1, $] -> 1, S[2, $] -> 0|>, <|S[1, $] -> 0, S[2, $] -> 1|>] + 
 Dyad[<|S[1, $] -> 1, S[2, $] -> 0|>, <|S[1, $] -> 1, S[2, $] -> 0|>]\
\>", "Output",
