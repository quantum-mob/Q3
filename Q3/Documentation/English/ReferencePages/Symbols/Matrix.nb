Cell[TextData[{
 "The above expression acts non-trivially only on qubits ",
 StyleBox["S[1,$]", "Input"],
 " and ",
 StyleBox["S[2,$]", "Input"],
 ", but trivially on other qubits, say, ",
 StyleBox["S[3,$]", "Input"],
 ". Therefore, any ",
 StyleBox["implicit",
  FontSlant->"Italic"],
 " Pauli operators ",
 StyleBox["S[3,\[Mu]]", "Input"],
 " does not appear in the expression. If you want to include the qubit ",
 StyleBox["S[3,$]", "Input"],
 " in the matrix expression as well, then just include it in the \
specification of the qubits."
}], "ExampleText",
 CellID->897706317,ExpressionUUID->"e3429a36-3cde-4c4f-aa45-c8f2e557c812"],

