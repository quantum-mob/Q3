Cell["\<\
Consider the following two spinor fields. We want to demonstrate that both \
are irreducible tensor operators of rank 1/2.\
\>", "ExampleText",
 CellID->1797625103,ExpressionUUID->"b5bb6386-4c8c-47df-86a0-ddb2299dabc7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"J", "=", 
   RowBox[{"3", "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Fermion", ",", "c", ",", 
   RowBox[{"Spin", "\[Rule]", "J"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ry", "=", 
   RowBox[{"TheRotation", "[", 
    RowBox[{"Pi", ",", 
     RowBox[{"{", 
      RowBox[{"J", ",", "2"}], "}"}]}], "]"}]}], ";", 
  RowBox[{"Ry", "//", "MatrixForm"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sp", "=", 
   RowBox[{"Dagger", "@", 
    RowBox[{"FockSpinor", "[", "c", "]"}]}]}], ";", 
  RowBox[{"sp", "//", "MatrixForm"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sm", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Dagger", "[", "sp", "]"}], ".", "Ry"}], "//", "Simplify"}]}], ";",
   " ", 
  RowBox[{"sm", "//", "MatrixForm"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->296771054,ExpressionUUID->"89ea4ae5-3eb4-4e39-bbd8-81343e092afc"],

