Cell[TextData[{
 "For a Gelfand pattern,\[LineSeparator]    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", "m", ")"}], "d"], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["m", 
         RowBox[{"d", "\[InvisibleSpace]", "1"}]], 
        SubscriptBox["m", 
         RowBox[{"d", "\[InvisibleSpace]", "2"}]], "\[Ellipsis]", 
        SubscriptBox["m", 
         RowBox[{"d", "\[VeryThinSpace]", "d"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[AscendingEllipsis]", 
        " "},
       {
        SubscriptBox["m", 
         RowBox[{"2", "\[InvisibleSpace]", "1"}]], 
        SubscriptBox["m", 
         RowBox[{"2", "\[InvisibleSpace]", "2"}]], " ", " "},
       {
        SubscriptBox["m", 
         RowBox[{"1", "\[InvisibleSpace]", "1"}]], " ", " ", " "}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "89fdfd6e-24a0-46a4-9ce7-170205365f99"],
 ",\[LineSeparator]the partial hooks are given by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["p", "ij"], "=", 
    RowBox[{
     SubscriptBox["m", "ij"], "+", 
     RowBox[{"(", 
      RowBox[{"i", "-", "j"}], ")"}]}]}],
   FontSlant->"Italic"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cc8e06d0-cca8-450e-96e7-7eebc97e65b4"],
 "."
}], "Notes",
 CellID->1638969956,ExpressionUUID->"d09a348e-e822-4125-bb5e-14958b670f02"],

Cell[TextData[{
 "Note that the indices of entries are reversed compared with the convention \
of ",
 ButtonBox["Louck (2008)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1142/6863"], None}],
 " or  ",
 ButtonBox["Biedenharn and Louck (1968)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://projecteuclid.org/journals/communications-in-mathematical-\
physics/volume-8/issue-2/A-pattern-calculus-for-tensor-operators-in-the-\
unitary-groups/cmp/1103840555.full"], None}],
 ". There, the entries are referred to as\[LineSeparator]    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", "m", ")"}], "d"], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["m", 
         RowBox[{"1", "d"}]], 
        SubscriptBox["m", 
         RowBox[{"2", "d"}]], "\[Ellipsis]", 
        SubscriptBox["m", 
         RowBox[{"d", "\[VeryThinSpace]", "d"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[AscendingEllipsis]", 
        " "},
       {
        SubscriptBox["m", "12"], 
        SubscriptBox["m", 
         RowBox[{"2", "\[InvisibleSpace]", "2"}]], " ", " "},
       {
        SubscriptBox["m", 
         RowBox[{"1", "\[InvisibleSpace]", "1"}]], " ", " ", " "}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d85616e3-b5b1-44a7-8839-c3d4cca98d31"],
 ".\[LineSeparator]In this case, the partial hooks are given by ",
 Cell[BoxData[
  StyleBox[
   RowBox[{
    SubscriptBox["p", "ij"], "=", 
    RowBox[{
     SubscriptBox["m", "ij"], "+", 
     RowBox[{"(", 
      RowBox[{"j", "-", "i"}], ")"}]}]}],
   FontSlant->"Italic"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c3299151-ccdd-45a6-bcd7-b44c7372dfe1"],
 "."
}], "Notes",
 CellID->694391809,ExpressionUUID->"db1b99d3-e301-48cd-8e37-abb31883e3c2"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

