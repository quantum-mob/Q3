Cell[TextData[{
 "The ",
 StyleBox["Young distance",
  FontSlant->"Italic"],
 " between two boxes is the number of steps needed to go up plus number of \
steps to the right minus number of steps to the left minus number of steps \
down. It can be seen easily that this does not\ndepend on the path taken. "
}], "Notes",
 CellID->1160435881,ExpressionUUID->"eb185f70-d180-4a73-ad4c-b98e61859508"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "x"], TraditionalForm]],ExpressionUUID->
  "a083329a-95dc-4f6a-9d5b-b6eaf3851da9"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "x"], TraditionalForm]],ExpressionUUID->
  "c2050ad6-26b6-4056-9863-4f1f9f6da2d9"],
 " be the row and column numbers of integer ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "3173f278-8505-472b-97e3-40c2c2a660f1"],
 " in the standard Young tableau. Then, the Young distance ",
 Cell[BoxData[
  FormBox[
   RowBox[{"D", "(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]],ExpressionUUID->
  "56da0834-d0c3-455c-b12b-070b4b7ea8c1"],
 " from ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "5c9aaed9-a22b-4243-bef9-1907150bcc6b"],
 " to ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "97790c22-73bc-4738-9e60-133b329cbf66"],
 " is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"D", "(", 
     RowBox[{"x", ",", "y"}], ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["c", "y"], "-", 
        SubscriptBox["r", "y"]}], ")"}], "-", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["c", "x"], "-", 
        SubscriptBox["r", "x"]}], ")"}]}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["r", "x"], "-", 
        SubscriptBox["c", "x"]}], ")"}], "-", 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["r", "y"], "-", 
        SubscriptBox["c", "y"]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"ff6dedc3-f3c5-4c83-8682-b923a412007d"],
 ".\[LineSeparator]Here, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "x"], "-", 
    SubscriptBox["r", "x"]}], TraditionalForm]],ExpressionUUID->
  "0878a62e-8e9d-4e89-aeca-ac3853a06374"],
 " is called the ",
 StyleBox["content",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "71d81729-3b20-415f-9110-72be7e0d2e2b"],
 " in the standard Young tableau."
}], "Notes",
 CellID->254986158,ExpressionUUID->"207e8f77-e917-4d53-8ee9-f187e13e766f"],

Cell[TextData[{
 "It is also known as the ",
 StyleBox["axial distance",
  FontSlant->"Italic"],
 " (",
 ButtonBox["Sagan, 2001",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-1-4757-6804-6"], None}],
 ") or ",
 StyleBox["Manhattan distance",
  FontSlant->"Italic"],
 " (",
 ButtonBox["Krovi, 2019",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.22331/q-2019-02-14-122"], None}],
 "). Note that the built-in function ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ManhattanDistance"]], "paclet:ref/ManhattanDistance"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5506fa59-5e2e-4e18-8ac1-ede9600df9a1"],
 " gives distance defined in a similar way, but it is always positive."
}], "Notes",
 CellID->1164409012,ExpressionUUID->"749a5328-beec-4947-82d8-0ceb9c5edda5"],

Cell[TextData[{
 "Unlike usual distance (or ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ManhattanDistance"]], "paclet:ref/ManhattanDistance"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4fb4e7cd-bbcb-4e5b-93d3-105d40683182"],
 "), it may be negative."
}], "Notes",
 CellID->26310414,ExpressionUUID->"b90c0b65-b3ea-4644-a3f1-5aa883cb7301"],

Cell[TextData[{
 "It is useful in the construction of ",
 StyleBox["Young's normal, seminormal and natural representations",
  FontSlant->"Italic"],
 " of the symmetric group (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Sagan, 2001, Exercise 2.11"]], 
    "https://doi.org/10.1007/978-1-4757-6804-6"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "dae87ec0-68bb-4fdd-b503-815991a1f023"],
 ")."
}], "Notes",
 CellID->173611647,ExpressionUUID->"86b27cb2-06d8-4520-b142-c3c456eff7dd"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

