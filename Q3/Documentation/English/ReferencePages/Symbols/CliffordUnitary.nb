Cell[TextData[{
 "The Clifford group is generated by the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CNOT"]], "paclet:QuantumMob/Q3/ref/CNOT", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "582fb718-db0b-4913-8e29-85e8c9f6c491"],
 ", ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ac11c20b-4028-4300-a46a-f79e8c74d441"],
 ", and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quadrant"]], "paclet:QuantumMob/Q3/ref/Quadrant", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "50945c26-d2fb-44e6-a0f7-cbcfcf7eef1f"],
 " gates. These elementary gates are particularly simple, and if a Clifford \
gate is known to be a simple combination of these, then it is faster to use \
them instead of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CliffordUnitary"]], "paclet:QuantumMob/Q3/ref/CliffordUnitary",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0296f9a9-0fc7-493e-9653-fb2f569fe090"],
 ". Below are some illustrations."
}], "ExampleText",
 CellID->1346228772,ExpressionUUID->"c6259a77-847b-4603-9cc8-fb7299b41630"],

