Cell[TextData[{
 "Internally, CliffordUnitary stores the full Gottesman matrix rather than \
the Clifford unitary matrix itself. To get the actually Clifford unitary \
matrix, use ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
