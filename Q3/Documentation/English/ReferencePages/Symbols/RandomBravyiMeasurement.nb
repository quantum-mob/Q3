Cell[TextData[{
 "Note that the dressed Dirac fermion modes ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["i", "TI"]], ":=", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalSigma]", "TR"], 
     StyleBox["j", "TI"]], "\[VeryThinSpace]", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["ij", "TI"]], "\[VeryThinSpace]", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["j", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "194ef77c-79a4-41d9-86a1-b4e214368583"],
 " in the resulting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMeasurement"]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["m", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e9d47c45-69d2-47e9-a5c6-3688ade6cdf6"],
 " are properly normalized; that is, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["b", "TI"], 
      StyleBox["i", "TI"]], ",", 
     SubsuperscriptBox[
      StyleBox["b", "TI"], 
      StyleBox["j", "TI"], "\[Dagger]"]}], "}"}], "=", 
   SubscriptBox[
    StyleBox["\[Delta]", "TR"], 
    StyleBox["ij", "TI"]]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2f0844f3-1b8e-4ad7-b499-dd28529b1190"],
 ". This implies that each row ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["m", "TI"], 
    StyleBox["i", "TI"]], ":=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["m", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["1", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     SubscriptBox[
      StyleBox["m", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["2", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "44c8ad5f-3218-4ff2-8bd7-8f479556eabc"],
 " of matrix ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1ce136f3-8ebc-41bd-b49d-cdc8865cd236"],
 " is normalized such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"], "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "9f1a2358-827c-4251-ba0f-52b81c16aec4"],
 " (not 1) for each ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "911792e3-b875-4d23-9d69-f28ba3deba91"],
 "."
}], "Notes",
 CellID->1239757124,ExpressionUUID->"1c97fb49-2274-4e62-a168-388064f3ac67"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

