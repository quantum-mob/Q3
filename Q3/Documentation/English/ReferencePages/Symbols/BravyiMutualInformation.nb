Cell["\<\
The mutual information can also be calculated as the difference between the \
sum of entropies of the subsystems and the entropy of the whole system.\
\>", "ExampleText",
 CellID->6140780,ExpressionUUID->"6412b162-e8d4-4a9d-9b9b-61ce3c96b1bd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sa", "=", 
   RowBox[{"BravyiEntanglementEntropy", "[", 
    RowBox[{"grn", ",", "kk"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sb", "=", 
   RowBox[{"BravyiEntanglementEntropy", "[", 
    RowBox[{"grn", ",", "ll"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ss", "=", 
   RowBox[{"BravyiEntanglementEntropy", "[", 
    RowBox[{"grn", ",", 
     RowBox[{"Range", "@", "$n"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"new", "=", 
  RowBox[{"sa", "+", "sb", "-", "ss"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->454527552,ExpressionUUID->"9f3b7a05-c975-4161-8176-d870a69a92ab"],

Cell[BoxData["0.6468548017171578`"], "Output",
 CellLabel->"Out[8]=",
 CellID->439696933,ExpressionUUID->"c2d29c4f-0638-40de-b35d-a5ebb3986dae"]
}, Open  ]],

