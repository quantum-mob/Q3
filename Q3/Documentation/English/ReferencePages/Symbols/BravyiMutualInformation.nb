Cell["\<\
Since the Bravyi state is a pure state, the mutual information must be equal \
to twice the entropy of the subsystem.\
\>", "ExampleText",
 CellID->1731062626,ExpressionUUID->"ae66df70-a556-4114-9e61-8fc99824aea7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"val", "-", 
   RowBox[{"2", "*", "ent"}]}], "//", "Chop"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
 CellID->296409719,ExpressionUUID->"93ee9c7f-ddac-478e-95d5-f3cb81cf025f"],

Cell[BoxData["0"], "Output",
 CellLabel->"Out[10]=",
 CellID->1534374282,ExpressionUUID->"b826f0b7-c74a-4ec1-a140-22ff7ca0ca99"]
}, Open  ]]
