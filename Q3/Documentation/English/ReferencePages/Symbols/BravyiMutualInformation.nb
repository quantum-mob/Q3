Cell["Take a partitioning of the system into two parts.", "ExampleText",
 CellID->1783224744,ExpressionUUID->"9c4ef7be-5f9f-498b-9662-d46389cf3832"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"subsystem", " ", "A"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"ll", "=", 
  RowBox[{"Supplement", "[", 
   RowBox[{
    RowBox[{"Range", "@", "$n"}], ",", "kk"}], "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"subsystem", " ", "B"}], " ", "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1588931760,ExpressionUUID->"4998bebc-f0d4-43a8-ab7d-d08fe488d67d"],

Cell[BoxData[
 RowBox[{"{", 
