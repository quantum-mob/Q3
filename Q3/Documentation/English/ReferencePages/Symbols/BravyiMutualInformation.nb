 CellID->702632558,ExpressionUUID->"be9c06af-d3ff-4117-a28b-e1936a4c6b2f"]
}, Open  ]],

Cell["Calculate the mutual information between the two parts.", "ExampleText",
 CellID->851715453,ExpressionUUID->"4ea96221-be38-48cd-a657-ef9c683cd620"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"val", "=", 
  RowBox[{"BravyiMutualInformation", "[", 
