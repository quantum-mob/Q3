  "Openers" -> {
   "PrimaryExamplesSection" -> Open, "ExampleSection" -> {"0" -> Open}, 
    "AllOptsTable" -> Closed, "NotesSection" -> Closed}, "NewStyles" -> True, 
  "CitationPopupData" -> $Failed, "ShowCitation" -> False, "HasOptions" -> 
  True, "RootCaptions" -> "", "HeaderCoreAreaLink" -> {}, 
  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 58, 20.567523}", 
    "history" -> {"12", "13.3", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {}, "specialkeywords" -> {}, 
    "tutorialcollectionlinks" -> {}, "index" -> True, "label" -> 
    "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> "QuantumMob/Q3",
     "status" -> "None", "summary" -> 
    "ThePauli[{m1, m2, ..., mn}] returns the tensor product of Pauli \
matrices. It is equivalent to \
ThePauli[m1]\\[CircleTimes]ThePauli[m2]\\[CircleTimes]...\\[CircleTimes]\
ThePauli[mn]. ThePauli[0] returns the 2*2 identity matrix. It is the matrix \
representation of Pauli[0]. ThePauli[1], ThePauli[2], and ThePauli[3] return \
the three Pauli matrices, respectively. They are the matrix representation of \
Pauli[1], Pauli[2], and Pauli[3], respectively. ThePauli[4] and ThePauli[5] \
return the raising and lowering matrix, respectively. They are the matrix \
representation of Pauli[4] and Pauli[5]. ThePauli[6] returns the Hadamard \
matrix, and is the matrix representation of Pauli[6]. ThePauli[7], \
ThePauli[8], and ThePauli[9] return the matrix representation of the quadrant \
(2 \\[Pi]/4), octant (2 \\[Pi]/8), and hexadecant (2 \\[Pi]/16) phase gates, \
respectively. ThePauli[C[-n]] returns the matrix representation of phase gate \
by phase 2 \\[Pi]/2^n.", "synonyms" -> {}, "tabletags" -> {}, "title" -> 
    "ThePauli", "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "ThePauli", "type" -> "Symbol", "uri" -> "QuantumMob/Q3/ref/ThePauli"}},
