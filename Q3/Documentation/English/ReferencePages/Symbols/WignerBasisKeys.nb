Cell[TextData[{
 "The Hilbert space ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
    SuperscriptBox["\[ScriptCapitalH]", 
     RowBox[{"(", "s", ")"}]]}], TraditionalForm]],ExpressionUUID->
  "1d6a0ed9-28b7-4b8a-a547-c2b942ea5f4f"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e4d02387-c940-4d77-9a50-94b68ada9089"],
 " spins of spin ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "42f9e5bc-cf6b-496a-8a99-27af1e29d524"],
 " is decomposed into \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]]}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "j"], 
     RowBox[{
      SubscriptBox["m", "j"], 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "j", ")"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "e878e841-11ef-4d44-bb2c-2e705e0b9ff5"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "j"], TraditionalForm]],ExpressionUUID->
  "25bf181f-8b4d-44ad-82de-9a7ed359b17a"],
 " is the multiplicity factor of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalH]", 
    RowBox[{"(", "j", ")"}]], TraditionalForm]],ExpressionUUID->
  "c1e6dc36-87bc-4aae-95fc-0fe2f6e0979e"],
 " for the total spin ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "3fca74bf-e202-4382-bd38-86fa22184527"],
 ". This is achieved by adding spins one by one. Then, the basis vectors of \
the multiplicity space is labeled by a list of intermediate total spins ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["n", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6f934cec-e20e-489f-bd75-6abf4cbe6e26"],
 "."
}], "Notes",
 CellID->475111707,ExpressionUUID->"40c4061a-a6ed-4580-8ca2-e2e64872f731"],

Cell[TextData[{
 "The returned association has key-value pairs of the form\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["j", "1"], ",", 
      SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["j", "n"]}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          SubscriptBox["j", "n"]}]},
       "Ket"], ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{
            SubscriptBox["j", "n"], "-", "1"}]}]},
       "Ket"], ",", "\[Ellipsis]", ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{"-", 
            SubscriptBox["j", "n"]}]}]},
       "Ket"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "419bd843-e5f2-4fc2-97d7-9afd65775d3e"],
 " ."
}], "Notes",
 CellID->578231079,ExpressionUUID->"134e2550-4103-466f-a3ed-fe32276c6c3b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

