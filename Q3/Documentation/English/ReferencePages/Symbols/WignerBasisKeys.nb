Cell[TextData[{
 "The Hilbert space ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
    SuperscriptBox["\[ScriptCapitalH]", 
     RowBox[{"(", "s", ")"}]]}], TraditionalForm]],ExpressionUUID->
  "8ab7fae8-e1e8-4fb2-bbb7-8a59949efdcd"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "407ca72e-2133-4b34-9ed6-67486c6dcbec"],
 " spins of spin ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a409e21f-f259-44b4-9bac-21501ca6927b"],
 " is decomposed into \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]]}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "j"], 
     RowBox[{
      SubscriptBox["m", "j"], 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "j", ")"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "47157737-c627-42c8-9e77-a6755e94d31d"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "j"], TraditionalForm]],ExpressionUUID->
  "f9d10ef6-10b6-4e4d-b1cf-76119db11300"],
 " is the multiplicity factor of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalH]", 
    RowBox[{"(", "j", ")"}]], TraditionalForm]],ExpressionUUID->
  "3c198cc7-7d7a-4fde-9885-0342c2b14ea5"],
 " for the total spin ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "5f55a776-2fcb-4295-888b-fea63836fd95"],
 ". This is achieved by adding spins one by one. Then, the basis vectors of \
the multiplicity space is labeled by a list of intermediate total spins ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["n", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f2ed82fb-bf0b-453f-ad54-87df9a89c8b0"],
 "."
}], "Notes",
 CellID->475111707,ExpressionUUID->"ec348ab5-64fa-46dd-9426-b4b92c6c1ccc"],

Cell[TextData[{
 "The returned association has key-value pairs of the form\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["j", "1"], ",", 
      SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["j", "n"]}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          SubscriptBox["j", "n"]}]},
       "Ket"], ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{
            SubscriptBox["j", "n"], "-", "1"}]}]},
       "Ket"], ",", "\[Ellipsis]", ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{"-", 
            SubscriptBox["j", "n"]}]}]},
       "Ket"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "6aaf6b03-16c7-4965-99d9-849959bc0372"],
 " ."
}], "Notes",
 CellID->578231079,ExpressionUUID->"28db7d7a-205e-4c14-9fd3-707166e2b74e"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

