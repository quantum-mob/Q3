Cell[TextData[{
 StyleBox["Lexicographic ordering of Gelfand patterns",
  FontSlant->"Italic"],
 " are defined according to that of corresponding Young tableaux.  "
}], "Notes",
 CellID->775309876,ExpressionUUID->"478d4727-9bb9-4a08-93f8-c02beff28a61"],

Cell[TextData[{
 StyleBox["Lexicographic ordering of Young shapes",
  FontSlant->"Italic"],
 ": Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "l"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ea5ae6c9-b9a1-4612-a87e-61e76bdec23e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "m"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "033f814a-3df6-4d57-acd9-26afc1246cd3"],
 " be partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "abc49f06-f2ba-4d6e-b1e7-f424ff8b0f92"],
 ". Then, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "<", "\[Mu]"}], TraditionalForm]],ExpressionUUID->
  "77ff6424-142c-40a7-8dfd-c11d35852952"],
 " in lexicographic order if, for some index ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "509a6ccc-f2ac-4111-aa60-61ab9b60db58"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "i"], "=", 
    SubscriptBox["\[Mu]", "i"]}], TraditionalForm]],ExpressionUUID->
  "736cc212-93eb-4092-8257-6a6c4f49ee26"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "<", "j"}], TraditionalForm]],ExpressionUUID->
  "4c2f1315-e5fa-4677-a686-6fa1731733ec"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "j"], "<", 
    SubscriptBox["\[Mu]", "j"]}], TraditionalForm]],ExpressionUUID->
  "6d4dffdf-ce43-44b3-ab69-9b5dfb1d22ef"],
 "."
}], "Notes",
 CellID->542711600,ExpressionUUID->"26ec542f-b27e-41e8-9771-40718e3ddb0f"],

Cell[TextData[{
 "Note that if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "\[LeftTriangleEqual]", "\[Mu]"}], TraditionalForm]],
  ExpressionUUID->"6833e838-74ee-467f-bd23-a2b7fa7b7fce"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "\[LessEqual]", "\[Mu]"}], TraditionalForm]],
  ExpressionUUID->"768ef45e-129c-4423-9a71-5bc825f64ba2"],
 "."
}], "Notes",
 CellID->501225389,ExpressionUUID->"47710b33-8109-470f-a99a-56bce4c79de8"],

Cell[TextData[{
 StyleBox["Lexicographic ordering of Young tableaux",
  FontSlant->"Italic"],
 ": Let ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "e91a2089-3526-498c-8f73-2aea0494e544"],
 " and ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "50763694-ee69-4fd7-9a35-34881187ffda"],
 " be two Young tableaux. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "<", "T"}], TraditionalForm]],ExpressionUUID->
  "3a4ccd2a-5004-42ee-b4fa-952994824f95"],
 " in lexicographic order if (i) ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"shape", "(", "S", ")"}], ">", 
    RowBox[{"shape", "(", "T", ")"}]}], TraditionalForm]],ExpressionUUID->
  "80c1247d-4d4c-4498-a111-869b83759a88"],
 "; (ii) ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "9a93329d-c311-4d2c-ae87-ae7da4c6767e"],
 " and ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "ef98aecd-2a9b-4f69-9777-a6b9dd6d6d99"],
 " have the same shape and the largest entry that appears in a different box \
in the two tableaux occurs earlier in ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "109156e8-0169-4d76-ad67-1083c8b5a25d"],
 " than in ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "24adc3d5-6b76-4b31-93be-48ed7dc748c1"],
 ", whereby we list the entries from the left to right in each row starting \
in the top row and moving to the bottom. See Pauncz (1995a, Section 3.2)."
}], "Notes",
 CellID->1900010238,ExpressionUUID->"db6ccbf8-45d4-44f1-a7f1-7cf5d1a73880"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

