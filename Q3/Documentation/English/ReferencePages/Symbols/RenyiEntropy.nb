Cell["\<\
In information theory, R\[EAcute]nyi entropy generalizes various forms of \
entropy, such as Hartley entropy and Shannon entropy to quantify information \
while maintaining additivity for independent events. It is named after Alfr\
\[EAcute]d R\[EAcute]nyi.\
\>", "Notes",
 CellID->452446872,ExpressionUUID->"2f0a0ffd-0049-4dce-9e6c-c8d012c06762"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "d2def168-ea01-4d72-9917-e7cf5c2c5bd5"],
 " be a random variable that takes values in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["x", "1"], ",", 
     SubscriptBox["x", "2"], ",", "\[Ellipsis]"}], "}"}], TraditionalForm]],
  ExpressionUUID->"54496d34-b13f-43f5-900e-7e959b28c35d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "1"], ",", 
    SubscriptBox["p", "2"], ",", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"724e6df7-d1fa-4d25-983e-aa34dfcdf9de"],
 " be the corresponding probabilities. Then, the R\[EAcute]nyi entropy of \
order ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "a17260f1-d86c-40c5-a50c-664ba6e3f877"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["H", "\[Alpha]"], "(", "X", ")"}], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"1", "-", "\[Alpha]"}]], 
     RowBox[{"log", "(", 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "k"], 
       SubsuperscriptBox["p", "k", "\[Alpha]"]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"85c19c61-37ae-4e23-8843-28758f22c1fc"],
 " ,\[LineSeparator]or, equivalently,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", "\[Alpha]"], "=", 
    RowBox[{
     FractionBox["\[Alpha]", 
      RowBox[{"1", "-", "\[Alpha]"}]], 
     RowBox[{"log", "(", 
      SubscriptBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        StyleBox["p",
         FontWeight->"Bold"], "\[RightDoubleBracketingBar]"}], "\[Alpha]"], 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "4e9d06e6-8646-419f-b36b-ad94ae2bb764"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"\[LeftDoubleBracketingBar]", 
     StyleBox["p",
      FontWeight->"Bold"], "\[RightDoubleBracketingBar]"}], "\[Alpha]"], 
   TraditionalForm]],ExpressionUUID->"5bd3c174-9f8d-428e-84e1-6ec655c1e2f6"],
 " is the \[Alpha]-norm of vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["p",
     FontWeight->"Bold"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["p", "1"], ",", 
      SubscriptBox["p", "2"], ",", "\[Ellipsis]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"48e03d2f-883c-47f8-998d-d66b1589283e"],
 "."
}], "Notes",
 CellID->426967667,ExpressionUUID->"7f1dd63d-cc39-408b-a5be-5bf23e0f165b"],

Cell[TextData[{
 "The R\[EAcute]nyi divergence (or  ",
 StyleBox["relative R\[EAcute]nyi entropy",
  FontSlant->"Italic"],
 ") of random variable ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "588858f7-3ce7-4c84-b1a4-3230059452d4"],
 " with respect to another random variable ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "be6406d4-f96d-4ebe-abc1-d9b82be084ac"],
 " is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["H", "\[Alpha]"], "(", 
      RowBox[{"X", "||", "Y"}], ")"}], "\[Congruent]", 
     RowBox[{
      SubscriptBox["H", "\[Alpha]"], "(", 
      RowBox[{
       RowBox[{"{", 
        SubscriptBox["p", "i"], "}"}], "||", 
       RowBox[{"{", 
        SubscriptBox["q", "j"], "}"}]}], ")"}]}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"1", "-", "a"}]], 
     RowBox[{"log", "(", 
      RowBox[{
       SubscriptBox["\[Sum]", "k"], 
       RowBox[{
        SubsuperscriptBox["p", "k", "a"], 
        SubsuperscriptBox["q", "k", 
         RowBox[{"1", "-", "a"}]]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"986f80db-2e1d-4882-8825-9ba9cdc7a059"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["p", "i"], "}"}], TraditionalForm]],ExpressionUUID->
  "88711c90-4681-472e-bbd7-8243b90dc683"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["q", "j"], "}"}], TraditionalForm]],ExpressionUUID->
  "37d2e15f-b151-420d-a883-d53934c428c6"],
 " are probability distributions of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "df6e4489-f03a-411c-a39f-3b16a96ff472"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "62cf8e0a-3af8-4d32-b52a-7e8d382bf560"],
 ", respectively. Sometimes, the R\[EAcute]nyi divergence is denoted by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["D", "\[Alpha]"], "(", 
     RowBox[{"X", "||", "Y"}], ")"}], "\[Congruent]", 
    RowBox[{
     SubscriptBox["D", "\[Alpha]"], "(", 
     RowBox[{
      RowBox[{"{", 
       SubscriptBox["p", "i"], "}"}], "||", 
      RowBox[{"{", 
       SubscriptBox["q", "j"], "}"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"b68fc628-9751-40ef-9d9c-1cb8f4c148d7"],
 "."
}], "Notes",
 CellID->740947698,ExpressionUUID->"a7dffe35-7368-496e-b52d-096e510a5197"],

Cell[TextData[{
 "For a density matrix ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "eca0a9bc-6b4b-4967-97a6-b85c206bdf65"],
 " of a quantum system, the R\[EAcute]nyi entropy of order \[Alpha] is given \
by \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["S", "\[Alpha]"], "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"1", "-", "\[Alpha]"}]], 
     RowBox[{"log", "(", 
      RowBox[{"Tr", "\[VeryThinSpace]", 
       SuperscriptBox["\[Rho]", "\[Alpha]"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"84f9ad0f-5746-44e4-b525-0ffad8b6b383"],
 "."
}], "Notes",
 CellID->1961395583,ExpressionUUID->"5c794a48-246e-4a37-91df-ac7f65c08831"],

Cell[TextData[{
 "The ",
 StyleBox["quantum R\[EAcute]nyi divergence",
  FontSlant->"Italic"],
 " (or ",
 StyleBox["relative quantum R\[EAcute]nyi entropy",
  FontSlant->"Italic"],
 ") of density matrix \[Rho] with respect to another density matrix \[Sigma] \
is defined by \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["S", "\[Alpha]"], "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"\[Alpha]", "-", "1"}]], 
     RowBox[{"log", "(", 
      RowBox[{"Tr", "[", 
       RowBox[{
        SuperscriptBox["\[Rho]", "\[Alpha]"], 
        SuperscriptBox["\[Sigma]", 
         RowBox[{"1", "-", "\[Alpha]"}]]}], "]"}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"13b17f53-9d62-48b1-a027-ab42c313743f"],
 ".\[LineSeparator]More precisely, this definition is just one kind of \
quantum R\[EAcute]nyi divergence called the ",
 StyleBox["Petz quantum R\[EAcute]nyi divergence",
  FontSlant->"Italic"],
 " (or simply Petz-R\[EAcute]nyi divergence); see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Tomamichel (2016)"]], 
    "https://doi.org/10.1007/978-3-319-21891-5"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "6a620f5a-de0b-461a-8124-f74786153475"],
 ". This is the value ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["RenyiEntropy"]], "paclet:QuantumMob/Q3/ref/RenyiEntropy", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["\[Alpha]", "TR"], ",", 
    StyleBox["\[Rho]", "TR"], ",", 
    StyleBox["\[Sigma]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ee7394b1-5452-4251-8c48-d6c1b4f44ee1"],
 " returns. Sometimes, it is denoted by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["D", "\[Alpha]"], "(", 
    RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], 
   TraditionalForm]],ExpressionUUID->"37d727ef-2ffe-4683-96ab-5fc275e4162c"],
 "."
}], "Notes",
 CellID->153265383,ExpressionUUID->"a0f75919-5c12-4ac0-9adb-2141096c8f3f"],

Cell[TextData[{
 "The ",
 StyleBox["minimal quantum R\[EAcute]nyi divergence ",
  FontSlant->"Italic"],
 " is defined by \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["S", "\[Alpha]"], "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"\[Alpha]", "-", "1"}]], 
     RowBox[{"log", "(", 
      RowBox[{"Tr", "[", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["\[Sigma]", 
           FractionBox[
            RowBox[{"1", "-", "\[Alpha]"}], 
            RowBox[{"2", "\[Alpha]"}]]], "\[Rho]", "\[VeryThinSpace]", 
          SuperscriptBox["\[Sigma]", 
           FractionBox[
            RowBox[{"1", "-", "\[Alpha]"}], 
            RowBox[{"2", "\[Alpha]"}]]]}], ")"}], "\[Alpha]"], "]"}], 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "02925925-e4a4-4e0f-8a76-0f1ddd071964"],
 ".\[LineSeparator]The ",
 StyleBox["maximal quantum R\[EAcute]nyi divergence",
  FontSlant->"Italic"],
 " is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["S", "\[Alpha]"], "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"\[Alpha]", "-", "1"}]], 
     RowBox[{"log", "(", 
      RowBox[{"Tr", "[", 
       RowBox[{
        SuperscriptBox[
         RowBox[{
          SuperscriptBox["\[Sigma]", 
           FractionBox["1", "2"]], "(", 
          RowBox[{
           SuperscriptBox["\[Sigma]", 
            RowBox[{"-", 
             FractionBox["1", "2"]}]], "\[Rho]", "\[VeryThinSpace]", 
           SuperscriptBox["\[Sigma]", 
            RowBox[{"-", 
             FractionBox["1", "2"]}]]}], ")"}], "\[Alpha]"], 
        SuperscriptBox["\[Sigma]", 
         FractionBox["1", "2"]]}], "]"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"42ec3c21-1957-4f5f-bef1-608dadf17e60"],
 ".\[LineSeparator]It is known that the any quantum generalization of \
(classical) R\[EAcute]yi divergence must lie between the minimal and maximal \
R\[EAcute]nyi divergences ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Tomamichel, 2016)"]], 
    "https://doi.org/10.1007/978-3-319-21891-5"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "249df91c-5994-40f4-9f10-c870b0eb34b6"],
 "."
}], "Notes",
 CellID->1784617654,ExpressionUUID->"11e8a1fa-1495-43c5-924f-9761766e7f80"],

Cell["\<\
The quantum R\[EAcute]nyi divergence diverges unless the support of \[Rho] \
(i.e, the subspace belonging to non-zero eigenvalues of \[Rho]) is a subspace \
of the support of \[Sigma].\
\>", "Notes",
 CellID->2129319806,ExpressionUUID->"9917fcfb-d3ce-4359-82cb-458ccdd2a280"],

Cell[TextData[{
 "The classical or quantum R\[EAcute]nyi divergence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["S", "\[Alpha]"], "(", 
    RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], 
   TraditionalForm]],ExpressionUUID->"7d800296-bdc9-4098-b6a8-2988faf18991"],
 ", as a function of order ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "483cabfa-32aa-4b10-b9a2-4872fc5eec2e"],
 " (cf. ",
 StyleBox["monotonicity",
  FontSlant->"Italic"],
 " under completely positive and trace preserving supermaps), is \
monotonically increasing. Moreover, it is strictly increasing unless ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", "\[Sigma]"}], TraditionalForm]],ExpressionUUID->
  "6efddfe5-41bb-47de-bc64-381f71a375f5"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Tomamichel, 2016)"]], 
    "https://doi.org/10.1007/978-3-319-21891-5"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "75318f30-7891-4fb5-9f5a-0e9552204516"],
 "."
}], "Notes",
 CellID->808912676,ExpressionUUID->"566a9b00-bdde-4abb-84a3-23fd63d145c1"],

Cell[TextData[{
 StyleBox["Monotonicity",
  FontSlant->"Italic"],
 ": The quantum R\[EAcute]nyi entropy is a ",
 StyleBox["monotone",
  FontSlant->"Italic"],
 " in the sense that for any completely-positive and trace-preserving (CPTP) \
supermap"
}], "Notes",
 CellID->367035169,ExpressionUUID->"7cfa0183-e4df-4533-ae12-5f9239419265"],

Cell[TextData[{
 StyleBox["Monotonicity",
  FontSlant->"Italic"],
 ": The quantum R\[EAcute]nyi entropy is a ",
 StyleBox["monotone",
  FontSlant->"Italic"],
 " in the sense that for any completely-positive and trace-preserving (CPTP) \
supermap ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "d87954ee-b3e7-458b-a385-be61da7df54a"],
 " and for all density operators  ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "c0f1c305-c6db-4602-bb6c-c1e86780a9d0"],
 " and \[Sigma],\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["S", "\[Alpha]"], "(", 
     RowBox[{"\[Rho]", "||", "\[Sigma]"}], ")"}], "\[GreaterEqual]", 
    RowBox[{
     SubscriptBox["S", "\[Alpha]"], "(", 
     RowBox[{
      RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "||", 
      RowBox[{"\[ScriptCapitalF]", "(", "\[Sigma]", ")"}]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"2d3de576-fd92-4dce-9cc1-7f353697ced0"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", "\[Alpha]", "\[LessEqual]", "2"}], 
   TraditionalForm]],ExpressionUUID->"cb3717ab-7d1b-407f-b38b-c21908d6645c"],
 ".\[LineSeparator]The monotonicity does not holds for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", ">", "2"}], TraditionalForm]],ExpressionUUID->
  "b8d02313-f1f4-469e-8a6b-a8f6ac075b7b"],
 " (the monotonicity under measurements still holds for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", ">", "2"}], TraditionalForm]],ExpressionUUID->
  "1c45117b-16b6-4853-a005-4d3fb7f5c306"],
 ", though; see Hayashi (2006, 2017)). On the other hand, the ",
 StyleBox["minimal quantum R\[EAcute]nyi divergence",
  FontSlant->"Italic"],
 " is a monotone for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"1", "/", "2"}], "\[LessEqual]", "\[Alpha]", "<", "\[Infinity]"}],
    TraditionalForm]],ExpressionUUID->
  "c05b92f4-5ad4-4717-a003-398164e457fc"],
 "."
}], "Notes",
 CellID->830892517,ExpressionUUID->"469b910d-8e3b-4942-a6e9-8ccd512b44b1"],

Cell[TextData[{
 StyleBox["Positivity",
  FontSlant->"Italic"],
 ": The quantum R\[EAcute]nyi entropy is positive,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["S", "\[Alpha]"], "(", 
     RowBox[{"\[Rho]", "||", "\[Sigma]"}], ")"}], "\[GreaterEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"201d258b-c7bb-4f7d-9a59-9911d68bc757"],
 " for all ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "1d600a2f-29e7-4e76-9244-51064d284887"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", "\[Alpha]", "<", "\[Infinity]"}], 
   TraditionalForm]],ExpressionUUID->"9a1dd7a2-a72e-4db2-8eaa-e17c44d71b07"],
 ").\nOn the other hand, the ",
 StyleBox["minimal quantum R\[EAcute]nyi divergence",
  FontSlant->"Italic"],
 " is  positive for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"1", "/", "2"}], "\[LessEqual]", "\[Alpha]", "<", "\[Infinity]"}],
    TraditionalForm]],ExpressionUUID->
  "1b8fa366-8746-4ca6-9d9a-17a39fd9ba36"],
 "."
}], "Notes",
 CellID->832897390,ExpressionUUID->"c5a98754-1dcd-4cba-a7e8-9d4642e115f0"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

