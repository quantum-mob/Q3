 RowBox[{
  RowBox[{"rho", "=", 
   RowBox[{"RandomPositive", "[", "3", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rho", "/=", 
   RowBox[{"Tr", "[", "rho", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "rho", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->2141358110,ExpressionUUID->"0dd19fd2-efb6-46fa-afcc-caad816bf9fe"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"0.3316396599846966`", "\[VeryThinSpace]", "+", 
       RowBox[{"0.`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{
       RowBox[{"-", "0.04578517199059683`"}], "-", 
       RowBox[{"0.030422416085172724`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{"0.0024829713776486203`", "\[VeryThinSpace]", "+", 
       RowBox[{"0.04908491646308531`", " ", "\[ImaginaryI]"}]}]},
     {
      RowBox[{
       RowBox[{"-", "0.04578517199059683`"}], "+", 
       RowBox[{"0.030422416085172724`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{"0.3985134338526475`", "\[VeryThinSpace]", "+", 
       RowBox[{"0.`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{
       RowBox[{"-", "0.2446577860783075`"}], "-", 
       RowBox[{"0.09970468992622417`", " ", "\[ImaginaryI]"}]}]},
     {
      RowBox[{"0.0024829713776486203`", "\[VeryThinSpace]", "-", 
       RowBox[{"0.04908491646308531`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{
       RowBox[{"-", "0.2446577860783075`"}], "+", 
       RowBox[{"0.09970468992622417`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{"0.2698469061626558`", "\[VeryThinSpace]", "+", 
       RowBox[{"0.`", " ", "\[ImaginaryI]"}]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
