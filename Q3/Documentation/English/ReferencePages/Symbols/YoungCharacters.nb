Cell[TextData[{
 "The rows (irreducible representations) and columns (conjugacy classes) are \
arranged in the same way as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c86dd02f-bfe6-4390-bc04-329c6acdc1b5"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Reverse"]], "paclet:ref/Reverse"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "20c145cd-8751-4ec1-a0eb-084008786c0f"],
 ", respectively. Note that ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ReverseSort"]], "paclet:ref/ReverseSort"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "26658fbd-4482-41af-9831-015b37c94854"],
 " is not the same as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Reverse"]], "paclet:ref/Reverse"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "809e7699-41b8-490b-94fe-f22684b9690a"],
 " because ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c6397892-c75b-4e0a-8367-29fb93cd64dc"],
 " is ",
 StyleBox["not",
  FontSlant->"Italic"],
 " lexicographically ordered."
}], "Notes",
 CellID->2002532819,ExpressionUUID->"f08fdcdc-cb62-4681-a61c-57e11d93d683"],

