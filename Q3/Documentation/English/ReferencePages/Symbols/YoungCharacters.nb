Cell[TextData[{
 "A ",
 StyleBox["cycle decomposition",
  FontSlant->"Italic"],
 " of a permutation is an expression of the permutation as a product of \
disjoint cycles, where each cycle represents a cyclic rearrangement of \
elements. This decomposition is unique up to the order of the cycles and \
cyclic rotations within each cycle."
}], "Notes",
 CellID->442409035,ExpressionUUID->"261a8aa2-9fa8-41c0-b9dc-908fe1e49060"],

Cell[TextData[{
 "The ",
 StyleBox["cycle decomposition type",
  FontSlant->"Italic"],
 " of a permutation of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f96320fb-c0e6-452e-8261-c1521b2c373b"],
 " elements is a list of the lengths of the cycles in its cycle \
decomposition. By convention, a cycle decomposition type is arranged in \
decreasing order, and is a partition of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "8203d113-5775-47e3-8aae-12e1651d18e0"],
 "."
}], "Notes",
 CellID->827090356,ExpressionUUID->"03e8b640-8178-4d32-b28d-6aa5eba47184"],

Cell[TextData[{
 StyleBox["Conjugacy classes",
  FontSlant->"Italic"],
 " in the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "4dc8b3d3-e91f-4339-839e-33963ddf0471"],
 " are uniquely determined by the ",
 StyleBox["cycle decomposition type",
  FontSlant->"Italic"],
 " of permutations. Hence, like irreducible representations of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "239ee818-bcc8-448f-bd74-325b550e4d60"],
 ", conjugacy classes in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "cee58b24-eb5b-472e-8d3d-be0681d06a16"],
 " are in one-to-one correspondence to partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f13634f0-07a7-40d4-bbb6-b58eda38d077"],
 "."
}], "Notes",
 CellID->285452206,ExpressionUUID->"dcfa0266-2b32-4374-89e3-6c73223341e1"],

Cell[TextData[{
 "The rows (irreducible representations) and columns (conjugacy classes) are \
arranged in the same way as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4645d678-9f91-4dcd-8dce-8cdd5d1830e2"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Reverse"]], "paclet:ref/Reverse"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "531c8292-b186-4cb4-88ba-61c8a7d9bf05"],
 ", respectively. Note that ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ReverseSort"]], "paclet:ref/ReverseSort"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2827231d-b1ef-4312-b24d-af0a5d2ddf42"],
 " is not the same as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Reverse"]], "paclet:ref/Reverse"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6412f88e-a463-4e0e-8c76-50392e1c3a6b"],
 " because ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "22bf20d9-c3f8-4f67-9b6e-4d28cfa9799c"],
 " is ",
 StyleBox["not",
  FontSlant->"Italic"],
 " lexicographically ordered."
}], "Notes",
 CellID->2010759369,ExpressionUUID->"bfa22995-36a8-4a2b-902a-3fd0779992fa"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungCharacters"]], "paclet:QuantumMob/Q3/ref/YoungCharacters",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9748133f-4013-4723-ad5c-9728b8bb334b"],
 " uses the MNinner algorithm by ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Bernstein (2004)"]], 
    "https://doi.org/10.1016/j.jsc.2003.11.001"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "90a758a0-6061-47a4-9d18-d00c5ab355f7"],
 " based on the Murnaghan-Nakayama rule."
}], "Notes",
 CellID->1212927008,ExpressionUUID->"fef4b2a4-e8c3-4729-9f5b-7aedf2112b9a"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

