Cell[TextData[{
 "As of Mathematica 14.2.1, the columns of ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FiniteGroup"]], "paclet:QuantumMob/Q3/ref/FiniteGroup", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<SymmetricGroup\>\"", ",", 
      StyleBox["n", "TI"]}], "}"}], ",", "\"\<CharacterTable\>\""}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6a004cf9-1e8a-4cb4-9998-8ff106371cfd"],
 " are not arranged consistently with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FiniteGroupData"]], "paclet:ref/FiniteGroupData"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<SymmetricGroup\>\"", ",", 
      StyleBox["n", "TI"]}], "}"}], ",", "\"\<ConjugacyClasses\>\""}], "]"}]],
   "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d35494d3-0ac5-46b9-90a7-5880df404d31"],
 ". At least, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungClasses"]], "paclet:QuantumMob/Q3/ref/YoungClasses", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "340a14a7-f133-4739-be3f-6bfb7921a06b"],
 " are consistent with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FiniteGroupData"]], "paclet:ref/FiniteGroupData"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<SymmetricGroup\>\"", ",", 
      StyleBox["n", "TI"]}], "}"}], ",", "\"\<ConjugacyClassSizes\>\""}], 
   "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6d6df17c-f99e-4f0f-8703-adeddd00f45b"],
 " and with the columns of ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FiniteGroup"]], "paclet:QuantumMob/Q3/ref/FiniteGroup", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\"\<SymmetricGroup\>\"", ",", 
      StyleBox["n", "TI"]}], "}"}], ",", "\"\<CharacterTable\>\""}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "485939ae-2b66-4f31-be42-11d7d2b78c70"],
