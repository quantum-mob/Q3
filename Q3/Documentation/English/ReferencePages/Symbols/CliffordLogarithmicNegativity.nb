Cell[TextData[{
 "The logarithmic entanglement negativity may be calculated efficiently using \
stabilizer generators. The current implementation is based on the algorithm \
suggested in ",
 ButtonBox["Sang et al. (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PRXQuantum.2.030313"], None}],
 "; see also ",
 ButtonBox["Weinstein, Bao, and Altman (2022)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevLett.129.080501"], None}],
 "."
}], "Notes",
 CellID->104613091,ExpressionUUID->"03d9cf2a-fe3c-4eff-9c85-4981f2410c17"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

