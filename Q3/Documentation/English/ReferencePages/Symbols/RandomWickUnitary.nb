  "Openers" -> {
   "PrimaryExamplesSection" -> Open, "ExampleSection" -> {"0" -> Open}, 
    "AllOptsTable" -> Closed, "NotesSection" -> Closed}, "NewStyles" -> True, 
  "CitationPopupData" -> $Failed, "ShowCitation" -> False, "HasOptions" -> 
  True, "RootCaptions" -> "", "HeaderCoreAreaLink" -> {}, 
  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 57, 37.252073}", 
    "history" -> {"14.3", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {
     "fermionic quantum computation", "fermionic Gaussian state"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "RandomWickUnitary[n] returns a uniformly distributed random Wick unitary \
on n fermion modes. RandomWickUnitary[{k1, k2, ...}] returns a random Wick \
unitary gate on fermion modes {k1, k2, ...}. RandomWickUnitary[ham -> pdf] \
chooses an evolution time \\[Tau] from the distribution function pdf and \
returns exp (-I \\[Tau] ham). RandomWickUnitary[ham -> {t1, t2}] or \
RandomWickUnitary[ham -> Uniform] chooses \\[Tau] from \
UniformDistribution[{t1, t2}]. Putting Uniform sets the interval to {0, 2 \
\\[Pi] n/Emax}, where n is the number of fermion modes and Emax is the \
largest energy scale of the Hamiltonian ham. RandomWickUnitary[ham -> \
\\[Gamma]] or RandomWickUnitary[ham -> Exponential] chooses \\[Tau] from \
ExponentialDistribution[n*\\[Gamma]]. Setting Exponential puts \\[Gamma] = \
1.", "synonyms" -> {}, "tabletags" -> {}, "title" -> "RandomWickUnitary", 
    "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "RandomWickUnitary", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/RandomWickUnitary"}},
