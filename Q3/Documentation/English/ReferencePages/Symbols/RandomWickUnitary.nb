Cell[TextData[{
 "The evolution time is chosen from the uniform distribution over the \
interval  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"0", ",", 
     SubscriptBox["\[Tau]", "max"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "128c5528-f704-4727-bd1f-c92f096c3328"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "max"], ":=", 
    RowBox[{"2", "\[Pi]", " ", 
     RowBox[{"n", "/", 
      SubscriptBox["E", "max"]}]}]}], TraditionalForm]],ExpressionUUID->
  "5e0c87da-356f-46e9-aa4d-bb7b6194f049"],
 ", ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "04338543-07ea-4f66-a9f0-967b1a98c237"],
 " is the number of fermion modes (system size) and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "max"], TraditionalForm]],ExpressionUUID->
  "b9163464-ab20-49fd-ab01-f2b2311c7114"],
 " is the largest energy scale in the Hamiltonian ham:"
