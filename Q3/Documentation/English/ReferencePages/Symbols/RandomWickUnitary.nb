      "8f55813f-9316-4643-91cf-4f932dca0d5f"],
     "\[LineSeparator]chooses \[Tau] from ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["UniformDistribution"]], "paclet:ref/UniformDistribution"},
        
        "RefLink",
