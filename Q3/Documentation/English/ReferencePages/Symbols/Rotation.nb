Cell["\<\
This is a way to specify a rotation operator on multiple qubits.\
\>", "ExampleText",
 CellID->1378677620,ExpressionUUID->"10562bdc-67b0-43cd-a189-24e5257c7527"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Rotation", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"b", ",", "3"}], "}"}]}], "]"}], "//", "Garner"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1127743971,ExpressionUUID->"cc339869-95b1-4d44-a6fd-e8cc13a63684"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Cos", "[", 
    FractionBox["a", "2"], "]"}], " ", 
   RowBox[{"Cos", "[", 
    FractionBox["b", "2"], "]"}], " ", 
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", "\<\"I\"\>"}],
    QuantumMob`Q3`Pauli[{0, 0}]]}], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"Cos", "[", 
    FractionBox["b", "2"], "]"}], " ", 
   InterpretationBox[
    RowBox[{"\<\"Y\"\>", "\[CircleTimes]", "\<\"I\"\>"}],
    QuantumMob`Q3`Pauli[{2, 0}]], " ", 
   RowBox[{"Sin", "[", 
    FractionBox["a", "2"], "]"}]}], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"Cos", "[", 
    FractionBox["a", "2"], "]"}], " ", 
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", "\<\"Z\"\>"}],
    QuantumMob`Q3`Pauli[{0, 3}]], " ", 
   RowBox[{"Sin", "[", 
    FractionBox["b", "2"], "]"}]}], "-", 
  RowBox[{
   InterpretationBox[
    RowBox[{"\<\"Y\"\>", "\[CircleTimes]", "\<\"Z\"\>"}],
    QuantumMob`Q3`Pauli[{2, 3}]], " ", 
   RowBox[{"Sin", "[", 
    FractionBox["a", "2"], "]"}], " ", 
   RowBox[{"Sin", "[", 
    FractionBox["b", "2"], "]"}]}]}]], "Output",
 CellLabel->"Out[4]=",
 CellID->220389074,ExpressionUUID->"4255d2cd-1e7c-4459-aab8-f3a8098b0644"]
}, Open  ]],

