Cell["\<\
You can specify an arbitrary axis other than the coordinates axes.\
\>", "ExampleText",
 CellID->107465858,ExpressionUUID->"5e72a5f6-7bd9-4a8c-9088-6b35e2a37148"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Rotation", "[", 
  RowBox[{"\[Phi]", ",", 
   RowBox[{"{", 
    RowBox[{"1", ",", "1", ",", "0"}], "}"}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->590945635,ExpressionUUID->"3d54b104-a3c1-475b-9015-f063a254d36d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Cos", "[", 
    FractionBox["\[Phi]", "2"], "]"}], " ", 
   InterpretationBox["\<\"I\"\>",
    QuantumMob`Q3`Pauli[{0}]]}], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"(", 
    RowBox[{
     FractionBox[
      InterpretationBox["\<\"X\"\>",
       QuantumMob`Q3`Pauli[{1}]], 
      SqrtBox["2"]], "+", 
     FractionBox[
      InterpretationBox["\<\"Y\"\>",
       QuantumMob`Q3`Pauli[{2}]], 
      SqrtBox["2"]]}], ")"}], " ", 
   RowBox[{"Sin", "[", 
    FractionBox["\[Phi]", "2"], "]"}]}]}]], "Output",
 CellLabel->"Out[1]=",
 CellID->1817359290,ExpressionUUID->"0cff156c-e814-41de-84c2-acf53e3ded49"]
}, Open  ]],

