          SqrtBox["3"], "2"]}], "0", "0", "0"},
       {
        RowBox[{"-", 
         FractionBox[
          SqrtBox["3"], "2"]}], 
        FractionBox["1", "2"], "0", "0", "0"},
       {"0", "0", 
        FractionBox["1", "2"], 
        RowBox[{"-", 
         FractionBox["1", 
          RowBox[{"2", " ", 
           SqrtBox["3"]}]]}], 
        SqrtBox[
         FractionBox["2", "3"]]},
       {"0", "0", 
        FractionBox[
         SqrtBox["3"], "2"], 
        FractionBox["1", "6"], 
        RowBox[{"-", 
         FractionBox[
          SqrtBox["2"], "3"]}]},
       {"0", "0", "0", 
        FractionBox[
         RowBox[{"2", " ", 
          SqrtBox["2"]}], "3"], 
