Cell[TextData[{
 "The matrices in Young's normal representation are in the ",
 ButtonBox["Specht basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
 ". For the relation between the Specht basis and Young's normal \
representation, see ",
 ButtonBox["Representations of the Symmetric Group",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/RepresentationsOfTheSymmetricGroup#\
636042487"],
 "."
}], "Notes",
 CellID->1153190676,ExpressionUUID->"25d938b3-8de4-4f51-a379-719d77475a61"],

Cell[TextData[{
 "Young's normal representation is a multiplicity-free subgroup-adapted basis \
(i.e., a Young-Yamanouchi basis), adapted to the canonical subgroup tower ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalS]", "n"], "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", 
     RowBox[{"n", "-", "1"}]], "\[Superset]", "\[Ellipsis]", "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", "2"], "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", "1"]}], TraditionalForm]],
  ExpressionUUID->"12417eca-6b61-4ace-8a6b-8f5510551ec6"],
 " for the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "094ddb8e-1f08-4af0-98ff-dc1771903e94"],
 " of degree ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "1ee1c092-1261-409d-b26b-c219ef693e2a"],
 "."
}], "Notes",
 CellID->1924844191,ExpressionUUID->"bb112552-f91b-46fc-a19b-0c2853ef947e"],

Cell[TextData[{
 "Young's ",
 StyleBox["normal",
  FontSlant->"Italic"],
 " representation is distinguished from Young\[CloseCurlyQuote]s ",
 StyleBox["seminormal",
  FontSlant->"Italic"],
 " representation (Sagan, 2001, Exercise 2.11) or Young\[CloseCurlyQuote]s ",
 StyleBox["natural",
  FontSlant->"Italic"],
 " representation (Sagan, 2001, Section 2.7)."
}], "Notes",
 CellID->951889003,ExpressionUUID->"0c258682-551d-446a-8850-176db8b50057"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

