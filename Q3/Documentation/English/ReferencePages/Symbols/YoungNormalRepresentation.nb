  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3be6ac15-8e2e-4108-8c3c-4a2ed4dad02c"],
 " calculates the matrix representations of adjacent permutations and returns \
full object\[LineSeparator]\t",
 Cell[BoxData[
  RowBox[{
   StyleBox["rep", "TI"], ":=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungNormalRepresentation"]], 
      "paclet:QuantumMob/Q3/ref/YoungNormalRepresentation", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["shape", "TI"], ",", " ", 
     StyleBox["tsr", "TI"]}], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "17252b46-b845-4da6-8948-9eabea081921"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  StyleBox["tsr", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3e839233-21f8-4ae5-a5a9-38de75412486"],
 " is an ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     StyleBox["n", "TI"], "-", "1"}], ")"}], "\[Times]", 
   SubscriptBox[
    StyleBox["d", "TI"], 
    StyleBox["\[Lambda]", "TR"]], "\[Times]", 
   SubscriptBox[
    StyleBox["d", "TI"], 
    StyleBox["\[Lambda]", "TR"]]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fdf15ba7-9acb-455f-bb8e-b120df7890a6"],
 " tensor with ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["tsr", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2831bda8-ebe6-4b1b-9a68-defda23ee637"],
 " referring to the matrix of transposition ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{
    StyleBox["k", "TI"], ",", 
    RowBox[{
     StyleBox["k", "TI"], "+", "1"}]}], ")"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "db1f96eb-7f0e-4c34-808a-4d90f5559351"],
 ". Here, ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "46f250a5-cf0d-43ac-b835-fda59f7485d8"],
 " is the degree of the symmetric group, \[Lambda] is the shape, and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["d", "TI"], 
   StyleBox["\[Lambda]", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "97e47a55-b09d-4a47-af59-59ecabf69fe8"],
 " is the dimension of Young's normal representation \[Lambda]."
}], "Notes",
 CellID->688589113,ExpressionUUID->"c03c460d-fa3e-4a22-ae14-a20047c72644"],

