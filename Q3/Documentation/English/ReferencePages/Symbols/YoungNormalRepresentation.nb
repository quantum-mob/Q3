         3^Rational[-1, 2], Rational[2, 3]^Rational[1, 2], Rational[1, 2] 
         3^Rational[1, 2], Rational[1, 6], Rational[-1, 3] 2^Rational[1, 2], 
         Rational[2, 3] 2^Rational[1, 2], Rational[1, 3]}}]]]]}], 
