  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0039c9a1-a67b-4649-aa5f-f0507ef5ff47"],
 ". It is handled efficiently when operating on a ",
 ButtonBox["full Gottesman vector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullGottesmanVector"],
 " or on ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CliffordState"]], "paclet:QuantumMob/Q3/ref/CliffordState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
