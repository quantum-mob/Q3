Cell[TextData[{
 "When ",
 Cell[BoxData["S"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4eb6d510-c8ec-4441-8310-ea4dce9ae138"],
 " is a ",
 ButtonBox["qubit",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Qubit"],
 ", ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{"\[Ellipsis]", ",", "6"}], "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{"\[Ellipsis]", ",", "1"}], "]"}], "+", 
      RowBox[{"S", "[", 
       RowBox[{"\[Ellipsis]", ",", "3"}], "]"}]}], ")"}], "/", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Sqrt"]], "paclet:ref/Sqrt"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", "2", "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7667381c-7125-4093-ac56-ec028b92d151"],
 "  corresponding to the ",
 Cell[BoxData["Hadamard"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7aed6e30-3f70-4b86-b5bd-34a257b39b78"],
 " gate on qubit ",
 Cell[BoxData[
  RowBox[{"S", "[", 
   RowBox[{"\[Ellipsis]", ",", 
    TemplateBox[{
      Cell[
       TextData["$"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d6557cd3-20bd-44b9-9949-dd456e25aae1"],
 "."
}], "Notes",
 CellID->139835173,ExpressionUUID->"b7245c23-2291-4186-82e0-ffd20992f562"],

Cell[TextData[{
 "When applied to each qubit in state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "9a0d47a3-3d15-4df7-a930-b86b20bcfead"],
 ", the Hadamard gate generates a linear superposition of all states in the \
computational basis,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["H", 
      RowBox[{"\[CircleTimes]", "n"}]], 
     SuperscriptBox[
      TemplateBox[{"0"},
       "Ket"], 
      RowBox[{"\[CircleTimes]", "n"}]]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}], "\[CircleTimes]", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}]}], "=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", 
        RowBox[{"n", "/", "2"}]]], 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"x", "=", "0"}], 
       RowBox[{
        SuperscriptBox["2", "n"], "-", "1"}]], 
      TemplateBox[{"x"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "26f326da-cea3-4bea-9abd-1fedb5e89fc0"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"x"},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["x", "1"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["x", "2"]},
      "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["x", "n"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "f6189ba7-e488-4b9f-b85d-677b5f69a529"],
 " for an integer ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "99c05e71-2fe1-4608-aebe-3db00918858e"],
 " represented by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], 
       SubscriptBox["x", "2"], 
       SubscriptBox["\[Ellipsis]x", "n"]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"a0aab5c6-9270-4f48-a024-13074b8c5dab"],
 " in the binary digits."
}], "Notes",
 CellID->1964087756,ExpressionUUID->"1e2c932d-4a9c-402e-b904-368ff9ff5595"],

Cell[TextData[{
 "More generally, for an arbitrary state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"y"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b7316446-4690-40a7-9943-babdc0d95b91"],
 " in the computational basis,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["H", 
      RowBox[{"\[CircleTimes]", "n"}]], 
     SuperscriptBox[
      TemplateBox[{"y"},
       "Ket"], 
      RowBox[{"\[CircleTimes]", "n"}]]}], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"x"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"x", "\[CenterDot]", "y"}]]}]}], TraditionalForm]],
  ExpressionUUID->"c86bd906-3ca5-48e9-a1d6-5c78a48afc77"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[CenterDot]", "y"}], TraditionalForm]],ExpressionUUID->
  "6d52e9d6-59ba-4e3f-901c-6a27b0681cab"],
 " denotes the bitwise dot product of two integers ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "29444d13-e0cb-45df-bc0a-c8b3435f35dc"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "0822301b-8eb3-417f-b483-dff173a128c6"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "\[CenterDot]", "y"}], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["x", "1"], 
      SubscriptBox["y", "1"]}], "+", 
     RowBox[{
      SubscriptBox["x", "2"], 
      SubscriptBox["y", "2"]}], "+", "\[CenterEllipsis]", "+", 
     RowBox[{
      SubscriptBox["x", "n"], 
      SubscriptBox["y", "n"], "  ", 
      RowBox[{"(", 
       RowBox[{"mod", " ", "2"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"b381465c-c411-448a-ae79-0e4ce5fe58fe"],
 " ."
}], "Notes",
 CellID->856054572,ExpressionUUID->"cc01bdb3-af42-4b8b-acc0-6d394eb8d84c"],

