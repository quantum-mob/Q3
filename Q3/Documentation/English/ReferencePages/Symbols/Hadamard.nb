Cell[TextData[{
 "When ",
 Cell[BoxData["S"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "752e7259-17b0-4191-9943-48bdf5f73537"],
 " is a ",
 ButtonBox["qubit",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Qubit"],
 ", ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{"\[Ellipsis]", ",", "6"}], "]"}], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{"\[Ellipsis]", ",", "1"}], "]"}], "+", 
      RowBox[{"S", "[", 
       RowBox[{"\[Ellipsis]", ",", "3"}], "]"}]}], ")"}], "/", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Sqrt"]], "paclet:ref/Sqrt"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", "2", "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "70d6311c-2ec4-425c-954b-e29b4f6c46eb"],
 "  corresponding to the ",
 Cell[BoxData["Hadamard"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "36ea3a7e-fca6-4dca-8c64-c3eef9140653"],
 " gate on qubit ",
 Cell[BoxData[
  RowBox[{"S", "[", 
   RowBox[{"\[Ellipsis]", ",", 
    TemplateBox[{
      Cell[
       TextData["$"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "454bbf93-21ba-4423-81c5-5bdf8a04962e"],
 "."
}], "Notes",
 CellID->139835173,ExpressionUUID->"ed36b6c7-63e3-4a7d-92f7-5b344ed22a7a"],

Cell[TextData[{
 "When applied to each qubit in state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "cc89715e-0e2f-4082-ba97-d447c36dcd3f"],
 ", the Hadamard gate generates a linear superposition of all states in the \
computational basis,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["H", 
      RowBox[{"\[CircleTimes]", "n"}]], 
     SuperscriptBox[
      TemplateBox[{"0"},
       "Ket"], 
      RowBox[{"\[CircleTimes]", "n"}]]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}], "\[CircleTimes]", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}]}], "=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", 
        RowBox[{"n", "/", "2"}]]], 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"x", "=", "0"}], 
       RowBox[{
        SuperscriptBox["2", "n"], "-", "1"}]], 
      TemplateBox[{"x"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "157cb080-4e10-4faa-8f2c-67cb9a0bf913"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"x"},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["x", "1"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["x", "2"]},
      "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["x", "n"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "55eab707-5a86-49ce-8ec1-f25bacce1621"],
 " for an integer ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "c2d0b1cc-a2ce-4bcc-b05b-a301b5cb64b0"],
 " represented by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], 
       SubscriptBox["x", "2"], 
       SubscriptBox["\[Ellipsis]x", "n"]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"f419c7a9-a765-4d79-819e-27a5dc4bb2ba"],
 " in the binary digits."
}], "Notes",
 CellID->1964087756,ExpressionUUID->"3914f6f3-29c1-4180-b6ea-3cdb9a308f6b"],

Cell[TextData[{
 "More generally, for an arbitrary state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"y"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "37e1a926-2982-418a-ba21-bf1209c67fd0"],
 " in the computational basis,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["H", 
      RowBox[{"\[CircleTimes]", "n"}]], 
     SuperscriptBox[
      TemplateBox[{"y"},
       "Ket"], 
      RowBox[{"\[CircleTimes]", "n"}]]}], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"x"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"x", "\[CenterDot]", "y"}]]}]}], TraditionalForm]],
  ExpressionUUID->"08687c64-ae62-4769-a4a8-4be7de49dd08"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[CenterDot]", "y"}], TraditionalForm]],ExpressionUUID->
  "9cd319ae-229a-434d-b7cf-6c31085eaf52"],
 " denotes the bitwise dot product of two integers ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "fa9bcbc7-1f65-4194-943d-006f68cffea7"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "c15efa31-a928-4f89-8e38-f78af79cd84b"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "\[CenterDot]", "y"}], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["x", "1"], 
      SubscriptBox["y", "1"]}], "+", 
     RowBox[{
      SubscriptBox["x", "2"], 
      SubscriptBox["y", "2"]}], "+", "\[CenterEllipsis]", "+", 
     RowBox[{
      SubscriptBox["x", "n"], 
      SubscriptBox["y", "n"], "  ", 
      RowBox[{"(", 
       RowBox[{"mod", " ", "2"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"ccadab2d-6ec1-402d-b0eb-18f494cbcc8b"],
 " ."
}], "Notes",
 CellID->856054572,ExpressionUUID->"bd459471-54e9-493c-88d8-62aebbd525b3"],

Cell[TextData[{
