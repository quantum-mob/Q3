Cell[TextData[{
 "The transformation rules between Dirac fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "36243767-16ed-468e-b270-6cce842c0ed2"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["a", "k", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "ab8ed2f6-1f9b-468b-8bf2-bd6d15f6dcc0"],
 " and the Majorana fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     RowBox[{"2", "k"}], "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "8826bf99-2576-4d96-a6c2-e4abbdf2564c"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{"2", "k"}]], TraditionalForm]],ExpressionUUID->
  "c0aea10a-f7e6-4fb6-aff3-c64ff9651c98"],
 " are given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", 
     RowBox[{
      RowBox[{"2", "k"}], "-", "1"}]], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "+", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"8c7e1943-602a-46e1-b011-92a86f7dca89"],
 ", \[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubscriptBox["c", 
      RowBox[{"2", "k"}]]}], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "-", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"d17f6c66-f5a6-4550-be89-91b2123fae80"],
 ".\[LineSeparator]Note that the Majorana operators are normalized as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["a", "i"], ",", 
      SubscriptBox["a", "j"]}], "}"}], "=", 
    RowBox[{"2", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"d063a337-b6b1-4f6a-8641-7d980408bab8"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "i", "2"], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"7f7d95c5-65cf-46c5-b39e-3d472e8f0abd"],
 "."
}], "Notes",
 CellID->307824357,ExpressionUUID->"847c111a-1368-4a22-b91f-d32991c759fd"],

