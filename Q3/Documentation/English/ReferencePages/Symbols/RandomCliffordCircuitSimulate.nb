Cell["\<\
The Pauli Z measurement and Pauli Z decoherence channel are applied randomly \
with a certain probability.\
\>", "ExampleText",
 CellID->1297285796,ExpressionUUID->"1c5ccf60-11aa-4d8b-a04a-beb0711d48a5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$n", "=", "10"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"the", " ", "number", " ", "of", " ", "qubits"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$T", "=", "40"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "number", " ", "of", " ", "layers", " ", "in", " ", "the", " ",
     "circuit"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$p", "=", "0.1"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "probability", " ", "for", " ", "the", " ", "Pauli", " ", "Z", 
    " ", "measurment"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$q", "=", "0.05"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "probability", " ", "for", " ", "the", " ", "Pauli", " ", "Z", 
    " ", "decherence"}], " ", "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->80905381,ExpressionUUID->"401ee8c4-deb3-45a5-bcba-7dd7d22bd83d"],

Cell["\<\
Generate 15 random Clifford circuits and execute each circuit 10 times, to \
get overall 150 trajectories of quantum states.\
\>", "ExampleText",
 CellID->419589916,ExpressionUUID->"2dd065c9-8844-4c29-b330-f6eb9c3542cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "385", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1858905111,ExpressionUUID->"6dd54a5a-8abd-432c-b8fd-e46672dd469d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"RandomCliffordCircuitSimulate", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"$n", ",", "$T"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"$p", ",", "$q"}], "}"}], ",", 
      RowBox[{"\"\<Samples\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"100", ",", "1"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1026104021,ExpressionUUID->"d628dd28-8204-411e-a165-60009b30761f"],

Cell[BoxData["40.808031`"], "EchoTiming",
 CellID->1648329930,ExpressionUUID->"50d90bb0-0461-4a51-a1c7-7fc55864b480"]
}, Open  ]],

