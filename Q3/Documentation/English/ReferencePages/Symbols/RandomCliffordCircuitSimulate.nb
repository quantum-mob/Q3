Cell["\<\
Take the average of the logarithmic negativity over all trajectories as a \
function of time.\
\>", "ExampleText",
 CellID->2017190627,ExpressionUUID->"7c37e55b-ba4d-4273-aa66-7af2f9b14764"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", "$T"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgNeg", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Mean", "[", "neg", "]"}]}], "}"}]}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
