Cell[TextData[{
 "It randomly generates a sequence of Clifford quantum circuits  ",
 Cell[BoxData[
  StyleBox["circuits", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7f5fdb1a-4f03-4adb-b64c-8a9560a01606"],
 ": ",
 Cell[BoxData[
  RowBox[{
   StyleBox["circuits", "TI"], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["qc", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["qc", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7c688e58-d68a-452b-95d9-dbcdb904b347"],
 " by using ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["RandomCliffordCircuit"]], 
    "paclet:QuantumMob/Q3/ref/RandomCliffordCircuit", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "38c10896-ea4b-4a79-824f-b22a89cbb19a"],
 ", simulates each circuit, and returns a list ",
 Cell[BoxData[
  RowBox[{
   StyleBox["data", "TI"], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["set", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["set", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6d6d7ea5-3505-4343-b054-c2d4f6a63a3e"],
 ". The latter contains subsets of trajectories, each subset ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["set", "TI"], 
    StyleBox["i", "TI"]], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["trj", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["1", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     SubscriptBox[
      StyleBox["trj", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["2", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "46eb8539-68d4-4d66-bee2-182349dc3f95"],
 " collects the trajectories from quantum circuit ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["qc", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "74985d9f-4e35-42b4-8836-17fcfdf240a6"],
 ". Each quantum trajectory ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["trj", "TI"], 
    StyleBox["ij", "TI"]], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["cs", "TI"], 
      StyleBox["ij1", "TI"]], ",", 
     SubscriptBox[
      StyleBox["cs", "TI"], 
      StyleBox["ij2", "TI"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "83819e1b-3e7f-472a-a57b-7cda372c8df8"],
 " is a sequence of Clifford states ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["cs", "TI"], 
   StyleBox["ijt", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4c4a4fba-4d9c-42b1-852a-845987bd76c8"],
 ". "
}], "Notes",
 CellID->1390533101,ExpressionUUID->"5a550dfd-61e3-489f-a6c4-1c05296dfec5"],

Cell[TextData[{
 "The input state ",
 Cell[BoxData[
  StyleBox["in", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4201bb57-b8a3-46d5-a935-c06288c2e1c6"],
 " may be either in the Ket or CliffordState form. If \"Random\" is put for \
",
 Cell[BoxData[
  StyleBox["in", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8e0bb415-9fac-4326-8fb4-b198e584f81e"],
 ", then a ",
 ButtonBox["random Clifford state",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/RandomCliffordState"],
 " is assumed."
}], "Notes",
 CellID->1747873995,ExpressionUUID->"a6138468-9fcf-4e48-b514-31af83faa491"],

