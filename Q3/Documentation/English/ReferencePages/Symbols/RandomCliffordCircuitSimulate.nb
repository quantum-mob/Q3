Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"trj", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"data", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"trj", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->2074452342,ExpressionUUID->"2895feec-6cfa-446f-b157-c4462224e370"],

