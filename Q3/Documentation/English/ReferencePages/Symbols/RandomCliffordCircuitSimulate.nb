Cell["\<\
Take the average of the logarithmic negativity over all trajectories as a \
function of time.\
\>", "ExampleText",
 CellID->1736565129,ExpressionUUID->"0a4d9887-adb7-4f45-9f32-73cf9da00abd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", "$T"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgNeg", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Mean", "[", "neg", "]"}]}], "}"}]}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->2147360373,ExpressionUUID->"7423ac74-840e-489d-95e0-259e95016bd7"],

