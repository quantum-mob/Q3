   RowBox[{"$p", "=", "0.5"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "probability", " ", "for", " ", "each", " ", "qubit", " ", 
    "to", " ", "be", " ", "measured", " ", "in", " ", "each", " ", "layer"}], 
   " ", "*)"}]}]}], "Input",
