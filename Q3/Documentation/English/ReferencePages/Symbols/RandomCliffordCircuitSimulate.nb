Cell["\<\
Combine the different sets of trajectories from different Clifford circuits \
to get a simpler structure.\
\>", "ExampleText",
 CellID->695621042,ExpressionUUID->"e31a8963-c78f-49c0-99d4-3c5b1656cb94"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"trj", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"data", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"trj", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->401878626,ExpressionUUID->"3b05a0a1-0f79-4ed2-92e7-a8e0c0e99910"],

