Cell["Calculate the logarithmic negativity in each state.", "ExampleText",
 CellID->749511225,ExpressionUUID->"42fab7a8-3e45-4e5e-ac7a-ea163d39c0c7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{"CliffordLogarithmicNegativity", "[", "kk", "]"}], ",", "trj", ",", 
      RowBox[{"{", "2", "}"}]}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
