Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{"CliffordLogarithmicNegativity", "[", "kk", "]"}], ",", "trj", ",", 
      RowBox[{"{", "2", "}"}]}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
