Cell["\<\
The Pauli Z decoherence channel is applied randomly with a certain \
probability.\
\>", "ExampleText",
 CellID->86081375,ExpressionUUID->"ad7a447d-2aef-4b1a-bb49-279b39edc46c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$n", "=", "8"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"the", " ", "number", " ", "of", " ", "qubits"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$T", "=", "15"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "number", " ", "of", " ", "layers", " ", "in", " ", "the", " ",
     "circuit"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$p", "=", "0.1"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "probability", " ", "for", " ", "the", " ", "Pauli", " ", 
    "decherence", " ", "channels"}], " ", "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->419344458,ExpressionUUID->"0f7e85a3-09fa-4937-9874-6903e9710850"],

Cell["\<\
Generate 15 random Clifford circuits and execute each circuit 10 times, to \
get overall 150 trajectories of quantum states.\
\>", "ExampleText",
 CellID->2028459799,ExpressionUUID->"ce362f23-7212-4fc6-b327-8fc7c0afc557"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "3512", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1020945668,ExpressionUUID->"bc810915-346a-4b9f-8911-8245d765b630"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"RandomCliffordCircuitSimulate", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"$n", ",", "$T"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "$p"}], "}"}], ",", 
      RowBox[{"\"\<Samples\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"50", ",", "2"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->639502546,ExpressionUUID->"696f440c-153b-48fb-bd67-ef7bb4195469"],

Cell[BoxData["8.701345`"], "EchoTiming",
 CellID->1947892846,ExpressionUUID->"5870c685-9587-48e1-ad49-3d06ead9e42a"]
}, Open  ]],

