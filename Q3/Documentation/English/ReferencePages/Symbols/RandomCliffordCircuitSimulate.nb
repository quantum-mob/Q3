 CellLabel->"In[2]:=",
 CellID->633915718,ExpressionUUID->"c5536796-068b-401f-9f53-1d62eee27f24"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"RandomCliffordCircuitSimulate", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"$n", ",", "$T"}], "}"}], ",", "$p", ",", 
      RowBox[{"\"\<Samples\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"50", ",", "2"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
