Cell["\<\
The Pauli X, Y, and Z decoherence channels are randomly selected with an \
equal probability in each layer.\
\>", "ExampleText",
 CellID->1460097158,ExpressionUUID->"503c43fe-8c10-44a9-b85e-beb391410419"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$n", "=", "8"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"the", " ", "number", " ", "of", " ", "qubits"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$T", "=", "15"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "number", " ", "of", " ", "layers", " ", "in", " ", "the", " ",
     "circuit"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$p", "=", "0.1"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "probability", " ", "for", " ", "the", " ", "Pauli", " ", 
    "decherence", " ", "channels"}], " ", "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->557300237,ExpressionUUID->"1896d6ee-dc16-4957-bd7d-46135ee80bfb"],

Cell["\<\
Generate 15 random Clifford circuits and execute each circuit 10 times, to \
get overall 150 trajectories of quantum states.\
\>", "ExampleText",
 CellID->1368898692,ExpressionUUID->"6729eb05-af56-4cd9-93c0-f0bc0c4142fc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "3512", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1088006133,ExpressionUUID->"2dce0bbf-af7f-4d6c-a64a-2acd7ea787d4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"RandomCliffordCircuitSimulate", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"$n", ",", "$T"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "1", ",", "1"}], "}"}], "*", 
         RowBox[{"$p", "/", "3"}]}]}], "}"}], ",", 
      RowBox[{"\"\<Samples\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"50", ",", "2"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->295823126,ExpressionUUID->"8a78c99c-bae0-4ca7-b469-975b7eff8499"],

Cell[BoxData["8.776855`"], "EchoTiming",
 CellID->788154687,ExpressionUUID->"97816910-b1ff-45b3-8e4c-c1d694495a4e"]
}, Open  ]],

