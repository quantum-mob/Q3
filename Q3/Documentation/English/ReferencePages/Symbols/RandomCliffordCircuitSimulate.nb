Cell[TextData[{
 "Random Clifford circuits are prototype quantum circuits that exhibits the \
phenomenon of ",
 StyleBox["measurement-induced entanglement transition",
  FontSlant->"Italic"],
 ", a transition between two distinct phases with the entanglement entropy \
characterized by area- and volume-law scaling. See also ",
 ButtonBox["Li, Chen, and Fisher (2018)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysrevb.98.205136"], None}],
 ", ",
 ButtonBox["Skinner, Ruhman, and Nahum (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysrevx.9.031009"], None}],
 ", ",
 ButtonBox["Chan et. al. (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevB.99.224307"], None}],
 ", ",
 ButtonBox["Sang et al. (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PRXQuantum.2.030313"], None}],
 ", and ",
 ButtonBox["Weinstein, Bao, and Altman (2022)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevLett.129.080501"], None}],
 "."
}], "Notes",
 CellID->1815464681,ExpressionUUID->"e9d7aa46-0a24-4804-a7b7-e4e7c979ed56"],

Cell[TextData[{
 "For ",
 StyleBox["efficient simulation of Clifford circuits",
  FontSlant->"Italic"],
 ", see ",
 ButtonBox["Cleve and Gottesman (1997)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103%2Fphysreva.56.76"], None}],
 ", ",
 ButtonBox["Gottesman (1998)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.57.127"], None}],
 ", ",
 ButtonBox["Aaronson and Gottesman (2004)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/physreva.70.052328"], None}],
 "."
}], "Notes",
 CellID->131206014,ExpressionUUID->"982e7d00-15f5-47f8-97bf-49394cbca2bc"],

Cell[TextData[{
 StyleBox["Changes since v3.8.4",
  FontWeight->"Bold"],
 ": ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["RandomCliffordCircuit"]], 
     "paclet:QuantumMob/Q3/ref/RandomCliffordCircuitSimulate", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["\[Ellipsis]", "TR"], ",", 
    RowBox[{"{", 
     RowBox[{"0", ",", 
      StyleBox["q", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1e58ea15-89e7-4b28-a0ec-83ddbb2de67a"],
 " is now equivalent to ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["RandomCliffordCircuitSimulate"]], 
      "paclet:QuantumMob/Q3/ref/RandomCliffordCircuitSimulate", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["\[Ellipsis]", "TR"], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", 
         StyleBox["q", "TI"]}], "}"}]}]}]}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4a932979-c0a5-48f2-ae73-b625ab23cdc2"],
 "; before, it meant ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["RandomCliffordCircuitSimulate"]], 
      "paclet:QuantumMob/Q3/ref/RandomCliffordCircuitSimulate", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["\[Ellipsis]", "TR"], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          StyleBox["q", "TI"], "/", "3"}], ",", 
         RowBox[{
          StyleBox["q", "TI"], "/", "3"}], ",", 
         RowBox[{
          StyleBox["q", "TI"], "/", "3"}]}], "}"}]}]}]}]}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "96bfcb5e-0163-4762-bc8e-0f0d066e7f20"],
 "."
}], "Notes",
 CellID->1846040036,ExpressionUUID->"382c51bf-c0e3-4ddb-ab51-fe4ea39c74ec"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

