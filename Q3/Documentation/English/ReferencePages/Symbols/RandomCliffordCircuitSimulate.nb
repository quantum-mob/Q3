Cell["\<\
Take the average of the logarithmic negativity over all trajectories as a \
function of time.\
\>", "ExampleText",
 CellID->1406427935,ExpressionUUID->"b67f1747-8d28-4356-bba5-1f5389243ec0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", "$T"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgNeg", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Mean", "[", "neg", "]"}]}], "}"}]}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->481801016,ExpressionUUID->"c385fe4d-3ed7-4110-a7b4-ddf35c7bcf8e"],

