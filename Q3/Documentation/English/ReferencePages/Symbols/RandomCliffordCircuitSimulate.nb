Cell["\<\
Take the average of the logarithmic negativity over all trajectories as a \
function of time.\
\>", "ExampleText",
 CellID->1345794975,ExpressionUUID->"f9c0fab7-76c0-4022-b906-dea70d0c0893"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", "$T"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgNeg", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Mean", "[", "neg", "]"}]}], "}"}]}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
