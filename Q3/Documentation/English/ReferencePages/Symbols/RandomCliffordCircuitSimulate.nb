Cell["\<\
The Pauli Z measurement is randomly applied with a certain probability on \
each qubit.\
\>", "ExampleText",
 CellID->1025600352,ExpressionUUID->"f5b23149-036e-40df-af09-beba51be1db8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$n", "=", "8"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"the", " ", "number", " ", "of", " ", "qubits"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$T", "=", "10"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "number", " ", "of", " ", "layers", " ", "in", " ", "the", " ",
     "circuit"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$p", "=", "0.5"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "the", " ", "probability", " ", "for", " ", "Pauli", " ", "Z", " ", 
    "measurement"}], " ", "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1103318177,ExpressionUUID->"d31a9858-c251-4d5d-9b17-9cff1a70a442"],

Cell["\<\
Generate 15 random Clifford circuits and execute each circuit 10 times, to \
get overall 150 trajectories of quantum states.\
\>", "ExampleText",
 CellID->1767565636,ExpressionUUID->"64847ddf-8d84-41d3-8394-064c7f5eb07f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "3512", "]"}], ";"}]], "Input",
