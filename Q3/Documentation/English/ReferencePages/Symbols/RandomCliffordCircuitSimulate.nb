Cell["\<\
Generate 15 random Clifford circuits and execute each circuit 10 times, to \
get overall 150 trajectories of quantum states. Note that the input state is \
randomly chosen from the set of all stabilizer states.\
\>", "ExampleText",
 CellID->419321625,ExpressionUUID->"78e16c6c-db46-4142-b4a3-3c6e739da0ce"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "3512", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1644705568,ExpressionUUID->"5d01499f-1386-43c0-9677-8f55bd0a7839"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"RandomCliffordCircuitSimulate", "[", 
     RowBox[{"\"\<Random\>\"", ",", 
      RowBox[{"{", 
       RowBox[{"$n", ",", "$T"}], "}"}], ",", "$p", ",", 
      RowBox[{"\"\<Samples\>\"", "->", 
       RowBox[{"{", 
        RowBox[{"50", ",", "2"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->156977192,ExpressionUUID->"a4b39397-f30b-45e0-9eb3-af869e0b6df5"],

Cell[BoxData["6.015919`"], "EchoTiming",
 CellID->2043761864,ExpressionUUID->"deb3aa14-83c4-4fe5-850a-c543780c629f"]
}, Open  ]],

