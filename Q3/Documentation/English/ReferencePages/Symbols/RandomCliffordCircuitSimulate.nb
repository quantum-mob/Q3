Cell["\<\
Take the average of the logarithmic negativity over all trajectories as a \
function of time.\
\>", "ExampleText",
 CellID->1555415305,ExpressionUUID->"e99a13ba-853d-4820-97d6-c5e24a373fd0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", "$T"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgNeg", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Mean", "[", "neg", "]"}]}], "}"}]}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
