Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"trj", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{"data", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"trj", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1129880765,ExpressionUUID->"33dca1be-d9df-4137-bb59-5f1d2cc0991c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"100", ",", "41"}], "}"}]], "Output",
 CellLabel->"Out[5]=",
 CellID->262809139,ExpressionUUID->"7f17d8b6-921f-42a0-beab-f80d62f31e99"]
}, Open  ]],

