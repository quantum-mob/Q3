Cell[BoxData[
 TemplateBox[{
  "SmolinState", "badsys", 
   "\"A generalized Smolin state is defined only for an even number of \
qubits: \\!\\(\\*RowBox[{\\\"{\\\", RowBox[{InterpretationBox[SubscriptBox[\\\
\"S\\\", TemplateBox[List[\\\",\\\", \\\"\\\\\\\",\\\\\\\"\\\", \\\"1\\\"], \
\\\"RowWithSeparators\\\"]], S[1, $]], \\\",\\\", \
InterpretationBox[SubscriptBox[\\\"S\\\", TemplateBox[List[\\\",\\\", \
