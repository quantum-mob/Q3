Cell[BoxData[
 RowBox[{
  RowBox[{"WW", "[", 
   RowBox[{"th_", ",", "ph_"}], "]"}], ":=", 
  RowBox[{"0.0008252189672045836`", "\[VeryThinSpace]", "-", 
   RowBox[{"0.031435503948121744`", " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "th", "]"}], "2"]}], "+", 
   RowBox[{"0.23631537717286888`", " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "th", "]"}], "4"]}], "+", 
   RowBox[{"0.4830841135800663`", " ", 
    SuperscriptBox[
     RowBox[{"Cos", "[", "th", "]"}], "6"]}], "+", 
   RowBox[{"0.4830841135800663`", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"6.`", " ", "ph"}], "]"}], " ", 
    SuperscriptBox[
     RowBox[{"Sin", "[", "th", "]"}], "6"]}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->923202389,ExpressionUUID->"133c4227-e3fc-4d75-ac47-d231ba787e4d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"WW", "[", 
   RowBox[{"v", ":", 
    RowBox[{"{", 
     RowBox[{"x_", ",", "y_", ",", "z_"}], "}"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "=", 
      RowBox[{"Norm", "[", "v", "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Chop", "@", 
     RowBox[{"WW", "[", 
      RowBox[{
       RowBox[{"ArcCos", "[", 
        RowBox[{"z", "/", "r"}], "]"}], ",", 
       RowBox[{"Arg", "[", 
        RowBox[{"x", "+", 
         RowBox[{"I", " ", "y"}]}], "]"}]}], "]"}]}]}], "\[IndentingNewLine]",
    "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->693202348,ExpressionUUID->"8ffe94f6-a20e-4478-94e1-8aaf0d741b9e"],

