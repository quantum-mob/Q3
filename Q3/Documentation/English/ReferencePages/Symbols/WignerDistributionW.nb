 CellID->1625720834,ExpressionUUID->"9095f569-2716-416a-a1ec-8f4b573eb7b3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"J", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Spin", ",", "S", ",", 
   RowBox[{"Spin", "\[Rule]", "J"}]}], "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1055616257,ExpressionUUID->"6c0a34d9-766f-4f59-b9a4-abc777e00136"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"v", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Ket", "[", 
      RowBox[{"S", "\[Rule]", "J"}], "]"}], "+", 
     RowBox[{"Ket", "[", 
      RowBox[{"S", "\[Rule]", 
       RowBox[{"-", "J"}]}], "]"}]}], ")"}], "/", 
   RowBox[{"Sqrt", "[", "2", "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vv", "=", 
   RowBox[{"Matrix", "[", "v", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"vv", "//", "Normal"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1380023532,ExpressionUUID->"d2f44f36-c6cf-41a0-bc57-97dd7ba03db8"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   InterpretationBox[
    TemplateBox[{"\"\[SpaceIndicator]\""},
     "Ket"],
    Ket[<||>]], "+", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox[
         RowBox[{"-", "3"}], 
         InterpretationBox["S", 
          $CellContext`S[Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[Q3`$] -> -3|>]]}], 
  SqrtBox["2"]]], "Output",
 CellLabel->"Out[2]=",
 CellID->1171468785,ExpressionUUID->"26ae95d1-ebbd-4ed7-86e0-46bf94f335ed"],

