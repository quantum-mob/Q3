Cell[TextData[{
 "In both cases, the complex matrix ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "60132d85-60e5-4fbc-a80d-dc11c04aac3f"],
 " specifies the linear combinations of ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " operators. This is useful because while the fermionic quantum computation \
is simulated based on the ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " representation, sometimes the ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " representation is more intuitive."
}], "Notes",
 CellID->2109920175,ExpressionUUID->"e54c44ee-cb45-44ce-b898-c7b110ebbad4"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiElements"]], "paclet:QuantumMob/Q3/ref/BravyiElements", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["m", "TI"], ",", " ", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["2", "TR"]], ",", " ", 
      StyleBox["\[Ellipsis]", "TR"], ",", " ", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox[
        RowBox[{
         StyleBox["2", "TR"], 
         StyleBox["n", "TI"]}],
        ZeroWidthTimes->True]]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9b360e50-1dcf-4c20-858c-740ed95e399c"],
 " for Majorana fermion modes ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7b3d9350-0f74-4db5-a1a1-2a1ec360ef73"],
 " returns a list of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalSigma]", 
     RowBox[{"j", "=", "1"}], 
     RowBox[{"2", "n"}]], 
    SubscriptBox["m", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
    SubscriptBox["c", "j"]}], TraditionalForm]],ExpressionUUID->
  "170d4779-6630-41b2-8334-853a75b8a4e8"],
 "."
}], "Notes",
 CellID->1389206880,ExpressionUUID->"2dbab61d-bf2b-4893-9002-59ad12314e10"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiElements"]], "paclet:QuantumMob/Q3/ref/BravyiElements", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["m", "TI"], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["1", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["n", "TI"]]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2faf9b16-5f67-487b-8a0c-ad81252baf21"],
 " for Dirac fermion modes ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["a", "TI"], 
     StyleBox["1", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
