  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], "n"], 
     RowBox[{
      SubscriptBox["m", 
       RowBox[{"i", ",", 
        RowBox[{
         RowBox[{"2", "j"}], "-", "1"}]}]], "\[ThinSpace]", "(", 
      RowBox[{
       SubscriptBox["a", "j"], "+", 
       SubsuperscriptBox["a", "j", "\[Dagger]"]}], ")"}]}], "-", 
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], "n"], 
     RowBox[{
      SubscriptBox["m", 
       RowBox[{"i", ",", 
        RowBox[{"2", "j"}]}]], "\[ThinSpace]", "(", 
      RowBox[{
       SubscriptBox["a", "j"], "-", 
       SubsuperscriptBox["a", "j", "\[Dagger]"]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"032640fa-bfc5-434f-8af2-c034df7f5be2"],
 "."
}], "Notes",
