Cell["\<\
As you can see below, exploiting the parity is significantly faster:\
\>", "ExampleText",
 CellID->150698936,ExpressionUUID->"d88b02ca-1a49-4999-9d58-933a76921604"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", 
   RowBox[{"full", "=", 
    RowBox[{"ChebyshevCoefficients", "[", 
     RowBox[{"fun", ",", 
      RowBox[{"$d", "+", "1"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EchoTiming", "[", 
   RowBox[{"mint", "=", 
    RowBox[{"ChebyshevCoefficients", "[", 
     RowBox[{"fun", ",", 
      RowBox[{"$n", "->", "$parity"}]}], "]"}]}], "]"}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->943915175,ExpressionUUID->"ac9d71dd-6aa2-4778-bbb1-a2215d0db092"],

