Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", 
  RowBox[{"3", "*", 
   RowBox[{"x", "^", "2"}], "*", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "2"}], "*", "x"}], "]"}], "*", 
   RowBox[{"Sin", "[", 
    RowBox[{"2", " ", "x", "*", "Pi"}], "]"}]}]}]], "Input",
