Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"full", "[", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"1", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", "$parity"}], ")"}], "/", "2"}]}], ";;", "All", ";;",
