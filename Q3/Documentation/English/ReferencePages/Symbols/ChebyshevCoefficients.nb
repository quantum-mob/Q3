Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "\t", "ExampleDelimiter",ExpressionUUID->
   "db931335-a648-4f54-afd3-59d99637663f"],
  $Line = 0; Null]], "ExampleDelimiter",
 CellID->431997124,ExpressionUUID->"01b13770-5406-41fc-a3dd-4a55060399a0"],

Cell[TextData[{
 "Exploiting the known parity of target function with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ChebyshevCoefficients"]], 
     "paclet:QuantumMob/Q3/ref/ChebyshevCoefficients", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["poly", "TI"], ",", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["n", "TI"], ",", 
      StyleBox["parity", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f3c173ba-bb7b-4f2b-9113-05bf02a1bf2c"],
 " is useful when the evaluation of ",
 Cell[BoxData[
  StyleBox["poly", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d3d88bcf-6122-48d3-a63e-45c02a60f7b7"],
 " is computationally expensive. Here is an example in the context of ",
 ButtonBox["quantum signal processing",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/QSP"],
 "."
}], "ExampleText",
 CellID->1581053267,ExpressionUUID->"f8fe9ace-7f64-49a3-a71f-7248f63006e2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "103", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QSP`"],
 CellLabel->"In[1]:=",
 CellID->229391064,ExpressionUUID->"06aa4976-1b36-479e-843b-3487ec0a7f46"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$d", "=", 
   RowBox[{"500", "+", 
    RowBox[{"RandomChoice", "[", 
     RowBox[{"Range", "[", 
      RowBox[{"5", ",", "10"}], "]"}], "]"}]}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"polynomial", " ", "degree"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$n", "=", 
   RowBox[{"Ceiling", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"$d", "+", "1"}], ")"}], "/", "2"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"$parity", "=", 
  RowBox[{"1", "-", 
   RowBox[{"2", "*", 
    RowBox[{"Mod", "[", 
     RowBox[{"$d", ",", "2"}], "]"}]}]}]}]}], "Input",
 CellProlog:>Needs["QSP`"],
 CellLabel->"In[2]:=",
 CellID->1677653743,ExpressionUUID->"e44543a4-c85f-4ef9-be5a-97f82f7e103c"],

