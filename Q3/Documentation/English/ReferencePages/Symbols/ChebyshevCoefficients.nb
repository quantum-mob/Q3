Cell["\<\
However, the expansion does reproduce the target function at the so-called \
Chebyshev points of the first kind:\
\>", "ExampleText",
 CellID->1339988060,ExpressionUUID->"b170925a-73a8-4dc5-9d2d-d320b0e93acd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"xx", "=", 
   RowBox[{"ChebyshevPoints", "[", 
    RowBox[{"$d", "+", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"yy", "=", 
   RowBox[{"f", "/@", "xx"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xy", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"xx", ",", "yy"}], "}"}]}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->200479929,ExpressionUUID->"0042ec99-075c-4038-ab8b-738a421d66e3"],

Cell["\<\
The two functions give the same values at the Chebyshev points:\
\>", "ExampleText",
 CellID->1295364188,ExpressionUUID->"b1ead9c4-a1ec-428a-94c0-f94e7e72f15a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"pts", "=", 
   RowBox[{"ListPlot", "[", 
    RowBox[{"xy", ",", 
     RowBox[{"PlotStyle", "->", "Red"}], ",", 
     RowBox[{"PlotMarkers", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<\[FilledCircle]\>\"", ",", "16"}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{"fig", ",", "pts"}], "}"}], "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->2057468427,ExpressionUUID->"0acaeee7-e1cf-4772-aa59-a2828060aca8"],

