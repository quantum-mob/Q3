Cell["Calculate the Chebyshev coefficients:", "ExampleText",
 CellID->1125515293,ExpressionUUID->"1e5f6227-dc07-46f8-bfdc-5743b55ae4db"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$d", "=", "7"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1321059822,ExpressionUUID->"4bd6de1a-3c21-4bb3-b012-b72d1d291ded"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cc", "=", 
  RowBox[{
   RowBox[{"ChebyshevCoefficients", "[", 
    RowBox[{"f", ",", 
     RowBox[{"$d", "+", "1"}]}], "]"}], "//", "N"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1713910240,ExpressionUUID->"ccaabdd7-b67b-4713-88dc-4fcccc50939c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1.5486812738439206`", ",", 
   RowBox[{"-", "2.808641684641369`"}], ",", "1.3769706370605979`", ",", 
   "0.18741419372214418`", ",", 
   RowBox[{"-", "1.3641124919024084`"}], ",", "2.0687364333043425`", ",", 
   RowBox[{"-", "1.6855946487513542`"}], ",", "0.9709515038561375`"}], 
  "}"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->296989188,ExpressionUUID->"42644b8b-8ad6-4b2a-bfcd-c5e5b043a450"]
}, Open  ]],

Cell["\<\
With the above coefficients, construct an approximate polynomial:\
\>", "ExampleText",
 CellID->986330755,ExpressionUUID->"fa5baf31-7dc1-4521-a882-d2e5c5179173"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"g", "=", 
  RowBox[{"ChebyshevSeries", "[", "cc", "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->97760346,ExpressionUUID->"7eb465ca-2a7e-4cf0-acea-dc5be28b5ca5"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["ChebyshevSeries",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
              ButtonFunction :> (Typeset`open$$ = True), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Degree: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["7", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Parity: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["\"Indefinite\"", "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}], True -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxCloser"]], 
              ButtonFunction :> (Typeset`open$$ = False), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Degree: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["7", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Parity: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["\"Indefinite\"", "SummaryItem"]}]}, {
               RowBox[{
                 TagBox["\"Coefficients: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox[
                  RowBox[{"{", 
                    RowBox[{"1.5486812738439206`", ",", 
                    RowBox[{"-", "2.808641684641369`"}], ",", 
                    "1.3769706370605979`", ",", "0.18741419372214418`", ",", 
                    RowBox[{"-", "1.3641124919024084`"}], ",", 
                    "2.0687364333043425`", ",", 
                    RowBox[{"-", "1.6855946487513542`"}], ",", 
                    "0.9709515038561375`"}], "}"}], "SummaryItem"]}]}}, 
             GridBoxAlignment -> {
              "Columns" -> {{Left}}, "Rows" -> {{Automatic}}}, AutoDelete -> 
             False, GridBoxItemSize -> {
              "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
             GridBoxSpacings -> {"Columns" -> {{2}}, "Rows" -> {{Automatic}}},
              BaseStyle -> {
              ShowStringCharacters -> False, NumberMarks -> False, 
               PrintPrecision -> 3, ShowSyntaxStyles -> False}]}}, 
          GridBoxAlignment -> {"Columns" -> {{Left}}, "Rows" -> {{Top}}}, 
          AutoDelete -> False, 
          GridBoxItemSize -> {
           "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}, 
          BaselinePosition -> {1, 1}]}, 
       Dynamic[Typeset`open$$], ImageSize -> Automatic]},
     "SummaryPanel"],
    DynamicModuleValues:>{}], "]"}],
  QuantumMob`Q3`ChebyshevSeries[{1.5486812738439206`, -2.808641684641369, 
    1.3769706370605979`, 0.18741419372214418`, -1.3641124919024084`, 
    2.0687364333043425`, -1.6855946487513542`, 0.9709515038561375} -> 0],
  Editable->False,
  SelectWithContents->True,
  Selectable->False]], "Output",
 CellLabel->"Out[5]=",
 CellID->2106110035,ExpressionUUID->"431bd317-cc72-470a-953c-d41e2506cdfc"]
}, Open  ]],

Cell[TextData[{
 "Compare the approximate polynomial with the original function. Since ",
 StyleBox["f(x)",
  FontSlant->"Italic"],
 " is not a polynomial of degree 7 (or less), the expansion does not \
reproduce ",
 StyleBox["f(x)",
  FontSlant->"Italic"],
 ":"
}], "ExampleText",
 CellID->436466161,ExpressionUUID->"2a8587b3-a9e1-454f-be8a-ba14055f3efb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fig", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], ",", 
      RowBox[{"g", "[", "x", "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<f\>\"", ",", "\"\<g\>\""}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<f(x)\>\""}], "}"}]}]}], "]"}]}]], "Input",\

