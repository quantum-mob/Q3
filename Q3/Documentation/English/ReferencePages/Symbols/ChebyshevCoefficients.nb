Cell[TextData[{
 "Now, consider an odd function (",
 Cell[BoxData[
  RowBox[{
   StyleBox["parity", "TI"], "=", 
   RowBox[{"-", "1"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3f69e94d-7c17-45a6-8ee1-ea6ea53a256d"],
 "):"
}], "ExampleText",
 CellID->2036235213,ExpressionUUID->"39840f70-97f0-4ae7-8a0f-db20cae901a7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"target", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"x", "^", "3"}], "*", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "5"}], "*", 
     RowBox[{"x", "^", "2"}]}], "]"}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
