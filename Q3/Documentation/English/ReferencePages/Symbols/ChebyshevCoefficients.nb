Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "ea25ab84-6aa3-4e2e-8aea-b3b78f86f651"],
 "be a function defined for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "1"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"fd190645-41da-42d9-a81a-cb18b2935cc2"],
 ". The coefficients ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["c", "0"], ",", 
     SubscriptBox["c", "1"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["c", 
      RowBox[{"n", "-", "1"}]]}], "}"}], TraditionalForm]],ExpressionUUID->
  "975d13ed-bfd0-4fa9-a910-66c7364a8783"],
 " are determined so that the polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "x", ")"}], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], 
      RowBox[{"n", "-", "1"}]], 
     RowBox[{
      SubscriptBox["c", "k"], 
      RowBox[{
       SubscriptBox["T", "k"], "(", "x", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"f319c18b-8724-4a52-a827-9663f3b1a638"],
 " of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "804b216d-a57c-4dcc-809a-cf070cf8d480"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "57d45073-b25b-4702-8317-cd5477101cb0"],
 " is the Chebyshev polynomial of the first kind of degree ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "364d592c-0036-4d5b-b533-1d99edb779ca"],
 ", reproduces the target function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     SubscriptBox["x", "k"], ")"}], "=", 
    RowBox[{"P", "(", 
     SubscriptBox["x", "k"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6e498d2d-59ca-4294-b7b4-abb9fcfdfd59"],
 " at the so-called ",
 StyleBox[ButtonBox["Chebyshev points of the first kind",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevPoints"],
  FontSlant->"Italic"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "k"], ":=", 
    RowBox[{"cos", "(", 
     RowBox[{
      RowBox[{"\[Pi]", "(", 
       RowBox[{"k", "-", 
        RowBox[{"1", "/", "2"}]}], ")"}], "/", "n"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"a20cee04-7a7a-4146-b855-818f5e3d83af"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "\[Ellipsis]", ",", "n"}], 
   TraditionalForm]],ExpressionUUID->"d0385ee3-e4f1-4b25-a342-33ed221d51cd"],
 "."
}], "Notes",
 CellID->182274,ExpressionUUID->"da954215-15c0-43d6-8105-2d7379de75a2"],

