   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "825bde1e-c360-46e6-9ae3-d77f39649827"],
 " is a polynomial of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "0430383d-8e00-4826-aec3-66740b52c5fc"],
 " or less, then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "x", ")"}], "=", 
    RowBox[{"f", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "6bc665a8-2fb0-437e-956b-8e01d850c8e0"],
 " at all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "1"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"11b4869c-7b2f-4abf-8411-36aa52f9fef0"],
 "."
}], "Notes",
 CellID->1495369264,ExpressionUUID->"4b2aeacd-6cac-4628-9794-2872041100e0"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ChebyshevCoefficients"]], 
    "paclet:QuantumMob/Q3/ref/ChebyshevCoefficients", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fd48f1cf-1b58-4b65-8fe8-11262d94de03"],
 " does not check if ",
 Cell[BoxData[
  StyleBox["poly", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dbaa8a3e-855d-490a-8237-9d45d799ae50"],
 " is a polynomial of suitable degree, but simply assumes it. If poly is not \
actually a polynomial or a higher-degree polynomial, then the returned \
coefficients describes the target function only approximately."
}], "Notes",
 CellID->944441675,ExpressionUUID->"a4d0f135-7374-446b-a70f-667958b12adc"],

Cell[TextData[{
 "Exploiting the known parity of target function with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ChebyshevCoefficients"]], 
     "paclet:QuantumMob/Q3/ref/ChebyshevCoefficients", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["poly", "TI"], ",", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["n", "TI"], ",", 
      StyleBox["parity", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "024cfe58-cf41-4007-a4d0-b03210ed6ebd"],
 " is useful when the evaluation of ",
 Cell[BoxData[
  StyleBox["poly", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "91d77a3f-a112-41fb-a6a9-38b8b48f4281"],
 " is computationally expensive."
}], "Notes",
 CellID->2126390889,ExpressionUUID->"233ed34d-7007-4681-822a-205a1c00feb0"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ChebyshevCoefficients"]], 
     "paclet:QuantumMob/Q3/ref/ChebyshevCoefficients", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["poly", "TI"], ",", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["n", "TI"], ",", 
      StyleBox["parity", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ccdf4428-2580-41d5-92a0-56d96ab66652"],
 " does not check the actual parity of ",
 Cell[BoxData[
  StyleBox["poly", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b25d71df-faec-46e6-8e20-52892aae1528"],
 ", but simply assumes the given ",
 Cell[BoxData[
  StyleBox["parity", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0f7461e4-056c-496b-8177-783b6ad327e8"],
 "."
}], "Notes",
 CellID->1775269502,ExpressionUUID->"f92b743b-2bdf-4e3a-bf78-b7934a1b27d6"],

Cell[TextData[{
 "The ",
 StyleBox["full",
  FontSlant->"Italic"],
 " vs ",
 StyleBox["reduced list of Chebyshev coefficients",
  FontSlant->"Italic"],
 " for polynomials with definite parity: For an even polynomial of degree ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "711beb80-196f-4e26-9d8e-2a56b5752913"],
 ", all coefficients in Chebyshev polynomials of odd degree vanish. \
Therefore, it is sufficient to keep the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "d"], ":=", 
    RowBox[{"\[LeftCeiling]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"d", "+", "1"}], ")"}], "/", "2"}], "\[RightCeiling]"}]}], 
   TraditionalForm]],ExpressionUUID->"2a33f3c2-1318-4744-ba24-1b7b3351e522"],
 " non-vanishing coefficients ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["0", "TR"]], ",", 
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["2", "TR"]], ",", 
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["4", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"], ",", 
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox[
     RowBox[{
      StyleBox["2", "TR"], 
      RowBox[{
       StyleBox["(", "TR"], 
       RowBox[{
        SubscriptBox[
         StyleBox["n", "TI"], 
         StyleBox["d", "TI"]], "-", "1"}], ")"}]}],
     ZeroWidthTimes->True]]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d8cfe9e4-885a-4bde-9ead-713a4ead292b"],
 ". Similarly, for an odd polynomial, it suffices to keep the  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "d"], ":=", 
    RowBox[{"\[LeftCeiling]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"d", "+", "1"}], ")"}], "/", "2"}], "\[RightCeiling]"}]}], 
   TraditionalForm]],ExpressionUUID->"dec9e110-1b4d-4f1b-812a-ff31c27f208e"],
 " non-vanishing coefficients ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["3", "TR"]], ",", 
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["5", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"], ",", 
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox[
     RowBox[{
      RowBox[{
       StyleBox["2", "TR"], 
       SubscriptBox[
        StyleBox["n", "TI"], 
        StyleBox["d", "TI"]]}], "-", "1"}],
     ZeroWidthTimes->True]]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4dfe0fca-d67e-4745-a952-5a2627640f27"],
 ". Such a list of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "d"], TraditionalForm]],ExpressionUUID->
  "4b57d2ab-b832-4a04-98e9-959835628704"],
 " non-vanishing coefficients is called the ",
 StyleBox["reduced",
  FontSlant->"Italic"],
 " list of Chebyshev coefficients, and together with parity ",
 Cell[BoxData[
  StyleBox["p", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f55d84f0-05d3-4393-8986-dd3193c29ba6"],
 ", uniquely specify the corresponding polynomial. The correspondence between \
the full and reduced lists of Chebyshev coefficients is obvious as follows:\
\[LineSeparator]\t",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["0", "TR"]], ",", "0", ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["2", "TR"]], ",", "0", ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["4", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", "0", ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox[
        RowBox[{
         StyleBox["2", "TR"], 
         RowBox[{
          StyleBox["(", "TR"], 
          RowBox[{
           StyleBox["n", "TI"], "-", "1"}], ")"}]}],
        ZeroWidthTimes->True]]}], "}"}], "\[LeftRightArrow]", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["0", "TR"]], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["2", "TR"]], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["4", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox[
        RowBox[{
         StyleBox["2", "TR"], 
         RowBox[{
          StyleBox["(", "TR"], 
          RowBox[{
           StyleBox["n", "TI"], "-", "1"}], ")"}]}],
        ZeroWidthTimes->True]]}], "}"}]}], "\[Rule]", 
   RowBox[{"+", "1"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a433372b-bbe3-41f7-9a90-114a83d65c6d"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["1", "TR"]], ",", "0", ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["3", "TR"]], ",", "0", ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["5", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", "0", ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox[
        RowBox[{
         RowBox[{
          StyleBox["2", "TR"], 
          StyleBox["n", "TI"]}], "-", "1"}],
        ZeroWidthTimes->True]]}], "}"}], "\[LeftRightArrow]", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["3", "TR"]], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["5", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox[
        RowBox[{
         RowBox[{
          StyleBox["2", "TR"], 
          StyleBox["n", "TI"]}], "-", "1"}],
        ZeroWidthTimes->True]]}], "}"}]}], "\[Rule]", 
   RowBox[{"-", "1"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "703d71f7-e176-4c85-a508-0e1b1b12114b"],
 "."
}], "Notes",
 CellID->1584125147,ExpressionUUID->"8837a503-f9c8-49c7-86dc-895d5f8d2621"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

