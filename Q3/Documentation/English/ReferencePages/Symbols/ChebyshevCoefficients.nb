Cell[BoxData[
 RowBox[{
  RowBox[{"target", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"x", "^", "2"}], "*", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "5"}], "*", 
     RowBox[{"x", "^", "2"}]}], "]"}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
