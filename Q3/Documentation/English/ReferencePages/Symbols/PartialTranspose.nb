Cell[TextData[{
 "Consider a system consisting of two subsystem with Hilbert-space dimensions \
2 and 3, respectively. ",
 StyleBox["A", "MathCaption"],
 " and ",
 StyleBox["B", "MathCaption"],
 " are matrix representations of operators on two respective systems."
}], "ExampleText",
 CellID->1317285909,ExpressionUUID->"a59f4a51-2774-4d71-a0ef-e548778e4a47"],

