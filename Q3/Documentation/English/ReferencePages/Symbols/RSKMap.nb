    "keywords" -> {
     "Young tableaux", "Weyl tableaux", "Schur-Weyl duality", 
      "Robinson-Schensted-Knuth algorithm", "RSK algorithm"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "RSKMap[{a1, a2, ..., an}, {b1, b2, ..., bn}] returns a pair {p, q} of \
Weyl tableaux (i.e., semistandard Young tableaux), corresponding to the \
generalized permutation specified by words {a1, a2, ..., an} and {b1, b2, \
..., bn}. RSKMap[{b1, b2, ..., bn}] is equivalent to RSKMap[{{1, 2, ..., n}, \
{b1, b2, ..., bn}}], in which case p is a standard Young tableau. RSKMap[mat] \
considers the generalized permutation specified by matrix mat with \
non-negative integer entries.", "synonyms" -> {}, "tabletags" -> {}, "title" -> 
    "RSKMap", "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "RSKMap", "type" -> "Symbol", "uri" -> "QuantumMob/Q3/ref/RSKMap"}},
