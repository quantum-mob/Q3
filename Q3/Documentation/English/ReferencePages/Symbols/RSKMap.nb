Cell[TextData[{
 "The ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Robinson\[Dash]Schensted\[Dash]Knuth (RSK) correspondence"]], 
    "https://en.wikipedia.org/wiki/Robinson\[Dash]Schensted\[Dash]Knuth_\
correspondence"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "8178cf3f-e9c1-4e2a-9fbc-8600d0fc6d9a"],
 " is a combinatorial bijection between so-called ",
 "generalized permutations",
 " and pairs of Weyl tableaux (semistandard Young tableaux)."
}], "Notes",
 CellID->1090958935,ExpressionUUID->"97157381-c876-4a00-99ee-879cb5df3974"],

Cell[TextData[{
 "A ",
 StyleBox["generalized permutation",
  FontSlant->"Italic"],
 " may be specified by means of a ",
 StyleBox["generalized permutation matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "66020aa8-80eb-49e6-974a-35c0a0e66ccc"],
 " with non-negative integer entries or ",
 StyleBox["two-word array",
  FontSlant->"Italic"],
 " (also known as ",
 StyleBox["two-line array",
  FontSlant->"Italic"],
 ") \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["i", "1"], 
       SubscriptBox["i", "2"], "\[Ellipsis]", 
       SubscriptBox["i", "n"]},
      {
       SubscriptBox["j", "1"], 
       SubscriptBox["j", "2"], "\[Ellipsis]", 
       SubscriptBox["j", "n"]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "0e962dcc-5cc4-4b0b-86dd-b8287747fd3e"],
 " .\[LineSeparator]The first word ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["i", "1"], 
       SubscriptBox["i", "2"], "\[Ellipsis]", 
       SubscriptBox["i", "n"]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "87989844-5f37-4a8e-bd0b-3a2a0f74184a"],
 " must weakly increase (i.e., be non-decreasing), and the second word \
satisfies that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["j", "k"], "\[LessEqual]", 
    SubscriptBox["j", 
     RowBox[{"k", "+", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "4fda8fed-8686-47f4-b360-fac4231035dc"],
 " whenever ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["i", "k"], "=", 
    SubscriptBox["i", 
     RowBox[{"k", "+", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "1398b39a-7cdd-4d5d-8827-3d835f354508"],
 ". "
}], "Notes",
 CellID->75390004,ExpressionUUID->"93df332d-ebc9-4ab5-bb5d-61d83c2315be"],

Cell[TextData[{
 "Matrix element ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],ExpressionUUID->
  "3f633c56-a183-48cc-a4b4-76320846ee98"],
 " gives the number of times ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"i"},
      {"j"}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "d66e3862-43ff-421b-b6f9-37618e6a43f5"],
 " occurs in the two-word array."
}], "Notes",
 CellID->493319526,ExpressionUUID->"96bea556-3db0-44b9-9200-07df7c461bb5"],

Cell[TextData[{
 "The correspondence between an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "af99ec24-5a49-4151-9698-44ae51065912"],
 " generalized permutation matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "4900683e-9ac8-4bfc-92b5-d9c12b69e78f"],
 " and a pair ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", ",", "q"}], "}"}], TraditionalForm]],ExpressionUUID->
  "b989ed20-38b5-45c2-b79e-2b48104d3553"],
 " of Weyl tableaux of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "e55f3c4d-e4da-4a84-80b6-584fb3c3ffbd"],
 ": Tableau ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "07673cd5-03b0-44c7-8389-0b247743663b"],
 " has entries in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", "m"}], "}"}], 
   TraditionalForm]],ExpressionUUID->"3fbd11ef-812b-4bc5-b369-ae4d4649d7eb"],
 " and tableau ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "fa8957f4-9cc3-4821-9f8f-c55d4c7ce761"],
 " has entries in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", "n"}], "}"}], 
   TraditionalForm]],ExpressionUUID->"e2096873-670c-4f93-af02-fdb8a5fac340"],
 ". The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["i", "th"], TraditionalForm]],ExpressionUUID->
  "68a2ca6e-b4de-46a9-8ef9-cfc197e6be37"],
 " row sum of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "88c37768-5df8-4624-ba57-aa029ee954e3"],
 " is the number of times ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "48f17f3b-ceb2-419a-b720-d186f29886fa"],
 " appears in ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "acca4072-c8c3-4dd5-95f5-84009330e8b8"],
 " whereas the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "th"], TraditionalForm]],ExpressionUUID->
  "9583b25d-911c-4850-b4a8-726228e796d9"],
 " column sum of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "629cd10c-7a05-4ff5-9ec9-f8473d9387ca"],
 " is the number of times ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "803dcaaa-539e-439e-b839-8dcce8b0fde3"],
 " appears in ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "76aa67ad-770d-4c84-bd8d-b48189e58b3a"],
 ". The sum of entries of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b4118128-00a3-4e19-aea5-af178581e1b1"],
 " determines the ",
 StyleBox["degree",
  FontSlant->"Italic"],
 " (or size, i.e., the number of boxes) of ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "4e83b277-d923-425d-a756-8fb39aa9241f"],
 " and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "03b5803f-b059-42d9-b6de-d75cc3c3ddb7"],
 ". ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "48387b27-40d7-4673-a29c-2d8cfc57ece6"],
 " is called a ",
 StyleBox["word matrix",
  FontSlant->"Italic"],
 " if every row sum equals 1 (",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "73624f7d-2be6-48c4-8122-df45a479c885"],
 " is a standard Young tableau), and it is called a ",
 StyleBox["permutation matrix",
  FontSlant->"Italic"],
 " if every row and column sum equals 1 (both ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "df8e15f7-aeb1-4f65-bb3f-0cc7d0c24d06"],
 " and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "05004c5d-6e43-4a3a-894b-0e34100f61e1"],
 " are standard Young tableaux). See ",
 ButtonBox["Fulton (1997)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1017/CBO9780511626241"], None}],
 " and Section 4.8 in ",
 ButtonBox[" Sagan (2001)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-1-4757-6804-6"], None}],
 " for more details."
}], "Notes",
 CellID->880669647,ExpressionUUID->"df561518-a7bc-41d4-8343-1110a957f398"],

Cell[TextData[{
 "The RSK correspondence is a generalization of the Robinson\[Dash]Schensted \
correspondence, where ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "81396484-b8d6-4575-a870-58225e200cd2"],
 " is a permutation matrix and both ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "d9f8da3a-28b0-4725-84a6-3402822f89a7"],
 " and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "60256a74-9abf-4742-8f5d-33827e4ad1dd"],
 " are standard Young tableaux."
}], "Notes",
 CellID->389480274,ExpressionUUID->"cb182fe7-6240-455c-a07f-71e45714eb00"],

Cell["\<\
The implementation is according to the Robinson-Schensted-Knuth (RSK) \
algorithm.\
\>", "Notes",
 CellID->2057633113,ExpressionUUID->"4be85558-1bce-4d40-8035-4d5c17d50b21"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

