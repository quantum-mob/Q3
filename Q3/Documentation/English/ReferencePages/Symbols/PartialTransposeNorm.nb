Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PartialTransposeNorm"]], 
    "paclet:QuantumMob/Q3/ref/PartialTransposeNorm", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "23e9d8cd-bd6e-45f9-af18-ef493be439b1"],
 " is useful, for example, when one handles block-diagonal matrices since ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PartialTransposeNorm"]], 
    "paclet:QuantumMob/Q3/ref/PartialTransposeNorm", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "97ccfa0d-46d2-488d-b4c6-c11fc5965963"],
 " is \"extensive\" (proportional to the number of blocks); the ",
 ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/LogarithmicNegativity"],
 " is not extensive."
}], "Notes",
 CellID->782859541,ExpressionUUID->"05687f6b-d5a7-44d4-9f74-a060c53a90da"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/LogarithmicNegativity"],
  FontSlant->"Italic"],
 " is the logarithm of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PartialTransposeNorm"]], 
    "paclet:QuantumMob/Q3/ref/PartialTransposeNorm", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "08e6f150-5a82-4496-909b-831000931b94"],
 " whereas ",
 StyleBox["negativity",
  FontSlant->"Italic"],
 " is ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"PartialTransposeNorm", "-", "1"}], ")"}], "/", "2"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e00c454e-ad19-4577-9236-d7a2541172d6"],
 "."
}], "Notes",
 CellID->139680433,ExpressionUUID->"68a0a86f-4efa-46b3-bd1d-30b2d283d02d"],

Cell["\<\
The logarithmic negativity is an entanglement monotone for mixed states, \
quantitatively measuring quantum entanglement.\
\>", "Notes",
 CellID->1614280326,ExpressionUUID->"ea050a02-97bc-4b10-b95d-1ca668f7be94"],

Cell[TextData[{
 "For a mixed state \[Rho] of a bipartite system consisting of subsystems  ",
 StyleBox["A",
  FontSlant->"Italic"],
 " and ",
 StyleBox["B",
  FontSlant->"Italic"],
 ", the logarithmic negativity is defined by ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["log", "2"], 
   SubscriptBox[
    RowBox[{"\[LeftDoubleBracketingBar]", 
     SuperscriptBox["\[Rho]", 
      StyleBox[
       SubscriptBox["T", "B"],
       FontSlant->"Italic"]], "\[RightDoubleBracketingBar]"}], "tr"]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "33efd276-e0b9-4bc9-9da6-eadeb1730948"],
 ", where ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{
   "\[LeftDoubleBracketingBar]", "\[CenterEllipsis]", 
    "\[RightDoubleBracketingBar]"}], "tr"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "24adf5ea-60d3-4116-93d4-82c17abb7061"],
 " indicates the ",
 ButtonBox["trace norm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/TraceNorm"],
 " of operators or matrices."
}], "Notes",
 CellID->453625225,ExpressionUUID->"ed94e1d4-e39a-44f3-abdd-da7ae4b333c3"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

