Cell[TextData[{
 "The above operator expression can be analyzed for the coefficient tensor. \
In fact, it corresponds to the Pauli decomposition of the operator. ",
 StyleBox["NOTE that the coefficients are normalized for Pauli matrices (",
  FontColor->RGBColor[1, 0, 0]],
 StyleBox["Pauli[j]=2 S[j]", "Input",
  FontColor->RGBColor[1, 0, 0]],
 StyleBox[")",
  FontColor->RGBColor[1, 0, 0]],
 "."
}], "ExampleText",
 CellID->1792872811,ExpressionUUID->"4dfb65ab-7cdf-4c33-b020-6a54cfb9c641"],

