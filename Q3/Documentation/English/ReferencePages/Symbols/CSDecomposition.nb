  FontSlant->"Italic"],
 " check wether matrix ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "18fbc36a-d0b4-4759-a3f1-8f5dcd17be2a"],
 " is unitary or not."
}], "Notes",
 CellID->347180908,ExpressionUUID->"f80ae254-0f77-40b9-be06-4e91c50b4222"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "43deed4b-3fc7-4086-a5e6-5ea41d84bda3"],
 ", ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "68463770-c43c-4569-8104-b7dc07d298f5"],
 " and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "9834e183-b647-47a5-8e01-3eac1a2bf8e4"],
 " be given integers with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "<", "p", "\[LessEqual]", "q", "<", "n"}], TraditionalForm]],
  ExpressionUUID->"8736d2b0-c91b-462f-9b11-7744ed092598"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "+", "q"}], "=", "n"}], TraditionalForm]],ExpressionUUID->
  "3bb00032-1cb6-406d-af70-3815cb478f85"],
 ". Let\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["U", "11"], 
        SubscriptBox["U", "12"]},
       {
        SubscriptBox["U", "21"], 
        SubscriptBox["U", "22"]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "165fb8ca-39e9-4950-b70a-b9d4e3c093c8"],
 "\[LineSeparator]be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "25648bbf-1034-4455-8874-d6d9a0eaa6b8"],
 " unitary matrix, where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "11"], TraditionalForm]],ExpressionUUID->
  "7b180a04-a11c-44e4-a6a6-1ca386d20d63"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "22"], TraditionalForm]],ExpressionUUID->
  "f573795b-2f17-4b9e-8fd9-e0e0f13ccc20"],
 " are a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "\[Times]", "p"}], TraditionalForm]],ExpressionUUID->
  "9aa2b1ea-290d-4995-b376-23868b2b46a4"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "\[Times]", "q"}], TraditionalForm]],ExpressionUUID->
  "6a073ab5-6cce-4fb9-b0df-8bb06d892fdf"],
 " matrices, respectively. Then, the cosine-sine (CS) decomposition of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "d24c8f0d-49d0-4ff5-9a53-4ccf379f7e59"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["U", "11"], 
        SubscriptBox["U", "12"]},
       {
        SubscriptBox["U", "21"], 
        SubscriptBox["U", "22"]}
      }], ")"}], "=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["V", "1"], "0"},
        {"0", 
         SubscriptBox["V", "2"]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {"C", "S", "0"},
        {
         RowBox[{"-", "S"}], "C", "0"},
        {"0", "0", "I"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SubsuperscriptBox["W", "1", "\[Dagger]"], "0"},
        {"0", 
         SubsuperscriptBox["W", "2", "\[Dagger]"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "983c06ac-2ae1-45f3-8216-6ecc6d123dff"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "1"], TraditionalForm]],ExpressionUUID->
  "b795f16d-89d2-4441-8232-f333b8e247fe"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["W", "1"], TraditionalForm]],ExpressionUUID->
  "6ce3db41-2da7-4bc4-9740-2d1d2a11a0ce"],
 " are ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "\[Times]", "p"}], TraditionalForm]],ExpressionUUID->
  "194684a4-dc43-4997-a7ac-56be2bb32537"],
 " unitary matrices, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "2"], TraditionalForm]],ExpressionUUID->
  "acc4d15f-146f-459b-830e-0f8ece95b391"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["W", "2"], TraditionalForm]],ExpressionUUID->
  "9918a406-cbfa-4d71-a378-cb8305c644ab"],
 " are ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", "\[Times]", "q"}], TraditionalForm]],ExpressionUUID->
  "5ce02fbd-0068-452c-bbac-52334a8b85d1"],
 " unitary matrices, ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "7b2fd98f-ff7a-45c7-9477-1256917802d7"],
 " is the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"q", "-", "p"}], ")"}], "\[Times]", 
    RowBox[{"(", 
     RowBox[{"q", "-", "p"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "2248688a-57aa-4fa5-bc69-a70e8cebef08"],
 " identity matrix,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"C", ":=", 
    RowBox[{"diag", "(", 
     RowBox[{
      SubscriptBox["\[Sigma]", "1"], ",", 
      SubscriptBox["\[Sigma]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Sigma]", "p"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"2952277c-1851-4b34-9c6a-51a0e647e0c5"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", ":=", 
    RowBox[{"diag", "(", 
     RowBox[{
      SqrtBox[
       RowBox[{"1", "-", 
        SubsuperscriptBox["\[Sigma]", "1", "2"]}]], ",", 
      SqrtBox[
       RowBox[{"1", "-", 
        SubsuperscriptBox["\[Sigma]", "2", "2"]}]], ",", "\[Ellipsis]", ",", 
      SqrtBox[
       RowBox[{"1", "-", 
        SubsuperscriptBox["\[Sigma]", "p", "2"]}]]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"9552c0e4-bd99-435e-9ff4-baef646615e5"],
 ",\nand ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Sigma]", "1"], "\[LessEqual]", 
    SubscriptBox["\[Sigma]", "2"], "\[LessEqual]", "\[Ellipsis]", "\[LessEqual]", 
    SubscriptBox["\[Sigma]", "p"]}], TraditionalForm]],ExpressionUUID->
  "671ef290-19d1-4989-b548-cba350a6b711"],
 " are the ",
 StyleBox["non-decreasingly",
  FontSlant->"Italic"],
 " ordered singular values of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "11"], TraditionalForm]],ExpressionUUID->
  "84ebc7fd-d236-4ffa-9483-6c9bd42191de"],
 ". Note that we follow the convention in ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Horn and Johnson (2013)"]], 
    "https://doi.org/10.1017/CBO9780511810817"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "09084670-5c16-4f6c-a527-59f86ca236f8"],
 " except that our ordering of the singular values are opposite."
}], "Notes",
 CellID->830460507,ExpressionUUID->"7b85a1f5-649e-4d13-b5a3-71a1c10c12e1"],

Cell[TextData[{
 "The CS decomposition is a parametric description of the set of all unitary \
matrices\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["U", "11"], 
        SubscriptBox["U", "12"]},
       {
        SubscriptBox["U", "21"], 
        SubscriptBox["U", "22"]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "a6e924ac-3624-4a9d-b1af-6680af35cb4b"],
 "\[LineSeparator]of size ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", 
    RowBox[{"p", "+", "q"}]}], TraditionalForm]],ExpressionUUID->
  "ddd3d285-4509-4d85-a336-9c7325d90713"],
 " that are partitioned conformally to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
