Cell[TextData[{
 "The Lie basis adopts the following convention:\[LineSeparator]- Every \
element is Hermitian.\[LineSeparator]- It is orthonormal with respect to the ",
 ButtonBox["Hilbert-Schmidt inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/HilbertSchmidtProduct"],
 " or ",
 ButtonBox["Frobenius inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FrobeniusProduct"],
 ".\[LineSeparator]- The first element is proportional to the identity \
matrix. The rest are all traceless."
}], "Notes",
 CellID->1752261046,ExpressionUUID->"28891087-f34a-4945-a575-d89ebe3a5344"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

