Cell[TextData[{
 "Consider  a system of ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "12d1921b-02f4-4141-a24b-986ccfd55688"],
 "-level quantum system (i.e., a ",
 ButtonBox["qudit",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Qudit"],
 "). The canonical basis of its Hilbert space is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], ",", 
     TemplateBox[{"1"},
      "Ket"], ",", 
     TemplateBox[{"2"},
      "Ket"], ",", "\[Ellipsis]", ",", 
     TemplateBox[{
       RowBox[{"d", "-", "1"}]},
      "Ket"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "436168b2-3f53-42fe-9dc2-e5edc095180c"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":", 
    RowBox[{
     TemplateBox[{"z"},
      "Ket"], "\[RightTeeArrow]", 
     RowBox[{
      TemplateBox[{"z"},
       "Ket"], 
      SuperscriptBox["\[Omega]", "z"]}]}]}], TraditionalForm]],ExpressionUUID->
  "23a98f36-5c30-4ecf-80d8-e5b4bf4bf55b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", ":", 
    RowBox[{
     TemplateBox[{"z"},
      "Ket"], "\[RightTeeArrow]", 
     TemplateBox[{
       RowBox[{"z", "+", "1"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "ddc36c99-aaf5-4844-9466-497b34c42879"],
 " be the ",
 StyleBox["generalized Pauli operators",
  FontSlant->"Italic"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"z", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"d", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "4ba6e5c9-8641-4968-b3d8-b632bab87075"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{"2", "\[Pi]", " ", 
      RowBox[{"\[ImaginaryI]", "/", "d"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ef4e312b-c23c-42ad-bbc1-54750483833b"],
 ". Then, the ",
 StyleBox["Weyl-Heisenberg basis",
  FontSlant->"Italic"],
 " is the generating set of the ",
 StyleBox["generalized Pauli group",
  FontSlant->"Italic"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalP]", "d"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Omega]", "c"], " ", 
       SuperscriptBox["X", "a"], 
       RowBox[{
        SuperscriptBox["Z", "b"], ":", "a"}]}], ",", "b", ",", 
      RowBox[{"c", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{"d", "-", "1"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "2b159e52-4e2a-452a-93b1-57a52b487868"],
 "."
}], "Notes",
 CellID->1882381721,ExpressionUUID->"ba595b76-d30a-407f-b52b-4ad2a9c0ee41"],

Cell[TextData[{
 "Note that the generalized Pauli operators ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "87c95179-0dcd-4004-9b61-852242d3038f"],
 " and ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "38491118-658a-42b4-bb31-484199981e15"],
 " satisfy the Wey-Heisenberg commutation relation\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Z", " ", "X"}], "=", 
    RowBox[{"\[Omega]", " ", "X", " ", "Z"}]}], TraditionalForm]],
  ExpressionUUID->"68ebfc7b-05c4-49b5-83c9-bb16e036b7d8"],
 "."
}], "Notes",
 CellID->770267794,ExpressionUUID->"292c940b-3c2c-4927-ab9a-afcad7f7958a"],

Cell[TextData[{
 "The ",
 StyleBox["Weyl-Heisenberg group",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "of odd degree",
 " ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "885a6f95-0862-45a8-80ee-f665c11ad6f2"],
 " coincides with the generalized Pauli group, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalH]", "d"], ":=", 
    SubscriptBox["\[ScriptCapitalP]", "d"]}], TraditionalForm]],
  ExpressionUUID->"62bc011a-9d4e-4159-93d1-48a417b900ae"],
 "."
}], "Notes",
 CellID->1802696894,ExpressionUUID->"f81e141e-b0eb-48ac-976a-98916d8dd331"],

Cell[TextData[{
 "The ",
 StyleBox["Weyl-Heisenberg group ",
  FontSlant->"Italic"],
 "of even degree",
 StyleBox[" ",
  FontSlant->"Italic"],
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d5cd66c3-3ead-433e-ae03-caba1fc6c8bf"],
 " is achieved by doubling the generalized Pauli group, that is,\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalH]", "d"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Tau]", "c"], 
       SuperscriptBox["X", "a"], 
       RowBox[{
        SuperscriptBox["Z", "b"], ":", "a"}]}], ",", "b", ",", 
      RowBox[{"c", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{"d", "-", "1"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "bba21f15-4868-46cc-8c2d-c9ee1f1aa048"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", ":=", 
    RowBox[{
     RowBox[{"-", 
      SqrtBox["\[Omega]"]}], "=", 
     RowBox[{"-", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Pi]", " ", 
        RowBox[{"\[ImaginaryI]", "/", "d"}]}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"5590b78f-9db0-4318-b796-8fee269d0c2b"],
 "."
}], "Notes",
 CellID->1542982260,ExpressionUUID->"c70c699a-a065-4fb9-8907-2f9d6f5b9bbd"],

Cell[TextData[{
 "The ",
 StyleBox["Clifford group",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalC]", "d"], TraditionalForm]],ExpressionUUID->
  "9a0ef8ab-7051-44a5-a6ea-dd623611bc29"],
 " is the normalizer of the Weyl-Heisenberg group in the unitary group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalU]", "(", "d", ")"}], TraditionalForm]],
  ExpressionUUID->"0e73cb77-0c72-485c-a89a-a9e900760881"],
 ". The doubling in the above definition of Weyl-Heisenberg group is required \
because additional phase factors emerge in the Clifford group."
}], "Notes",
 CellID->976052040,ExpressionUUID->"666c9f8c-31de-450a-bcd3-15b76e40ef34"],

Cell[TextData[{
 "The Weyl-Heisenberg basis satisfies the following convention:\
\[LineSeparator]- It is ",
 StyleBox["orthonormal",
  FontSlant->"Italic"],
 " (normalized to ",
 StyleBox["d",
  FontSlant->"Italic"],
 ") with respect to the ",
 ButtonBox["Hilbert-Schmidt inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/HilbertSchmidtProduct"],
 " or ",
 ButtonBox["Frobenius inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FrobeniusProduct"],
 ".\[LineSeparator]- The first element is identical to the identity matrix. \
The rest are all ",
 StyleBox["traceless",
  FontSlant->"Italic"],
 ".\[LineSeparator]- All elements are ",
 StyleBox["unitary",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1752261046,ExpressionUUID->"671c97f3-12a6-46eb-865a-26a0571ee936"],

Cell["\<\
For more properties of the Weyl-Heisenberg basis, see Gottesman, Kitaev, and \
Preskill (2001), Wolf (2003), and Tolar (2018).\
\>", "Notes",
 CellID->1900252760,ExpressionUUID->"efdafdf3-70d5-4e03-a249-f01d82d21e78"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

