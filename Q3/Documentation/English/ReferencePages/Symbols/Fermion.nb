Cell["\<\
Fermionic operators obey the canonical anti-commutation relations.\
\>", "Notes",
 CellID->804325993,ExpressionUUID->"45806441-43c7-42e0-ba91-9b2673b43228"],

Cell[TextData[{
 "The phase convention of Ket involving fermions is such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["c", "1", "\[Dagger]"], 
     SubsuperscriptBox["c", "2", "\[Dagger]"], 
     SubsuperscriptBox["\[Ellipsis]c", "n", "\[Dagger]"], 
     TemplateBox[{"\[SpaceIndicator]"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{
        SubscriptBox["1", 
         SubscriptBox["c", "1"]], ",", 
        SubscriptBox["1", 
         SubscriptBox["c", "2"]], ",", "\[Ellipsis]", ",", 
        SubscriptBox["1", 
         SubscriptBox["c", "n"]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "f70097b3-427b-4bd2-bacc-819dc17e66bf"],
 "."
}], "Notes",
 CellID->562275005,ExpressionUUID->"7b37bce9-3388-4777-b736-5ea784444122"],

Cell["The following options can be given: ", "Notes",ExpressionUUID->"5393e2e9-d597-461e-8a49-e0be234b2d88"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "1e2cf709-3041-46a7-9463-6dc6b4744da2"], 
    TemplateBox[{
      Cell[
       TextData["Spin"]], "paclet:QuantumMob/Q3/ref/Spin", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"3ColumnTableMod"], 
    RowBox[{"1", "/", "2"}], Cell["\<\
The spin magnitude of the particles represented by the operators.\
\>", "TableText",ExpressionUUID->"2c15bab1-73cb-47eb-89d0-a721ee8c2443"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "5d2c5c8d-ed04-4048-bd6f-1aa1938688a6"], 
    TemplateBox[{
      Cell[
       TextData["Vacuum"]], "paclet:QuantumMob/Q3/ref/Vacuum", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"3ColumnTableMod"], "\"\<Void\>\"", Cell["\<\
Either \"Void\" or \"Sea\". \"Void\" (\"Sea\") declares that the vacuum state \
for the fermion operator is the completely empty state (Fermi sea with all \
levels below the Fermi level filled up). The vacuum state determines how the \
fermionic operators are reordered.\
\>", "TableText",ExpressionUUID->"093be819-ec98-44b8-86f9-188378d3c84f"]}
  }]], "3ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{"Columns" -> {{None}}, "Rows" -> {None, {None}}},
 GridBoxDividers->{
  "Rows" -> {{
     True, True, 
      True}}}},ExpressionUUID->"aa9da88d-0202-41f0-9463-21db3608eab0"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

