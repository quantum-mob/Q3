Cell[TextData[{
 "The phase convention of Ket involving fermions is such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["c", "1", "\[Dagger]"], 
     SubsuperscriptBox["c", "2", "\[Dagger]"], 
     SubsuperscriptBox["\[Ellipsis]c", "n", "\[Dagger]"], 
     TemplateBox[{"\[SpaceIndicator]"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{
        SubscriptBox["1", 
         SubscriptBox["c", "1"]], ",", 
        SubscriptBox["1", 
         SubscriptBox["c", "2"]], ",", "\[Ellipsis]", ",", 
        SubscriptBox["1", 
         SubscriptBox["c", "n"]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "effc1d54-2294-46ba-9849-53ed67510055"],
 "."
}], "ExampleText",
 CellID->1141423776,ExpressionUUID->"92da7ba0-37c0-4866-b2c0-f5644b6cb945"],

