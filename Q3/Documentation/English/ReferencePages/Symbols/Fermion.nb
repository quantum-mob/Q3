Cell["Fermions are declared as follows:", "ExampleText",
 CellID->1391563778,ExpressionUUID->"5ab430a7-c0cd-41b0-9350-55b8a1d93cbe"],

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Fermion", ",", "c", ",", 
   RowBox[{"Vacuum", "\[Rule]", "\"\<Sea\>\""}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Fermion", ",", "d"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Fermion", ",", "f", ",", 
   RowBox[{"Spin", "\[Rule]", "0"}], ",", " ", 
   RowBox[{"Vacuum", "\[Rule]", "\"\<Sea\>\""}]}], "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1915501016,ExpressionUUID->"64a3721d-5c30-425e-9677-37e8376c2dd6"],

Cell["\<\
By the above declaration, c[i,j,...] are all bosonic annihilation operators, \
and Dagger[ci,j,...]] are creation operators:\
\>", "ExampleText",
 CellID->898223735,ExpressionUUID->"4d2ebd84-29b6-4601-b52a-a796e5e0d949"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"c", "[", "Down", "]"}], "**", 
  RowBox[{"c", "[", "Up", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Dagger", "[", 
   RowBox[{"c", "[", 
    RowBox[{"1", ",", "Up"}], "]"}], "]"}], "**", 
  RowBox[{"Dagger", "[", 
   RowBox[{"c", "[", 
    RowBox[{"2", ",", "Down"}], "]"}], "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1783759382,ExpressionUUID->"502d6dca-e519-4305-b692-583de35ba8a7"],

Cell[BoxData[
 RowBox[{"-", 
  InterpretationBox[
   TemplateBox[{
     TemplateBox[{
       InterpretationBox[
        SubscriptBox[
         TemplateBox[{"c"}, "RowDefault"], 
         TemplateBox[{"\"\[UpArrow]\""}, "RowDefault"]], 
        $CellContext`c[Plus[1]/2]], 
       InterpretationBox[
        SubscriptBox[
         TemplateBox[{"c"}, "RowDefault"], 
         TemplateBox[{"\"\[DownArrow]\""}, "RowDefault"]], 
        $CellContext`c[(-1)/2]]}, "RowDefault"]},
    "RowDefault"],
   Q3`Multiply[
    $CellContext`c[
