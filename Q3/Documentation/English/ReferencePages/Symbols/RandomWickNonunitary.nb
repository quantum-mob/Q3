WindowTitle->"RandomWickNonunitary",
Visible->True,
TaggingRules->{
 "ModificationHighlight" -> False, "ColorType" -> "", "LinkTrails" -> "", 
  "ExampleCounter" -> 1, 
  "Openers" -> {
   "PrimaryExamplesSection" -> Open, "ExampleSection" -> {"0" -> Open}, 
    "AllOptsTable" -> Closed}, "NewStyles" -> True, 
  "CitationPopupData" -> $Failed, "ShowCitation" -> False, "HasOptions" -> 
  True, "RootCaptions" -> "", "HeaderCoreAreaLink" -> {}, 
  "Metadata" -> {
   "built" -> "{2026, 2, 21, 11, 53, 27.509135}", 
    "history" -> {"14.3", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {
     "fermionic quantum computation", "fermionic Gaussian state"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "RandomWickNonunitary[n] randomly constructs a WickNonunitary operator on \
n fermion modes. RandomWickNonunitary[{k1, k2, ...}] construct a random \
WickNonunitary gate on fermion modes {k1, k2, ...}. \
RandomWickNonunitary[{ham, dmp, gmm} -> pdf] chooses an evolution time \
\\[Tau] from the distribution function pdf and returns WickNonunitary \
corresponding to exp(-gmm \\[Tau]) exp (-I (ham - I dmp)). \
RandomWickNonunitary[{ham, dmp, gmm} -> {t1, t2}] or \
RandomWickNonunitary[{ham, dmp, gmm} -> Uniform] chooses \\[Tau] from \
UniformDistribution[{t1, t2}]. Putting Uniform sets the interval to {0, 2 \
\\[Pi] n/Emax}, where n is the number of fermion modes and Emax is the \
largest scale in ham, dmp or gmm. RandomWickNonunitary[{ham, dmp, gmm} -> \
\\[Gamma]] or RandomWickNonunitary[{ham, dmp, gmm} -> Exponential] chooses \
\\[Tau] from ExponentialDistribution[n*\\[Gamma]]. Setting Exponential puts \
\\[Gamma] = 1. RandomWickNonunitary[{ham, jmp} -> spec] automatically \
construct dmp and \\[Gamma] from the Wick jump object jmp.", "synonyms" -> {},
     "tabletags" -> {}, "title" -> "RandomWickNonunitary", "titlemodifier" -> 
    "", "metadescription" -> "", "windowtitle" -> "RandomWickNonunitary", 
    "type" -> "Symbol", "uri" -> "QuantumMob/Q3/ref/RandomWickNonunitary"}},
