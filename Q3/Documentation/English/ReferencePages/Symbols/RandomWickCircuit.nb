Cell[TextData[{
 "Each unitary layer describes unitary evolution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      StyleBox["ham",
       FontSlant->"Italic"], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"aa266828-092e-4d64-ac1d-7a533b6acb3b"],
 " with random evolution time \[Tau] governed by the distribution function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[Tau]", ")"}], "\[Proportional]", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"75413bb3-f18a-4548-a73c-eab26a54119a"],
 ", and in each measurement layer, each fermion mode is measured with \
probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"1", "/", "n"}]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e5a77c42-6f59-4753-8c6a-a1db9fc67ccf"],
 "."
}], "ExampleText",
 CellID->1259663973,ExpressionUUID->"9f75ab49-c3a3-4109-917c-5a546dbbdc71"],

