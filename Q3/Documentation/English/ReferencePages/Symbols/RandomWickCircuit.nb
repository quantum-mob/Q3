Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["RandomWickCircuit"]], 
     "paclet:QuantumMob/Q3/ref/RandomWickCircuit", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["ham", "TI"], ",", 
    StyleBox["dep", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f7859ba2-2b58-4e0d-94d2-4e0468416c9d"],
 " may be regarded as a discrete circuit model to describe continuous \
monitoring of each fermion mode with rate ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],ExpressionUUID->
  "261a8386-9af0-46be-80a8-9e203702728d"],
 ". Each unitary layer  corresponds to time-evolution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"exp", "[", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "H", "\[VeryThinSpace]",
       "\[Tau]"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "3ddce727-04cc-4851-91fe-dc38f1b65de5"],
 " with the interaction time ",
 Cell[BoxData[
  FormBox["\[Tau]", TraditionalForm]],ExpressionUUID->
  "7d536594-915b-4117-8e60-2a749cce7510"],
 " distributed by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[Tau]", ")"}], "=", 
    RowBox[{"n", "\[VeryThinSpace]", "\[Gamma]", "\[VeryThinSpace]", 
     RowBox[{"exp", "[", 
      RowBox[{
       RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Gamma]", "\[VeryThinSpace]",
        "\[Tau]"}], "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "48f81439-23f7-42ed-aed6-ba00c5fac36a"],
 ", where ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b1b4ccfd-5927-4ada-887f-0a793f410605"],
 " is the number of fermion modes (i.e., the system size) and ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],ExpressionUUID->
  "63de7462-d76e-488f-bb78-2258b7e424ce"],
 " is the rate at which each fermion mode is monitored. Since the average \
evolution time is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", "\[Tau]", "\[RightAngleBracket]"}], "=", 
    RowBox[{
     RowBox[{"1", "/", "n"}], "\[VeryThinSpace]", "\[Gamma]"}]}], 
   TraditionalForm]],ExpressionUUID->"f44a488b-e786-4472-b427-9b6dcd28ec45"],
 ", it is reasonable to assume that for each measurement layer, the \
probability ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "b9729f89-8ad7-4a30-a4ff-a19b49bd0528"],
 " for a fermion mode to be measured is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{
     RowBox[{"\[Gamma]", 
      RowBox[{"\[LeftAngleBracket]", "\[Tau]", "\[RightAngleBracket]"}]}], "=", 
     RowBox[{"1", "/", "n", "\[VeryThinSpace]"}]}]}], TraditionalForm]],
  ExpressionUUID->"95cef745-c9c5-4899-9c5c-e17162443c63"],
 ". Note that ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ExponentialDistribution"]], 
     "paclet:ref/ExponentialDistribution"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "79f38db6-d71b-42c3-9bd8-b1f5ab2f3f5f"],
 " is used internally, implying that a unit system is chosen such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Gamma]", "\[VeryThinSpace]", "\[Tau]"}], "\[RightTeeArrow]", 
    "\[Tau]"}], TraditionalForm]],ExpressionUUID->
  "3cf67dd3-078b-4cb9-a927-3c44c73faeb1"],
 "."
}], "Notes",
 CellID->63026278,ExpressionUUID->"2bfb9be7-82b0-4da4-acbb-64e87d76ba16"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

