Cell[TextData[{
 "Each unitary layer describes unitary evolution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      StyleBox["ham",
       FontSlant->"Italic"], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"d6bbdaec-2fbd-4b26-8dcd-d8ac0df55653"],
 " with uniformly random evolution time \[Tau], and in each measurement \
layer, each fermion mode is measured with probability ",
 Cell[BoxData[
  RowBox[{
   StyleBox["p", "TI"], "=", "0.2"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c52c0346-d0d7-4f19-93fa-79614ab21834"],
 ":"
}], "ExampleText",
 CellID->1702849045,ExpressionUUID->"581a8a2f-d384-419a-847b-3d320d63d15b"],

