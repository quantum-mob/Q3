Cell[TextData[{
 "Each unitary layer describes unitary evolution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      StyleBox["ham",
       FontSlant->"Italic"], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"8d01e818-ebae-4f7e-a845-6265d8087ea9"],
 " with uniformly random evolution time \[Tau], and in each measurement \
layer, each fermion mode is measured with probability ",
 Cell[BoxData[
  RowBox[{
   StyleBox["p", "TI"], "=", "0.2"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ee9311b5-9d96-4e47-aa06-3271abc2dbc5"],
 ":"
}], "ExampleText",
 CellID->1702849045,ExpressionUUID->"7eb8580c-fa16-43c4-96e1-fa7c7c7b85bc"],

