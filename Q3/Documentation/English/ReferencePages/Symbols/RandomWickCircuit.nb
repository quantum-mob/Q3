Cell[TextData[{
 "Each unitary layer describes unitary evolution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"u", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      StyleBox["ham",
       FontSlant->"Italic"], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"abb1634a-5b1e-43d8-bcf5-7113c2ac1684"],
 " with random evolution time \[Tau] governed by the distribution function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[Tau]", ")"}], "\[Proportional]", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"bf751d28-079e-47c3-80e3-77bf6d42797e"],
 ", and in each measurement layer, each fermion mode is measured with \
probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"1", "/", "n"}]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "84721c6a-0dbc-4761-afd9-6a6f8e4f0ef0"],
 "."
}], "ExampleText",
 CellID->1259663973,ExpressionUUID->"0b967682-cdae-4631-92a8-91a6a40018ce"],

