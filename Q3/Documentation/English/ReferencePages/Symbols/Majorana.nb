Cell[TextData[{
 "The Majorana operators are normalized as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["c", "i"], ",", 
      SubscriptBox["c", "j"]}], "}"}], "=", 
    RowBox[{"2", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"93b0a74d-6210-435f-80b1-0dd8564f24b0"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["c", "i", "2"], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"0017d0f2-9b4d-422d-8b08-65b21988ddab"],
 "."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"2a1833eb-0e82-41c2-81d6-4aa7d9650d01"],

