Cell[TextData[{
 "The ",
 Cell[BoxData["CNOT"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "97073c06-8922-43cc-bcdd-83f06174299d"],
 " gate flips the target qubit ",
 StyleBox["if and only if",
  FontSlant->"Italic"],
 " the control qubit is in the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "38d899da-7fe4-4eb0-bfaa-16c0524bf975"],
 ". More explicitly, the CNOT gate maps states ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"c"},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{"t"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "deb02196-02b8-4506-bf95-c7a958f57ae5"],
 " in the two-qubit computational basis associated with the control (c) and \
target (t) qubit by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"c"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"t"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"c"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"c", "\[CirclePlus]", "t"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "6607982f-7e4f-4fa8-bffe-9765ee2d6b2f"],
 " ."
}], "Notes",
 CellID->926070231,ExpressionUUID->"b91b95eb-f2f1-4552-8beb-afd59911bb3f"],

Cell[TextData[{
 "Under the multi-control and multi-target CNOT gate, the state is \
transformed as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{
         SubscriptBox["c", "1"], ",", 
         SubscriptBox["c", "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox["c", "m"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{
         SubscriptBox["t", "1"], ",", 
         SubscriptBox["t", "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox["t", "n"]}]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{
       RowBox[{
         SubscriptBox["c", "1"], ",", 
         SubscriptBox["c", "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox["c", "m"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{
         RowBox[{
           RowBox[{"(", 
             RowBox[{
               SubscriptBox["c", "1"], "\[Wedge]", 
               SubscriptBox["c", "1"], "\[Wedge]", "\[CenterEllipsis]", 
               "\[Wedge]", 
               SubscriptBox["c", "m"]}], ")"}], "\[CirclePlus]", 
           SubscriptBox["t", "1"]}], ",", 
         RowBox[{
           RowBox[{"(", 
             RowBox[{
               SubscriptBox["c", "1"], "\[Wedge]", 
               SubscriptBox["c", "1"], "\[Wedge]", "\[CenterEllipsis]", 
               "\[Wedge]", 
               SubscriptBox["c", "m"]}], ")"}], "\[CirclePlus]", 
           SubscriptBox["t", "2"]}], ",", "\[Ellipsis]", ",", 
         RowBox[{
           RowBox[{"(", 
             RowBox[{
               SubscriptBox["c", "1"], "\[Wedge]", 
               SubscriptBox["c", "1"], "\[Wedge]", "\[CenterEllipsis]", 
               "\[Wedge]", 
               SubscriptBox["c", "m"]}], ")"}], "\[CirclePlus]", 
           SubscriptBox["t", "n"]}]}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "4741fced-edff-4576-b645-38fd32202cb1"],
 " "
}], "Notes",
 CellID->35980174,ExpressionUUID->"9ac5972b-01ec-4aa9-a429-55f6f1939c36"],

