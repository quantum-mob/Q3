Cell[TextData[{
 "The ",
 Cell[BoxData["CNOT"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5066f783-13ab-472f-b187-f0012edc9428"],
 " gate flips the target qubit ",
 StyleBox["if and only if",
  FontSlant->"Italic"],
 " the control qubit is in the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8192998e-1c0d-473f-9a5b-582c3f0d7841"],
 ". More explicitly, the CNOT gate maps states ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"c"},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{"t"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "61926245-e43d-4c8b-b9ba-2142fb03fb8b"],
 " in the two-qubit computational basis associated with the control (c) and \
target (t) qubit by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"c"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"t"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"c"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"c", "\[CirclePlus]", "t"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "d01587a8-66f5-4a19-b653-de0189d303b9"],
 " ."
}], "Notes",
 CellID->926070231,ExpressionUUID->"960aafaf-a970-4e2b-b3f8-786b45a3c392"],

Cell[TextData[{
 "Under the multi-control and multi-target CNOT gate, the state is \
transformed as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{
         SubscriptBox["c", "1"], ",", 
         SubscriptBox["c", "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox["c", "m"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{
         SubscriptBox["t", "1"], ",", 
         SubscriptBox["t", "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox["t", "n"]}]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{
       RowBox[{
         SubscriptBox["c", "1"], ",", 
         SubscriptBox["c", "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox["c", "m"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{
         RowBox[{
           RowBox[{"(", 
             RowBox[{
               SubscriptBox["c", "1"], "\[Wedge]", 
               SubscriptBox["c", "1"], "\[Wedge]", "\[CenterEllipsis]", 
               "\[Wedge]", 
               SubscriptBox["c", "m"]}], ")"}], "\[CirclePlus]", 
           SubscriptBox["t", "1"]}], ",", 
         RowBox[{
           RowBox[{"(", 
             RowBox[{
               SubscriptBox["c", "1"], "\[Wedge]", 
               SubscriptBox["c", "1"], "\[Wedge]", "\[CenterEllipsis]", 
               "\[Wedge]", 
               SubscriptBox["c", "m"]}], ")"}], "\[CirclePlus]", 
           SubscriptBox["t", "2"]}], ",", "\[Ellipsis]", ",", 
         RowBox[{
           RowBox[{"(", 
             RowBox[{
               SubscriptBox["c", "1"], "\[Wedge]", 
               SubscriptBox["c", "1"], "\[Wedge]", "\[CenterEllipsis]", 
               "\[Wedge]", 
               SubscriptBox["c", "m"]}], ")"}], "\[CirclePlus]", 
           SubscriptBox["t", "n"]}]}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "0389dac1-62df-4482-a98a-a1819bca122c"],
 " "
}], "Notes",
 CellID->35980174,ExpressionUUID->"cc69f85f-7f29-4185-8901-0944dfc6780f"],

