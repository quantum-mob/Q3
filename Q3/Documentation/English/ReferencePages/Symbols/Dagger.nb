Cell[TextData[{
 "It is important to note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Dagger"]], "paclet:QuantumMob/Q3/ref/Dagger", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bcf1ae1a-e65d-4f3b-bb31-8b4c5662eda9"],
 " has the attribute ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Listable"]], "paclet:ref/Listable"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8a30e0ef-2a7e-408d-8617-b220158517a1"],
 ", meaning that it operates element-wise of any list. In particular, the \
common expectation ",
 Cell[BoxData[
  RowBox[{"Dagger", "[", 
   StyleBox["m", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9a02141a-15a3-4c79-bfbd-36c1b7b9ef95"],
 " \[Equal] ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Transpose"]], "paclet:ref/Transpose"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Conjugate"]], "paclet:ref/Conjugate"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["m", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "256cffeb-d3c8-47a3-b3fb-60ec98976c94"],
 " for a matrix ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4a7a732-81aa-418a-aada-1d6ca30dda49"],
 " of c-numbers does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " hold any longer. For such purposes use ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Topple"]], "paclet:QuantumMob/Q3/ref/Topple", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cb44d19c-1866-4144-87fa-f665bd9f77e7"],
 ", instead."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"cf9b08a2-8a68-40ab-9ee5-59800cb2bb66"]
}, Dynamic[CurrentValue[
