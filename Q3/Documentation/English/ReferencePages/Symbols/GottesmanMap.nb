Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanMap"]], "paclet:QuantumMob/Q3/ref/GottesmanMap", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c758d543-3963-40ec-9479-a79359fea8b5"],
 "  describes the transformation of a Pauli string to another by conjugation \
by operating on Gottesman vectors but not directly on Pauli strings as a true \
",
 ButtonBox["supermap",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Supermap"],
 "."
}], "Notes",
 CellID->952942582,ExpressionUUID->"d0f69f38-c991-41e9-a2d8-f225ce64b86c"],

Cell[TextData[{
 "A ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "4d17a8b0-cfb0-4ea1-bfb4-392a797ed731"],
 " is completely specified (up to a global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"\[ImaginaryI]", " ", "m", " ", 
     RowBox[{"\[Pi]", " ", "/", "4"}]}]], TraditionalForm]],ExpressionUUID->
  "e67180e4-07ef-4816-95d9-a37a17e82256"],
 ") by the transformation of ",
 ButtonBox["Pauli operators",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "ec2f8e79-12ca-4872-9124-72aa5a4f8269"],
 ":\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["X", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["p", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["a", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["b", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "808b2429-b365-4470-8808-bb8ca545fb2e"],
 "\nand\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["Z", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["q", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["c", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["d", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "d68a58ad-2c41-4e16-a73e-310500b18e11"],
 "."
}], "Notes",
 CellID->1417856937,ExpressionUUID->"cdc77734-ee47-405f-bed6-88ba9fbbd695"],

Cell[TextData[{
 "The Gottesman matrix of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "7d295866-2f6c-4fff-8a2d-7f4776abd4ec"],
 " is then defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "U", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["a", "11"], 
        SubscriptBox["c", "11"], 
        SubscriptBox["a", "12"], 
        SubscriptBox["c", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "11"], 
        SubscriptBox["d", "11"], 
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["a", "21"], 
        SubscriptBox["c", "21"], 
        SubscriptBox["a", "22"], 
        SubscriptBox["c", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "21"], 
        SubscriptBox["b", "22"], 
        SubscriptBox["d", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "549f19e4-a87e-445c-8c14-9596cb16a33e"]
}], "Notes",
 CellID->1647214467,ExpressionUUID->"44326ee9-4651-4cea-b6ba-8a023aa73472"],

Cell[TextData[{
 "The Gottesman matrix of a ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " is a binary symplectic matrix. Recall that the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"ce8b45f6-7ff1-47c0-9671-2768a190d906"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "86832a76-219c-48f5-b598-474a24b25267"],
 "qubits is equivalent to the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"66007ac4-7514-4888-ad86-1ead0168cabd"],
 " up to the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"658cad2e-f443-41df-b747-0d08ead10593"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], "\[Congruent]", 
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"eb69babe-0819-4081-9fc6-dbfcd5db318b"],
 "."
}], "Notes",
 CellID->17963594,ExpressionUUID->"46c7e390-caee-4d8d-818a-56299cc477a5"],

Cell[TextData[{
 "Recall that a Pauli operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"5444e1a7-797f-4e90-bc10-55570cd8ed85"],
 "\[LineSeparator]is completely specified (up to a global phase factor) by \
the corresponding Gottesman vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["z", "1"], ",", 
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["x", "n"], ",", 
       SubscriptBox["z", "n"]}], ")"}], "T"]}], TraditionalForm]],
  ExpressionUUID->"f82ba6b3-e793-4b83-a509-87806cf04f13"],
 "."
}], "Notes",
 CellID->1441760612,ExpressionUUID->"1507b215-e100-4cc2-a121-4c7ef3b38ef0"],

Cell[TextData[{
 "Under conjugation by a Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "5f6455a1-05c4-4ee5-9a68-0840e0d72bf0"],
 ", the Gottesman vector transforms as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", 
     RowBox[{"U", " ", "P", " ", 
      SuperscriptBox["U", "\[Dagger]"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"v", "(", "P", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "268a7bc5-e38c-425b-bd79-ca0d2e605ab5"],
 "."
}], "Notes",
 CellID->1746253034,ExpressionUUID->"37046aaa-5ec2-4115-9087-cf887b4a942a"],

Cell[TextData[{
 "Furthermore, a series of consecutive conjugations by Clifford operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ",", " ", "V", ",", " ", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"aea0ec9d-f28c-449e-8b8a-21da3d5ca3fe"],
 " is described by the multiplications of corresponding Gottesman matrices,\
\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], "\[Ellipsis]"}]}], TraditionalForm]],
  ExpressionUUID->"97012419-053e-4796-b67f-e70f8312e841"],
 ". \[LineSeparator]That is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]", " ", "P"}], " ", "..."}], " ", 
     SuperscriptBox["V", "\[Dagger]"], 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
     SuperscriptBox[
      RowBox[{"P", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "\[Dagger]"]}]}], 
   TraditionalForm]],ExpressionUUID->"ebce7b48-9992-48f0-bf6d-576be4b80477"],
 "\[LineSeparator]leads to\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"v", "(", "P", ")"}], "\[RightTeeArrow]", 
     RowBox[{
      RowBox[{"S", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
      RowBox[{"v", "(", "P", ")"}]}]}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], 
     RowBox[{"\[Ellipsis]v", "(", "P", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"78e3bd5b-800f-4f40-8001-531aeed4ef90"],
 "."
}], "Notes",
 CellID->863527665,ExpressionUUID->"cc28f6db-1706-47e8-bf1f-a6388d7a2f3c"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

