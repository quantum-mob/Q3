Cell[TextData[{
 "The term ",
 StyleBox["Clifford group",
  FontSlant->"Italic"],
 " was introduced by Daniel Gottesman (1998) in his stabilizer formulation of \
quantum error-correction codes."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"439f8b31-daa6-430c-9521-fccaeed7dbab"],

Cell[TextData[{
 "The full Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["C", "~"], "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"246052ac-708c-47bf-b996-fdba9e159753"],
 " is the normalizer of the full Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"ea8188d8-26cb-46ca-aa03-b44344b98672"],
 ", that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{"U", ":", 
      RowBox[{
       RowBox[{"U", " ", "P", " ", 
        SuperscriptBox["U", "\[Dagger]"]}], "\[Element]", 
       RowBox[{
        RowBox[{
         OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "  ", 
        "for", " ", "all", " ", "P"}], "\[Element]", 
       RowBox[{
        OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}]}]}], "}"}]}],
    TraditionalForm]],ExpressionUUID->
  "00c2c4b5-e6b3-436a-bb81-513f18b08801"],
 "."
}], "Notes",
 CellID->1836205616,ExpressionUUID->"411fa655-48b8-4d0e-9551-458ec7cfa859"],

Cell[TextData[{
 StyleBox["Gottesman Theorem",
  FontWeight->"Bold"],
 ": The (full) Clifford group is generated by the Hadamard gates and the \
quadrant phase gates on individual qubits and the CNOT (CZ) gates on pairs of \
qubits."
}], "Notes",
 CellID->1029202184,ExpressionUUID->"7301ae61-9cc3-4bb8-b174-cf976667ebcf"],

Cell[TextData[{
 "The Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"bdec8214-b99f-4ad3-821a-a39c1b40efa7"],
 " is a quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], ":=", 
    RowBox[{
     RowBox[{
      OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"88854cbe-11c9-46ff-9979-ee2963ce5a14"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["C", "~"], "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"7824f9db-91c4-4cd0-95c7-65810b780e2d"],
 " is the full Clifford group and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalZ]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"i", " ", "m", " ", 
          RowBox[{"\[Pi]", "/", "4"}]}]], ":", "m"}], "=", "0"}], ",", "1", ",",
       "2", ",", "\[Ellipsis]", ",", "7"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"9ccc5110-b241-4a67-941b-cf2f3f7b4e38"],
 ". That is, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["CliffordGroup"]], "paclet:QuantumMob/Q3/ref/CliffordGroup", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "261bdd5d-53c8-4e48-adf9-2ce445ff083c"],
 " is a quotient group ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["FullCliffordGroup"]], 
      "paclet:QuantumMob/Q3/ref/FullCliffordGroup", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "/", 
   FormBox[
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "m", "\[VeryThinSpace]", 
          RowBox[{
          "\[Pi]", "\[VeryThinSpace]", "/", "\[VeryThinSpace]", "4"}]}]], ":",
         "m"}], "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      "7"}], "}"}],
    TraditionalForm]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "076ee9a0-038c-4e3b-a109-09738f1e6d01"],
 "."
}], "Notes",
 CellID->1413575425,ExpressionUUID->"8b93b0ae-834b-4a77-8924-bf811acb5792"],

Cell[TextData[{
 "The Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"36178b39-45f7-4882-a5d8-9897f2c2fe01"],
 " is equivalent to the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 ", alias ",
 ButtonBox["Gottesman group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalG]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"9dc1cd00-72e6-4637-ad8b-795780c0a7a9"],
 ", up to the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"e3bea3fd-03ab-4aa5-947f-b3b6c93846c1"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}], "\[TildeEqual]", 
    RowBox[{"\[ScriptCapitalG]", "(", "n", ")"}], "\[Congruent]", 
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"98052b9c-c7c0-4e1d-9d62-0f9d305461f2"],
 "."
}], "Notes",
 CellID->1023764637,ExpressionUUID->"144a4176-e389-4095-88c2-fe7da72582a8"],

Cell[TextData[{
 "The order of the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "81b45d96-a03e-4389-8593-2bd538d47e81"],
 "-qubit Clifford group is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", 
     RowBox[{
      SuperscriptBox["n", "2"], "+", 
      RowBox[{"2", "n"}]}]], 
    RowBox[{
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "n"], "(", 
     RowBox[{
      SuperscriptBox["4", "k"], "-", "1"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"3b2bdb81-b02b-40e1-bd3d-74cd1c56198d"],
 "."
}], "Notes",
 CellID->1790747771,ExpressionUUID->"7661e571-4bff-404f-aefc-6751e2373e23"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

