Cell[TextData[{
 "Here we will consider a Spin-1/2 XXZ chain. See ",
 StyleBox["Giamarchi",
  IgnoreSpellCheck->True],
 "  (2004) Chapter 6 and ",
 StyleBox["Moradmard",
  IgnoreSpellCheck->True],
 " et al (2013)."
}], "ExampleText",
 CellID->1134748374,ExpressionUUID->"149d9d9f-1107-4d5b-9428-b721e5a2c9be"],

