QuantumCircuit[ControlledGate[{S[1, $] -> 1}, 
  ActOn[(1 + E^((4*I)*\[Phi]))/2 + ((1 - E^((4*I)*\[Phi]))*T[4])/2 + 
    ((1 - E^((4*I)*\[Phi]))*T[5])/2, {T[$]}], 
  \"Label\" -> Superscript[\"U\", Superscript[2, 2]], \"LabelSize\" -> 0.65], \

 ControlledGate[{S[2, $] -> 1}, ActOn[(1 + E^((2*I)*\[Phi]))/2 + 
    ((1 - E^((2*I)*\[Phi]))*T[4])/2 + ((1 - E^((2*I)*\[Phi]))*T[5])/2, \
{T[$]}], 
  \"Label\" -> Superscript[\"U\", Superscript[2, 1]], \"LabelSize\" -> 0.65], \

 ControlledGate[{S[3, $] -> 1}, 
  ActOn[(1 + E^(I*\[Phi]))/2 + ((1 - E^(I*\[Phi]))*T[1])/2, {T[$]}], 
  \"Label\" -> Superscript[\"U\", Superscript[2, 0]], \"LabelSize\" -> 0.65]]\
\
\>", "Output",
 CellLabel->"Out[7]//InputForm=",
 CellID->135765464,ExpressionUUID->"94804e30-842e-4e39-8881-4bf58e6e1f0d"]
}, Open  ]],

