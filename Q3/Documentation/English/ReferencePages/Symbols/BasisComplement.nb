Cell[TextData[{
 "Here, we draw attention to a dangerous case for ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BasisComplement"]], "paclet:QuantumMob/Q3/ref/BasisComplement",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f1811c9b-4d26-444d-987e-c9c3b52e9fd3"],
 " and introduce the ",
 StyleBox["\"SVD\"", "Input"],
 " option that might be useful in such a case (the issue is overcome in the \
current implementation even without the ",
 StyleBox["\"SVD\"", "Input"],
 " option)."
}], "ExampleText",
 CellID->518486824,ExpressionUUID->"8c0d845e-6d4f-4008-ac1f-db69d9da0468"],

