Cell[TextData[{
 "The basis vectors ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["v", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a8b0cc7c-d8bf-4169-b449-67c3ffe46672"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["w", "TI"], 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2beabfb7-3e97-44e2-ac78-dc93cf38aa71"],
 " can be given in row vectors of components or in expressions of ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Ket", 
     "QuantumMob Package Symbol"},
    "PackageLink",
