Cell[TextData[{
 "When the subspace spanned by ",
 StyleBox["sub", "Input"],
 " is projected out,  the first element must vanish, but numerically, not \
quite in many cases."
}], "ExampleText",
 CellID->991869671,ExpressionUUID->"59ff084b-b6a7-4a73-a99a-49d0334427e2"],

