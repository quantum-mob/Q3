  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b7bbec55-6b8e-4468-a5bd-338b9a740a9d"],
 " or ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Ket", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"<|", 
    StyleBox["\[Ellipsis]", "TR"], "|>"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4d61d17b-765a-4899-a7dc-d827676879bc"],
 "."
}], "Notes",
 CellID->221119269,ExpressionUUID->"a80a6a8d-fc57-4b68-9410-2c64ab3a32ee"],

Cell[TextData[{
 "Internally, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BasisComplement"]], "paclet:QuantumMob/Q3/ref/BasisComplement",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c1c26025-9b55-49b6-8165-6f8247ea828e"],
 " uses ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Orthogonalize"]], "paclet:ref/Orthogonalize"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aeeef824-9eec-4b15-b5c8-848a8718428c"],
 ", which by default generates a Gram\[Dash]Schmidt basis."
}], "Notes",
 CellID->930120528,ExpressionUUID->"06a64526-0350-4662-a2d7-67dbc78038ac"],

Cell[TextData[{
 "Other bases can be obtained by giving alternative settings for the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Method"]], "paclet:ref/Method"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9e38eab9-dce2-4d04-8bda-7ec569c43d99"],
 " option. Possible settings include: \"SVD\" as well as other options to ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Orthogonalize"]], "paclet:ref/Orthogonalize"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c8c86c6c-fe53-4c6e-a006-ee922f08399f"],
 " such as  ",
 Cell[BoxData["\"\<GramSchmidt\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "07a7a384-7d7c-4641-87cd-e4f6c717c6a2"],
 ", ",
 Cell[BoxData["\"\<ModifiedGramSchmidt\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b711046c-8272-4313-9074-7e0871ad359a"],
 ", ",
 Cell[BoxData["\"\<Reorthogonalization\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0d1d0650-b9ae-4306-9099-0c2316a9ef02"],
 ", and ",
 Cell[BoxData["\"\<Householder\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "96bed1b3-7d1f-48d0-93bc-effec2732eeb"],
 ". With \"SVD\", it uses the singular-value decomposition for \
orthogonalization."
}], "Notes",
 CellID->887541132,ExpressionUUID->"a7d5c146-aba8-4315-a33c-452689084c6c"]
