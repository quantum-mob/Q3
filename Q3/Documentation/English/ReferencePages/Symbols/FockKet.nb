Cell["\<\
A vector in the Fock space can be generated by multiplying a series of \
creation operators to the vacuum state.\
\>", "ExampleText",
 CellID->1980795043,ExpressionUUID->"9af6e475-e70f-4e31-b4ea-39d59ad09a70"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"v1", "=", 
  RowBox[{
   RowBox[{"Ket", "[", "Vacuum", "]"}], "+", 
   RowBox[{"I", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"a", "[", "1", "]"}], "^", "Dagger"}], " ", "**", " ", 
     RowBox[{
      RowBox[{"a", "[", "2", "]"}], "^", "Dagger"}], " ", "**", " ", 
     RowBox[{
      RowBox[{"a", "[", "3", "]"}], "^", "Dagger"}], "**", 
     RowBox[{"Ket", "[", "Vacuum", "]"}]}]}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->930791907,ExpressionUUID->"5525a420-8c70-4c08-9369-0903477c090b"],

