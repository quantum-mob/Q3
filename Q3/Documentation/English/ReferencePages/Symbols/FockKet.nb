  InterpretationBox[
   TagBox[
    TemplateBox[{
      TemplateBox[{"\"\[SpaceIndicator]\""}, "RowDefault"]},
     "Ket"],
    DisplayForm],
   Ket[Q3`Vacuum]], "+", 
  RowBox[{"\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        InterpretationBox[
         TemplateBox[{"a", 
           TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"\[Dagger]\""}, "RowWithSeparators"]},
           "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
         Q3`Dagger[
          $CellContext`a[1]]], 
        InterpretationBox[
         TemplateBox[{"a", 
           TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"\[Dagger]\""}, "RowWithSeparators"]},
           "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
         Q3`Dagger[
          $CellContext`a[2]]], 
        InterpretationBox[
         TemplateBox[{"a", 
           TemplateBox[{",", "\",\"", "3"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"\[Dagger]\""}, "RowWithSeparators"]},
           "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
         Q3`Dagger[
          $CellContext`a[3]]], 
        InterpretationBox[
         TagBox[
          TemplateBox[{
            TemplateBox[{"\"\[SpaceIndicator]\""}, "RowDefault"]}, "Ket"], 
          DisplayForm], 
         Ket[Q3`Vacuum]]}, "RowDefault"]},
     "RowDefault"],
    Q3`Multiply[
     Q3`Dagger[
      $CellContext`a[1]], 
     Q3`Dagger[
      $CellContext`a[2]], 
     Q3`Dagger[
      $CellContext`a[3]], 
     Ket[Q3`Vacuum]]]}]}]], "Output",
 CellLabel->"Out[4]=",
 CellID->850240637,ExpressionUUID->"3743aec6-f00d-4a5e-b5a0-eae830efd941"]
}, Open  ]],

Cell[TextData[{
 "Such representation, which we will call the ",
 StyleBox["Cat form",
  FontWeight->"Bold"],
 ", is natural in the second quantization formulation of the Fock space. \
However, some times it is also convenient to represent the same vector in the \
occUpation number representation. In the above example, the occUpation \
numbers of the single-particle states ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["\[Psi]", "1"], ",", " ", 
   SubscriptBox["\[Psi]", "2"], ",", " ", 
   SubscriptBox["\[Psi]", "3"]}]],ExpressionUUID->
  "f00273ef-50b6-404a-9be9-50a4ad46f08e"],
 " in ",
 StyleBox["v1", "Input"],
 "  are ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox["n", "1"], "=", 
   RowBox[{
    SubscriptBox["n", "2"], "=", 
    RowBox[{
     SubscriptBox["n", "3"], "=", "1"}]}]}]],ExpressionUUID->
  "87caabe1-3262-4b8e-936a-89fb0e041d00"],
 ". In Q3, such a representation, which we will call the ",
 StyleBox["Ket form",
  FontWeight->"Bold"],
 ", is obtained by ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FockKet"]], "paclet:QuantumMob/Q3/ref/FockKet", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7a4938e4-0f8e-411d-8ff6-e2dfb7f6f158"],
 ". "
}], "ExampleText",
 CellID->1435248567,ExpressionUUID->"4116f9be-38aa-472c-a05d-a02a568a477b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"v2", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Ket", "[", "]"}], "+", 
    RowBox[{"I", " ", 
     RowBox[{"Ket", "[", 
      RowBox[{
       RowBox[{"a", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2", ",", "3"}], "}"}], "]"}], "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"1", ",", "1", ",", "1"}], "}"}]}], "]"}]}]}], "//", 
   "KetRegulate"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1686342465,ExpressionUUID->"b4788b6b-2ff2-4991-8e6f-6674bdf1bec8"],

