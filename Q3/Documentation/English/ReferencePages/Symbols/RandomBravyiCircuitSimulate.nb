Cell[TextData[{
 "The probability distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "\[Tau]", ")"}], TraditionalForm]],ExpressionUUID->
  "6d1f0f04-fcb7-4c3e-a99d-1f257412ca4c"],
 " of the interaction time ",
 Cell[BoxData[
  FormBox["\[Tau]", TraditionalForm]],ExpressionUUID->
  "53c7fa23-0d3d-4ce9-b24d-8754faa25a78"],
 " is given by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[Tau]", ")"}], "\[Proportional]", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"839908fb-e6d6-48f9-81ad-61db71d285aa"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "89bdc82f-a20b-404e-b41d-fbd5d764e292"],
 " is the number of Dirac fermion modes. The unit system is chosen such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Gamma]", "\[VeryThinSpace]", "\[Tau]"}], "\[RightTeeArrow]", 
    "\[Tau]"}], TraditionalForm]],ExpressionUUID->
  "130cfe8d-b464-445c-b440-96dfec79f5eb"],
 "."
}], "ExampleText",
 CellID->2019827657,ExpressionUUID->"4a840fc8-ff88-4719-b969-d85dd19084d4"],

