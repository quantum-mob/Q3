Cell["\<\
Finally, construct an approximate density matrices by averaging states in \
different trajectories, and calculate the the logarithmic negativity (LN) \
between the subsystem and the rest:\
\>", "ExampleText",
 CellID->1177617208,ExpressionUUID->"57ca1ce9-a49a-45e3-9300-91188d11f6dc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"BravyiMean", "[", "trj", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"BravyiLogarithmicNegativity", "[", 
      RowBox[{"avg", ",", "kk"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
