 RowBox[{"{", 
  RowBox[{"100", ",", "31"}], "}"}]], "Output",
 CellLabel->"Out[5]=",
 CellID->523020760,ExpressionUUID->"74e5f6d6-3a6e-45f0-bd47-3a06f0f80305"]
}, Open  ]],

