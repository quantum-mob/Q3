Cell["\<\
Calculate the logarithmic negativity (LN) between the first and second halves \
of the system:\
\>", "ExampleText",
 CellID->1847549236,ExpressionUUID->"e6c25206-8443-4907-b1fd-eed261ca7bad"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"BravyiLogarithmicNegativity", "[", 
     RowBox[{"trj", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "neg", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1293957479,ExpressionUUID->"c4d91d8e-7ad2-416a-950b-e6dd3d69b001"],

Cell[BoxData["3.638634`"], "EchoTiming",
