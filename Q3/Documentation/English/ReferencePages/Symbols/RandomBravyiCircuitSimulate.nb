Cell[TextData[{
 "The interaction time ",
 Cell[BoxData[
  FormBox["\[Tau]", TraditionalForm]],ExpressionUUID->
  "ec770379-e491-4e66-933a-e2218951dcb4"],
 " is uniformly distributed over the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"0", ",", 
     SubscriptBox["\[Tau]", "max"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "3874023f-739a-4201-925c-538f33c38c54"],
 " with\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      SubscriptBox["\[Tau]", "max"], ":=", 
      RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
       RowBox[{"n", "/", 
        SubscriptBox["E", "max"]}]}]}], TraditionalForm]],ExpressionUUID->
    "d207cbdb-e7c2-46a4-9d1c-1a526b78d723"]],ExpressionUUID->
    "f901df7e-3120-4700-b954-e1f981b7aaf2"], TraditionalForm]],ExpressionUUID->
  "746630fa-8d25-411d-a057-b5c64d084ac7"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "7c5244df-6d14-4c4f-a6f1-810c0ad64061"],
 " is the number of Dirac fermion modes and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "max"], TraditionalForm]],ExpressionUUID->
  "dab01230-8dab-4795-aafd-f2f8865fad7f"],
 " is the largest energy scale of the Hamiltonian."
}], "ExampleText",
 CellID->1753522467,ExpressionUUID->"ccb47c37-48d6-4bc1-b0d1-526c73f791c0"],

