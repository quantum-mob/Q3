Cell["\<\
Construct the approximate density matrix, and calculate the logarithmic \
negativity (LN) of it between the first and second halves of the system:\
\>", "ExampleText",
 CellID->837958276,ExpressionUUID->"0ab18562-733e-4235-b436-9fb0a1b7e6cd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"BravyiMean", "[", "trj", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"BravyiEntanglementEntropy", "[", 
      RowBox[{"avg", ",", "kk"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "negRho", "]"}]}], "Input",
