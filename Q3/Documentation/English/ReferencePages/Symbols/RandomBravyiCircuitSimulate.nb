          StyleBox["dep", "TI"], ",", 
          StyleBox["ds", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6ccf0b30-218b-46c3-96b0-668ad635516c"],
     "\[LineSeparator]simulates a random quantum circuit specified by ",
     Cell[BoxData[
      StyleBox["spec", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4a69a0bb-e131-45dd-976f-fee768078e21"],
     " (see ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["RandomBravyiCircuit"]], 
        "paclet:QuantumMob/Q3/ref/RandomBravyiCircuit", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "047eefba-fe74-4b4e-8009-033f78ec353d"],
     ") on non-interacting fermion modes starting from initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d0daa529-b6f5-4ac4-936c-eb3c0e88912d"],
     ", where layers of unitary gates alternate with layers of ",
     ButtonBox["Fermi measurements",
      BaseStyle->"Link",
      ButtonData->"paclet:QuantumMob/Q3/ref/BravyiMeasurement"],
     " to form an overall depth ",
     Cell[BoxData[
      StyleBox["dep", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c62202d8-73bf-42cc-92de-ff4688ad8de6"],
     ". It collects a state at every ",
     Cell[BoxData[
      StyleBox["ds", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "95f03c60-27f3-48c2-99d8-bc4fcd5d8fab"],
     " layers for each run of quantum circuits."
    }],ExpressionUUID->"41d2fd9f-2134-47c5-90dd-92ac220f5340"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["RandomBravyiCircuitSimulate"]], 
         "paclet:QuantumMob/Q3/ref/RandomBravyiCircuitSimulate", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["spec", "TI"], ",", 
        StyleBox["dep", "TI"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9cf90c33-339d-4c52-b6ee-28dcf4ac9b9c"],
     "\[LineSeparator]is equivalent to ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["RandomBravyiCircuitSimulate"]], 
         "paclet:QuantumMob/Q3/ref/RandomBravyiCircuitSimulate", 
