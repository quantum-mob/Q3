Cell[TextData[{
 "The random circuit specification ",
 Cell[BoxData[
  StyleBox["spec", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "38687c15-24e7-4ff9-b957-32dc9365d0fc"],
 " must be consistent with initial state ",
 Cell[BoxData[
  StyleBox["in", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5bcef076-d458-4a2e-a9aa-4e1163332eeb"],
 ". See ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["RandomBravyiCircuit"]], 
    "paclet:QuantumMob/Q3/ref/RandomBravyiCircuit", 
    "QuantumMob Package Symbol"},
