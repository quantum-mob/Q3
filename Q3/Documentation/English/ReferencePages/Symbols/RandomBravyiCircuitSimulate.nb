Cell["\<\
Calculate the logarithmic negativity (LN) between the first and second halves \
of the system:\
\>", "ExampleText",
 CellID->948574183,ExpressionUUID->"d4ead814-56e7-4aed-8d8b-d1f9a3e5c584"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"BravyiLogarithmicNegativity", "[", 
     RowBox[{"trj", ",", "kk", ",", 
      RowBox[{"\"\<Epsilon\>\"", "->", "1.25*^-16"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "neg", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1915182000,ExpressionUUID->"03aea96f-14d5-48bc-bd98-4b118573c67d"],

Cell[BoxData["3.703079`"], "EchoTiming",
 CellID->1312949475,ExpressionUUID->"c9dcb31c-1687-416f-bd20-81313500243c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"100", ",", "31"}], "}"}]], "Output",
 CellLabel->"Out[5]=",
 CellID->1347353400,ExpressionUUID->"05f4de6b-6071-45ec-a7e3-1daa6e5da10f"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Mean", "[", 
    RowBox[{"Re", "@", "neg"}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\[ThinSpace]\!\(\*StyleBox[\"t\",FontSlant->\"\
Italic\"]\)\>\"", 
      ",", "\"\<\[LeftAngleBracket]LN \
(\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\), \
\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\)/2)\[RightAngleBracket]\>\""}], 
     "}"}]}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
