Cell["\<\
This demonstrates the relation between the Euler rotation and the rotation \
around an axis.\
\>", "ExampleText",
 CellID->1464318430,ExpressionUUID->"cec2de3b-1baa-4e9d-8b57-b73ef8cf4f73"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{"TheEulerRotation", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Pi", "/", "3"}], ",", 
      RowBox[{"Pi", "/", "2"}], ",", 
      RowBox[{"Pi", "/", "6"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"mat", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RotationAxis", "[", "mat", "]"}], "//", "ExpToTrig"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->967123104,ExpressionUUID->"4af76c56-dad9-487c-b680-19bce6c054cc"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox[
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         FractionBox[
          RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "4"]}]], 
       SqrtBox["2"]], 
      RowBox[{"-", 
       FractionBox[
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"-", 
          FractionBox[
           RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "12"]}]], 
        SqrtBox["2"]]}]},
     {
      FractionBox[
       SuperscriptBox["\[ExponentialE]", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "12"]], 
       SqrtBox["2"]], 
      FractionBox[
       SuperscriptBox["\[ExponentialE]", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "4"]], 
       SqrtBox["2"]]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
