Cell[TextData[{
 "Usually, it is more efficient to use ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6e578136-01a3-470b-ac5d-3289f6eb3c38"],
 ". Sometimes, however, it is required to construct the matrix representation \
in a specific basis other than the computational or canonical basis."
}], "Notes",
 CellID->96777523,ExpressionUUID->"2fa670c5-98ad-41f7-a88a-59393918f68f"],

