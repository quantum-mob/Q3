Cell[TextData[{
 "Notice the difference between ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorProduct"]], "paclet:ref/TensorProduct"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "707c4990-42e1-40bf-bc26-e8f5b886d6ae"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CircleTimes"]], "paclet:QuantumMob/Q3/ref/CircleTimes", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ca147271-626a-49ae-aa56-1a54ac67710a"],
 ". While ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["TensorProduct"]], "paclet:ref/TensorProduct"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d20ed1bc-07f5-4178-8c5a-42c8a7c5b890"],
 " preserves the tensor product form (in blocks), ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CircleTimes"]], "paclet:QuantumMob/Q3/ref/CircleTimes", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d3c079b9-be09-4f0f-be1b-84ba00bc96f9"],
 " gives the matrix direct product with component blocks flattened. For two \
matrices ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "9d08f21a-236f-4dc9-b888-8160b9bb449f"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "2f4bc275-5d92-4fe0-8069-8cb7782ef9d0"],
 " as an example, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["T", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["TensorProduct"]], "paclet:ref/TensorProduct"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    RowBox[{
     StyleBox["A", "TI"], ",", 
     StyleBox["B", "TI"]}], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7425f9b0-de86-437a-b266-133610117cd6"],
 " gives ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", 
     RowBox[{"i", ",", "j", ",", "k", ",", "l"}]], "=", 
    RowBox[{
     SubscriptBox["A", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["B", 
      RowBox[{"k", "\[VeryThinSpace]", "l"}]]}]}], TraditionalForm]],
  ExpressionUUID->"751fb0ae-4e14-4e37-9005-1b3563f02eef"],
 " while ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{"A", "\[CircleTimes]", "B"}], ")"}], 
     RowBox[{
      RowBox[{"i", "\[VeryThinSpace]", "j"}], ";", 
      RowBox[{"k", "\[VeryThinSpace]", "l"}]}]], "=", 
    RowBox[{
     SubscriptBox["A", 
      RowBox[{"i", "\[VeryThinSpace]", "k"}]], 
     SubscriptBox["B", 
      RowBox[{"j", "\[VeryThinSpace]", "l"}]]}]}], TraditionalForm]],
  ExpressionUUID->"0934ad7f-d494-47e5-982f-e37fe7fe1790"],
 "."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"02d03ff3-adb0-49cb-8fe1-637f567ccbe5"],

Cell[TextData[{
 "In fact, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["CircleTimes"]], "paclet:QuantumMob/Q3/ref/CircleTimes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], " ", "=", " ", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Flatten"]], "paclet:ref/Flatten"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], " ", "@", " ", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["TensorProdut"]], "paclet:ref/TensorProdut"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     StyleBox["\[Ellipsis]", "TR"], "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9fbee079-5724-4e33-8fc7-6b1e6a115c2b"],
 " for vectors and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["CircleTimes"]], "paclet:QuantumMob/Q3/ref/CircleTimes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["TensorFlatten"]], "paclet:QuantumMob/Q3/ref/TensorFlatten", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "@", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["TensorProduct"]], "paclet:ref/TensorProduct"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     StyleBox["\[Ellipsis]", "TR"], "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e4bbd5b5-17f8-4fbb-ab0c-3c514a83246e"],
 " for matrices."
}], "Notes",
 CellID->489048990,ExpressionUUID->"5d59b421-aea9-4148-826c-f2addfcf977d"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Tensorize"]], "paclet:QuantumMob/Q3/ref/Tensorize", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ac5b637e-3ae5-4a9b-9676-64ab306958c7"],
 " recovers the tensor product form from the matrix direct product."
}], "Notes",
 CellID->693042406,ExpressionUUID->"0c4982e0-8df1-41ee-9566-80ab303829d7"]
}, Dynamic[CurrentValue[
