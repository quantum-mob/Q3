      StyleBox["n", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1cfaed20-ec01-44ba-b88f-58dd99833454"],
     " is the number of qubits."
    }],ExpressionUUID->"4e2de31e-5ac9-4599-b568-c932e6f72b24"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["Tensorize"]], "paclet:QuantumMob/Q3/ref/Tensorize", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       StyleBox["v", "TI"], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "fa46f713-b695-4077-b38b-b4c8a5cbabfe"],
     "\[LineSeparator]gives the tensor product form of the vector ",
     Cell[BoxData[
      StyleBox["v", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "86fb72eb-07e3-48b4-9bd7-5ed588357046"],
     ". The vector ",
     Cell[BoxData[
