Cell[TextData[{
 "In this particular example, the submethod option forces ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FindMinimum"]], "paclet:ref/FindMinimum"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b4f6b250-43b7-4448-9853-75301df399cb"],
 " to use the Newton method. This Newton method should be distinguished from \
the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QSPPACK"]], "https://github.com/qsppack/QSPPACK"},
   "WebLink",
   BaseStyle->{"ExampleText"}]],ExpressionUUID->
  "e2372382-625d-4f8b-b9d8-d463ab81aa10"],
 "-implementation achieved by setting the main method option ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Method"]], "paclet:ref/Method"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", "\"\<Newton\>\""}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "03705966-42d0-499d-a3d3-2feb1a523ce6"],
 "."
}], "ExampleText",
 CellID->563890150,ExpressionUUID->"f8cd4a3c-223e-4b4c-8d7f-487487aa5fbd"],

