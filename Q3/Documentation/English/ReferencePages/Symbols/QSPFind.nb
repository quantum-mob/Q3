Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{"hun", "=", 
   RowBox[{"QSPFind", "[", 
    RowBox[{
     RowBox[{"coeff", "->", "$parity"}], ",", 
     RowBox[{"Method", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<FindMinimum\>\"", ",", 
        RowBox[{"Method", "->", "\"\<Newton\>\""}]}], "}"}]}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
