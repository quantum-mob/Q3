Cell["\<\
Construct a combination of Chebyshev polynomials of even or odd order:\
\>", "ExampleText",
 CellID->1398426892,ExpressionUUID->"6c5a747c-8303-417f-a846-18506d889809"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "101", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->635352222,ExpressionUUID->"dc57340d-bd26-4e4f-b886-85fbdcfcc2ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$parity", "=", 
   RowBox[{"RandomChoice", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1"}], ",", " ", "1"}], "}"}], "]"}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"1", "->", "even"}], ",", " ", 
    RowBox[{
     RowBox[{"-", "1"}], "->", "odd"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"$degree", "=", 
  RowBox[{
   RowBox[{"2", "*", "$n"}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "$parity"}], ")"}], "/", "2"}]}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1299741076,ExpressionUUID->"660a5550-ab7a-48e0-8e85-06958da60a29"],

Cell[BoxData[
 RowBox[{"-", "1"}]], "Output",
 CellLabel->"Out[2]=",
 CellID->1981707030,ExpressionUUID->"042f5842-fe1d-47da-a359-fee59216f92c"],

Cell[BoxData["11"], "Output",
 CellLabel->"Out[2]=",
 CellID->1226171887,ExpressionUUID->"3cbae4e0-2c8f-44a8-9faa-6280c2d83d2c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"coeff", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"0.2", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "1"}], "}"}]}], ",", 
     RowBox[{"$n", "+", "1"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"target", "=", 
  RowBox[{"ChebyshevSeries", "[", 
   RowBox[{"coeff", "->", "$parity"}], "]"}]}]}], "Input",
