Cell["This time, consider Chebyshev polynomials of odd order:", "ExampleText",
 CellID->639681490,ExpressionUUID->"ce198996-f248-48bf-ab12-bfd0d5a0045d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$parity", "=", 
    RowBox[{"-", "1"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"1", "->", "even"}], ",", " ", 
    RowBox[{
     RowBox[{"-", "1"}], "->", "odd"}]}], "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->45262995,ExpressionUUID->"f622304d-a6a6-4ef5-bb69-1af094604133"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "100", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->525945927,ExpressionUUID->"e230263c-9a87-4dc2-8e20-0691e37e1c6c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"coeff", "=", 
   RowBox[{"Riffle", "[", 
    RowBox[{
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"0.2", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], ",", 
       RowBox[{"$n", "+", "1"}]}], "]"}], ",", "0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"coeff", "=", 
  RowBox[{"coeff", "[", 
   RowBox[{"[", 
    RowBox[{
     RowBox[{"1", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "$parity"}], ")"}], "/", "2"}]}], ";;"}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"degree", "=", 
  RowBox[{
   RowBox[{"Length", "[", "coeff", "]"}], "-", "1"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1834949736,ExpressionUUID->"cb7ebafb-b333-4b43-a3a9-5561edd790fe"],

Cell[BoxData[
 RowBox[{"{", 
