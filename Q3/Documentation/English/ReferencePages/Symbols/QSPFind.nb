Cell[TextData[{
 "The quantum signal processing (QSP) of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "63d2387a-dda2-432c-8b5d-69897f21b94b"],
 " with phases ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "=", 
    RowBox[{":", 
     OverscriptBox["\[Phi]", "\[RightVector]"]}]}], TraditionalForm]],
  ExpressionUUID->"1ceb835f-77e2-4dcd-8064-fc318a9eddf0"],
 " is a parameterized representation of a polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "82636dc9-f5a7-4a62-93f9-ddeac292d820"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "a397a5b9-7e49-4856-be32-c54e19fa7f6b"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"0412d939-f3af-4c78-9c29-aeb55497b4fa"],
 ", through the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Times]", "2"}], TraditionalForm]],ExpressionUUID->
  "e9bb2be7-ba85-4e09-bfc5-7f661baa0ace"],
 " unitary matrix\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"Q", "(", "x", ")"}], 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["x", "2"]}]]}]},
        {
         RowBox[{"\[VeryThinSpace]", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
           RowBox[{
            SuperscriptBox["Q", "*"], "(", "x", ")"}], 
           SqrtBox[
            RowBox[{"1", "-", 
             SuperscriptBox["x", "2"]}]]}]}], 
         RowBox[{
          SuperscriptBox["P", "*"], "(", "x", ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "a60410a8-543c-4105-93d5-aca73941bcc7"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "b6777135-6805-4d53-87bf-2a2f58f78bec"],
 " is the Pauli-",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "81e11caa-c6b7-470a-9eb5-dd2291db492c"],
 " matrix,\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "92722b86-2911-40fc-8ee7-7b9f9f6aaa06"],
 " ,\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "4786bdff-dce6-4ea9-8af5-655ab7c64010"],
 " is a rotation in the Bloch space around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "9b26a973-fbe8-4ebf-948d-be43cf506030"],
 "-axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "2"}], 
    RowBox[{"arccos", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "eef004f5-ba1c-4363-b398-a11f0440ee91"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", "(", "x", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"x", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}], "x"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "4a94796e-2bbe-4d1a-a2e5-274b40ede439"],
 " ,\nand ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "1ed2fc77-a49d-4b37-ba3c-927785965686"],
 " is a polynomial of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "c914ed11-72dc-4c9c-bd62-fd89122b5015"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", "-", 
       RowBox[{"1", " ", "mod", " ", "2"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"b082c15b-3015-4cd9-b5aa-ef544e56e491"],
 " satisfying the unitarity constraint \n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"P", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"Q", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["x", "2"]}], ")"}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"5da2ec32-da20-4ecd-953f-38008f10f701"],
 "."
}], "Notes",
 CellID->958672882,ExpressionUUID->"957251fd-417a-48d9-96ad-2ec124826711"],

Cell[TextData[{
 "Quantum signal processing is ",
 StyleBox["symmetric",
  FontSlant->"Italic"],
 " if the phase vector is symmetric ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "d"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "1"], ",", 
      SubscriptBox["\[Phi]", "0"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"5413af3c-46f7-49cf-8de0-981ff061262b"],
 " under list reversal. A symmetric quantum signal processing has its \
characteristic unitary matrix symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"], "T"], "(", "x", ")"}]}], 
   TraditionalForm]],ExpressionUUID->"f181b327-3439-470c-91ff-e6a83e72ceb8"],
 ", and polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "f6399734-54a4-42ef-a3e3-b2fc96b8bdd9"],
 " is real. See Theorem 2 in Dong et al. (2021)."
}], "Notes",
 CellID->1795688728,ExpressionUUID->"521dcfe0-31a1-4708-b616-328c194e74f6"],

Cell[TextData[{
 "A quantum signal processing is said to be ",
 StyleBox["symmetric",
  FontSlant->"Italic"],
 " if the phase vector is symmetric; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "d"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "1"], ",", 
      SubscriptBox["\[Phi]", "0"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"e7dc958c-2234-444d-9406-e2b805dcfd68"],
 ", which leaves only ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "d"], ":=", 
    RowBox[{"\[LeftCeiling]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"d", "+", "1"}], ")"}], "/", "2"}], "\[RightCeiling]"}]}], 
   TraditionalForm]],ExpressionUUID->"32ab4c02-b0d2-4a3f-9bc8-d548e3772f5b"],
 " independent phase variables. A symmetric quantum signal processing has its \
characteristic unitary matrix symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"], "T"], "(", "x", ")"}]}], 
   TraditionalForm]],ExpressionUUID->"f9b0293c-c0a1-4a25-9b79-5609122e518b"],
 ", and the polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "d05a9cd4-60cb-4a89-a5fc-5ee94191440a"],
 " is real ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021: Theorem 2)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "a7f2bbbd-287a-4db9-9b6e-3e6d003615a7"],
 "."
}], "Notes",
 CellID->1190343635,ExpressionUUID->"d2cf5c2d-ce41-4235-a16a-2462a43dd42d"],

Cell[TextData[{
 "Given a ",
 StyleBox["reduced",
  FontSlant->"Italic"],
 " set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[CurlyPhi]", "0"], ",", 
     SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["\[CurlyPhi]", 
      RowBox[{
       SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], TraditionalForm]],
  ExpressionUUID->"05abe9a9-db15-4aea-af02-9590738daa45"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "d"], TraditionalForm]],ExpressionUUID->
  "d460e1cc-52ab-4cde-8c07-1f6d364cb15d"],
 " independent phase variables and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"\[PlusMinus]", "1"}]}], TraditionalForm]],ExpressionUUID->
  "077def28-2f34-41f5-8836-a245ca723ba2"],
 " for a symmetric quantum signal processing, one can recover the ",
 StyleBox["full vector",
  FontSlant->"Italic"],
 " of phase variables as follows:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox["\[CurlyPhi]", "0"], ",", 
        SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["\[CurlyPhi]", 
         RowBox[{
          SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], ",", 
      RowBox[{"+", "1"}]}], "}"}], "\[RightTeeArrow]", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      RowBox[{"2", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]]}], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", 
      SubscriptBox["\[CurlyPhi]", "0"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"9d6126d3-8fc0-484d-bdc4-d5c0610d7548"],
 " (notice the factor of 2 for technical convenience),\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox["\[CurlyPhi]", "0"], ",", 
        SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["\[CurlyPhi]", 
         RowBox[{
          SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], ",", 
      RowBox[{"-", "1"}]}], "}"}], "\[RightTeeArrow]", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]], ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", 
      SubscriptBox["\[CurlyPhi]", "0"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"b6881a4b-658f-4f03-81cb-9a480c2925d8"],
 ".\nThe pair ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], ",", 
     RowBox[{"p", "=", 
      RowBox[{"\[PlusMinus]", "1"}]}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"88c96177-3bc9-4935-940c-aa7e195a8727"],
 " is called the ",
 StyleBox["reduced phase vector",
  FontSlant->"Italic"],
 " to be distinguished from the ",
 StyleBox["full phase vector",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1535193593,ExpressionUUID->"c5433390-5672-4283-92f4-062ba8e830a3"],

Cell[TextData[{
 "The correspondence between the reduced and full phase vector is closely \
related to that between the ",
 ButtonBox["reduced and full Chebyshev coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevCoefficients"],
 " list."
}], "Notes",
 CellID->227248759,ExpressionUUID->"53608880-1ba2-41bc-9399-a30581ec9f72"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["n", "TI"]]}], "}"}], ",", 
    RowBox[{
     StyleBox["p", "TI"], "=", 
     RowBox[{"\[PlusMinus]", "1"}]}]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e30ca31b-194c-40ab-aa86-a1225fba34ec"],
 " is a ",
 StyleBox["reduced",
  FontSlant->"Italic"],
 " list of the Chebyshev expansion coefficients. See ",
 ButtonBox["ChebyshevCoefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevCoefficients"],
 " and ",
 ButtonBox["ChebyshevSeries",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevSeries"],
 " for details."
}], "Notes",
 CellID->1698901965,ExpressionUUID->"92f4ab90-c044-4e6c-9b8d-49b9052d8d5d"],

Cell[TextData[{
 "For an even (",
 Cell[BoxData[
  RowBox[{
   StyleBox["parity", "TI"], "=", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bd1acc15-e961-4d39-93fb-792ffdf86490"],
 ") polynomial of degree ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0c611020-2677-414f-bb0a-d1d853ee3d56"],
 ", the reduced list ",
 Cell[BoxData[
  StyleBox["coeff", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3f4cd3b2-dc39-4610-b7d3-ed546efbde5e"],
 " must be of the form ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["0", "TR"]], ",", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["2", "TR"]], ",", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["4", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox[
      RowBox[{
       StyleBox["2", "TR"], 
       StyleBox["n", "TI"]}],
      ZeroWidthTimes->True]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "05b8ae0d-552d-4a8f-9160-fa0733681525"],
 " implying that ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["k", "TI"]], "=", "0"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f1cae069-f3c3-487e-9dee-21c3db7a8f26"],
 " for all odd ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d24d9fa0-b1a9-4935-af96-dc02850be1b5"],
 "."
}], "Notes",
 CellID->1768896574,ExpressionUUID->"6280c28c-3ed9-429c-b7dd-fdf80f7a928d"],

Cell[TextData[{
 "For an odd (",
 Cell[BoxData[
  RowBox[{
   StyleBox["parity", "TI"], "=", 
   RowBox[{"-", "1"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1bc477e3-7762-401d-b5d2-7c8dc4fc561a"],
 ") polynomial of degree ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"2", 
    StyleBox["n", "TI"]}], "-", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "51c09965-34a1-417b-8f6e-e1817c7dae08"],
 ", the reduced list ",
 Cell[BoxData[
  StyleBox["coeff", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "06d6ea0e-cf15-4196-ba91-9fdbb9e27882"],
 " must be of the form ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["c", "TI"], "1"], ",", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["3", "TR"]], ",", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["5", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox[
      RowBox[{
       RowBox[{
        StyleBox["2", "TR"], 
        StyleBox["n", "TI"]}], "-", "1"}],
      ZeroWidthTimes->True]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a5ae4b05-ee77-4853-aa38-700b6f5f2665"],
 " implying that ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["c", "TI"], 
    StyleBox["k", "TI"]], "=", "0"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cdfc383a-252d-46c0-80f8-1d1907ae76bd"],
 " for all even ",
 Cell[BoxData[
  StyleBox["k", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "da3be363-4344-40cd-9939-7f12183295bb"],
 "."
}], "Notes",
 CellID->2078057512,ExpressionUUID->"c6fadea6-9ef6-401f-a1ba-3f22c49ab3fd"],

Cell["The following options can be given: ", "Notes",
 CellID->1118167288,ExpressionUUID->"fafb165f-5be3-41f3-80bd-e119ba578e1c"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "4263e9bc-3d73-4dd8-aa81-806eea20dc44"], 
    TemplateBox[{
      Cell[
       TextData["Method"]], "paclet:ref/Method"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], "\"\<FindMinimum\>\"", Cell[
    "The internal optimization method to use.", "TableText",ExpressionUUID->
     "b5487564-f8d9-441b-b8bc-c7e8fa6846b5"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "04694eda-e165-49c0-871c-41e5eb18676e"], 
    TemplateBox[{
      Cell[
       TextData["MaxIterations"]], "paclet:ref/MaxIterations"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], "50000", Cell["\<\
MaxIterations is an option that specifies the maximum number of iterations \
that should be tried in various built-in functions and algorithms.\
\>", "TableText",ExpressionUUID->"810040f5-6665-4904-aa81-4e75a386af61"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "362dcff7-8d37-44bf-b683-2c839c5f6b35"], 
    TemplateBox[{
      Cell[
       TextData["Tolerance"]], "paclet:ref/Tolerance"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], 
    RowBox[{"1.0", "\[Times]", 
     SuperscriptBox["10", 
      RowBox[{"-", "10"}]]}], Cell["\<\
Tolerance is an option for various numerical options which specifies the \
tolerance that should be allowed in computing results.\
\>", "TableText",ExpressionUUID->"97a0e390-00b9-443f-8e48-bfacbb14f958"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "b8bdd080-c896-49b2-9ba1-7a5bbd7015d3"], "\"\<PostProcessor\>\"", 
    TemplateBox[{
      Cell[
       TextData["Re"]], "paclet:ref/Re"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], Cell[TextData[{
     "Whether to target the real or imaginary part of ",
     Cell[BoxData[
      FormBox[
       RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
      "38656f5f-f863-4ece-9b7a-59801bab1250"],
     ", the (1,1) element of the QSP unitary matrix."
    }], "TableText",ExpressionUUID->"aecd2db8-2e8d-4d16-9e15-2516eba3e0eb"]}
  }]], "3ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{
  "Columns" -> {{None}}, "Rows" -> {None, None, None, {None}}},
 GridBoxDividers->{"Rows" -> {{True, True, True, True, True}}}},
 CellID->408214519,ExpressionUUID->"63d6eec4-346b-4e87-acce-f807f0b003f4"],

Cell[TextData[{
 "Given a target polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"65765510-daa4-4111-b2a6-79cad139781a"],
 ", it is rather difficult to represent it with the polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "b4d28463-b48b-42a6-a6d7-244f66a22ee3"],
 " of the QSP unitary matrix due to constraints characteristic to QSP. It is \
thus much easier to require ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{"Re", "[", 
     RowBox[{"P", "(", "x", ")"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "74832043-f87f-40b0-bba8-fd64d30cae60"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{"Im", "[", 
     RowBox[{"P", "(", "x", ")"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "327702d1-6fa9-4fa3-ad15-678e860abd4d"],
 ". The setting of ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
   "\[OpenCurlyDoubleQuote]", "PostProcessor", "\[CloseCurlyDoubleQuote]"}], "\[Rule]", 
   StyleBox["post", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2a76478b-7e8b-41d8-a46c-436972fc6f9c"],
 ", allows to choose one of these. ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
   "\[OpenCurlyDoubleQuote]", "PostProcessor", "\[CloseCurlyDoubleQuote]"}], "\[Rule]", 
   TemplateBox[{
     Cell[
      TextData["Identity"]], "paclet:ref/Identity"},
    "RefLink",
    BaseStyle->{"InlineFormula"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2a97f49a-efb8-4230-ace2-17c9f2169ad1"],
 " require ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{"P", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "e79adf0b-65cf-4fa0-8469-f84d679b7efe"],
 "."
}], "Notes",
 CellID->1530042028,ExpressionUUID->"a598d467-f192-4d8c-bc24-4910dde8d253"],

Cell[TextData[{
 "The following settings are available for ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Method"]], "paclet:ref/Method"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e0234dfd-00f5-409f-8e63-f184bfc5ae2a"],
 ":"
}], "Notes",
 CellID->153133889,ExpressionUUID->"e2a51688-5dcc-4c92-a7db-7ca5db1302de"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "9edc6893-ca71-4106-b1ee-cc117f2d90c7"], Cell[
    "\"FixedPointIterations\"", "TableText",ExpressionUUID->
     "2d6409d3-ce63-42a6-9045-21ff11589768"], Cell[TextData[{
     "Using fixed point iterations based on the ",
     ButtonBox["contraction mapping theorem",
      BaseStyle->"Hyperlink",
      ButtonData->{
        URL["https://en.wikipedia.org/wiki/Contraction_mapping"], None}],
     " as implemented in the ",
     ButtonBox["QSPPACK",
      BaseStyle->"Hyperlink",
      ButtonData->{
        URL["https://github.com/qsppack/QSPPACK"], None}],
     "."
    }], "TableText",ExpressionUUID->"7186552d-3d08-494b-ba1a-a0f1b23accd2"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "79f79f6a-8de6-42e0-8ea8-34ee4245d348"], Cell[
    "\"BFGS\"", "TableText",ExpressionUUID->
     "930235e7-e2c5-48e5-93a3-6b0da8fe4319"], Cell[TextData[{
     "Using the  limited-memory BFGS (L-BFGS) optimization method as \
implemented in the ",
     ButtonBox["QSPPACK",
      BaseStyle->"Hyperlink",
      ButtonData->{
        URL["https://github.com/qsppack/QSPPACK"], None}],
     ". The BFGS mehtod is known as one of  the  most efficient (and popular) \
 quasi-Newton methods. See ",
     ButtonBox["Sun and Yuan (2006)",
      BaseStyle->"Hyperlink",
      ButtonData->{
        URL["https://doi.org/10.1007/b106451"], None}],
     " for details."
    }], "TableText",ExpressionUUID->"b0108501-caba-421a-a90e-0c5537e5442d"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "9f69131e-95ab-4e72-aafb-be2187737d82"], Cell[
    "\"Newton\"", "TableText",ExpressionUUID->
     "9bc2f5e6-d9b3-458b-a7f0-c69f37d9e6c4"], Cell[TextData[{
     "Using the Newton method as implemented in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["QSPPACK"]], "https://github.com/qsppack/QSPPACK"},
       "WebLink",
       BaseStyle->{"TableText"}]],ExpressionUUID->
      "a5b145ea-d0d1-4d56-81b4-ef499bd039d2"],
     " (to be distiniguished from the Newton method implemented, e.g., by ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["FindMinimum"]], "paclet:ref/FindMinimum"},
       "RefLink",
       BaseStyle->{"2ColumnTableMod"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c299a295-dbcc-4739-bb0f-fc9dccb27e7d"],
     ")."
    }], "TableText",ExpressionUUID->"4c9bcc85-0141-44d1-9631-629fe197aba3"]},
