Cell["\<\
Construct a combination of Chebyshev polynomials of even or odd order:\
\>", "ExampleText",
 CellID->881009647,ExpressionUUID->"39a5fc56-4e62-42d5-84a9-76e881ca493e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "103", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->229391064,ExpressionUUID->"3feb5495-0053-4add-a679-219d857d788b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"$n", "=", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{"Range", "[", 
    RowBox[{"5", ",", "10"}], "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"$parity", "=", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{"-", "1"}]}], "}"}], "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"1", "->", "even"}], ",", " ", 
    RowBox[{
     RowBox[{"-", "1"}], "->", "odd"}]}], "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1677653743,ExpressionUUID->"d6600c77-eb3c-4ce6-8a54-5f42f40859c1"],

Cell[BoxData["8"], "Output",
 CellLabel->"Out[2]=",
 CellID->702134354,ExpressionUUID->"580f8184-59d1-4711-912c-8edca441e02d"],

Cell[BoxData[
 RowBox[{"-", "1"}]], "Output",
 CellLabel->"Out[2]=",
 CellID->349447413,ExpressionUUID->"5c8b4e78-b6b1-4013-85f5-1920041f8618"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"coeff", "=", 
   RowBox[{"Riffle", "[", 
    RowBox[{
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"0.2", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1"}], ",", "1"}], "}"}]}], ",", 
       RowBox[{"$n", "+", "1"}]}], "]"}], ",", "0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"coeff", "=", 
  RowBox[{"coeff", "[", 
   RowBox[{"[", 
    RowBox[{
     RowBox[{"1", "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "$parity"}], ")"}], "/", "2"}]}], ";;"}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"target", "=", 
  RowBox[{"ChebyshevSeries", "[", "coeff", "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1644243185,ExpressionUUID->"d8b77252-eff7-4a4e-872f-faa532250333"],

