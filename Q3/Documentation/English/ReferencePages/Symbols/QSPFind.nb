Cell["Use the Newton method:", "ExampleText",
 CellID->152361005,ExpressionUUID->"93b37d31-7ec9-4437-b81a-5839b58d0c75"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{"gun", "=", 
   RowBox[{"QSPFind", "[", 
    RowBox[{
     RowBox[{"coeff", "->", "$parity"}], ",", 
     RowBox[{"Method", "->", "\"\<Newton\>\""}]}], "]"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
