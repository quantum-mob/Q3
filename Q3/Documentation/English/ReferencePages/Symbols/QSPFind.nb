Cell["\<\
Let us consider a linear combination of randomly chosen Chebyshev polynomials \
of even order:\
\>", "ExampleText",
 CellID->919863471,ExpressionUUID->"c834142a-d82a-447d-87ea-7ebc898d288b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$parity", "=", "1"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"even", ":", " ", "1"}], ",", " ", 
    RowBox[{"odd", ":", " ", 
     RowBox[{"-", "1"}]}]}], " ", "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->196843117,ExpressionUUID->"d1b5e07d-8a87-4f5e-8af7-3953ddfddca8"],

