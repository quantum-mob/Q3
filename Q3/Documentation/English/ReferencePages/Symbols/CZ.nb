Cell[TextData[{
 "The ",
 StyleBox["single-target",
  FontSlant->"Italic"],
 " controlled-Z gate is symmetric over all qubits, and any qubit in ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["CZ"]], "paclet:QuantumMob/Q3/ref/CZ", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["s", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["s", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["s", "TI"], 
      StyleBox["n", "TI"]]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "708ccf4b-aa61-4f3c-996c-bd1a80a0e4e2"],
 " may be regarded as the target qubit and the rest as the control qubits."
}], "Notes",
 CellID->1767519195,ExpressionUUID->"2b949ee5-7df7-4f31-8387-1703713e043e"],

Cell[TextData[{
