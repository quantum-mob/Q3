  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullGottesmanVector"],
 "."
}], "Notes",
 CellID->309725214,ExpressionUUID->"f4428969-9941-4d95-9053-85979d5113ac"]
