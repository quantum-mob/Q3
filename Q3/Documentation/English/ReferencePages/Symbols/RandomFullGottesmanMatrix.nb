Cell[TextData[{
 "A ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "548f6b72-437d-4983-8acd-e9889153bc3d"],
 " is completely specified (up to a global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"\[ImaginaryI]", " ", "m", " ", 
     RowBox[{"\[Pi]", " ", "/", "4"}]}]], TraditionalForm]],ExpressionUUID->
  "988f7803-d395-4596-8b2c-3a8256303520"],
 ") by the transformation of ",
 ButtonBox["Pauli operators",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "61bf3738-a9c9-46f2-a2d5-9f51fcf3671d"],
 ":\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["X", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["p", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["a", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["b", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "063bc8ed-2e92-4886-a6bb-a7de6d21af42"],
 "\nand\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["Z", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["q", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["c", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["d", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "b23e5a1b-ca0f-4262-badf-d483260c66f0"],
 "."
}], "Notes",
 CellID->1417856937,ExpressionUUID->"b4d904d5-8ca1-4fe3-a95f-871828cbcd2c"],

Cell[TextData[{
 "The Gottesman matrix of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "ecf84227-d78b-4327-b8d8-53813b18c5d5"],
 " is then defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "U", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["a", "11"], 
        SubscriptBox["c", "11"], 
        SubscriptBox["a", "12"], 
        SubscriptBox["c", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "11"], 
        SubscriptBox["d", "11"], 
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["a", "21"], 
        SubscriptBox["c", "21"], 
        SubscriptBox["a", "22"], 
        SubscriptBox["c", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "21"], 
        SubscriptBox["b", "22"], 
        SubscriptBox["d", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e06b18be-2c46-4966-aac4-b809020b6229"]
}], "Notes",
 CellID->1647214467,ExpressionUUID->"b809bec2-fcd3-4e93-8333-3a875fa6a3b5"],

Cell[TextData[{
 "The Gottesman matrix of a ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " is a binary symplectic matrix. Recall that the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"39b24cbb-4f13-4f38-849b-11385759b2bd"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "2370d26a-cfa3-49ab-8bf6-64ad859e1362"],
 "qubits is equivalent to the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"3649cc61-ba7a-43e7-b599-f6fe412216c5"],
 " up to the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"701a3d82-c1ac-4968-a30f-c2eedb66213b"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], "\[Congruent]", 
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"0f9d1633-9934-46b1-b7fb-44b5c4afd736"],
 "."
}], "Notes",
 CellID->17963594,ExpressionUUID->"b8e763ca-f974-4dcc-8ad9-1fac2d4420ac"],

Cell[TextData[{
 "Recall that a Pauli operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"9402169f-266c-499e-b332-5eb53212e672"],
 "\[LineSeparator]is completely specified (up to a global phase factor) by \
the corresponding Gottesman vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["z", "1"], ",", 
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["x", "n"], ",", 
       SubscriptBox["z", "n"]}], ")"}], "T"]}], TraditionalForm]],
  ExpressionUUID->"3646ae10-6026-4649-adbe-0b53ed187ece"],
 "."
}], "Notes",
 CellID->1441760612,ExpressionUUID->"2b064777-ae17-4d8f-a18b-5d3b3e181f61"],

Cell[TextData[{
 "Under conjugation by a Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "93ffb9b3-b81e-42cb-9d01-1efc7167c507"],
 ", the Gottesman vector transforms as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", 
     RowBox[{"U", " ", "P", " ", 
      SuperscriptBox["U", "\[Dagger]"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"v", "(", "P", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "b7530898-62cf-46cb-81a5-1d65eeb313d7"],
 "."
}], "Notes",
 CellID->1746253034,ExpressionUUID->"b1ffc11f-7a8f-48b0-8f35-d5e9839e632c"],

Cell[TextData[{
 "Furthermore, a series of consecutive conjugations by Clifford operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ",", " ", "V", ",", " ", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"e5836574-ef1e-4fa4-b12d-416824b10e3c"],
 " is described by the multiplications of corresponding Gottesman matrices,\
\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], "\[Ellipsis]"}]}], TraditionalForm]],
  ExpressionUUID->"b105fc36-5c96-4be2-bbb6-2c85220f5097"],
 ". \[LineSeparator]That is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]", " ", "P"}], " ", "..."}], " ", 
     SuperscriptBox["V", "\[Dagger]"], 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
     SuperscriptBox[
      RowBox[{"P", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "\[Dagger]"]}]}], 
   TraditionalForm]],ExpressionUUID->"3c5ab4eb-92e3-4247-afe6-7f2f79f275f1"],
 "\[LineSeparator]leads to\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"v", "(", "P", ")"}], "\[RightTeeArrow]", 
     RowBox[{
      RowBox[{"S", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
      RowBox[{"v", "(", "P", ")"}]}]}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], 
     RowBox[{"\[Ellipsis]v", "(", "P", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"b5b90165-2153-4aed-bb43-fb1e76b2abcf"],
 "."
}], "Notes",
 CellID->863527665,ExpressionUUID->"de39fcdf-7d5f-4d69-8b70-0fea616e4fe0"],

Cell[TextData[{
 "For technical reasons, however,  ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanMatrix"]], "paclet:QuantumMob/Q3/ref/GottesmanMatrix",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f608d87e-d55e-4b06-b08c-fde2de601780"],
 " returns the transposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["S", "T"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"ce96a075-569d-4bfd-a7dd-8d58c915a1ec"],
 " rather than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "(", "U", ")"}], TraditionalForm]],ExpressionUUID->
  "70ebd2f1-ac71-4a98-95e4-d5626e9af74c"],
 " itself. ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FromGottesmanMatrix"]], 
    "paclet:QuantumMob/Q3/ref/FromGottesmanMatrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9a442555-4b71-482b-b0b1-1eb61baf2d86"],
 " also recovers Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "bb5303de-686c-4d9d-a44c-0899705afc4b"],
 " by assuming that the input matrix is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["S", "T"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"c10b2e9b-fee6-4c99-9f25-47ce7da8b120"],
 "."
}], "Notes",
 CellID->327820378,ExpressionUUID->"767b887d-ea1a-4f2b-ad98-4bbd5f915676"],

