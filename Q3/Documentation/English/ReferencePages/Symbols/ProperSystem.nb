Cell[TextData[{
 "The operator expression should be a valid expression. Here the two terms \
are inconsistent because ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Pauli"]], "paclet:QuantumMob/Q3/ref/Pauli", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"1", ",", "3"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "88f8f283-b8ed-44a7-a9ec-43edf47479a1"],
 " is a two-qubit operator whereas ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Pauli"]], "paclet:QuantumMob/Q3/ref/Pauli", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", "3", "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f8f44308-107b-4a80-884d-8897dd316965"],
 " acts only on a single qubit."
}], "ExampleText",
 CellID->518846205,ExpressionUUID->"c531a5b5-22ee-4403-abb7-59fa3f9e7d73"],

