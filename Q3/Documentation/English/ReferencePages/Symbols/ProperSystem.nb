Cell[BoxData[
 PanelBox[
  TagBox[GridBox[{
     {
      RowBox[{"-", "4"}], 
      RowBox[{
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"Ket", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", "0"}], "}"}], "]"}]}], "+", 
       RowBox[{"Ket", "[", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], "]"}], "-", 
       RowBox[{"\[ImaginaryI]", " ", 
