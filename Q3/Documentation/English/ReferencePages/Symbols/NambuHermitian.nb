Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["NambuHermitian"]], "paclet:QuantumMob/Q3/ref/NambuHermitian", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     StyleBox["H", "TI"], ",", 
     StyleBox["\[CapitalDelta]", "TI"]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7785a73a-fff7-48e5-b31c-388bb8b4399f"],
 " represents the quadratic many-body Hamiltonian\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], ":=", 
    RowBox[{
     FractionBox["1", "2"], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", "j"}]], 
     SubsuperscriptBox[
      UnderoverscriptBox["a", "_", "^"], "i", "\[Dagger]"], 
     SubscriptBox[
      UnderscriptBox["H", "_"], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox[
      UnderoverscriptBox["a", "_", "^"], "j"]}]}], TraditionalForm]],
  ExpressionUUID->"0b197bd5-8d1e-45fd-a6dc-a1e088c688ef"],
 " (notice the factor of 1/2)   with   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["H", "_"], ":=", 
    RowBox[{"(", GridBox[{
       {"H", "\[CapitalDelta]"},
       {
        SuperscriptBox["\[CapitalDelta]", "\[Dagger]"], 
        RowBox[{"-", 
         SuperscriptBox["H", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "66835079-801a-4422-9662-3ec16d304d9c"],
 "    and    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["a", "_", "^"], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox[
         OverscriptBox["a", "^"], "i"]},
       {
        SubsuperscriptBox[
         OverscriptBox["a", "^"], "i", "\[Dagger]"]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "133abf47-96b4-4d5d-b36d-a0abf019dc45"],
 "\[LineSeparator] for Dirac fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["a", "^"], "i"], TraditionalForm]],ExpressionUUID->
  "cd625299-d42e-48c7-a495-0eebe117a1fe"],
 "."
}], "Notes",
 CellID->1744165731,ExpressionUUID->"b4c6ae9e-eea8-472d-b1af-d5e17ffce834"],

Cell[TextData[{
 "The sub-block matrices ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "f34c0794-97a0-42ed-905b-ef72df54b88f"],
 " and ",
 Cell[BoxData[
  FormBox["\[CapitalDelta]", TraditionalForm]],ExpressionUUID->
  "7786c0ea-9947-4833-a058-79a5b005237b"],
 " are supposed to satisfy ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["H", "\[Dagger]"], "=", "H"}], TraditionalForm]],
  ExpressionUUID->"7b21195a-6801-4660-845f-1f45fb7c75ff"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalDelta]", "T"], "=", 
    RowBox[{"-", "\[CapitalDelta]"}]}], TraditionalForm]],ExpressionUUID->
  "e9e91c5a-4473-4c39-ac59-ffbad54725be"],
 "."
}], "Notes",
 CellID->2144996101,ExpressionUUID->"d050365e-d18a-48e6-a8a8-bc8d675f6007"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["NambuHermitian"]], "paclet:QuantumMob/Q3/ref/NambuHermitian",
       "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["H", "TI"], ",", 
      StyleBox["\[CapitalDelta]", "TI"]}], "}"}], "]"}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e5f89fc1-f6f3-440f-97ba-b2cc7a20bbbd"],
 " returns the matrix representation of the many-body Hamiltonian ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "d154ee6d-d280-4049-835e-d1147f67b635"],
 " in the ",
 StyleBox["Fock space",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->727929663,ExpressionUUID->"e58e5c82-fe9f-4cfa-a975-35836fca7da0"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Normal"]], "paclet:ref/Normal"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["NambuHermitian"]], "paclet:QuantumMob/Q3/ref/NambuHermitian",
       "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["H", "TI"], ",", 
      StyleBox["\[CapitalDelta]", "TI"]}], "}"}], "]"}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "839de025-5ca5-4bcb-a34c-cca1e0dd9649"],
 " returns the full ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9e49cade-a387-4283-a43d-02128bb65277"],
 " matrix in the ",
 StyleBox["Nambu space",
  FontSlant->"Italic"],
 "; that is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"H", ",", "\[CapitalDelta]"}], "}"}], "\[RightTeeArrow]", 
     UnderscriptBox["H", "_"]}], ":=", 
    RowBox[{"(", GridBox[{
       {"H", "\[CapitalDelta]"},
       {
        SuperscriptBox["\[CapitalDelta]", "\[Dagger]"], 
        RowBox[{"-", 
         SuperscriptBox["H", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "05844e8f-a29f-48e7-b136-5603926c1993"],
 " assuming that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["H", "\[Dagger]"], "=", "H"}], TraditionalForm]],
  ExpressionUUID->"b782d63a-8708-4ffb-a9e4-a29f25366dfd"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalDelta]", "T"], "=", 
    RowBox[{"-", "\[CapitalDelta]"}]}], TraditionalForm]],ExpressionUUID->
  "c2020fb3-b113-4665-a81f-6facf3e8870e"],
 "."
}], "Notes",
 CellID->64037791,ExpressionUUID->"53132185-77dd-407f-815c-af62c2373304"],

Cell[TextData[{
 "The transformation rules between Dirac fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "3ccddac1-0493-4cc7-851c-dbab5b4ea6f5"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["a", "k", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "107cf700-ec31-45c9-b4c0-e4a00d480d1d"],
 " and the Majorana fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     RowBox[{"2", "k"}], "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "95cdf59b-8d77-44f6-b7c4-554ba1ea7fb4"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{"2", "k"}]], TraditionalForm]],ExpressionUUID->
  "b42df97f-81f7-4a72-b1b9-b04bbac269ee"],
 " are given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", 
     RowBox[{
      RowBox[{"2", "k"}], "-", "1"}]], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "+", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"f0605907-7f91-47e9-856e-0c5247dc8552"],
 ", \[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubscriptBox["c", 
      RowBox[{"2", "k"}]]}], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "-", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"c48b1b4b-0de4-47ef-bcd4-670490a9bb84"],
 ".\[LineSeparator]Note that the Majorana operators are normalized as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["a", "i"], ",", 
      SubscriptBox["a", "j"]}], "}"}], "=", 
    RowBox[{"2", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"af92f13e-a300-469d-a59c-948250cda7fb"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "i", "2"], "=", "1"}], TraditionalForm]],
