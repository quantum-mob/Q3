  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{"EE", "\[VeryThinSpace]", "(", 
     RowBox[{"L", ",", 
      SubscriptBox["L", "A"]}], ")"}], "\[RightAngleBracket]"}], 
   TraditionalForm]],ExpressionUUID->"638a4659-ecb0-4d57-a29c-52961a368f34"],
