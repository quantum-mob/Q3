Cell[TextData[{
 "Let us examine the average entanglement entropy in more detail, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{"EE", "\[VeryThinSpace]", "(", 
     RowBox[{"L", ",", 
      SubscriptBox["L", "A"]}], ")"}], "\[RightAngleBracket]"}], 
   TraditionalForm]],ExpressionUUID->"00287ff6-c9ce-40cb-843b-4f96f9194296"],
 " for different subsystem size ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "A"], TraditionalForm]],ExpressionUUID->
  "d44556e0-9b05-47af-bdd4-c308a97efa94"],
 " with fixed total system size ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "5dc8e727-1389-4efe-abba-79462500ec7c"],
 "."
}], "ExampleText",
 CellID->2081253447,ExpressionUUID->"75907aab-6a67-4415-8a8e-a1e2264fe4be"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"avgEntTime", "=", 
    RowBox[{"Table", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"kk", "=", 
        RowBox[{"Range", "[", "k", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Mean", "@", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"EntanglementEntropy", "[", 
            RowBox[{"#", ",", "kk"}], "]"}], "&"}], ",", "trj", ",", 
          RowBox[{"{", "2", "}"}]}], "]"}]}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", 
        RowBox[{"$L", "/", "2"}]}], "}"}]}], "\[IndentingNewLine]", "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"avgEntTime", "//", "Dimensions"}]}], "Input",
