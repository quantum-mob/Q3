  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"avgEnt", "=", 
    RowBox[{"Mean", "@", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"EntanglementEntropy", "[", 
         RowBox[{"#", ",", "kk"}], "]"}], "&"}], ",", "trj", ",", 
       RowBox[{"{", "2", "}"}]}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"avgEnt", "//", "Dimensions"}]}], "Input",
