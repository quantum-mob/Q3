Cell[TextData[{
 "Set the parameters: ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "50edd714-de65-40ea-9117-66c5d9931c81"],
 " is the probability, ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "ea77c3d0-30ec-42d8-8c5f-41986f639485"],
 " is the total depth of random circuits, and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "0155c1f9-ebb4-4102-8d9d-46b5ec4a374e"],
 " is the number of random circuits to try."
}], "ExampleText",
 CellID->632631874,ExpressionUUID->"f33b5924-fd04-47a1-b8f8-64535bfdbc8f"],

