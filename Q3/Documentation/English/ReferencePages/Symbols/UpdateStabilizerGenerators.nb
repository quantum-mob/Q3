Cell["\<\
Consider a Pauli measurement specified by the following full Gottesman vector.\
\>", "ExampleText",
 CellID->1416526311,ExpressionUUID->"b4f28854-5f23-4069-bb54-39d3fe8dd40d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"msr", "=", 
  RowBox[{"{", 
   RowBox[{
   "1", ",", "0", ",", "0", ",", "0", ",", "1", ",", "0", ",", "1", ",", "0", 
    ",", 
    RowBox[{"-", "1"}]}], "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"FromGottesmanVector", "[", 
  RowBox[{"msr", ",", "Pauli"}], "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->642614881,ExpressionUUID->"0d096b09-3f36-47b4-895b-70121153474e"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
  "1", ",", "0", ",", "0", ",", "0", ",", "1", ",", "0", ",", "1", ",", "0", ",", 
   RowBox[{"-", "1"}]}], "}"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->166454710,ExpressionUUID->"9576ba78-e5c6-4e55-a052-8500ccecd4be"],

Cell[BoxData[
 RowBox[{"-", 
  RowBox[{"(", 
   InterpretationBox[
    RowBox[{"\<\"X\"\>", "\[CircleTimes]", "\<\"I\"\>", 
     "\[CircleTimes]", "\<\"X\"\>", "\[CircleTimes]", "\<\"X\"\>"}],
    Q3`Pauli[{1, 0, 1, 1}]], ")"}]}]], "Output",
 CellLabel->"Out[4]=",
 CellID->1580602576,ExpressionUUID->"5d875c2e-66a1-47a3-aaf7-6d9441deeddd"]
}, Open  ]],

Cell["\<\
Check if there exists any generator that anti-commutes with the measurement \
operator.\
\>", "ExampleText",
 CellID->1175951049,ExpressionUUID->"ef30bc76-029b-4ad6-8c49-ae12cba2a12c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"GottesmanDot", "[", 
  RowBox[{
   RowBox[{"Most", "@", "msr"}], ",", 
   RowBox[{"gnr", "[", 
    RowBox[{"[", 
     RowBox[{";;", ",", 
      RowBox[{";;", 
       RowBox[{"-", "2"}]}]}], "]"}], "]"}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1306159610,ExpressionUUID->"d155b15a-5fff-4ae8-8662-31bc265d55ee"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"0", ",", "1", ",", "1", ",", "0"}], "}"}]], "Output",
 CellLabel->"Out[5]=",
 CellID->1513393381,ExpressionUUID->"1ade81d2-7605-4476-b117-7aadc2891761"]
}, Open  ]],

Cell["\<\
Update the stabilizer generators assuming that the measurement outcome is 1.\
\>", "ExampleText",
 CellID->214223290,ExpressionUUID->"60213ac3-3b60-47e3-a566-936738be47c0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"new", "=", 
   RowBox[{"UpdateStabilizerGenerators", "[", 
    RowBox[{"gnr", ",", "msr"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"FromGottesmanVector", "[", 
    RowBox[{"#", ",", "Pauli"}], "]"}], "&"}], "/@", "new"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1868997692,ExpressionUUID->"d32f7865-3be3-4134-952e-fe0e0c24f332"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    RowBox[{"(", 
     InterpretationBox[
      RowBox[{"\<\"Y\"\>", "\[CircleTimes]", "\<\"I\"\>", 
       "\[CircleTimes]", "\<\"Z\"\>", "\[CircleTimes]", "\<\"X\"\>"}],
      Q3`Pauli[{2, 0, 3, 1}]], ")"}]}], ",", 
   RowBox[{"-", 
    RowBox[{"(", 
     InterpretationBox[
      RowBox[{"\<\"X\"\>", "\[CircleTimes]", "\<\"I\"\>", 
       "\[CircleTimes]", "\<\"X\"\>", "\[CircleTimes]", "\<\"X\"\>"}],
      Q3`Pauli[{1, 0, 1, 1}]], ")"}]}], ",", 
   RowBox[{"-", 
    RowBox[{"(", 
     InterpretationBox[
      RowBox[{"\<\"X\"\>", "\[CircleTimes]", "\<\"I\"\>", 
       "\[CircleTimes]", "\<\"Z\"\>", "\[CircleTimes]", "\<\"Y\"\>"}],
      Q3`Pauli[{1, 0, 3, 2}]], ")"}]}], ",", 
   RowBox[{"-", 
    RowBox[{"(", 
     InterpretationBox[
      RowBox[{"\<\"Z\"\>", "\[CircleTimes]", "\<\"X\"\>", 
       "\[CircleTimes]", "\<\"I\"\>", "\[CircleTimes]", "\<\"Z\"\>"}],
      Q3`Pauli[{3, 1, 0, 3}]], ")"}]}]}], "}"}]], "Output",
 CellLabel->"Out[6]=",
 CellID->1853549385,ExpressionUUID->"f9432817-c9e5-4cc3-9fe5-970b8800d447"]
}, Open  ]],

Cell["\<\
Check that the new generators are independent of each other and all commute \
with each other..\
\>", "ExampleText",
 CellID->422721713,ExpressionUUID->"1c7e581b-6f29-4714-8b74-85b4aa83aab6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixRank", "[", 
  RowBox[{
   RowBox[{"Most", "/@", "new"}], ",", 
   RowBox[{"Modulus", "->", "2"}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->967146474,ExpressionUUID->"2cb179f1-a44e-41c4-b874-aa529ff1fe89"],

Cell[BoxData["4"], "Output",
 CellLabel->"Out[7]=",
 CellID->582317910,ExpressionUUID->"561a0155-8a7a-4838-ac52-ccf0d74c842e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
