 RowBox[{
  RowBox[{"full", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"Append", "[", 
     RowBox[{
      RowBox[{"Transpose", "@", "gm"}], ",", 
      RowBox[{"RandomChoice", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{"-", "1"}]}], "}"}], ",", 
        RowBox[{"2", "$n"}]}], "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"full", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
