Cell[TextData[{
 "If ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "456351a4-6ac3-45eb-a3f9-f05e42bda4f8"],
 " is a ",
 StyleBox["full",
  FontSlant->"Italic"],
 " Gottesman matrix, then the returned Clifford operator includes a Pauli \
string to get the exact phase factors. Otherwise, the returned operator is up \
to a Pauli string."
}], "Notes",
 CellID->1911797892,ExpressionUUID->"897de34d-3cce-40e3-beb3-528946537f4c"],

Cell[TextData[{
 "A Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "42fe6b25-b96c-47f8-8937-79f0ff1d3706"],
 " is completely specified (up to a global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"\[ImaginaryI]", " ", "m", " ", 
     RowBox[{"\[Pi]", " ", "/", "4"}]}]], TraditionalForm]],ExpressionUUID->
  "88fa76a8-21ef-4f0b-bddb-d0e0d33ca6ee"],
 ") by the transformation of Pauli operators under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "ae0e31ec-855f-4272-a912-5740c56f6e8c"],
 ":\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["X", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["p", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["a", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["b", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "87ad838f-26b9-4487-bbab-2c58ad856f9a"],
 "\nand\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["Z", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["q", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["c", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["d", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "d657b5cb-a793-41f9-a1ed-909a365b2d62"],
 "."
}], "Notes",
 CellID->1417856937,ExpressionUUID->"80d325ff-26a2-449e-942e-7d0bd869d3ee"],

Cell[TextData[{
 "The Gottesman matrix of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "9b0058a4-963c-4b8c-8118-8f91aafa935f"],
 " is defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "U", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["a", "11"], 
        SubscriptBox["c", "11"], 
        SubscriptBox["a", "12"], 
        SubscriptBox["c", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "11"], 
        SubscriptBox["d", "11"], 
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["a", "21"], 
        SubscriptBox["c", "21"], 
        SubscriptBox["a", "22"], 
        SubscriptBox["c", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "21"], 
        SubscriptBox["b", "22"], 
        SubscriptBox["d", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "92a6a5d3-24a1-4630-a84e-fb21dafd2e10"]
}], "Notes",
 CellID->2083430531,ExpressionUUID->"ddf44e98-89fc-4db4-9a2b-7ea7130d91f8"],

Cell[TextData[{
 "The Gottesman matrix of a ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " is a binary symplectic matrix. Recall that the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"f2e62c9b-449c-4a62-90b9-7287fa2c1c53"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "35a30349-d685-4cee-9531-c19f2b37f4f9"],
 "qubits is equivalent to the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"8bd72932-3e75-428f-b50c-bc13d718410c"],
 " up to the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"45d2356f-1e0e-462d-ba83-de767d9fb0e8"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], "\[Congruent]", 
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"954bfd73-d2b9-46c5-89be-8280edba1886"],
 "."
}], "Notes",
 CellID->17963594,ExpressionUUID->"b3d727d6-5235-4826-a599-e61c7fd47412"],

Cell[TextData[{
 "Recall that a Pauli operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"4bbf4382-4471-4eaa-801e-44f21c331443"],
 "\[LineSeparator]is completely specified by the corresponding Gottesman \
vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["z", "1"], ",", 
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["x", "n"], ",", 
       SubscriptBox["z", "n"]}], ")"}], "T"]}], TraditionalForm]],
  ExpressionUUID->"abd4074b-8a2a-488c-b734-bac7e0f66964"],
 "."
}], "Notes",
 CellID->1441760612,ExpressionUUID->"fb78fd47-78f1-4763-a3bd-856d254184cd"],

Cell[TextData[{
 "Under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "001c446d-3db3-4b26-8576-d4578bac5bea"],
 ", the Gottesman vector transforms as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", 
     RowBox[{"U", " ", "P", " ", 
      SuperscriptBox["U", "\[Dagger]"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"v", "(", "P", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "af92cac9-7934-48f6-9137-767ac33440db"],
 "."
}], "Notes",
 CellID->1746253034,ExpressionUUID->"fcbf3a2a-00d8-42d8-995e-ea29fa081e35"],

Cell[TextData[{
 "Furthermore, a series of consecutive conjugations by Clifford operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ",", " ", "V", ",", " ", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"4e8a85ea-a378-4880-af31-22bb341aeb52"],
 " is described by the multiplications of corresponding Gottesman matrices,\
\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], "\[Ellipsis]"}]}], TraditionalForm]],
  ExpressionUUID->"3a2f5bb3-d2a5-4193-808f-103d9378592d"],
 ". \[LineSeparator]That is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]", " ", "P"}], " ", "..."}], " ", 
     SuperscriptBox["V", "\[Dagger]"], 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
     SuperscriptBox[
      RowBox[{"P", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "\[Dagger]"]}]}], 
   TraditionalForm]],ExpressionUUID->"53f622a1-53c7-4417-addf-3f06ad09f5a1"],
 "\[LineSeparator]leads to\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"v", "(", "P", ")"}], "\[RightTeeArrow]", 
     RowBox[{
      RowBox[{"S", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
      RowBox[{"v", "(", "P", ")"}]}]}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], 
     RowBox[{"\[Ellipsis]v", "(", "P", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"b61ef6bb-35ca-43aa-b28c-07cee7af0a32"],
 "."
}], "Notes",
 CellID->863527665,ExpressionUUID->"8da095d6-62a5-4516-afb5-3b9850650637"],

Cell[TextData[{
 "For technical reasons, however,  ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanMatrix"]], "paclet:QuantumMob/Q3/ref/GottesmanMatrix",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4832b50c-1154-4560-af1c-7064d3c7f027"],
 " returns the transposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["S", "T"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"18f59075-c0b6-40d7-9530-024a2fc77f84"],
 " rather than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "(", "U", ")"}], TraditionalForm]],ExpressionUUID->
  "fbea8524-1f70-4dfa-b256-15b4625d1a77"],
 " itself. ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FromGottesmanMatrix"]], 
    "paclet:QuantumMob/Q3/ref/FromGottesmanMatrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3926204c-d8c9-4f56-943a-afac717cf330"],
 " also recovers Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "f2f80c85-6b7c-4d99-a82b-600a895d8ae3"],
 " by assuming that the input matrix is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["S", "T"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"912d986e-0405-47d9-979e-a6fd1ec3e292"],
 "."
}], "Notes",
 CellID->327820378,ExpressionUUID->"d1303fe7-78b8-4f60-81f5-fdbcf339be83"],

Cell[TextData[{
 "In many case, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["GottesmanMatrix"]], 
     "paclet:QuantumMob/Q3/ref/GottesmanMatrix", "QuantumMob Package Symbol"},
    
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["op", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8624ae5a-1152-44d2-8370-e3fa5df6bf3e"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["GottesmanMatrix"]], 
     "paclet:QuantumMob/Q3/ref/GottesmanMatrix", "QuantumMob Package Symbol"},
    
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["op", "TI"], ",", 
     StyleBox["ss", "TI"]}], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b3100f68-530b-4b41-a7dc-789a7cc83828"],
 " are faster than ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["GottesmanMatrix"]], 
     "paclet:QuantumMob/Q3/ref/GottesmanMatrix", "QuantumMob Package Symbol"},
    
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["op", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "326449e3-d748-40dd-ba9d-cb024f6f1d2c"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["GottesmanMatrix"]], 
     "paclet:QuantumMob/Q3/ref/GottesmanMatrix", "QuantumMob Package Symbol"},
    
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["op", "TI"], ",", 
    StyleBox["ss", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "abc55c72-1cbc-4a38-af19-65ea66962da4"],
 ", respectively. However, there are cases where the latter are faster."
}], "Notes",
 CellID->1427886327,ExpressionUUID->"5e5b936d-751f-4150-bdd8-c335dec2020b"],

Cell[TextData[{
 "Internally, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FromGottesmanMatrix"]], 
    "paclet:QuantumMob/Q3/ref/FromGottesmanMatrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4b5505be-4536-43d6-a2e7-b82e622dbebd"],
 " uses ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CliffordFactor"]], "paclet:QuantumMob/Q3/ref/CliffordFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "07b589d4-b12e-433f-bc45-ca3d5f2b02e6"],
 ". Since Q3 v3.5.11, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CliffordFactor"]], "paclet:QuantumMob/Q3/ref/CliffordFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "32735186-fe96-4185-b376-367a7397abb0"],
 " is based on the algorithm in ",
 ButtonBox["van den Berg (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1109/qce52317.2021.00021"], None}],
 ". Previously, it was based on Gottesman's theorem in ",
 ButtonBox["Gottesman (1998)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.57.127"], None}],
 ". While the latter provides a more compact set of (a bit higher-level) \
gates, the former is faster and easier to trace the changes in the sign of \
Pauli strings."
}], "Notes",
 CellID->982671809,ExpressionUUID->"a4ae51ee-087c-4c08-a55a-692d49be5695"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

