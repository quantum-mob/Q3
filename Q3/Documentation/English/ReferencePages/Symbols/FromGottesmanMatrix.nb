Cell[TextData[{
 "In general, the above Clifford unitary from reduced Gottesman matrix is up \
to a factor of Pauli string which may lead to an additional phase factor of \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], TraditionalForm]],ExpressionUUID->
  "7743754f-867b-4488-b9db-e5505b315bd9"],
 " upon conjugation transformation. Q3 returns a representative that has no \
factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], TraditionalForm]],ExpressionUUID->
  "8b8d4f48-cdf1-4aca-ba30-ae9a3f106c6d"],
 "."
}], "ExampleText",
 CellID->1371886520,ExpressionUUID->"f7410853-d295-47fe-96d5-8e16ba375726"],

