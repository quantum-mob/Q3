     {"0", "0", "0", "1", "\<\"\[Ellipsis]\"\>"},
     {"1", "1", "1", "1", "\<\"\[Ellipsis]\"\>"},
     {"0", "0", "0", "1", "\<\"\[Ellipsis]\"\>"},
     {"1", "0", "0", "1", "\<\"\[Ellipsis]\"\>"},
     {"\<\"\[Ellipsis]\"\>", "\<\"\[Ellipsis]\"\>", "\<\"\[Ellipsis]\"\>", \
