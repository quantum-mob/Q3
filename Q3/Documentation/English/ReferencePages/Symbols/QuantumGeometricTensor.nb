  ButtonFunction:>(FrontEndExecute[{
     FrontEnd`SelectionMove[
      FrontEnd`SelectedNotebook[], All, ButtonCell], 
     FrontEndToken["OpenCloseGroup"], 
     FrontEnd`SelectionMove[
      FrontEnd`SelectedNotebook[], After, CellContents]}]& ),
  Evaluator->None,
  Method->
   "Preemptive"]],ExpressionUUID->"45d8e5ee-14b0-4001-b46b-ac28820650d2"]], \
"NotesSection",
 ShowGroupOpener->"Thumbnail",
 WholeCellGroupOpener->True,
 CellGroupingRules->{"SectionGrouping", 50},
 CacheGraphics->False,
 CellID->2011520867,ExpressionUUID->"7b765d84-aecb-4000-abdd-ebcd66737b1d"],

Cell["\<\
The quantum geometric tensor (QGT) is a complex-valued tensor that \
characterizes the local geometry of quantum states in parameter space. It \
encodes both the distance and phase structure of quantum states, providing a \
unified framework for understanding quantum geometry and topology.\
\>", "Notes",
 CellID->1984473323,ExpressionUUID->"06887e23-f36e-47b7-b319-6d588c5a4e24"],

Cell[TextData[{
 "The QGT is defined as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["\[PartialD]", "\[Mu]"], "\[Psi]"}]},
       "Bra"], "(", 
      RowBox[{"I", "-", 
       RowBox[{
        TemplateBox[{"\[Psi]"},
         "Ket"], 
        TemplateBox[{"\[Psi]"},
         "Bra"]}]}], ")"}], 
     TemplateBox[{
       RowBox[{
         SubscriptBox["\[PartialD]", "\[Nu]"], "\[Psi]"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "d598b39d-e8f5-4e97-a73c-e483e4e56322"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "baa51436-678e-4abe-90e6-b9930eaf4257"],
 " is the quantum state and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "327ef449-8212-46a3-8b79-f14953acaccb"],
 " denotes the derivative with respect to parameter ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "115ac4c6-0fad-4718-a60d-d2bbfae2b161"],
 ". Note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "-", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], 
     TemplateBox[{"\[Psi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "e6d26092-bc21-42b3-bf8e-153aef5ce5b1"],
 " projects onto the subspace orthogonal to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "102bd019-5259-45c9-9ad6-5f79c409a3e5"],
 "."
}], "Notes",
 CellID->677884236,ExpressionUUID->"cedce457-db71-4f61-bf75-89191429bcd6"],

Cell[TextData[{
 "The real part, i.e., the symmetric part, of the QGP, is called the ",
 StyleBox["Fubini-Study metric",
  FontSlant->"Italic"],
 " and measures the distance between nearby quantum states (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Stokes et al., 2020"]], 
    "https://doi.org/10.22331/q-2020-05-25-269"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "86f3206d-7d25-4baf-8d06-507df5cfa838"],
 ")."
}], "Notes",
 CellID->1501045863,ExpressionUUID->"9f5750ee-4c7b-481f-828e-149b57a75699"],

Cell[TextData[{
 "The imaginary part, i.e., the anti-symmetric part, of the QGT, corresponds \
to the ",
 StyleBox["Berry curvature",
  FontSlant->"Italic"],
 " and encodes topological properties such as geometric phases and Chern \
numbers."
}], "Notes",
 CellID->1170758950,ExpressionUUID->"66c4aced-caea-40b3-90c2-8606f1e26381"],

Cell[TextData[{
 "The QGT provides complete information about the geometry of quantum states: \
The ",
 StyleBox["Fubini-Study metric",
  FontSlant->"Italic"],
 " quantifies how \[OpenCurlyDoubleQuote]far apart\[CloseCurlyDoubleQuote] \
quantum states are in parameter space whereas the ",
 StyleBox["Berry curvature",
  FontSlant->"Italic"],
 " reveals the topological nature of quantum systems, influencing transport \
properties and phase transitions."
}], "Notes",
 CellID->1347478979,ExpressionUUID->"f1fa98f7-6f17-48fc-8453-55d0f0a27ea7"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["g", "TI"]]}], "}"}], ",", 
    StyleBox["vec", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "31f442d4-ddcc-42a3-bf4b-24c99f6bdf5a"],
 " calculates the Fubini-Study metric tensor under a special condition as \
follows (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Stokes et al., 2020"]], 
    "https://doi.org/10.22331/q-2020-05-25-269"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "c3cbc4a0-f87e-4f38-abe0-6f214e3baa6b"],
 "): Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"V", "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "52f42d11-2416-4f2c-83fb-b9ef1fc39c21"],
 ". There exists a Hermitian generator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "d6f7a499-95dc-4592-8cd4-ee55a2535a1e"],
 " such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], "V"}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", "\[Mu]"], "V"}]}], TraditionalForm]],ExpressionUUID->
  "f27562da-9f9c-4aeb-bb40-54335a4a0fd7"],
 " .\[LineSeparator]The crucial assumption is that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], 
     SubscriptBox["H", "\[Nu]"]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"b3956052-4b2f-49cd-96c1-6ba41ae6ca0e"],
 ". This in turn implies that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], ",", 
      SubscriptBox["H", "\[Nu]"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"fdceb914-6bed-45de-8f6b-1a22f9eb6770"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "\[Nu]"}], TraditionalForm]],
  ExpressionUUID->"219e1422-2bca-4294-ac1c-bc8b5f9e376a"],
 ". Then, the QGT is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}], "-", 
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"], 
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "4870cfe5-18b3-4698-9063-ed59931107c4"],
 ".\[LineSeparator]Since the generators are commuting with each other, the \
Fubini-Study tensor is identical to the QGT in this case."
}], "Notes",
 CellID->1393278909,ExpressionUUID->"6276fba1-fca3-4792-973e-b05c7bff7a33"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["11", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["12", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["21", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["22", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["l", "TI"]]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "11fe1ea0-925a-4a46-ac0a-e7e7494a3bf4"],
 " gives an block-diagonal approximation of the Fubini-Study tensor. It \
assumes the parametrized quantum state of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "b79c0734-ee93-4c18-b912-6af087b9fede"],
 ",\[LineSeparator]where the overall unitary gate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "L"], TraditionalForm]],ExpressionUUID->
  "606c54d0-2602-49ce-87b1-e94672727fec"],
 " is composed of ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "3052b39a-b876-4b36-825e-6d20f93acd67"],
 " layers in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"k", "=", "1"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "a8ce42fb-6d97-45b1-8af3-8c58d9ccf952"],
 " .\[LineSeparator]Each layer has two parts (or sub-layers), the \
parametrization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "35f84f12-5f0f-4e9e-93f3-e022a7337ac5"],
 " with parameters\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "k"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "1"}]], ",", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]"}], ")"}], 
     "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", 
      SubscriptBox["g", "k"]]}]}], TraditionalForm]],ExpressionUUID->
  "14a12af4-a262-4e02-b28e-aadc321ffb2a"],
 "\nand the non-parametrization part ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["W", "k"], TraditionalForm]],ExpressionUUID->
  "0f5523db-60fd-49e7-999b-4b2b004f439a"],
 " containing parameters.\[LineSeparator]Naturally, the overall parameters ",
 Cell[BoxData[
  FormBox["\[Theta]", TraditionalForm]],ExpressionUUID->
  "99e0daa0-328e-413b-b003-42aabbb82d8c"],
 " consist of\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Theta]", "1"], "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "2"], "\[CirclePlus]", "\[CenterEllipsis]", "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "L"]}], "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"9f5be660-ebaf-454c-9bd2-b76671ff1884"],
 "\[LineSeparator] with  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Congruent]", 
    RowBox[{"L", "\[VeryThinSpace]", "g"}]}], TraditionalForm]],
  ExpressionUUID->"0abd6553-1138-448c-82a4-77d1df4f27ed"],
 ". The parameterization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "f8d24d46-c495-4e37-a93d-d210d0d8393f"],
 " of each layer is characterized by a set of mutually commuting Hermitian \
generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["H", 
        RowBox[{"k", ",", "\[Mu]"}]], ":", "\[Mu]"}], "=", "1"}], ",", "2", ",",
      "\[Ellipsis]", ",", "g"}], "}"}], TraditionalForm]],ExpressionUUID->
  "1dba2c04-869b-4bdc-ae53-3cfae14be519"],
 " such that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", ",", "\[Mu]"}]]}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", 
      RowBox[{"k", ",", "\[Mu]"}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"3151fd15-0787-4102-9058-e7fdbbcb028f"],
 " .\[LineSeparator]The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "d88de5a5-2a6b-43d0-abc6-8999446825af"],
 " block of the approximate Fubini-Study tensor is calculated at state vector\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox["\[Psi]", "k"], "(", 
        SubscriptBox["\[Theta]", "k"], ")"}]},
     "Ket"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"l", "=", "k"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"], 
      TemplateBox[{
        SubscriptBox["\[Psi]", "0"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c9e42700-60c1-4291-ab19-65c6d7b0d643"],
 " .\[LineSeparator]The overall block-diagonal tensor is an approximation of \
the Fubini-Study tensor at the final state vector ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["v", "TI"], 
   StyleBox["l", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "14fe457c-fa74-4303-b5ca-b2e5a1b550b5"],
 "."
}], "Notes",
 CellID->2055687195,ExpressionUUID->"5356f119-6ef7-4b00-9904-10b8e353c64a"],

Cell[TextData[{
 "Each state vector is supposed to be normalized, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e5611dd7-fe07-432a-b49a-8c34a5c9214f"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->362091143,ExpressionUUID->"9f4b8a2f-3222-4781-b11e-f6f615412bc8"],

Cell[TextData[{
 "Each generator is supposed to be a Hermitian matrix, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f55e5adb-cdf3-4377-a634-3dc6f3d03eb6"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->18454412,ExpressionUUID->"b1639743-6de0-442a-b375-e86044229dc0"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

