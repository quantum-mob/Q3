Cell["\<\
Suppose that the quantum state is prepared by the following parametric \
quantum circuit consisting of two  layers of the same structure:\
\>", "ExampleText",
 CellID->625948321,ExpressionUUID->"85c08c61-0765-4598-bdc8-95a294adc811"],

Cell[BoxData[
 RowBox[{
  RowBox[{"cz", "=", 
   RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"CZ", "@@@", 
      RowBox[{"Partition", "[", 
       RowBox[{"SS", ",", "2"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"CZ", "@@@", 
      RowBox[{"Partition", "[", 
       RowBox[{
        RowBox[{"Rest", "@", "SS"}], ",", "2"}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1938528041,ExpressionUUID->"66da05ea-84ed-46d4-98e2-cba13affabd9"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "layer", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"init", "=", 
   RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Ket", "[", "SS", "]"}], ",", 
     RowBox[{"S", "[", 
      RowBox[{"kk", ",", "6"}], "]"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"layer", "[", "l_Integer", "]"}], ":=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"cz", ",", "\[IndentingNewLine]", 
    RowBox[{"Rotation", "[", 
     RowBox[{
      RowBox[{"x", "[", 
       RowBox[{"l", ",", "kk"}], "]"}], ",", 
      RowBox[{"S", "[", 
       RowBox[{"kk", ",", "2"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"pqc", "=", 
  RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
   RowBox[{"init", ",", "\"\<Separator\>\"", ",", "\[IndentingNewLine]", 
    RowBox[{"layer", "[", "1", "]"}], ",", "\"\<Separator\>\"", ",", 
    "\[IndentingNewLine]", 
    RowBox[{"layer", "[", "2", "]"}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
