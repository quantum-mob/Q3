     FrontEnd`SelectionMove[
      FrontEnd`SelectedNotebook[], All, ButtonCell], 
     FrontEndToken["OpenCloseGroup"], 
     FrontEnd`SelectionMove[
      FrontEnd`SelectedNotebook[], After, CellContents]}]& ),
  Evaluator->None,
  Method->
   "Preemptive"]],ExpressionUUID->"177169ba-33a0-4a35-9d02-baca732a81b0"]], \
"NotesSection",
 ShowGroupOpener->"Thumbnail",
 WholeCellGroupOpener->True,
 CellGroupingRules->{"SectionGrouping", 50},
 CacheGraphics->False,
 CellID->2009166220,ExpressionUUID->"6b689db8-fb73-4c7e-a521-e344db7596bd"],

Cell["\<\
The quantum geometric tensor (QGT) is a complex-valued tensor that \
characterizes the local geometry of quantum states in parameter space. It \
encodes both the distance and phase structure of quantum states, providing a \
unified framework for understanding quantum geometry and topology.\
\>", "Notes",
 CellID->1984473323,ExpressionUUID->"4c6b447b-bf59-481c-975f-8c7a42cfb46a"],

Cell[TextData[{
 "The QGT is defined as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["\[PartialD]", "\[Mu]"], "\[Psi]"}]},
       "Bra"], "(", 
      RowBox[{"I", "-", 
       RowBox[{
        TemplateBox[{"\[Psi]"},
         "Ket"], 
        TemplateBox[{"\[Psi]"},
         "Bra"]}]}], ")"}], 
     TemplateBox[{
       RowBox[{
         SubscriptBox["\[PartialD]", "\[Nu]"], "\[Psi]"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "5b1b4bcc-d281-463e-8e7e-eb6df68591e1"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "de9f549a-75dd-45e9-ac51-961959378219"],
 " is the quantum state and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "82b996d7-45c6-49c6-8afe-a2710c1c59a1"],
 " denotes the derivative with respect to parameter ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "646020e7-42a8-40bc-968b-e191896d9f18"],
 ". Note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "-", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], 
     TemplateBox[{"\[Psi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "5c3b5f6c-a0fb-4be2-b719-480b63f27d4d"],
 " projects onto the subspace orthogonal to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "777c4936-7e1c-4f6e-8abd-875035a27a02"],
 "."
}], "Notes",
 CellID->677884236,ExpressionUUID->"0d904540-afb6-4452-90dd-d6f2aed94259"],

Cell[TextData[{
 "The real part, i.e., the symmetric part, of the QGP, is called the ",
 StyleBox["Fubini-Study metric",
  FontSlant->"Italic"],
 " and measures the distance between nearby quantum states (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Stokes et al., 2020"]], 
    "https://doi.org/10.22331/q-2020-05-25-269"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "789d9271-750e-403e-8077-37ca4dbbaae0"],
 ")."
}], "Notes",
 CellID->1501045863,ExpressionUUID->"0a8f35a5-fa1f-4c64-9d58-f6a8c8e9f487"],

Cell[TextData[{
 "The imaginary part, i.e., the anti-symmetric part, of the QGT, corresponds \
to the ",
 StyleBox["Berry curvature",
  FontSlant->"Italic"],
 " and encodes topological properties such as geometric phases and Chern \
numbers."
}], "Notes",
 CellID->1170758950,ExpressionUUID->"8bf12703-8d16-4dd2-84f8-40d9ec369488"],

Cell[TextData[{
 "The QGT provides complete information about the geometry of quantum states: \
The ",
 StyleBox["Fubini-Study metric",
  FontSlant->"Italic"],
 " quantifies how \[OpenCurlyDoubleQuote]far apart\[CloseCurlyDoubleQuote] \
quantum states are in parameter space whereas the ",
 StyleBox["Berry curvature",
  FontSlant->"Italic"],
 " reveals the topological nature of quantum systems, influencing transport \
properties and phase transitions."
}], "Notes",
 CellID->1347478979,ExpressionUUID->"ea5440ea-e500-4008-b5b3-7b608a8b6fb2"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["g", "TI"]]}], "}"}], ",", 
    StyleBox["vec", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "02947f60-7572-4346-8d31-98112434ef3d"],
 " calculates the Fubini-Study metric tensor under a special condition as \
follows (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Stokes et al., 2020"]], 
    "https://doi.org/10.22331/q-2020-05-25-269"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "33e46b62-6747-4a69-a7a9-a5e940db0f6a"],
 "): Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"V", "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "160c3f07-ddd5-4297-a9d2-8a97033b8b3f"],
 ". There exists a Hermitian generator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "8898f70b-1200-4380-badf-ec1549d2f1de"],
 " such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], "V"}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", "\[Mu]"], "V"}]}], TraditionalForm]],ExpressionUUID->
  "b6b3e7ca-717e-4fb8-922d-c65ae2c1af7b"],
 " .\[LineSeparator]The crucial assumption is that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], 
     SubscriptBox["H", "\[Nu]"]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"b427a8e9-a613-4399-af7f-991b454c3fb0"],
 ". This in turn implies that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], ",", 
      SubscriptBox["H", "\[Nu]"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"f38995ca-d788-4b0b-9502-a3b08f22fa58"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "\[Nu]"}], TraditionalForm]],
  ExpressionUUID->"b51a1302-86c0-4fd7-ada0-a2fbe7eaaaed"],
 ". Then, the QGT is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}], "-", 
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"], 
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "e2a340c7-33f6-46ff-971d-2b76f505ba3e"],
 ".\[LineSeparator]Since the generators are commuting with each other, the \
Fubini-Study tensor is identical to the QGT in this case."
}], "Notes",
 CellID->1393278909,ExpressionUUID->"9eb0b815-65c3-4a00-8f03-a200f4f20903"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["11", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["12", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["21", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["22", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["l", "TI"]]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d9acf2b0-0408-46ac-90b2-813c6804f71f"],
 " gives an block-diagonal approximation of the Fubini-Study tensor. It \
assumes the parametrized quantum state of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "a7dc1acb-2cd5-40a0-9e83-7d1e0c473428"],
 ",\[LineSeparator]where the overall unitary gate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "L"], TraditionalForm]],ExpressionUUID->
  "da302ce1-b322-4044-b512-25b081e044d8"],
 " is composed of ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "9c1ca7ad-09a6-46fc-bcf9-011a9dff4adc"],
 " layers in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"k", "=", "1"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "af5993ba-bc30-4ead-8e4e-d43ebcff6801"],
 " .\[LineSeparator]Each layer has two parts (or sub-layers), the \
parametrization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "68653c17-bb3e-4638-9b2f-9a439028e1c2"],
 " with parameters\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "k"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "1"}]], ",", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]"}], ")"}], 
     "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", 
      SubscriptBox["g", "k"]]}]}], TraditionalForm]],ExpressionUUID->
  "463ac81b-78de-4686-b94b-a5d104a573cd"],
 "\nand the non-parametrization part ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["W", "k"], TraditionalForm]],ExpressionUUID->
  "3230e38f-c001-4b07-9747-8d6dd32d11bc"],
 " containing parameters.\[LineSeparator]Naturally, the overall parameters ",
 Cell[BoxData[
  FormBox["\[Theta]", TraditionalForm]],ExpressionUUID->
  "6e46ed64-a467-4504-8e01-294dd6aff4e7"],
 " consist of\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Theta]", "1"], "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "2"], "\[CirclePlus]", "\[CenterEllipsis]", "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "L"]}], "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"2e4f98fa-9c74-4059-b4e9-c3e9978bd83c"],
 "\[LineSeparator] with  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Congruent]", 
    RowBox[{"L", "\[VeryThinSpace]", "g"}]}], TraditionalForm]],
  ExpressionUUID->"450afa8c-d3f1-4f73-92b3-f43a830d1b9c"],
 ". The parameterization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "c9f80d13-29c7-428a-ba2a-e75175a9eb7e"],
 " of each layer is characterized by a set of Hermitian generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["H", 
        RowBox[{"k", ",", "\[Mu]"}]], ":", "\[Mu]"}], "=", "1"}], ",", "2", ",",
      "\[Ellipsis]", ",", "g"}], "}"}], TraditionalForm]],ExpressionUUID->
  "1079a1f0-76d5-4aaa-82f6-a79db764f0ba"],
 " such that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", ",", "\[Mu]"}]]}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", 
      RowBox[{"k", ",", "\[Mu]"}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"3a5cccff-1184-40ae-beea-9eaded182b80"],
 " .\[LineSeparator]The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "26b5e9fc-d606-4479-95bb-2f5ff258ec7f"],
 " bock of the approximate Fubini-Study tensor is calculated at state vector\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox["\[Psi]", "k"], "(", 
        SubscriptBox["\[Theta]", "k"], ")"}]},
     "Ket"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"l", "=", "k"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"], 
      TemplateBox[{
        SubscriptBox["\[Psi]", "0"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "9c6a66f1-6a03-4e38-9039-5eda8a901b32"],
 " .\[LineSeparator]The overall block-diagonal tensor is regarded as an \
approximation at the final state vector ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["v", "TI"], 
   StyleBox["l", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "58177cff-8cec-47c9-8877-53017a75f921"],
 "."
}], "Notes",
 CellID->2055687195,ExpressionUUID->"ccf8f881-ac2a-4153-ac60-a5e438bb693f"],

Cell[TextData[{
 "Each state vector is supposed to be normalized, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "58a015cb-8756-4a5c-956b-c07d9483ca2c"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->362091143,ExpressionUUID->"2ec4500a-c4cf-471c-8e22-900b5b91a658"],

Cell[TextData[{
 "Each generator is supposed to be a Hermitian matrix, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "32b12415-d087-489c-b7c8-c6fcff3616f9"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->18454412,ExpressionUUID->"b5952e57-564a-4297-b592-065ae2215fff"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

