  ButtonFunction:>(FrontEndExecute[{
     FrontEnd`SelectionMove[
      FrontEnd`SelectedNotebook[], All, ButtonCell], 
     FrontEndToken["OpenCloseGroup"], 
     FrontEnd`SelectionMove[
      FrontEnd`SelectedNotebook[], After, CellContents]}]& ),
  Evaluator->None,
  Method->
   "Preemptive"]],ExpressionUUID->"7d446484-8f60-4679-bc06-9ec5886106c0"]], \
"NotesSection",
 ShowGroupOpener->"Thumbnail",
 WholeCellGroupOpener->True,
 CellGroupingRules->{"SectionGrouping", 50},
 CacheGraphics->False,
 CellID->761596919,ExpressionUUID->"87f8a0bb-fcf3-4d07-8975-474b886da3a1"],

Cell["\<\
The quantum geometric tensor (QGT) is a complex-valued tensor that \
characterizes the local geometry of quantum states in parameter space. It \
encodes both the distance and phase structure of quantum states, providing a \
unified framework for understanding quantum geometry and topology.\
\>", "Notes",
 CellID->1984473323,ExpressionUUID->"01fcec05-ef0d-40eb-b00a-4ed8aaad1450"],

Cell[TextData[{
 "The QGT is defined as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["\[PartialD]", "\[Mu]"], "\[Psi]"}]},
       "Bra"], "(", 
      RowBox[{"I", "-", 
       RowBox[{
        TemplateBox[{"\[Psi]"},
         "Ket"], 
        TemplateBox[{"\[Psi]"},
         "Bra"]}]}], ")"}], 
     TemplateBox[{
       RowBox[{
         SubscriptBox["\[PartialD]", "\[Nu]"], "\[Psi]"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "7e0f9370-a31b-4b87-af89-f266c4cbc733"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "1b306175-d0e1-42a2-bd86-5298f1fdcfab"],
 " is the quantum state and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[PartialD]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "a68417ac-0928-4809-8f59-f7bb97c2d9bc"],
 " denotes the derivative with respect to parameter ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Theta]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "0d9de527-ca64-4ebc-9d38-21776c5a953e"],
 ". Note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "-", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], 
     TemplateBox[{"\[Psi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "ddc9e0e7-ff57-4d5b-b89c-835bfd5a253e"],
 " projects onto the subspace orthogonal to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3df6528e-ffa9-4ab8-850f-92e1a38842e2"],
 "."
}], "Notes",
 CellID->677884236,ExpressionUUID->"4ffc0ba1-1344-4101-9ba9-6eafbc7d8491"],

Cell[TextData[{
 "The real part, i.e., the symmetric part, of the QGP, is called the ",
 StyleBox["Fubini-Study metric",
  FontSlant->"Italic"],
 " and measures the distance between nearby quantum states (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Stokes et al., 2020"]], 
    "https://doi.org/10.22331/q-2020-05-25-269"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "e02fb631-3d0d-4bf1-b785-029c294e3094"],
 ")."
}], "Notes",
 CellID->1501045863,ExpressionUUID->"89e71522-86ee-4a5e-bbc1-e393de841124"],

Cell[TextData[{
 "The imaginary part, i.e., the anti-symmetric part, of the QGT, corresponds \
to the ",
 StyleBox["Berry curvature",
  FontSlant->"Italic"],
 " and encodes topological properties such as geometric phases and Chern \
numbers."
}], "Notes",
 CellID->1170758950,ExpressionUUID->"d5d901f4-631e-4a23-96a0-982315254f03"],

Cell[TextData[{
 "The QGT provides complete information about the geometry of quantum states: \
The ",
 StyleBox["Fubini-Study metric",
  FontSlant->"Italic"],
 " quantifies how \[OpenCurlyDoubleQuote]far apart\[CloseCurlyDoubleQuote] \
quantum states are in parameter space whereas the ",
 StyleBox["Berry curvature",
  FontSlant->"Italic"],
 " reveals the topological nature of quantum systems, influencing transport \
properties and phase transitions."
}], "Notes",
 CellID->1347478979,ExpressionUUID->"6cfd9a3c-97c5-491d-86d6-e2705520674e"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["m", "TI"], 
       StyleBox["g", "TI"]]}], "}"}], ",", 
    StyleBox["vec", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d77680f0-7b0b-4621-9850-89445d637d62"],
 " calculates the Fubini-Study metric tensor under a special condition as \
follows (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Stokes et al., 2020"]], 
    "https://doi.org/10.22331/q-2020-05-25-269"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "9cdc671c-1c02-4b7a-a91f-8647ae7ab822"],
 "): Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"V", "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "9e7c0ab9-f640-41b7-aa30-9f0fe10f7b6f"],
 ". There exists a Hermitian generator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "ec3d567c-4749-4808-84e1-13895f5bba0e"],
 " such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], "V"}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", "\[Mu]"], "V"}]}], TraditionalForm]],ExpressionUUID->
  "612755be-5b4e-4f31-b160-02a6a7c1c3ed"],
 " .\[LineSeparator]The crucial assumption is that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "\[Mu]"], 
     SubscriptBox["H", "\[Nu]"]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"c6574573-7c4c-4dab-a7ca-f6f09178f3e4"],
 ". This in turn implies that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["H", "\[Mu]"], ",", 
      SubscriptBox["H", "\[Nu]"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"008ebcb3-5c8a-407d-9607-db42f6496812"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "\[Nu]"}], TraditionalForm]],
  ExpressionUUID->"2a34d3d9-d401-47bc-a10b-cd3b9a2cef80"],
 ". Then, the QGT is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "\[Mu]\[Nu]"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}], "-", 
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Mu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"], 
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubscriptBox["H", "\[Nu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "839b1d1a-e087-403b-a885-2b8b3f2a4233"],
 ".\[LineSeparator]Since the generators are commuting with each other, the \
Fubini-Study tensor is identical to the QGT in this case."
}], "Notes",
 CellID->1393278909,ExpressionUUID->"a6fb14f4-0641-4759-8262-6854e29ae842"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["QuantumGeometricTensor"]], 
     "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["11", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["12", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["21", "TR"]], ",", 
        SubscriptBox[
         StyleBox["h", "TI"], 
         StyleBox["22", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["v", "TI"], 
       StyleBox["l", "TI"]]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fa2989bc-8704-4076-97ac-f27376698fbe"],
 " gives an block-diagonal approximation of the Fubini-Study tensor. It \
assumes the parametrized quantum state of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "(", "\[Theta]", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "f39c7bd6-c476-408e-bb4f-112d63d570e7"],
 ",\[LineSeparator]where the overall unitary gate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "L"], TraditionalForm]],ExpressionUUID->
  "e452e0ce-f276-4347-9dc8-605593758067"],
 " is composed of ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "9b4a4ca2-3d04-4168-868e-85fba8f66023"],
 " layers in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "L"], "(", "\[Theta]", ")"}], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"k", "=", "1"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "fe16790d-7c1a-48c3-a6e6-6d999d44a0e9"],
 " .\[LineSeparator]Each layer has two parts (or sub-layers), the \
parametrization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "8d5c3ee3-86a9-47a6-9ba4-19930a0724ba"],
 " with parameters\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "k"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "1"}]], ",", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]"}], ")"}], 
     "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", 
      SubscriptBox["g", "k"]]}]}], TraditionalForm]],ExpressionUUID->
  "63bf3160-8462-4c40-a965-ad5037a5e481"],
 "\nand the non-parametrization part ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["W", "k"], TraditionalForm]],ExpressionUUID->
  "631f4070-f800-4a60-8e24-f1a90b64258b"],
 " containing parameters.\[LineSeparator]Naturally, the overall parameters ",
 Cell[BoxData[
  FormBox["\[Theta]", TraditionalForm]],ExpressionUUID->
  "683b23a8-e4d9-4a6a-a6d7-f4bcf2bf1b9b"],
 " consist of\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Theta]", "1"], "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "2"], "\[CirclePlus]", "\[CenterEllipsis]", "\[CirclePlus]", 
      SubscriptBox["\[Theta]", "L"]}], "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", "d"]}]}], TraditionalForm]],
  ExpressionUUID->"d159fb94-8436-4b84-998c-1c3374cc1404"],
 "\[LineSeparator] with  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[Congruent]", 
    RowBox[{"L", "\[VeryThinSpace]", "g"}]}], TraditionalForm]],
  ExpressionUUID->"8c10cc84-a677-4526-a10c-6ca3e2bafee6"],
 ". The parameterization part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "k"], "(", 
    SubscriptBox["\[Theta]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "8e91b274-4c2e-4551-abc7-3c54876daf34"],
 " of each layer is characterized by a set of mutually commuting Hermitian \
generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["H", 
        RowBox[{"k", ",", "\[Mu]"}]], ":", "\[Mu]"}], "=", "1"}], ",", "2", ",",
      "\[Ellipsis]", ",", "g"}], "}"}], TraditionalForm]],ExpressionUUID->
  "7644973e-aaed-4170-8b12-0cbc2be8cf8a"],
 " such that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["\[PartialD]", 
      RowBox[{"\[PartialD]", 
       SubscriptBox["\[Theta]", 
        RowBox[{"k", ",", "\[Mu]"}]]}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", 
     SubscriptBox["H", 
      RowBox[{"k", ",", "\[Mu]"}]], 
     RowBox[{
      SubscriptBox["V", "k"], "(", 
      SubscriptBox["\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"1b6297af-02a6-497c-a6b8-15490186042c"],
 " .\[LineSeparator]The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "676f65d6-7d5f-432b-9bf2-b08eef3db281"],
 " block of the approximate Fubini-Study tensor is calculated at state vector\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox["\[Psi]", "k"], "(", 
        SubscriptBox["\[Theta]", "k"], ")"}]},
     "Ket"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{"l", "=", "k"}], "L"], 
     RowBox[{
      RowBox[{
       SubscriptBox["V", "k"], "(", 
       SubscriptBox["\[Theta]", "k"], ")"}], 
      SubscriptBox["W", "k"], 
      TemplateBox[{
        SubscriptBox["\[Psi]", "0"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "506f9128-7e3d-47a4-a60b-8ac2cfabd06e"],
 " .\[LineSeparator]The overall block-diagonal tensor is an approximation of \
the Fubini-Study tensor at the final state vector ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["v", "TI"], 
   StyleBox["l", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c3bae790-83f7-41aa-9ed8-71c3c612ed01"],
 "."
}], "Notes",
 CellID->2055687195,ExpressionUUID->"bd1de349-9286-4cee-a55d-094edb951590"],

Cell[TextData[{
 "Each state vector is supposed to be normalized, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9d12a611-fc3f-4443-9c43-40748e74208f"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->362091143,ExpressionUUID->"bfc5e1cf-6369-437b-be91-8c2ed86ceef3"],

Cell[TextData[{
 "Each generator is supposed to be a Hermitian matrix, which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumGeometricTensor"]], 
    "paclet:QuantumMob/Q3/ref/QuantumGeometricTensor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ad15a856-2ac4-4635-aaf3-8a98e6960038"],
 " does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " check."
}], "Notes",
 CellID->18454412,ExpressionUUID->"0028d681-4659-49e6-989e-a9d2c6540304"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

