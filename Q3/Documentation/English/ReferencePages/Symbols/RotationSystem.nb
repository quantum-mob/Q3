Cell["\<\
This demonstrates the relation between the Euler rotation and the rotation \
around an axis.\
\>", "ExampleText",
 CellID->1464318430,ExpressionUUID->"3c8cc64e-a873-4d77-9611-2619228ff839"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{"TheEulerRotation", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Pi", "/", "3"}], ",", 
      RowBox[{"Pi", "/", "2"}], ",", 
      RowBox[{"Pi", "/", "6"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"mat", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RotationSystem", "[", "mat", "]"}], "//", "Simplify"}]}], "Input",
