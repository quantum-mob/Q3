Cell[TextData[{
 "For rotations in the three-dimensional space ",
 Cell[BoxData[
  SuperscriptBox["\[DoubleStruckCapitalR]", "3"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "70f2f9a8-8638-43de-abc8-883bef32c046"],
 " of real vectors, ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "84e61bbc-85d1-4424-ae1a-c8d78a3a06bd"],
 " is a 3\[Times]3 orthogonal matrix. In this case, the returned angle is in \
the range from -\[Pi] to \[Pi]."
}], "Notes",
 CellID->1602753117,ExpressionUUID->"e1003c8e-4fa4-4e71-aa7d-3647d73ab37a"],

Cell[TextData[{
 "For rotations in the Bloch space, ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d729ad4e-93a3-4bf7-816e-59e89905d58b"],
 " is a 2\[Times]2 unitary matrix. In this case, the returned angle is in the \
range from -2\[Pi] to 2\[Pi]."
}], "Notes",
 CellID->125053450,ExpressionUUID->"37c99ef7-e99d-44bc-aaff-cf228048ef7b"],

