Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "bf8e10ba-b87b-46b1-a5d7-d20b2164c159"],
 " be bosonic modes. They may be expressed in terms of Heisenberg modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "k"], TraditionalForm]],ExpressionUUID->
  "42cbc5f4-c22f-4139-a478-6bfb20c6ad5d"],
 " and its canonical conjugate ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["x", "k", "c"], TraditionalForm]],ExpressionUUID->
  "47c64982-d154-47e4-be73-8d3eb2a2a464"],
 " as:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "k"], "+", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubsuperscriptBox["x", "k", "c"]}]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "a89c9ba7-3340-4b8e-b641-173bec085b11"],
 " ,\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "k", "\[Dagger]"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "k"], "-", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubsuperscriptBox["x", "k", "c"]}]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "350c52d4-cd51-44ac-99d1-d2e273e57099"],
 " ."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"0fb9a22e-1430-43f5-8f47-642d64e43d09"],

Cell[TextData[{
 "The bosonic modes satisfies the commutation relations\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["a", "i"], ",", 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "]"}], "=", 
    SubscriptBox["\[Delta]", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], TraditionalForm]],
  ExpressionUUID->"2cf6beb8-5b86-4eb5-bdd3-3513a851379f"],
 " ,        ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["a", "i"], ",", 
      SubscriptBox["a", "j"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"5e35102a-9329-433c-9863-13c91d712876"],
 ",        ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubsuperscriptBox["a", "i", "\[Dagger]"], ",", 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "]"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"37ef022f-3f07-488b-8fa3-f25b1ee5db27"],
 "."
}], "Notes",
 CellID->991385285,ExpressionUUID->"d826d7cb-139a-4291-bfb6-3243fa7e39cf"],

Cell[TextData[{
 "On the other hand, the Heisenberg modes and their canonical conjugates \
satisfy the commutation relations\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["x", "i"], ",", 
      SubsuperscriptBox["x", "j", "c"]}], "]"}], "=", 
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"01a20c56-18f3-4015-ad62-812000f6ea54"],
 " ,        ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["x", "i"], ",", 
      SubscriptBox["x", "j"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"acafe5cd-ba3f-46dc-8aeb-26a9f2caf618"],
 " ,        ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubsuperscriptBox["x", "i", "c"], ",", 
      SubsuperscriptBox["x", "j", "c"]}], "]"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"366cef03-f8ad-47d1-bf16-4380e7d27c73"],
 " ."
}], "Notes",
 CellID->1623682607,ExpressionUUID->"dd9e368c-96ab-4c9f-82ca-56f8eda849ef"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

