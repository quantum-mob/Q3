       StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], ",", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["a", "TI"], 
        StyleBox["2", "TR"]], ",", 
