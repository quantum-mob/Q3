  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2bddc3b9-7072-421c-b8dc-cb919324e44b"],
 " (mapping between ",
 StyleBox["sets",
  FontSlant->"Italic"],
 " of qubits):  ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["TransformBy"]], "paclet:QuantumMob/Q3/ref/TransformBy", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["\[Ellipsis]", "TR"], ",", 
    RowBox[{
     SubscriptBox[
      StyleBox["a", "TI"], 
      StyleBox["k", "TI"]], "\[Rule]", 
     SubscriptBox[
      StyleBox["b", "TI"], 
      StyleBox["k", "TI"]]}], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    StyleBox["m", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ff7cd73c-666c-4394-bab7-20cecab37109"],
 " gives a list of rules ",
