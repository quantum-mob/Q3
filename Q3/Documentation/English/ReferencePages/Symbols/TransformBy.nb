   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalSigma]", "TR"], 
     StyleBox["uv", "TI"]], " ", 
    SubsuperscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["su", "TI"], "\[Dagger]"], " ", 
