       StyleBox["u", "TI"], "\[Rule]", 
       StyleBox["v", "TI"]}]}], "]"}], 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["vt", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f23dc3c2-1761-4e98-9e7a-786b11a06289"],
