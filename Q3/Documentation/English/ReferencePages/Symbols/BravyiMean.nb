Cell["Do the Monte Carlo simulation.", "ExampleText",
 CellID->2115427440,ExpressionUUID->"b53061a2-dfb2-4525-b551-d3b326711ffd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"BravyiSimulate", "[", 
     RowBox[{"ham", ",", "jmp", ",", "in", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"nT", "=", "200"}], ",", 
        RowBox[{"dt", "=", "0.01"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<Samples\>\"", "->", "100"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "data", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1759710031,ExpressionUUID->"9d38675c-09bb-432c-9667-5089194d1f33"],

Cell[BoxData["77.01026`"], "EchoTiming",
 CellID->496053359,ExpressionUUID->"da1bf4e3-1377-41c6-9855-7655a88029f3"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"100", ",", "201"}], "}"}]], "Output",
 CellLabel->"Out[6]=",
 CellID->637287059,ExpressionUUID->"21017536-f347-4660-99f5-26883885aafd"]
}, Open  ]],

Cell["\<\
Calculate the average of covariance matrices associated with states at the \
same time instants in different trajectories.\
\>", "ExampleText",
 CellID->565637460,ExpressionUUID->"235f2c25-9231-4bd3-b999-db8cfcbd7bb6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"avg", "=", 
    RowBox[{"BravyiMean", "[", "data", "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->2077710701,ExpressionUUID->"044f11e9-729c-4a65-8390-67cddc39893b"],

Cell[BoxData["0.309606`"], "EchoTiming",
 CellID->328830181,ExpressionUUID->"a51e8fe4-238f-4367-bd03-5235521bc3d4"]
}, Open  ]],

Cell["Choose a subsystem.", "ExampleText",
 CellID->1432281069,ExpressionUUID->"9622596e-8e1b-4044-8bf9-ad04ecb33bed"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"kk", "=", 
  RowBox[{"Range", "[", 
   RowBox[{"$n", "/", "2"}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
