Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]], "Output",
 CellLabel->"Out[8]=",
 CellID->1173428336,ExpressionUUID->"31edcd53-f295-414a-880a-55573a0ea0e7"]
}, Open  ]],

Cell[TextData[{
 "Calculate the ",
 ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity"],
 " (LN) of the mixed states along the average trajectory."
}], "ExampleText",
 CellID->355339612,ExpressionUUID->"e0da6faf-f4f9-44ac-993d-4fff34a9822b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"BravyiLogarithmicNegativity", "[", 
     RowBox[{"avg", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[9]:=",
 CellID->1466953377,ExpressionUUID->"b83cc4a7-be3b-41c4-9541-df62b6ed0734"],

Cell[BoxData["0.31168`"], "EchoTiming",
 CellID->1851036615,ExpressionUUID->"c542dafb-7a87-4e25-9629-58fddda85f75"]
}, Open  ]],

Cell["Plot the logarithmic negativity as a function of time.", "ExampleText",
 CellID->154672796,ExpressionUUID->"592d8c01-2352-47ec-bfb6-607b01549849"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", "neg"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", 
      RowBox[{"$T", "*", "dt"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma] \!\(\*StyleBox[\"t\",FontSlant->\"Italic\"]\)\>\"",
       ",", "\"\<LN (\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\), \
\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\)/2)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
