Cell[TextData[{
 "Sometimes, simply avoiding to type full information in or as an \
intermediate result, one may have the following expression. Note that ",
 ButtonBox["Q3: Symbolic Quantum Simulation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/Q3"],
 " assumes default values for any species in ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:ref/Ket"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"<|", "\[Ellipsis]", "|>"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c333440d-f9dd-451d-8522-616113956fe3"],
 " when the values of the species are not specified explicitly."
}], "ExampleText",
 CellID->1843242963,ExpressionUUID->"f5b51566-745a-4af3-a992-6527fce05979"],

