Cell[TextData[{
 "The (normal) Green\[CloseCurlyQuote]s function of fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "a73b81dc-6050-423d-81a8-a27d3f9eb2c4"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"5239daca-5fab-4407-b791-da2001493903"],
 ". The matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "f922fa76-708e-4284-b8c8-b8724d8a0ae7"],
 " is Hermitian, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", "\[Dagger]"], "=", "G"}], TraditionalForm]],
  ExpressionUUID->"ca50cbec-c3c8-46d2-a326-bed34b187369"],
 ". The ",
 StyleBox["correlation matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubsuperscriptBox["a", "i", "\[Dagger]"], 
       SubscriptBox["a", "j"]}], "\[RightAngleBracket]"}], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"I", "-", 
        SuperscriptBox["G", "T"]}], ")"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"b43bef61-4299-4d8c-88a1-30f1e00b948b"],
 " has equivalent information and is also frequently used. Obviously, the \
matrix ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "91d62636-37f8-480c-b633-3da7a9fd55a6"],
 " is Hermitian as well, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["C", "\[Dagger]"], "=", "C"}], TraditionalForm]],
  ExpressionUUID->"f331e270-e15e-492c-8d62-fa75af06fb5b"],
 "."
}], "Notes",
 CellID->348061621,ExpressionUUID->"bbd04c55-f38a-4e52-a187-7cf4e2a7f70b"],

Cell[TextData[{
 "The anomalous Green\[CloseCurlyQuote]s function of fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "eb276a2d-ebe1-4731-9f8f-113bb87b8daf"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubscriptBox["a", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"5a6aab62-da3b-4168-8f64-1e384d30aaa1"],
 ". The matrix ",
 Cell[BoxData[
  FormBox["F", TraditionalForm]],ExpressionUUID->
  "7093af8a-56d5-4fea-9f5c-cf00be7f7ed9"],
 " is skew-symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", "T"], "=", 
    RowBox[{"-", "F"}]}], TraditionalForm]],ExpressionUUID->
  "91fe3ea4-0f02-4710-84d2-a6905674590d"],
 "."
}], "Notes",
 CellID->1383491325,ExpressionUUID->"5e7f5655-1ead-4b8f-bcbc-301ad3e06a2b"],

Cell[TextData[{
 "In the ",
 StyleBox["Nambu space",
  FontSlant->"Italic"],
 ", the full single-particle Green\[CloseCurlyQuote]s function is represented \
by the ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4cc71d90-2a75-42f0-b483-083a597e15ee"],
 " matrix\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["G", "_"], ":=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       UnderscriptBox["a", "_"], 
       SuperscriptBox[
        UnderscriptBox["a", "_"], "\[Dagger]"]}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      RowBox[{"(", GridBox[{
         {"G", "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], 
          RowBox[{"I", "-", 
           SuperscriptBox["G", "T"]}]}
        }], ")"}], "=", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"I", "-", 
           SuperscriptBox["C", "T"]}], "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], "C"}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "bb8ffcd8-fcd1-4f5a-837e-0f722e33c049"],
 ",\[LineSeparator]where  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     UnderscriptBox["a", "_"], "\[Dagger]"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["a", "1", "\[Dagger]"], ",", "\[Ellipsis]", ",", 
      SubsuperscriptBox["a", "n", "\[Dagger]"], ",", 
      SubscriptBox["a", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["a", "n"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "eee8a713-3f59-4476-85d4-6e9264c8751f"],
 " is the Nambu spinor of the fermion modes."
}], "Notes",
 CellID->795234925,ExpressionUUID->"e8862d61-93c7-4e23-baad-3c0e96375240"],

Cell[TextData[{
 "Similarly, in the ",
 StyleBox["Nambu space",
  FontSlant->"Italic"],
 ", the full single-particle correlation matrix has the form\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["C", "_"], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", GridBox[{
         {"I", "0"},
         {"0", "0"}
        }], ")"}], "-", 
      UnderscriptBox["G", "_"]}], "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"(", GridBox[{
          {
           RowBox[{"G", "-", "I"}], "F"},
          {
           SuperscriptBox["F", "\[Dagger]"], 
           RowBox[{"I", "-", 
            SuperscriptBox["G", "T"]}]}
         }], ")"}]}], "=", 
      RowBox[{"-", 
       RowBox[{"(", GridBox[{
          {
           RowBox[{"-", 
            SuperscriptBox["C", "T"]}], "F"},
          {
           SuperscriptBox["F", "\[Dagger]"], "C"}
         }], ")"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "91aa72e2-387a-40e7-ba7a-b9ce075b3353"],
 " ."
}], "Notes",
 CellID->775823808,ExpressionUUID->"0dfe1ab4-3749-48f0-b067-ee854ea34dd6"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Normal"]], "paclet:ref/Normal"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["NambuGreen"]], "paclet:QuantumMob/Q3/ref/NambuGreen", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["G", "TI"], ",", 
      StyleBox["F", "TI"]}], "}"}], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "998c90ef-cb03-4f53-81a6-5cb008506c42"],
 " is returns the full ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "16e30849-a49c-42fe-a41a-b3899dba840d"],
 " Green's function matrix in the ",
 StyleBox["Nambu space",
  FontSlant->"Italic"],
 "; that is,\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"G", ",", "F"}], "}"}], "\[RightTeeArrow]", 
     UnderscriptBox["G", "_"]}], ":=", 
    RowBox[{"(", GridBox[{
       {"G", "F"},
       {
        SuperscriptBox["F", "\[Dagger]"], 
        RowBox[{"I", "-", 
         SuperscriptBox["G", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "cc79b650-739f-4253-b0cc-7b9a02517933"],
 "  assuming that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", "\[Dagger]"], "=", "G"}], TraditionalForm]],
  ExpressionUUID->"6c6fb53e-7dd7-476b-a19e-5ea34dbb28dd"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", "T"], "=", 
    RowBox[{"-", "F"}]}], TraditionalForm]],ExpressionUUID->
  "38fcbe4d-f381-4bab-9fea-45e04d65fd66"],
 "."
}], "Notes",
 CellID->292545916,ExpressionUUID->"8a650a7b-5b42-4d6a-b90b-95642514dfcc"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["NambuHermitian"]], "paclet:QuantumMob/Q3/ref/NambuHermitian", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["NambuGreen"]], "paclet:QuantumMob/Q3/ref/NambuGreen", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{"{", 
     RowBox[{
      StyleBox["G", "TI"], ",", 
      StyleBox["F", "TI"]}], "}"}], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9c1166e6-cafa-4c66-bc5a-db311a37bf8c"],
 " returns the reduced Nambu form ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["NambuHermitian"]], "paclet:QuantumMob/Q3/ref/NambuHermitian", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SuperscriptBox[
      StyleBox["C", "TI"], "T"], ",", 
     RowBox[{"-", 
      StyleBox["F", "TI"]}]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0f286ade-aa54-4316-ace2-fd3994759b62"],
 " corresponding to the full correlation matrix\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"G", ",", "F"}], "}"}], "\[RightTeeArrow]", 
     UnderscriptBox["C", "_"]}], "=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"G", "-", "I"}], "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], 
          RowBox[{"I", "-", 
           SuperscriptBox["G", "T"]}]}
        }], ")"}]}], "=", 
     RowBox[{"-", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"-", 
           SuperscriptBox["C", "T"]}], "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], "C"}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "7aeea676-241f-42f3-af15-4276bbc76b7f"],
 "."
}], "Notes",
 CellID->543905378,ExpressionUUID->"b61b09b5-9e3d-4520-b5c6-3686702b9dbb"],

