Cell["\<\
Simulate the Lindblad equation using the quantum jump approach.\
\>", "ExampleText",
 CellID->1958431180,ExpressionUUID->"0b39b0c3-69d1-497e-b931-7c0394188777"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[CapitalGamma]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalGamma]", "[", "\"\<+\>\"", "]"}], "=", ".3"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[CapitalGamma]", "[", "\"\<-\>\"", "]"}], "=", ".7"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"LindbladSimulate", "[", 
        RowBox[{
        "opH", ",", "opL", ",", "in", ",", "tt", ",", "\[IndentingNewLine]", 
         RowBox[{"\"\<Samples\>\"", "->", "100"}]}], "]"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->870984691,ExpressionUUID->"d41a31dd-0552-4c65-b9e1-d05f7e6e71a3"],

