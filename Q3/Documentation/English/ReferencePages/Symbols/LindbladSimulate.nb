      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c9c89e6f-2cb9-47ee-99de-e147ed68076a"],
     " and the Lindblad operators ",
     Cell[BoxData[
      RowBox[{
       SubscriptBox[
        StyleBox["a", "TI"], 
