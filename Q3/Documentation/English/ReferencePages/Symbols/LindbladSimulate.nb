  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f835d612-d316-43f7-a81e-b3eff5b27f46"],
 " and ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["a", "TI"], 
