 CellLabel->"In[3]:=",
 CellID->1891395320,ExpressionUUID->"d64c4fc4-b586-4a8a-b100-954565147a6a"],

Cell["\<\
Pick the time slices at every of which a state vector is sampled.\
\>", "ExampleText",
 CellID->3338789,ExpressionUUID->"84e57a06-9e38-481c-90c3-00a32b4e7ae6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", "10", ",", "0.05"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->442045801,ExpressionUUID->"7435bfc3-0ae4-4259-a22b-5f4f76c50f24"],

Cell["\<\
Simulate the Lindblad equation using the quantum jump approach. The progress \
indicator moves one step forward each time a trajectory is generated.\
\>", "ExampleText",
 CellID->1333360839,ExpressionUUID->"b99a3878-3323-4b41-a345-215dfbf8f1f6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[CapitalGamma]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalGamma]", "[", "\"\<+\>\"", "]"}], "=", ".3"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[CapitalGamma]", "[", "\"\<-\>\"", "]"}], "=", ".7"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"LindbladSimulate", "[", 
        RowBox[{"opH", ",", "opL", ",", "in", ",", "tt", ",", 
         RowBox[{"\"\<Samples\>\"", "->", "500"}]}], "]"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1301683069,ExpressionUUID->"614513ac-0bac-4093-a024-dedb0ff704c6"],

Cell[BoxData["0.559817`"], "EchoTiming",
 CellID->267346607,ExpressionUUID->"49ecf73e-5a1c-4eed-a44a-15acfc6ba516"]
}, Open  ]],

Cell[TextData[{
 "Construct the density matrix at each times. Note that ",
 StyleBox["data", "Input"],
 " from the above has the structure of form ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["data", "TI"], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["v", "TI"], 
         StyleBox["in", "TI"]], ",", 
        RowBox[{
         SubscriptBox[
          StyleBox["v", "TI"], 
          StyleBox["1", "TR"]], 
         RowBox[{"(", 
          SubscriptBox[
           StyleBox["t", "TI"], 
           StyleBox["1", "TR"]], ")"}]}], ",", 
        RowBox[{
         SubscriptBox[
          StyleBox["v", "TI"], 
          StyleBox["1", "TR"]], 
         RowBox[{"(", 
          SubscriptBox[
           StyleBox["t", "TI"], 
           StyleBox["2", "TR"]], ")"}]}], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["v", "TI"], 
         StyleBox["in", "TI"]], ",", 
        RowBox[{
         SubscriptBox[
          StyleBox["v", "TI"], 
          StyleBox["2", "TR"]], 
         RowBox[{"(", 
          SubscriptBox[
           StyleBox["t", "TI"], 
           StyleBox["1", "TR"]], ")"}]}], ",", 
        RowBox[{
         SubscriptBox[
          StyleBox["v", "TI"], 
          StyleBox["2", "TR"]], 
         RowBox[{"(", 
          SubscriptBox[
           StyleBox["t", "TI"], 
           StyleBox["2", "TR"]], ")"}]}], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "10b10e02-cdb7-480e-964f-a5a89bedbb3a"],
 "; see the ",
 ButtonBox["Details and Options",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/LindbladSimulate#1226658091"],
 " section section above."
}], "ExampleText",
 CellID->751405728,ExpressionUUID->"7ee1dcaa-055c-4b09-8502-20324d75b3de"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"EchoTiming", "[", 
  RowBox[{
   RowBox[{"tmp", "=", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Dyad", "[", 
        RowBox[{"#", ",", "#"}], "]"}], "&"}], ",", "data", ",", 
      RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"EchoTiming", "[", 
  RowBox[{
   RowBox[{"rho", "=", 
    RowBox[{"Mean", "/@", 
     RowBox[{"Transpose", "[", "tmp", "]"}]}]}], ";"}], "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1223714674,ExpressionUUID->"97e663b8-c3fa-4601-b03e-e8c4325b5721"],

