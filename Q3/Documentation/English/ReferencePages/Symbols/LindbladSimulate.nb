Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rho", "=", 
   RowBox[{"Mean", "/@", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Dyad", "[", 
        RowBox[{"#", ",", "#"}], "]"}], "&"}], ",", 
      RowBox[{"Transpose", "@", "data"}], ",", 
      RowBox[{"{", "2", "}"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "rho", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
