       SubscriptBox[
        StyleBox["a", "TI"], 
        StyleBox["2", "TR"]], ",", 
       StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "5ceea2f3-b4ee-41e2-be01-ae525d64268e"],
