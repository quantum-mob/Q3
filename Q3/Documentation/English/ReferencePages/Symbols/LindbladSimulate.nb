  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54d5373d-f13f-49fe-9abd-0386c95cf9f2"],
 " at time ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["t", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
