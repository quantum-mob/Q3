Cell["\<\
As an example, calculate the averages of the Pauli X, Y, and Z operators.\
\>", "ExampleText",
 CellID->682180063,ExpressionUUID->"c864cb81-ee46-47f9-a6b7-c67883e1fae8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"II", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", "#", "]"}], "&"}], ",", "rho"}], "]"}]}], 
     "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"XX", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ThePauli", "[", "1", "]"}], ".", "#"}], "]"}], "&"}], ",",
         "rho"}], "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"YY", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
