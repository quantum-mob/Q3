Cell["\<\
As an example, calculate the averages of the Pauli X, Y, and Z operators.\
\>", "ExampleText",
 CellID->1459452562,ExpressionUUID->"39a3923f-2074-4e67-a90a-663197c8fd63"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"II", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", "#", "]"}], "&"}], ",", "rho"}], "]"}]}], 
     "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"XX", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ThePauli", "[", "1", "]"}], ".", "#"}], "]"}], "&"}], ",",
         "rho"}], "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"YY", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ThePauli", "[", "2", "]"}], ".", "#"}], "]"}], "&"}], ",",
         "rho"}], "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ZZ", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ThePauli", "[", "3", "]"}], ".", "#"}], "]"}], "&"}], ",",
         "rho"}], "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"XX", ",", "YY", ",", "ZZ"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Joined", "->", "True"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(B\), \(z\)]\) t\>\"", 
      ",", "\"\<\[LeftAngleBracket]X\[RightAngleBracket], \
\[LeftAngleBracket]Y\[RightAngleBracket], \[LeftAngleBracket]Z\
\[RightAngleBracket]\>\""}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotLegends", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
