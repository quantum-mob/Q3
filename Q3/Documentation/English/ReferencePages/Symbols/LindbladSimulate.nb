 "-dimensional Hilbert space of the system."
}], "Notes",
 CellID->1226658091,ExpressionUUID->"fb13f9bf-370e-4eba-8eac-80c729a0a5f1"],

Cell[TextData[{
 "If option ",
 Cell[BoxData["\"\<SaveData\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4eef5dc3-20d7-4287-9789-67e33ba3c03d"],
 " is ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["True"]], "paclet:ref/True"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bce3f31e-5e16-4bc2-b0e3-2d7c9b90433f"],
 ", then ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["LindbladSimulate"]], 
    "paclet:QuantumMob/Q3/ref/LindbladSimulate", "QuantumMob Package Symbol"},
   
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f67bb15b-f05b-4a23-9e45-84fd46697867"],
 " returns the name of the file that stores the quantum trajectories. The \
file stores the compressed data of the form ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Association"]], "paclet:ref/Association"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    RowBox[{"\"\<Times\>\"", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["1", "TR"]], ",", 
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["2", "TR"]], ",", 
       StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], ",", 
    RowBox[{"\"\<Data\>\"", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["trajectory", "TI"], 
        StyleBox["1", "TR"]], ",", 
       SubscriptBox[
        StyleBox["trajectory", "TI"], 
        StyleBox["2", "TR"]], ",", 
       StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "84382cdc-d8b7-4356-8447-d13e71da33b4"],
 ". The compressed data can be uncompressed using ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Uncompress"]], "paclet:ref/Uncompress"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7ac496cf-7366-4fdc-b205-08ab8001f2f0"],
 "."
}], "Notes",
 CellID->908825388,ExpressionUUID->"af5b885a-1385-4b5b-84a1-09aaa1f9efcd"],

Cell[TextData[{
 "The data file format is the MX file; see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["DumpSave"]], "paclet:ref/DumpSave"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "84a3cfca-18f5-4e97-859c-dbbbb64522f9"],
 ". One can read in the data using ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Import"]], "paclet:ref/Import"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], 
   "[", "\"\<\!\(\*StyleBox[\"filename\", \"TI\"]\).mx\>\"", "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4657f162-63d4-43a4-85d7-47e3bc884d17"],
 "."
}], "Notes",
 CellID->1999173437,ExpressionUUID->"e41ba157-ab52-42f3-a526-323d0ad50377"],

Cell["\<\
As long as the parameters are the same, data sets stored in different files \
(generated at different instants of simulation) may be combined to improve \
the statistical error.\
\>", "Notes",
 CellID->281100389,ExpressionUUID->"248415b6-5a0b-4c82-8be5-dee19e20b3be"],

Cell["The following options can be given: ", "Notes",
 CellID->1473646436,ExpressionUUID->"2c898af3-70f5-44ed-abf1-c48099d5388c"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "b0c24023-9ada-469e-9bdb-6a641b500cfe"], "\"\<Samples\>\"", "500", Cell[
    "How many trajectories to generate", "TableText",ExpressionUUID->
     "1bfc2a0f-3ad3-40e9-bbfb-127827a6b825"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "e0ad9db1-3be8-4efc-b4c9-cedb4858b127"], "\"\<SaveData\>\"", 
    TemplateBox[{
      Cell[
       TextData["False"]], "paclet:ref/False"},
     "RefLink",
     BaseStyle->{"3ColumnTableMod"}], Cell[
    "If True, the trajectories are saved to a file.", "TableText",
     ExpressionUUID->"744f1b51-c1be-483c-bb18-c5846e69ed5d"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "9723e4cd-df5d-46e4-93c2-7957426a93ae"], "\"\<Overwrite\>\"", 
    TemplateBox[{
      Cell[
       TextData["True"]], "paclet:ref/True"},
