Cell[TextData[{
 "A Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "398f8b14-545b-4f1f-ab3d-5d0434b0b11b"],
 " is completely specified (up to a global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"\[ImaginaryI]", " ", "m", " ", 
     RowBox[{"\[Pi]", " ", "/", "4"}]}]], TraditionalForm]],ExpressionUUID->
  "ddb6f8d2-5de8-4966-a140-b50a2a4bbae9"],
 ") by the transformation of Pauli operators under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "49600daf-42fb-400b-b13a-c99a576b2826"],
 ":\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["X", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["p", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["a", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["b", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "1d517c8a-ed39-4bd7-81b6-dddd03a5d271"],
 "\nand\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["Z", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["q", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["c", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["d", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "829ab730-a346-4809-8f6e-8335f7cac9c8"],
 "."
}], "Notes",
 CellID->1417856937,ExpressionUUID->"792952b8-db80-425b-8eb0-1dfd02f01895"],

Cell[TextData[{
 "The Gottesman matrix of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "95d0f992-460b-4263-ac4e-2a15da02f41a"],
 " is defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "U", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["a", "11"], 
        SubscriptBox["c", "11"], 
        SubscriptBox["a", "12"], 
        SubscriptBox["c", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "11"], 
        SubscriptBox["d", "11"], 
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["a", "21"], 
        SubscriptBox["c", "21"], 
        SubscriptBox["a", "22"], 
        SubscriptBox["c", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "21"], 
        SubscriptBox["b", "22"], 
        SubscriptBox["d", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "a6e223b9-7355-4ece-a037-941923839227"]
}], "Notes",
 CellID->2083430531,ExpressionUUID->"bc39cc9e-5c94-4690-9e1c-a5ad4b5c57dd"],

Cell[TextData[{
 "The Gottesman matrix of a ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " is a binary symplectic matrix. Recall that the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"61defbcb-04e4-4512-9c06-02ac82ae4c69"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e5c1336e-4d9c-4d65-acef-1dd11e8db463"],
 "qubits is equivalent to the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"737ff6c4-1164-4b88-9373-522190a9ae00"],
 " up to the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"8b5d009c-99c0-4e54-ae80-4c2e8ae98da3"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], "\[Congruent]", 
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"cb58b819-4987-4338-b49e-41b957f176e0"],
 "."
}], "Notes",
 CellID->17963594,ExpressionUUID->"0983e773-26c9-469e-8fc3-486dbe005f65"],

Cell[TextData[{
 "Recall that a Pauli operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"d58b90e5-3f56-4461-ac6d-f2faab318956"],
 "\[LineSeparator]is completely specified by the corresponding Gottesman \
vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["z", "1"], ",", 
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["x", "n"], ",", 
       SubscriptBox["z", "n"]}], ")"}], "T"]}], TraditionalForm]],
  ExpressionUUID->"dbab1614-30aa-4915-84b1-b570b852e7fb"],
 "."
}], "Notes",
 CellID->1441760612,ExpressionUUID->"2ad28b14-96d8-40a0-ac41-3d3e8f822c2e"],

Cell[TextData[{
 "Under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "14ff2119-0555-4c6a-8fe1-706ae1858368"],
 ", the Gottesman vector transforms as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", 
     RowBox[{"U", " ", "P", " ", 
      SuperscriptBox["U", "\[Dagger]"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"v", "(", "P", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "9fb6ce60-4cec-4f45-b2ca-c2299dcf8c94"],
 "."
}], "Notes",
 CellID->1746253034,ExpressionUUID->"90b75ce3-af60-49c7-af4f-252c919f4133"],

Cell[TextData[{
 "Furthermore, a series of consecutive conjugations by Clifford operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ",", " ", "V", ",", " ", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"90a78272-01a4-41dd-9eb8-3b89bf1cfb3e"],
 " is described by the multiplications of corresponding Gottesman matrices,\
\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], "\[Ellipsis]"}]}], TraditionalForm]],
  ExpressionUUID->"77270905-7570-4584-aaf4-568e9cb83054"],
 ". \[LineSeparator]That is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]", " ", "P"}], " ", "..."}], " ", 
     SuperscriptBox["V", "\[Dagger]"], 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
     SuperscriptBox[
