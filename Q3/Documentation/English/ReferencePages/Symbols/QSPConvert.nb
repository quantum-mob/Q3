 CellLabel->"In[3]:=",
 CellID->963601213,ExpressionUUID->"87774a96-2bee-4ed0-a6a1-93e0de154e1f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["\[Phi]", 
     TemplateBox[{",", "\",\"", "0"},
      "RowWithSeparators"]],
    $CellContext`\[Phi][0]], ",", 
   InterpretationBox[
    SubscriptBox["\[Phi]", 
     TemplateBox[{",", "\",\"", "1"},
      "RowWithSeparators"]],
    $CellContext`\[Phi][1]], ",", 
   RowBox[{"2", " ", 
    InterpretationBox[
     SubscriptBox["\[Phi]", 
      TemplateBox[{",", "\",\"", "2"},
       "RowWithSeparators"]],
     $CellContext`\[Phi][2]]}], ",", 
   InterpretationBox[
