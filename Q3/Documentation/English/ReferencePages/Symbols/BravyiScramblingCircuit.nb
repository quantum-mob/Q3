Cell[TextData[{
 "Generate the quantum information scrambling circuit for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", ":=", 
    RowBox[{
     SubscriptBox["X", "k"], "\[Congruent]", 
     RowBox[{
      SubscriptBox["f", "k"], "+", 
      SubsuperscriptBox["f", "k", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"0657c477-6b7f-4052-b105-16e08ebae820"],
 " on the fermion mode ",
 StyleBox["k",
  FontSlant->"Italic"],
 ":"
}], "ExampleText",
 CellID->1084025249,ExpressionUUID->"4fd9d910-3a6b-4eb1-b5cd-169dba85fbd4"],

