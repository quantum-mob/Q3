      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4018b881-73d0-49cc-8349-f12c1462712a"],
     " is a local ",
     ButtonBox["Bravyi unitary",
      BaseStyle->"Link",
      ButtonData->"paclet:QuantumMob/Q3/ref/BravyiUnitary"],
     " operator and ",
     Cell[BoxData[
      FormBox[
       RowBox[{"u", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
      "64198ee6-2ba9-4db4-857b-d7046858b3fb"],
     " is the time-evolution operator. For the remaining arguments ",
     Cell[BoxData[
      RowBox[{
       StyleBox["spec", "TI"], ",", 
       StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d6b66d05-d370-43dd-ae05-1120142b08f1"],
