Cell[BoxData[{
 RowBox[{
  RowBox[{"sgm", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"PartialTrace", "[", 
       RowBox[{"#", ",", "kk"}], "]"}], "&"}], ")"}], "/@", "vec"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"avg", "=", 
  RowBox[{
   RowBox[{"Dot", "[", 
    RowBox[{"val", ",", 
     RowBox[{"VonNeumannEntropy", "/@", "sgm"}]}], "]"}], "//", 
   "Chop"}]}]}], "Input",
