Cell[TextData[{
 "By convention, the quantum relative entropy ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["VonNeumann"]], "paclet:QuantumMob/Q3/ref/VonNeumann", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    RowBox[{
     StyleBox["\[Rho]", "TR"], ",", 
     StyleBox["\[Sigma]", "TR"]}], "]"}], "=", "\[Infinity]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f5574b54-7225-4244-b3e0-2cc3a3d5a1d3"],
 " when the support of \[Rho] is not orthogonal to the null space of \[Sigma]."
}], "Notes",
 CellID->1343353943,ExpressionUUID->"6a707a42-edf3-4960-b912-6df30d8e155f"],

Cell[TextData[{
 "The von Neumann entropy (also known as quantum entropy) of quantum state ",
 Cell[BoxData["\[Rho]"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "423f991d-1cb8-4e56-b7f0-4fda0e890563"],
 " is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{"\[Minus]", 
     RowBox[{"Tr", " ", "[", 
      RowBox[{"\[Rho]", " ", "log", "\[VeryThinSpace]", "\[Rho]"}], "]"}]}]}],
    TraditionalForm]],ExpressionUUID->
  "60fcae1d-9835-479e-bb45-2389cf67bd3e"],
 " ,\[LineSeparator]where the logarithm is usually to base 2."
}], "Notes",
 CellID->837081221,ExpressionUUID->"6162ccad-1b08-4a78-b810-4d542610b8b1"],

Cell[TextData[{
 "For two quantum states \[Rho] and \[Sigma], the ",
 StyleBox["relative von Neumann entropy",
  FontSlant->"Italic"],
 " of \[Rho] to \[Sigma] is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"Tr", "[", 
       RowBox[{
       "\[Rho]", "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "\[Rho]"}], 
       "]"}], "-", 
      RowBox[{"Tr", "[", 
       RowBox[{
       "\[Rho]", "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "\[Sigma]"}], 
       "]"}]}], "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"S", "(", "\[Rho]", ")"}]}], "-", 
      RowBox[{"Tr", "[", 
       RowBox[{
       "\[Rho]", "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "\[Sigma]"}], 
       "]"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "2e02fe10-2b77-4d13-9311-42171174945d"],
 " .\[LineSeparator]The relative von Neumann entropy is also known as \
relative ",
 StyleBox["quantum entropy",
  FontSlant->"Italic"],
 ", ",
 StyleBox["quantum divergence",
  FontSlant->"Italic"],
 " or ",
 StyleBox["Umegaki divergence.",
  FontSlant->"Italic"],
 " "
}], "Notes",
 CellID->1110713806,ExpressionUUID->"3384a1b2-dfc3-4d89-bbc5-28ab2998fba2"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

