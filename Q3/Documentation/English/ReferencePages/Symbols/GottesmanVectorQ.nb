Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"aecc978f-39f7-431a-83a9-019e00993be6"],
 " be the full Pauli group on ",
 StyleBox["n",
  FontSlant->"Italic"],
 " qubits. The center of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"fc8ed074-615e-4b8f-b30c-36efa4f30b98"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalZ]", ":=", 
    RowBox[{"{", 
     RowBox[{"I", ",", " ", 
      RowBox[{"-", "I"}], ",", " ", 
      RowBox[{"\[ImaginaryI]", " ", "I"}], ",", " ", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "I"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"57bceae5-b6f9-4486-ac83-677ad238021a"],
 ". The Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"d3e56952-a97f-457c-a6ae-2dbe7f9c7ea5"],
 " is defined to be the quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], "/", 
     "\[ScriptCapitalZ]"}]}], TraditionalForm]],ExpressionUUID->
  "84375f21-6ec9-4b9e-9aad-f57b8fb90e78"],
 ". The Pauli group is isomorphic to the Abelian group ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "787e1d6d-6e0e-42ea-a333-aee05aebc62d"],
 ", which can also be regarded as a vector space over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalZ]", "2"], TraditionalForm]],
  ExpressionUUID->"f14a73b8-37f9-407a-9ffc-9c91ef249aef"],
 "."
}], "Notes",
 CellID->447549871,ExpressionUUID->"fcb0b8d0-4c34-4176-bc62-49ca6a384a85"],

Cell[TextData[{
 "A Pauli string (i.e., a tensor product of single-qubit Pauli operators)\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"460d8adb-240b-42a8-8ae2-588ca62e3b1f"],
 "\[LineSeparator]is completely specified by the corresponding Gottesman \
vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["x", "1"], ",", 
        SubscriptBox["z", "1"], ",", 
        SubscriptBox["x", "2"], ",", 
        SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["x", "n"], ",", 
        SubscriptBox["z", "n"]}], ")"}], "T"], "\[Element]", 
     SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
      RowBox[{"2", "n"}]]}]}], TraditionalForm]],ExpressionUUID->
  "90f3c5a0-99fa-44f2-80af-c4b77430acd3"],
 "."
}], "Notes",
 CellID->1183077781,ExpressionUUID->"eccbf477-03cb-49e2-a3e6-6a78b7513170"],

Cell[TextData[{
 "Sometimes, the vector space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "8cc0b7a7-aac8-4654-81b4-a68c03363bea"],
 " is called the ",
 StyleBox["Gottesman vector space",
  FontSlant->"Italic"],
 " on ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4b9d5cb-0196-4dac-b273-9421c31afad2"],
 " qubits to emphasize the aforementioned isomorphism."
}], "Notes",
 CellID->1010290685,ExpressionUUID->"26d18803-fac2-429f-9bc3-6ed078adbcf8"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

