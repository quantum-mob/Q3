Cell["\<\
Fidelity is a measure of how close two quantum states are and represents the \
probability that one state will pass a test to identify as the other.\
\>", "Notes",
 CellID->1067943069,ExpressionUUID->"6f761f30-eb79-4cf4-bc7e-664606ab8537"],

Cell[TextData[{
 "For two states described by density operators ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "4c75f4d3-a8b6-462a-9cb6-741540564e1b"],
 " and ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]],ExpressionUUID->
  "87b75caa-c084-4cda-8652-abc6eaacb11d"],
 ", the fidelity (also known as Uhlmann or Uhlmann-Jozsa fidelity) between \
them is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"F", "(", 
     RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{
         SqrtBox["\[Rho]"], 
         SqrtBox["\[Sigma]"]}], "\[RightDoubleBracketingBar]"}], "Tr"], "\[Congruent]", 
      RowBox[{"Tr", "(", 
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{
         SqrtBox["\[Rho]"], 
         SqrtBox["\[Sigma]"]}], "\[RightBracketingBar]"}], ")"}]}], "=", 
     RowBox[{
      RowBox[{"Tr", "[", 
       SqrtBox[
        RowBox[{
         SqrtBox["\[Sigma]"], "\[Rho]", 
         SqrtBox["\[Sigma]"]}]], "]"}], "=", 
      RowBox[{"Tr", "[", 
       SqrtBox[
        RowBox[{
         SqrtBox["\[Rho]"], "\[Sigma]", 
         SqrtBox["\[Rho]"]}]], "]"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "6d1fd23f-8efc-4a7b-8225-3a52f6bd4d0d"],
 ",\[LineSeparator]where for matrix or linear operator ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "a68dba5a-dcbf-4d42-9d1e-894cd0c24c64"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"||", "A", "||"}], "Tr"], TraditionalForm]],ExpressionUUID->
  "1df269e5-261c-4716-9174-7da34663894f"],
 " denotes the trace norm and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", "A", "\[RightBracketingBar]"}], ":=", 
    SqrtBox[
     RowBox[{"A", " ", 
      SuperscriptBox["A", "\[Dagger]"]}]]}], TraditionalForm]],ExpressionUUID->
  "b14655e9-f583-4e6d-880b-5457efcb4df5"],
 "."
}], "Notes",
 CellID->561898199,ExpressionUUID->"21f3ef26-03ec-4fd2-b705-e7099816abe8"],

Cell[TextData[{
 "If one of the two is a pure state, say, \
\[Rho]=|\[Alpha]\[RightAngleBracket]\[LeftAngleBracket]\[Alpha]|, then the \
fidelity is given by ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{
     TemplateBox[{"\[Alpha]"},
      "Bra"], "\[Sigma]", 
     TemplateBox[{"\[Alpha]"},
      "Ket"]}]], TraditionalForm]],ExpressionUUID->
  "b526676f-63a9-4f07-b4aa-5c8afb1c9171"],
 "."
}], "Notes",
 CellID->819171279,ExpressionUUID->"2058fdb0-d79e-482b-b992-d28192956f96"],

Cell[TextData[{
 "If both are pure states, \[Rho]=|\[Alpha]\[RightAngleBracket]\
\[LeftAngleBracket]\[Alpha]| and \[Sigma]=|\[Beta]\[RightAngleBracket]\
\[LeftAngleBracket]\[Beta]|, then the fidelity of them is equivalent to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftBracketingBar]", 
    TemplateBox[{"\[Alpha]", "\[Beta]"},
     "BraKet"], "\[RightBracketingBar]"}], TraditionalForm]],ExpressionUUID->
  "2b00aad1-b936-486f-a9b6-dfac8aa98347"],
 "."
}], "Notes",
 CellID->4618410,ExpressionUUID->"257c0b34-01b4-4d06-9869-e31f821ec467"],

Cell["\<\
Note that some authors use a different convention, where the above definition \
is squared.\
\>", "Notes",
 CellID->284448317,ExpressionUUID->"7e553f85-1040-4fc1-a260-7d8cb7d05329"],

Cell[TextData[{
 "For two quantum states \[Rho] and \[Sigma], the trace distance is related \
to the fidelity by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"1", "-", 
     RowBox[{"F", "(", 
      RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}]}], "\[LessEqual]", 
    RowBox[{
     SubscriptBox["D", "Tr"], "(", 
     RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}], "\[LessEqual]", 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox[
       RowBox[{"F", "(", 
        RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}], "2"]}]]}], 
   TraditionalForm]],ExpressionUUID->"d1d423fd-4a27-4c84-bd7b-cc2255842e05"],
 "."
}], "Notes",
 CellID->596377685,ExpressionUUID->"3db933b8-72c2-424b-824d-f443e3a5122b"],

Cell[TextData[{
 "The fidelity here should be distinguished from ",
 StyleBox["Holevo\[CloseCurlyQuote]s fidelity",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Holevo, 1972)"]], "https://doi.org/10.1007/BF01035528"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "d3c6ee6d-d116-43ab-8a53-de9a040abd2b"],
 "\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["F", "H"], "(", 
     RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}], ":=", 
    RowBox[{"Tr", "(", 
     RowBox[{
      SqrtBox["\[Rho]"], 
      SqrtBox["\[Sigma]"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d3202e5a-4cec-4b4c-8685-07813cfd15e0"],
 ".\[LineSeparator]In fact, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["F", "H"], "(", 
     RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}], "\[LessEqual]", 
    RowBox[{"F", "(", 
     RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"8b6e787b-c76f-4008-a6b7-e4131fcbf8f8"],
 "."
}], "Notes",
 CellID->581143115,ExpressionUUID->"dbe4407c-f995-4e0c-998d-b34e1b409df4"],

Cell[TextData[{
 "While the definition provides a clear physical interpretation in terms of \
the maximum overlap of all purification of \[Rho] and \[Sigma], it is \
relatively expensive to numerically compute. This may be overcome by \
observing the following property (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Baldwin and Jones, 2023"]], 
    "https://doi.org/10.1103/PhysRevA.107.012427"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "48f763fe-f044-4e30-9109-32189c3dcc1d"],
 "): Since the trace of a matrix is equal to the sum of eigenvalues,\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"F", "(", 
     RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     SqrtBox["\[Lambda]"]}]}], TraditionalForm]],ExpressionUUID->
  "7a95c511-9885-4950-be1c-2d09526c152f"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "433a3cf9-33e3-40cd-9014-3e8038f44c59"],
 " are the eigenvalues of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SqrtBox["\[Sigma]"], "\[Rho]", 
    SqrtBox["\[Sigma]"]}], TraditionalForm]],ExpressionUUID->
  "c4965556-1317-479d-ac02-570297cd2101"],
 ". Furthermore, since the spectrum of a matrix product is invariant under \
cyclic permutation, the eigenvalues ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "5a9e1a3f-2a7a-4241-856c-cffaf8bbbf67"],
 " above may instead be calculated from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[VeryThinSpace]", "\[Sigma]"}], TraditionalForm]],
  ExpressionUUID->"9fad80e5-7363-4f7a-9f9b-f741dcdcc57c"],
 ". This leads to the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"F", "(", 
     RowBox[{"\[Rho]", ",", "\[Sigma]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"Tr", "[", 
      SqrtBox[
       RowBox[{"\[Rho]", "\[VeryThinSpace]", "\[Sigma]"}]], "]"}], "=", 
     RowBox[{"Tr", "[", 
      SqrtBox[
       RowBox[{"\[Sigma]", "\[VeryThinSpace]", "\[Rho]"}]], "]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"53294b52-14cc-4b18-844d-5fcd1a39b89c"],
 ",\[LineSeparator]which is more favorable for numerical computation."
}], "Notes",
 CellID->1863985865,ExpressionUUID->"6419943a-5210-440f-bd7f-e1232a09965c"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

