Cell[TextData[{
 "The group element ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "71751207-51be-4905-b5f5-cac1d59c3e51"],
 " can be specified differently depending on the group. For a symmetric group \
",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["S", "n"],
   FontSlant->"Italic"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "482025ae-5260-44c9-8474-2bd4c1d3b230"],
 " as an example, it can be specified by an partition of ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "58a96139-5197-4f3f-80b4-1b2426dc693b"],
 "., which determines the conjugacy class that the element belongs to."
}], "Notes",
 CellID->394586610,ExpressionUUID->"898edb6d-df36-42f8-8eae-fc86a064f9a0"],

Cell[TextData[{
 "The inverse of the GroupCentralizerSize[class] coincides, up to a factor of \
the group order, with the size of the class: ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[ScriptCapitalZ]", 
    RowBox[{"(", "g", ")"}]}], "=", 
   RowBox[{"|", "\[ScriptCapitalG]", "|", 
    RowBox[{"/", 
     RowBox[{"|", 
      RowBox[{"\[ScriptCapitalC]", 
       RowBox[{"(", "g", ")"}]}], "|"}]}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "715f31db-99a1-4397-9771-b467eff1146c"],
 ", where \[ScriptCapitalZ](g) is the centralizer of the element ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fab6904e-9aef-4fc5-9ad8-eff5808982ed"],
 ", and \[ScriptCapitalC](g) is the conjugacy class containing ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "309509a6-683c-4c6c-afb9-cbcf21de6f8e"],
 "."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"3b583cc2-0e6a-4c2b-b0c1-4086f6aefd97"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

