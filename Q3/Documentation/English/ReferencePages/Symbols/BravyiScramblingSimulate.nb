Cell[TextData[{
 "Typically, quantum information scrambling is examined in terms of the \
out-of-time-order correlator (OTOC) \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"C", "(", "t", ")"}], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      RowBox[{
       SuperscriptBox["A", "\[Dagger]"], "(", "t", ")"}], 
      SuperscriptBox["B", "\[Dagger]"], 
      RowBox[{"A", "(", "t", ")"}], "B"}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"b2eff31a-6deb-4b73-9c57-d089d489636f"],
 ", \[LineSeparator]where ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "abe628d9-843b-4d71-a4c9-ad814a64e3e2"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "52ab5ff6-e9c9-425c-8e2a-0c15107c0c59"],
 " are local unitary operators, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "(", "t", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["U", "\[Dagger]"], "(", "t", ")"}], "A", " ", 
     RowBox[{"U", "(", "t", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "901b9d4f-8cbb-4a6b-9a2e-e63ee7183815"],
 " is the Heisenberg picture of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "e3e11686-bf7d-48c4-8cca-97b194acc4ac"],
 " governed by the time-evolution operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "8a83a0f2-513b-41d7-bd80-c755cbe73c9e"],
 "(t)."
}], "Notes",
 CellID->491373739,ExpressionUUID->"f5418ed5-5c14-4894-984c-fdb3438542cb"],

Cell[TextData[{
 "The OTOC satisfies the following relation:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Re", "[", 
     RowBox[{"C", "(", "t", ")"}], "]"}], "=", 
    RowBox[{"1", " ", "-", " ", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"[", 
          RowBox[{
           RowBox[{"A", "(", "t", ")"}], ",", "B"}], "]"}], "\[Dagger]"], "[", 
        RowBox[{
         RowBox[{"A", "(", "t", ")"}], ",", "B"}], "]"}], 
       "\[RightAngleBracket]"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "c036f4ee-edfc-498d-b213-eafeb4b7ca6f"],
 " ."
}], "Notes",
 CellID->984433309,ExpressionUUID->"7f3270fc-56cb-460c-9216-ffa173129330"],

Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiScramblingSimulate"]], 
    "paclet:QuantumMob/Q3/ref/BravyiScramblingSimulate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "21cfdc25-26c0-4282-9632-460b9293eb01"],
 " returns the absolute value of the OTOC but not the OTOC value itself."
}], "Notes",
 CellID->839838813,ExpressionUUID->"98ee5493-5afa-4ae8-ad3e-e320ac43b77c"],

Cell["The following options can be given: ", "Notes",
 CellID->797319258,ExpressionUUID->"a62e2a59-299e-44e9-8824-3cad220fee54"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "0069d472-47e3-42d4-992d-0f45ebe9a42e"], "\"\<Samples\>\"", 
    RowBox[{"{", 
     RowBox[{"10", ",", " ", "3"}], "}"}], Cell[TextData[{
     Cell[BoxData[
      RowBox[{"{", 
