Cell[TextData[{
 "Now, simulate the scrambling and evaluate the OTOC between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ":=", 
    RowBox[{
     SubscriptBox["f", "k"], "+", 
     SubsuperscriptBox["f", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"3088d1f6-c4ed-4dd7-b434-647970f6bb43"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", ":=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      SubsuperscriptBox["f", "1", "\[Dagger]"], 
      SubscriptBox["f", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "27b6ee6b-1cdf-482c-bab5-c16f2de6322e"],
 " in the presence of quantum decoherence, which is modeled by random \
measurement of fermionic modes:"
}], "ExampleText",
 CellID->1439151282,ExpressionUUID->"0245453e-1c75-4499-affc-82e627a0adb8"],

