     SubscriptBox["f", "k"], "+", 
     SubsuperscriptBox["f", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"986a0dc8-5de3-4267-84c6-786c6cd0b3c9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", ":=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      SubsuperscriptBox["f", "1", "\[Dagger]"], 
      SubscriptBox["f", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "b3d1e056-8ae3-4f52-9fe9-e9d683b97a90"],
 " (without decoherence):"
}], "ExampleText",
