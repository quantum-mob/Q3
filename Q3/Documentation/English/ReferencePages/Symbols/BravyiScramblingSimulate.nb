Cell[TextData[{
 "Typically, quantum information scrambling is examined in terms of the \
out-of-time-order correlator (OTOC) \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"C", "(", "t", ")"}], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      RowBox[{
       SuperscriptBox["A", "\[Dagger]"], "(", "t", ")"}], 
      SuperscriptBox["B", "\[Dagger]"], 
      RowBox[{"A", "(", "t", ")"}], "B"}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"c84b23b5-44be-4016-98bb-9222aa0f3a25"],
 ", \[LineSeparator]where ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b873d53e-f2e4-4428-85ba-c6b8a753583b"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "c55b871f-a638-4fbb-8efb-36d3955aca1a"],
 " are local unitary operators, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "(", "t", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["U", "\[Dagger]"], "(", "t", ")"}], "A", " ", 
     RowBox[{"U", "(", "t", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c4828366-059d-430b-b1a5-fd4ba2918b71"],
 " is the Heisenberg picture of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "4cb8948b-89e8-4e60-be33-7c447ae14cbd"],
 " governed by the time-evolution operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "4970dcba-0e7c-4690-adcb-96ea7ea1a925"],
 "(t)."
}], "Notes",
 CellID->491373739,ExpressionUUID->"c8918613-974e-4ecd-8a09-5288eb55b1c3"],

Cell[TextData[{
 "The OTOC satisfies the following relation:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Re", "[", 
     RowBox[{"C", "(", "t", ")"}], "]"}], "=", 
    RowBox[{"1", " ", "-", " ", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"[", 
          RowBox[{
           RowBox[{"A", "(", "t", ")"}], ",", "B"}], "]"}], "\[Dagger]"], "[", 
        RowBox[{
         RowBox[{"A", "(", "t", ")"}], ",", "B"}], "]"}], 
       "\[RightAngleBracket]"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "cb08377d-2c05-40db-ad1d-024eaca06f76"],
 " ."
}], "Notes",
 CellID->984433309,ExpressionUUID->"1039fe56-a45d-414f-8d98-a4a42fff6d6c"],

Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiScramblingSimulate"]], 
    "paclet:QuantumMob/Q3/ref/BravyiScramblingSimulate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a19b69d7-e496-4667-803e-05fc70e79ff3"],
 " returns the absolute value of the OTOC but not the OTOC value itself."
}], "Notes",
 CellID->839838813,ExpressionUUID->"ac2a0acd-eeb4-4b90-8ecd-55bd88c3a403"],

Cell["The following options can be given: ", "Notes",
 CellID->797319258,ExpressionUUID->"0a1f11a2-2a52-4dc3-8ef3-6f83b2c6d88c"],

