Cell[TextData[{
 "Now, simulate the scrambling and evaluate the OTOC between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", ":=", 
    RowBox[{
     SubscriptBox["f", "k"], "+", 
     SubsuperscriptBox["f", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"346564ca-ebda-46d4-8ba2-963dd3d79eb6"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", ":=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      SubsuperscriptBox["f", "1", "\[Dagger]"], 
      SubscriptBox["f", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "8e2164a1-c2e0-4dc7-a3b2-0775d13b7c4a"],
 " in the presence of quantum decoherence, which is modeled by random \
measurement of fermionic modes:"
}], "ExampleText",
