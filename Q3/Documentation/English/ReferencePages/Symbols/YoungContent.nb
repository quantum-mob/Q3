  "62959205-eec6-4dad-b385-ad9468ab8561"],
 " is called the ",
 StyleBox["content",
  FontSlant->"Italic"],
 " or ",
 StyleBox["type",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "aa02b477-b0fb-4919-ae5a-655e2f3f611b"],
 ". The content of any ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "81add7b5-34d4-484e-b556-a44d77a979f6"],
 "-tuple is a ",
