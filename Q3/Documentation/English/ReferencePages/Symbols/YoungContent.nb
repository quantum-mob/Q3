Cell[TextData[{
 "A ",
 StyleBox["composition",
  FontSlant->"Italic"],
 " of integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "a459fd1d-d7fd-48ce-99c7-d4511de0723a"],
 " is an ordered sequence of nonnegative integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Tau]", "1"], ",", 
      SubscriptBox["\[Tau]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Tau]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"27520c3b-52d4-4235-a440-2e39b83250ff"],
 "\[LineSeparator]such that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Tau]", "1"], "+", 
     SubscriptBox["\[Tau]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Tau]", "d"]}], ":=", "n"}], TraditionalForm]],
  ExpressionUUID->"9174b6b8-f9b3-4e87-9cdf-dfb18ae9ba75"],
 ".\[LineSeparator]The integers ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "k"], TraditionalForm]],ExpressionUUID->
  "509e4c3a-ba63-411a-85ef-00e00f6eb68b"],
 " are called the ",
 StyleBox["parts",
  FontSlant->"Italic"],
 " of the composition."
}], "Notes",
 CellID->1280405461,ExpressionUUID->"5f6b08f1-75b0-42f1-bb2b-87098a3db6cb"],

Cell[TextData[{
 "A ",
 StyleBox["partition",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "592fb1ac-f82c-452c-aa54-064983e07b0a"],
 " is a ",
 StyleBox["weakly decreasing",
  FontSlant->"Italic"],
 " sequence of nonnegative integers\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"1767ccba-494f-41a4-bf2f-a76a4b5376d0"],
 "\[LineSeparator]such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"551b8651-4158-491b-9acf-48b3b05e0ef2"],
 ". A partition is a composition, but a composition is not necessarily a \
partition."
}], "Notes",
 CellID->1209047982,ExpressionUUID->"97e66c26-b33d-4fb9-81e7-8834900dc90b"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["i", "1"], ",", 
      SubscriptBox["i", "2"], ",", "\[Ellipsis]", ",", 
