      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3b1c82eb-e018-4019-b3d9-c538724c8270"],
     "\[LineSeparator]classically simulates the quantum information \
scrambling in ",
     ButtonBox["random quantum circuits",
      BaseStyle->"Link",
      ButtonData->"paclet:QuantumMob/Q3/ref/RandomQuantumCircuit"],
     " on qubits ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["s", "TI"], 
         StyleBox["1", "TR"]], ",", 
        SubscriptBox[
         StyleBox["s", "TI"], 
         SubscriptBox[
          StyleBox["2", "TR"], 
          StyleBox["", "TR"]]], ",", 
        StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3357509d-5940-4236-8ab5-d5702739de61"],
     " in terms of the out-of-time-order correlator ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        RowBox[{"C", "(", "t", ")"}], ":=", 
        RowBox[{"\[LeftAngleBracket]", 
         RowBox[{
          RowBox[{
           SuperscriptBox["a", "\[Dagger]"], "(", "t", ")"}], 
          SuperscriptBox["b", "\[Dagger]"], 
          RowBox[{"a", "(", "t", ")"}], "b"}], "\[RightAngleBracket]"}]}], 
       TraditionalForm]],ExpressionUUID->
      "5b5b065c-9f68-4a33-8870-8178a520a9d3"],
     ", where ",
     Cell[BoxData[
      FormBox["a", TraditionalForm]],ExpressionUUID->
      "5955ea71-a7cc-49fb-b984-ad1277583335"],
     " and ",
     Cell[BoxData[
      FormBox["b", TraditionalForm]],ExpressionUUID->
      "7a0ad1ab-5b09-4257-820a-149e87dca1f2"],
     " are local unitary operators. The random quantum circuit consists of \
random two-qubit unitary gates and random single-qubit measurements in the \
computational basis. The measurement is performed with probability ",
     Cell[BoxData[
      StyleBox["p", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6c6cfc54-df9a-451e-aa4f-b0243d39ea53"],
     ", and the circuit has depth ",
     Cell[BoxData[
      StyleBox["t", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f38a5f1f-ff3a-457e-a789-1056cdfd1621"],
     "."
    }],ExpressionUUID->"409358cd-6631-4e5b-84d5-147da1007232"]}
