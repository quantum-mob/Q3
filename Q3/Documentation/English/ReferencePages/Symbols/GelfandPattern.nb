Cell[TextData[{
 "A Gelfand pattern (also known as Gelfand-Zetlin or Gelfand-Tsetlin pattern) \
of dimension ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b8870c47-8a1c-416e-8b1d-bdf91ba3970c"],
 " is a triangular arrangement of non-negative integers of ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "df759191-2ecf-4f8e-baed-6877490b5cff"],
 " rows:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["m", 
        RowBox[{"d", "\[InvisibleSpace]", "1"}]], 
       SubscriptBox["m", 
        RowBox[{"d", "\[InvisibleSpace]", "2"}]], "\[Ellipsis]", 
       SubscriptBox["m", 
        RowBox[{"d", "\[VeryThinSpace]", "d"}]]},
      {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[AscendingEllipsis]", 
       " "},
      {
       SubscriptBox["m", 
        RowBox[{"2", "\[InvisibleSpace]", "1"}]], 
       SubscriptBox["m", 
        RowBox[{"2", "\[InvisibleSpace]", "2"}]], " ", " "},
      {
       SubscriptBox["m", 
        RowBox[{"1", "\[InvisibleSpace]", "1"}]], " ", " ", " "}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "d1ba9bcd-5873-47ae-9471-80df0458d3e3"]
}], "Notes",
 CellID->1671460309,ExpressionUUID->"dd5bef57-9940-4ece-a14d-496c3c9970e8"],

Cell[TextData[{
 "The entries satisfy the \"betweenness\" condition,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->"Italic"]], "\[GreaterEqual]", 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     RowBox[{
      RowBox[{"i", "-", "1"}], ",", 
      StyleBox["j",
       FontSlant->"Italic"]}]], "\[GreaterEqual]", 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], ",", 
      RowBox[{
       StyleBox["j",
        FontSlant->"Italic"], "+", "1"}]}]]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "88ad8ee7-a7d1-475e-86af-64700624d222"],
 "."
}], "Notes",
 CellID->452598569,ExpressionUUID->"f63b7bce-353b-4dd2-b372-8c57f77ed54c"],

Cell[TextData[{
 "There is a one-to-one correspondence between Gelfand patterns of dimension ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "889dc741-babf-439b-92f6-e3a6140b4271"],
 " and ",
 ButtonBox["Weyl tableaux",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/WeylTableaux"],
 " (semi-standard Young tableaux) of shape ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Lambda]", "TR"], ":=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["m", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["d", "TI"], 
        StyleBox["1", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     SubscriptBox[
      StyleBox["m", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["d", "TI"], 
        StyleBox["2", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["m", "TI"], 
      StyleBox["dd", "TI"]]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4842b51e-98a5-40c8-871b-9faaf0a9c664"],
 " with entries of ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7b2b07e4-557c-4270-80f0-4ba32bf352e0"],
 " letters. Note that the shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "69441129-f2c0-4a9e-9b57-40257280c9d7"],
 " has at most ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "158d81d1-ae5f-4266-afe3-88e77f3dbe11"],
 " parts, and when the order ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], ":=", 
   RowBox[{
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox[
      RowBox[{
       StyleBox["d", "TI"], 
       StyleBox["1", "TR"]}],
      ZeroWidthTimes->True]], "+", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox[
      RowBox[{
       StyleBox["d", "TI"], 
       StyleBox["2", "TR"]}],
      ZeroWidthTimes->True]], "+", 
    StyleBox["\[Ellipsis]", "TR"], "+", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["dd", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ff0474b4-dd69-415f-8c50-983656e7eb9d"],
 " is less than dimension ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "e826deac-0781-4d00-98ef-c57901fd5ebf"],
 ", the trailing parts are zero (",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["m", "TI"], 
    StyleBox["dk", "TI"]], "=", "0"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4ee335ad-ab82-4be4-9cc0-007597eb488f"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", ">=", 
    RowBox[{"d", "+", "1"}]}], TraditionalForm]],ExpressionUUID->
  "eae04b70-8acd-4706-ac49-9605e7b68e15"],
 ")."
}], "Notes",
 CellID->649833363,ExpressionUUID->"f4509c4e-0121-4d2f-89b7-73a069347ffe"],

Cell[TextData[{
 "Given a Gelfand pattern ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "d60042b1-6189-4109-8289-d68d1f5032b6"],
 ", one can construct the corresponding Weyl tableau ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "6d0b6183-1b37-483d-99bc-293b278cb99c"],
 " by noting that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", 
     RowBox[{"i", ",", "j"}]], "-", 
    SubscriptBox["m", 
     RowBox[{
      RowBox[{"i", "-", "1"}], ",", "j"}]]}], TraditionalForm]],
  ExpressionUUID->"6b85f6ed-bdcb-4f02-b9bb-b5a3477e339d"],
 " is the number of boxes with number ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "acb85aee-f203-4448-b8af-59bec3747350"],
 " to appear in the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["i", "th"], TraditionalForm]],ExpressionUUID->
  "fc679044-19a8-4dbf-8cb5-730b1aedf9a5"],
 " row of ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "81a44add-534b-4917-a416-2cfb33839b3b"],
 "."
}], "Notes",
 CellID->2104557014,ExpressionUUID->"8af1a63a-f28e-4a66-9f82-6ff6a974899e"],

Cell[TextData[{
 "Conversely, given a Weyl tableau ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "cbff4a26-6ef8-4f6c-b47c-f70d15bbfda4"],
 ", the corresponding Gelfand pattern ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "9850787d-9b90-40dc-a270-d6c6ad06e681"],
 " may be constructed as follows: The first row of ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "4de37455-9d19-4c10-9d8f-745268a97fd6"],
 " is given by the shape of ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "a398654c-9562-480e-80cf-8bbc6f04dbb7"],
 ". The second row is given by the shape after boxes with ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "6b81515c-0607-4ebc-a0b7-49a74b2c3297"],
 " are removed from the Weyl tableau. Continuing this procedure, the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "ed42b208-2692-4390-b7ca-d648f7a68b88"],
 " row of ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "60c07ecf-9e3f-40fc-b7e2-88df1353af9e"],
 " is given by the shape of the resulting Weyl tableau after boxes with ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "118261af-eb86-4e73-828c-b3b81cb5b690"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "7989f486-2430-4d50-ab6f-1409b4d9f4f9"],
 ", \[Ellipsis], ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "k", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "8c658fd5-b10d-4203-a315-199e0cc4e622"],
 " are removed."
}], "Notes",
 CellID->71813943,ExpressionUUID->"d56e80e8-1913-48f7-9865-278a94c36c5d"],

Cell[TextData[{
 "If a Gelfand pattern corresponds to a stand Young tableau, then it is \
called a ",
 StyleBox["Gelfand-Young pattern",
  FontSlant->"Italic"],
 ". Otherwise, it is called a ",
 StyleBox["Gelfand-Weyl pattern",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1208191622,ExpressionUUID->"58333c7a-3bf4-48d9-af59-91a3d34b78c8"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

