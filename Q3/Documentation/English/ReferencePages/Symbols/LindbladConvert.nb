Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["LindbladConvert"]], "paclet:QuantumMob/Q3/ref/LindbladConvert",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8b1d4f34-d2e4-411c-8b55-aad62b297b1d"],
 " converts the Lindblad equation into the form\n\t",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{
        SubscriptBox[
         OverscriptBox["\[Rho]", "."], 
         StyleBox["i", "TI"]], "\[LongEqual]", 
        UnderoverscriptBox["\[Sum]", 
         RowBox[{
           StyleBox["j", "TI"], "\[LongEqual]", "1"}], 
         RowBox[{
           SuperscriptBox[
            StyleBox["n", "TI"], "2"], "-", "1"}], LimitsPositioning -> True], 
        SubscriptBox[
         StyleBox["M", "TI"], 
         RowBox[{
           StyleBox["i", "TI"], 
           StyleBox["j", "TI"]}]], 
        SubscriptBox["\[Rho]", 
         StyleBox["j", "TI"]], "+", 
        SubscriptBox[
         StyleBox["v", "TI"], 
         StyleBox["j", "TI"]], "  ", 
        RowBox[{"(", 
          RowBox[{
            StyleBox["i", "TI"], "\[LongEqual]", "1", ",", "\[Ellipsis]", ",", 
            SuperscriptBox[
             StyleBox["n", "TI"], "2"], "-", "1"}], ")"}]}], TraditionalForm],
     "errors" -> {}, "input" -> 
    "\\dot\\rho_i=\\sum_{j=1}^{n^2-1}M_{ij}\\rho_j+v_j \\quad \
(i=1,\\dots,n^2-1)", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"]], "Input",ExpressionUUID->
  "80b02d77-749a-46cc-a403-abf05047d9c8"],
 ",\nwhere the density operator is represented in the Lie basis, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"{", 
         RowBox[{
           SubscriptBox[
            StyleBox["B", "TI"], 
            StyleBox["j", "TI"]], ":", 
           StyleBox["j", "TI"], "\[LongEqual]", "1", ",", "2", ",", 
           "\[Ellipsis]", ",", 
           SuperscriptBox[
            StyleBox["n", "TI"], "2"], "-", "1"}], "}"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\{B_j:j=1,2,\\dots,n^2-1\\}", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "68099347-a359-4f9b-8dc3-ee3e259018a1"],
 ", as\n\t",
 Cell[BoxData[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{"\[Rho]", "\[LongEqual]", 
        FractionBox["1", 
         StyleBox["n", "TI"]], 
        StyleBox["I", "TI"], "+", 
        UnderoverscriptBox["\[Sum]", 
         RowBox[{
           StyleBox["j", "TI"], "\[LongEqual]", "1"}], 
         RowBox[{
           SuperscriptBox[
            StyleBox["n", "TI"], "2"], "-", "1"}], LimitsPositioning -> True], 
        SubscriptBox[
         StyleBox["B", "TI"], 
         StyleBox["j", "TI"]], 
        SubscriptBox["\[Rho]", 
         StyleBox["j", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
    "\\rho=\\frac{1}{n}I+\\sum_{j=1}^{n^2-1}B_j\\rho_j", "state" -> "Boxes"|>,
   
   "TeXAssistantTemplate"]], "Input",ExpressionUUID->
  "cddb4340-ce7d-49a5-a75f-f28cd76a5dc5"],
 " ."
}], "Notes",
 CellID->1292051031,ExpressionUUID->"619d5877-3107-4c2f-86a9-569b18fdd729"],

Cell[TextData[{
 "The solution of the Lindblad equation is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Rho]", 
          StyleBox["i", "TI"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         UnderscriptBox["\[Sum]", 
          StyleBox["j", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          RowBox[{"[", 
            SuperscriptBox[
             StyleBox["e", "TI"], 
             RowBox[{
               StyleBox["M", "TI"], 
               StyleBox["t", "TI"]}]], "]"}], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox["\[Rho]", 
          StyleBox["j", "TI"]], 
         RowBox[{"(", "0", ")"}], "+", 
         UnderscriptBox["\[Sum]", 
          StyleBox["j", "TI"], LimitsPositioning -> True], 
         SubscriptBox[
          RowBox[{"[", 
            RowBox[{
              SubsuperscriptBox["\[Integral]", "0", 
               StyleBox["t", "TI"]], 
              RowBox[{
                StyleBox["d", "TI"], 
                StyleBox["s", "TI"]}], " ", 
              SuperscriptBox[
               StyleBox["e", "TI"], 
               RowBox[{
                 StyleBox["M", "TI"], 
                 StyleBox["s", "TI"]}]]}], "]"}], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]], 
         SubscriptBox[
          StyleBox["v", "TI"], 
          StyleBox["j", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\rho_i(t)=\\sum_j[e^{Mt}]_{ij}\\rho_j(0)+\\sum_j\\left[\\int_0^t{ds}\\,\
e^{Ms}\\right]_{ij}v_j", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2589d3c0-05c2-496e-8ebb-9325ffbad7bd"],
 "."
}], "Notes",
 CellID->421100671,ExpressionUUID->"4f35e85a-3db9-4935-b7a5-8e146b3ffe12"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["LindbladConvert"]], "paclet:QuantumMob/Q3/ref/LindbladConvert",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "84a8e88e-83c9-421a-836b-4e98f787e44d"],
 " returns ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["n", "2"], "-", "1"}], ")"}], "\[Times]", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["n", "2"], "-", "1"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"492a6f89-cc75-45d7-9838-a744bedd3bc3"],
 " matrix and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["n", "2"], "-", "1"}], ")"}], TraditionalForm]],
  ExpressionUUID->"2264b4b7-a92f-4358-a45d-54b96052eaff"],
 "-component column vector, where ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e360c705-28cd-4aff-82e9-4d6d16a883f0"],
 " is the Hilbert-space dimension of the system."
}], "Notes",
 CellID->1313509585,ExpressionUUID->"c7a8b9f1-3233-4f02-97c0-d83576269750"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

