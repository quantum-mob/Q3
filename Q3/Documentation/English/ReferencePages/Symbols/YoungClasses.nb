Cell[TextData[{
 "A ",
 StyleBox["cycle decomposition",
  FontSlant->"Italic"],
 " of a permutation is an expression of the permutation as a product of \
disjoint cycles, where each cycle represents a cyclic rearrangement of \
elements. This decomposition is unique up to the order of the cycles and \
cyclic rotations within each cycle."
}], "Notes",
 CellID->442409035,ExpressionUUID->"4de7a3c0-c3ae-40fc-85b3-11bca2733a96"],

Cell[TextData[{
 "The ",
 StyleBox["cycle decomposition type",
  FontSlant->"Italic"],
 " of a permutation of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "5358ad53-2fcc-40da-b07a-10f0ec980da2"],
 " elements is a list of the lengths of the cycles in its cycle \
decomposition. By convention, a cycle decomposition type is arranged in \
decreasing order, and is a partition of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "acbdf5d2-5647-4e3f-8620-3c0294ab04a5"],
 "."
}], "Notes",
 CellID->827090356,ExpressionUUID->"f38948b5-c570-48ad-b324-44bb58dbb2c8"],

Cell[TextData[{
 StyleBox["Conjugacy classes",
  FontSlant->"Italic"],
 " in the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "7da8706f-cf84-4565-a301-1c3f252759b4"],
 " are uniquely determined by the ",
 StyleBox["cycle decomposition type",
  FontSlant->"Italic"],
 " of permutations. Hence, like irreducible representations of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "c21635bf-ab0c-4eb0-b28a-369c8fb50c1e"],
 ", conjugacy classes in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "3d1da71b-2b3f-4fd7-b087-3e90b5cdf591"],
 " are in one-to-one correspondence to partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e015ef6b-d106-48d4-bc4e-11c9049f0854"],
 "."
}], "Notes",
 CellID->285452206,ExpressionUUID->"2bd0bd0a-7180-4c72-abff-062ea877a48a"],

Cell[TextData[{
 "The keys of the returned association (corresponding to conjugacy classes) \
are arranged in the same way as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Reverse"]], "paclet:ref/Reverse"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ff0e9685-1e47-4903-848b-47880d3fbeb3"],
 ". Note that ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ReverseSort"]], "paclet:ref/ReverseSort"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3ba79998-6be2-47d8-aa72-b549055bc0c9"],
 " is not the same as ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Reverse"]], "paclet:ref/Reverse"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d138ceec-1c39-49d5-ae87-b7ac247ee8e2"],
 " because ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungShapes"]], "paclet:QuantumMob/Q3/ref/YoungShapes", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4822249-69c4-48d9-95e6-ff315d49962b"],
 " is ",
 StyleBox["not",
  FontSlant->"Italic"],
 " lexicographically ordered."
}], "Notes",
 CellID->586170552,ExpressionUUID->"5a9b7def-1084-4b82-9f42-eb2e7833def6"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

