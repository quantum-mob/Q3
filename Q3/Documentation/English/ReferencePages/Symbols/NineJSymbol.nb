Cell[TextData[{
 "The 9\[Hyphen]",
 Cell[BoxData[
  FormBox[
   StyleBox["j", "TI"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "572f83b9-475f-4b4d-9870-48206ea471c0"],
 " symbols vanish except when certain triples of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["j", "TI"], 
    StyleBox["i", "TI"]], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "85323ecf-b866-4034-b010-9542db1261e9"],
 " satisfy triangle inequalities."
}], "Notes",
 CellID->1862693206,ExpressionUUID->"2f4b6274-fb70-4413-8beb-5c67214bcf08"],

Cell[TextData[{
 "The 9-j symbols arise when there is a recoupling of four degrees of \
freedom. For example, they are used in the computation of the matrix elements \
of products of tensor operators, and used as the transformation from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[VeryThinSpace]", "S"}], TraditionalForm]],ExpressionUUID->
  "04a5c854-06b6-4336-a0d0-9805d2df07c6"],
 " coupling scheme to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "\[VeryThinSpace]", "j"}], TraditionalForm]],ExpressionUUID->
  "2e115503-8973-4f61-8a5d-06742cb3f263"],
 " coupling. "
}], "Notes",
 CellID->1604774189,ExpressionUUID->"ed608ba1-acde-49e1-9cff-04514a8e0ff8"],

