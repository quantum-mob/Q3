Cell[TextData[{
 "The 9\[Hyphen]",
 Cell[BoxData[
  FormBox[
   StyleBox["j", "TI"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1eb092fd-1141-4b86-a260-6715771ce5f5"],
