 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["j", "TI"], 
    StyleBox["i", "TI"]], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4d4e8ebf-ac9c-4f06-9c50-831fc0d04730"],
 " satisfy triangle inequalities."
}], "Notes",
 CellID->1862693206,ExpressionUUID->"4cf4f830-e77a-4a61-bf39-44e30c0b7c83"],

Cell[TextData[{
 "The 9-j symbols arise when there is a recoupling of four degrees of \
freedom. For example, they are used in the computation of the matrix elements \
of products of tensor operators, and used as the transformation from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", "\[VeryThinSpace]", "S"}], TraditionalForm]],ExpressionUUID->
  "d93a3199-7d3c-401b-9fd0-13a47ad29081"],
 " coupling scheme to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "\[VeryThinSpace]", "j"}], TraditionalForm]],ExpressionUUID->
  "2e5da98b-c993-4033-a3a0-174b41eb684b"],
 " coupling. "
}], "Notes",
 CellID->1604774189,ExpressionUUID->"46ffbdb3-8efb-488c-81f6-197aedd3bc24"],

