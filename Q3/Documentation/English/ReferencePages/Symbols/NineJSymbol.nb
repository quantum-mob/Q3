         SubscriptBox["ji", 
          RowBox[{"\[LeftDoubleBracket]", 
           RowBox[{"2", "\[InvisibleComma]", "1"}], 
           "\[RightDoubleBracket]"}]], ",", 
         SubscriptBox["ji", 
          RowBox[{"\[LeftDoubleBracket]", 
           RowBox[{"3", "\[InvisibleComma]", "1"}], 
           "\[RightDoubleBracket]"}]]}], "}"}]}], "]"}]}]}]}], "]"}]], "Input",\

