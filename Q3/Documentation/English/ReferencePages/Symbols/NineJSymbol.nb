Cell[BoxData[
 RowBox[{"With", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ji", "=", 
     RowBox[{"(", GridBox[{
        {"1", "2", "3"},
        {"1", "2", "3"},
        {"2", "2", "0"}
       }], ")"}]}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"NineJSymbol", "[", "ji", "]"}], "==", 
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{
        SubscriptBox["ji", 
         RowBox[{"\[LeftDoubleBracket]", 
          RowBox[{"2", "\[InvisibleComma]", "1"}], "\[RightDoubleBracket]"}]],
         "+", 
        SubscriptBox["ji", 
         RowBox[{"\[LeftDoubleBracket]", 
          RowBox[{"1", "\[InvisibleComma]", "2"}], "\[RightDoubleBracket]"}]],
         "+", 
        SubscriptBox["ji", 
         RowBox[{"\[LeftDoubleBracket]", 
          RowBox[{"3", "\[InvisibleComma]", "1"}], "\[RightDoubleBracket]"}]],
         "+", 
        SubscriptBox["ji", 
         RowBox[{"\[LeftDoubleBracket]", 
          RowBox[{"1", "\[InvisibleComma]", "3"}], 
          "\[RightDoubleBracket]"}]]}]], 
      SqrtBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", 
           SubscriptBox["ji", 
            RowBox[{"\[LeftDoubleBracket]", 
             RowBox[{"1", "\[InvisibleComma]", "3"}], 
             "\[RightDoubleBracket]"}]]}], "+", "1"}], ")"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", 
           SubscriptBox["ji", 
            RowBox[{"\[LeftDoubleBracket]", 
             RowBox[{"3", "\[InvisibleComma]", "1"}], 
             "\[RightDoubleBracket]"}]]}], "+", "1"}], ")"}]}]]], 
     RowBox[{"KroneckerDelta", "[", 
      RowBox[{
       SubscriptBox["ji", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"1", "\[InvisibleComma]", "3"}], "\[RightDoubleBracket]"}]], 
       ",", 
       SubscriptBox["ji", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"2", "\[InvisibleComma]", "3"}], 
         "\[RightDoubleBracket]"}]]}], "]"}], 
     RowBox[{"KroneckerDelta", "[", 
      RowBox[{
       SubscriptBox["ji", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"3", "\[InvisibleComma]", "1"}], "\[RightDoubleBracket]"}]], 
       ",", 
       SubscriptBox["ji", 
        RowBox[{"\[LeftDoubleBracket]", 
         RowBox[{"3", "\[InvisibleComma]", "2"}], 
         "\[RightDoubleBracket]"}]]}], "]"}], 
     RowBox[{"SixJSymbol", "[", 
      RowBox[{
       RowBox[{"First", "[", "ji", "]"}], ",", 
