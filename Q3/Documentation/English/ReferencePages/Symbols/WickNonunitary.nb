Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickNonunitary"]], 
         "paclet:QuantumMobQ3/ref/WickNonunitary", 
         "QuantumMobQ3 Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{"{", 
        RowBox[{
         StyleBox["fac", "TI"], ",", 
         StyleBox["non", "TI"]}], "}"}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "427c5125-7418-4ca3-a742-12bafec5973d"],
     "\[LineSeparator]represents a fermionic Gaussian gate (without pairing \
correlation) characterized by the damping factor fac := Exp[-gmm*\[Tau]] and \
n\[Times]n non-unitary matrix non := MatrixExp[-\[ImaginaryI](ham - \
\[ImaginaryI] dmp)\[Tau]]. "
    }],ExpressionUUID->"5262ba9f-1d95-4f83-8dba-492b7bf7f63d"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickNonunitary"]], 
         "paclet:QuantumMobQ3/ref/WickNonunitary", 
         "QuantumMobQ3 Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          StyleBox["ham", "TI"], ",", 
          StyleBox["jmp", "TI"]}], "}"}], ",", 
        StyleBox["\[Tau]", "TR"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "46a20af3-b96c-4044-8b66-901ae5b86135"],
     "\[LineSeparator]is a shortcut to construct ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickNonunitary"]], 
         "paclet:QuantumMob/Q3/ref/WickNonunitary", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{"{", 
        RowBox[{
         StyleBox["fac", "TI"], ",", 
         StyleBox["non", "TI"]}], "}"}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "0795f0c0-01f6-4da4-92b2-651abc177df3"],
     " with ",
     Cell[BoxData[
      RowBox[{
       StyleBox["fac", "TI"], ":=", 
       RowBox[{
        StyleBox["exp", "TI"], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", 
           StyleBox["\[Gamma]", "TR"]}], " ", 
          StyleBox["\[Tau]", "TR"]}], ")"}]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ed4f1d70-93a8-4957-8dd8-43828d8414f9"],
     " and ",
     Cell[BoxData[
      RowBox[{
       StyleBox["non", "TI"], ":=", 
       RowBox[{
        StyleBox["exp", "TI"], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", 
          RowBox[{"(", 
           RowBox[{
            StyleBox["ham", "TI"], "-", 
            RowBox[{"\[ImaginaryI]", " ", 
             StyleBox["dmp", "TI"]}]}], ")"}], 
          StyleBox["\[Tau]", "TR"]}], ")"}]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "611ff2f3-2c5e-448c-b30a-aeb8737599e9"],
     ", where ",
     Cell[BoxData[
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         StyleBox["dmp", "TI"], ",", 
         StyleBox["\[Gamma]", "TR"]}], "}"}], "=", 
       RowBox[{
        TemplateBox[{
          Cell[
           TextData["WickDampingOperator"]], 
          "paclet:QuantumMob/Q3/ref/WickDampingOperator", 
          "QuantumMob Package Symbol"},
         "PackageLink",
         BaseStyle->"InlineFormula"], "[", 
        StyleBox["jmp", "TI"], "]"}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "61b5f954-0dd8-4192-aca6-1b812634ab0c"],
     "."
    }],ExpressionUUID->"9e7780ab-c73e-4503-825c-b039a7183c27"]},
