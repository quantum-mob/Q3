   "built" -> "{2026, 4, 12, 17, 58, 56.145953}", 
    "history" -> {"14.3", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {
     "fermionic quantum computation", "fermionic Gaussian state"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "WickNonunitary[{fac, non}] represents a fermionic Gaussian gate (without \
pairing correlation) characterized by the damping factor fac := \
Exp[-gmm*\\[Tau]] and n*n non-unitary matrix non := MatrixExp[-I(ham - I dmp)\
\\[Tau]]. WickNonunitary[{ham, jmp}, \\[Tau]] is a shortcut to construct \
WickNonunitary[{fac, non}] with fac := exp (-\\[Gamma] \\[Tau]) and non := \
exp (-I (ham - I dmp) \\[Tau]), where {dmp, \\[Gamma]} = \
WickDampingOperator[jmp]. WickNonunitary[spec, {k1, k2, ...}] assumes that \
the non-unitary gate operates on fermion modes {k1, k2, ...} \\[Subset] [n].",
     "synonyms" -> {}, "tabletags" -> {}, "title" -> "WickNonunitary", 
    "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "WickNonunitary", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/WickNonunitary"}},
