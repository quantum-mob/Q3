Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickNonunitary"]], 
         "paclet:QuantumMobQ3/ref/WickNonunitary", 
         "QuantumMobQ3 Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{"{", 
        RowBox[{
         StyleBox["fac", "TI"], ",", 
         StyleBox["non", "TI"]}], "}"}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d2050557-2def-441d-818a-7f1643e2dc42"],
     "\[LineSeparator]represents a fermionic Gaussian gate (without pairing \
correlation) characterized by the damping factor fac := Exp[-gmm*\[Tau]] and \
n\[Times]n non-unitary matrix non := MatrixExp[-\[ImaginaryI](ham - \
\[ImaginaryI] dmp)\[Tau]]. "
    }],ExpressionUUID->"929eea71-2608-4191-b5d5-1359cf76576e"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickNonunitary"]], 
         "paclet:QuantumMobQ3/ref/WickNonunitary", 
         "QuantumMobQ3 Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          StyleBox["ham", "TI"], ",", 
          StyleBox["jmp", "TI"]}], "}"}], ",", 
        StyleBox["\[Tau]", "TR"]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c3a8bada-4a54-4bea-a52f-f35b05ad7184"],
     "\[LineSeparator]is a shortcut to construct ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["WickNonunitary"]], 
         "paclet:QuantumMob/Q3/ref/WickNonunitary", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{"{", 
        RowBox[{
         StyleBox["fac", "TI"], ",", 
         StyleBox["non", "TI"]}], "}"}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "7ffbc830-7ceb-4138-bb56-3b0d715eac70"],
     " with ",
     Cell[BoxData[
      RowBox[{
       StyleBox["fac", "TI"], ":=", 
       RowBox[{
        StyleBox["exp", "TI"], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", 
           StyleBox["\[Gamma]", "TR"]}], " ", 
          StyleBox["\[Tau]", "TR"]}], ")"}]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "cba34f7f-8972-4abe-924c-7eb71be4af68"],
     " and ",
     Cell[BoxData[
      RowBox[{
       StyleBox["non", "TI"], ":=", 
       RowBox[{
        StyleBox["exp", "TI"], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", 
          RowBox[{"(", 
           RowBox[{
            StyleBox["ham", "TI"], "-", 
            RowBox[{"\[ImaginaryI]", " ", 
             StyleBox["dmp", "TI"]}]}], ")"}], 
          StyleBox["\[Tau]", "TR"]}], ")"}]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d0bed709-23ce-4fa7-b377-1482141fdacf"],
     ", where ",
     Cell[BoxData[
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         StyleBox["dmp", "TI"], ",", 
         StyleBox["\[Gamma]", "TR"]}], "}"}], "=", 
       RowBox[{
        TemplateBox[{
          Cell[
           TextData["WickDampingOperator"]], 
          "paclet:QuantumMob/Q3/ref/WickDampingOperator", 
          "QuantumMob Package Symbol"},
         "PackageLink",
         BaseStyle->"InlineFormula"], "[", 
        StyleBox["jmp", "TI"], "]"}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4c071525-7f3a-45c6-8cfa-d0e13922aaec"],
     "."
    }],ExpressionUUID->"531e59dc-1920-40b5-9bd3-8c657fb975c8"]},
