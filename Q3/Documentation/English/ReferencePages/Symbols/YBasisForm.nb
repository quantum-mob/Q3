      "Ket"],
     Ket[<|$CellContext`S[1, Q3`$] -> "L", $CellContext`S[2, Q3`$] -> 0|>]]}],
    "+", 
   FractionBox[
    RowBox[{"\[ImaginaryI]", " ", 
     InterpretationBox[
      TemplateBox[{
        TemplateBox[{
          SubscriptBox["\"L\"", 
           InterpretationBox[
            SubscriptBox[
             TemplateBox[{"S"}, "RowDefault"], 
             TemplateBox[{"1"}, "RowDefault"]], 
            $CellContext`S[1, Q3`$]]], 
          SubscriptBox["1", 
           InterpretationBox[
            SubscriptBox[
             TemplateBox[{"S"}, "RowDefault"], 
             TemplateBox[{"2"}, "RowDefault"]], 
            $CellContext`S[2, Q3`$]]]}, "RowDefault"]},
       "Ket"],
