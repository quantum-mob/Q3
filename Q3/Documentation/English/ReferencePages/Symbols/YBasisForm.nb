Cell[TextData[{
 "The vectors of the Pauli Y operator are given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"L"},
     "Ket"], ":=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], " ", "+", " ", 
      RowBox[{"\[ImaginaryI]", 
       TemplateBox[{"1"},
        "Ket"]}]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "6f370859-2ad0-4911-9498-9650e10f2449"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"R"},
     "Ket"], ":=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], " ", "-", " ", 
      RowBox[{"\[ImaginaryI]", 
       TemplateBox[{"1"},
        "Ket"]}]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "42ffbb35-00d2-4a62-bef8-297c38cce80b"],
 "."
}], "Notes",
 CellID->1797646534,ExpressionUUID->"1118739a-1fbb-4d8c-8dcf-44df8b593bc5"]
