Cell[BoxData[
 InterpretationBox[
  RowBox[{
   RowBox[{
    SqrtBox["2"], " ", 
    InterpretationBox[
     TemplateBox[{
       TemplateBox[{
         SubscriptBox["\"L\"", 
          InterpretationBox[
           SubscriptBox[
            TemplateBox[{"S"}, "RowDefault"], 
            TemplateBox[{"1"}, "RowDefault"]], 
