Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"CliffordCircuit", "@", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"CliffordState", "[", 
      RowBox[{"Ket", "@", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", "4"}], "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"CliffordUnitary", "[", 
      RowBox[{
       RowBox[{"RandomFullGottesmanMatrix", "[", "2", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3"}], "}"}], ",", 
       RowBox[{"\"\<Label\>\"", "->", "\"\<U\>\""}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"CNOT", "[", 
      RowBox[{"1", ",", "2"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"SWAP", "[", 
      RowBox[{"2", ",", "3"}], "]"}], ",", "\[IndentingNewLine]", 
     RowBox[{"Hadamard", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Quadrant", "[", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"PauliMeasurement", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "1"}], "}"}], ",", 
         RowBox[{"{", "4", "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"PauliDecoherence", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}], ",", 
         RowBox[{"{", "1", "}"}]}], "]"}]}], "}"}]}], "\[IndentingNewLine]", 
    "}"}]}]}]], "Input",
