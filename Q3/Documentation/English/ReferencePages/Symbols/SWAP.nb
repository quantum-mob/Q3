Cell[TextData[{
 "This is a quantum circuit model to construct the CZ gate from the ",
 Cell[BoxData[
  FormBox[
   SqrtBox["SWAP"], TraditionalForm]],ExpressionUUID->
  "81beff8e-af1d-40d1-b31c-60352e439e53"],
 " gate and single-qubit rotation gates. In this diagram, ",
 Cell[BoxData[
  FormBox[
   SqrtBox["U"], TraditionalForm]],ExpressionUUID->
  "a18003ae-f820-4386-8348-0c92f27e0484"],
 " denotes the ",
 Cell[BoxData[
  FormBox[
   SqrtBox["SWAP"], TraditionalForm]],ExpressionUUID->
  "6ee66013-3187-4559-9dad-78b6f444de5d"],
 "gate and ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "ec30a19b-105c-4b56-aa1b-7b781a480850"],
 " the ",
 ButtonBox["quadrant phase gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Quadrant"],
 " (or, equivalently, the rotation around the z-axis by angle \[Pi]/2):"
}], "ExampleText",
 CellID->27233292,ExpressionUUID->"4ce629da-5fd1-41e8-a6d4-1cd1d1a6ba99"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"sqrt", ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "3"}], "]"}], ",", "sqrt", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "7"}], "]"}], ",", 
      RowBox[{"Dagger", "@", 
       RowBox[{"S", "[", 
        RowBox[{"2", ",", "7"}], "]"}]}]}], "}"}]}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1505230369,ExpressionUUID->"6f52287d-2dd5-4fd8-95b6-12320f171c9e"],

