Cell[TextData[{
 "This is a quantum circuit model to construct the CZ gate from the ",
 Cell[BoxData[
  FormBox[
   SqrtBox["SWAP"], TraditionalForm]],ExpressionUUID->
  "49d6bb9f-dd9f-4ad9-9084-d417c8a3fd53"],
 " gate and single-qubit rotation gates. In this diagram, ",
 Cell[BoxData[
  FormBox[
   SqrtBox["U"], TraditionalForm]],ExpressionUUID->
  "bfe4afc0-c318-45e6-a39d-7f80e72838b9"],
 " denotes the ",
 Cell[BoxData[
  FormBox[
   SqrtBox["SWAP"], TraditionalForm]],ExpressionUUID->
  "4ecfd4a8-340f-4681-bad2-21c109eea279"],
 "gate and ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "5aca8e8f-763d-4106-b52a-81718de021b9"],
 " the ",
 ButtonBox["quadrant phase gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Quadrant"],
 " (or, equivalently, the rotation around the z-axis by angle \[Pi]/2):"
}], "ExampleText",
 CellID->27233292,ExpressionUUID->"fca2aa52-8282-4a3a-a76e-a74f705d3ca5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
