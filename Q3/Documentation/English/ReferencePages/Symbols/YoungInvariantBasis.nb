Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", ":=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "1"]},
        "Ket"], ",", 
       TemplateBox[{
         SubscriptBox["v", "2"]},
        "Ket"], ",", "\[Ellipsis]", ",", 
       TemplateBox[{
         SubscriptBox["v", "n"]},
        "Ket"]}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "6f953815-0e83-4938-b61d-4ba944ac9cc2"],
 " be a vector space and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "b0cd36fb-354f-4f6e-aeeb-c6d045fba353"],
 " be a group acting on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "c912bc91-810e-40ab-b5de-97ccd223e2d4"],
 ". Then, the subspace ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalV]", "\[ScriptCapitalG]"], 
   TraditionalForm]],ExpressionUUID->"f1be387b-a4f8-4524-86f7-7380a692a133"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "ba3d4016-de0a-4195-86d2-9dc5ebc967a6"],
 "-invariant vectors  in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "5885f373-0104-4073-80ec-ac64a1798c6e"],
 " is defined to be  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalV]", "\[ScriptCapitalG]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         TemplateBox[{"v"},
          "Ket"], "\[Element]", "\[ScriptCapitalV]"}], "|", 
        RowBox[{
         OverscriptBox["G", "^"], 
         TemplateBox[{"v"},
          "Ket"]}]}], "=", 
       TemplateBox[{"v"},
        "Ket"]}], " ", ",", 
      RowBox[{"\[ForAll]", 
       RowBox[{"G", "\[Element]", "\[ScriptCapitalG]"}]}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"abbdfccc-23ce-49bb-a11c-4cfa953d4e94"],
 "."
}], "Notes",
 CellID->1305355882,ExpressionUUID->"c69dbdb9-e60c-4432-83ca-f474f7bd0f5e"]
