Cell[TextData[{
 "Now, let us examine all possible tensor products of ",
 StyleBox["three",
  FontSlant->"Italic"],
 " irreducible subspaces. This is relevant for the Clebsch-Gordan \
transformation on the symmetric group."
}], "ExampleText",
 CellID->1498390831,ExpressionUUID->"f5bad94d-de15-46ee-9473-fbefe8d92fdb"],

