 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1", "0", 
      FractionBox["1", "2"], 
      FractionBox["\[ImaginaryI]", "2"], 
      FractionBox["1", "4"], 
      FractionBox["\[ImaginaryI]", "4"]},
     {"0", "1", 
      RowBox[{"-", 
       FractionBox["\[ImaginaryI]", "2"]}], 
      FractionBox["1", "2"], 
      RowBox[{"-", 
       FractionBox["\[ImaginaryI]", "4"]}], 
      FractionBox["1", "4"]},
     {
      RowBox[{"-", 
       FractionBox["1", "2"]}], 
      FractionBox["\[ImaginaryI]", "2"], "1", "0", 
      FractionBox["1", "2"], 
      FractionBox["\[ImaginaryI]", "2"]},
     {
      RowBox[{"-", 
