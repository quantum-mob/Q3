  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 52, 37.711851}", 
    "history" -> {"12", "", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {"Bloch sphere"}, "specialkeywords" -> {}, 
    "tutorialcollectionlinks" -> {}, "index" -> True, "label" -> 
    "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> "QuantumMob/Q3",
     "status" -> "None", "summary" -> 
    "BlochVector[{c0, c1}] returns the coordinates of the point on the Bloch \
sphere corresponding to the pure state Ket[0]*c0 + Ket[1]*c1. \
BlochVector[mat] returns the coordinates of the point in the Bloch sphere \
corresponding to density matrix mat. BlochVector[expr] assumes expr to be \
expressed in terms of Ket or Pauli for unlabelled qubits, get the reduced \
density matrix for the first qubit, and finally returns the coordinates of \
the point in the Bloch sphere. BlochVector[expr, j] is similar to \
BlochVector[expr] but tracing out all qubits except for the jth qubit. \
BlochVector[expr, q] assumes that expr is expressed in terms of Ket or \
operators of the species q, get the reduced density matrix for q, and finally \
returns the coordinates of the point in the Bloch sphere.", "synonyms" -> {}, 
    "tabletags" -> {}, "title" -> "BlochVector", "titlemodifier" -> "", 
    "metadescription" -> "", "windowtitle" -> "BlochVector", "type" -> 
    "Symbol", "uri" -> "QuantumMob/Q3/ref/BlochVector"}},
