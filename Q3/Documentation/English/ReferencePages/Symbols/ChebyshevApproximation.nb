       RowBox[{"-", "1"}], ",", 
       RowBox[{"-", "0.5"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0.5", ",", "1"}], "}"}]}], "]"}]}], ";", 
  RowBox[{"gun", "=", 
   RowBox[{"ChebyshevApproximation", "[", 
