Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ghost", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"fun", "[", "x", "]"}], ",", 
       RowBox[{"gun", "[", "x", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], "]"}]}], ";", 
  RowBox[{"range", "=", 
   RowBox[{"Lookup", "[", 
    RowBox[{
     RowBox[{"AbsoluteOptions", "[", "ghost", "]"}], ",", "PlotRange"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fig1a", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"fun", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "range"}], ",", 
     RowBox[{"Filling", "->", "Bottom"}], ",", 
     RowBox[{"PlotStyle", "->", "None"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fig1b", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"fun", "[", "x", "]"}], ",", 
       RowBox[{"gun", "[", "x", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Dashed"}], "}"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<target\>\"", ",", "\"\<approx.\>\""}], "}"}]}]}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{"fig", "=", 
  RowBox[{"Show", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"fig1a", ",", "fig1b"}], "}"}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<f(x)\>\""}], "}"}]}]}], 
   "]"}]}]}], "Input",
