 Cell[BoxData[
  TemplateBox[{1},
   "Spacer1"]],ExpressionUUID->"4ae7e0ee-962f-4d7e-9ebd-bc603a9fc5f8"],
 "\"Parity\"",
 "\[NonBreakingSpace]\[NonBreakingSpace]",
 Cell["(3)", "ExampleCount",ExpressionUUID->
  "119667ee-b0ef-4eca-8ebf-50f8f46bd6ef"]
}], "ExampleSubsection", "ExampleSubsection",
