  RowBox[{"3", "*", 
   RowBox[{"x", "^", "2"}], "*", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "2"}], "*", "x"}], "]"}], "*", 
   RowBox[{"Sin", "[", 
