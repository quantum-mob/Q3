Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "\t", "ExampleDelimiter",ExpressionUUID->
   "4588da7c-6822-474b-9c0b-bf51dd1af7ba"],
  $Line = 0; Null]], "ExampleDelimiter",
 CellID->1193291372,ExpressionUUID->"d882c6bc-1dfe-4f34-9925-6058838eb815"],

Cell["This time, consider an odd function:", "ExampleText",
 CellID->2058452840,ExpressionUUID->"6b14243f-9765-4e2c-bc78-8d728aa3d62b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun", "[", "x_", "]"}], ":=", 
  RowBox[{"x", "*", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "5"}], 
     RowBox[{"x", "^", "2"}]}], "]"}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1675384076,ExpressionUUID->"1db2686c-5d2d-4859-a644-f28c701d684c"],

Cell[TextData[{
 "Make sure to the degree and parity satisfy ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   RowBox[{"2", "*", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Mod"]], "paclet:ref/Mod"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     RowBox[{
      StyleBox["d", "TI"], ",", "2"}], "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3f4b41bb-946f-4bfa-803c-67ccee840db2"],
 ":"
}], "ExampleText",
 CellID->1324746306,ExpressionUUID->"b20170a8-4b4e-4c42-b101-3aaee6da9618"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"gun", "=", 
  RowBox[{"ChebyshevApproximation", "[", 
   RowBox[{"fun", ",", "11", ",", 
    RowBox[{"\"\<Points\>\"", "->", "16"}], ",", 
    RowBox[{"\"\<Parity\>\"", "->", "False"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"new", "=", 
  RowBox[{"ChebyshevApproximation", "[", 
   RowBox[{"fun", ",", 
    RowBox[{"5", "->", 
     RowBox[{"-", "1"}]}], ",", 
    RowBox[{"\"\<Points\>\"", "->", "8"}], ",", 
    RowBox[{"\"\<Parity\>\"", "->", "True"}]}], "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->247904976,ExpressionUUID->"861c1b3c-8b33-4a7f-9b65-03596c0d66bb"],

