Cell["Consider an even function:", "ExampleText",
 CellID->1504522001,ExpressionUUID->"2ba7f8f4-3e9e-446e-8b24-0eb091aa5749"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fun", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{"x", "^", "2"}], "*", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "5"}], 
     RowBox[{"x", "^", "2"}]}], "]"}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1067981961,ExpressionUUID->"2bc469d8-fee5-496a-9304-d51f9218605f"],

Cell[TextData[{
 "Assuming the parity ",
 Cell[BoxData[
  RowBox[{"1", "-", 
   RowBox[{"2", "*", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Mod"]], "paclet:ref/Mod"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     RowBox[{
      StyleBox["d", "TI"], ",", "2"}], "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ef04597a-2d8e-40e6-89a0-869dea4dc80f"],
 " and actively exploiting it, the same level of error can be achieved by \
using only half the number of evaluation points:"
}], "ExampleText",
 CellID->1048723581,ExpressionUUID->"6cb2cc48-187a-4711-a654-09b6f3c6f5b6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"gun", "=", 
  RowBox[{"ChebyshevApproximation", "[", 
   RowBox[{"fun", ",", "10", ",", 
    RowBox[{"\"\<Points\>\"", "->", "16"}], ",", 
    RowBox[{"\"\<Parity\>\"", "->", "False"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"new", "=", 
  RowBox[{"ChebyshevApproximation", "[", 
   RowBox[{"fun", ",", 
    RowBox[{"5", "->", "1"}], ",", 
    RowBox[{"\"\<Points\>\"", "->", "8"}], ",", 
    RowBox[{"\"\<Parity\>\"", "->", "True"}]}], "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->904496901,ExpressionUUID->"fd88ee68-5297-4df4-af3a-dfb4829c8b4b"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TagBox["ChebyshevSeries",
    "SummaryHead"], "[", 
   DynamicModuleBox[{Typeset`open$$ = False, Typeset`embedState$$ = "Ready"}, 
    
    TemplateBox[{
      PaneSelectorBox[{False -> GridBox[{{
            PaneBox[
             ButtonBox[
              DynamicBox[
               FEPrivate`FrontEndResource["FEBitmaps", "SummaryBoxOpener"]], 
              ButtonFunction :> (Typeset`open$$ = True), Appearance -> None, 
              BaseStyle -> {}, Evaluator -> Automatic, Method -> 
              "Preemptive"], Alignment -> {Center, Center}, ImageSize -> 
             Dynamic[{
               Automatic, 
                3.5 (CurrentValue["FontCapHeight"]/AbsoluteCurrentValue[
                 Magnification])}]], 
            GridBox[{{
               RowBox[{
                 TagBox["\"Degree: \"", "SummaryItemAnnotation"], 
                 "\[InvisibleSpace]", 
                 TagBox["10", "SummaryItem"]}]}, {
