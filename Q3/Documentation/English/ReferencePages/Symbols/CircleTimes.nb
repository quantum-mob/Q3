Cell[TextData[{
 "When the input arguments are all vectors, more precisely, one-dimensional \
arrays, ",
 Cell[BoxData["CircleTimes"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9c6ba2c8-f006-450c-ad0d-dc6a6e6d415f"],
 " regards those one-dimensional arrays as column vectors and evaluates the \
direct product of them. The result is thus a one-dimensional array. This is \
clearly distinguished from ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["KroneckerProduct"]], "paclet:ref/KroneckerProduct"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ab87e6df-05b6-4ed4-93af-a8c7668d9ff3"],
 ". For example, consider the following three vectors."
}], "ExampleText",
 CellID->650828168,ExpressionUUID->"fab61a46-0f6a-4105-b56e-3c24118de317"],

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Complex", ",", "a", ",", "b", ",", "c"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"aa", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", "[", "1", "]"}], ",", 
     RowBox[{"a", "[", "2", "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bb", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"b", "[", "1", "]"}], ",", 
     RowBox[{"b", "[", "2", "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cc", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"c", "[", "1", "]"}], ",", 
     RowBox[{"c", "[", "2", "]"}]}], "}"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->263280016,ExpressionUUID->"6fe66040-1de3-4f86-b56a-1560ea77eff1"],

Cell["\<\
This gives the direct product of column vectors -- the result is a \
one-dimensional array.\
\>", "ExampleText",
 CellID->133224467,ExpressionUUID->"d526c5ad-2850-414a-b6e6-5cd1759fe708"],

