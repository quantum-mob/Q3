Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CircleTimes"]], "paclet:ref/CircleTimes"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ca324bde-67d9-49d6-a2f7-e4bf510009f3"],
 " is a built-in symbol with full name ",
 StyleBox["System`CircleTimes", "Input"],
 " but without any built-in meaning. It has been extended in ",
 StyleBox["Q3", "Input"],
 " either to represent the tensor products of Hilbert space vectors and \
operators or to evaluate the matrix direct product of matrices and column \
vectors."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"9fc52db6-1db8-425d-9e50-355f78599534"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

