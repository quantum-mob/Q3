Cell[TextData[{
 "To the contrary, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["KroneckerProduct"]], "paclet:ref/KroneckerProduct"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "555ebb60-9e87-47c9-b0b1-f0c78872127e"],
 " regards the first vector as a column vector, but the rest as row vectors. \
Hence, the result is a 2\[Times]4 matrix."
}], "ExampleText",
 CellID->623966254,ExpressionUUID->"e686161d-2e5d-4616-93ac-ebc204f5abb1"],

