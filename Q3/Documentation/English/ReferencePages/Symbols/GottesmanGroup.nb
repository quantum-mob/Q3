Cell[TextData[{
 "The binary symplectic group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"a02ca0b2-e888-4170-b462-593ddd190d80"],
 " alias ",
 ButtonBox["Gottesman group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalG]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"fc5a96ba-7eb5-404d-8f6a-aaba05918fd8"],
 " is isomorphic to the quotient group of the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"1574c5a5-be93-4f66-84cf-96e59fac506a"],
 " in the Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"d3c941d6-18ee-4531-befa-ab1ce3dc82c0"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalG]", "(", "n", ")"}], "\[Congruent]", 
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], "\[TildeEqual]", 
    
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"2bbcc7c6-ccd0-4200-b697-c6d82cf39d2b"],
 ". For this reason, in many cases especially in the context of quantum \
error-correction codes, the elements of binary symplectic group are called ",
 ButtonBox["Gottesman matrices",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanMatrix"],
 "."
}], "Notes",
 CellID->873179210,ExpressionUUID->"6c1ab9f6-5fd6-4088-b65a-5f56714e039a"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "76ce3778-14b4-48dc-a72d-dc8cb521c6a9"],
 " matrix is symplectic with respect to ",
 StyleBox["J",
  FontSlant->"Italic"],
 " if it satisfies the following condition,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "\[VeryThinSpace]", "J", "\[VeryThinSpace]", 
     SuperscriptBox["S", "T"]}], "=", "J"}], TraditionalForm]],ExpressionUUID->
  "a9d98066-b7ba-41f5-91bb-bc4fc0cb04ad"],
 " ,        ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", ":=", 
    RowBox[{"(", GridBox[{
       {"0", 
        SubscriptBox["I", "n"]},
       {
        RowBox[{"-", 
         SubscriptBox["I", "n"]}], "0"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "80ad7189-2370-4695-a23f-7cd21c58ed64"],
 " ."
}], "Notes",
 CellID->1031699036,ExpressionUUID->"44a86d44-b29d-4c63-9ea7-897eb38e979d"],

Cell[TextData[{
 "The order of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"3a2687ae-b279-40bc-b1db-6f0c3d17181f"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", 
     SuperscriptBox["n", "2"]], 
    RowBox[{
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "n"], "(", 
     RowBox[{
      SuperscriptBox["4", "k"], "-", "1"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"b929df2d-799a-4e12-b4bd-ba2de40a12fc"],
 "; see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Koenig and Smolin (2014)"]], 
    "https://doi.org/10.1063/1.4903507"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "a6140ce7-130e-463a-8223-dbb67c68113b"],
 "."
}], "Notes",
 CellID->1304849647,ExpressionUUID->"c4a182d2-c0ec-4384-8740-ec94098ad380"],

Cell[TextData[{
 "As of Q3 v2.14.15, the elements of the Gottesman group are constructed \
based on the algorithm suggested by ",
 ButtonBox["Koenig and Smolin (2014)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1063/1.4903507"], None}],
 ". A more efficient and simpler way was suggested by ",
 ButtonBox["van den Berg (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1109/qce52317.2021.00021"], None}],
 "."
}], "Notes",
 CellID->982671809,ExpressionUUID->"907de869-07cf-463e-a217-dccc4d9f960c"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

