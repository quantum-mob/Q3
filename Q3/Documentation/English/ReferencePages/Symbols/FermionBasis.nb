Cell[TextData[{
 "Both bases have been constructed so as to be optimal for the case when the \
charge and spin are conserved; hence the option \"Conserved\"",
 StyleBox["->{Number,Spin}",
  FontWeight->"Bold"],
 ". In \[LineSeparator]the sector of quantum number, say, (Q,S)=(0,0),"
}], "ExampleText",
 CellID->1917806647,ExpressionUUID->"47f62ad7-fe0c-42dd-919f-4320f5a606e8"],

