Cell[TextData[{
 "For fermions with ",
 StyleBox["\"Sea\"", "Input"],
 " vacuum, the flavor indices should be consistent. Otherwise, ",
 Cell[BoxData["FermionBasis"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6e98eef0-cb79-47e6-a75b-d70ab91c2b74"],
 " will give an unexpected result. Let\[CloseCurlyQuote]s take an example."
}], "ExampleText",
 CellID->461017331,ExpressionUUID->"ae22611b-b2b0-4310-b0ea-40b406a8dee5"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Fermion", ",", "c", ",", 
   RowBox[{"Spin", "\[Rule]", 
    RowBox[{"1", "/", "2"}]}], ",", 
   RowBox[{"Vacuum", "\[Rule]", "\"\<Sea\>\""}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->197283741,ExpressionUUID->"9a7951a4-d69b-449f-8b7e-584c601cbdd1"],

Cell[TextData[{
 "Below the orbital part ",
 StyleBox["c[1]", "Input"],
 " and ",
 StyleBox["c[2]", "Input"],
 " of operators ",
 StyleBox["c[1,Any]", "Input"],
 " and ",
 StyleBox["c[2,Any]", "Input"],
 ", respectively, are consistent with the ",
 StyleBox["\"Sea\"", "Input"],
 " vacuum and non-zero spin. Hence, the result is as expected."
}], "ExampleText",
 CellID->33084019,ExpressionUUID->"c9a011e9-c3aa-4436-8133-626cdc509a55"],

