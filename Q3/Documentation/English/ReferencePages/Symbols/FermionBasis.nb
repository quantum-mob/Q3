Cell[TextData[{
 "On the other hand, in the following example, the orbital part of the first \
operator ",
 StyleBox["c[Any]", "Input"],
 " is not consistent with the ",
 StyleBox["\"Sea\"", "Input"],
 " vacuum and non-zero spin. Therefore, ",
 StyleBox["c[Any]", "Input"],
 " will be regarded as spinless and is not handled properly ."
}], "ExampleText",
 CellID->1795299767,ExpressionUUID->"d137e0fc-74d8-4f60-8f48-369a7fd66f81"],

Cell[TextData[{
 "To see how the problem arises, let us first take a look at the result from ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FockAddSpin"]], "paclet:QuantumMob/Q3/ref/FockAddSpin", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b74ff3cc-53f2-4847-8704-7be3c76dcacf"],
 " on which ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FermionBasis"]], "paclet:QuantumMob/Q3/ref/FermionBasis", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c0da35c8-f620-486b-836d-2393f8058ddc"],
 " is based on for the spin conserved case."
}], "ExampleText",
 CellID->1457943619,ExpressionUUID->"702cf227-3b40-4563-a408-8c08241f05a7"],

