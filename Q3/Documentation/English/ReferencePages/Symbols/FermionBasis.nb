Cell["\<\
Fermion systems have relatively smaller (compared with bosonic systems) \
Hilbert space. Hence, one can construct the complete basis for the entire \
Hilbert space (yet the system cannot be so large as most realistic systems).\
\>", "ExampleText",
 CellID->1666385620,ExpressionUUID->"fec4d3f2-245a-4ae4-9b73-f6424454a8aa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bs0", "=", 
  RowBox[{"FermionBasis", "[", 
   RowBox[{
    RowBox[{"c", "@", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<Conserved\>\"", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<Number\>\"", ",", "\"\<Spin\>\""}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\"\<Representation\>\"", "\[Rule]", "\"\<Generators\>\""}]}], 
   "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1608874813,ExpressionUUID->"09a2db20-ac9d-48c3-bef4-2cb8b84b028b"],

