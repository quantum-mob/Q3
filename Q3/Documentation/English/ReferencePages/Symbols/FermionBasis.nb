Cell[TextData[{
 "Notice the difference between ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FermionBasis"]], "paclet:QuantumMob/Q3/ref/FermionBasis", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b7f54b87-cefc-46f6-9972-a4b25ca38ba7"],
 " and more general ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Basis"]], "paclet:QuantumMob/Q3/ref/Basis", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "23cf14e8-4322-4ba0-bc5d-d1082490b3e0"],
 "."
}], "Notes",
 CellID->624998404,ExpressionUUID->"770690e8-1e57-4076-9c3e-ec7c7fe98ac8"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FermionBasis"]], "paclet:QuantumMob/Q3/ref/FermionBasis", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
    StyleBox["n", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "daf2bffe-ebf9-4562-bfa8-1be25f4a9603"],
 " is quite different from ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FermionBasis"]], "paclet:QuantumMob/Q3/ref/FermionBasis", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}], ",", 
    RowBox[{"\"\<Conserved\>\"", "\[Rule]", "\"\<Number\>\""}]}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c16af80b-bf6c-49f7-8a43-ffc357f46911"],
 " unless the fermions are spinless (",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Spin"]], "paclet:QuantumMob/Q3/ref/Spin", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "=", "0"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "331eaf8f-c53d-45d0-832f-ff600360c7f2"],
 "). Even for the spinless case, the keys formats of the returned association \
as well as the arranging order of elements are different."
}], "Notes",
 CellID->1630897690,ExpressionUUID->"fd06409c-cb80-433b-80e5-3e9a38841d7b"],

