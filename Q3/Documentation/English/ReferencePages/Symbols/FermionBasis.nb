            Ket[Q3`Vacuum]]}, "RowWithSeparators"]},
        "RowDefault"],
       Q3`Multiply[
        Q3`Dagger[
         $CellContext`c[1, 
          Rational[1, 2]]], 
        Ket[Q3`Vacuum]]]}], "}"}]}], ",", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"2", ",", "0"}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", 
       InterpretationBox[
        TemplateBox[{
          TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
            InterpretationBox[
             TemplateBox[{"c", 
               
