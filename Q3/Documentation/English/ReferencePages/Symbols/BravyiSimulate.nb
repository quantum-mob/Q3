Cell["To verify the above result, solve the Lindblad equation:", "ExampleText",
 CellID->885622144,ExpressionUUID->"a513cd95-8863-4932-879c-3d8d50d83389"],

Cell[BoxData[
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"BravyiLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "$T", ",", 
       RowBox[{"4", "*", "$dt"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1723549137,ExpressionUUID->"92177b77-8f28-4d4d-ab63-7f2b53b1abac"],

Cell["\<\
Calculate the entanglement between the subsystem and the rest:\
\>", "ExampleText",
 CellID->1620316432,ExpressionUUID->"eb4d57ff-f46e-4fdf-aa3a-0a0b5016f8f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"negSol", "=", 
   RowBox[{"BravyiLogarithmicNegativity", "[", 
    RowBox[{"out", ",", "sub"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->132278913,ExpressionUUID->"16d9c3b0-58a7-4ec5-ba16-5d2f80128c81"],

Cell["Compare the two results:", "ExampleText",
 CellID->95302880,ExpressionUUID->"6d00e13a-dabf-42c6-924f-257a82ac7bdb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", 
    RowBox[{"{", 
     RowBox[{"negSol", ",", "negRho"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
