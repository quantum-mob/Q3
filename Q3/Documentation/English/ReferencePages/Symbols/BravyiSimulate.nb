 RowBox[{
  RowBox[{"{", 
   RowBox[{"ham", ",", "msr"}], "}"}], "=", 
  RowBox[{"HatanoNelsonModel", "[", 
   RowBox[{
    RowBox[{"$J", "/", "$\[Gamma]"}], ",", "1", ",", "$L"}], "]"}]}]], "Input",\

 CellProlog:>Needs["QuantumMob`Q3`"],
