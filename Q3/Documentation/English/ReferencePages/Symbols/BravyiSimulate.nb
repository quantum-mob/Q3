Cell["\<\
Construct an approximate density matrix , and calculate the entanglement \
between the subsystem and the rest:\
\>", "ExampleText",
 CellID->1788699700,ExpressionUUID->"a5441a43-8110-44a1-81ed-5cc0657828fd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"avg", "=", 
   RowBox[{"BravyiMean", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"negRho", "=", 
   RowBox[{"BravyiLogarithmicNegativity", "[", 
    RowBox[{"avg", ",", "sub"}], "]"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[12]:=",
 CellID->185629150,ExpressionUUID->"89d37901-e01b-46cf-8bb9-7af000696296"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", "negRho"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma] t\>\"", ",", "\"\<LN (L, L/2)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
