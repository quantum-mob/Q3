Cell[TextData[{
 "Calculate the ",
 StyleBox["mutual information",
  FontSlant->"Italic"],
 " (MI) between the subsystem and the rest:"
}], "ExampleText",
 CellID->1000811302,ExpressionUUID->"abf66d4f-c80f-4b04-9954-44db1312256b"],

