Cell[TextData[{
 "Calculate the ",
 StyleBox["logarithmic entanglement negativity",
  FontSlant->"Italic"],
 " (LN) between the subsystem and the rest:"
}], "ExampleText",
 CellID->492085590,ExpressionUUID->"be2af567-bccf-4575-9c02-9b42f8b8c1fb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"BravyiLogarithmicNegativity", "[", 
     RowBox[{"data", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1917312037,ExpressionUUID->"e7aaa681-baed-408d-822f-8feee34f989c"],

Cell[BoxData["1.514609`"], "EchoTiming",
 CellID->1896604639,ExpressionUUID->"c378da6b-3e43-4b1c-8b9d-b9e1e1fd2b01"]
}, Open  ]],

Cell["\<\
Plot the logarithmic negativity averaged over the quantum trajectories. Here, \
\[Gamma] refers to the damping rate, which equals to 1 in our unit system:\
\>", "ExampleText",
 CellID->1673927040,ExpressionUUID->"6ff5b262-d12e-4c9c-ae9e-82ba7f9df891"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Mean", "[", 
    RowBox[{"Re", "@", "neg"}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", "12"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\[ThinSpace]t\>\"", 
      ",", "\"\<\[LeftAngleBracket]LN \
(\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\), \
\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\)/2)\[RightAngleBracket]\>\""}], 
     "}"}]}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
