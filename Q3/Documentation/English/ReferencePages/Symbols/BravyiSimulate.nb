     RowBox[{"\"\<\[Gamma] t\>\"", ",", "\"\<LN (L, L/2)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
