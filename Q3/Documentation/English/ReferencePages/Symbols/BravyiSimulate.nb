Cell[TextData[{
 "Finally, calculate the ",
 StyleBox["logarithmic entanglement negativity",
  FontSlant->"Italic"],
 " (LN) in the mixed states (density matrices):"
}], "ExampleText",
 CellID->1233775756,ExpressionUUID->"6a3ff8f0-f11e-4b23-8a97-f3cbde464ec5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"BravyiMean", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"BravyiLogarithmicNegativity", "[", 
      RowBox[{"avg", ",", "kk"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->2114519307,ExpressionUUID->"1a3d6598-8808-4a58-9001-b53d5686a587"],

Cell[BoxData["0.039672`"], "EchoTiming",
 CellID->704781974,ExpressionUUID->"f629211b-d31e-4537-abfe-b2c9a8b68543"]
}, Open  ]],

Cell["\<\
Plot the logarithmic negativity in the mixed state. Here, \[Gamma] refers to \
the damping rate, which equals to 1 in our unit system:\
\>", "ExampleText",
 CellID->1350339219,ExpressionUUID->"93d0448f-91a3-420d-8802-e8709572d786"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", "negRho"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
