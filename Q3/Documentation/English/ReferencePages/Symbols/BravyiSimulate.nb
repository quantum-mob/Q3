Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "\t", "ExampleDelimiter",ExpressionUUID->
   "5417b258-f5eb-42f6-8686-f8e1fb00f27b"],
  $Line = 0; Null]], "ExampleDelimiter",
 CellID->792374113,ExpressionUUID->"e5cefa02-4189-4a09-9fb2-55a1e36e639c"],

Cell["To verify the above result, solve the Lindblad equation:", "ExampleText",
 CellID->885622144,ExpressionUUID->"56dad73d-fdf7-4bcf-b711-153f2ec48c8b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"BravyiLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "$T", ",", 
       RowBox[{"4", "*", "$dt"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1723549137,ExpressionUUID->"b0041ee1-25d6-460b-bf78-72637eb62f95"],

Cell["\<\
Calculate the entanglement between the subsystem and the rest:\
\>", "ExampleText",
 CellID->1620316432,ExpressionUUID->"bd78f622-d898-4477-bf56-6cfcc9ae2dbb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"negSol", "=", 
   RowBox[{"BravyiLogarithmicNegativity", "[", 
    RowBox[{"out", ",", "sub"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->132278913,ExpressionUUID->"6a85b046-86a3-44af-90bb-80506f01d5b5"],

Cell["Compare the two results:", "ExampleText",
 CellID->95302880,ExpressionUUID->"dc81e5a6-e14e-43e9-910e-4e300cbfde4f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", 
    RowBox[{"{", 
     RowBox[{"negSol", ",", "negRho"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", "\"\<\[EmptyCircle]\>\""}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma] t\>\"", ",", "\"\<LN (L, L/2)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->566116146,ExpressionUUID->"2b0b06dc-dd9a-44f6-af3a-e875bb6e459d"],

