Cell[TextData[{
 "Calculate the ",
 StyleBox["mutual information",
  FontSlant->"Italic"],
 " (MI) between the subsystem and the rest:"
}], "ExampleText",
 CellID->1000811302,ExpressionUUID->"2c2420c6-868f-449c-b647-e16b58abaa65"],

