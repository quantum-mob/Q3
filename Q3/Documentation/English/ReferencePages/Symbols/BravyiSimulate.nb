Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiSimulate"]], 
         "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["jmp", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f20327f9-8e9b-4130-887d-3e5595c6c221"],
     "\[LineSeparator]solves the quantum master equation for a \
non-interacting dissipative fermionic many-body system by using the Monte \
Carlo simulation method (also known as the ",
     StyleBox["quantum jump approach",
      FontSlant->"Italic"],
     " or ",
     StyleBox["quantum trajectory method",
      FontSlant->"Italic"],
     "). The model is specified by the single-particle Hamiltonian ",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3cbe0636-7421-4caf-89d0-c5795f8d1362"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiHermitian"]], 
        "paclet:QuantumMob/Q3/ref/BravyiHermitian", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "47a772ef-d8a2-4558-9e87-2a34ea4b18e4"],
     " form and the quantum jump operators are specified by ",
     Cell[BoxData[
      StyleBox["jmp", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6e2f1d22-f4f9-42cc-9480-6aa4f50b788d"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3243f73d-33b8-4229-97e9-9eaba7ae754b"],
     " or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9916fb7a-9543-4510-b5a1-576d576424e9"],
     " form. The simulation starts from the initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ddec714d-6c1c-4b44-8e3f-077efad8a1f4"],
     " in the  ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "42bd69c8-a80a-483d-b803-11646f624d84"],
     " form at time 0 and runs to time \[Tau] in steps of size ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8957aaa9-c2f0-4dce-b316-5a698f1ae07b"],
     "."
    }],ExpressionUUID->"0db5f299-66d1-4395-819a-ad0a6a8fff14"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiSimulate"]], 
         "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["jmp", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f9d21044-6f6b-4d25-bc4e-9fbb00eff7de"],
     "\[LineSeparator]collects states in steps of ",
     Cell[BoxData[
      RowBox[{
       StyleBox["k", "TI"], "\[Times]", 
       StyleBox["dt", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f3aea51d-752a-4a2c-8b2a-825ee05e26a9"],
     " (rather than ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e6f68352-78ca-4a04-9fe3-285876d3c031"],
     "), where ",
     Cell[BoxData[
      StyleBox["k", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f33cbfc6-44a4-4837-b5c6-68a807e69546"],
     " must be an integer or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["All"]], "paclet:ref/All"},
       "RefLink",
       BaseStyle->{"InlineFormula"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6b2a340d-ad55-4bbc-b598-a44e531d3e60"],
     "."
    }],ExpressionUUID->"ddb8a54d-c733-442f-ae5c-c399f7d1ad99"]}
  }]], "Usage",
 CellID->1058277371,ExpressionUUID->"2850ddfb-65d8-4a56-9b44-35b987d7af6e"]
}, Open  ]],

