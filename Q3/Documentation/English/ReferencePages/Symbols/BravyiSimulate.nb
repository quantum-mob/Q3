Cell[TextData[{
 "Finally, calculate the ",
 StyleBox["logarithmic entanglement negativity",
  FontSlant->"Italic"],
 " (LN) in the mixed states (density matrices):"
}], "ExampleText",
 CellID->1233775756,ExpressionUUID->"fc6a1a5d-4cf3-43f0-97af-5ea074f71352"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"BravyiMean", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"BravyiLogarithmicNegativity", "[", 
      RowBox[{"avg", ",", "kk"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->2114519307,ExpressionUUID->"22df658d-8d83-421e-b76b-5d3d356b88f3"],

Cell[BoxData["0.039672`"], "EchoTiming",
 CellID->704781974,ExpressionUUID->"26a57143-fad2-409b-a867-65edc5bd4745"]
}, Open  ]],

Cell["\<\
Plot the logarithmic negativity in the mixed state. Here, \[Gamma] refers to \
the damping rate, which equals to 1 in our unit system:\
\>", "ExampleText",
 CellID->1350339219,ExpressionUUID->"b8985de0-d7d9-47db-9c4d-61bb35d291ff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", "negRho"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
