Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiSimulate"]], 
         "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["jmp", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f877ad22-518d-441c-a4a3-58db804190ae"],
     "\[LineSeparator]solves the quantum master equation for a \
non-interacting dissipative fermionic many-body system by using the Monte \
Carlo simulation method (also known as the ",
     StyleBox["quantum jump approach",
      FontSlant->"Italic"],
     " or ",
     StyleBox["quantum trajectory method",
      FontSlant->"Italic"],
     "). The model is specified by the single-particle Hamiltonian ",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "478979d0-a2fe-4c57-8d4a-71ff2a7e2a35"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiHermitian"]], 
        "paclet:QuantumMob/Q3/ref/BravyiHermitian", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "7a999edc-126e-45e7-b149-ba8fca73deec"],
     " form and the quantum jump operators are specified by ",
     Cell[BoxData[
      StyleBox["jmp", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6ee2350a-bd93-4fa4-bb55-a9acb8734bf6"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "cf9a6d28-37b1-4d1b-a560-06354c02fa58"],
     " or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c86c86d1-7d6d-4e66-a141-f9cf66eab7f1"],
     " form. The simulation starts from the initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "13b6fab1-11d0-45e4-ac10-2b3dbef87b8a"],
     " in the  ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "61420ea3-ca38-4288-b599-e172c0a30f18"],
     " form at time 0 and runs to time \[Tau] in steps of size ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9f86d00c-d5b3-4ad6-bc5e-243da040dc2b"],
     "."
    }],ExpressionUUID->"694f19ca-e1f0-4c0a-83c5-e66c8c130d49"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiSimulate"]], 
         "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["jmp", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "068412bc-50a4-43e7-b7fe-9f7ccf97589e"],
     "\[LineSeparator]collects states in steps of ",
     Cell[BoxData[
      RowBox[{
       StyleBox["k", "TI"], "\[Times]", 
       StyleBox["dt", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c2152e16-a5c4-4009-94c1-b2bbc423a3ad"],
     " (rather than ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "0816f177-3f5f-4078-b7a6-53b7c510be49"],
     "), where ",
     Cell[BoxData[
      StyleBox["k", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9c5621e0-d6c9-4533-8e83-136ad06e81b2"],
     " must be an integer or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["All"]], "paclet:ref/All"},
       "RefLink",
       BaseStyle->{"InlineFormula"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "895a9b6b-eb02-44a9-a017-061b6c3b15d8"],
     "."
    }],ExpressionUUID->"77acfff7-144f-4daa-b723-9028c5f69387"]}
  }]], "Usage",
 CellID->1058277371,ExpressionUUID->"56be5a11-1bcd-4b8b-84f1-73ecc6358e0b"]
}, Open  ]],

