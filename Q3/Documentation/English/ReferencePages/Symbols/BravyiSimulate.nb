Cell["\<\
Construct an approximate density matrix , and calculate the entanglement \
between the subsystem and the rest:\
\>", "ExampleText",
 CellID->1788699700,ExpressionUUID->"eb48c96c-8084-4071-b48b-c8da77205107"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"avg", "=", 
   RowBox[{"BravyiMean", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"negRho", "=", 
   RowBox[{"BravyiLogarithmicNegativity", "[", 
    RowBox[{"avg", ",", "sub"}], "]"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[12]:=",
