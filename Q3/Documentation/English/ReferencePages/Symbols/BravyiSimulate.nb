Cell["\<\
Let us now examine various entanglement properties. Take the first half of \
the fermion modes as a subsystem:\
\>", "ExampleText",
 CellID->478283074,ExpressionUUID->"98212939-de79-4526-b313-0725e0b846ba"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"kk", "=", 
  RowBox[{"Range", "[", 
   RowBox[{"$n", "/", "2"}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1346002203,ExpressionUUID->"4bc0c51b-0e2d-4aaa-bafc-554f704d1aac"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "2"}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->1967204880,ExpressionUUID->"620a922f-9128-4ad4-827f-8d074fa3272a"]
}, Open  ]],

Cell[TextData[{
 "Calculate the ",
 StyleBox["entanglement entropy",
  FontSlant->"Italic"],
 " (EE) between the subsystem and the rest:"
}], "ExampleText",
 CellID->2108780712,ExpressionUUID->"59135305-10e4-4365-9276-881579680fbf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"ee", "=", 
    RowBox[{"BravyiEntanglementEntropy", "[", 
     RowBox[{"data", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1203043985,ExpressionUUID->"bf01b6a6-ab64-4fcb-8cd4-ee447ed2f3e3"],

Cell[BoxData["0.236214`"], "EchoTiming",
 CellID->1588370754,ExpressionUUID->"ba786f49-12a4-4091-aafb-44f24ada95a9"]
}, Open  ]],

Cell["\<\
Plot the entanglement entropy averaged over the quantum trajectories. Here, \
\[Gamma] refers to the damping rate, which equals to 1 in our unit system:\
\>", "ExampleText",
 CellID->961579217,ExpressionUUID->"5cbd835b-718a-4108-a2a2-f326b0f96c00"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Mean", "[", "ee", "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", "12"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\[ThinSpace]t\>\"", 
      ",", "\"\<\[LeftAngleBracket]EE \
(\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\), \
\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\)/2)\[RightAngleBracket]\>\""}], 
     "}"}]}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1422494101,ExpressionUUID->"ab937886-1bf6-4a10-9a3b-a7e275051865"],

