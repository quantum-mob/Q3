Cell["\<\
Let us now examine various entanglement properties. Take the first half of \
the fermion modes as a subsystem:\
\>", "ExampleText",
 CellID->478283074,ExpressionUUID->"91c14157-b45e-4a59-8917-5745bf09def2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"kk", "=", 
  RowBox[{"Range", "[", 
   RowBox[{"$n", "/", "2"}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1346002203,ExpressionUUID->"796cd655-0165-45f9-8653-d1c7ddbbe836"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "2"}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->1967204880,ExpressionUUID->"9f659217-0429-4083-ae11-dd44a86897f1"]
}, Open  ]],

Cell[TextData[{
 "Calculate the ",
 StyleBox["entanglement entropy",
  FontSlant->"Italic"],
 " (EE) between the subsystem and the rest:"
}], "ExampleText",
 CellID->2108780712,ExpressionUUID->"2f913783-e998-44d2-bab8-154aefd10e9a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"ee", "=", 
    RowBox[{"BravyiEntanglementEntropy", "[", 
     RowBox[{"data", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1203043985,ExpressionUUID->"2c1280cf-98c9-4634-a636-7fbd2da00667"],

Cell[BoxData["0.236214`"], "EchoTiming",
 CellID->1588370754,ExpressionUUID->"0ff01d90-81d6-41d9-a8e5-c81c5f1ce446"]
}, Open  ]],

Cell["\<\
Plot the entanglement entropy averaged over the quantum trajectories. Here, \
\[Gamma] refers to the damping rate, which equals to 1 in our unit system:\
\>", "ExampleText",
 CellID->961579217,ExpressionUUID->"35bc3ef6-e808-4f23-b826-980c76c22248"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Mean", "[", "ee", "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", "12"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\[ThinSpace]t\>\"", 
      ",", "\"\<\[LeftAngleBracket]EE \
(\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\), \
\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\)/2)\[RightAngleBracket]\>\""}], 
     "}"}]}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1422494101,ExpressionUUID->"01abf493-f9ce-4caf-ad43-b2c2dc1656b7"],

