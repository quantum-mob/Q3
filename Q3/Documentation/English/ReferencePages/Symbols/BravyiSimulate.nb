Cell[TextData[{
 "It returns a collection of quantum trajectories, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["data", "TI"], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["trj", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["trj", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "383514fc-665e-4cd3-961e-fea49f5cf8c5"],
 ": each trajectory stores a sequence of quantum states, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["trj", "TI"], 
    StyleBox["i", "TI"]], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["ws", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["1", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     SubscriptBox[
      StyleBox["ws", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["2", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["ws", "TI"], 
      StyleBox["in", "TI"]]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2d9b262e-31d1-40f0-8108-3748f557de00"],
 ", where every quantum state is in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8095aa88-4ed4-4742-bf7b-683f2d35f21a"],
 " form."
}], "Notes",
 CellID->1967207486,ExpressionUUID->"a5f39e24-74e6-4864-a342-efe1f8c4612d"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  RowBox[{
   StyleBox["jmp", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5e77b077-2b27-4946-9196-13b03819a663"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"]}], 
   TraditionalForm]],ExpressionUUID->"b50a5f35-41c1-46e8-ac4c-b00158363074"],
 " (notice the factor of 2), where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "i"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["m", 
       RowBox[{"i", "\[VeryThinSpace]", "1"}]], ",", 
      SubscriptBox["m", 
       RowBox[{"i", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]", ",", 
      SubscriptBox["m", 
       RowBox[{"i", ",", 
        RowBox[{"2", "n"}]}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6f1ecc3a-b708-4ae1-83ff-6b3bec2ba198"],
 " is the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["i", "th"], TraditionalForm]],ExpressionUUID->
  "a63b2677-5752-4ed4-af93-bfbd460c1d51"],
 " row of matrix ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "f4e0adaa-7d5a-4bd4-a9a1-0e82ac99a6be"],
 ", gives the decoherence rate of the quantum jump operator\[LineSeparator]\t \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "e1978189-8d5a-4e79-bc13-1f382049b969"],
 " (not necessarily a dressed mode)."
}], "Notes",
 CellID->725440945,ExpressionUUID->"9b72f615-7542-4390-a66b-c102007a5bc4"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  RowBox[{
   StyleBox["jmp", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMeasurement"]], 
      "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2b7b9a08-5a19-4d3e-bf41-25ca2c06724e"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", 
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "4"]}], 
   TraditionalForm]],ExpressionUUID->"3b855465-a26a-4681-bd0a-24850f8eae59"],
 " (notice the power of 4 rather than 2), gives the decoherence rate of the \
quantum jump operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["b", "i", "\[Dagger]"], 
     SubscriptBox["b", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "cf60abd4-4a94-47d9-9546-f88af4db702a"],
 " association with the dressed Fermion mode\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "97fce689-fe46-4716-8e3f-7500e95a89cc"],
 " (unnormalized)."
}], "Notes",
 CellID->1069290512,ExpressionUUID->"9e47f21f-759d-4028-98a2-08a9ebe644d0"],

Cell[TextData[{
 "The accuracy and speed of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiSimulate"]], "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e9b079c4-c42e-42a3-9320-7965063af8e6"],
 " may be adjusted by parameter ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["$BravyiMinorSteps"]], 
    "paclet:QuantumMob/Q3/ref/$BravyiMinorSteps", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1da17a6c-890e-4653-a6a9-08851c9536e0"],
 ". The bigger this parameter is, the accuracy is increased but ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiSimulate"]], "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8265daa8-6bb2-410d-b824-bf6e173291e5"],
 " becomes slower, and vice versa."
}], "Notes",
 CellID->1521906099,ExpressionUUID->"e9fbb16a-f9ac-4eb5-b6b7-a583105e02c1"],

Cell[TextData[{
 "For the non-unitary evolution governed by the non-Hermitian part of the \
effective Hamiltonian, BravyiSimulate internally uses the 4th-order ",
 StyleBox["Runge-Kutta method",
  FontSlant->"Italic"],
 ". The step size is controlled by parameter ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["$BravyiMinorSteps"]], 
    "paclet:QuantumMob/Q3/ref/$BravyiMinorSteps", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "38b4b7c1-02d9-4550-95e6-7cd2b8f041a2"],
 "."
}], "Notes",
 CellID->859340705,ExpressionUUID->"8fe243d5-1661-4078-aa0c-53a31329e938"],

