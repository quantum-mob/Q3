Cell["To verify the above result, solve the Lindblad equation:", "ExampleText",
 CellID->259242180,ExpressionUUID->"ebd362b1-f0f4-4af6-abda-e0f76e1a4fcd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"BravyiLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "$T", ",", 
       RowBox[{"4", "*", "$dt"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1986483144,ExpressionUUID->"bb5881ab-0518-4e97-a6f0-cad297a9040d"],

Cell["\<\
Calculate the entanglement between the subsystem and the rest:\
\>", "ExampleText",
 CellID->2041424946,ExpressionUUID->"adc9bda1-7557-4aee-b399-d5da56fff5ea"],

Cell[BoxData[
 RowBox[{
  RowBox[{"negSol", "=", 
   RowBox[{"BravyiLogarithmicNegativity", "[", 
    RowBox[{"out", ",", "sub"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->2030322950,ExpressionUUID->"43b2e64c-bdb5-4411-bbe0-634db8c014ce"],

Cell["Compare the two results:", "ExampleText",
 CellID->371480877,ExpressionUUID->"dc7c928e-51e4-480a-b9ad-168e78a2cb16"],

Cell[CellGroupData[{

