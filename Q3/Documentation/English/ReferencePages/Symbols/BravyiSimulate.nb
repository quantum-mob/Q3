Cell["To verify the above result, solve the Lindblad equation:", "ExampleText",
 CellID->259242180,ExpressionUUID->"b7dc7d1c-81d7-45bd-8679-1ca1035f16fb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"BravyiLindbladSolve", "[", 
    RowBox[{"ham", ",", "jmp", ",", "in", ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "$T", ",", 
       RowBox[{"4", "*", "$dt"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1986483144,ExpressionUUID->"d60fef67-7b05-4a3e-8a16-9150cb633922"],

Cell["\<\
Calculate the entanglement between the subsystem and the rest:\
\>", "ExampleText",
 CellID->2041424946,ExpressionUUID->"5203c708-3002-45c1-84a4-b368cf2536b6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"negSol", "=", 
   RowBox[{"BravyiLogarithmicNegativity", "[", 
    RowBox[{"out", ",", "sub"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->2030322950,ExpressionUUID->"bd370953-5bf0-46c6-b1fd-b45f386a7bcb"],

Cell["Compare the two results:", "ExampleText",
