Cell[TextData[{
 "It returns a collection of quantum trajectories, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["data", "TI"], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["trj", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["trj", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "35cc34c9-01af-4917-9bca-f6ac34b37a51"],
 ": each trajectory stores a sequence of quantum states, ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["trj", "TI"], 
    StyleBox["i", "TI"]], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["ws", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["1", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     SubscriptBox[
      StyleBox["ws", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["2", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["ws", "TI"], 
      StyleBox["in", "TI"]]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f72b1037-e5fb-43a0-8c1e-d7f22c12e73b"],
 ", where every quantum state is in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a812f326-3352-48e3-92e0-871f94780dfe"],
 " form."
}], "Notes",
 CellID->1967207486,ExpressionUUID->"0fc719f0-48d9-4c2f-aaa9-311a296644a0"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  RowBox[{
   StyleBox["jmp", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e855c47f-46ca-4e64-8a6b-481c57053f01"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", 
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"]}], 
   TraditionalForm]],ExpressionUUID->"1d685783-766b-4875-bf35-8a7360d14782"],
 " (notice the factor of 2), where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "i"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["m", 
       RowBox[{"i", "\[VeryThinSpace]", "1"}]], ",", 
      SubscriptBox["m", 
       RowBox[{"i", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]", ",", 
      SubscriptBox["m", 
       RowBox[{"i", ",", 
        RowBox[{"2", "n"}]}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "1d98324f-b6b6-4f0b-8504-318bbcd45168"],
 " is the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["i", "th"], TraditionalForm]],ExpressionUUID->
  "fe05bd9f-886c-4aa1-ad9e-e688eae420cc"],
 " row of matrix ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "0ac4ec36-8f16-4a6b-a5fc-1881c5c8d59a"],
 ", gives the decoherence rate of the quantum jump operator\[LineSeparator]\t \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "0015822d-67eb-45eb-b843-a336694a9f81"],
 " (not necessarily a dressed mode)."
}], "Notes",
 CellID->725440945,ExpressionUUID->"9d8dd399-e4f0-4391-8987-28490a57240f"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  RowBox[{
   StyleBox["jmp", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMeasurement"]], 
      "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3c2f6acd-10f2-450f-88ca-a56199da0bb3"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", 
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "4"]}], 
   TraditionalForm]],ExpressionUUID->"1b65e4c9-6de5-47f6-a204-8787c9bfce73"],
 " (notice the power of 4 rather than 2), gives the decoherence rate of the \
quantum jump operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["b", "i", "\[Dagger]"], 
     SubscriptBox["b", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "7d77cf51-4d1e-4ef5-a121-84d1b7efeb7e"],
 " association with the dressed Fermion mode\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "65e368dd-3f30-4bd2-9c32-96d5a6223faf"],
 " (unnormalized)."
}], "Notes",
 CellID->1069290512,ExpressionUUID->"33d014b6-56b7-4dc3-a6c3-53dcc57c43f7"],

Cell[TextData[{
 "The accuracy and speed of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiSimulate"]], "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f8a4b22d-c731-4468-9137-e52acd9b3274"],
 " may be adjusted by parameter ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["$BravyiMinorSteps"]], 
    "paclet:QuantumMob/Q3/ref/$BravyiMinorSteps", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b559bb53-f70d-4cd8-9176-81a1c3789faf"],
 ". The bigger this parameter is, the accuracy is increased but ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiSimulate"]], "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "90caf181-e977-4584-9a29-7b73ec2a6e6a"],
 " becomes slower, and vice versa."
}], "Notes",
 CellID->1521906099,ExpressionUUID->"0055747a-5919-443d-ad5b-88e17394e14a"],

Cell[TextData[{
 "For the non-unitary evolution governed by the non-Hermitian part of the \
effective Hamiltonian, BravyiSimulate internally uses the 4th-order ",
 StyleBox["Runge-Kutta method",
  FontSlant->"Italic"],
 ". The step size is controlled by parameter ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["$BravyiMinorSteps"]], 
    "paclet:QuantumMob/Q3/ref/$BravyiMinorSteps", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "871c7b9a-305c-44dc-9310-f20e6f6d8a6e"],
 "."
}], "Notes",
 CellID->859340705,ExpressionUUID->"7ae3051c-0ddb-4c5f-9d52-6ee8a8c96b98"],

