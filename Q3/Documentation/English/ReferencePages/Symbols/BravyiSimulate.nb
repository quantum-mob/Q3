Cell[TextData[{
 "Calculate the ",
 StyleBox["logarithmic entanglement negativity",
  FontSlant->"Italic"],
 " (LN) between the subsystem and the rest:"
}], "ExampleText",
 CellID->492085590,ExpressionUUID->"6ea4c1c7-e3cd-4afd-97ff-7729ecfb9443"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"BravyiLogarithmicNegativity", "[", 
     RowBox[{"data", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1917312037,ExpressionUUID->"611dbe27-3ab4-4844-94af-ad518e3f9bfa"],

Cell[BoxData["1.514609`"], "EchoTiming",
 CellID->1896604639,ExpressionUUID->"7b11d143-ce8e-4578-ac6f-61e89d6f731f"]
}, Open  ]],

Cell["\<\
Plot the logarithmic negativity averaged over the quantum trajectories. Here, \
\[Gamma] refers to the damping rate, which equals to 1 in our unit system:\
\>", "ExampleText",
 CellID->1673927040,ExpressionUUID->"480eff37-1f5f-461b-a3ca-6c4c941677c1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Mean", "[", 
    RowBox[{"Re", "@", "neg"}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", 
    RowBox[{"{", 
     RowBox[{"Automatic", ",", " ", "12"}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\[ThinSpace]t\>\"", 
      ",", "\"\<\[LeftAngleBracket]LN \
(\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\), \
\!\(\*StyleBox[\"L\",FontSlant->\"Italic\"]\)/2)\[RightAngleBracket]\>\""}], 
     "}"}]}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
