Cell[TextData[{
 "Define the ",
 StyleBox["Hatano",
  IgnoreSpellCheck->True],
 "-Nelson model."
}], "ExampleText",
 CellID->1728295122,ExpressionUUID->"71b48f6f-bad1-4007-b973-7c2edcb20769"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "HatanoNelsonModel", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"HatanoNelsonModel", "[", 
   RowBox[{"J_", ",", "\[Gamma]_", ",", "L_Integer"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ham", ",", "cff", ",", "msr"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ham", "=", 
      RowBox[{"PlusTopple", "[", 
       RowBox[{
        RowBox[{"-", "J"}], "*", 
        RowBox[{"One", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"L", ",", "L"}], "}"}], ",", "1"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ham", "=", 
      RowBox[{"BravyiHermitian", "[", 
       RowBox[{"NambuHermitian", "@", 
        RowBox[{"{", 
         RowBox[{"ham", ",", "0"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"cff", "=", 
      RowBox[{
       RowBox[{"One", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], "]"}], "+", 
       RowBox[{"I", "*", 
        RowBox[{"One", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], ",", "1"}], 
         "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"cff", "=", 
      RowBox[{"ArrayFlatten", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"cff", ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0", ",", "cff"}], "}"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"msr", "=", 
      RowBox[{
       RowBox[{"Surd", "[", 
        RowBox[{"\[Gamma]", ",", "4"}], "]"}], "*", 
       RowBox[{"BravyiMeasurement", "[", 
        RowBox[{"Canonicalize", "@", 
         RowBox[{"NambuMeasurement", "@", "cff"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"ham", ",", "msr"}], "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->592306132,ExpressionUUID->"02d35347-fa15-4ec3-b3b4-06eda00f4503"],

Cell["Set the model:", "ExampleText",
 CellID->1302456679,ExpressionUUID->"f757f305-b861-430b-be99-aadb6f12d21e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$J", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$\[Gamma]", "=", "0.5"}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1088590082,ExpressionUUID->"2ea66e8c-b618-43ec-9ba9-3e4a5717f23f"],

Cell[CellGroupData[{

