Cell[TextData[{
 "The ",
 StyleBox["quantum oracle",
  FontSlant->"Italic"],
 " is an essential entity of the ",
 StyleBox["quantum query model",
  FontSlant->"Italic"],
 " of computation."
}], "Notes",
 CellID->755583080,ExpressionUUID->"b81fd767-9f8a-4f7e-9bfd-360b342f635d"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", ":", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "m"]}], "\[Rule]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], "n"]}], TraditionalForm]],
  ExpressionUUID->"54a37a8f-0408-4d34-8140-ecf4732c9a13"],
 " must be defined properly by an association of the form ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["f", "TI"], "[", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["c", "TI"], 
       StyleBox["m", "TI"]]}], "}"}], "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["t", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["t", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["t", "TI"], 
      StyleBox["n", "TI"]]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1777ad3c-a0fb-4b38-9714-5790375e0df5"],
 " or ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["f", "TI"], "[", 
    StyleBox["c", "TI"], "]"}], "=", 
   StyleBox["t", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3a6857a3-a067-49ba-a96c-ef2c042167fa"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", ":=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["c", "1"], 
       SubscriptBox["c", "2"], 
       SubscriptBox["\[Ellipsis]c", "m"]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"10cc9d2d-df99-40e4-960b-5511d84d7f9d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", ":=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["t", "1"], 
       SubscriptBox["t", "2"], 
       SubscriptBox["\[Ellipsis]t", "n"]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"9abc5f68-ec04-4f7f-a3b9-f50ec076dfbb"],
 "."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"97b94448-0aa8-4317-8afd-ff4c020585c1"],

Cell[TextData[{
 "The unitary operator corresponds to the mapping ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"|", 
            StyleBox["c", "TI"]}], "\[RightAngleBracket]"}], 
          "\[CircleTimes]"}], "|", 
         StyleBox["t", "TI"]}], "\[RightAngleBracket]"}], "\[Rule]", 
       RowBox[{"|", 
        StyleBox["c", "TI"]}]}], "\[RightAngleBracket]"}], "\[CircleTimes]"}],
     "|", 
    RowBox[{
     StyleBox[
      RowBox[{"f", 
       RowBox[{"(", "c", ")"}]}], "TI"], "\[CirclePlus]", 
     StyleBox["t", "TI"]}]}], "\[RightAngleBracket]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f0ede4e4-64b6-4cfb-a642-a8af898a076b"],
 "."
}], "Notes",
 CellID->599398300,ExpressionUUID->"8259a2ba-3062-4285-928e-67cce0562965"],

