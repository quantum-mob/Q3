Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "3c07ee6e-d814-4f1e-8661-f5cc87c428c5"],
 " be a finite group and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"65a7327a-e801-480f-9166-707eda67c672"],
 " the basis of its group algebra. For each element ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "71e45a5f-ce0b-418c-b907-2aabdc24153e"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "8781b578-6290-4694-9846-7b667ca2ece0"],
 ", define a linear map ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["L", "^"], "(", "g", ")"}], TraditionalForm]],
  ExpressionUUID->"a4d0b878-5617-42d3-bf4f-343f3d29a53c"],
 " by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"g", "\[VeryThinSpace]", "h"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "ce220bcd-2c10-4875-987f-ca59c5b5a911"],
 "\[LineSeparator]for all elements ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "d3904cd9-bf38-4d2a-b283-d6e3de9f8c37"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "482d2364-7ec4-41e7-9855-b59ec4a70910"],
 ". It is called the ",
 StyleBox["left regular representation",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "25365cd2-9b04-4077-9b45-06feed9d1b0c"],
 ". In the matrix form, the left regular representation is given by\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["L", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
     SubscriptBox["g", "k"], ")"}], "=", 
    TemplateBox[{
      SubscriptBox["g", "i"], 
      RowBox[{
        SubscriptBox["g", "k"], 
        SubscriptBox["g", "j"]}]},
     "BraKet"]}], TraditionalForm]],ExpressionUUID->
  "85d11134-b9ae-4a11-8a26-6241e122b1ee"],
 "."
}], "Notes",
 CellID->1359449983,ExpressionUUID->"cd135da9-bd49-474c-ad64-36adf763215b"],

Cell[TextData[{
 "Similarly, a linear map ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["R", "^"], "(", "g", ")"}], TraditionalForm]],
  ExpressionUUID->"5426354b-5ce3-46a8-9a61-c5434d12d0b3"],
 " defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"h", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "29972d68-ba8e-475c-8816-b1d3ea73fae5"],
 "  \[LineSeparator]is called the ",
 StyleBox["right regular representation",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "ef9debe2-bc3d-4887-a356-6dfa243d2c90"],
 ". In the matrix representation, it is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["R", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
     SubscriptBox["g", "k"], ")"}], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["g", "i"], 
       RowBox[{
         SubscriptBox["g", "j"], 
         SubsuperscriptBox["g", "k", 
          RowBox[{"-", "1"}]]}]},
      "BraKet"], "=", 
     TemplateBox[{
       RowBox[{
         SubscriptBox["g", "i"], 
         SubscriptBox["g", "k"]}], 
       SubscriptBox["g", "j"]},
      "BraKet"]}]}], TraditionalForm]],ExpressionUUID->
  "00a29450-2207-47da-a12f-79803c19fa46"],
 " ."
}], "Notes",
 CellID->1139465644,ExpressionUUID->"b5e7d007-8803-4630-abf2-bfc0f05cfde7"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

