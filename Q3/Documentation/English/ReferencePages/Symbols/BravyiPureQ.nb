Cell[TextData[{
 "A Bravyi state (i.e., fermionic Gaussian state) with covariance matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "e82a0879-f1c5-4ede-aa50-6480f4ab35ba"],
 " is a pure state if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["V", "T"], "V"}], "=", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["V", "2"]}], "=", "I"}]}], TraditionalForm]],
  ExpressionUUID->"cb3ead27-3686-47a0-8714-8dae072c2520"],
 "."
}], "Notes",
 CellID->1602308148,ExpressionUUID->"2982bce2-3439-4848-9048-dd619a8c70ae"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

