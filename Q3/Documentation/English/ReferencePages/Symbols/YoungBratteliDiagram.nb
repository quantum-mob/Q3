Cell[TextData[{
 "Given a finite group or compact Lie group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "9d6add94-1d20-4393-956d-f6fbc4c64cbb"],
 ", let\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalG]", ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[ScriptCapitalG]", "m"], "\[Superset]", "\[Ellipsis]", "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "2"], "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "1"], "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "0"]}], ":=", 
     RowBox[{"{", "1", "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "79fdf64b-37fb-4c15-9cdd-805e72674efc"],
 "\[LineSeparator]be a tower of subgroups of length ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "40903d39-bce5-4e47-b895-b0dd84b7de44"],
 " for ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "389de1b5-1e3a-4483-be01-57774464d6fb"],
 ". The corresponding ",
 StyleBox["Bratteli diagram",
  FontSlant->"Italic"],
 " is a leveled graph whose nodes of level ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    "m"}], TraditionalForm]],ExpressionUUID->
  "597e8101-2478-4447-af72-d8e2d721134c"],
 " are in one-to-one correspondence with the (inequivalent) irreducible \
representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "41e8b0aa-3ce9-4353-9319-a536241d02c7"],
 ". Conventionally, the vertices in the diagram are referred to by the \
representation with which they are associated. The number of edges from an \
irreducible representation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "1fc91324-2ad4-46a6-917b-5896b1c3e4c0"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "a8ae642d-64e6-479f-861f-964754925484"],
 "  to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "7fefdfd9-f57d-4a85-8d85-a0e04cc7d07b"],
 "  of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "3f3a695a-78e9-45de-b1c1-a57d77bf404e"],
 " is equal to the ",
 StyleBox["multiplicity",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "4279dd7c-5428-42f0-aa27-37f5b377491f"],
 " of  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "b7f10310-74cc-4a10-9b59-ae55cd713085"],
 " in the restriction of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "fc390ea0-146e-4b5b-9551-975da87cff19"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "6088307b-12f7-4772-842e-e72082b96ce9"],
 ". A Bratteli diagram for a given tower is a rooted tree starting from a \
unique irreducible representation of the trivial group."
}], "Notes",
 CellID->1643613333,ExpressionUUID->"8b77e8ba-8aaa-4943-a1b1-50f028442176"],

Cell[TextData[{
 "If the branching for each ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "k"], "\[Superset]", 
    SubscriptBox["G", 
     RowBox[{"k", "-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "f1b6ca85-5ddf-4300-b0d1-6a517a74d10e"],
 " is multiplicity-free (i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "k"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "25df546f-b813-43d8-81c4-41c2c5911bd1"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "k"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "bf93ad70-a85e-43f2-856f-0445fde434b5"],
 " for all ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "a3bca112-9514-43d7-885b-69a466962766"],
 "), the Bratteli diagram is said to be ",
 StyleBox["multiplicity-free",
  FontSlant->"Italic"],
 " and the tower of subgroup is called ",
 StyleBox["canonical",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->2081566209,ExpressionUUID->"285cca06-b7ea-4bd4-9de3-4e55168cc5ab"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungBratteliDiagram"]], 
     "paclet:QuantumMob/Q3/ref/YoungBratteliDiagram", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c44c13d5-cf21-4374-9d71-7e842803e141"],
 " constructs the Bratteli diagram corresponding to the canonical tower\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalS]", "n"], "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", 
     RowBox[{"n", "-", "1"}]], "\[Superset]", "\[Ellipsis]", "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", "2"], "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", "1"]}], TraditionalForm]],
  ExpressionUUID->"9ab901bf-083f-41e3-824f-a75389f4057a"],
 "\nof subgroups for the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "a5c813d8-cbc3-4672-8aa5-ce5d4c63179c"],
 " of degree ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "769b5462-80d6-471d-92e8-769470172df8"],
 ". Each vertex is a Young diagram referring to the corresponding irreducible \
representation. Each pair of vertices are connected by a single edge (if at \
all), that is, the diagram is ",
 StyleBox["multiplicity-free",
  FontSlant->"Italic"],
 " since the subgroup tower is ",
 StyleBox["canonical",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1227707711,ExpressionUUID->"eb843bf9-52f8-4576-8da9-f0efd0df5ec4"],

Cell[TextData[{
 "For a fixed node ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "933ae75e-d632-4354-bca6-6a5a55719da2"],
 " at the final level ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "60dfee33-1e38-4ec9-984c-028056302e18"],
 ", each path from the top node can be labeled equivalently by a ",
 ButtonBox["Young vector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungVector"],
 ", ",
 ButtonBox["standard Young tableau",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungTableau"],
 ", or a ",
 ButtonBox["Gelfand-Young pattern",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandYoungPatternQ"],
 "."
}], "Notes",
 CellID->1046913857,ExpressionUUID->"2ff77897-33ac-46a3-9542-97746b4e23eb"],

Cell[TextData[{
 "A subgroup-adapted basis adapted to this canonical tower of subgroups is \
called a Young-Yamanouchi basis of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "bab0a7e2-0c3b-4318-91b6-b0f749c09796"],
 ". ",
 ButtonBox["Young's normal representation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungNormalRepresentation"],
 " is an example."
}], "Notes",
 CellID->1435483002,ExpressionUUID->"8373aabe-0674-454b-a3ca-bb38daa26bf8"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

