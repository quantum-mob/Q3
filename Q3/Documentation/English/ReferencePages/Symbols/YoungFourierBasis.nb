 CellID->1795093597,ExpressionUUID->"c73ad200-1836-4666-9e5b-aebcd8dd9755"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bs", "=", 
  RowBox[{"YoungFourierBasis", "[", 
