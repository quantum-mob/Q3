Cell[TextData[{
 "When ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "f622d61c-ec04-4e86-91e7-9c31d31e9c29"],
 " is the ",
 StyleBox["symmetric group",
  FontSlant->"Italic"],
 ", we call the regular basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{"g"},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "542efe8a-44aa-4f12-ad61-36c2780ebe4b"],
 " the ",
 StyleBox["Young regular basis",
  FontSlant->"Italic"],
 " and the Fourier basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "b36eb40e-2c49-4743-be0d-fca4325b8445"],
 " the ",
 StyleBox["Young-Fourier basis",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1744323879,ExpressionUUID->"e5616bde-0a23-4454-8ff0-8fa7655766de"]
