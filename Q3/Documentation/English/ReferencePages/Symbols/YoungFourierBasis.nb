Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"0a9139d4-e5ea-4625-9050-426233010913"],
 " is the ",
 StyleBox["right regular basis",
  FontSlant->"Italic"],
 " of group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "e6707241-6e28-4fba-a9f3-0d354d72eadd"],
 ", i.e.,  the canonical basis of the vector space that carries the ",
 StyleBox["right regular representation",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "92752263-d08e-40aa-9b2a-db8b40e3d90f"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5d1b8fb0-40c4-4bfc-9b86-3ff8b6c1bb37"],
 ". For all elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "bb40fc4e-39b6-4da9-984a-6bd620356ede"],
 " and ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "90098e2c-1728-4dd1-9c98-cccb223c8108"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "acc9f5c4-0bf9-4aae-94d7-6966e2b7671d"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"h", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "8cde2771-00ac-409d-9da6-546c94f80b36"],
 " ."
}], "Notes",
 CellID->1048209744,ExpressionUUID->"6c5e209f-7d36-455c-b493-1bda53079449"],

Cell[TextData[{
 "The ",
 StyleBox["right Fourier basis",
  FontSlant->"Italic"],
 " consists of vectors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "dfb93888-0ff5-4bf3-8e71-adeed9011dde"],
 " defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]], 
     TemplateBox[{"g"},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "5f2c3d05-53cd-469b-8cd4-026a1de90eee"],
 "\[LineSeparator]for each irreducible representation  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"ddbf9f7c-2b1c-4928-a5cb-7691c17a7157"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "bda8fb85-ea2e-464d-a10c-54efbea81e29"],
 " and each index ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ",", 
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "0a5d1c19-8a02-4d25-a660-d42d44904cbc"],
 ". The basis change from the canonical to Fourier basis is called the ",
 StyleBox["quantum Fourier transform over group",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "51f7f212-4a94-4e8e-ae47-72b3341abeff"],
 " or simply the ",
 StyleBox["generalized quantum Fourier transform",
  FontSlant->"Italic"],
 ". The inverse transform gives\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"g"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "=", "1"}]}], 
      SubscriptBox["d", "\[Lambda]"]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], " ", 
     SuperscriptBox[
      RowBox[{
       SqrtBox[
        FractionBox[
         SubscriptBox["d", "\[Lambda]"], 
         RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
        ")"}], "]"}], "*"]}]}], TraditionalForm]],ExpressionUUID->
  "7d86b2b7-ea93-42fb-b10c-d3ca5eb1cfe3"],
 " ,\nwhere the first summation is over all inequivalent irreducible \
representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "f4428a0b-f5c5-4fd0-b75f-bbb6fe94e84f"],
 ". Note that the dimension of an irreducible representation ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "a6a5d3ff-9608-433d-9016-4a22ec300ead"],
 " of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "418bdcf4-0022-4ca9-b4c0-392dd56ba0cc"],
 " always divides the order of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "ea327b49-11fa-409a-8219-70b83fb583bb"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
     "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], "/", 
     RowBox[{"dim", "(", "\[Lambda]", ")"}]}], "\[Element]", 
    "\[DoubleStruckCapitalZ]"}], TraditionalForm]],ExpressionUUID->
  "cd3161bf-8438-48e1-a0c1-0dd7ba4df860"],
 "."
}], "Notes",
 CellID->1790577104,ExpressionUUID->"be0b1ee8-904c-4d9a-bf5a-4cab2f08ca2f"],

Cell[TextData[{
 "Under the group action, the Fourier basis transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "d1565dc0-1d2c-4a04-ae7d-2b973008b7d5"],
 "\[LineSeparator]with index ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "c5aaa024-0cbd-4893-9ed7-3e5b5538c538"],
 " labeling the multiplicity space. Note that every basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a58743b6-644d-432a-9c58-d8b8723a6967"],
 " transforms in the same way regardless of index ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f4edbf15-c184-4bbe-8b29-f8da6f88841d"],
 ". That is to say, in the Fourier basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "80e3b333-c117-4a2f-8da7-bb3a7697f216"],
 ", the right regular representation ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "9fe59f87-8c68-491d-bae3-eeff5ea316e6"],
 " is block-diagonal in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "g", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], "\[VeryThinSpace]", 
     RowBox[{
      SubscriptBox["I", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"a0d8cfe9-1c5d-461a-b102-8641ffc5794b"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "5cbe015c-a5a6-4235-8450-443e3c9048df"],
 " refers to the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "\[Lambda]"], "\[Times]", 
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "2461e32a-0a0f-49d9-8f9b-a23562d4edca"],
 " identity matrix in the multiplicity space."
}], "Notes",
 CellID->882427163,ExpressionUUID->"882c699c-a6fa-426f-a892-116d88754acb"],

Cell[TextData[{
 "Setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FourierParameters"]], "paclet:ref/FourierParameters"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{"\"\<Right\>\"", ",", " ", "\"\<Right\>\""}], "}"}]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "30dc0a79-9744-4aec-bd61-127c50a8614d"],
 " (default) implements the above type of generalized quantum Fourier \
transform. The first ",
 Cell[BoxData["\"\<Right\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ebbe6edf-4775-41fa-a44e-0510a844b308"],
 " refers to the right regular representation and the second ",
 Cell[BoxData["\"\<Right\>\""], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0e6cedd8-7e34-4e0d-80b6-29aee84680df"],
 " indicates that the irreducible space is to the right of the multiplicity \
space."
}], "Notes",
 CellID->1151071605,ExpressionUUID->"1789906d-8378-43a5-a734-cf96d12e8704"],

Cell[TextData[{
 "If the ",
 StyleBox["left regular representation",
  FontSlant->"Italic"],
 " is concerned, the canonical basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"3b662eb9-a46c-43f3-9205-f7aeea905ccd"],
 " transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"g", "\[VeryThinSpace]", "h"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "d688c025-3d76-427f-9597-1b96b24a6e82"],
 " .\[LineSeparator]In this case, the ",
 StyleBox["left Fourier basis",
  FontSlant->"Italic"],
 " vectors are defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]], 
     TemplateBox[{"g"},
      "Ket"], 
     SubscriptBox[
      RowBox[{
       SqrtBox[
        FractionBox[
         SubscriptBox["d", "\[Lambda]"], 
         RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], "[", 
       RowBox[{
        SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]], ")"}], "]"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"c368186f-5cd0-44c4-91e2-c013a4c7ad84"],
 " .\[LineSeparator]Here, notice the input argument  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["g", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "601fc854-3186-49ff-84fb-3bb31908b790"],
 " of matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SuperscriptBox["g", 
     RowBox[{"-", "1"}]], ")"}], TraditionalForm]],ExpressionUUID->
  "51b4a94b-9991-4a12-a3e8-fbd4f0900800"],
 ". The inverse transform is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"g"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"j", "\[VeryThinSpace]", "i"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "b1454820-5440-40c7-9026-1414163e109a"],
 " .\[LineSeparator]Here, notice the reversed indices in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalGamma]", 
     RowBox[{"j", "\[VeryThinSpace]", "i"}], "\[Lambda]"], "(", "g", ")"}], 
   TraditionalForm]],ExpressionUUID->"502d5e69-e77c-4ea4-b953-e2051cd171d0"],
 ". Under the group action, the left Fourier basis transforms as\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "244fca7d-2819-44e7-934a-51350c8fe51d"],
 "\[LineSeparator]and hence, in the left Fourier basis,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"L", "(", "g", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], "\[VeryThinSpace]", 
     RowBox[{
      SubscriptBox["I", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"a4b2868f-c303-4d73-a6cf-adc3d0719ad6"],
 " ."
}], "Notes",
 CellID->519159934,ExpressionUUID->"84e55184-e4e4-4c7b-83f3-37f3dd960e1c"],

Cell[TextData[{
 "Setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["FourierParameters"]], "paclet:ref/FourierParameters"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{"\"\<Left\>\"", ",", " ", "\"\<Right\>\""}], "}"}]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c8dc71e0-5cf0-467e-9f96-19c8a85ecfa2"],
 " implements the above type of generalized quantum Fourier transform."
}], "Notes",
 CellID->935160286,ExpressionUUID->"d0f71027-1b54-4a95-aa10-043e3d5646b5"],

