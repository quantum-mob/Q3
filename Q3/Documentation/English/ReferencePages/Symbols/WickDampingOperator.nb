Cell[TextData[{
 "For quantum jump operators (Lindblad operators) ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "i"], TraditionalForm]],ExpressionUUID->
  "79d394c0-98b2-4b86-8065-a88a16baf33f"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalGamma]", ":=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["\[CapitalSigma]", "i"], 
      SubsuperscriptBox["L", "i", "\[Dagger]"], 
      SubscriptBox["L", "i"]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalSigma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubsuperscriptBox["a", "i", "\[Dagger]"], 
       SubscriptBox["g", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["a", "j"]}], "+", "\[Gamma]"}]}]}], TraditionalForm]],
  ExpressionUUID->"00055a1a-add2-47b8-b031-25510ed02718"],
 ". Then, ",
 Cell[BoxData[
  RowBox[{
   StyleBox["dmp", "TI"], ":=", 
   StyleBox["g", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "77d88e9a-6e7d-4c23-986b-ff8e99467a5f"],
 " and ",
 Cell[BoxData[
  RowBox[{
   StyleBox["gmm", "TI"], ":=", 
   StyleBox["\[Gamma]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "61475f41-ce0e-425d-b8d1-0cd6e3f927e1"],
 "."
}], "Notes",
