Cell[TextData[{
 Cell[BoxData["Topple"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "71629906-906a-410f-ba70-6d73069c2907"],
 " is similar to ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ConjugateTranspose"]], "paclet:ref/ConjugateTranspose"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "27d3afc1-541c-4bbe-b3a7-162368b58df1"],
 ", but applies ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Dagger"]], "paclet:QuantumMob/Q3/ref/Dagger", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4b8fb2c3-d9ac-4f20-b97e-e40c3f346d14"],
 " instead of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Conjugate"]], "paclet:ref/Conjugate"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d68bdcd4-9cac-4780-8a80-784deefdbdd4"],
 ". Therefore, it acts also on a tensor of operators (not just numbers)."
}], "Notes",
 CellID->1803572420,ExpressionUUID->"bc654f9e-5e09-497e-81b7-8ff875e91647"]
}, Dynamic[CurrentValue[
