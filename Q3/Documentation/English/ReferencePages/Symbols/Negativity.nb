Cell[TextData[{
 "The ",
 StyleBox["negativity",
  FontSlant->"Italic"],
 " is an entanglement monotone for quantum states (whether pure or mixed), \
quantitatively measuring quantum entanglement."
}], "Notes",
 CellID->1614280326,ExpressionUUID->"852cc236-9513-42ac-8073-452ff45ff141"],

Cell[TextData[{
 "For a mixed state \[Rho] of a bipartite system consisting of subsystems ",
 StyleBox["A",
  FontSlant->"Italic"],
 " and ",
 StyleBox["B",
  FontSlant->"Italic"],
 ", the negativity is defined by ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     SubscriptBox[
      RowBox[{"\[LeftDoubleBracketingBar]", 
       SuperscriptBox["\[Rho]", 
        StyleBox[
         SubscriptBox["T", "B"],
         FontSlant->"Italic"]], "\[RightDoubleBracketingBar]"}], "tr"], "-", 
     "1"}], ")"}], "/", "2"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d627680d-dee0-424e-8589-9476041d02e8"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Rho]", 
    SubscriptBox["T", "B"]], TraditionalForm]],ExpressionUUID->
  "2c5e91dd-c722-4574-a16b-6285239f145a"],
 " denotes the partial transpose with respect to subsystem ",
 StyleBox["B",
  FontSlant->"Italic"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{
   "\[LeftDoubleBracketingBar]", "\[CenterEllipsis]", 
    "\[RightDoubleBracketingBar]"}], "tr"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "16ef7b07-1aeb-4174-b2a2-f69ac672e099"],
 " indicates the ",
 ButtonBox["trace norm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/TraceNorm"],
 " of operators or matrices."
}], "Notes",
 CellID->453625225,ExpressionUUID->"eeb1686b-052c-4b01-9dc6-aa97bccf035a"],

Cell["\<\
The negativity is manifestly convex (Vidal and Werner, 2002).\
\>", "Notes",
 CellID->884593971,ExpressionUUID->"66a9591d-63ff-41ec-8b79-4044d798902c"],

Cell["\<\
A drawback of the negativity is that it is not additive. In this respect, the \
logarithmic negativity, which is manifestly additive, is often regarded a \
more suitable entanglement monotone.\
\>", "Notes",
 CellID->1897658230,ExpressionUUID->"6f2af13f-e948-4776-955e-6c1899575f34"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

