Cell[TextData[{
 "It merely provides a shortcut tool for convenience as most calculations in \
fermionic quantum computing are based on ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " operators for efficiency while sometimes the ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " representation is more intuitive."
}], "Notes",
 CellID->1899870126,ExpressionUUID->"4e20855c-1daf-4250-86d5-3b90573d101f"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

