Cell["Now consider Fermions the vacuum of which is the Fermi sea.", \
"ExampleText",
 CellID->595488024,ExpressionUUID->"e2f6585b-01bc-4934-864f-8c7a900df359"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Fermion", ",", "d", ",", 
   RowBox[{"Vacuum", "\[Rule]", "\"\<Sea\>\""}]}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->836133574,ExpressionUUID->"d75cac62-25d4-4bb8-910d-8442a0cb2a39"],

Cell["\<\
For such Fermions, the first flavor index is special and represents the wave \
number below (negative) or above (positive) the Fermi sea.\
\>", "ExampleText",
 CellID->1120788202,ExpressionUUID->"406c6cb4-9c26-4528-9dad-49809208633e"],

