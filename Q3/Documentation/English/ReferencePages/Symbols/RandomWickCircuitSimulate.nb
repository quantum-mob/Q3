Cell["\<\
Calculate the mutual information (MI) between the first and second halves of \
the system:\
\>", "ExampleText",
 CellID->922854080,ExpressionUUID->"2ca3ebbd-71fd-4a7d-8aa2-0215b9333583"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"mi", "=", 
    RowBox[{"WickMutualInformation", "[", 
     RowBox[{"trj", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "mi", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1281623926,ExpressionUUID->"e109ea38-6a22-4c53-83b1-2df078458479"],

Cell[BoxData["0.347092`"], "EchoTiming",
 CellID->1839902135,ExpressionUUID->"db2ffbf8-c09d-447a-b333-f8aef8a6eccc"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"100", ",", "31"}], "}"}]], "Output",
 CellLabel->"Out[3]=",
 CellID->1618149792,ExpressionUUID->"46a28f41-3b84-4cc9-9d70-3d7845a13aee"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Mean", "[", 
    RowBox[{"Re", "@", "mi"}], "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\[ThinSpace]\!\(\*StyleBox[\"t\",FontSlant->\"\
Italic\"]\)\>\"", 
