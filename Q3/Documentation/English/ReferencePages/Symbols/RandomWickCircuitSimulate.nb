Cell["\<\
Calculate the mutual information (MI) between the first and second halves of \
the system:\
\>", "ExampleText",
 CellID->726519029,ExpressionUUID->"850b6152-2b64-4896-9f1f-7280d03ebec8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"mi", "=", 
    RowBox[{"WickMutualInformation", "[", 
     RowBox[{"trj", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "mi", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->13303561,ExpressionUUID->"ceadd40c-e167-4cdb-95e2-ccf0a077b513"],

Cell[BoxData["0.358225`"], "EchoTiming",
 CellID->832627124,ExpressionUUID->"3be4fe50-b986-40e2-bc27-b0ac72cb13b2"],

