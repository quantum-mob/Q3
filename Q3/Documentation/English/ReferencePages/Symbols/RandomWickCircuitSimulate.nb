Cell[TextData[{
 "The probability distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "\[Tau]", ")"}], TraditionalForm]],ExpressionUUID->
  "09f1f6cf-6afb-48a4-8136-6643e619af44"],
 " of the interaction time ",
 Cell[BoxData[
  FormBox["\[Tau]", TraditionalForm]],ExpressionUUID->
  "f9cf5c26-de61-4288-8b27-5ffe914ad790"],
 " is given by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "\[Tau]", ")"}], "\[Proportional]", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "n"}], "\[VeryThinSpace]", "\[Tau]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"40ece6de-cc82-4a16-8bcf-45f7c38713e1"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "93be22fe-bed1-423f-a8e7-7d6a892fb33e"],
 " is the number of Dirac fermion modes. The unit system is chosen such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Gamma]", "\[VeryThinSpace]", "\[Tau]"}], "\[RightTeeArrow]", 
    "\[Tau]"}], TraditionalForm]],ExpressionUUID->
  "da5c378d-15e0-42f2-8cdd-e4a9ae44a03c"],
