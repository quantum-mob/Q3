 RowBox[{"{", 
  RowBox[{"100", ",", "31"}], "}"}]], "Output",
 CellLabel->"Out[3]=",
 CellID->960629216,ExpressionUUID->"96998887-ad0d-47a9-a2a4-ef53054acc9e"]
}, Open  ]],

