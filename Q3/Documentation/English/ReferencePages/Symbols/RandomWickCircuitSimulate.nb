Cell["\<\
Calculate the entanglement entropy (EE) between the first and second halves \
of the system:\
\>", "ExampleText",
 CellID->1713979101,ExpressionUUID->"9433570b-7298-4f14-a1cd-b50ac418a3d1"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"ee", "=", 
    RowBox[{"Mean", "@", 
     RowBox[{"WickEntanglementEntropy", "[", 
      RowBox[{"trj", ",", "kk"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "ee", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->501109649,ExpressionUUID->"29d90bdd-d067-4cee-a030-e137454f9c52"],

