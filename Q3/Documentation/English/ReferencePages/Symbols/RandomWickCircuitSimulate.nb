Construct the approximate density matrix, and calculate the logarithmic \
negativity (LN) of it between the first and second halves of the system:\
\>", "ExampleText",
 CellID->837958276,ExpressionUUID->"aeff3595-7ea6-4333-bbc4-93cc650c7b08"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"Mean", "@", 
      RowBox[{"WickGreen", "[", "trj", "]"}]}]}], ";", "\[IndentingNewLine]", 
    
    RowBox[{"negRho", "=", 
