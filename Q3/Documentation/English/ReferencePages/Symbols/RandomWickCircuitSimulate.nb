Cell[TextData[{
 "The interaction time ",
 Cell[BoxData[
  FormBox["\[Tau]", TraditionalForm]],ExpressionUUID->
  "91010f95-1fa6-4a94-b68a-5124f65f0751"],
 " is uniformly distributed over the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"0", ",", 
     SubscriptBox["\[Tau]", "max"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "31b75ba4-6943-42d1-8586-d9ccbc04192f"],
 " with\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[Cell[TextData[Cell[BoxData[
    FormBox[
     RowBox[{
      SubscriptBox["\[Tau]", "max"], ":=", 
      RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
       RowBox[{"n", "/", 
        SubscriptBox["E", "max"]}]}]}], TraditionalForm]],ExpressionUUID->
    "ebe535df-68a9-415a-98f3-924b8a4e610f"]],ExpressionUUID->
    "323b55ef-590e-46e5-b11d-7e2965c1388b"], TraditionalForm]],ExpressionUUID->
  "b69961a6-0231-498f-834f-dfc8ac062e8c"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "a0be3484-397f-4d43-8470-7f5e819c3db0"],
 " is the number of Dirac fermion modes and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "max"], TraditionalForm]],ExpressionUUID->
  "3fccb756-b7b9-4c4d-aed1-f39f598b4490"],
 " is the largest energy scale of the Hamiltonian."
}], "ExampleText",
 CellID->1753522467,ExpressionUUID->"c9292fa9-df3c-47c0-b7bc-5d656367b8e5"],

