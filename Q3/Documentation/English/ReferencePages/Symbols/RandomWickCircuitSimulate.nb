Cell["\<\
Calculate the logarithmic negativity (LN) between the first and second halves \
of the system:\
\>", "ExampleText",
 CellID->948574183,ExpressionUUID->"620e1201-6ae2-4dfc-8518-2489287800a4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$n", "/", "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"neg", "=", 
    RowBox[{"WickLogarithmicNegativity", "[", 
     RowBox[{"trj", ",", "kk"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "neg", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1915182000,ExpressionUUID->"1176feec-30cb-42a9-aeb9-c567fc75e946"],

Cell[BoxData["0.322378`"], "EchoTiming",
