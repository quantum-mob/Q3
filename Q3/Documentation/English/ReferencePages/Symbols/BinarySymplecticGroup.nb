\>", "ExampleText",
 CellID->1899902730,ExpressionUUID->"9da53622-6cf8-46b6-a6cf-5ce033d156d4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "/@", 
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
