Cell[TextData[{
 "The binary symplectic group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"2b616643-4fad-4dff-aeb8-bafb8f3bfa24"],
 " alias ",
 ButtonBox["Gottesman group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalG]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"ef51e865-1099-49b6-95e3-ea826f82f501"],
 " is isomorphic to the quotient group of the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"5b95c1e7-e1bf-42b5-8852-22183dd8ae6d"],
 " in the Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"781b9f34-72ad-412f-9c46-51aa753a5e74"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalG]", "(", "n", ")"}], "\[Congruent]", 
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], "\[TildeEqual]", 
    
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"e7cd90ff-2ca0-4a9c-8d78-aefd90a3f7c9"],
 ". For this reason, in many cases especially in the context of quantum \
error-correction codes, the elements of binary symplectic group are called ",
 ButtonBox["Gottesman matrices",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanMatrix"],
 "."
}], "Notes",
 CellID->873179210,ExpressionUUID->"f99c18d6-4c45-4d0c-b368-56b80ecee32c"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"], "\[Times]", "2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ef0a8da6-235d-4b0d-877c-a57662e766f0"],
 " matrix is symplectic with respect to ",
 StyleBox["J",
  FontSlant->"Italic"],
 " if it satisfies the following condition,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "\[VeryThinSpace]", "J", "\[VeryThinSpace]", 
     SuperscriptBox["S", "T"]}], "=", "J"}], TraditionalForm]],ExpressionUUID->
  "855d088b-ffb2-4fc0-a099-0cadb05dc4cf"],
 " ,        ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", ":=", 
    RowBox[{"(", GridBox[{
       {"0", 
        SubscriptBox["I", "n"]},
       {
        RowBox[{"-", 
         SubscriptBox["I", "n"]}], "0"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "459bcee2-4b92-45c8-aee9-9263264559c2"],
 " ."
}], "Notes",
 CellID->1031699036,ExpressionUUID->"66de25fb-91ff-4a7e-9a07-468c4374066a"],

Cell[TextData[{
 "The order of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"cc763052-491a-49bd-b501-65dc512538a9"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", 
     SuperscriptBox["n", "2"]], 
    RowBox[{
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "n"], "(", 
     RowBox[{
      SuperscriptBox["4", "k"], "-", "1"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"8f1324b0-26f4-443f-83d8-29ff5f8519c7"],
 "; see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Koenig and Smolin (2014)"]], 
    "https://doi.org/10.1063/1.4903507"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "a2edc47d-c321-4663-81a8-c5f6a17fb9f4"],
 "."
}], "Notes",
 CellID->1304849647,ExpressionUUID->"2e55e03d-f256-4ad4-99ce-fabee83277c9"],

Cell[TextData[{
 "As of Q3 v2.14.15, the elements of the Gottesman group are constructed \
based on the algorithm suggested by ",
 ButtonBox["Koenig and Smolin (2014)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1063/1.4903507"], None}],
 ". A more efficient and simpler way was suggested by ",
 ButtonBox["van den Berg (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1109/qce52317.2021.00021"], None}],
 "."
}], "Notes",
 CellID->982671809,ExpressionUUID->"18aa3a1a-072d-406b-8a33-46c30f67b7bd"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

