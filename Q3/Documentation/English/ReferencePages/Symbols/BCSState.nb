Cell[TextData[{
 "A generalized BCS ground state is given by \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"BCS"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{"exp", "(", 
      RowBox[{
       FractionBox["1", "2"], 
       UnderscriptBox["\[CapitalSigma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["W", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubsuperscriptBox["a", "i", "\[Dagger]"], 
       SubsuperscriptBox["a", "j", "\[Dagger]"]}], ")"}], 
     TemplateBox[{
       RowBox[{"\[InvisibleSpace]", "\[SpaceIndicator]"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "87279e12-7d7d-4e39-93f7-87d354550557"],
 " , \nwhere ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "eee27ce1-284d-4bfb-bdb8-c4a8f012885a"],
 " is a complex anti-symmetric matrix. The matrix elements ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["W", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],ExpressionUUID->
  "d2984e23-d243-44ed-a0c4-dea7727cdfd6"],
 " characterizes the pairing correlation between fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "i"], TraditionalForm]],ExpressionUUID->
  "86d1232c-ed25-4f8a-9398-4f379aef4430"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "j"], TraditionalForm]],ExpressionUUID->
  "d4249e97-8696-4997-a4f9-d704bc3b4140"],
 "."
}], "Notes",
 CellID->277860432,ExpressionUUID->"00af58f5-9a6a-4559-8786-20cad9ea6b99"],

Cell[TextData[{
 "Note that an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "3717da32-276e-443c-8725-45049d9d39ff"],
 " anti-symmetric matrix ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "431b190d-280f-4298-8ea5-ebb27bcbe7f3"],
 " may always be put into the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "=", 
    RowBox[{"U", "\[VeryThinSpace]", "\[CapitalLambda]", "\[VeryThinSpace]", 
     SuperscriptBox["U", "T"]}]}], TraditionalForm]],ExpressionUUID->
  "91111535-fc92-420c-a516-4f04e979aaa1"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "f366e178-12d5-424c-bf41-59ab7f472ee8"],
 " is a unitary matrix and\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", "=", 
    RowBox[{
     UnderoverscriptBox["\[CirclePlus]", 
      RowBox[{"k", "=", "1"}], 
      RowBox[{"n", "/", "2"}]], 
     RowBox[{"(", GridBox[{
        {"0", 
         SubscriptBox["\[Lambda]", "k"]},
        {
         RowBox[{"-", 
          SubscriptBox["\[Lambda]", "k"]}], "0"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "28046177-2863-43b4-a015-ea8ecc200fff"],
 "      (",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "94ecedc7-ac74-4833-b95b-a768e77a5072"],
 " even)\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", "=", 
    RowBox[{
     UnderoverscriptBox["\[CirclePlus]", 
      RowBox[{"k", "=", "1"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"n", "-", "1"}], ")"}], "/", "2"}]], 
     RowBox[{"(", GridBox[{
        {"0", 
         SubscriptBox["\[Lambda]", "k"]},
        {
         RowBox[{"-", 
          SubscriptBox["\[Lambda]", "k"]}], "0"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "dba65e05-1c14-4658-a5d0-f60bd22a2efd"],
 "\[CirclePlus]",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "0", ")"}], TraditionalForm]],ExpressionUUID->
  "f9f34696-8caa-4d87-92d8-03701788bd13"],
 "     (",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "12dde559-b9b4-41b8-863f-9460272a2036"],
 " odd)\t\[LineSeparator]with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "k"], "\[GreaterEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"597acf98-8959-41a1-b667-67f3a1d7b3e0"],
 ". Then, defining new dressed fermion modes by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["d", "j", "\[Dagger]"], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "i"], 
     SubsuperscriptBox["a", "i", "\[Dagger]"], 
     SubscriptBox["U", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"61b252d3-b1db-4931-a21d-6d8bac4ae625"],
 " ,\[LineSeparator]the generalized BCS ground state can be rewritten as\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"BCS"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"exp", "(", 
       RowBox[{
        UnderoverscriptBox["\[CapitalSigma]", 
         RowBox[{"k", "=", "1"}], 
         RowBox[{"\[LeftFloor]", 
          RowBox[{"n", "/", "2"}], "\[RightFloor]"}]], 
        SubscriptBox["\[Lambda]", "k"], 
        SubsuperscriptBox["d", 
         RowBox[{
          RowBox[{"2", "k"}], "-", "1"}], "\[Dagger]"], 
        SubsuperscriptBox["d", 
         RowBox[{"2", "k"}], "\[Dagger]"]}], ")"}], 
      TemplateBox[{
        RowBox[{"\[InvisibleSpace]", "\[SpaceIndicator]"}]},
       "Ket"]}], "=", 
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{"k", "=", "1"}], 
       RowBox[{"\[LeftFloor]", 
        RowBox[{"n", "/", "2"}], "\[RightFloor]"}]], " \[VeryThinSpace]", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{
         SubscriptBox["\[Lambda]", "k"], 
         SubsuperscriptBox["d", 
          RowBox[{
           RowBox[{"2", "k"}], "-", "1"}], "\[Dagger]"], 
         SubsuperscriptBox["d", 
          RowBox[{"2", "k"}], "\[Dagger]"]}]}], ")"}], 
      TemplateBox[{
        RowBox[{"\[InvisibleSpace]", "\[SpaceIndicator]"}]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "bf577bdd-05ac-486a-9a0e-b7e9f0b0dd5f"],
 " .\[LineSeparator]This means that the dressed modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "j"], TraditionalForm]],ExpressionUUID->
  "e5fd167f-8889-48f6-b594-4298270fab4c"],
 " are BCS paired. Now, make a Bogoliubov transformation\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["b", 
         RowBox[{
          RowBox[{"2", "k"}], "-", "1"}]]},
       {
        SubsuperscriptBox["b", 
         RowBox[{"2", "k"}], "\[Dagger]"]}
      }], ")"}], "=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{
        RowBox[{"1", "+"}], "|", 
        SubscriptBox["\[Lambda]", "k"], 
        SuperscriptBox["|", "2"]}]]], 
     RowBox[{"(", GridBox[{
        {"1", 
         RowBox[{"-", 
          SubscriptBox["\[Lambda]", "k"]}]},
        {
         SubsuperscriptBox["\[Lambda]", "k", "*"], "1"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["d", 
          RowBox[{
           RowBox[{"2", "k"}], "-", "1"}]]},
        {
         SubsuperscriptBox["d", 
          RowBox[{"2", "k"}], "\[Dagger]"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "273811a0-10a4-463d-b828-03627a47f84c"],
 ".\[LineSeparator]Then, the BCS state is the vacuum of all fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["b", "i"], TraditionalForm]],ExpressionUUID->
  "bb304315-7642-4c42-971a-eb5dec04eaaa"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["b", "i"], 
     TemplateBox[{"BCS"},
      "Ket"]}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "203986a2-f503-424a-b08b-4ede7ad51378"],
 " ."
}], "Notes",
 CellID->1794423760,ExpressionUUID->"996398b9-0c5e-46d9-aa61-dd903be87a91"],

Cell[TextData[{
 "A generalized BCS state is a Gaussian state, and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BCSState"]], "paclet:QuantumMob/Q3/ref/BCSState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", "\[Ellipsis]", "]"}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "06e2a9ca-b358-48e5-ba5b-06b50964f067"],
 " converts to ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["\[Ellipsis]", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "833f373f-fe8e-4b55-9d4a-298ca800c2bb"],
 "."
}], "Notes",
 CellID->1840747767,ExpressionUUID->"b911bba9-a742-47cb-aedb-273218a4cc1a"],

Cell[TextData[{
 "Conversely, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BCSState"]], "paclet:QuantumMob/Q3/ref/BCSState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "41587cab-9fcd-4665-b71e-d22f273e3da7"],
 " may convert to ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BCSState"]], "paclet:QuantumMob/Q3/ref/BCSState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["\[Ellipsis]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "77b41852-e335-4a93-81fd-e8396ec4a0be"],
 ". However, a pure state orthogonal to the vacuum state cannot be a \
generalized BCS ground state; see the Thouless theorem (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Ring and Schuck,  1980"]], 
    "https://link.springer.com/book/9783540212065"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "bac25c93-abb7-43fa-bbf9-94885fc3452b"],
 "). In this case, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BCSState"]], "paclet:QuantumMob/Q3/ref/BCSState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["\[Ellipsis]", "TR"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e3dab84a-a360-4e7a-bac7-9b2d2e8a10a7"],
 " returns ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["$Failed"]], "paclet:ref/$Failed"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "74764463-8448-45bd-ada9-0addb3f44258"],
 ". A mixed Bravyi state cannot be converted, either."
}], "Notes",
 CellID->1530870937,ExpressionUUID->"886b3761-e2f1-49f4-99ee-1226ae4f2582"]
}, Dynamic[CurrentValue[
