Cell[TextData[{
 "Construct the matrix representation of the group generator in the interim \
Young-Fourier basis. Note that this is just for illustration, and takes \
rather long. The identical result is obtained more efficiently by combining \
",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungLeftRepresentation"]], 
    "paclet:QuantumMob/Q3/ref/YoungLeftRepresentation", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5eac5d17-cd0c-4010-b03d-43a7ff28fa9c"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungInterimMatrix"]], 
    "paclet:QuantumMob/Q3/ref/YoungInterimMatrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6c0092a5-e1cb-416c-829b-acdd2916aff0"],
 "."
}], "ExampleText",
 CellID->1445836792,ExpressionUUID->"1328554c-0f02-49a0-97ab-6b22a6e1aa1a"],

