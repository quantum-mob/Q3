Cell["\<\
Find the basis for the permutation module associated with a particular type \
(in physical terms, an ordered  list of \"occupation\" numbers):\
\>", "ExampleText",
 CellID->594888171,ExpressionUUID->"1436c9a8-1850-473c-b5d6-fb6d840a3946"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"PermutationBasis", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "2"}], "}"}], ",", "AA"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"PermutationBasis", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"2", ",", "0", ",", "1"}], "}"}], ",", "AA"}], "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->589013595,ExpressionUUID->"1e9da978-04f2-436a-8c48-5c1ef57242d6"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["A", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`A[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["2", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["A", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`A[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["2", 
