  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "90bf2e7b-b858-4317-b1e8-86474b9d4649"],
 ". A ",
 StyleBox["composition",
  FontSlant->"Italic"],
 " of positive integer ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8964f4c1-9de2-488b-9bd2-760dd8efab4b"],
 " is an ordered sequence of nonnegative integers ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "d"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "b46339ad-3d5f-471e-a57d-67e48376b333"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Mu]", "1"], "+", 
     SubscriptBox["\[Mu]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Mu]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"1a732592-8cd0-475e-83c3-aa3bf024bd16"],
 ". The integer ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Mu]", "k"], TraditionalForm]],ExpressionUUID->
  "2b66f2ce-9201-46b1-85a1-310cae42b839"],
 " is called the ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["k",
    FontSlant->"Italic"], "th"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "858063fd-6300-4f32-b1d6-3a4de748db97"],
 " ",
 StyleBox["part",
  FontSlant->"Italic"],
 " (physically, meaning the ",
 StyleBox["occupation number",
  FontSlant->"Italic"],
 " for the ",
 Cell[BoxData[
  SuperscriptBox[
   StyleBox["k",
    FontSlant->"Italic"], "th"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ecd96317-94b3-487c-bec1-961413eed044"],
 " level) of the composition. Note that unlike a ",
 StyleBox["partition",
  FontSlant->"Italic"],
 ", there is no weakly decreasing condition on the parts in a composition. \
Thus, (1, 3, 2) and (3, 2, 1) are both compositions of 6, but only the latter \
is a partition."
}], "Notes",
 CellID->1435776092,ExpressionUUID->"5b321969-a060-42ea-bd4e-35caf6579b17"],

Cell[TextData[{
 "Given a ",
 StyleBox["composition",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "0"], ",", 
      SubscriptBox["\[Mu]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", 
       RowBox[{"d", "-", "1"}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "af543f71-6fb3-480f-81c4-e49c8f4e480a"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "baae8728-790d-4861-b2bd-9fa514314003"],
 ", let\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SuperscriptBox["\[Alpha]", "\[Mu]"]},
     "Ket"], ":=", 
    TemplateBox[{
      RowBox[{
        UnderscriptBox[
         RowBox[{"0", "\[Ellipsis]0"}], 
         UnderscriptBox["\[UnderBrace]", 
          SubscriptBox["\[Mu]", "0"]]], 
        UnderscriptBox[
         RowBox[{"1", "\[Ellipsis]1"}], 
         UnderscriptBox["\[UnderBrace]", 
          SubscriptBox["\[Mu]", "1"]]], "\[Ellipsis]"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "5453b62f-1868-4db8-86ce-271a2fdf9a3e"],
 " .\n",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PermutationBasis"]], 
     "paclet:QuantumMob/Q3/ref/PermutationBasis", "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", "\[Mu]", "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e139bb06-f991-4cc0-9c40-c6c3f1d14f6c"],
 " or ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PermutationBasis"]], 
     "paclet:QuantumMob/Q3/ref/PermutationBasis", "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"\[Mu]", ",", " ", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["s", 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["n", "TI"]]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dc9ba030-dbea-425d-8879-cbaaae7844f7"],
 " returns basis\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      OverscriptBox["g", "^"], 
      TemplateBox[{
        SuperscriptBox["\[Alpha]", "\[Mu]"]},
       "Ket"]}], "|", 
     RowBox[{"g", "\[Element]", 
      SubscriptBox["S", "n"]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "4e2c218b-ffe6-4175-a773-2f1c8f54a8eb"],
 ";\[LineSeparator]in ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Ket", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", "\[Ellipsis]", "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b8dfad28-0d77-4a46-a56a-d06924ed9f32"],
 " or ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Ket", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"<|", "\[Ellipsis]", "|>"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "61c79d79-86b7-485a-9753-04a597b75928"],
 " form, respectively. The ",
 StyleBox["permutation module",
  FontSlant->"Italic"],
 "  spanned by this basis is denoted by ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"5819517f-c37b-47e0-bdbd-ac82331e9bf7"],
 "."
}], "Notes",
 CellID->45090011,ExpressionUUID->"f662ab65-d766-45da-8c22-d851fafc4260"],

Cell[TextData[{
 "The representation of the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "4fcf3880-258c-4c31-bd44-2a0850a1be45"],
 " on the tensor product ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "ea25d369-1eb7-4907-ada4-47641d0f1b66"],
 "of ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fba0076d-b765-43ac-b035-493ff76b5c28"],
 " copies of the Hilbert space ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", "d"], TraditionalForm]],ExpressionUUID->
  "e6ae8ef5-a352-4610-9223-77c785d8fdb5"],
 " associated with a ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "389bb303-9e7f-4667-b792-46b114da84e4"],
 "-level species is the direct sum of permutation modules,\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Mu]"], " ", 
     SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"]}]}], TraditionalForm]],
  ExpressionUUID->"585eed59-e650-48e6-890a-d116cb4d649e"],
 " ,\[LineSeparator]where the direct sum is over all possible ",
 StyleBox["compositions",
  FontSlant->"Italic"],
 " (not necessarily ",
 StyleBox["partitions",
  FontSlant->"Italic"],
 ") \[Mu] of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "c443582e-323d-43c2-82be-2bd359c22123"],
 "."
}], "Notes",
 CellID->1003705927,ExpressionUUID->"bfd22cf6-37a0-432d-8838-2ab5b937fc99"],

Cell[TextData[{
 "According to ",
 StyleBox["Young's rule",
  FontSlant->"Italic"],
 " (Theorem 2.11.2, Sagan, 2001), permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"ade6bee2-cc6c-4dd3-aaa9-79f76e73291c"],
 " of type \[Mu] is reducible in general and decompose into ",
 StyleBox[ButtonBox["Specht modules",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"554a9fbe-d8f5-49ce-97b2-5ca0c5e5b0fc"],
 ", \t\t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], 
      SubscriptBox["K", 
       RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"d2c91dd7-95f0-4169-bbd3-4b71e9f1d2be"],
 " ,\nwhere the sum is over all ",
 StyleBox["partitions",
  FontSlant->"Italic"],
 " \[Lambda] of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "d832ad0a-1b79-44f2-8fa0-14de8f635642"],
 " ",
 ButtonBox["dominating",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/DominatesQ"],
 " ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ReverseSort"]], "paclet:ref/ReverseSort"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   StyleBox["\[Mu]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "13572a91-585f-46bc-b33c-c03ceedc5db2"],
 ". ",
 ButtonBox["Specht module",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"8b87bde3-e5e1-4b9a-a42b-d0904a876db8"],
 " for each partition \[Lambda] is an irreducible representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "2cc8d9e8-0675-432a-812d-e7f09c23f8b0"],
 ". The multiplicity factor ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"0b84f3fe-34c1-4770-a493-0f6d4f4a2d3e"],
 " is called the ",
 StyleBox[ButtonBox["Kostka number",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/KostkaNumber"],
  FontSlant->"Italic"],
 " for partition \[Lambda] and composition \[Mu] of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "0322ab11-76f6-46e8-866e-7a7473e73a56"],
 "."
}], "Notes",
 CellID->1049446101,ExpressionUUID->"85ef15e0-1854-4577-8981-d77249cbfbc5"],

Cell[TextData[{
 "Combining the above two facts leads to\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CirclePlus]", "\[Mu]"], " ", 
      SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"]}], "\[TildeEqual]", 
     RowBox[{
      UnderscriptBox["\[CirclePlus]", 
       RowBox[{
        RowBox[{"\[Mu]", "\[RightTee]", "n"}], "|", "d"}]], " ", 
      RowBox[{
       SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], 
       SubscriptBox["m", "\[Mu]"]}]}], "\[TildeEqual]", 
     RowBox[{
      UnderscriptBox["\[CirclePlus]", 
       RowBox[{
        RowBox[{"\[Mu]", "\[RightTee]", "n"}], "|", "d"}]], " ", 
      RowBox[{
       UnderscriptBox["\[CirclePlus]", 
        RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
       RowBox[{
        SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], 
        SubscriptBox["K", 
         RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], 
        SubscriptBox["m", "\[Mu]"]}]}]}], "\[TildeEqual]", 
     RowBox[{
      UnderscriptBox["\[CirclePlus]", 
       RowBox[{
        RowBox[{"\[Lambda]", "\[RightTee]", "n"}], "|", "d"}]], " ", 
      RowBox[{
       SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], 
       SubscriptBox["\[CapitalSigma]", 
        RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
       SubscriptBox["K", 
        RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], 
       SubscriptBox["m", "\[Mu]"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "a2b93a1d-6034-4415-96d9-cfc1b1d97004"],
 "\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CirclePlus]", 
    RowBox[{
     RowBox[{"\[Lambda]", "\[RightTee]", "n"}], "|", "d"}]], 
   TraditionalForm]],ExpressionUUID->"9a3f73ea-d42c-4a9e-a118-0be365bafb9c"],
 " indicates the direct sum over partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "54f8b97f-7950-45df-ab3e-4a03d8dc1c7e"],
 " with ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "bf9bad69-9d0c-4567-831c-dfb8483dae1d"],
 " or less rows, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "30cf8ded-dfb8-455d-a9c5-7adc0ba7d876"],
 " is the number of distinct permutations of partition ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "0a53193e-a62a-4be1-91af-5d6bb311ca8a"],
 " with 0 padded if it has less than ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "9cc88587-451f-4fc3-924b-116641f98a96"],
 " rows."
}], "Notes",
 CellID->138096876,ExpressionUUID->"129e8c78-fc04-4710-b374-5368041dd924"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

