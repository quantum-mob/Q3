Cell[TextData[{
 "A ",
 StyleBox["cycle decomposition",
  FontSlant->"Italic"],
 " of a permutation is an expression of the permutation as a product of \
disjoint cycles, where each cycle represents a cyclic rearrangement of \
elements. This decomposition is unique up to the order of the cycles and \
cyclic rotations within each cycle."
}], "Notes",
 CellID->442409035,ExpressionUUID->"a197b746-8112-43e5-8d6f-536644e93fda"],

Cell[TextData[{
 "The ",
 StyleBox["cycle decomposition type",
  FontSlant->"Italic"],
 " of a permutation of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "4caf4421-a8bc-4048-a443-0ba5a8b11b01"],
 " elements is a list of the lengths of the cycles in its cycle \
decomposition. By convention, a cycle decomposition type is arranged in \
decreasing order, and is a partition of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b631abb6-7d5e-4a2a-aac6-4113235b9031"],
 "."
}], "Notes",
 CellID->827090356,ExpressionUUID->"81863443-67aa-4ffc-a349-84edff563fc0"],

Cell[TextData[{
 StyleBox["Conjugacy classes",
  FontSlant->"Italic"],
 " in the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "c2c096fb-509b-4eef-bd56-88fc39d012b8"],
 " are uniquely determined by the ",
 StyleBox["cycle decomposition type",
  FontSlant->"Italic"],
 " of permutations. Hence, like irreducible representations of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "78279e53-2ce3-4be3-99d8-83ba8b85e50e"],
 ", conjugacy classes in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "92c3b4f5-43a8-41c0-af60-c16bcf1e2def"],
 " are in one-to-one correspondence to partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "83c6e85b-d5d7-4870-b43d-39494b4445f2"],
 "."
}], "Notes",
 CellID->285452206,ExpressionUUID->"818b2f40-abc3-4f41-9be3-56f8beeb1a67"],

Cell[TextData[{
 "For any finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "af5aaf2e-7453-4a07-a6ab-a110759fafa4"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"\[ScriptCapitalZ]", "(", "g", ")"}], "\[RightBracketingBar]"}],
      "\[VeryThinSpace]", "\[CenterDot]", 
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"\[ScriptCapitalC]", "(", "g", ")"}], 
      "\[RightBracketingBar]"}]}], "=", 
    RowBox[{
    "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}]}], 
   TraditionalForm]],ExpressionUUID->"bbc558f2-caca-42f7-8470-263fb60ed745"],
 ". Hence, the inverse of ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungClassSize"]], "paclet:QuantumMob/Q3/ref/YoungClassSize", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["class", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54ffd7cc-670f-40db-a744-c34c30e0cbe2"],
 "coincides with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungCentralizerSize"]], 
     "paclet:QuantumMob/Q3/ref/YoungCentralizerSize", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["class", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c77461a5-a65e-4f45-bcc9-fdad19c11c9e"],
 " up to a factor of the group order (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Sagan, 2001"]], "https://doi.org/10.1007/978-1-4757-6804-6"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "43f8b8e3-4c10-451a-a0e3-22e5406c0254"],
 ")."
}], "Notes",
 CellID->1946686439,ExpressionUUID->"a7d7026c-f58f-4b9c-853e-e835f465d7d8"],

Cell[TextData[{
 "The cardinality (size) of conjugacy class ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalC]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"11a2e693-66ca-405d-98a2-85553ca5b3ac"],
 " of cycle decomposition type ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "\[RightTee]", "n"}], TraditionalForm]],
  ExpressionUUID->"9b24a5ea-4dc6-4ec6-9fba-e8c4d43c86d8"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     SubscriptBox["\[ScriptCapitalC]", "\[Lambda]"], 
     "\[RightBracketingBar]"}], ":=", 
    RowBox[{
     FractionBox[
      RowBox[{"n", "!"}], 
      RowBox[{
       RowBox[{
        RowBox[{
         SuperscriptBox["1", 
          SubscriptBox["m", "1"]], 
         SuperscriptBox["2", 
          SubscriptBox["m", "2"]]}], "..."}], 
       SuperscriptBox["n", 
        RowBox[{
         SubscriptBox["m", "n"], " "}]], 
       RowBox[{
        SubscriptBox["m", "1"], "!"}], 
       RowBox[{
        SubscriptBox["m", "2"], "!"}], 
       RowBox[{
        SubscriptBox["\[Ellipsis]m", "n"], "!"}]}]], "=", 
     FractionBox[
      RowBox[{"n", "!"}], 
      RowBox[{"\[LeftBracketingBar]", 
       SubscriptBox["\[ScriptCapitalZ]", "\[Lambda]"], 
       "\[RightBracketingBar]"}]]}]}], TraditionalForm]],ExpressionUUID->
  "e316cf97-364a-433d-9a13-92a2b457e8ec"],
 " ."
}], "Notes",
 CellID->653835715,ExpressionUUID->"e0957320-f0cf-42ab-8705-33dc6899a4c1"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

