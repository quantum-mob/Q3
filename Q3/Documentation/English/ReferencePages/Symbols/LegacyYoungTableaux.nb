Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["LegacyYoungTableaux"]], 
     "paclet:QuantumMob/Q3/ref/LegacyYoungTableaux", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["shape", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8aff698a-1577-4a99-9ae3-9bd2e2bf922d"],
 " returns a list in the special lexicographic order for Young tableaux (it \
is different from the standard ",
 ButtonBox["lexicographic order",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/LexicographicOrder"],
 " for lists). On the other hand, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["YoungTableaux"]], "paclet:QuantumMob/Q3/ref/YoungTableaux", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["shape", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "315c1ff9-5269-4f52-848d-a4c771fd2406"],
 " gives the list in the reversed lexicographic order for Young tableaux. \
That is, given a shape, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Reverse"]], "paclet:ref/Reverse"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["YoungTableaux"]], "paclet:QuantumMob/Q3/ref/YoungTableaux", 
       "QuantumMob Package Symbol"},
      "PackageLink",
      BaseStyle->"InlineFormula"], "[", 
     StyleBox["shape", "TI"], "]"}], "]"}], "==", 
   RowBox[{"LegacyYoungTableaux", "[", 
    StyleBox["shape", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9106daac-ac49-4c27-a2ee-6844845a3324"],
 "."
}], "Notes",
 CellID->288315490,ExpressionUUID->"c383bf05-1219-4b46-8be1-9facb6bf5617"],

Cell[TextData[{
 "The resulting list must equal to ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Reverse"]], "paclet:ref/Reverse"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Map"]], "paclet:ref/Map"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["YoungTableau"]], "paclet:QuantumMob/Q3/ref/YoungTableau", 
       "QuantumMob Package Symbol"},
      "PackageLink",
      BaseStyle->"InlineFormula"], ",", " ", 
     RowBox[{
      TemplateBox[{
        Cell[
         TextData["GelfandYoungPatterns"]], 
        "paclet:QuantumMob/Q3/ref/GelfandYoungPatterns", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"], "[", 
      StyleBox["shape", "TI"], "]"}]}], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "86fcca9e-5612-4fc4-9315-430deb8057f9"],
 ". However, the conversion process makes this method slightly slower. See \
the detailed analysis in ",
 ButtonBox["Properties & Relations",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandYoungPatterns#1703517899"],
 " in the  ",
 ButtonBox["GelfandYoungPatterns",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandYoungPatterns#1703517899"],
 " documentation."
}], "Notes",
 CellID->1793054591,ExpressionUUID->"7177cf1d-a7a4-4722-abf0-fe22eaeda1fc"]
}, Dynamic[CurrentValue[
