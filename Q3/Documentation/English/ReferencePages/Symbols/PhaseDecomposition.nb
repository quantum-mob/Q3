Cell[TextData[{
 "The phase decomposition of an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "4e2d6b58-8188-4e6c-abf6-317ef7ab4c8d"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "8c81ed0d-2ec0-4f4a-a0a9-4345b4ec6572"],
 " is given by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"V", ".", 
     RowBox[{"Exp", "[", 
      RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "\[CapitalPhi]"}], "]"}], ".", 
     SuperscriptBox["W", "T"]}]}], TraditionalForm]],ExpressionUUID->
  "f7ba6e9b-606f-49cb-9a47-a25fc8c45444"],
 "\[LineSeparator]with  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", ",", 
    RowBox[{"W", "\[Element]", 
     RowBox[{"SO", "(", "n", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c9af7566-8f13-421e-baf0-ac617440135b"],
 "  and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalPhi]", ":=", 
    RowBox[{"diag", "(", 
     RowBox[{
      SubscriptBox["\[Phi]", "1"], ",", 
      SubscriptBox["\[Phi]", "2"], ",", "\[Ellipsis]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"4a7845f9-0841-4f30-b0ed-8511e200ab20"],
 "."
}], "Notes",
 CellID->1851897733,ExpressionUUID->"7f8a8614-f04b-4c95-81be-82bd9b259015"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

