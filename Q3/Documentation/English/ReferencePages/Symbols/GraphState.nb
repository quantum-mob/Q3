Cell[TextData[{
 "Since this graph does not have any information about qubits,  ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QuantumCircuit"]], "paclet:QuantumMob/Q3/ref/QuantumCircuit", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9c273350-d714-4c2f-9081-a4d4a25efe9d"],
 " cannot work directly with this graph. In this case, to construct the \
quantum circuit generating the graph state, use ",
 ButtonBox["VertexReplace",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/VertexReplace"],
 "."
}], "ExampleText",
 CellID->2008507498,ExpressionUUID->"f7374dd4-6cdb-421e-a32a-82dcdd5e9e2e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"VertexReplace", "[", 
    RowBox[{"g", ",", 
     RowBox[{"Thread", "[", 
      RowBox[{
       RowBox[{"VertexList", "@", "g"}], "->", 
       RowBox[{"S", "@", 
        RowBox[{"Range", "[", "6", "]"}]}]}], "]"}]}], "]"}], 
   "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->831498671,ExpressionUUID->"4cd8f88a-7028-4379-98c9-905b229740f2"],

