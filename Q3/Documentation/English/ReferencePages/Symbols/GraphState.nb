Cell[TextData[{
 "The projection operator onto the graph state is given by\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"\[ScriptCapitalG]"},
      "Ket"], 
     TemplateBox[{"\[ScriptCapitalG]"},
      "Bra"]}], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", "n"]], 
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"S", "\[Element]", "\[ScriptCapitalS]"}]], "S"}], "=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", "n"]], 
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Mu]", "\[Element]", 
        SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", "n"]}]], 
      SuperscriptBox["K", "\[Mu]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "5ff3663b-3bfa-4d53-b58e-13b6a970ffdd"],
