Cell[TextData[{
 "Sometimes, a ",
 StyleBox["graph state",
  FontSlant->"Italic"],
 " is also called a ",
 StyleBox["cluster state",
  FontSlant->"Italic"],
 ". However, the cluster state refers to a special subclass of the graph \
state."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"bd655d34-58de-4562-acf0-3b78af9f6be4"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalG]", ":=", 
    RowBox[{"(", 
     RowBox[{"\[ScriptCapitalV]", ",", "\[ScriptCapitalE]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"e01cb7e5-447b-4df5-992d-ce9a69c1fbdf"],
 " be a graph with set ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "bfa67b6c-7591-42b3-971e-a626a0b13377"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "7071b713-deef-4345-b120-9908fa5ab0ce"],
 " vertices and set ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "4d828fd9-3751-496c-a8dc-63803d68e987"],
 " of edges. The graph state corresponding to the graph is defined by\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[ScriptCapitalG]"},
     "Ket"], ":=", 
    RowBox[{
     UnderscriptBox["\[CapitalPi]", 
      RowBox[{"a", "\[Element]", "\[ScriptCapitalE]"}]], 
     SubscriptBox["CZ", 
      RowBox[{"a", "\[VeryThinSpace]", "b"}]], 
     SuperscriptBox[
      TemplateBox[{"+"},
       "Ket"], 
      RowBox[{"\[CircleTimes]", "\[ScriptCapitalV]"}]]}]}], TraditionalForm]],
  ExpressionUUID->"7db63a90-2f4f-40d7-ba2a-3a7ca25c15ac"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["CZ", 
    RowBox[{"a", "\[VeryThinSpace]", "b"}]], TraditionalForm]],ExpressionUUID->
  "7245970d-4466-43f7-b5e5-7a7634496c19"],
 " denotes the controlled-",
 StyleBox["Z",
  FontSlant->"Italic"],
 " operator acting on the two vertices ",
 StyleBox["a",
  FontSlant->"Italic"],
 " and ",
 StyleBox["b",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1485005044,ExpressionUUID->"f1f85976-de69-4664-991e-67f21b6504b2"],

Cell[TextData[{
 "For each vertex ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "\[Element]", "\[ScriptCapitalV]"}], TraditionalForm]],
  ExpressionUUID->"c890863a-9fbf-49c5-a455-03d0afddeff4"],
 ", define the ",
 StyleBox["correlation operator",
  FontSlant->"Italic"],
 " at ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "99194e53-5a9e-4d63-838b-aab07741ceb2"],
 " by\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["K", "a"], ":=", 
    RowBox[{
     SubscriptBox["X", "a"], 
     RowBox[{
      UnderscriptBox["\[CapitalPi]", 
       RowBox[{"b", "\[Element]", 
        SubscriptBox["\[ScriptCapitalN]", "a"]}]], 
      SubscriptBox["Z", "b"]}]}]}], TraditionalForm]],ExpressionUUID->
  "3fe041f8-bc38-4ff3-a1a6-9a3c3e371a3b"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalN]", "a"], ":=", 
    RowBox[{"{", 
     RowBox[{"b", "|", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"a", ",", "b"}], ")"}], "\[Element]", "\[ScriptCapitalE]"}]}],
      "}"}]}], TraditionalForm]],ExpressionUUID->
  "f4cca906-4430-40c4-bad7-c004c12cca1f"],
 " is the set of neighboring vertices of ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "be6f2a2f-f1a9-4e3c-b1f1-a7ec6768bbfd"],
 "."
}], "Notes",
 CellID->2008780740,ExpressionUUID->"277d827f-cfe3-4d8c-9655-fc1c31d216e3"],

Cell[TextData[{
 "The ",
 StyleBox["correlation operators",
  FontSlant->"Italic"],
 " are independent of each other and form a generating set of Abelian group \
",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "10c00a51-1403-46f7-a5e9-f41e9602ebc8"],
 ". The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]],ExpressionUUID->
  "3254886f-6fe3-4ebf-8bd9-12b8c0a3edf0"],
 " elements in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "=", 
    RowBox[{"{", 
     RowBox[{
      SuperscriptBox["K", "\[Mu]"], "|", 
      RowBox[{"\[Mu]", "\[Element]", 
       SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", "n"]}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"72dd1d3a-7622-48ef-9117-5533650a149f"],
 " are given by\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["K", "\[Mu]"], ":=", 
    RowBox[{
     UnderscriptBox["\[CapitalPi]", 
      RowBox[{"a", "\[Element]", "\[ScriptCapitalV]"}]], 
     SubsuperscriptBox["K", "a", 
      SubscriptBox["\[Mu]", "a"]]}]}], TraditionalForm]],ExpressionUUID->
  "765607d9-f6f3-4a23-aefb-5111d2999c6b"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "n"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "aa2e4fa4-3b92-4c04-8917-456f06456ec8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Mu]", "a"], "\[Element]", 
    SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], TraditionalForm]],
  ExpressionUUID->"c9e90904-5ecd-485c-b703-8873438387d2"],
 "."
}], "Notes",
 CellID->1210052295,ExpressionUUID->"597716db-610a-4534-8088-70d308a826ef"],

Cell[TextData[{
 "The graph state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[ScriptCapitalG]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a7728ecf-5c7b-4aae-943d-46c2cb4c7829"],
 " is the unique common eigenstate of all correlation operators belonging to \
eigenvalue +1; that is, \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["K", "a"], " ", 
     TemplateBox[{"\[ScriptCapitalG]"},
      "Ket"]}], "=", 
    TemplateBox[{"\[ScriptCapitalG]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "c6c8bbc9-d107-4825-860c-3fc3b86d3e33"],
 "\[LineSeparator]for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "\[Element]", "\[ScriptCapitalV]"}], TraditionalForm]],
  ExpressionUUID->"9451310e-a582-42db-81a7-27015f4a78dc"],
 ". Therefore, the Abelian subgroup ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "b32b978e-1684-4b23-a87a-5ce17cc4fb88"],
 " generated by the correlation operators is the stabilizer of the graph \
state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[ScriptCapitalG]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "dd0c0ef6-4980-482d-8cdc-f9d1120a7ebd"],
 "."
}], "Notes",
 CellID->2019015940,ExpressionUUID->"af908b3f-ec66-4c29-9ce4-2ecef8c2ee4b"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Omega]", "1"], ",", 
