Cell[BoxData[
 RowBox[{
  RowBox[{
   SqrtBox["2"], " ", 
   InterpretationBox[
    TagBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         TemplateBox[{"0"},
          "Ket"], 
         SqrtBox["2"]], "-", 
        FractionBox[
         TemplateBox[{"1"},
          "Ket"], 
         SqrtBox["2"]]}], ")"}], "\[CircleTimes]", 
      TemplateBox[{"1"},
       "Ket"]}],
     HoldForm],
    QuantumMob`Q3`OTimes[
    2^Rational[-1, 2] Ket[{0}] - 2^Rational[-1, 2] Ket[{1}], 
     Ket[{1}]]]}], "+", 
  RowBox[{
   SqrtBox["2"], " ", 
   InterpretationBox[
    TagBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        FractionBox[
         TemplateBox[{"0"},
          "Ket"], 
         SqrtBox["2"]], "+", 
        FractionBox[
         TemplateBox[{"1"},
          "Ket"], 
         SqrtBox["2"]]}], ")"}], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}],
     HoldForm],
    QuantumMob`Q3`OTimes[
    2^Rational[-1, 2] Ket[{0}] + 2^Rational[-1, 2] Ket[{1}], 
     Ket[{0}]]]}]}]], "Output",
 CellLabel->"Out[6]=",
 CellID->994624550,ExpressionUUID->"19aefd58-1034-4734-b7c2-17ec5f3cd115"]
}, Open  ]],

