Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["Schmidt decomposition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchmidtDecomposition"],
  FontSlant->"Italic"],
 " of a state vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6ce2039e-d0ee-4467-a3e2-e0f177b3c4a1"],
 " in a tensor-product space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", "\[CircleTimes]", "\[ScriptCapitalW]"}], 
   TraditionalForm]],ExpressionUUID->"a24c901a-7b2a-4dd9-a951-ba8719b2c0de"],
 " is to rewrite ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "fb6b40d3-2b7f-49b5-9e44-90d4dad9c6da"],
 " in the least number of terms of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "1"}], "R"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["v", "k"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["w", "k"]},
       "Ket"]}], 
     SubscriptBox["s", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "120b92c6-673c-46b5-8ead-64c6d6679562"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "i"]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "\[Ellipsis]", ",", "m"}], "}"}],
    TraditionalForm]],ExpressionUUID->
  "5ce088e4-3bae-4a0c-a545-699dafd24956"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["w", "j"]},
        "Ket"], ":", "j"}], "=", "1"}], ",", "\[Ellipsis]", ",", "n"}], "}"}],
    TraditionalForm]],ExpressionUUID->
  "e2a005b2-f2d8-493b-bf14-e87e86f3dde9"],
 " are orthonormal bases of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "89d09f63-e346-4d75-a4da-71acfce1634b"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "44f61be9-294c-4465-b0e4-c080ffdca726"],
 ", respectively, and the coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["s", "k"], TraditionalForm]],ExpressionUUID->
  "3c84ec21-86ab-4a4f-b240-b25b113b395b"],
 " are all positive (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", 
     RowBox[{"k", " "}]], ">", "0"}], TraditionalForm]],ExpressionUUID->
  "d1fe0b8e-3635-4d7a-8205-24de06c33302"],
 "). Here, the so-called ",
 StyleBox["Schmidt rank",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "350e853a-7960-419c-90e3-9d0c83589339"],
 " of the quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2051fc38-5041-4d60-9144-71733660d5e7"],
 " cannot be larger than the smaller of the dimensions of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "97de8785-d659-4513-b24a-f265458cd772"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "f203f7b1-e1dd-49df-b009-1cb38168ccc8"],
 "; i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", " ", "\[LessEqual]", " ", 
    RowBox[{"min", 
     RowBox[{"(", 
      RowBox[{"m", ",", " ", "n"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"ea280305-04f6-428e-81c5-bf326d70e14e"],
 ". If the Schmidt rank is 2 or larger, then the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "836c353b-38c0-4c20-afef-bd0b44430a09"],
 " is ",
 StyleBox["entangled",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1364052628,ExpressionUUID->"a254ffaf-9e8f-40c7-ae62-de724ce37224"],

Cell[TextData[{
 "In the form ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["SchmidtDecomposition"]], 
