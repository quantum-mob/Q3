Cell[TextData[{
 "An ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "8325f52d-af5d-4f10-90e4-737cef21b70f"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[GreaterEqual]", "n"}], TraditionalForm]],ExpressionUUID->
  "3adad232-f34d-40d7-b36c-007be74be0f1"],
 ") matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "fd2e7d1d-cd6d-49fd-aaa4-a694d70a94dc"],
 " is said to be ",
 StyleBox["isometric",
  FontSlant->"Italic"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["A", "\[Dagger]"], "A"}], "=", 
    SubscriptBox["I", 
     RowBox[{"n", "\[Times]", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "7b13827a-66bb-48b7-940e-4144829fd73e"],
 "."
}], "Notes",
 CellID->1572790540,ExpressionUUID->"cc276967-537b-4beb-a920-a0f24041aa4a"],

