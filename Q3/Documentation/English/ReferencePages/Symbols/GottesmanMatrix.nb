Cell[TextData[{
 "A ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "956ac06b-4b34-41fc-8748-6a106a815416"],
 " is completely specified (up to a global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["e", 
    RowBox[{"\[ImaginaryI]", " ", "m", " ", 
     RowBox[{"\[Pi]", " ", "/", "4"}]}]], TraditionalForm]],ExpressionUUID->
  "e91a7f0f-95c3-45f7-93fc-8dec67386c53"],
 ") by the transformation of ",
 ButtonBox["Pauli operators",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "0a78c583-4c7f-413a-ad4d-d0f17f3ca332"],
 ":\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["X", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["p", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["a", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["b", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "31e5a031-d841-4a46-a7b0-e6d02ef6e434"],
 "\nand\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubscriptBox["Z", "j"], " ", 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      SubscriptBox["q", "j"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["c", 
        StyleBox["ij",
         FontSlant->"Italic"]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["d", 
        StyleBox["ij",
         FontSlant->"Italic"]]]}]}]}], TraditionalForm]],ExpressionUUID->
  "b6192956-4cc2-4824-b2da-670549778f7f"],
 "."
}], "Notes",
 CellID->1417856937,ExpressionUUID->"6ae00833-a980-4992-a2a8-0ca10e4450c0"],

Cell[TextData[{
 "The Gottesman matrix of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "211f2844-3a32-4a4a-9777-e7dcd63b7cbb"],
 " is then defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "U", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["a", "11"], 
        SubscriptBox["c", "11"], 
        SubscriptBox["a", "12"], 
        SubscriptBox["c", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "11"], 
        SubscriptBox["d", "11"], 
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "12"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["a", "21"], 
        SubscriptBox["c", "21"], 
        SubscriptBox["a", "22"], 
        SubscriptBox["c", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {
        SubscriptBox["b", "12"], 
        SubscriptBox["d", "21"], 
        SubscriptBox["b", "22"], 
        SubscriptBox["d", "22"], "\[Ellipsis]", "\[Ellipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[VerticalEllipsis]", 
        "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
        "\[DescendingEllipsis]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "7d739630-0295-431b-8ddf-d0c700ea1bf9"]
}], "Notes",
 CellID->1647214467,ExpressionUUID->"2bc4d557-eeb0-4a5d-ba48-7212be266928"],

Cell[TextData[{
 "The Gottesman matrix of a ",
 ButtonBox["Clifford operator",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " is a binary symplectic matrix. Recall that the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"4f57d436-ed3a-434c-8d34-fa5d03032676"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "345ea928-89ba-4a1f-b336-951101a7e367"],
 "qubits is equivalent to the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Sp", "(", 
    RowBox[{
     RowBox[{"2", "n"}], ",", 
     SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"6cb89999-9226-4d84-8c8c-eecf4428d96f"],
 " up to the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"9a29f692-3083-4ca7-b6f9-4e6aee678745"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}], "\[Congruent]", 
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"48242aa1-7236-449d-90ff-c4a806861d48"],
 "."
}], "Notes",
 CellID->17963594,ExpressionUUID->"4209333f-52bf-40e3-90c9-3c41fd484a6e"],

Cell[TextData[{
 "Recall that a Pauli operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"6d687204-add7-4d9c-b9f0-9dc6f2b20576"],
 "\[LineSeparator]is completely specified (up to a global phase factor) by \
the corresponding Gottesman vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["z", "1"], ",", 
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["x", "n"], ",", 
       SubscriptBox["z", "n"]}], ")"}], "T"]}], TraditionalForm]],
  ExpressionUUID->"7d71c335-696d-44b4-b137-672679f7fb8d"],
 "."
}], "Notes",
 CellID->1441760612,ExpressionUUID->"812584ab-4ec0-4940-87d1-2ef74e1ff1ce"],

Cell[TextData[{
 "Under conjugation by a Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "ca4237a1-cc97-4a13-8231-b56d75db84fe"],
 ", the Gottesman vector transforms as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", 
     RowBox[{"U", " ", "P", " ", 
      SuperscriptBox["U", "\[Dagger]"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"v", "(", "P", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "f4df7252-69c7-4b8b-a85e-2bcbdfec2a47"],
 "."
}], "Notes",
 CellID->1746253034,ExpressionUUID->"0f157176-32b5-4acd-8a0a-60e41a1358ab"],

Cell[TextData[{
 "Furthermore, a series of consecutive conjugations by Clifford operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ",", " ", "V", ",", " ", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"0da7f4a0-5422-4459-bd0b-ca5b0318f6d1"],
 " is described by the multiplications of corresponding Gottesman matrices,\
\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], "\[Ellipsis]"}]}], TraditionalForm]],
  ExpressionUUID->"8d77112c-e389-46d3-b4a1-bccbf43d42bf"],
 ". \[LineSeparator]That is,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]", " ", "P"}], " ", "..."}], " ", 
     SuperscriptBox["V", "\[Dagger]"], 
     SuperscriptBox["U", "\[Dagger]"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
     SuperscriptBox[
      RowBox[{"P", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], "\[Dagger]"]}]}], 
   TraditionalForm]],ExpressionUUID->"fe7b848a-2b10-43ce-8f6a-6d628dda232a"],
 "\[LineSeparator]leads to\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"v", "(", "P", ")"}], "\[RightTeeArrow]", 
     RowBox[{
      RowBox[{"S", "(", 
       RowBox[{"U", " ", "V", " ", "\[Ellipsis]"}], ")"}], 
      RowBox[{"v", "(", "P", ")"}]}]}], "=", 
    RowBox[{
     RowBox[{"S", "(", "U", ")"}], 
     RowBox[{"S", "(", "V", ")"}], 
     RowBox[{"\[Ellipsis]v", "(", "P", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"0d11f358-f8f7-4c33-b57b-ab755852813a"],
 "."
}], "Notes",
 CellID->863527665,ExpressionUUID->"9a759846-f0c2-4c38-a777-0b8ac34f5a81"],

Cell[TextData[{
 "For technical reasons, however,  ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanMatrix"]], "paclet:QuantumMob/Q3/ref/GottesmanMatrix",
     "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6f9936f1-c4df-48aa-9d82-c52a927d64ed"],
 " returns the transposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["S", "T"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"4d8a60c6-ed6a-4e06-9f15-fa1e2c6c25d9"],
 " rather than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "(", "U", ")"}], TraditionalForm]],ExpressionUUID->
  "1388f9e6-41d8-4625-a801-cf838ce7ff93"],
 " itself. ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FromGottesmanMatrix"]], 
    "paclet:QuantumMob/Q3/ref/FromGottesmanMatrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "05734c05-b5b8-4dc5-bd30-a48addea1419"],
 " also recovers Clifford operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "67316515-cc51-468b-acc8-34f152621271"],
 " by assuming that the input matrix is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["S", "T"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"ee5fb127-5f1b-4a7a-bda7-7cfa608e4fbf"],
 "."
}], "Notes",
 CellID->327820378,ExpressionUUID->"97198440-ab9c-4c5e-bd0e-44cf98fd63a4"],

Cell[TextData[{
 "A ",
 StyleBox["Gottesman matrix",
  FontSlant->"Italic"],
 " consists of rows of ",
 ButtonBox["Gottesman vectors",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanVector"],
 " that form a ",
 ButtonBox["symplectic basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanBasis"],
 " with respect to the ",
 ButtonBox["Gottesman inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanDot"],
 " in the ",
 Cell[BoxData[
  RowBox[{"2", 
   StyleBox["n", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d4495e8f-81bc-4e1f-88a6-a7bdd1afd9f1"],
 "-dimensional ",
 ButtonBox["Gottesman vector space",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanVector"],
 "."
}], "Notes",
 CellID->1737636103,ExpressionUUID->"464f072b-51e6-4fae-a526-82eb268b7f84"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

