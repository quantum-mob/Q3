Cell[TextData[{
 "Recall that the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 " alias ",
 ButtonBox["Gottesman group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanGroup"],
 "  is a quotient group of the Pauli group in the Clifford group. This means \
that one can only recover the Clifford operator from its Gottesman matrix \
only up to a factor of Pauli operator."
}], "ExampleText",
 CellID->2046551456,ExpressionUUID->"8a03e9b8-fafe-4e25-819d-5ecaaf9d5373"],

