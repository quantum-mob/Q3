Cell[TextData[{
 "The ",
 StyleBox["Shannon entropy",
  FontSlant->"Italic"],
 " of probability distribution ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5bd772ec-4a4b-4f79-a756-94a9ba44e13c"],
 " is defined by ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"-", 
    SubscriptBox[
     StyleBox["\[CapitalSigma]", "TR"], 
     StyleBox["k", "TI"]]}], " ", 
   SubscriptBox[
    StyleBox["p", "TI"], 
    StyleBox["k", "TI"]], " ", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Log"]], "paclet:ref/Log"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["k", "TI"]], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ab01c3c8-89a1-438d-aa6e-9748705406f2"],
 "."
}], "Notes",
 CellID->1930188767,ExpressionUUID->"51552ba9-3f01-4c31-b359-5cd17e419fe6"],

Cell[TextData[{
 "The logarithm involved in the evaluation is to base 2. If other base is \
necessary, multiply the result by a factor ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Log"]], "paclet:ref/Log"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", "2", "]"}], "/", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["Log"]], "paclet:ref/Log"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
    StyleBox["base", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ca5afb02-6541-42b5-a091-efe4a8d650c3"],
 "."
}], "Notes",
 CellID->1580299307,ExpressionUUID->"0e3669b3-5624-4b5c-ba76-ca5a9da5420f"],

Cell["\<\
Shannon entropy is a measure of the uncertainty of a random variable.\
\>", "Notes",
 CellID->1829639072,ExpressionUUID->"61a30c2f-4ad2-461c-9943-0dcaf4f0230b"],

Cell[TextData[{
 "The ",
 StyleBox["relative Shannon entropy",
  FontSlant->"Italic"],
 " (also known as the ",
 StyleBox["Kullback-Leibler divergence",
  FontSlant->"Italic"],
 ") of two probability distributions ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["p", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9edc65f3-92aa-48fd-bc79-349e3119b76f"],
 " and ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["q", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["q", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "feb47378-5c97-4d51-b564-1cc3524969e2"],
 " is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{
      RowBox[{"{", 
       SubscriptBox["p", "k"], "}"}], "\[DoubleVerticalBar]", 
      RowBox[{"{", 
       SubscriptBox["q", "k"], "}"}]}], ")"}], ":=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "k"], 
      SubscriptBox["p", "k"], 
      RowBox[{"Log", "[", 
       RowBox[{
        SubscriptBox["p", "k"], "/", 
        SubscriptBox["q", "k"]}], "]"}]}], "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"H", "(", 
        RowBox[{"{", 
         SubscriptBox["p", "k"], "}"}], ")"}]}], "-", 
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", "k"], 
       SubscriptBox["p", "k"], 
       RowBox[{"Log", "[", 
        SubscriptBox["q", "k"], "]"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"86e518c2-5550-4b5a-b92c-f932ed9e5742"],
 ".\[LineSeparator]The second term, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     UnderscriptBox["\[CapitalSigma]", "k"]}], 
    SubscriptBox["p", "k"], 
    RowBox[{"Log", "[", 
     SubscriptBox["q", "k"], "]"}]}], TraditionalForm]],ExpressionUUID->
  "c2ba3879-5e1e-4dc6-8aad-5e3690ed5dca"],
 ", is often called the ",
 ButtonBox["cross-entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CrossEntropy"],
 "."
}], "Notes",
 CellID->1527407885,ExpressionUUID->"dffec113-fc09-48f1-8884-bee33d6e6009"],

Cell[TextData[{
 "Relative (Shannon) entropy is a measure of the difference between two \
probability distributions; and so is the ",
 ButtonBox["cross-entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CrossEntropy"],
 "."
}], "Notes",
 CellID->1608679502,ExpressionUUID->"0780f008-00b2-47d9-b89b-e613fd432bf3"],

Cell["\<\
The relative entropy between any two probability distributions is \
non-negative.\
\>", "Notes",
 CellID->2076158791,ExpressionUUID->"0b7da7dd-1e0b-48b8-bc4c-0834d49e691a"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

