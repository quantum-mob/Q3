Cell["\<\
Here is the matrix representation of the operator in the logical basis.\
\>", "ExampleText",
 CellID->658733575,ExpressionUUID->"55635a6a-09c0-4968-900b-04e62de8f38e"],

Cell[CellGroupData[{

Cell[BoxData[{
