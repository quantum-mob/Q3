 CellLabel->"In[3]:=",
 CellID->1993732127,ExpressionUUID->"b4e8c253-5589-44ba-afec-59e4374ffd1f"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"3", "0", "0", "1"},
     {"0", 
      RowBox[{"-", "3"}], "1", "0"},
     {"0", "1", 
      RowBox[{"-", "3"}], "0"},
     {"1", "0", "0", "3"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
