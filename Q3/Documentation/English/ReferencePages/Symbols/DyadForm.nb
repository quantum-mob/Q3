Cell["\<\
Consider an operator expressed in terms of the Pauli operators for unlabelled \
qubits.\
\>", "ExampleText",
 CellID->215207831,ExpressionUUID->"d187fa2f-c1d4-48f1-82b7-8e101300c902"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"op", "=", 
  RowBox[{
   RowBox[{"Pauli", "[", 
    RowBox[{"{", 
     RowBox[{"1", ",", "1"}], "}"}], "]"}], "+", 
   RowBox[{"3", "*", 
    RowBox[{"Pauli", "[", 
     RowBox[{"{", 
      RowBox[{"3", ",", "3"}], "}"}], "]"}]}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->2004965281,ExpressionUUID->"8f5c618c-bcb2-47ee-8c7a-72562b3dbe20"],

Cell[BoxData[
 RowBox[{
  InterpretationBox[
   RowBox[{"\<\"X\"\>", "\[CircleTimes]", "\<\"X\"\>"}],
   Q3`Pauli[{1, 1}]], "+", 
  RowBox[{"3", " ", 
   InterpretationBox[
    RowBox[{"\<\"Z\"\>", "\[CircleTimes]", "\<\"Z\"\>"}],
    Q3`Pauli[{3, 3}]]}]}]], "Output",
 CellLabel->"Out[1]=",
 CellID->609116323,ExpressionUUID->"f0770d8f-39f2-4833-9c44-a5d027863edb"]
}, Open  ]],

