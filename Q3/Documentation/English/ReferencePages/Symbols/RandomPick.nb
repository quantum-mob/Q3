Cell["\<\
Examine the average number of actually picked elements to check that it is \
close to the probability for a sufficiently large sample:\
\>", "ExampleText",
 CellID->1840821027,ExpressionUUID->"12872531-3c69-42cf-a44d-dfc515f56e77"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$p", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$n", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nn", "=", 
   RowBox[{"Range", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"elm", "=", 
   RowBox[{"RandomPick", "[", 
    RowBox[{
     RowBox[{"$p", "->", "nn"}], ",", "50000"}], "]"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->170534508,ExpressionUUID->"09f1e668-30ed-4928-bdd1-295445ad6e5c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Mean", "[", 
    RowBox[{"Map", "[", 
     RowBox[{"Length", ",", "elm"}], "]"}], "]"}], "/", "$n"}], "//", 
  "N"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1430290858,ExpressionUUID->"5728caed-b4bf-4367-831c-ffe5c76283a8"],

