Cell["\<\
Examine the average number of actually picked elements to check that it is \
close to the probability for a sufficiently large sample:\
\>", "ExampleText",
 CellID->1840821027,ExpressionUUID->"9a8ee678-2c6d-4663-9e86-ec0788649311"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$p", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$n", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nn", "=", 
   RowBox[{"Range", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"elm", "=", 
   RowBox[{"RandomPick", "[", 
    RowBox[{
     RowBox[{"$p", "->", "nn"}], ",", "50000"}], "]"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->170534508,ExpressionUUID->"16fc831a-bbac-4525-9255-e14427fe219d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Mean", "[", 
    RowBox[{"Map", "[", 
     RowBox[{"Length", ",", "elm"}], "]"}], "]"}], "/", "$n"}], "//", 
  "N"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1430290858,ExpressionUUID->"52d841ce-f371-48bb-b629-c95b82d597c7"],

