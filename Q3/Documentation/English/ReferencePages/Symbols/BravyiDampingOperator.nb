Cell["\<\
Construct the effective damping operator in the conventional matrix \
representation in the Fock space.\
\>", "ExampleText",
 CellID->1659944863,ExpressionUUID->"1974af31-f7bd-4097-9b40-f80a56a5ddd3"],

