Cell[TextData[{
 "The ",
 StyleBox["Hatano",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox["-Nelson model",
  FontSlant->"Italic"],
 " is a non-Hermitian Hamiltonian model of fermionic modes exhibiting the \
so-called ",
 StyleBox["skin effect",
  FontSlant->"Italic"],
 ". It was introduced by  ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
      StyleBox[{
        StyleBox["Hatano", IgnoreSpellCheck -> True], 
        " and Nelson in 1996"}]]], 
    "https://doi.org/10.1103/PhysRevLett.77.570"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "c6ef7ef4-8b7d-4047-8501-a4cfd92fa91d"],
 ", originally, in the context of localization transitions, and later applied \
to describe vortex pinning in superconductors ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
      StyleBox[{"(", 
        StyleBox["Hatano", IgnoreSpellCheck -> True], 
        " and Nelson, 1997)"}]]], "https://doi.org/10.1103/PhysRevB.56.8651"},
   
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "e930fd0d-8212-48a8-94a3-6ccb241a2c4b"],
 ". The non-hermicity and associated skin effect come from quantum \
dissipative processes through a coupling to the bath ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
      StyleBox[{"(Kawabata, ", 
        StyleBox["Numasawa", IgnoreSpellCheck -> True], " and ", 
        StyleBox["Ryu", IgnoreSpellCheck -> True], ", 2023)"}]]], 
    "https://doi.org/10.1103/PhysRevX.13.021007"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "373d5d66-ba25-49ba-9771-5902ead5176b"],
 "."
}], "ExampleText",
 CellID->84723117,ExpressionUUID->"aec927bc-10c3-4a88-a4d7-e820d12f2173"],

Cell[TextData[{
 "Here, we consider a ",
 StyleBox["projective model",
  FontSlant->"Italic"],
 " for the ",
 StyleBox["Hatano",
  IgnoreSpellCheck->True],
 "-Nelson Hamiltonian, where the non-Hermitian terms come from the projective \
quantum jump operators. These projective quantum jump operators may be \
described by using ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6a1ed277-174b-41fb-8ea1-b446b560cf7d"],
 "."
}], "ExampleText",
 CellID->2002068658,ExpressionUUID->"eb5641b0-728f-457c-9f4c-cb0b46e31fdc"],

Cell["Set the number of fermion modes.", "ExampleText",
 CellID->1251699765,ExpressionUUID->"8e247410-7a31-4af7-aa09-1e982b80045e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$L", "=", "4"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1943623144,ExpressionUUID->"587ba8b6-d091-47e0-b11f-d23f43152a65"],

Cell[TextData[{
 "Construct the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ed14f694-e673-490e-b1ec-87fe0f67fa27"],
 ", which here will be used to describe the projective quantum jump operators \
rather than the measurement processes."
}], "ExampleText",
 CellID->664356365,ExpressionUUID->"14277db0-08e8-432c-99d8-36e96565065c"],

