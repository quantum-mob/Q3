Cell[TextData[{
 "Given quantum jump operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "k"], TraditionalForm]],ExpressionUUID->
  "3b8d9e8f-0959-46a3-98f3-f7668af6d550"],
 ", the effective damping operator is defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{
     FractionBox["1", "2"], 
     UnderscriptBox["\[CapitalSigma]", "k"], 
     SubsuperscriptBox["L", "k", "\[Dagger]"], 
     SubscriptBox["L", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "5cd2a7bd-912e-45e5-ae9c-bb766b244e2d"],
 "\[LineSeparator]It is expressed as a bilinear combination of Majorana \
operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "058ec576-8780-4127-bcbd-f4967f1bd088"],
 " as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", "=", 
    RowBox[{
     SubscriptBox["g", "0"], "+", 
     RowBox[{
      FractionBox["\[ImaginaryI]", "4"], 
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
      SubscriptBox["c", "i"], 
      SubscriptBox["g", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], " ", 
      SubscriptBox["c", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "105d3d39-1dbe-49a8-a822-dcab75aa4e70"],
 "\[LineSeparator]Here, notice the factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ImaginaryI]", "/", "4"}], TraditionalForm]],ExpressionUUID->
  "dcb7567b-ddfc-4537-bf9d-bbe1424e5f06"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiDampingOperator"]], 
    "paclet:QuantumMob/Q3/ref/BravyiDampingOperator", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "49e10d4b-3f40-41f4-8574-c0a3ae201b4f"],
 " returns ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"g", ",", 
     SubscriptBox["g", "0"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "c03010b0-97ab-4b7d-8a15-bba6975a1aff"],
 "."
}], "Notes",
 CellID->1494756519,ExpressionUUID->"89ad9dec-5e1c-4f1a-b2f9-78947a7fd676"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ops", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "87282e4a-58b6-413a-9477-1f52eb9d2e42"],
 ", \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", ":=", 
    RowBox[{"\[ImaginaryI]", "[", 
     RowBox[{
      RowBox[{"m", " ", 
       SuperscriptBox["m", "\[Dagger]"]}], "-", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"m", " ", 
         SuperscriptBox["m", "\[Dagger]"]}], ")"}], "*"]}], "]"}]}], 
   TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "e82982eb-7192-46ee-867e-689ca4e60e9a"],
 " ,  \t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "0"], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"Tr", "[", 
       RowBox[{"m", "\[VeryThinSpace]", 
        SuperscriptBox["m", "\[Dagger]"]}], "]"}]}], "\[Congruent]", 
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["\[CapitalSigma]", "i"], 
      SuperscriptBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"8831967f-5bda-46b0-867c-c2961d4855c9"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "i"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["m", 
       RowBox[{"i", "\[VeryThinSpace]", "1"}]], ",", 
      SubscriptBox["m", 
       RowBox[{"i", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]", ",", 
      SubscriptBox["m", 
       RowBox[{"i", ",", 
        RowBox[{"2", "n"}]}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "768fa365-0064-404e-a31f-8efce6e2b53f"],
 " is the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["i", "th"], TraditionalForm]],ExpressionUUID->
  "303eb681-afdd-4127-8fe4-4ad342acb1fd"],
 " row of matrix ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "143b35b8-ff4f-4479-a956-8ca4c551b8c7"],
 " describes the decoherence process of the quantum jump operator\
\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "0eab7f4a-fb05-4fdb-81ec-0e4cc9872d02"],
 " (not necessarily a dressed mode)."
}], "Notes",
 CellID->725440945,ExpressionUUID->"25923258-1b7f-471b-9de8-b4a0f32f25ae"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ops", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMeasurement"]], 
      "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fd1929f4-9f84-4e66-95b8-426a524f3218"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "i"], 
     RowBox[{"\[ImaginaryI]", "(", 
      RowBox[{
       TemplateBox[{
         SubscriptBox["m", "i"]},
        "Ket"], "|", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          RowBox[{"\[LeftDoubleBracketingBar]", 
           SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"], 
         TemplateBox[{
           SubscriptBox["m", "i"]},
          "Bra"]}], "-", 
        RowBox[{
         TemplateBox[{
           SubsuperscriptBox["m", "i", "*"]},
          "Ket"], 
         SuperscriptBox[
          RowBox[{"\[LeftDoubleBracketingBar]", 
           SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"], 
         TemplateBox[{
           SubsuperscriptBox["m", "i", "*"]},
          "Bra"]}]}]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "309d03ab-cd05-4672-b066-6bc303d7d226"],
 ",    \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "0"], ":="}], TraditionalForm]],ExpressionUUID->
  "a5699d05-627e-4cce-8dac-2b7d21e81983"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalSigma]", "i"], 
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "4"]}], 
   TraditionalForm]],ExpressionUUID->"da5719b9-8276-492b-a75c-681cb6fd5259"],
 ",\[LineSeparator]where the row ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "i"], TraditionalForm]],ExpressionUUID->
  "3468243a-ac33-4d17-b9fd-065587d10e0f"],
 " describes the decoherence process of the quantum jump operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["b", "i", "\[Dagger]"], 
     SubscriptBox["b", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "3aa61880-6f4b-4177-bac0-f66544beb5fd"],
 " association with the dressed Fermion mode\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "4d5d34c5-f139-4d27-8530-0c070ce35ce1"],
 " (unnormalized)."
}], "Notes",
 CellID->1069290512,ExpressionUUID->"0c087ad9-d864-4201-9973-863cd323edba"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

