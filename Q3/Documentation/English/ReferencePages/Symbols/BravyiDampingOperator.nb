Cell[TextData[{
 "Given quantum jump operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "k"], TraditionalForm]],ExpressionUUID->
  "4d257dfc-8b27-45cd-834f-944d12444394"],
 ", the effective damping operator is defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{
     FractionBox["1", "2"], 
     UnderscriptBox["\[CapitalSigma]", "k"], 
     SubsuperscriptBox["L", "k", "\[Dagger]"], 
     SubscriptBox["L", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "7d4f0242-df97-40e3-b03a-2df3e81c0dc7"],
 "\[LineSeparator]It is expressed as a bilinear combination of Majorana \
operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "c5b4afc1-5c02-4d7a-b4bb-056953af0386"],
 " as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", "=", 
    RowBox[{
     SubscriptBox["g", "0"], "+", 
     RowBox[{
      FractionBox["\[ImaginaryI]", "4"], 
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
      SubscriptBox["c", "i"], 
      SubscriptBox["g", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], " ", 
      SubscriptBox["c", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "a9fa6f6b-5c26-45d1-b796-18dc08df0586"],
 "\[LineSeparator]Here, notice the factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ImaginaryI]", "/", "4"}], TraditionalForm]],ExpressionUUID->
  "9929c487-0d05-40bd-85d9-e45fff739e1e"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiDampingOperator"]], 
    "paclet:QuantumMob/Q3/ref/BravyiDampingOperator", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "950d0650-3b42-4657-9cf1-561d9ca52fec"],
 " returns ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"g", ",", 
     SubscriptBox["g", "0"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "db65a0a5-a07f-4be9-910d-53eeaf2386e5"],
 "."
}], "Notes",
 CellID->1494756519,ExpressionUUID->"01556155-5688-432e-8c8f-159925b66298"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ops", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dd2336ea-a783-4059-a661-82aec3ca81a5"],
 ", \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", ":=", 
    RowBox[{"\[ImaginaryI]", "[", 
     RowBox[{
      RowBox[{"m", " ", 
       SuperscriptBox["m", "\[Dagger]"]}], "-", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"m", " ", 
         SuperscriptBox["m", "\[Dagger]"]}], ")"}], "*"]}], "]"}]}], 
   TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "8d2f964d-52fe-4d37-acb6-2b435230ecdd"],
 " ,  \t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "0"], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"Tr", "[", 
       RowBox[{"m", "\[VeryThinSpace]", 
        SuperscriptBox["m", "\[Dagger]"]}], "]"}]}], "\[Congruent]", 
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["\[CapitalSigma]", "i"], 
      SuperscriptBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"c47c8c69-6eae-4bcd-8f58-17468185b7dc"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "i"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["m", 
       RowBox[{"i", "\[VeryThinSpace]", "1"}]], ",", 
      SubscriptBox["m", 
       RowBox[{"i", "\[VeryThinSpace]", "2"}]], ",", "\[Ellipsis]", ",", 
      SubscriptBox["m", 
       RowBox[{"i", ",", 
        RowBox[{"2", "n"}]}]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "282b11a5-f87b-4ffe-91f3-187458308fc9"],
 " is the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["i", "th"], TraditionalForm]],ExpressionUUID->
  "bf3ab38a-6850-4274-bb2f-c06694d4c4b4"],
 " row of matrix ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "9ee06484-6c1a-445e-a513-248a4f97729d"],
 " describes the decoherence process of the quantum jump operator\
\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "dd6cc0c7-f628-4399-b837-62b9f1b58601"],
 " (not necessarily a dressed mode)."
}], "Notes",
 CellID->725440945,ExpressionUUID->"145c6a38-f3ca-4b6d-bb52-83e16ad96c65"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  RowBox[{
   StyleBox["ops", "TI"], "=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMeasurement"]], 
      "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4c8c5b2e-7d61-4a0b-b67a-8e98e4a80a5e"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "i"], 
     RowBox[{"\[ImaginaryI]", "(", 
      RowBox[{
       TemplateBox[{
         SubscriptBox["m", "i"]},
        "Ket"], "|", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          RowBox[{"\[LeftDoubleBracketingBar]", 
           SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"], 
         TemplateBox[{
           SubscriptBox["m", "i"]},
          "Bra"]}], "-", 
        RowBox[{
         TemplateBox[{
           SubsuperscriptBox["m", "i", "*"]},
          "Ket"], 
         SuperscriptBox[
          RowBox[{"\[LeftDoubleBracketingBar]", 
           SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"], 
         TemplateBox[{
           SubsuperscriptBox["m", "i", "*"]},
          "Bra"]}]}]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "ee59bb9c-2f60-438e-8b33-47247c046cbf"],
 ",    \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", "0"], ":="}], TraditionalForm]],ExpressionUUID->
  "932a913e-7793-4c1b-aebb-d599565859e6"],
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalSigma]", "i"], 
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "4"]}], 
   TraditionalForm]],ExpressionUUID->"51635690-a3c7-4cee-bd9d-67c670c213ef"],
 ",\[LineSeparator]where the row ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "i"], TraditionalForm]],ExpressionUUID->
  "e78c8dd9-91ad-4c2d-bb3f-7fb4074af4b7"],
 " describes the decoherence process of the quantum jump operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["b", "i", "\[Dagger]"], 
     SubscriptBox["b", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "93a95eb4-28b1-4031-8e0b-43a10370a36f"],
 " association with the dressed Fermion mode\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "fbe84b1e-20fa-4ae2-8cd1-bd47203be022"],
 " (unnormalized)."
}], "Notes",
 CellID->1069290512,ExpressionUUID->"4a4f16d8-1419-44d5-a4cc-e71856320d31"]
