  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 53, 14.039320}", 
    "history" -> {"14.0", "14.3", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {"Chebyshev polynomial"}, "specialkeywords" -> {}, 
    "tutorialcollectionlinks" -> {}, "index" -> True, "label" -> 
    "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> "QuantumMob/Q3",
     "status" -> "None", "summary" -> 
    "ChebyshevSeries[{c0, c2, ..., c 2 n} -> 1] represents a series in \
Chebyshev polynomials T 2 k with coefficients c 2 k, which leads to an even \
polynomial of degree 2 n. ChebyshevSeries[{c1, c3, ..., c 2 n - 1} -> -1] \
represents a series in Chebyshev polynomials T 2 k - 1 with coefficients c 2 \
k - 1, which leads to an odd polynomial of degree 2 n - 1. \
ChebyshevSeries[{c0, c1, c2, ..., cn} -> 0] represents a series in Chebyshev \
polynomials T k with coefficients c k, which leads to a polynomial of degree \
n without definite parity. ChebyshevSeries[{c0, c1, c2, ..., cn}] \
automatically converts to ChebyshevSeries[coeff -> parity] according to the \
parity indicated in coefficients {c0, c1, c2, ..., cn}.", "synonyms" -> {}, 
    "tabletags" -> {}, "title" -> "ChebyshevSeries", "titlemodifier" -> "", 
    "metadescription" -> "", "windowtitle" -> "ChebyshevSeries", "type" -> 
    "Symbol", "uri" -> "QuantumMob/Q3/ref/ChebyshevSeries"}},
