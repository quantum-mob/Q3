Cell[TextData[{
 "Any polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "a041f4d1-31c2-4fb1-a17d-f97a964adba0"],
 " of degree ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ea0a3fca-99b8-4367-81ea-633c2dd3f6c7"],
 " defined for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "1"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"b2ef41a0-0da8-4e89-911f-0eb08f3435e0"],
 " may be expanded as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "x", ")"}], "\[TildeTilde]", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], "n"], 
     RowBox[{
      SubscriptBox["c", "k"], 
      RowBox[{
       SubscriptBox["T", "k"], "(", "x", ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"d27a4d92-f8b7-4059-b2ee-d1a2f73e0d95"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "d4dbd371-02fd-4f40-a5fd-970c23997d59"],
 " is the Chebyshev polynomial of the first kind of degree ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "8f2150d1-4d15-4b06-a2f4-39adb8dcf1da"],
 "."
}], "Notes",
