Cell[TextData[{
 "Note that nevertheless, the single-particle Majorana Hamiltonian from the \
single-particle Dirac Hamiltonian may be different from the logarithm of ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "e3136c41-1d93-42d1-ab44-47ab7317c33f"],
 " as the anti-symmetric matrix generating a rotation is not unique."
}], "ExampleText",
 CellID->1264279909,ExpressionUUID->"b17bd772-f232-4591-8433-2ff05647b166"],

