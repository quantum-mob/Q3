Cell[TextData[{
 "The two results ",
 StyleBox["vout", "Input",
  IgnoreSpellCheck->True],
 " and ",
 StyleBox["mint", "Input"],
 " look different, but that is due to a global phase factor. Note that the \
matrix representation of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d5483654-1a3c-4306-898f-51fd42af9c34"],
 " is always in the canonical form:"
}], "ExampleText",
 CellID->459971255,ExpressionUUID->"d37b3372-3b67-488f-8021-27c0f6f64f78"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"vout", "-", 
   RowBox[{"CanonicalizeVector", "[", "mint", "]"}]}], "//", 
  "ArrayZeroQ"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
 CellID->1416867293,ExpressionUUID->"95fff076-3042-43bf-a4fc-5fcc1bcfcfde"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[10]=",
 CellID->271276877,ExpressionUUID->"ea4be08b-0a32-4618-ba93-47be09a03a56"]
}, Open  ]],

