Cell[TextData[{
 "Suppose that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["u", "TI"], ":=", 
   RowBox[{"BravyiUnitary", "[", 
    StyleBox["a", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f2863456-d3f9-4a9b-a7cf-44e02b4a4bc2"],
 ". Then, ",
 Cell[BoxData[
  StyleBox["u", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0d3ac27e-2391-4759-b553-d380b55cc971"],
 " represents the canonical transformation of ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " modes ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c", "TI"], 
   StyleBox["k", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "626b42d2-49da-47e3-a057-8e0cc031735d"],
 ":  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"u", " ", 
     SubscriptBox["c", "j"], 
     SuperscriptBox["u", "\[Dagger]"]}], ":=", 
    RowBox[{
     SubscriptBox["\[Sum]", "i"], 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubscriptBox["r", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"582ff6ae-3230-48a6-a20b-9c5ae7af5de2"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"2", "n"}]}], TraditionalForm]],ExpressionUUID->
  "6a313e29-acc8-4a30-8ee1-13e5ee68d08e"],
 ",  where ",
 Cell[BoxData[
  RowBox[{
   StyleBox["r", "TI"], ":=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["MatrixExp"]], "paclet:ref/MatrixExp"},
     "RefLink",
     BaseStyle->{"InlineFormula"}], "[", 
