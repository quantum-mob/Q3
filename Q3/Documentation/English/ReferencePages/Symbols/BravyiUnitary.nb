Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"hamOp", "=", 
   RowBox[{
    RowBox[{"MultiplyDot", "[", 
     RowBox[{"cc", ",", 
      RowBox[{"ham", ".", "cc"}]}], "]"}], "*", 
    RowBox[{"I", "/", "4"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hamOp", "=", 
   RowBox[{"ToDirac", "[", 
    RowBox[{"hamOp", ",", 
     RowBox[{"cc", "->", "aa"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"uni", "=", 
  RowBox[{"MatrixExp", "[", 
   RowBox[{
    RowBox[{"-", "I"}], "*", 
    RowBox[{"Matrix", "[", 
     RowBox[{"hamOp", ",", "aa"}], "]"}]}], "]"}]}]}], "Input",
