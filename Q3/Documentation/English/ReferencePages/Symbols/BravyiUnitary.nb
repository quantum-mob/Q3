Cell[TextData[{
 "Get the representative anti-symmetric matrix of the Hamiltonian. Notice the \
factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "4"}], "\[ImaginaryI]"}], TraditionalForm]],ExpressionUUID->
  "f2d3c66e-496b-48bd-a533-4c5a5e1049d9"],
 " since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", ":=", 
    RowBox[{
     FractionBox["\[ImaginaryI]", "4"], 
     SubscriptBox["c", "i"], 
     SubscriptBox["A", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "5aab1780-8d35-44ef-98e3-807ad1f44037"],
 ":"
}], "ExampleText",
 CellID->932658973,ExpressionUUID->"28d0a423-db68-4630-b217-c34629c69118"],

