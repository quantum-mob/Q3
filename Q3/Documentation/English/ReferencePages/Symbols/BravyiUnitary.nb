Cell[TextData[{
 "The above Hermitian matrix represents a quadratic many-body Hamiltonian for \
fermion modes. Notice the factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "/", "2"}], TraditionalForm]],ExpressionUUID->
  "897cd761-a14f-4c7e-847f-00a2c151e661"],
 " since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", ":=", 
    RowBox[{
     FractionBox["1", "2"], " ", 
     SuperscriptBox[
      RowBox[{
       UnderscriptBox["a", "_"], " "}], "\[Dagger]"], 
     UnderscriptBox["H", "_"], 
     UnderscriptBox["a", "_"], " "}]}], TraditionalForm]],ExpressionUUID->
  "9b155702-798a-4893-8cc8-f9f8e77b0187"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{
      UnderscriptBox["a", "_"], " "}], "\[Dagger]"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["a", "1", "\[Dagger]"], ",", 
      SubsuperscriptBox["a", "2", "\[Dagger]"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["a", "1"], ",", 
      SubscriptBox["a", "2"], ",", "\[Ellipsis]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"16824fb7-6a31-4ffb-a7ee-2c60f54e19c8"],
 ":"
}], "ExampleText",
 CellID->257892830,ExpressionUUID->"80142568-115f-49a2-8f94-695b65fe6c5d"],

