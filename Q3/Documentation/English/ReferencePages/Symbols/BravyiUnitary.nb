Cell[TextData[{
 "A Gaussian-type many-body unitary operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["U", "^"], TraditionalForm]],ExpressionUUID->
  "ef1969c4-d18a-4651-a898-e9623e6d1c20"],
 " may be represented by the unitary matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "H"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"ddbfcd79-df1b-4d20-89cc-07bc51b5a908"],
 " in the Dirac spinor space and the real orthogonal matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", " ", "=", " ", 
    RowBox[{"exp", "(", "A", ")"}]}], TraditionalForm]],ExpressionUUID->
  "8cc81e97-6518-4be0-ab0b-d5ce2c33020f"],
 " in the Majorana spinor space. Here, we illustrate the relation between the \
two matrices ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "e2e9e5f9-db10-487d-abf9-2b0db60de617"],
 " and ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "9f32064b-7095-4a28-98bf-ec297d0eb2c5"],
 "."
}], "ExampleText",
 CellID->1320245205,ExpressionUUID->"9501ed36-f441-4961-892d-340db0531588"],

