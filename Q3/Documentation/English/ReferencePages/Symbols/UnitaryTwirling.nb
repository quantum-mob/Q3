Cell[TextData[{
 "The returned Choi matrix is a rank 4 tensor:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"C", "(", 
     RowBox[{"i", ",", 
      RowBox[{"k", "|", "j"}], ",", "l"}], ")"}], ":=", 
    RowBox[{"\[ScriptCapitalC]", "(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox["i", "1"], ",", 
        SubscriptBox["i", "2"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["i", "n"]}], "}"}], ",", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         SubscriptBox["k", "1"], ",", 
         SubscriptBox["k", "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox["k", "n"]}], "}"}], "|", 
       RowBox[{"{", 
        RowBox[{
         SubscriptBox["j", "1"], ",", 
         SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
         SubscriptBox["j", "n"]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox["l", "1"], ",", 
        SubscriptBox["l", "2"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["l", "n"]}], "}"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"1c18bd48-b1ad-4fa1-ae37-9aec95f6bf1e"],
 ",\[LineSeparator]Here, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ",", "j", ",", "k", ",", "l"}], TraditionalForm]],
  ExpressionUUID->"65058cb8-61f2-410c-ad52-844eb2fd39a1"],
 " are collective indices; for example, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["k", "1"], ",", 
      SubscriptBox["k", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["k", "n"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "fa6fbfb9-f1c1-4e32-a793-7e4dbc03ccff"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["k", "s"], "\[Element]", 
    RowBox[{"[", "d", "]"}]}], TraditionalForm]],ExpressionUUID->
  "5a58906d-35f2-48b9-bc58-de9746d7af97"],
 "."
}], "Notes",
 CellID->860017879,ExpressionUUID->"8dc83c09-24ee-4a87-bef1-5486b396e026"],

Cell[TextData[{
 "The twirling operation over the Haar measure of the unitary group is leads \
to Choi matrix:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"C", "(", 
     RowBox[{"i", ",", 
      RowBox[{"k", "|", "j"}], ",", "l"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"i"},
       "Bra"], 
      RowBox[{"\[DoubleStruckCapitalE]", "(", 
       RowBox[{"U", 
        TemplateBox[{"k"},
         "Ket"], 
        TemplateBox[{"l"},
         "Bra"], 
        SuperscriptBox["U", "\[Dagger]"]}], ")"}], 
      TemplateBox[{"j"},
       "Ket"]}], "=", 
     RowBox[{"\[DoubleStruckCapitalE]", "(", 
      RowBox[{
       SubscriptBox["U", 
        RowBox[{"i", "\[VeryThinSpace]", "k"}]], 
       SubsuperscriptBox["U", 
        RowBox[{"j", "\[VeryThinSpace]", "l"}], "*"]}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"3dae0375-87ef-4583-b017-98fd66289584"],
 "\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"C", "(", 
     RowBox[{"i", ",", 
      RowBox[{"k", "|", "j"}], ",", "l"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Pi]", ",", "\[Sigma]"}]], 
      RowBox[{
       SubscriptBox["\[CapitalGamma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", "\[Pi]", ")"}], 
      RowBox[{
       SubsuperscriptBox["\[CapitalGamma]", 
        RowBox[{"k", "\[VeryThinSpace]", "l"}], "*"], "(", "\[Sigma]", ")"}], 
      
      RowBox[{"Wg", "(", 
       RowBox[{
        SuperscriptBox["\[Pi]", 
         RowBox[{"-", "1"}]], "\[Sigma]"}], ")"}]}], "=", 
     RowBox[{
      SubscriptBox[
       RowBox[{
        SubscriptBox["\[CapitalSigma]", 
         RowBox[{"\[Pi]", ",", "\[Sigma]"}]], "[", 
        RowBox[{
         RowBox[{"\[CapitalGamma]", "(", "\[Pi]", ")"}], "\[CircleTimes]", 
         RowBox[{
          SuperscriptBox["\[CapitalGamma]", "*"], "(", "\[Sigma]", ")"}]}], 
        "]"}], 
       RowBox[{"i", ",", 
        RowBox[{"k", ";", "j"}], ",", "l"}]], 
      RowBox[{"Wg", "(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[Pi]", 
          RowBox[{"-", "1"}]], "\[Sigma]"}], ",", "d"}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"55df3082-d7a0-47e6-92de-d4581a9b7299"],
 "\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DoubleStruckCapitalE]", "(", "\[CenterDot]", ")"}], 
   TraditionalForm]],ExpressionUUID->"8a462a16-9ea9-46fc-8c84-607c23aaa3e6"],
 " denotes the expectation value over the Haar measure, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalGamma]", "(", "\[Pi]", ")"}], TraditionalForm]],
  ExpressionUUID->"28fe1a08-02b4-4dad-97f2-8db81797d5e4"],
 " is the matrix representation of permutation ",
 Cell[BoxData[
  FormBox["\[Pi]", TraditionalForm]],ExpressionUUID->
  "31c28598-f283-47bc-b173-6db20131f4a3"],
 " on ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "6a39897b-f911-4b17-a95c-c7e7ac7c1249"],
 ", and ",
 Cell[BoxData[
  FormBox["Wg", TraditionalForm]],ExpressionUUID->
  "8f2e7c9f-df93-48e2-902d-1969e4be7b4a"],
 " is the Weingarten function."
}], "Notes",
 CellID->1951184690,ExpressionUUID->"e8f26ba7-4dd2-46db-a432-6810af107833"],

Cell[TextData[{
 "This approach of calculating the whole Choi matrix is useful when the \
twirling operation is applied repeated to many operators. At the moment, this \
method gets slow for large ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ec8ccb88-ae61-42c9-a7bc-efed6cb4729d"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[GreaterEqual]", "5"}], TraditionalForm]],ExpressionUUID->
  "66e4cfd3-a779-4feb-a196-3457628d2df5"],
 ")."
}], "Notes",
 CellID->1679251106,ExpressionUUID->"2df49f15-7e6a-4987-9ef1-5054c1496127"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

