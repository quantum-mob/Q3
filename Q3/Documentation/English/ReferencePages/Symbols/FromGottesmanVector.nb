Cell[TextData[{
 "If ",
 Cell[BoxData[
  StyleBox["vec", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "208f2019-aac2-4e7e-b9f8-afc17637c950"],
 " is a ",
 StyleBox["full",
  FontSlant->"Italic"],
 " Gottesman vector, the returned Pauli string includes the phase factor."
}], "Notes",
 CellID->909702718,ExpressionUUID->"007ad4c2-3a95-4be8-8552-446797806076"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"f63ecad8-83c9-4e9f-a35c-18e248efdfaf"],
 " be the full Pauli group on ",
 StyleBox["n",
  FontSlant->"Italic"],
 " qubits. The center of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"8c7a7c10-c7cd-4570-88b7-85981e18b4a8"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalZ]", ":=", 
    RowBox[{"{", 
     RowBox[{"I", ",", " ", 
      RowBox[{"-", "I"}], ",", " ", 
      RowBox[{"\[ImaginaryI]", " ", "I"}], ",", " ", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "I"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"0fb859cd-7129-45ec-9580-130efb53377b"],
 ". The Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"e988f1f9-0bd3-474e-97f0-6643f149b27f"],
 " is defined to be the quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ScriptCapitalP]", "\[Prime]"], "(", "n", ")"}], "/", 
     "\[ScriptCapitalZ]"}]}], TraditionalForm]],ExpressionUUID->
  "d60ac41d-6222-46f6-8c4e-2279d2c9a12a"],
 ". The Pauli group is isomorphic to the Abelian group ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "46b7fbd6-95ff-4b04-925a-b6d5eda18a37"],
 ", which can also be regarded as a vector space over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalZ]", "2"], TraditionalForm]],
  ExpressionUUID->"2e9b46d2-05d9-44c5-bf49-3ff97c213cdd"],
 "."
}], "Notes",
 CellID->447549871,ExpressionUUID->"2d07ceb8-6955-4655-85bb-40300434bb04"],

Cell[TextData[{
 "A Pauli operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalPi]", 
       RowBox[{" ", 
        RowBox[{"j", "=", "1"}]}], 
       RowBox[{" ", "n"}]], 
      RowBox[{
       SubsuperscriptBox["X", "j", 
        SubscriptBox["x", "j"]], 
       SubsuperscriptBox["Z", "j", 
        SubscriptBox["z", "j"]]}]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"6be7998e-1405-4f1d-b20d-49cfb03b5e82"],
 "\[LineSeparator]is completely specified by the corresponding Gottesman \
vector,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"v", "(", "P", ")"}], ":=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["x", "1"], ",", 
        SubscriptBox["z", "1"], ",", 
        SubscriptBox["x", "2"], ",", 
        SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["x", "n"], ",", 
        SubscriptBox["z", "n"]}], ")"}], "T"], "\[Element]", 
     SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
      RowBox[{"2", "n"}]]}]}], TraditionalForm]],ExpressionUUID->
  "dadec926-fc97-4820-9345-e5350fa18ab0"],
 "."
}], "Notes",
 CellID->1183077781,ExpressionUUID->"98b744f4-38fd-47c5-88c5-9338dfcf4a4e"],

Cell[TextData[{
 "Sometimes, the vector space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "d143e496-79cd-4877-8fec-37437b120c6c"],
 " is called the ",
 StyleBox["Gottesman vector space",
  FontSlant->"Italic"],
 " on ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "df305462-d992-4ba6-a816-848d3be9c51f"],
 " qubits to emphasize the aforementioned isomorphism."
}], "Notes",
 CellID->1010290685,ExpressionUUID->"ff6e49b9-e9f1-4d3b-902d-f6f7740ea87b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

