Cell[TextData[{
 "The ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"k", "+", "1"}], ")"}], "th"], TraditionalForm]],ExpressionUUID->
  "b977907e-76e0-470f-9f18-b3da3ee3f6f5"],
 " GHZ state of  ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "d53f381a-0557-4cc6-8a95-ec2af4cd0888"],
 " many ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "cfd02650-102d-4e2d-9ba2-1455c3919673"],
 "-level quantum systems is given by (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Wolf, 2003"]], 
    "https://www-m5.ma.tum.de/foswiki/pub/M5/Allgemeines/PublicationsWolf/\
thesismerge.pdf"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "fdfed708-6fa2-454b-a3da-8b43907c9b54"],
 ")\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["GHZ", "k"]},
     "Ket"], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox["d"]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{"d", "-", "1"}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{"x", "+", 
          SubscriptBox["k", "1"]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"x", "+", 
          SubscriptBox["k", "2"]}]},
       "Ket"], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"x", "+", 
          SubscriptBox["k", "n"]}]},
       "Ket"]}], 
     RowBox[{"exp", "(", 
      RowBox[{
      "2", "\[Pi]", "\[VeryThinSpace]", "\[ImaginaryI]", "\[VeryThinSpace]", 
       "x", "\[VeryThinSpace]", 
       RowBox[{
        SubscriptBox["k", "1"], "/", "d"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"8b15ce61-01cc-49b1-86bd-c0b767f7e49e"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "i"], TraditionalForm]],ExpressionUUID->
  "ce41339a-5056-4005-a8a7-30cdef3d4954"],
 " are base-",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "ad3ce4a4-08d4-493e-85f2-a60e760e7872"],
 " digits of integer ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[Element]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{
       SuperscriptBox["d", "n"], "-", "1"}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"caf458fe-01ce-41c2-987b-819ae7c4ab68"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", ":=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["k", "1"], 
       SubscriptBox["k", "2"], "\[Ellipsis]", "\[VeryThinSpace]", 
       SubscriptBox["k", "n"]}], ")"}], "d"]}], TraditionalForm]],
  ExpressionUUID->"a6a4661c-50f3-438e-8cb3-ba36e9824ebc"],
 "."
}], "Notes",
 CellID->95824658,ExpressionUUID->"2a11880d-0891-46a6-9c2a-7f367f0854b3"],

Cell[TextData[{
 "The GHZ states form an orthonormal basis for the Hilbert space ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalC]", 
    RowBox[{"d", "\[Times]", "n"}]], TraditionalForm]],ExpressionUUID->
  "72ccfd45-ebae-4c5c-a4c4-5898ed4d3b7d"],
 "of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " ",
 StyleBox["d",
  FontSlant->"Italic"],
 "-level quantum systems."
}], "Notes",
 CellID->1957705826,ExpressionUUID->"15556824-7cd2-464e-a4e1-044c628b89e5"],

Cell[TextData[{
 "All GHZ states are ",
 StyleBox["local unitary equivalent",
  FontSlant->"Italic"],
