Cell[TextData[{
 "A ",
 StyleBox["Gelfand pattern",
  FontSlant->"Italic"],
 " is called a ",
 StyleBox["Gelfand-Young pattern",
  FontSlant->"Italic"],
 " if it corresponds to a ",
 StyleBox["standard Young tableau",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1166026277,ExpressionUUID->"d8c9bb67-90ca-457f-8fa4-7b4bd541d622"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandYoungPatterns"]], 
    "paclet:QuantumMob/Q3/ref/GelfandYoungPatterns", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "17edc124-52a4-4a07-8faf-e8e497e04ad4"],
 " itself is much faster than ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["LegacyYoungTableaux"]], 
    "paclet:QuantumMob/Q3/ref/LegacyYoungTableaux", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6ad8ee52-6cff-4c49-9801-67a4bb9b11a5"],
 " when generating equivalent lists. However, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungTableaux"]], "paclet:QuantumMob/Q3/ref/YoungTableaux", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d483a172-845d-478d-a3ba-90c1b129b06a"],
 " is slightly slower than ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["LegacyYoungTableaux"]], 
    "paclet:QuantumMob/Q3/ref/LegacyYoungTableaux", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0f316cec-5b81-428f-b586-0c427fd641fc"],
 " since it first generates the Gelfand-Young patterns and then convert them \
to standard Young tableaux. See the detailed analysis in ",
 ButtonBox["Properties & Relations",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandYoungPatterns#1703517899"],
 "."
}], "Notes",
 CellID->1414691926,ExpressionUUID->"4d17edbd-24bf-41af-8326-d9534fbf3d36"],

Cell[TextData[{
 "The resulting list is not in ",
 ButtonBox["lexicographic order",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandOrder"],
 ". For the ",
 StyleBox["lexicographic ordering",
  FontSlant->"Italic"],
 " of Gelfand-Young patterns or standard Young tableaux, see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandOrder"]], "paclet:QuantumMob/Q3/ref/GelfandOrder", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "18c4da73-5429-49c4-8c67-068cb2b2010f"],
 "."
}], "Notes",
 CellID->997747669,ExpressionUUID->"8e6c0443-f625-4fc8-a9be-e50e39bc300c"],

Cell[TextData[{
 StyleBox["N.B.",
  FontWeight->"Bold"],
 " Since Q3 v2.11.0, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungTableaux"]], "paclet:QuantumMob/Q3/ref/YoungTableaux", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1739a3bc-e085-4dd9-a9d4-082a5a6cd1f7"],
 " is based on ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandYoungPatterns"]], 
    "paclet:QuantumMob/Q3/ref/GelfandYoungPatterns", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "be994cba-319b-48c1-af94-e99fe0760939"],
 ", and does not use the method in the legacy Combinatorica package any \
longer. "
}], "Notes",
 CellID->1819209086,ExpressionUUID->"bbb01611-9db5-49a3-9497-0018e9293e9f"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

