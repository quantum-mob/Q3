Cell[TextData[{
 StyleBox["Verdict 2",
  FontWeight->"Bold"],
 ": Directly generating the Gelfand-Young patterns using ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandYoungPatterns"]], 
    "paclet:QuantumMob/Q3/ref/GelfandYoungPatterns", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8957ef0b-e9ef-4acf-86b3-e1c8097401ad"],
 " is ",
 StyleBox["definitely",
  FontSlant->"Italic"],
 " faster. Generating the standard Young tableaux using ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungTableaux"]], "paclet:QuantumMob/Q3/ref/YoungTableaux", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0f4be565-ad84-4024-9a79-eb8b8e388f7a"],
 " already takes longer than generating the corresponding Gelfand-Young \
patterns using ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandYoungPatterns"]], 
    "paclet:QuantumMob/Q3/ref/GelfandYoungPatterns", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6d801a05-1546-4ffb-9f55-76c8f30bd639"],
 ", and then converting the results to the Gelfand-Young patterns takes \
additional high cost."
}], "ExampleText",
 CellID->1988339663,ExpressionUUID->"6a12ed1d-2bdf-4065-9163-20f823f9a796"]
}, Open  ]]
}, Dynamic[CurrentValue[
