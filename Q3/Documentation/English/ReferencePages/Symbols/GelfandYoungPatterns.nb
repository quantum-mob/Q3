Cell["\<\
First generate  the standard Young tableaux and then convert them to the \
Gelfand-Young patterns:\
\>", "ExampleText",
 CellID->1204936576,ExpressionUUID->"51449cd2-666f-47fe-b11d-c586ffe140c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"myGelfandYoungPatterns", "[", "p_YoungShape", "]"}], ":=", 
  RowBox[{"With", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", "=", 
      RowBox[{"Total", "@", 
       RowBox[{"First", "@", "p"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"GelfandPattern", "[", 
       RowBox[{"#", ",", "n"}], "]"}], "&"}], "/@", 
     RowBox[{"Reverse", "[", 
      RowBox[{"LegacyYoungTableaux", "@", "p"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->598241622,ExpressionUUID->"5cc9ad56-32cc-4c4b-82ba-20b58cb14513"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", 
