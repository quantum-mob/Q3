Cell[TextData[{
 "Let us compare the performance of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandYoungPatterns"]], 
    "paclet:QuantumMob/Q3/ref/GelfandYoungPatterns", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "34aa0e4b-d72e-480b-9db3-36bc0dee57b2"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungTableaux"]], "paclet:QuantumMob/Q3/ref/YoungTableaux", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6d68ec82-952d-4909-a7f4-6e6448f2c7ce"],
 ". Note that since Q3 v2.11.0, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungTableaux"]], "paclet:QuantumMob/Q3/ref/YoungTableaux", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aa2e208e-35fb-4ad6-a3ea-0fac52571189"],
 " is based on ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandYoungPatterns"]], 
    "paclet:QuantumMob/Q3/ref/GelfandYoungPatterns", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2d482a5e-7bfb-4bdb-8969-8a995e43b915"],
 " and does not use the method in the legacy Combinatorica package."
}], "ExampleText",
 CellID->769392259,ExpressionUUID->"738794bb-a439-4a5a-b9a3-310faae16333"],

