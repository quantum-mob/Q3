   RowBox[{"bbb", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"myGelfandYoungPatterns", "/@", "pp"}], ",", "1"}], "]"}]}], 
   ";"}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->128505700,ExpressionUUID->"9c956df4-64a1-4d9c-b36b-4f5bde40f4bb"],

