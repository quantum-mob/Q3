Cell[TextData[{
 "The Hilbert space ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
    SuperscriptBox["\[ScriptCapitalH]", 
     RowBox[{"(", "s", ")"}]]}], TraditionalForm]],ExpressionUUID->
  "272eed61-c70d-4a19-b556-997b365c21f5"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "83241dd5-9381-48e2-bcb6-e3ae8fa4e4ab"],
 " spins of spin ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4227a24-f3a7-44b3-9c72-63e8348d475d"],
 " is decomposed into \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]]}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "j"], 
     RowBox[{
      SubscriptBox["m", "j"], 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "j", ")"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "bed674f5-5ab8-4001-88d5-d12e672dabad"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "j"], TraditionalForm]],ExpressionUUID->
  "1e17f0a7-69d1-44fc-be77-fa51c25c4b5f"],
 " is the multiplicity factor of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalH]", 
    RowBox[{"(", "j", ")"}]], TraditionalForm]],ExpressionUUID->
  "c11e7796-c652-49de-8b7b-d2794ded579d"],
 " for the total spin ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "9d28d8bd-b930-4f21-b145-6e45ba6589b9"],
 ". This is achieved by adding spins one by one. Then, the basis vectors of \
the multiplicity space is labeled by a list of intermediate total spins ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["n", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d4707a1a-520b-4806-a690-805bfa8955ea"],
 "."
}], "Notes",
 CellID->475111707,ExpressionUUID->"8d591754-ac86-4a54-a3f6-1b9ea1df39de"],

Cell[TextData[{
 "The returned association has key-value pairs of the form\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["j", "1"], ",", 
      SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["j", "n"]}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          SubscriptBox["j", "n"]}]},
       "Ket"], ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{
            SubscriptBox["j", "n"], "-", "1"}]}]},
       "Ket"], ",", "\[Ellipsis]", ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{"-", 
            SubscriptBox["j", "n"]}]}]},
       "Ket"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "81d1a2cc-e4ae-420b-8531-35fb8bafcf63"],
 " ."
}], "Notes",
 CellID->578231079,ExpressionUUID->"16bcdf4b-9a3d-472d-af32-b7bff4f3aaa7"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

