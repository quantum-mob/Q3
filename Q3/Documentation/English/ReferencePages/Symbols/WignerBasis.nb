Cell[TextData[{
 "The Hilbert space ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
    SuperscriptBox["\[ScriptCapitalH]", 
     RowBox[{"(", "s", ")"}]]}], TraditionalForm]],ExpressionUUID->
  "e38a1de9-4690-490d-8099-20cdeca2bb59"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "8e9578cb-fd85-4e6d-8b99-d80894c23254"],
 " spins of spin ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5590b559-81b1-4650-8c39-9f92f3055048"],
 " is decomposed into \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]]}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "j"], 
     RowBox[{
      SubscriptBox["m", "j"], 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "j", ")"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "7ca3a8d3-3f13-4255-8be8-6cba4965ca3c"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "j"], TraditionalForm]],ExpressionUUID->
  "32899836-944c-4a50-8291-e3a36fb05465"],
 " is the multiplicity factor of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalH]", 
    RowBox[{"(", "j", ")"}]], TraditionalForm]],ExpressionUUID->
  "0d9df751-58a8-48f4-9a30-287364410293"],
 " for the total spin ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "932293c6-fced-4161-aa7e-081705f582ed"],
 ". This is achieved by adding spins one by one. Then, the basis vectors of \
the multiplicity space is labeled by a list of intermediate total spins ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["n", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8e13e725-979c-491a-8f6b-ab1726c58932"],
 "."
}], "Notes",
 CellID->475111707,ExpressionUUID->"4fae5896-f339-4547-bf18-d84ea46e39ad"],

Cell[TextData[{
 "The returned association has key-value pairs of the form\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["j", "1"], ",", 
      SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["j", "n"]}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          SubscriptBox["j", "n"]}]},
       "Ket"], ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{
            SubscriptBox["j", "n"], "-", "1"}]}]},
       "Ket"], ",", "\[Ellipsis]", ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{"-", 
            SubscriptBox["j", "n"]}]}]},
       "Ket"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "808bbb79-24dd-408b-8844-e11163abcaea"],
 " ."
}], "Notes",
 CellID->578231079,ExpressionUUID->"eef9c545-95c3-4ac0-83f9-c52d5476a8c5"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

