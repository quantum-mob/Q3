Cell[TextData[{
 "The Hilbert space ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
    SuperscriptBox["\[ScriptCapitalH]", 
     RowBox[{"(", "s", ")"}]]}], TraditionalForm]],ExpressionUUID->
  "44590333-1e44-41f2-b82a-6e61bdb4b4e2"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cbd679cf-0a6d-4ee8-a19e-c7cdb3e31616"],
 " spins of spin ",
 Cell[BoxData[
  StyleBox["s", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dc46786e-139e-421a-9531-e5668997451a"],
 " is decomposed into \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "s", ")"}]], "\[CircleTimes]", "\[Ellipsis]"}], 
     SuperscriptBox["\[ScriptCapitalH]", 
      RowBox[{"(", "s", ")"}]]}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "j"], 
     RowBox[{
      SubscriptBox["m", "j"], 
      SuperscriptBox["\[ScriptCapitalH]", 
       RowBox[{"(", "j", ")"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "1fc72662-e82b-41b1-a8fa-ff047a575a72"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "j"], TraditionalForm]],ExpressionUUID->
  "ad494498-617a-4f28-a22a-ac8c5bcf22ad"],
 " is the multiplicity factor of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalH]", 
    RowBox[{"(", "j", ")"}]], TraditionalForm]],ExpressionUUID->
  "62c795e3-3fbd-4659-950e-3428f231844f"],
 " for the total spin ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "68980980-c8b7-45ef-b2f1-40f178e27739"],
 ". This is achieved by adding spins one by one. Then, the basis vectors of \
the multiplicity space is labeled by a list of intermediate total spins ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["n", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "18f5572c-f12d-4ce9-bd8f-2224ce9f0094"],
 "."
}], "Notes",
 CellID->475111707,ExpressionUUID->"a86d3908-f204-4b65-b128-e1cebfdde689"],

Cell[TextData[{
 "The returned association has key-value pairs of the form\[LineSeparator]\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["j", "1"], ",", 
      SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["j", "n"]}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          SubscriptBox["j", "n"]}]},
       "Ket"], ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{
            SubscriptBox["j", "n"], "-", "1"}]}]},
       "Ket"], ",", "\[Ellipsis]", ",", 
      TemplateBox[{
        RowBox[{
          SubscriptBox["j", "n"], ",", 
          RowBox[{"-", 
            SubscriptBox["j", "n"]}]}]},
       "Ket"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "88ec6771-f2ec-4692-ab7d-e7827024e6b8"],
 " ."
}], "Notes",
 CellID->578231079,ExpressionUUID->"35a57321-90f1-4fbf-979d-484db54b42ba"],

