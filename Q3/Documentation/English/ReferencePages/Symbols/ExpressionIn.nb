        RowBox[{"A", "[", 
         RowBox[{"j", ",", "#2"}], "]"}]}], "&"}], ",", 
      RowBox[{"{", 
       RowBox[{"dd", ",", "rr"}], "}"}]}], "]"}]}]}]}], "\[IndentingNewLine]", 
