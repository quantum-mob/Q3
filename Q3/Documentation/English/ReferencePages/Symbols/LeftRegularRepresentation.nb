Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "16abbecb-9c61-4671-8a6f-03874c345e13"],
 " be a finite group and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"381c7e83-8dcc-4790-a681-f3ac9da5ab0e"],
 " the basis of its group algebra. For each element ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "edd1cca2-e8cb-46e9-8e87-2c5728c01373"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "02e4fc49-2f86-4953-94f9-ce4c5ab5fca5"],
 ", define a linear map ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["L", "^"], "(", "g", ")"}], TraditionalForm]],
  ExpressionUUID->"fe516586-03b2-4b28-9353-2c16bd4c683e"],
 " by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"g", "\[VeryThinSpace]", "h"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "6ebfd269-c80b-4087-b731-bfa0bbabd544"],
 "\[LineSeparator]for all elements ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "2d4e0d8b-7f2d-4d7c-bf5e-a51be0623cfb"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "8a779c65-3ea0-460f-bf77-ff8cfa12a1cc"],
 ". It is called the ",
 StyleBox["left regular representation",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "1e33b329-83b9-4cd2-9697-3194fb2a9ed8"],
 ". In the matrix form, the left regular representation is given by\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["L", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
     SubscriptBox["g", "k"], ")"}], "=", 
    TemplateBox[{
      SubscriptBox["g", "i"], 
      RowBox[{
        SubscriptBox["g", "k"], 
        SubscriptBox["g", "j"]}]},
     "BraKet"]}], TraditionalForm]],ExpressionUUID->
  "01f4844a-6ae0-4c8d-8624-3b4f1b47e170"],
 "."
}], "Notes",
 CellID->1359449983,ExpressionUUID->"55ca8077-4f59-4910-810c-7ab971daabcc"],

Cell[TextData[{
 "Similarly, a linear map ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["R", "^"], "(", "g", ")"}], TraditionalForm]],
  ExpressionUUID->"a7ca8902-df4c-4bbe-88b4-81b3beec9a61"],
 " defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"h", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "503fc539-483d-4745-82ab-714f366ecf71"],
 "  \[LineSeparator]is called the ",
 StyleBox["right regular representation",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "7abeec74-9c70-4d68-9988-ab0ad7be651e"],
 ". In the matrix representation, it is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["R", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
     SubscriptBox["g", "k"], ")"}], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["g", "i"], 
       RowBox[{
         SubscriptBox["g", "j"], 
         SubsuperscriptBox["g", "k", 
          RowBox[{"-", "1"}]]}]},
      "BraKet"], "=", 
     TemplateBox[{
       RowBox[{
         SubscriptBox["g", "i"], 
         SubscriptBox["g", "k"]}], 
       SubscriptBox["g", "j"]},
      "BraKet"]}]}], TraditionalForm]],ExpressionUUID->
  "6bc65d15-ccbe-42ac-aa59-b094d6c1b77f"],
 " ."
}], "Notes",
 CellID->1139465644,ExpressionUUID->"a1b1e0d6-a9f5-4660-a316-33902fc5e1e3"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

