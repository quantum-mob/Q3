  StyleBox["a", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2900e957-ccc6-45db-8f81-6738bfbc1616"],
 "."
}], "Notes",
 CellID->1474099705,ExpressionUUID->"11648822-76c3-4744-8b72-29efc30a55dd"],

