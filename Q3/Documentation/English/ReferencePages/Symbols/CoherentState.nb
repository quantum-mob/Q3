Cell[BoxData[
 RowBox[{
  RowBox[{"Dagger", "[", 
   RowBox[{"a", "[", "5", "]"}], "]"}], "**", "cs"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->961314299,ExpressionUUID->"5b75c82e-ca53-40d8-a702-a8321c454998"],

Cell[BoxData[
 InterpretationBox[
  TemplateBox[{
    TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
      InterpretationBox[
       TemplateBox[{"a", 
         TemplateBox[{",", "\",\"", "5"}, "RowWithSeparators"], 
         TemplateBox[{",", "\",\"", "\"\[Dagger]\""}, "RowWithSeparators"]}, 
        "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
       Q3`Dagger[
        $CellContext`a[5]]], 
      InterpretationBox[
       InterpretationBox[
