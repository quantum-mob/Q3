 CellID->1641383878,ExpressionUUID->"eb99d56f-de01-4919-b6d8-42ca0ee0e79c"],

Cell[TextData[{
 "For a bosonic mode ",
 Cell[BoxData[
  StyleBox["a", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "06a62fad-194d-455d-9568-3e54df75f03b"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["CoherentState"]], "paclet:Graphy/ref/CoherentState", 
     "Graphy Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"<|", 
    RowBox[{"\[Ellipsis]", ",", " ", 
     RowBox[{
      StyleBox["a", "TI"], "\[Rule]", 
      StyleBox["z", "TI"]}], ",", " ", "\[Ellipsis]"}], "|>"}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a37245d8-541e-420a-ac73-ffd207b20d5b"],
 " is expanded as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox[
         RowBox[{"\[LeftBracketingBar]", "z", "\[RightBracketingBar]"}], 
         "2"]}], "/", "2"}], ")"}], 
     RowBox[{"exp", "[", 
      RowBox[{"z", "\[VeryThinSpace]", 
       SuperscriptBox["a", "\[Dagger]"]}], "]"}], 
     TemplateBox[{"0"},
      "Ket"]}], "\[Congruent]", 
    RowBox[{
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox[
         RowBox[{"\[LeftBracketingBar]", "z", "\[RightBracketingBar]"}], 
         "2"]}], "/", "2"}], ")"}], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"n", "=", "0"}], "\[Infinity]"], 
     FractionBox[
      SuperscriptBox["z", "n"], 
      SqrtBox[
       RowBox[{"n", "!"}]]], 
     TemplateBox[{"n"},
      "Ket"]}]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "d4934db0-e032-43df-8759-2adac11586fb"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"exp", "(", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", "z", "\[RightBracketingBar]"}], "2"]}],
      "/", "2"}], ")"}], TraditionalForm]],ExpressionUUID->
  "42146076-06d2-4c8d-93ed-f348337f9632"],
 " is the normalization factor."
}], "Notes",
 CellID->755508818,ExpressionUUID->"9064d83c-6e0b-4372-979a-cfbb54e559bf"],

Cell[TextData[{
 "For a fermionic mode ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]],ExpressionUUID->
  "d1df9d5c-73c5-4ad5-8c77-7ed6d1a8cb2f"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["CoherentState"]], "paclet:QuantumMob/Q3/ref/CoherentState", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"<|", 
    RowBox[{"\[Ellipsis]", ",", " ", 
     RowBox[{
      StyleBox["c", "TI"], "\[Rule]", 
      StyleBox["\[Xi]", "TR"]}], ",", "\[Ellipsis]"}], "|>"}], "]"}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aa3f7906-9376-446c-a0c2-e9614f77b069"],
 " is expanded as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["\[Xi]", "*"]}], 
        RowBox[{"\[Xi]", "/", "2"}]}], "-", 
       RowBox[{"\[Xi]", "\[VeryThinSpace]", 
        SuperscriptBox["c", "\[Dagger]"]}]}], ")"}], 
     TemplateBox[{"0"},
      "Ket"]}], "\[Congruent]", 
    RowBox[{
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["\[Xi]", "*"]}], 
       RowBox[{"\[Xi]", "/", "2"}]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"\[Xi]", "\[VeryThinSpace]", 
        SuperscriptBox["c", "\[Dagger]"]}]}], ")"}], 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "cadbf102-9604-442a-98c7-ecc7c6cb5088"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"exp", "(", 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox["\[Xi]", "*"]}], 
     RowBox[{"\[Xi]", "/", "2"}]}], ")"}], TraditionalForm]],ExpressionUUID->
  "dd1d07a1-73d2-4665-b158-e15dcc5538d3"],
 " is the normalization factor."
}], "Notes",
 CellID->1322214744,ExpressionUUID->"d2b5ef4c-bfec-4b8e-9ff7-0ffd5d362871"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Elaborate"]], "paclet:QuantumMob/Q3/ref/Elaborate", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
