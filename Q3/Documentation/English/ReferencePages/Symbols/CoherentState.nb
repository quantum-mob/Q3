Cell["This shows how to specify a coherent state.", "ExampleText",
 CellID->1605853767,ExpressionUUID->"5670dc28-5eb9-428b-9fa2-58b84e9cbb41"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cs", "=", 
  RowBox[{"CoherentState", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "1", "]"}], "\[Rule]", 
     RowBox[{"1", "+", 
      RowBox[{"3", " ", "I"}]}]}], ",", " ", 
    RowBox[{
     RowBox[{"a", "[", "2", "]"}], "\[Rule]", 
     RowBox[{"-", "1"}]}]}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->147680091,ExpressionUUID->"8ce93fb4-6c9e-423d-b5a6-a7af16ddf60f"],

Cell[BoxData[
 InterpretationBox[
  InterpretationBox[
   TemplateBox[{
     TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
       SubscriptBox[
        TagBox[
         RowBox[{"(", 
           RowBox[{"1", "+", 
             RowBox[{"3", " ", "\[ImaginaryI]"}]}], ")"}], DisplayForm], 
        TemplateBox[{",", "\",\"", 
          InterpretationBox[
           SubscriptBox["a", 
            TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
           $CellContext`a[1]]}, "RowWithSeparators"]], 
       SubscriptBox[
        TagBox[
         RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}], DisplayForm], 
        TemplateBox[{",", "\",\"", 
          InterpretationBox[
           SubscriptBox["a", 
            TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
           $CellContext`a[2]]}, "RowWithSeparators"]]}, "RowWithSeparators"]},
    
    "Ket"],
   Ket[<|$CellContext`a[1] -> Complex[1, 3], $CellContext`a[2] -> -1|>]],
  Q3`CoherentState[<|$CellContext`a[1] -> 
    Complex[1, 3], $CellContext`a[2] -> -1|>]]], "Output",
 CellLabel->"Out[2]=",
 CellID->938379845,ExpressionUUID->"6a15d9ce-30b8-47ef-bddd-611d84a6315c"]
}, Open  ]],

