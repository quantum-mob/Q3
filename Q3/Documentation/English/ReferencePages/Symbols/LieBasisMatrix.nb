Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sbs", "=", 
   RowBox[{"NestList", "[", 
    RowBox[{"RotateRight", ",", 
     RowBox[{"PadRight", "[", 
      RowBox[{
       RowBox[{"{", "1", "}"}], ",", 
       RowBox[{"$n", "*", "$n"}]}], "]"}], ",", 
     RowBox[{
      RowBox[{"$n", "*", "$n"}], "-", "1"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sbs", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"ArrayReshape", "[", 
      RowBox[{"#", ",", 
       RowBox[{"{", 
        RowBox[{"$n", ",", "$n"}], "}"}]}], "]"}], "&"}], "/@", "sbs"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "/@", "sbs"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1832941869,ExpressionUUID->"611b823d-e6f0-42a6-a178-a1126594b4ce"],

