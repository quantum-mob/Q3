Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "c58d4977-3352-4f31-a4b2-c3c164ec7682"],
 " be bosonic modes. They may be expressed in terms of Heisenberg modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "k"], TraditionalForm]],ExpressionUUID->
  "bb45e445-1983-4076-9923-316312eecabd"],
 " and its canonical conjugate ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["x", "k", "c"], TraditionalForm]],ExpressionUUID->
  "845c4054-b0ba-4616-8171-b8ff7774445d"],
 " as:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "k"], "+", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubsuperscriptBox["x", "k", "c"]}]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "d863588d-e595-4c2d-8d00-a7f7fb7ca8ff"],
 " ,\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "k", "\[Dagger]"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "k"], "-", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubsuperscriptBox["x", "k", "c"]}]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "de49ea2c-6776-4d75-96cf-dfae0d1aa5f0"],
 " ."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"5562a6fe-d756-4fcc-bcd3-aa2c189b0972"],

Cell[TextData[{
 "The bosonic modes satisfies the commutation relations\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["a", "i"], ",", 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "]"}], "=", 
    SubscriptBox["\[Delta]", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], TraditionalForm]],
  ExpressionUUID->"ab9b6f9c-d5f9-4f7e-920d-edd0b187d2bd"],
 " ,        ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["a", "i"], ",", 
      SubscriptBox["a", "j"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"f22f7f88-766c-47b5-ba00-fd4033fa2a32"],
 ",        ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubsuperscriptBox["a", "i", "\[Dagger]"], ",", 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "]"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"83d86d78-d9de-4136-a682-b184a305502d"],
 "."
}], "Notes",
 CellID->991385285,ExpressionUUID->"1dcb7d9b-4ad9-4069-b143-16bbe62ff525"],

Cell[TextData[{
 "On the other hand, the Heisenberg modes and their canonical conjugates \
satisfy the commutation relations\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["x", "i"], ",", 
      SubsuperscriptBox["x", "j", "c"]}], "]"}], "=", 
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"306c9344-2ceb-4a07-8ca6-3e48282732be"],
 " ,        ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["x", "i"], ",", 
      SubscriptBox["x", "j"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"d55cc9d8-55a7-433f-94cb-b261b53f2449"],
 " ,        ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubsuperscriptBox["x", "i", "c"], ",", 
      SubsuperscriptBox["x", "j", "c"]}], "]"}], "=", "0"}], 
   TraditionalForm]],ExpressionUUID->"2b9e8bb8-ebc0-4851-960d-c305b5e5e15f"],
 " ."
}], "Notes",
 CellID->1623682607,ExpressionUUID->"d8c15a8d-63ea-41f8-9877-4ff9d7c45c59"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

