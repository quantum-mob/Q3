Cell["Supermap is a linear mapping of linear operators.", "Notes",
 CellID->1067943069,ExpressionUUID->"f2f17958-4ae8-4b51-8817-e7c8d4b855bb"],

Cell[TextData[{
 "Specifically, let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "871afcd2-4902-448f-a27f-2a78e0acbccf"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "75998ddc-d592-4005-b981-743eb5836e20"],
 " be vector spaces, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      OverscriptBox["A", "^"], ":", 
      RowBox[{"\[ScriptCapitalV]", "\[RightArrow]", "\[ScriptCapitalV]"}]}], 
     "}"}]}], TraditionalForm]],ExpressionUUID->
  "65ead125-86b1-4505-bc11-076b237a62c0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalW]", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      OverscriptBox["A", "^"], ":", 
      RowBox[{"\[ScriptCapitalW]", "\[RightArrow]", "\[ScriptCapitalW]"}]}], 
     "}"}]}], TraditionalForm]],ExpressionUUID->
  "391307c0-2494-4606-bf0d-b3cb7782d537"],
 " vector spaces of linear operators on \[ScriptCapitalV] and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "fa1bd6dd-d5c5-44de-a80c-b83515b32ddd"],
 ", respectively. A linear map ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", ":", 
    RowBox[{
     RowBox[{"\[ScriptCapitalL]", 
      RowBox[{"(", "\[ScriptCapitalV]", ")"}]}], "\[RightArrow]", 
     RowBox[{"\[ScriptCapitalL]", 
      RowBox[{"(", "\[ScriptCapitalW]", ")"}], " "}]}]}], TraditionalForm]],
  ExpressionUUID->"81212403-3bc0-48d0-9173-91ea9e52efc7"],
 "is called a ",
 StyleBox["supermap",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->579543253,ExpressionUUID->"9ba33589-373d-4839-b4fc-cdd47f51d9c8"],

Cell[TextData[{
 "A supermap is typically specified by an operator-sum representation or ",
