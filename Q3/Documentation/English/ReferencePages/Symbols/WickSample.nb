Cell[TextData[{
 "Build a random Green\[CloseCurlyQuote]s function G with the physics \
convention: pick eigenvalues ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "i"], TraditionalForm]],ExpressionUUID->
  "a71cf22b-0d73-46fd-bfea-635a9f2378cf"],
 " in [0,1] for the correlation matrix C, then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", " ", "=", " ", 
    RowBox[{
     SuperscriptBox["U", "\[Dagger]"], " ", 
     RowBox[{"(", 
      RowBox[{"I", " ", "-", " ", 
       RowBox[{"diag", 
        RowBox[{"(", "\[Lambda]", ")"}]}]}], ")"}], " ", "U"}]}], 
   TraditionalForm]],ExpressionUUID->"6a4235ba-9c4e-47e8-bdcd-9467e14fd1d6"],
 ":"
}], "ExampleText",
 CellID->709364841,ExpressionUUID->"4d16a367-5358-4d26-a406-c2108b6c8de9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1613158190,ExpressionUUID->"87c401c9-8f76-4cf5-b081-3e817582410f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$m", "=", "4"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->984566510,ExpressionUUID->"3d78a08e-6299-4940-8d84-f38afb1f971d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"UU", "=", 
   RowBox[{"RandomUnitary", "[", "$m", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lambda", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", "$m"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Gtest", "=", 
   RowBox[{
    RowBox[{"ConjugateTranspose", "[", "UU", "]"}], ".", 
    RowBox[{"DiagonalMatrix", "[", 
     RowBox[{"1", "-", "lambda"}], "]"}], ".", "UU"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Gtest", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Gtest", "+", 
       RowBox[{"ConjugateTranspose", "[", "Gtest", "]"}]}], ")"}], "/", 
     "2"}]}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{"enforce", " ", "Hermiticity"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Gtest", "//", "Chop"}], "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->2112149060,ExpressionUUID->"eeba167d-b093-4a88-bd22-e557bb933a2b"],

