Cell[TextData[{
 "Build a random Green\[CloseCurlyQuote]s function G with the physics \
convention: pick eigenvalues ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "i"], TraditionalForm]],ExpressionUUID->
  "e30450f6-93ee-4a9b-b02f-854e4736ae67"],
 " in [0,1] for the correlation matrix C, then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", " ", "=", " ", 
    RowBox[{
     SuperscriptBox["U", "\[Dagger]"], " ", 
     RowBox[{"(", 
      RowBox[{"I", " ", "-", " ", 
       RowBox[{"diag", 
        RowBox[{"(", "\[Lambda]", ")"}]}]}], ")"}], " ", "U"}]}], 
   TraditionalForm]],ExpressionUUID->"5554ff76-d700-4835-8dcd-7bdc7fe23250"],
 ":"
}], "ExampleText",
 CellID->709364841,ExpressionUUID->"59289264-f850-4be2-94e3-c8597b8d0a27"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1613158190,ExpressionUUID->"0ff31b96-6829-47e7-90cb-871d4b34b78e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"$m", "=", "4"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->984566510,ExpressionUUID->"195b3f1f-4b09-463c-ab02-91bdd931dc8b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"UU", "=", 
   RowBox[{"RandomUnitary", "[", "$m", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"lambda", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", "$m"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Gtest", "=", 
   RowBox[{
    RowBox[{"ConjugateTranspose", "[", "UU", "]"}], ".", 
    RowBox[{"DiagonalMatrix", "[", 
     RowBox[{"1", "-", "lambda"}], "]"}], ".", "UU"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Gtest", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Gtest", "+", 
       RowBox[{"ConjugateTranspose", "[", "Gtest", "]"}]}], ")"}], "/", 
     "2"}]}], ";"}], "   ", 
  RowBox[{"(*", 
   RowBox[{"enforce", " ", "Hermiticity"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Gtest", "//", "Chop"}], "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->2112149060,ExpressionUUID->"6b3a1bcf-c185-4ac2-ba7f-ca46f4cdf924"],

