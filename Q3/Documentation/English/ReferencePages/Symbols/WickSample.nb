Cell[TextData[{
 "\[OpenCurlyDoubleQuote]Being definitely occupied\[CloseCurlyDoubleQuote] \
means ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", " ", "n", " ", "\[RightAngleBracket]"}], 
    " ", "=", " ", "1"}], TraditionalForm]],ExpressionUUID->
  "a74c086e-c515-4069-a738-7b45a03b6482"],
 ", i . e . ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "i"}]], " ", "=", " ", "0"}], 
   TraditionalForm]],ExpressionUUID->"390bca30-a4a9-4f27-ad51-792f156750cb"],
 " (and the entire row/column vanishes. Here, to check the numerical \
stability of the implementation, consider a 3-mode state where mode 1 is \
definitely occupied, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "11"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "72cd71ab-47c5-4ccd-aa3e-0e6aa9b6daee"],
 ", and the first row/column are zero. The remaining 2x2 block is a generic \
legitimate Green's function on modes 2 and 3."
}], "ExampleText",
 CellID->405225119,ExpressionUUID->"d0269f1d-6d45-4341-9ddb-fee479a6943d"],

