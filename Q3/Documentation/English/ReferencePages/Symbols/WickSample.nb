Cell["\<\
Calculate the exact joint probabilities  (warning: it takes long for a large \
number of modes):\
\>", "ExampleText",
 CellID->510314090,ExpressionUUID->"1e229a53-5451-4152-b520-5886216fb1c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"exactProb", "[", 
    RowBox[{"s_List", ",", "G_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", ",", 
       RowBox[{"mm", "=", 
        RowBox[{"Length", "[", "s", "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"M", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"s", "[", 
             RowBox[{"[", "a", "]"}], "]"}], "==", "1"}], ",", 
           RowBox[{
            RowBox[{"KroneckerDelta", "[", 
             RowBox[{"a", ",", "b"}], "]"}], "-", 
            RowBox[{"G", "[", 
             RowBox[{"[", 
              RowBox[{"a", ",", "b"}], "]"}], "]"}]}], ",", 
           RowBox[{"G", "[", 
            RowBox[{"[", 
             RowBox[{"a", ",", "b"}], "]"}], "]"}]}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"a", ",", "mm"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"b", ",", "mm"}], "}"}]}], "\[IndentingNewLine]", "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"Re", "[", 
       RowBox[{"Det", "[", "M", "]"}], "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1946708159,ExpressionUUID->"6d65feaf-43fa-482b-bd7f-6644fd41dd77"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"allOutcomes", "=", 
   RowBox[{"Tuples", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", "$m"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"exactDist", "=", 
    RowBox[{"AssociationMap", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"exactProb", "[", 
        RowBox[{"#", ",", "Gtest"}], "]"}], "&"}], ",", "allOutcomes"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Echo", "[", 
   RowBox[{
    RowBox[{"Total", "[", 
     RowBox[{"Values", "[", "exactDist", "]"}], "]"}], 
    ",", "\"\<Sanity: sum of exact probabilities = \>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Echo", "[", 
   RowBox[{
    RowBox[{"1", "-", 
     RowBox[{"Re", "[", 
      RowBox[{"Gtest", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}]}], 
    ",", "\"\<Sanity: <n_1> from G = \>\""}], "]"}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1410666268,ExpressionUUID->"a70aa259-ad37-4200-98c7-f9984b18e070"],

Cell[CellGroupData[{

Cell[BoxData["0.000265`"], "EchoTiming",
 CellID->1962482462,ExpressionUUID->"8fc6c782-bb1e-40d4-a81a-10761c74fc6e"],

Cell[BoxData[
 RowBox[{
  TagBox["\<\"Sanity: sum of exact probabilities = \"\>",
   "EchoLabel"], "  ", "1.`"}]], "Echo",
 CellID->241404561,ExpressionUUID->"9428c11d-c6e4-4287-8d83-6f9cf4df7309"],

Cell[BoxData[
 RowBox[{
  TagBox["\<\"Sanity: <n_1> from G = \"\>",
   "EchoLabel"], "  ", "0.9002361921613021`"}]], "Echo",
 CellID->689847544,ExpressionUUID->"cb220646-06d0-4531-96ff-3d657aa17e22"]
}, Open  ]]
}, Open  ]],

Cell["Do the Monte Carlo simulation:", "ExampleText",
 CellID->2022511031,ExpressionUUID->"364d046f-8e7c-4950-86e4-8661ea8e888b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"nSamples", "=", "200000"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"samples", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"First", "[", 
       RowBox[{"WickSample", "[", "Gtest", "]"}], "]"}], ",", "nSamples"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"empiricalDist", "=", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"Counts", "[", "samples", "]"}], "/", "nSamples"}], "]"}]}], 
  ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1971733301,ExpressionUUID->"88fa68ed-a586-4e67-a823-d740ff183b39"],

Cell[BoxData["5.385217`"], "EchoTiming",
 CellID->3461855,ExpressionUUID->"e12e48ff-3e23-443d-b7b5-40cf5b012332"]
}, Open  ]],

Cell["Compare the Monte Carlo result with the exact probabilities:", \
"ExampleText",
 CellID->1101433050,ExpressionUUID->"29c7d394-d0ce-41e6-abdd-43ddc8cd667b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TableForm", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "s", "}"}], ",", 
       RowBox[{"exactDist", "[", "s", "]"}], ",", 
       RowBox[{"Lookup", "[", 
        RowBox[{"empiricalDist", ",", 
         RowBox[{"Key", "[", "s", "]"}], ",", "0."}], "]"}], ",", 
       RowBox[{
        RowBox[{"Lookup", "[", 
         RowBox[{"empiricalDist", ",", 
          RowBox[{"Key", "[", "s", "]"}], ",", "0."}], "]"}], "-", 
        RowBox[{"exactDist", "[", "s", "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"s", ",", "allOutcomes"}], "}"}]}], "\[IndentingNewLine]", 
    "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"TableHeadings", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", 
      RowBox[{"{", 
       RowBox[{"\"\<outcome\>\"", ",", "\"\<exact\>\"", 
        ",", "\"\<empirical\>\"", ",", "\"\<diff\>\""}], "}"}]}], "}"}]}]}], 
