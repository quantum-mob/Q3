  RowBox[{
   RowBox[{"Table", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", "s", "}"}], ",", 
       RowBox[{"exactDist", "[", "s", "]"}], ",", 
