Cell[TextData[{
 "Green\[CloseCurlyQuote]s function matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "2d0feff8-bb19-4f45-b041-48b08196185a"],
 ", defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubsuperscriptBox["c", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"f46a101a-84a1-4275-b2f4-ef6ffaa0d2cf"],
 ", must be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Times]", "m"}], TraditionalForm]],ExpressionUUID->
  "9f5b00c1-bd5f-4017-aed2-6f9b0ec5573f"],
 " Hermitian matrix satisfying ",
 Cell[BoxData[
  FormBox[
   RowBox[{
   "0", " ", "\[LessEqual]", " ", "G", " ", "\[LessEqual]", " ", "I"}], 
   TraditionalForm]],ExpressionUUID->"c0cb7536-6169-4f00-8359-309703ae0de5"],
 " (eigenvalues in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"0", ",", "1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "b08787c6-c11f-4b60-a00d-44afec31d8ba"],
 "). The diagonal entry ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "i"}]], "=", 
    RowBox[{"1", "-", 
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox["n", "i"], "\[RightAngleBracket]"}]}]}], TraditionalForm]],
  ExpressionUUID->"a2c1d4b7-26ad-420d-b5c7-1ba603166dd8"],
 ", i.e. the probability that mode ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "06177f44-1be5-40da-a854-879cbf909daa"],
 " is empty."
}], "Notes",
 CellID->1400058095,ExpressionUUID->"4048fd18-6899-4e47-9555-4d3fcfbd04ce"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["WickSample"]], "paclet:QuantumMob/Q3/ref/WickSample", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["G", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3738e13d-ddae-43c0-8b08-d2b0f46d4864"],
 " returns ",
 Cell[BoxData[
  RowBox[{
   StyleBox["outcome", "TI"], "\[Rule]", 
   StyleBox["probability", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2137fb3b-bb30-4339-a4b2-1c26ed335c4c"],
 ", where ",
 Cell[BoxData[
  StyleBox["outcome", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "59dfb728-9303-41fc-96e2-83b62bc2167f"],
 " is a length-",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ed84c5bb-874d-4713-839a-80782436102f"],
 " list of bits (1 = occupied, 0 = empty) sampled from the exact joint \
distribution\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "s", ")"}], "=", 
    RowBox[{"det", "[", 
     RowBox[{
      RowBox[{
       SubscriptBox["s", "i"], "(", 
       RowBox[{
        SubscriptBox["\[Delta]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]], "-", 
        SubscriptBox["G", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], ")"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SubscriptBox["s", "i"]}], ")"}], 
       SubscriptBox["G", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"92555e62-add6-4be4-8432-488f37cf8015"],
 ",\[LineSeparator]and ",
 Cell[BoxData[
  StyleBox["probability", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b565a361-4953-4b82-b2ba-654e4aaabbe5"],
 " is the corresponding joint probability of that outcome."
}], "Notes",
 CellID->803053899,ExpressionUUID->"303a4473-5b0b-4867-ac53-222820244181"],

Cell[TextData[{
 "With option ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Tolerance"]], "paclet:ref/Tolerance"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   StyleBox["tol", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8f0f1b8e-1104-49ac-a28b-4115afc9701f"],
 ", ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["WickSample"]], "paclet:QuantumMob/Q3/ref/WickSample", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["G", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f2a1cdce-a134-4e27-b2d6-b44c9eb7b312"],
 " uses tolerance ",
 Cell[BoxData[
  StyleBox["tol", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "979859b9-de84-47fc-86a9-c9f6e67d009d"],
 " (default ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "10"}]], TraditionalForm]],ExpressionUUID->
  "eaf899a6-9eaa-4a3c-bc65-12cf532dae0b"],
 ") to detect deterministic modes (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", 
    RowBox[{"i", "\[VeryThinSpace]", "i"}]], TraditionalForm]],ExpressionUUID->
  "1c8b0ff2-fada-4341-92f7-f6399c48aee0"],
 " numerically 0 or 1), for which the outcome is forced and the \
Schur-complement update is skipped."
}], "Notes",
 CellID->1347794300,ExpressionUUID->"d62b5375-0930-441a-9a34-ff2f623ffcbb"],

Cell[TextData[{
 "The implementation is the chain-rule / Schur-complement sampler for \
free-fermion states and runs in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"O", "(", 
    SuperscriptBox["m", "3"], ")"}], TraditionalForm]],ExpressionUUID->
  "4a5b2f93-18ec-4287-9a18-bee4293d65a9"],
 " time."
}], "Notes",
