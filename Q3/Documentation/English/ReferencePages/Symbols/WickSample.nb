Cell["\<\
Calculate the exact joint probabilities  (warning: it takes long for a large \
number of modes):\
\>", "ExampleText",
 CellID->510314090,ExpressionUUID->"f0f07945-2174-40b5-bb1c-de22bc3df021"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"exactProb", "[", 
    RowBox[{"s_List", ",", "G_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"M", ",", 
       RowBox[{"mm", "=", 
        RowBox[{"Length", "[", "s", "]"}]}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"M", "=", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"s", "[", 
             RowBox[{"[", "a", "]"}], "]"}], "==", "1"}], ",", 
           RowBox[{
            RowBox[{"KroneckerDelta", "[", 
             RowBox[{"a", ",", "b"}], "]"}], "-", 
            RowBox[{"G", "[", 
             RowBox[{"[", 
              RowBox[{"a", ",", "b"}], "]"}], "]"}]}], ",", 
           RowBox[{"G", "[", 
            RowBox[{"[", 
             RowBox[{"a", ",", "b"}], "]"}], "]"}]}], "]"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"a", ",", "mm"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"b", ",", "mm"}], "}"}]}], "\[IndentingNewLine]", "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"Re", "[", 
       RowBox[{"Det", "[", "M", "]"}], "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1946708159,ExpressionUUID->"f4b20380-5411-4286-b513-38b7e45658ba"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"allOutcomes", "=", 
   RowBox[{"Tuples", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", "$m"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"exactDist", "=", 
    RowBox[{"AssociationMap", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"exactProb", "[", 
        RowBox[{"#", ",", "Gtest"}], "]"}], "&"}], ",", "allOutcomes"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Echo", "[", 
   RowBox[{
    RowBox[{"Total", "[", 
     RowBox[{"Values", "[", "exactDist", "]"}], "]"}], 
    ",", "\"\<Sanity: sum of exact probabilities = \>\""}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Echo", "[", 
   RowBox[{
    RowBox[{"1", "-", 
     RowBox[{"Re", "[", 
      RowBox[{"Gtest", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}]}], 
    ",", "\"\<Sanity: <n_1> from G = \>\""}], "]"}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->1410666268,ExpressionUUID->"e6926706-c3f5-4fff-bb96-11e5f1d1724f"],

Cell[CellGroupData[{

Cell[BoxData["0.000265`"], "EchoTiming",
 CellID->1962482462,ExpressionUUID->"68e226fe-0308-4e41-a7de-219306f9fff5"],

Cell[BoxData[
 RowBox[{
  TagBox["\<\"Sanity: sum of exact probabilities = \"\>",
   "EchoLabel"], "  ", "1.`"}]], "Echo",
 CellID->241404561,ExpressionUUID->"6e24f9f7-30c5-48cb-99df-6b13d9fe56a6"],

Cell[BoxData[
 RowBox[{
