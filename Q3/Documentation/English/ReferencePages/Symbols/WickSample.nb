Cell[BoxData[{
 RowBox[{
  RowBox[{"worstDiff", "=", 
   RowBox[{"Max", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"Lookup", "[", 
         RowBox[{"empiricalDist", ",", 
          RowBox[{"Key", "[", "#", "]"}], ",", "0."}], "]"}], "-", 
        RowBox[{"exactDist", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
     "allOutcomes"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Worst |empirical - exact| = \>\"", ",", "worstDiff", 
    ",", "\"\<   (expect ~ \>\"", ",", 
    RowBox[{"1.", "/", 
     RowBox[{"Sqrt", "[", "nSamples", "]"}]}], ",", "\"\<)\>\""}], "]"}], 
  ";"}]}], "Input",
