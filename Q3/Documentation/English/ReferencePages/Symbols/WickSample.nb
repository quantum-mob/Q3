Cell["Do the Monte Carlo simulation:", "ExampleText",
 CellID->2022511031,ExpressionUUID->"2b1101f3-bc56-46f5-b4a8-0cf9a7fe356d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"nSamples", "=", "200000"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"samples", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"First", "[", 
       RowBox[{"WickSample", "[", "Gtest", "]"}], "]"}], ",", "nSamples"}], 
     "]"}]}], "\[IndentingNewLine]", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"empiricalDist", "=", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"Counts", "[", "samples", "]"}], "/", "nSamples"}], "]"}]}], 
  ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->1971733301,ExpressionUUID->"74036a7c-a178-49cc-a984-1a1636e0f369"],

Cell[BoxData["5.385217`"], "EchoTiming",
 CellID->3461855,ExpressionUUID->"9f00d5c3-611d-4f17-903b-fedaf4b6044a"]
}, Open  ]],

