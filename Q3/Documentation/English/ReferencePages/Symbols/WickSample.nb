Cell[BoxData[{
 RowBox[{
  RowBox[{"worstDiff", "=", 
   RowBox[{"Max", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{
        RowBox[{"Lookup", "[", 
         RowBox[{"empiricalDist", ",", 
          RowBox[{"Key", "[", "#", "]"}], ",", "0."}], "]"}], "-", 
