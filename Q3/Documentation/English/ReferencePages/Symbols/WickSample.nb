Cell[TextData[{
 "Green\[CloseCurlyQuote]s function matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "a55e985c-306b-4879-9bdc-1cfa32a73ed1"],
 ", defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubsuperscriptBox["c", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"6f241dd6-2d00-4b39-a2cc-d27935d0ed11"],
 ", must be an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[Times]", "m"}], TraditionalForm]],ExpressionUUID->
  "e5c5ecd0-03ad-4e17-b846-e231f2cc51ff"],
 " Hermitian matrix satisfying ",
 Cell[BoxData[
  FormBox[
   RowBox[{
   "0", " ", "\[LessEqual]", " ", "G", " ", "\[LessEqual]", " ", "I"}], 
   TraditionalForm]],ExpressionUUID->"75651b06-44de-4838-a1f8-55a8906c8e80"],
 " (eigenvalues in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"0", ",", "1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "ef726745-9487-4796-a455-7570779f53d7"],
 "). The diagonal entry ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "i"}]], "=", 
    RowBox[{"1", "-", 
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox["n", "i"], "\[RightAngleBracket]"}]}]}], TraditionalForm]],
  ExpressionUUID->"74cb0ced-3d13-4366-b6ed-03a8b33807e0"],
 ", i.e. the probability that mode ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "3f744c13-7b9c-40c8-b67e-81fe47f605f5"],
 " is empty."
}], "Notes",
 CellID->1400058095,ExpressionUUID->"7bc06107-568b-4e13-a28b-85ef77a3d5f8"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["WickSample"]], "paclet:QuantumMob/Q3/ref/WickSample", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["G", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f00537fb-d7c1-4ddd-9cd9-e3e5ceb551d3"],
 " returns ",
 Cell[BoxData[
  RowBox[{
   StyleBox["outcome", "TI"], "\[Rule]", 
   StyleBox["probability", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4eda76de-c228-4150-9e52-71c437b74997"],
 ", where ",
 Cell[BoxData[
  StyleBox["outcome", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "712bd95c-de0d-42b0-bc07-777e33703af7"],
 " is a length-",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fde41dd8-48d0-40ef-a2a3-6803efbffcbd"],
 " list of bits (1 = occupied, 0 = empty) sampled from the exact joint \
distribution\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "s", ")"}], "=", 
    RowBox[{"det", "[", 
     RowBox[{
      RowBox[{
       SubscriptBox["s", "i"], "(", 
       RowBox[{
        SubscriptBox["\[Delta]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]], "-", 
        SubscriptBox["G", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], ")"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SubscriptBox["s", "i"]}], ")"}], 
       SubscriptBox["G", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"5e73acb0-67cb-4f58-a908-abc908f9d764"],
 ",\[LineSeparator]and ",
 Cell[BoxData[
  StyleBox["probability", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "eaf77e43-6f3b-4376-beb5-a756785bbb07"],
 " is the corresponding joint probability of that outcome."
}], "Notes",
 CellID->803053899,ExpressionUUID->"1dacf3ea-d808-481e-96c2-d04a637ffc99"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["WickSample"]], "paclet:QuantumMob/Q3/ref/WickSample", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["G", "TI"], ",", " ", 
    StyleBox["tol", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "958a5dd6-91b2-4cb9-a9c1-6930658eb6eb"],
 " uses tolerance ",
 Cell[BoxData[
  StyleBox["tol", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f02cd277-6d61-4c41-8fc7-b1dfa43bc103"],
 " (default ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]],ExpressionUUID->
  "dce32d7e-9396-4b6d-938f-4a935e247f4f"],
 ") to detect deterministic modes (",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", 
    RowBox[{"i", "\[VeryThinSpace]", "i"}]], TraditionalForm]],ExpressionUUID->
  "cc74ce2c-9135-47ee-bab2-e97779b1a7f0"],
 " numerically 0 or 1), for which the outcome is forced and the \
Schur-complement update is skipped."
}], "Notes",
 CellID->1347794300,ExpressionUUID->"2f825e6f-c0d5-462c-ab5c-f36964f55d23"],

Cell[TextData[{
 "The implementation is the chain-rule / Schur-complement sampler for \
free-fermion states and runs in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"O", "(", 
    SuperscriptBox["m", "3"], ")"}], TraditionalForm]],ExpressionUUID->
  "bc5d99d1-2b71-4a64-9534-804e74bca1bf"],
 " time."
}], "Notes",
 CellID->771478869,ExpressionUUID->"66df6406-23f7-447f-bc68-321c9e63fe42"]
