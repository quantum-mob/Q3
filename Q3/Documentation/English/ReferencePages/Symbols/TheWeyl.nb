Cell[TextData[{
 "Consider  a system of ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "065a7746-a26b-4f86-b0b8-90a4995179ca"],
 "-level quantum system (i.e., a ",
 ButtonBox["qudit",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Qudit"],
 "). The canonical basis of its Hilbert space is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], ",", 
     TemplateBox[{"1"},
      "Ket"], ",", 
     TemplateBox[{"2"},
      "Ket"], ",", "\[Ellipsis]", ",", 
     TemplateBox[{
       RowBox[{"d", "-", "1"}]},
      "Ket"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "c4ae4805-fe33-4254-be84-85e7b44700d9"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":", 
    RowBox[{
     TemplateBox[{"z"},
      "Ket"], "\[RightTeeArrow]", 
     RowBox[{
      TemplateBox[{"z"},
       "Ket"], 
      SuperscriptBox["\[Omega]", "z"]}]}]}], TraditionalForm]],ExpressionUUID->
  "e0bac371-5c60-4789-8702-977e3a405223"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", ":", 
    RowBox[{
     TemplateBox[{"z"},
      "Ket"], "\[RightTeeArrow]", 
     TemplateBox[{
       RowBox[{"z", "+", "1"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "a9a95c9f-b9b5-4d8f-a01c-fab9091d973b"],
 " be the ",
 StyleBox["generalized Pauli operators",
  FontSlant->"Italic"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"z", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"d", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "ef7ca1b6-790f-45b4-85fb-e121f11d5668"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{"2", "\[Pi]", " ", 
      RowBox[{"\[ImaginaryI]", "/", "d"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"bff880d1-1135-4464-94c4-19b0e5361131"],
 ". Then, the ",
 StyleBox["Weyl-Heisenberg basis",
  FontSlant->"Italic"],
 " is the generating set of the ",
 StyleBox["generalized Pauli group",
  FontSlant->"Italic"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalP]", "d"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Omega]", "c"], " ", 
       SuperscriptBox["X", "a"], 
       RowBox[{
        SuperscriptBox["Z", "b"], ":", "a"}]}], ",", "b", ",", 
      RowBox[{"c", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{"d", "-", "1"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "f8f06c86-2658-44cb-b746-0551e3be770d"],
 "."
}], "Notes",
 CellID->1882381721,ExpressionUUID->"35cdc126-8f1d-4072-8a57-bb7248cbe59c"],

Cell[TextData[{
 "Note that the generalized Pauli operators ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "fd8476ec-0afa-4e85-8e02-3047479a6e4a"],
 " and ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "1ef2d32c-1fa2-4722-b113-fff424a1daae"],
 " satisfy the Wey-Heisenberg commutation relation\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Z", " ", "X"}], "=", 
    RowBox[{"\[Omega]", " ", "X", " ", "Z"}]}], TraditionalForm]],
  ExpressionUUID->"13edfcd6-fcfa-4804-8962-db1763e2e7eb"],
 "."
}], "Notes",
 CellID->770267794,ExpressionUUID->"b559371d-496d-4b3a-aca0-4c457e6d5e94"],

Cell[TextData[{
 "The ",
 StyleBox["Weyl-Heisenberg group",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "of odd degree",
 " ",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "219f955c-8d85-49a3-975a-faabb13079ae"],
 " coincides with the generalized Pauli group, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalH]", "d"], ":=", 
    SubscriptBox["\[ScriptCapitalP]", "d"]}], TraditionalForm]],
  ExpressionUUID->"3f497f71-418a-467d-88a5-325a1a7359ce"],
 "."
}], "Notes",
 CellID->1802696894,ExpressionUUID->"f77eb855-cad4-41cb-93c5-2a8788c2b8d6"],

Cell[TextData[{
 "The ",
 StyleBox["Weyl-Heisenberg group ",
  FontSlant->"Italic"],
 "of even degree",
 StyleBox[" ",
  FontSlant->"Italic"],
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "110a711f-272d-4a8f-85f9-c0be22999b34"],
 " is achieved by doubling the generalized Pauli group, that is,\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalH]", "d"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Tau]", "c"], 
       SuperscriptBox["X", "a"], 
       RowBox[{
        SuperscriptBox["Z", "b"], ":", "a"}]}], ",", "b", ",", 
      RowBox[{"c", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{"d", "-", "1"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "24a68703-f5ab-44fd-938a-f38c50e389e1"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", ":=", 
    RowBox[{
     RowBox[{"-", 
      SqrtBox["\[Omega]"]}], "=", 
     RowBox[{"-", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Pi]", " ", 
        RowBox[{"\[ImaginaryI]", "/", "d"}]}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"0e79d745-7111-4c15-9996-de61b1c91a0e"],
 "."
}], "Notes",
 CellID->1542982260,ExpressionUUID->"6008361c-1abb-4752-bf15-ce70a12df6e5"],

Cell[TextData[{
 "The ",
 StyleBox["Clifford group",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalC]", "d"], TraditionalForm]],ExpressionUUID->
  "f5dbc0ab-91cf-487a-b948-f2eae21b9cff"],
 " is the normalizer of the Weyl-Heisenberg group in the unitary group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalU]", "(", "d", ")"}], TraditionalForm]],
  ExpressionUUID->"cb7a3561-2c46-4e4f-aab2-4150c584d3b5"],
 ". The doubling in the above definition of Weyl-Heisenberg group is required \
because additional phase factors emerge in the Clifford group."
}], "Notes",
 CellID->976052040,ExpressionUUID->"370f9885-fd55-489b-bf71-4956689a0f50"],

Cell[TextData[{
 "The Weyl-Heisenberg basis satisfies the following convention:\
\[LineSeparator]- It is ",
 StyleBox["orthonormal",
  FontSlant->"Italic"],
 " (normalized to ",
 StyleBox["d",
  FontSlant->"Italic"],
 ") with respect to the ",
 ButtonBox["Hilbert-Schmidt inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/HilbertSchmidtProduct"],
 " or ",
 ButtonBox["Frobenius inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FrobeniusProduct"],
 ".\[LineSeparator]- The first element is identical to the identity matrix. \
The rest are all ",
 StyleBox["traceless",
  FontSlant->"Italic"],
 ".\[LineSeparator]- All elements are ",
 StyleBox["unitary",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1752261046,ExpressionUUID->"2e2e46f9-c6c6-4142-95b4-ae28dd42d036"],

Cell["\<\
For more properties of the Weyl-Heisenberg basis, see Gottesman, Kitaev, and \
Preskill (2001), Wolf (2003), and Tolar (2018).\
\>", "Notes",
 CellID->1900252760,ExpressionUUID->"83e8c30e-4c87-48aa-bc8d-03785b068791"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

Cell[CellGroupData[{

