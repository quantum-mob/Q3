Cell[TextData[{
 "As one of the methods to enumerate different paths to a given partition \
down the Bratteli diagram, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungVector"]], "paclet:QuantumMob/Q3/ref/YoungVector", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "17fcd547-63dd-4b30-8e93-8a0e8f059365"],
 " one-to-one corresponds to ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungTableau"]], "paclet:QuantumMob/Q3/ref/YoungTableau", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2b3b96a4-5c42-493e-8ab0-d834c940582a"],
 " and to ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandPattern"]], "paclet:QuantumMob/Q3/ref/GelfandPattern", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f52f3d25-3380-4eda-a784-b6c4812fa757"],
 "."
}], "Notes",
 CellID->1254890122,ExpressionUUID->"316baac9-baf7-49d9-b6de-63a9ce5c13b5"],

Cell[TextData[{
 "A valid standard Young tableau always has ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["r", "TI"], 
    StyleBox["1", "TR"]], "=", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fda6da76-ede8-452d-92ab-b803df241384"],
 ", and ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["r", "TI"], 
   StyleBox["1", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "067bf330-aaaa-4d88-b2cb-4e41d412da1d"],
 " may be omitted as sometimes adopted for convention. Q3 keeps it for a bit \
more human-friendly encoding."
}], "Notes",
 CellID->127669919,ExpressionUUID->"999dc021-7c59-4326-abeb-c08bc7f7b721"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

