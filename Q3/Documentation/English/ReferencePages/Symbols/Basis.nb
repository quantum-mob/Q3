Cell[TextData[{
 "Notice the difference in the meanings of the integer arguments in the two \
forms, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Basis"]], "paclet:QuantumMob/Q3/ref/Basis", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3ac9eaca-814e-4348-a952-f84567532556"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Basis"]], "paclet:QuantumMob/Q3/ref/Basis", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["dim", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["dim", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "66bebbba-8a52-467c-b584-b2d2dd163d55"],
 ", for the unlabelled systems: ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a3fc8887-6507-4026-b0a5-22dd532b52b8"],
 " in ",
 Cell[BoxData[
  RowBox[{"Basis", "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c2b09be4-23dd-4dc3-8b3e-a634f2f2b5fb"],
 " is the number of qubits whereas ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["dim", "TI"], 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "74e633e7-9522-475e-bcfb-1c47ddd5fc3e"],
 " in ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Basis"]], "paclet:QuantumMob/Q3/ref/Basis", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["dim", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["dim", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2f039309-6e02-4c45-84dc-b56aa836ba46"],
 " is the dimension of the Hilbert space associated with the ",
 Cell[BoxData[
  StyleBox["j", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "646f359c-5239-40a9-b6c9-5686a26c8059"],
 "th system."
}], "Notes",
 CellID->1750022199,ExpressionUUID->"607bd507-3f8d-448a-8d48-41c6b94096bd"],

