    "tutorialcollectionlinks" -> {}, "index" -> True, "label" -> 
    "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> "QuantumMob/Q3",
     "status" -> "None", "summary" -> 
    "Basis[n] constructs the standard tensor-product basis of a system of n \
unlabelled qubits. Basis[{dim1, dim2, ..., dimn}] constructs the standard \
tensor-product basis of a total of n unlabelled systems with the Hilbert \
space dimensions dim1, dim2, ..., dimn, respectively. Basis[q1, q2, ...] \
constructs the tensor product basis for the system consisting of species q1, \
q2, .... Basis[q1, {q2, q3}, ...] is equivalent to Basis[q1, q2, q3, ...]. \
Basis[expr] finds the relevant species from the expression expr and \
constructs the basis.", "synonyms" -> {}, "tabletags" -> {}, "title" -> 
    "Basis", "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "Basis", "type" -> "Symbol", "uri" -> "QuantumMob/Q3/ref/Basis"}},
