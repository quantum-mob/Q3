Cell["\<\
The Deutsch gate is a universal quantum gate. It was invented by David \
Deutsch in 1989.\
\>", "Notes",
 CellID->1544137805,ExpressionUUID->"58bd86f2-32f2-4328-9483-34a28860c5b4"],

Cell[TextData[{
 "The Deutsch gate is a two-qubit-control unitary gate operating the \
rotation, ",
 Cell[BoxData[
  RowBox[{
   StyleBox[
    SubscriptBox[
     StyleBox[
      RowBox[{"\[ImaginaryI]", 
       StyleBox["R",
        FontSlant->"Italic"]}]], "x"],
    FontSlant->"Italic"], 
   RowBox[{"(", "\[Phi]", ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8599daf8-e7e4-42e6-9360-8b3002804d4c"],
 ", around the x-axis by angle \[Phi] conditioned on the states of the two \
control qubits."
}], "Notes",
 CellID->1154596347,ExpressionUUID->"92239c04-d3e4-46f0-a07f-b5e43c3ebdc5"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

