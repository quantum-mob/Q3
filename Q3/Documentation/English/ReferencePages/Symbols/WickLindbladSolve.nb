       3}, {4}, {5}, {4}, {5}, {6}, {5}, {6}}}, {0., -1.5, -2.5, 
      0., -1.5, -2.5, 0., -1.5, -2.5, 0., -1.5, -2.5, 0., -1.5, -2.5, 
      0.}}]]]]], "Output",
 CellLabel->"Out[4]//MatrixForm=",
 CellID->643144695,ExpressionUUID->"244da6b1-ffac-4f91-af23-ab0542234fa4"]
}, Open  ]],

