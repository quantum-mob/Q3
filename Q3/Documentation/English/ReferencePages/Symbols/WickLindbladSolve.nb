      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9238bd65-5a72-4e33-9e25-8a633e36839d"],
     " to ",
     Cell[BoxData[
      SubscriptBox[
       StyleBox["t", "TI"], 
       StyleBox["f", "TI"]]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4876cf3a-2e09-4066-b816-4e7f87c04585"],
     " at step ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e4bd6ed0-149d-49ee-a418-1951d8bbff5d"],
     "."
    }],ExpressionUUID->"d0c3db3b-d2f2-454f-843e-b842b0a46102"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
