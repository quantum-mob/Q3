   RowBox[{"WickDampingOperator", "[", "jmp", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eff", "=", 
   RowBox[{"ham", "-", 
    RowBox[{"I", "*", "dmp"}]}]}], ";"}], "\[IndentingNewLine]", 
