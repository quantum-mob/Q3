Cell[TextData[{
 "We take the dissipative model for the ",
 StyleBox["Hatano",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox["-Nelson Hamiltonian",
  FontSlant->"Italic"],
 "."
}], "ExampleText",
 CellID->1554113314,ExpressionUUID->"54a20194-1a63-4000-a68d-bbc290ddd91e"],

Cell["Construct the model:", "ExampleText",
 CellID->1228412337,ExpressionUUID->"49d0b51b-6260-4ec6-852d-a907731f0e87"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "HatanoNelsonModel", "]"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{
   RowBox[{"HatanoNelsonModel", "[", 
    RowBox[{"L_", ",", "J_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ham", ",", "cff", ",", "jmp"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ham", "=", 
       RowBox[{"PlusTopple", "[", 
        RowBox[{
         RowBox[{"-", "J"}], "*", 
         RowBox[{"One", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"L", ",", "L"}], "}"}], ",", "1"}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"ham", "=", 
       RowBox[{"WickHermitian", "[", "ham", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cff", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"One", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], "]"}], "+", 
          RowBox[{"I", "*", 
           RowBox[{"One", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], ",", "1"}], 
            "]"}]}]}], ")"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"jmp", "=", 
       RowBox[{"WickJump", "@", 
        RowBox[{"Join", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Thread", "[", 
           RowBox[{"cff", "->", "0"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Conjugate", "[", "cff", "]"}], "->", "1"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"ham", ",", "jmp"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1177694704,ExpressionUUID->"db157a46-f7dd-4c21-b6f7-bbadeb2414de"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$L", "=", "6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$\[Gamma]", "=", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$J", "=", 
   RowBox[{"1", "/", "$\[Gamma]"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->171829249,ExpressionUUID->"f1541f9c-5c72-4388-a9d2-10ce4ebbcafa"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ham", ",", "jmp"}], "}"}], "=", 
   RowBox[{"HatanoNelsonModel", "[", 
    RowBox[{"$L", ",", "$J"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->18365701,ExpressionUUID->"f8e869f9-ff7f-4e0c-8241-9068435ec027"],

Cell["\<\
Check that the effective non-Hermitian Hamiltonian is the Hatano-Helson \
Hamiltonian, exhibiting the non-Hermitian skin effect:\
\>", "ExampleText",
 CellID->1668994244,ExpressionUUID->"75bf9ad3-3de3-457e-8561-ac951252c2c4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"dmp", ",", "gmm"}], "}"}], "=", 
   RowBox[{"WickDampingOperator", "[", "jmp", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eff", "=", 
   RowBox[{"ham", "-", 
    RowBox[{"I", "*", "dmp"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"eff", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1116131714,ExpressionUUID->"929f0dda-73ff-4ac1-bf7a-8ea393335456"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0.`", 
      RowBox[{"-", "1.5`"}], "0.`", "0.`", "0.`", "0.`"},
     {
      RowBox[{"-", "2.5`"}], "0.`", 
      RowBox[{"-", "1.5`"}], "0.`", "0.`", "0.`"},
     {"0.`", 
      RowBox[{"-", "2.5`"}], "0.`", 
