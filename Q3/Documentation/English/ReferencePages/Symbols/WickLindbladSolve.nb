Cell[TextData[{
 "We take the dissipative model for the ",
 StyleBox["Hatano",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox["-Nelson Hamiltonian",
  FontSlant->"Italic"],
 "."
}], "ExampleText",
 CellID->1554113314,ExpressionUUID->"1f4ee849-3358-46cd-ba3a-875bdce5aedc"],

Cell["Construct the model:", "ExampleText",
 CellID->1228412337,ExpressionUUID->"cebdc3d6-f3b3-4acd-9083-20f1844da91b"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "HatanoNelsonModel", "]"}], "\[IndentingNewLine]", 
 RowBox[{" ", 
  RowBox[{
   RowBox[{"HatanoNelsonModel", "[", 
    RowBox[{"L_", ",", "J_"}], "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ham", ",", "cff", ",", "jmp"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ham", "=", 
       RowBox[{"PlusTopple", "[", 
        RowBox[{
         RowBox[{"-", "J"}], "*", 
         RowBox[{"One", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"L", ",", "L"}], "}"}], ",", "1"}], "]"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"ham", "=", 
       RowBox[{"WickHermitian", "[", "ham", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"cff", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"One", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], "]"}], "+", 
          RowBox[{"I", "*", 
           RowBox[{"One", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"L", "-", "1"}], ",", "L"}], "}"}], ",", "1"}], 
            "]"}]}]}], ")"}], "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"jmp", "=", 
       RowBox[{"WickJump", "@", 
        RowBox[{"Join", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Thread", "[", 
           RowBox[{"cff", "->", "0"}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Conjugate", "[", "cff", "]"}], "->", "1"}], "]"}]}], 
         "\[IndentingNewLine]", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"ham", ",", "jmp"}], "}"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1177694704,ExpressionUUID->"37ef6336-3920-4e10-83bc-7843896d51d4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$L", "=", "6"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$\[Gamma]", "=", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$J", "=", 
   RowBox[{"1", "/", "$\[Gamma]"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->171829249,ExpressionUUID->"2a3ca9a5-d35a-45f1-a223-20ac6df392f1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ham", ",", "jmp"}], "}"}], "=", 
   RowBox[{"HatanoNelsonModel", "[", 
    RowBox[{"$L", ",", "$J"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->18365701,ExpressionUUID->"823e10b6-596a-468d-8828-ea259c2d562e"],

Cell["\<\
Check that the effective non-Hermitian Hamiltonian is the Hatano-Helson \
Hamiltonian, exhibiting the non-Hermitian skin effect:\
\>", "ExampleText",
 CellID->1668994244,ExpressionUUID->"2733602b-ebe0-43ff-8e35-8176e94070ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"dmp", ",", "gmm"}], "}"}], "=", 
   RowBox[{"WickDampingOperator", "[", "jmp", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eff", "=", 
   RowBox[{"ham", "-", 
    RowBox[{"I", "*", "dmp"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"eff", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1116131714,ExpressionUUID->"d9083547-1800-4c28-958b-96eab3d2f304"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0.`", 
      RowBox[{"-", "1.5`"}], "0.`", "0.`", "0.`", "0.`"},
     {
      RowBox[{"-", "2.5`"}], "0.`", 
      RowBox[{"-", "1.5`"}], "0.`", "0.`", "0.`"},
     {"0.`", 
      RowBox[{"-", "2.5`"}], "0.`", 
