     {"0.`", "0.`", "0.`", 
      RowBox[{"-", "2.5`"}], "0.`", 
      RowBox[{"-", "1.5`"}]},
     {"0.`", "0.`", "0.`", "0.`", 
      RowBox[{"-", "2.5`"}], "0.`"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
