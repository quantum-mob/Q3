Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5c091c58-58b3-4d56-bf6f-73efe4b45b87"],
 " be a finite group. Suppose that for all elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "21dca1f9-2d43-4824-811c-4761b4e7dd65"],
 " and ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "a2ecc076-cae1-4a89-9991-8aaa65a1dfaa"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "8ad0f819-1bd8-4ded-a936-9caf3604a049"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"g", "\[VeryThinSpace]", "h"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "ba865328-5425-43b7-add2-1b546a69e83b"],
 "     and     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"h", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "dddcf3b1-1414-4e22-be16-d6c235ee6db3"],
 "  .\[LineSeparator]Then, the set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"f43c853b-51a3-4ce1-8d43-838f303e7b9a"],
 "  forms a basis of both ",
 StyleBox["left and right regular representations",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "f69cf235-3b56-45f0-929c-79dd3e6a91ab"],
 " and ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "3b670c19-a922-4441-aa4e-28a8f6d0f7d8"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "0ac677d7-fb03-411f-8510-8f52ce3dbd3e"],
 ". It is called the ",
 StyleBox["left and right regular basis",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "9660b72e-e201-4098-8dda-b623850446a6"],
 ", respectively. Note that in the matrix form, the left and right regular \
representations are respectively given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["L", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
     SubscriptBox["g", "k"], ")"}], "=", 
    TemplateBox[{
      SubscriptBox["g", "i"], 
      RowBox[{
        SubscriptBox["g", "k"], 
        SubscriptBox["g", "j"]}]},
     "BraKet"]}], TraditionalForm]],ExpressionUUID->
  "fefd3fd0-c457-45bf-b3f6-0bddefd5a213"],
 "     and     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["R", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
     SubscriptBox["g", "k"], ")"}], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["g", "i"], 
       RowBox[{
         SubscriptBox["g", "j"], 
         SubsuperscriptBox["g", "k", 
          RowBox[{"-", "1"}]]}]},
      "BraKet"], "=", 
     TemplateBox[{
       RowBox[{
         SubscriptBox["g", "i"], 
         SubscriptBox["g", "k"]}], 
       SubscriptBox["g", "j"]},
      "BraKet"]}]}], TraditionalForm]],ExpressionUUID->
  "8a0b5b24-85dd-45e5-a085-8928709b1671"],
 " ."
}], "Notes",
 CellID->519159934,ExpressionUUID->"6b82bb9a-a9d0-4a4f-b1f6-9be6084c37fd"],

Cell[TextData[{
 "When ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5effaa89-ecaa-439f-af51-7a8906273556"],
 " is the symmetric group, the basis is called the ",
 StyleBox["Young regular basis",
  FontSlant->"Italic"],
 "."
}], "Notes",
 CellID->1950903263,ExpressionUUID->"aca98cde-1ce9-408f-8cd2-d920db16ec58"],

Cell[TextData[{
 "The explicit relation between Young regular basis and Young-Fourier basis \
can be adjusted by setting ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FourierParameters"]], "paclet:ref/FourierParameters"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "299cb486-d62f-4bbb-b208-9a134a37255d"],
 "; see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["YoungFourier"]], "paclet:QuantumMob/Q3/ref/YoungFourier", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3f7e5019-0cb1-465d-91c6-089079eda64d"],
 " for details."
}], "Notes",
 CellID->1047282608,ExpressionUUID->"af20758f-c818-4b5a-afbd-8cab6f508e4d"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

