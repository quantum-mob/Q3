Cell[TextData[{
 "Consider Dirac fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "f13c1dee-504e-4df2-97dc-1dd45063b9e7"],
 " and corresponding Majorana modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     RowBox[{"2", "k"}], "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "34a6ecb7-aaf8-4966-aeba-c3be357345ce"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{"2", "k"}]], TraditionalForm]],ExpressionUUID->
  "e3635a0c-9dd7-42ad-a692-29f9730054be"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", "n"}], 
   TraditionalForm]],ExpressionUUID->"8fc37a5e-b900-48dc-82d0-b4798e42fc8b"],
 ". A quadratic Hermitian operator ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "0ca7838e-d6cc-4dc6-b2f2-4439efe7b042"],
 " may be written as\[LineSeparator]\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", "j"}], 
      RowBox[{"2", "n"}]], 
     SubsuperscriptBox[
      UnderscriptBox["a", "_"], "i", "\[Dagger]"], 
     SubscriptBox["H", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox[
      UnderscriptBox["a", "_"], "j"]}], "=", 
    RowBox[{
     FractionBox["\[ImaginaryI]", "4"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", "j"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["c", "i"], 
     SubscriptBox["A", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "5ad1df7e-aefd-4cd5-8194-f85f650f3695"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "45935f21-c734-4bae-bee9-c925599b0008"],
 " is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "da687479-9439-4c95-aa5d-8b8f557c13f1"],
 " complex Hermitian matrix and ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "c94851dc-a8c8-45b5-9041-a72090dc396a"],
 " is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "f92ec5b6-29c2-403f-a084-283c3f44f4a4"],
 " real anti-symmetric matrix. ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "bf8a7652-41ca-4159-9790-141264a7a14f"],
 " must be of the block form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", ":=", 
    RowBox[{"(", GridBox[{
       {"h", "\[Delta]"},
       {
        SuperscriptBox["\[Delta]", "\[Dagger]"], 
        RowBox[{"-", 
         SuperscriptBox["h", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e4d92694-9096-42b7-a04f-7d6302aade00"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "7d3da97b-f213-408d-9509-b4a129c4d08b"],
 " is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "e99915f1-5c26-4038-a6e4-325df4c8d730"],
 " Hermitian matrix and ",
 Cell[BoxData[
  FormBox["\[Delta]", TraditionalForm]],ExpressionUUID->
  "9b9f6d0d-2147-4140-85ca-39b437bd0f5c"],
 " is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "18897908-6e46-45d5-9c2a-03b9979d5a1c"],
 " complex anti-symmetric matrix."
}], "Notes",
 CellID->1812876774,ExpressionUUID->"551efd8a-e5ba-431f-ab2d-a3435484dc22"],

