Cell[TextData[{
 "The ",
 ButtonBox["uniformly controlled rotations",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/UniformlyControlledRotation"],
 " themselves may be decomposed further into products of more elementary \
gates as follows (notice the Unfold",
 ButtonBox["All",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ExpandAll"],
 " command):"
}], "ExampleText",
 CellID->1576401756,ExpressionUUID->"d0c2c06c-1bef-4301-87b0-ebfaf6c1423f"],

