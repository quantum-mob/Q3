Cell[TextData[{
 "The ",
 StyleBox["amplitude encoding",
  FontSlant->"Italic"],
 " is mapping, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["x", 
       SuperscriptBox["2", "n"]]}], "}"}], "\[RightTeeArrow]", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "1"}], 
      SuperscriptBox["2", "n"]], 
     TemplateBox[{
       RowBox[{"k", "-", "1"}]},
      "Ket"], 
     SubscriptBox["x", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "b8c51766-41a2-47be-aeed-638e733232dc"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"a"},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["a", "1"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["a", "2"]},
      "Ket"], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["a", "n"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "c6321d49-9d6f-4a54-abc6-401e4076e68f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", ":=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["a", "1"], 
       SubscriptBox["a", "2"], "\[Ellipsis]", "\[VeryThinSpace]", 
       SubscriptBox["a", "n"]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"11d61068-a7e4-43ae-885a-94b071a19126"],
 " is the binary-digit representation of integer ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "9034fc03-64d2-45cd-8acf-ad232b0470fa"],
 "."
}], "Notes",
 CellID->1961894503,ExpressionUUID->"b146f1df-2319-49b6-a28a-99605e33f1f6"],

Cell[TextData[{
 "The current implementation in Q3 is different from the defining map by a \
global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "\[Phi]"}]], 
   TraditionalForm]],ExpressionUUID->"d0d60467-cbf6-4726-96d3-432c611ddc69"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", ":=", 
    RowBox[{
     FractionBox["1`", "N"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "=", "1"}], "N"], 
     SubscriptBox["\[Phi]", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "a425dbd2-8859-495d-8a56-bcff788524dd"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Phi]", "i"], ":=", 
    RowBox[{"Arg", "[", 
     SubscriptBox["x", "i"], "]"}]}], TraditionalForm]],ExpressionUUID->
  "f4d7d022-c2a8-4495-a145-d6aea705459c"],
 "."
}], "Notes",
 CellID->1923399010,ExpressionUUID->"a936ae0d-685b-4a8a-83d1-d811bd39d275"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

