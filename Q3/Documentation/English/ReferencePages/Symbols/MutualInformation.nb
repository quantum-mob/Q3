Cell[TextData[{
 "In the classical case, the joint probability distribution of two random \
variables ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "8e3a9bbe-a319-4e02-b761-f755bfd114e5"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "e9b90293-0bda-4259-90d7-1fe18a813e8d"],
 " is specified in the matrix  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", 
     RowBox[{"i", " ", "j"}]], ":=", 
    RowBox[{"p", "(", 
     RowBox[{
      SubscriptBox["x", "i"], ",", 
      SubscriptBox["y", "j"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e66956fe-402b-4915-a970-fde6544a09b3"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", "2", ",", "\[Ellipsis]"}], 
   TraditionalForm]],ExpressionUUID->"ecbc3c48-ee27-436c-bcd6-0ef0dedb984b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]"}], 
   TraditionalForm]],ExpressionUUID->"5ed527c8-293d-4fd7-ba05-ccba662c134f"],
 "."
}], "Notes",
 CellID->98248964,ExpressionUUID->"ab4501cd-d9cb-4660-b8a6-069eedb0acf8"],

Cell["\<\
The classical mutual information quantifies the correlation between two \
random variables.\
\>", "Notes",
 CellID->2054234533,ExpressionUUID->"d6f60f09-cdee-47ff-8832-60d6f3136a57"],

Cell[TextData[{
 "For a composite quantum system of two subsystems ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "d8932ea7-a590-4377-8003-260c754d7d0f"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "864e7fd8-4629-48b3-98e1-8cd73e4a1db5"],
 ", the ",
 StyleBox["quantum mutual information",
  FontSlant->"Italic"],
 " between ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "7ae48eeb-40fc-46a6-960e-9b098bf8bdeb"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "a1f7d1ed-8f52-4ac6-8efe-63651185b6bd"],
 " is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"A", ":", "B"}], ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "(", "A", ")"}], "+", 
      RowBox[{"S", "(", "B", ")"}], "-", 
      RowBox[{"S", "(", 
       RowBox[{"A", ",", "B"}], ")"}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"S", "(", "A", ")"}], "-", 
       RowBox[{"S", "(", 
        RowBox[{"A", "|", "B"}], ")"}]}], "=", 
      RowBox[{
       RowBox[{"S", "(", "B", ")"}], "-", 
       RowBox[{"S", "(", 
        RowBox[{"B", "|", "A"}], ")"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"899527ae-0b2c-4f14-a91e-4340deb8dc62"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"A", ",", "B"}], ")"}], ":=", 
    RowBox[{"S", "(", 
     SubscriptBox["\[Rho]", 
      RowBox[{"A", "\[VeryThinSpace]", "B"}]], ")"}]}], TraditionalForm]],
  ExpressionUUID->"1a5cef51-e8c4-4bdf-aaac-bc1080debd0b"],
 " is the quantum entropy of the whole  system associated with the density \
matrix ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "b5e3b5bf-0fda-4c50-b434-cd317b8edd0b"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "A", ")"}], ":=", 
    RowBox[{"S", "(", 
     SubscriptBox["\[Rho]", "A"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d76dc0dd-bbd7-450c-80c6-3c73af79bf70"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "B", ")"}], ":=", 
    RowBox[{"S", "(", 
     SubscriptBox["\[Rho]", "B"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e9223cc0-8588-4455-9284-7192b1908c35"],
 " are associated with the reduced density operators\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", "A"], ":=", 
    RowBox[{
     UnderscriptBox["Tr", "B"], 
     SubscriptBox["\[Rho]", 
      RowBox[{"A", "\[VeryThinSpace]", "B"}]]}]}], TraditionalForm]],
  ExpressionUUID->"a1df25bf-1245-4e4e-8739-c76e5e2a55d1"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", "B"], ":=", 
    RowBox[{
     UnderscriptBox["Tr", "A"], 
     SubscriptBox["\[Rho]", 
      RowBox[{"A", "\[VeryThinSpace]", "B"}]]}]}], TraditionalForm]],
  ExpressionUUID->"9b00c661-ff90-406d-b2c8-0f10facb9dc1"],
 " ,\nrespectively,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"A", "|", "B"}], ")"}], ":=", 
    RowBox[{
     RowBox[{"S", "(", 
      RowBox[{"A", ",", "B"}], ")"}], "-", 
     RowBox[{"S", "(", "B", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c26f5f33-1aa8-4299-8dbe-d4028d114821"],
 " is the the ",
 StyleBox["quantum conditional entropy",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "6768c8fc-e30a-4130-b694-22bebf75ceee"],
 " on ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "faa2bc9c-b820-4e26-aad7-fb1b27f555b7"],
 ", and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"B", "|", "A"}], ")"}], ":=", 
    RowBox[{
     RowBox[{"S", "(", 
      RowBox[{"A", ",", "B"}], ")"}], "-", 
     RowBox[{"S", "(", "A", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "37283152-7b15-408c-bfe7-6be055978c8d"],
 " is the conditional quantum entropy of ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "f6bee4bf-1cb2-4080-a595-e81692218834"],
 " on ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "69a49837-a9c9-496f-9d74-be233dea1bb4"],
 "."
}], "Notes",
 CellID->1166931226,ExpressionUUID->"cb829f1c-a18d-47f6-ba64-4e0235e35174"],

Cell["\<\
The quantum mutual information captures both the classical and quantum \
correlations between two subsystems. For this reason, it is frequently used \
to quantitatively investigate quantum entanglement. However, in general, it \
is not a rigorous measure of quantum entanglement because it may be finite \
even for separable (yet classical correlated) states.\
\>", "Notes",
 CellID->1915222616,ExpressionUUID->"ca01544d-37d6-41d9-97b1-99d42006896e"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

