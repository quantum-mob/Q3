}, Open  ]],

Cell["Rewrite the ZZ interaction in an operator expression:", "ExampleText",
 CellID->912761031,ExpressionUUID->"4db874c7-f965-4387-8cee-351ae95407b1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Elaborate", "[", "op", "]"}], "//", "ExpToTrig"}], "//", 
  "Simplify"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->2025318320,ExpressionUUID->"88838d2c-8fb4-4920-a1b6-99f7df935145"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Cos", "[", "\[Phi]", "]"}], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        InterpretationBox[
         TemplateBox[{"S", 
           TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"Z\""}, "RowWithSeparators"]}, 
          "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
         $CellContext`S[1, 3]], 
        InterpretationBox[
         TemplateBox[{"S", 
           TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"Z\""}, "RowWithSeparators"]}, 
          "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
         $CellContext`S[2, 3]]}, "RowWithSeparators"]},
     "RowDefault"],
    QuantumMob`Q3`Multiply[
     $CellContext`S[1, 3], 
     $CellContext`S[2, 3]]], " ", 
   RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}]], "Output",
 CellLabel->"Out[5]=",
 CellID->429072124,ExpressionUUID->"9bfb16af-4736-48cf-8df3-f3442947f3ed"]
}, Open  ]],

Cell["Calculate the matrix representation of the ZZ interaction:", \
"ExampleText",
 CellID->776732127,ExpressionUUID->"61789894-280c-41de-9565-25fa4159a4ba"],

