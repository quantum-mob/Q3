Cell[TextData[{
 "Consider a unitary gate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "H"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"daf58377-39fc-42b6-b381-103f87ca1a69"],
 " for an exchange coupling Hamiltonian ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "18a149fd-61ba-4592-a6f9-000b55d833f9"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Exchange"]], "paclet:QuantumMob/Q3/ref/Exchange", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "79c48ad4-fa48-484b-8ff9-ac88e95c9264"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ExchangeExp"]], "paclet:QuantumMob/Q3/ref/ExchangeExp", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "20533750-0bc8-43bc-a148-4cd8afc87ea8"],
 " describe ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "288f86d5-e4a1-426f-b679-49293953f474"],
 " and ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "34198429-d4f7-4837-80b0-3cc3bd05073b"],
 ", respectively."
}], "Notes",
 CellID->1432115322,ExpressionUUID->"0f77d7cf-69c0-4b8f-9b6c-6b419842e76b"],

Cell[TextData[{
 "For the connectivity of the coupling, see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Chain"]], "paclet:QuantumMob/Q3/ref/Chain", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "894510cb-358a-44b7-ad5d-dbcf31d94a44"],
 " or ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ChainBy"]], "paclet:QuantumMob/Q3/ref/ChainBy", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "368bf3c3-2550-4da4-9ead-acb0a5b7ddc3"],
 "."
}], "Notes",
 CellID->669978790,ExpressionUUID->"316c139b-afe8-45c6-8db2-d0556184a9f2"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "32205321-e2ce-4452-b4e3-2f078522f5b1"],
 " is a vector ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["x", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["y", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["z", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1bf30a4e-6d6b-42f8-a47c-de96c4b3056d"],
 ", then the coupling between two qubits or spins ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "i"], TraditionalForm]],ExpressionUUID->
  "a6a146f2-c9b9-44f5-a05e-9670da56a3a0"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "j"], TraditionalForm]],ExpressionUUID->
  "adcc965b-bbb1-4bcb-9762-4f3f23a778c3"],
 " connected by a link gives the Hamiltonian term:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["g", "x"], 
      SubsuperscriptBox["S", "i", "X"], 
      SubsuperscriptBox["S", "j", "X"]}], "+", 
     RowBox[{
      SubscriptBox["g", "y"], 
      SubsuperscriptBox["S", "i", "Y"], 
      SubsuperscriptBox["S", "j", "Y"]}], "+", 
     RowBox[{
      SubscriptBox["g", "z"], 
      SubsuperscriptBox["S", "i", "Z"], 
      SubsuperscriptBox["S", "j", "Z"]}]}]}], TraditionalForm]],
  ExpressionUUID->"d717a8d2-5155-4df7-8813-8f2acb3e5d15"],
 " ."
}], "Notes",
 CellID->115471954,ExpressionUUID->"e039861f-2843-462f-8be1-3bf99d447cff"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6d952140-f431-41e5-b0a1-c16b44197251"],
 " is a 3\[Times]3 matrix ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "ebe22358-fc19-4604-a56b-1def4b2dfaa8"],
 ", then the coupling gives the term\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubscriptBox["g", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubsuperscriptBox["S", "i", "\[Mu]"], 
     SubsuperscriptBox["S", "j", "\[Nu]"]}]}], TraditionalForm]],
  ExpressionUUID->"35fc0fa7-4161-40c8-b7bc-6ce844a168c0"],
 " ."
}], "Notes",
 CellID->906834529,ExpressionUUID->"9be5dcdf-4468-48ae-8179-461f19a37fc2"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

