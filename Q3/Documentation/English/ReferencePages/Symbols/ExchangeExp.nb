Cell["\<\
Let us consider pair-wise ZZ interaction of neighboring qubits:\
\>", "ExampleText",
 CellID->204252008,ExpressionUUID->"10f0fb8f-55e7-4324-b745-95df5ef463e9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MapIndexed", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ExchangeExp", "[", 
        RowBox[{
         RowBox[{"a", "@", 
          RowBox[{"First", "@", "#2"}]}], ",", "#1"}], "]"}], "&"}], ",", 
      RowBox[{"Partition", "[", 
       RowBox[{"SS", ",", "2"}], "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"MapIndexed", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"ExchangeExp", "[", 
        RowBox[{
         RowBox[{"a", "@", 
          RowBox[{"First", "@", "#2"}]}], ",", "#1"}], "]"}], "&"}], ",", 
      RowBox[{"Partition", "[", 
       RowBox[{
        RowBox[{"Rest", "@", "SS"}], ",", "2"}], "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->2124868822,ExpressionUUID->"8e56d962-3816-46c2-8869-7c3569e0fb9d"],

