Cell[TextData[{
 "Consider a unitary gate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "H"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"13df79b1-85d0-45b2-882a-560ba28c2e5d"],
 " for an exchange coupling Hamiltonian ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "f798e757-fb2c-4633-a60f-f3994b3b4b2e"],
 ". ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Exchange"]], "paclet:QuantumMob/Q3/ref/Exchange", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a2542ff7-6bf6-4217-9573-6f31a0e6cae9"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ExchangeExp"]], "paclet:QuantumMob/Q3/ref/ExchangeExp", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "91e1497b-ff66-4447-b34c-0bb6888ca491"],
 " describe ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "1f9c9b5d-ffcf-4041-9ea2-aad04d9a1256"],
 " and ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "c91dc1cd-8ed9-467b-824c-39227e2fedb2"],
 ", respectively."
}], "Notes",
 CellID->1432115322,ExpressionUUID->"95cd74e3-f76f-4fd3-901e-1ed0d6316da3"],

Cell[TextData[{
 "For the connectivity of the coupling, see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Chain"]], "paclet:QuantumMob/Q3/ref/Chain", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "93dc2be1-17f7-4690-96c1-eb8c016a693c"],
 " or ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ChainBy"]], "paclet:QuantumMob/Q3/ref/ChainBy", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54bcbb63-0e22-4053-af53-32a4e67e32dc"],
 "."
}], "Notes",
 CellID->669978790,ExpressionUUID->"5e70c9ed-63e2-4d08-add7-d4874ab69074"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0b13bcb7-870f-4a41-adfa-005fcf20d644"],
 " is a vector ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["x", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["y", "TI"]], ",", 
    SubscriptBox[
     StyleBox["g", "TI"], 
     StyleBox["z", "TI"]]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "af4625b0-f620-420a-8c4f-cb42d3ac7951"],
 ", then the coupling between two qubits or spins ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "i"], TraditionalForm]],ExpressionUUID->
  "f6d56f59-e513-41cb-80ce-bce9b980a298"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "j"], TraditionalForm]],ExpressionUUID->
  "2160b2c7-ae0c-43e7-bbaa-5b87c6fc2db2"],
 " connected by a link gives the Hamiltonian term:\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["g", "x"], 
      SubsuperscriptBox["S", "i", "X"], 
      SubsuperscriptBox["S", "j", "X"]}], "+", 
     RowBox[{
      SubscriptBox["g", "y"], 
      SubsuperscriptBox["S", "i", "Y"], 
      SubsuperscriptBox["S", "j", "Y"]}], "+", 
     RowBox[{
      SubscriptBox["g", "z"], 
      SubsuperscriptBox["S", "i", "Z"], 
      SubsuperscriptBox["S", "j", "Z"]}]}]}], TraditionalForm]],
  ExpressionUUID->"1c5207ef-592c-4832-9c66-956be88eea4d"],
 " ."
}], "Notes",
 CellID->115471954,ExpressionUUID->"6ef20eb1-ceaa-47b9-9584-413602f2cefa"],

Cell[TextData[{
 "If the ",
 Cell[BoxData[
  StyleBox["array", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6a2c06ab-c08f-44c6-b75e-2a17ad3be9d8"],
 " is a 3\[Times]3 matrix ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "b6824b7c-3cd0-461f-8dac-bdb41003dabe"],
 ", then the coupling gives the term\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubscriptBox["g", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubsuperscriptBox["S", "i", "\[Mu]"], 
     SubsuperscriptBox["S", "j", "\[Nu]"]}]}], TraditionalForm]],
  ExpressionUUID->"10a249b5-9cbd-4c0f-80ae-cf36690334e5"],
 " ."
}], "Notes",
 CellID->906834529,ExpressionUUID->"1659f214-ab88-4e69-b959-5afb6b8d54fb"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  DynamicBox[ToBoxes[
