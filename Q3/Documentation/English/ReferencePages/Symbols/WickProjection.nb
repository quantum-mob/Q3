Cell["Construct the dressed modes to measure:", "ExampleText",
 CellID->2132876610,ExpressionUUID->"3d522fc5-e8c8-46a6-b5fa-3166a62670de"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"dd", "=", 
   RowBox[{"trs", ".", "cc"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"qq", "=", 
   RowBox[{
    RowBox[{"Dagger", "[", "dd", "]"}], "**", "dd"}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[11]:=",
 CellID->540735181,ExpressionUUID->"072cc57d-e819-42ed-befe-dddfc90f3124"],

Cell["\<\
Construct the projector corresponding to the measurement outcome:\
\>", "ExampleText",
 CellID->1557926104,ExpressionUUID->"94cf2276-1177-48df-b862-94cc9c4db203"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"val", "*", "qq"}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "val"}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{"1", "-", "qq"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"Apply", "[", 
     RowBox[{"Multiply", ",", "prj"}], "]"}], "//", "Chop"}]}], 
  ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[12]:=",
 CellID->1701731404,ExpressionUUID->"fa5fe4ae-6523-464f-b66e-436e55c53818"],

