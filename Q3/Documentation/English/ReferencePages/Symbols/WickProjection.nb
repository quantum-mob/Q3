Cell[TextData[{
 "However, note that the latter form internally uses the QR decomposition and \
the cost scales as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"m", " ", "M", " ", "N"}], ")"}], TraditionalForm]],
  ExpressionUUID->"6e3346f0-90a4-44e4-870b-0dcf22fe7b99"],
 ", where ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "32e65429-8e62-4523-9a86-27914f512115"],
 " is the number of measured dressed modes, ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "879e99d0-e413-4664-bd9c-51ac5c985fd1"],
 " is the total number of bare modes and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "3ad95923-bde3-43c0-97fa-af843173ab58"],
 " is the number of particles in the input state."
}], "ExampleText",
 CellID->550323129,ExpressionUUID->"65706a28-1565-4c4e-8b77-9f4f03c4d3c3"]
}, Open  ]]
}, Open  ]],

