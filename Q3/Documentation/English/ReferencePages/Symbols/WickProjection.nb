Cell[TextData[{
 "Note that the dressed-mode form internally uses the QR decomposition and \
the cost scales as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"m", " ", "M", " ", "N"}], ")"}], TraditionalForm]],
  ExpressionUUID->"6e6f9a48-4340-490e-8d2d-6634402b7c3e"],
 ", where ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "ee6e710b-be01-4c4b-b339-bb6f785f1aba"],
 " is the number of measured dressed modes, ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "dc4c1a27-ede1-40bf-99fc-3ff8fa65596d"],
 " is the total number of bare modes and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "6b0f9419-961d-46a4-bc3e-11dddf6c8847"],
 " is the number of particles in the input state."
}], "Notes",
 CellID->1810872678,ExpressionUUID->"2b9f2456-1809-4e29-85fd-bd8b58fa263d"]
}, Closed]],

