        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       StyleBox["mat", "TI"], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3b5fa8b3-eb7a-4a4d-874e-cc0ef9eac0c6"],
     "\[LineSeparator]tridiagonalizes the skew-symmetric matrix ",
     Cell[BoxData[
      StyleBox["mat", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4b15ae0e-0205-4a28-93b9-06fc7c4b2af1"],
     " and returns ",
     Cell[BoxData[
      RowBox[{"{", 
       RowBox[{
        StyleBox["tri", "TI"], ",", " ", 
        StyleBox["map", "TI"], ",", " ", 
        StyleBox["prm", "TI"]}], "}"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c0b678cc-0653-4637-9d3a-d831911287e0"],
     " such that ",
     Cell[BoxData[
      RowBox[{
       RowBox[{
        StyleBox["prm", "TI"], ".", 
        StyleBox["mat", "TI"], ".", 
        SuperscriptBox[
         StyleBox["prm", "TI"], "T"]}], " ", "=", " ", 
       RowBox[{
        StyleBox["map", "TI"], ".", 
        StyleBox["tri", "TI"], ".", 
        SuperscriptBox[
         StyleBox["map", "TI"], "T"]}]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9c463c98-6ef0-480b-8f27-145ffab156c1"],
     ", where ",
     Cell[BoxData[
      StyleBox["tri", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c3ebe148-db35-4834-a2b9-8f9660d52a42"],
     " is a skew-symmetric tridiagonal matrix."
    }],ExpressionUUID->"dce5ac68-1ed5-4a8d-929a-8b91c62a34cd"]}
