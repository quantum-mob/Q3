Cell[TextData[{
 "The Pfaffian of the skew-symmetric matrix can be calculated from the \
decomposition. Internally, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Pfaffian"]], "paclet:QuantumMob/Q3/ref/Pfaffian", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "43935d81-8c56-42d8-8546-f67ebf9a033b"],
 " does not use the decomposition explicitly, though."
}], "ExampleText",
