Cell[TextData[{
 "For the ",
 StyleBox["Parlett",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox["-Reid method",
  FontSlant->"Italic"],
 ", ",
 Cell[BoxData[
  StyleBox["map", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4d9c0db5-c871-4bbf-a3d6-5d63f91de8b3"],
 " is a unit lower triangular matrix and ",
 Cell[BoxData[
  StyleBox["prm", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "320cd28b-c6ff-4b7a-9172-d0474aa4c675"],
 " is a permutation matrix."
}], "Notes",
 CellID->643587427,ExpressionUUID->"f1aec648-d527-413f-be3a-fc61df38eaee"],

Cell[TextData[{
 "For the ",
 StyleBox["Householder and Hessenberg methods",
  FontSlant->"Italic"],
 ", ",
 Cell[BoxData[
  StyleBox["map", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "676c1d28-11e4-4e1a-b2b4-54986f92b714"],
 " is a unitary matrix, and ",
 Cell[BoxData[
  StyleBox["prm", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "87459f23-9188-450f-94ec-26a5d72f4596"],
 " is the identity matrix (to be ignored)."
}], "Notes",
 CellID->772113112,ExpressionUUID->"f92d2d66-c7a4-47d1-a684-632aec7d2f34"],

Cell[TextData[{
 "A ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Method"]], "paclet:ref/Method"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "19c8bce3-98c9-4754-b2d4-75dbb956dc86"],
 " option can be given. Default setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Method"]], "paclet:ref/Method"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   TemplateBox[{
     Cell[
      TextData["Automatic"]], "paclet:ref/Automatic"},
    "RefLink",
    BaseStyle->{"InlineFormula"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "53bba370-fcaf-46d4-a96f-b3f6192f51d1"],
 "  uses the ",
 StyleBox["Hessenberg decomposition",
  FontSlant->"Italic"],
 " (\"Hessenberg\") for real matrices (note that it converts any exact number \
to a finite-precision number, and hence the returned value is always an \
inexact number) and the ",
 StyleBox["Householder tridiagonalization",
  FontSlant->"Italic"],
 " for complex matrices. Other settings include: "
}], "Notes",
 CellID->1347491459,ExpressionUUID->"75b324bc-88fc-4b41-b68b-1919c91d2e43"],

Cell[BoxData[GridBox[{
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "65756463-7a8f-43ab-8746-c8d22377f61f"], Cell[
    "\"Parlett-Reid\"", "TableText",ExpressionUUID->
     "9fcdd2ac-3872-4206-baf9-bf23f7338970"], Cell[
    "Uses the Parlett-Reid tridiagonalization.", "TableText",ExpressionUUID->
     "dc83da0c-b7c8-4222-9c2b-07e00d13c16b"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "b9473d92-a711-4626-ba4f-f15793cc87eb"], Cell[
    "\"Householder\"", "TableText",ExpressionUUID->
     "3225a8c9-2fd4-4a2b-a2ed-d189443716a0"], Cell["\<\
Uses the Householder tridiagonalization, and is the default choice for \
complex matrices.\
\>", "TableText",ExpressionUUID->"dd10baa1-71b4-4ed1-9c94-c111b0b42792"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "86ede6bd-e5de-45a2-83e5-53bcd5af0e15"], Cell[
    "\"Hessenberg\"", "TableText",ExpressionUUID->
     "5465eba2-9971-4796-900a-6e690cbb93c8"], Cell[TextData[{
     "Uses the Hessenberg decomposition, is usually the fastest for ",
     StyleBox["real",
      FontSlant->"Italic"],
     " matrices, and hence is the default choice for ",
     StyleBox["real",
      FontSlant->"Italic"],
     " matrices. However, it works only for finite-preision matrices. For \
infinite-precision real matrices, use \"Householder\"."
    }], "TableText",ExpressionUUID->"c44af47b-4562-4416-a21a-943f32735d25"]},
   {Cell["      ", "TableRowIcon",ExpressionUUID->
     "8df28811-86f5-4d25-84ec-a8b2ced2feb4"], Cell[
    "\"Heuristic\"", "TableText",ExpressionUUID->
     "e40d8cf2-b548-4089-8e38-96430d07a730"], Cell["\<\
Uses the heuristic recursive method. This method is very slow for large \
matrices.\
\>", "TableText",ExpressionUUID->"7f6f0638-75b9-475b-9f8e-62f848651872"]}
  }]], "2ColumnTableMod",
 GridBoxOptions->{
 GridBoxBackground->{
  "Columns" -> {{None}}, "Rows" -> {None, None, None, {None}}},
 GridBoxDividers->{"Rows" -> {{True, True, True, True, True}}}},
 CellID->487478069,ExpressionUUID->"18d799a0-5365-433a-8b0d-b65c993c2844"],

Cell[TextData[{
 "For ",
 StyleBox["real",
  FontSlant->"Italic"],
 " matrices, the tridiagonalization can be computed using the Hessenberg \
decomposition. Since the Hessenberg decomposition is implemented efficiently \
in Mathematica, this approach is usually fastest for ",
 StyleBox["real",
  FontSlant->"Italic"],
 " matrices."
}], "Notes",
 CellID->188511912,ExpressionUUID->"3b10a248-8fba-4039-b215-137900a21619"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

