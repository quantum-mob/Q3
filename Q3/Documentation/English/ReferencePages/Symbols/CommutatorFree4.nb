Cell["As an example, we consider the Rabi oscillation.", "ExampleText",
 CellID->54922489,ExpressionUUID->"d54b3d6a-54ae-47e9-a31c-9d686d6a03f0"],

Cell[TextData[{
 "Set the time-dependent Hamiltonian \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{
      FractionBox["\[CapitalDelta]", "2"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"cos", "(", 
          RowBox[{"\[Omega]", "\[VeryThinSpace]", "t"}], ")"}], 
         SuperscriptBox["\[Sigma]", "x"]}], "+", 
        RowBox[{
         RowBox[{"sin", "(", 
          RowBox[{"\[Omega]", "\[VeryThinSpace]", "t"}], ")"}], 
         SuperscriptBox["\[Sigma]", "y"]}]}], ")"}]}], "+", 
     RowBox[{
      FractionBox["B", "2"], 
      SuperscriptBox["\[Sigma]", "z"]}]}]}], TraditionalForm]],ExpressionUUID->
  "e2dfcdb2-0b6f-41d1-9f39-251b19346f48"],
 " \[LineSeparator]with field rotating at angular frequence \[Omega]:"
}], "ExampleText",
 CellID->1209418989,ExpressionUUID->"8848af5e-a23e-4c48-901b-61370c10b0cd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Omega]", "=", 
   RowBox[{"2", "Pi"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalDelta]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"B", "[", "1", "]"}], "=", 
   RowBox[{"\[CapitalDelta]", "*", 
    RowBox[{"Cos", "[", 
     RowBox[{"\[Omega]", "*", "t"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"B", "[", "2", "]"}], "=", 
   RowBox[{"\[CapitalDelta]", "*", 
    RowBox[{"Sin", "[", 
     RowBox[{"\[Omega]", "*", "t"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"B", "[", "3", "]"}], "=", 
   RowBox[{"1.1", "\[Omega]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"HH", "[", "t_", "]"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"B", "[", "1", "]"}], "/", "2"}], "*", 
      RowBox[{"ThePauli", "[", "1", "]"}]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{"B", "[", "2", "]"}], "/", "2"}], "*", 
      RowBox[{"ThePauli", "[", "2", "]"}]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{"B", "[", "3", "]"}], "/", "2"}], "*", 
      RowBox[{"ThePauli", "[", "3", "]"}]}]}], "//", "Normal"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"HH", "[", "t", "]"}], "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->155947334,ExpressionUUID->"341e8187-12c1-4246-bd6b-2315587aeea1"],

