Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["CommutatorFree4"]], 
     "paclet:QuantumMob/Q3/ref/CommutatorFree4", "QuantumMob Package Symbol"},
    
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["mat", "TI"], ",", 
    StyleBox["spec", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e58195e2-39dc-4b0b-801b-1d39b1ac1514"],
 " operates on either a vector or matrix, and returns a list of vectors or \
matrices corresponding to the time steps."
}], "Notes",
 CellID->1053203487,ExpressionUUID->"55c4f7e9-1a32-4419-ac69-95fb40a7cbf1"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  RowBox[{"\"\<List\>\"", "\[Rule]", 
   TemplateBox[{
     Cell[
      TextData["False"]], "paclet:ref/False"},
    "RefLink",
    BaseStyle->{"InlineFormula"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "68c73b57-6cc2-4a91-b9d9-24d95b521223"],
 ", CommutatorFree4[mat,spec][in] returns only the final vector or matrix, \
dropping the resuls at the intermediate time steps."
}], "Notes",
 CellID->613345033,ExpressionUUID->"f32ea281-5559-4537-9472-126ea51aaac0"],

Cell[TextData[{
 "It uses the fourth-order commutator-free (CF4) exponential integrator of ",
 ButtonBox["Blanes and Moan (2006)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1016/j.apnum.2005.11.004"], None}],
 ", in the form adopted as the standard scheme for time-dependent quantum \
propagation by ",
 ButtonBox["Alvermann and Fehske (2011)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1016/j.jcp.2011.04.006"], None}],
 ". The name is literal: it is a fourth-order accurate truncation of the \
Magnus expansion (Blanes et al., 2009) that uses no commutators, only \
ordinary matrix exponentials."
}], "Notes",
 CellID->1044649057,ExpressionUUID->"6e279fa2-3ce9-4870-b0ed-c6af2cc7ac31"],

Cell["Natural units are assumed with \[HBar]=1.", "Notes",
 CellID->582289924,ExpressionUUID->"f38bb2ca-3807-4982-a635-6f8d25e3a25b"],

Cell[TextData[{
 "The global error is of order ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"d", "\[VeryThinSpace]", 
     SuperscriptBox["t", "4"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "bcb37a88-2807-45b5-bcbd-da7c60356896"],
 " for the step size ",
 Cell[BoxData[
  StyleBox["dt", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f5fd808c-708b-4ab6-83aa-2e0b0f0d3e92"],
 "."
}], "Notes",
 CellID->590619038,ExpressionUUID->"82ff76fd-3416-424f-9b17-b3c7de185e2d"]
}, Closed]],

