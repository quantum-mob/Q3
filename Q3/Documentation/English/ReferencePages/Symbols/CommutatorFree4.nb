Cell[TextData[{
 "From the time-independent Hamiltonian in the rotating frame, get the full \
time-evolution operator, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["R", "z"], "(", 
      RowBox[{"\[Omega]", "\[VeryThinSpace]", "t"}], ")"}], 
     RowBox[{
      SubscriptBox["U", "R"], "(", "t", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"ff14b1c4-27c2-4b07-85e6-0fae3d1c9ed7"],
 ":"
}], "ExampleText",
 CellID->898210223,ExpressionUUID->"8a7f9748-9ba5-4121-af20-be5b225cc2db"],

