  RowBox[{
   RowBox[{"TheRotation", "[", 
    RowBox[{
     RowBox[{"\[Omega]", "*", "t"}], ",", "3"}], "]"}], ".", 
   RowBox[{"MatrixExp", "[", 
    RowBox[{
     RowBox[{"-", "I"}], "*", "t", "*", "HR"}], "]"}]}]}], "\[IndentingNewLine]", 
