Cell[TextData[{
 "To get the exact solution, get the Hamiltonian\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", "R"], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        SubsuperscriptBox["R", "z", "\[Dagger]"], "(", 
        RowBox[{"\[Omega]", " ", "t"}], ")"}], " ", 
       RowBox[{"H", "(", "t", ")"}], " ", 
       RowBox[{
        SubscriptBox["R", "z"], "(", 
        RowBox[{"\[Omega]", "\[VeryThinSpace]", "t"}], ")"}]}], "-", 
      RowBox[{
       RowBox[{
        SubsuperscriptBox["R", "z", "\[Dagger]"], "(", 
        RowBox[{"\[Omega]", "\[VeryThinSpace]", "t"}], ")"}], "\[ImaginaryI]",
        "\[VeryThinSpace]", 
       RowBox[{
        SubscriptBox["\[PartialD]", "t"], 
        RowBox[{
         SubscriptBox["R", "z"], "(", 
         RowBox[{"\[Omega]", "\[VeryThinSpace]", "t"}], ")"}]}]}]}], "=", 
     RowBox[{
      RowBox[{
       FractionBox["\[CapitalDelta]", "2"], 
       SuperscriptBox["\[Sigma]", "x"]}], "+", 
      RowBox[{
       FractionBox[
        RowBox[{"B", "-", "\[Omega]"}], "2"], 
       SuperscriptBox["\[Sigma]", "z"]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"4d2af03e-c681-417c-bf71-d93eac39c59e"],
 "\[LineSeparator]in the rotating frame:"
}], "ExampleText",
 CellID->1285652313,ExpressionUUID->"a8c037a8-d88e-44f9-a1d4-1d6f35144b20"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"HR", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"ThePauli", "[", "1", "]"}], "*", 
      RowBox[{"\[CapitalDelta]", "/", "2"}]}], "+", 
     RowBox[{
      RowBox[{"ThePauli", "[", "3", "]"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"B", "[", "3", "]"}], "-", "\[Omega]"}], ")"}], "/", 
       "2"}]}]}], "//", "Normal"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"HR", "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1186541537,ExpressionUUID->"cbeca95d-870e-473b-ab89-615b31324fcf"],

