Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiNonunitary"]], 
     "paclet:QuantumMob/Q3/ref/BravyiNonunitary", "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"{", 
    RowBox[{
     StyleBox["h", "TI"], ",", 
     StyleBox["g", "TI"], ",", 
     SubscriptBox[
      StyleBox["g", "TI"], 
      StyleBox["0", "TR"]]}], "}"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "363b9237-fc53-439a-9fa9-08e0ccaa584d"],
 ", with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "f2b73033-64e1-4a09-8fdc-f69276ee92be"],
 " ",
 StyleBox["real",
  FontSlant->"Italic"],
 " anti-symmetric matrices ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "6099d10a-a711-4d52-a183-a8dc5d785df0"],
 " and ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "8020c915-84bf-426e-a914-ba9a96899bfc"],
 " and a real positive number ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["g", "TI"], 
   StyleBox["0", "TR"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "268799ac-db76-476f-bd3c-47cd25abfd90"],
 ", represents an arbitrary many-fermion operator of the form\[LineSeparator]\
\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["W", "^"], ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", 
       SubscriptBox["g", "0"]}], "+", 
      RowBox[{
       FractionBox["1", "4"], 
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}], 
        RowBox[{"2", "n"}]], 
       SubscriptBox[
        RowBox[{
         SubscriptBox[
          OverscriptBox["c", "^"], "i"], " ", "[", 
         RowBox[{"h", "-", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "g"}]}], "]"}], 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox[
        OverscriptBox["c", "^"], "j"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"59286ee4-96fb-441d-8627-a060afcf196a"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["c", "^"], "k"], TraditionalForm]],ExpressionUUID->
  "a5ef8e86-a260-457b-9d03-5643e56c2e0c"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["c", "^"], "k"], TraditionalForm]],ExpressionUUID->
  "f615ed34-02e7-40e0-9b41-0e43a5f43ca9"],
 " are the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n"}], TraditionalForm]],ExpressionUUID->
  "6ff08616-70a4-46b5-a04c-afc592df393d"],
 " ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " operators corresponding to ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cc52e252-93df-45ef-8c8a-cd66fb100e96"],
 " Dirac fermion modes. Physically, it describes a non-unitary dynamics \
governed by the non-Hermitian Hamiltonian ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["H", "^"], "non"], "=", 
    RowBox[{
     OverscriptBox["H", "^"], "-", 
     RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
      OverscriptBox["G", "^"]}]}]}], TraditionalForm]],ExpressionUUID->
  "74d2c49a-7139-4315-86fd-b05a40869266"],
 ", where\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], ":=", 
    RowBox[{
     FractionBox["\[ImaginaryI]", "4"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox[
      OverscriptBox["c", "^"], "i"], " ", 
     SubscriptBox["h", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox[
      OverscriptBox["c", "^"], "j"]}]}], TraditionalForm]],ExpressionUUID->
  "92f52cd8-7ca7-434e-93b3-c6b005414749"],
 "\[LineSeparator]is the effective Hamiltonian and\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["G", "^"], ":=", 
    RowBox[{
     SubscriptBox["g", "0"], "+", 
     RowBox[{
      FractionBox["\[ImaginaryI]", "4"], 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], 
       RowBox[{"2", "n"}]], 
      SubscriptBox[
       OverscriptBox["c", "^"], "i"], " ", 
      SubscriptBox["g", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
      SubscriptBox[
       OverscriptBox["c", "^"], "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "53b70c38-4a0d-42e5-a490-4a9d92d46af5"],
 "\[LineSeparator]is the effective damping operator."
}], "Notes",
 CellID->1582982925,ExpressionUUID->"d4f3a90f-72f5-4428-b608-b90d52b23a87"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  StyleBox["ham", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c4111117-376f-4fae-a00b-9df224d84243"],
 " and ",
 Cell[BoxData[
  StyleBox["dmp", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b1916875-1633-406e-8cbd-8c3a3ceb40c9"],
 " are given in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["NambuHermitian"]], "paclet:QuantumMob/Q3/ref/NambuHermitian", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8aed85e4-2500-4754-9b2b-37876e6f5850"],
 " object, then they are automatically converted to the coefficient matrices \
for ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " modes."
}], "Notes",
 CellID->1920253778,ExpressionUUID->"4a6447dc-4c4f-4144-a36a-a7739e024474"],

Cell[TextData[{
 "A quadratic many-body operator (such as Hamiltonian) is typically expressed \
as a bilinear combination of Dirac or Majorana fermion operators as follows:\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", GridBox[{
         {
          SuperscriptBox["a", "\[Dagger]"], "a"}
        }], ")"}], "H", " ", 
      RowBox[{"(", GridBox[{
         {"a"},
         {
          SuperscriptBox["a", "\[Dagger]"]}
        }], ")"}]}], "=", 
     RowBox[{
      FractionBox["\[Iota]", "4"], 
      RowBox[{"(", GridBox[{
         {
          SubscriptBox["c", "1"], 
          SubscriptBox["c", "2"], "\[Ellipsis]"}
        }], ")"}], "A", " ", 
      RowBox[{"(", GridBox[{
         {
          SubscriptBox["c", "1"]},
         {
          SubscriptBox["c", "2"]},
         {"\[VerticalEllipsis]"}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "15150eb3-6964-4e5b-8949-d551768ff8b2"],
 " .\[LineSeparator]Here, notice the numerical pre-factors ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "/", "2"}], TraditionalForm]],ExpressionUUID->
  "bddb63ba-8da3-40b4-9b70-aa59b8471290"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ImaginaryI]", "/", "4"}], TraditionalForm]],ExpressionUUID->
  "a600f51f-586a-42e7-8c96-b29cf0f37f9b"],
 ", respectively. Due to these pre-factors, the two coefficients matrices are \
related each other by ",
 Cell[BoxData[
  RowBox[{
   StyleBox["A", "TI"], "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "2"}], "\[ImaginaryI]"}], ")"}], 
    RowBox[{
     TemplateBox[{
       Cell[
