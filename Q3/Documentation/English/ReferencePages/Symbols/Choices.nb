  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a4f06d92-95f3-4da0-9fec-dc9e87f941a1"],
 " deals with a special case of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["WeylTableaux"]], "paclet:QuantumMob/Q3/ref/WeylTableaux", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "60746618-d60e-47d0-890a-ef87bfc3ccec"],
 ", and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Choices"]], "paclet:QuantumMob/Q3/ref/Choices", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["p", "TI"], ",", 
    RowBox[{"{", 
     StyleBox["n", "TI"], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f6e694a0-2704-415f-8824-c38a13c9e627"],
 " is effectively equivalent to ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["WeylTableaux"]], "paclet:QuantumMob/Q3/ref/WeylTableaux", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["YoungShape"]], "paclet:QuantumMob/Q3/ref/YoungShape", 
       "QuantumMob Package Symbol"},
      "PackageLink",
      BaseStyle->"InlineFormula"], "[", 
     RowBox[{"{", 
      StyleBox["n", "TI"], "}"}], "]"}], ",", " ", 
    StyleBox["p", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4d139316-ef02-4669-b174-a9376e980a33"],
 ". Of course, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Choices"]], "paclet:QuantumMob/Q3/ref/Choices", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["p", "TI"], ",", 
    RowBox[{"{", 
     StyleBox["n", "TI"], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "615b8375-f8a7-4943-a89c-a01a16a7fec6"],
 " is faster than ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["WeylTableaux"]], "paclet:QuantumMob/Q3/ref/WeylTableaux", 
     "QuantumMob Package Symbol"},
