Cell[TextData[{
 "Each of the resulting pairs of Gelfand-Young and Gelfand-Weyl patterns \
refers to a unique element of the Schur basis associated with irreducible \
representations of ",
 ButtonBox["symmetric group",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SymmetricGroup"],
 " S(",
 StyleBox["n",
  FontSlant->"Italic"],
 ") with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n", "TI"], "=", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["YoungDegree"]], "paclet:ref/SymmetricGroup"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     StyleBox["gy", "TI"], "]"}], "+", "1"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ded857d5-1fec-4b44-8478-a117106f9d72"],
 " and unitary group U(",
 Cell[BoxData[
  StyleBox["d", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4da8d119-4a7b-49e2-b712-09523b8c62e3"],
 ")."
}], "Notes",
 CellID->829765466,ExpressionUUID->"865dbc33-e94e-449d-9fa7-2681d9b42a3b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

