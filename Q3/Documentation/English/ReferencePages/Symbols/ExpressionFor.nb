Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ExpressionFor"]], "paclet:QuantumMob/Q3/ref/ExpressionFor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3e8f7910-9258-4dbf-ad7f-f4a2a553d0f5"],
 " expresses the operator in terms of ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Pauli"]], "paclet:QuantumMob/Q3/ref/Pauli", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[Mu]", "TR"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["\[Mu]", "TR"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8e255f37-3cf2-4c53-a792-f8f3bd64a6a6"],
 ", where ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["\[Mu]", "TR"], 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "23367377-d18e-47b3-a839-d2cd10917d60"],
 " are 3 (corresponding to the Pauli Z operator), 4 (raising), or 5 \
(lowering)."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"f28cdb10-44ef-480a-b65c-c8b3cc3f97ee"],

