Cell[TextData[{
 "For qubits and spins (with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Spin"]], "paclet:QuantumMob/Q3/ref/Spin", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "=", 
   RowBox[{"1", "/", "2"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e6cba770-f5e3-4eaa-8fe9-027f063accbf"],
 "), ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["ExpressionFor"]], "paclet:QuantumMob/Q3/ref/ExpressionFor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["mat", "TI"], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f999b2c2-95f7-451a-8dfa-04bc2e75c76c"],
 " returns an expression in terms of the raising, lowering, and Pauli (spin) \
Z operators, rather than the Pauli X, Y, and Z operators. This is for \
efficiency."
}], "Notes",
 CellID->268181230,ExpressionUUID->"f4cdbe4a-0b05-4f27-86ec-bd2bcc7af772"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["ExpressionFor"]], "paclet:QuantumMob/Q3/ref/ExpressionFor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "78c81b90-a3be-4cb0-abed-0ed0ed7ee224"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a2ad004d-8ef7-4c01-ab52-02c8f8033b57"],
 " allow to work either on more abstract operators or more concrete matrices \
depending on the context, going back and forth between them. For simple \
systems, matrix representations are enough, but they are basis-dependent. \
Operator expressions are not only basis-independent but also, for many \
complex systems, more efficient and inspiring. "
}], "Notes",
 CellID->58646586,ExpressionUUID->"cb89cc9b-97a5-4b40-8a6c-8e921137d3c0"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

