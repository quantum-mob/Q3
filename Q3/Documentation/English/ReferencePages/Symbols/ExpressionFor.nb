Cell[TextData[{
 "Although the above matrix representation is obviously for an operator given \
in terms of the spin operators, ",
 StyleBox["S[\[Ellipsis],1], S[\[Ellipsis],2], and S[\[Ellipsis],3]", "Input"],
 ", in general an operator on the Hilbert space associated with spins cannot \
be expressed in terms of the spin operators. Therefore, ",
 Cell[BoxData["ExpressionFor"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2e2d2839-0876-4ba3-938f-b3f62e3311cd"],
 " gives the operator expression corresponding to the matrix representation \
in terms of dyadic products."
}], "ExampleText",
 CellID->1568841398,ExpressionUUID->"ec4ad7e1-9a71-4e03-9669-b22d3736af64"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"new", "=", 
  RowBox[{"ExpressionFor", "[", 
   RowBox[{"mat", ",", 
    RowBox[{"S", "@", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}]}]}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
