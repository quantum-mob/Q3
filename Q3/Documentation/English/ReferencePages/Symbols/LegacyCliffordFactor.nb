Cell[TextData[{
 "Since Q3 v3.5.11, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CliffordFactor"]], "paclet:QuantumMob/Q3/ref/CliffordFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b0285e38-47ea-40bf-8dad-990f8d956d83"],
 " is based on the algorithm in ",
 ButtonBox["van den Berg (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1109/qce52317.2021.00021"], None}],
 ". Previously, it was based on Gottesman's theorem in ",
 ButtonBox["Gottesman (1998)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.57.127"], None}],
 ", and is now renamed ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["LegacyCliffordFactor"]], 
    "paclet:QuantumMob/Q3/ref/LegacyCliffordFactor", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c6196231-cbdf-46b3-96d0-52110afe962e"],
 ". While the latter provides a more compact set of (a bit higher-level) \
gates, the former is faster and easier to trace the changes in the sign of \
Pauli strings."
}], "Notes",
 CellID->982671809,ExpressionUUID->"63bdd45f-d9e8-47e6-a7a3-a8d2e7e24245"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

