Cell[TextData[{
 "When ",
 Cell[BoxData[
  StyleBox["jmp", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "60ad2124-6a56-4242-bcba-d8ce1b7086d5"],
 " are given in the form of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2e18ef39-edf6-4bee-94c1-ca0a1c746668"],
 ", each quantum jump operator is regarded as a ",
 StyleBox["projection operator",
  FontSlant->"Italic"],
 " associated with a dressed fermion mode."
}], "Notes",
 CellID->1177845785,ExpressionUUID->"706544cd-5931-4f73-9664-96c5f28f7ea2"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiLindbladSolve"]], 
    "paclet:QuantumMob/Q3/ref/BravyiLindbladSolve", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fb32bfed-147e-486b-9637-b826c918eccc"],
 " solves the quantum master equation\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["d\[Rho]", "dt"], "=", 
    RowBox[{"\[ScriptCapitalL]", "(", "\[Rho]", ")"}]}], TraditionalForm]],
  ExpressionUUID->"32f18353-99bd-4f0f-850b-e5a7bf485cd8"],
 "\nwith Lindblad supermap\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"\[ImaginaryI]", "[", 
        RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "-", 
      RowBox[{
       FractionBox["1", "2"], 
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], 
          SubscriptBox["L", "\[Mu]"]}], ",", "\[Rho]"}], "}"}]}], "+", 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
       SubscriptBox["L", "\[Mu]"], "\[Rho]", "\[ThinSpace]", 
       SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}], "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"i", "[", 
        RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "+", 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "\[Mu]"], "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["L", "\[Mu]"], "\[Rho]"}], ",", 
         SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}], "]"}]}], "+", 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "\[Mu]"], "[", 
        RowBox[{
         SubscriptBox["L", "\[Mu]"], ",", 
         RowBox[{"\[Rho]", "\[ThinSpace]", 
          SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}], "]"}]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"49eea9ad-723a-4498-ad5a-37395f2cde71"],
 " ,\[LineSeparator]where each quantum jump operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "20bd45de-82b6-478f-b7a4-d19d7c1eaa18"],
 " is a linear superposition of Majorana fermion operators, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "099898e3-edb3-476a-a48b-23b37d65993f"],
 ", \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "\[Mu]"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["\[ScriptL]", 
      RowBox[{"\[Mu]", ",", "i"}]], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "ee18c3c8-0d36-4a43-9f34-c383de89fb08"],
 " ,\[LineSeparator]or a projection operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "\[Mu]"], ":=", 
    RowBox[{
     SubsuperscriptBox["b", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["b", "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "7b9b551b-3171-4a58-8760-f8eed80a8fd5"],
 "   \[LineSeparator]associated with dressed fermion mode\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "\[Mu]"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["\[ScriptL]", 
      RowBox[{"\[Mu]", ",", "i"}]], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "573907f8-a618-48db-b6dc-feae1daf1a60"],
 "."
}], "Notes",
 CellID->1299582758,ExpressionUUID->"d8e3f76d-80ff-43cc-a31f-c94256432819"],

Cell[TextData[{
 "It is useful to note that with respect to the Hermitian product, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"A", ",", "B"}], "\[RightAngleBracket]"}], ":=", 
    RowBox[{"Tr", "[", 
     RowBox[{
      SuperscriptBox["A", "\[Dagger]"], "B"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"c8adbb29-75e6-4036-aa97-1e9d6ee1041b"],
 ", the Hermitian conjugate ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalL]", "\[Dagger]"], TraditionalForm]],
  ExpressionUUID->"a03e46fa-cfa5-402d-8d39-511f1bfe88db"],
 " of the Lindblad supermap ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalL]", TraditionalForm]],ExpressionUUID->
  "631cad9d-9bc1-4656-aebd-36102fd01a75"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalL]", "\[Dagger]"], "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{"+", 
      RowBox[{"\[ImaginaryI]", "[", 
       RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
      RowBox[{
       SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], "\[ThinSpace]", "[", 
       RowBox[{"\[Rho]", ",", 
        SubscriptBox["L", "\[Mu]"]}], "]"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], "\[ThinSpace]", "[", 
       RowBox[{
        SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], ",", "\[Rho]"}], "]"}], 
      
      SubscriptBox["L", "\[Mu]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "466a18a4-46a2-43ac-aaa4-fa8bda4d3d7f"],
 " ."
}], "Notes",
 CellID->2112322187,ExpressionUUID->"63709d19-2a9a-4096-9b71-b2bcd5dc00a3"],

Cell[TextData[{
 "Furthermore, when the quantum jump operators are Hermitian (such as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "k", "\[Dagger]"], 
    SubscriptBox["a", "k"]}], TraditionalForm]],ExpressionUUID->
  "d791a443-a1a5-4ac1-9063-8a7978d750e6"],
 "), the Hermitian conjugate is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalL]", "\[Dagger]"], "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{"+", 
      RowBox[{"\[ImaginaryI]", "[", 
       RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "-", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], "\[ThinSpace]", "[", 
       "\[ThinSpace]", 
       RowBox[{
        SubscriptBox["L", "\[Mu]"], ",", 
        RowBox[{"[", 
         RowBox[{
          SubscriptBox["L", "\[Mu]"], ",", "\[Rho]"}], "]"}]}], "]"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"30513667-aeca-4d25-a7a0-91cde2420d4b"],
 " .\[LineSeparator]From this, it is clear that the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalL]", "\[Dagger]"], "(", "\[Rho]", ")"}], 
   TraditionalForm]],ExpressionUUID->"705b22fe-307f-44da-bac1-e73a7b093eaf"],
 " is quadratic if ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "6dcd0b0e-863d-41a9-8b0d-10af43877e2b"],
 " are quadratic."
}], "Notes",
 CellID->1030785274,ExpressionUUID->"c217ef99-d255-4b89-8ce9-1cdd4592316c"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

