Cell["Solve the quantum master equation.", "ExampleText",
 CellID->362653969,ExpressionUUID->"069ce44e-ffd8-4997-ae5d-0d1b6a47c171"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "rho", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rho", "[", "t_", "]"}], "=", 
    RowBox[{"NLindbladSolve", "[", 
     RowBox[{"spr", ",", "in", ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0", ",", "$T"}], "}"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}]}], "Input",
