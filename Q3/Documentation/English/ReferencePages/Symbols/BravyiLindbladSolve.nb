 CellID->1928741974,ExpressionUUID->"9ffbf498-b689-4411-a9c9-5480fc6f1315"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"hamOp", ",", "msrOp"}], "}"}], "=", 
   RowBox[{"Matrix", "/@", 
    RowBox[{"HatanoNelsonModel", "[", 
     RowBox[{
      RowBox[{"$J", "/", "$\[Gamma]"}], ",", "1", ",", "$L"}], "]"}]}]}], 
  ";"}]], "Input",
