Cell["Let us verify the above result in a conventional way.", "ExampleText",
 CellID->1928741974,ExpressionUUID->"2f821c27-7671-489d-811d-bff1617466d9"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"hamOp", ",", "msrOp"}], "}"}], "=", 
   RowBox[{"Matrix", "/@", 
    RowBox[{"HatanoNelsonModel", "[", 
     RowBox[{
      RowBox[{"$J", "/", "$\[Gamma]"}], ",", "1", ",", "$L"}], "]"}]}]}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->100705553,ExpressionUUID->"dd1e8df0-0bc5-4f47-a714-8a3f13016d45"],

Cell[BoxData[
 RowBox[{
  RowBox[{"spr", "=", 
   RowBox[{"N", "@", 
    RowBox[{"LindbladSupermap", "[", 
     RowBox[{"hamOp", ",", "msrOp"}], "]"}]}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->341115435,ExpressionUUID->"49b15197-5e81-469c-9f2a-72284f58a92d"],

