Cell[TextData[{
 "When ",
 Cell[BoxData[
  StyleBox["jmp", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "25310c4c-5a58-4326-9c3d-6e6af3a26e91"],
 " are given in the form of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8ad123ff-2eeb-498c-bab7-6ed487f12ca5"],
 ", each quantum jump operator is regarded as a ",
 StyleBox["projection operator",
  FontSlant->"Italic"],
 " associated with a dressed fermion mode."
}], "Notes",
 CellID->1177845785,ExpressionUUID->"7b519e12-4895-4ad3-adc4-70197edbc22f"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiLindbladSolve"]], 
    "paclet:QuantumMob/Q3/ref/BravyiLindbladSolve", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e4e9a95e-311f-4791-9cd0-cca1a6b8007c"],
 " solves the quantum master equation\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["d\[Rho]", "dt"], "=", 
    RowBox[{"\[ScriptCapitalL]", "(", "\[Rho]", ")"}]}], TraditionalForm]],
  ExpressionUUID->"f9a6aac9-476f-405a-8956-ac5884a67bf6"],
 "\nwith Lindblad supermap\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"\[ImaginaryI]", "[", 
        RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "-", 
      RowBox[{
       FractionBox["1", "2"], 
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], 
          SubscriptBox["L", "\[Mu]"]}], ",", "\[Rho]"}], "}"}]}], "+", 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
       SubscriptBox["L", "\[Mu]"], "\[Rho]", "\[ThinSpace]", 
       SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}], "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"i", "[", 
        RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "+", 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "\[Mu]"], "[", 
        RowBox[{
         RowBox[{
          SubscriptBox["L", "\[Mu]"], "\[Rho]"}], ",", 
         SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}], "]"}]}], "+", 
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{
        SubscriptBox["\[CapitalSigma]", "\[Mu]"], "[", 
        RowBox[{
         SubscriptBox["L", "\[Mu]"], ",", 
         RowBox[{"\[Rho]", "\[ThinSpace]", 
          SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}], "]"}]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"6ce45977-e4d3-4ae7-89cf-a3907d507bd2"],
 " ,\[LineSeparator]where each quantum jump operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "47153798-b3bd-4b0c-aa3b-9c24123652fd"],
 " is a linear superposition of Majorana fermion operators, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "bfa04416-fc54-4d2f-ae72-570b13788165"],
 ", \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "\[Mu]"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["\[ScriptL]", 
      RowBox[{"\[Mu]", ",", "i"}]], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "d569265b-dc50-4d37-9d2e-bb927130903f"],
 " ,\[LineSeparator]or a projection operator\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "\[Mu]"], ":=", 
    RowBox[{
     SubsuperscriptBox["b", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["b", "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "1190b032-8a3b-4bda-b41e-49763e924883"],
 "   \[LineSeparator]associated with dressed fermion mode\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "\[Mu]"], ":=", 
    RowBox[{
     SubsuperscriptBox["\[CapitalSigma]", 
      RowBox[{"i", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["\[ScriptL]", 
      RowBox[{"\[Mu]", ",", "i"}]], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "785a00d7-a0ec-4fdb-9bb7-9c249abbe5da"],
 "."
}], "Notes",
 CellID->1299582758,ExpressionUUID->"baeedcda-aa76-4e57-ac28-ea0c71b45368"],

Cell[TextData[{
 "It is useful to note that with respect to the Hermitian product, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"A", ",", "B"}], "\[RightAngleBracket]"}], ":=", 
    RowBox[{"Tr", "[", 
     RowBox[{
      SuperscriptBox["A", "\[Dagger]"], "B"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"2bca50d4-c74e-4602-ba30-60c1873e1563"],
 ", the Hermitian conjugate ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalL]", "\[Dagger]"], TraditionalForm]],
  ExpressionUUID->"79d78290-3481-4b4e-a372-a065a6825d4f"],
 " of the Lindblad supermap ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalL]", TraditionalForm]],ExpressionUUID->
  "30b76eea-8f5b-4b11-b691-2cb78ec19c7f"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalL]", "\[Dagger]"], "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{"+", 
      RowBox[{"\[ImaginaryI]", "[", 
       RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
      RowBox[{
       SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], "\[ThinSpace]", "[", 
       RowBox[{"\[Rho]", ",", 
        SubscriptBox["L", "\[Mu]"]}], "]"}]}], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], "\[ThinSpace]", "[", 
       RowBox[{
        SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], ",", "\[Rho]"}], "]"}], 
      
      SubscriptBox["L", "\[Mu]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "d946bb67-e555-4004-b9f7-e393ed484694"],
 " ."
}], "Notes",
 CellID->2112322187,ExpressionUUID->"fc1fe181-1800-465e-82d8-7b154605297d"],

Cell[TextData[{
 "Furthermore, when the quantum jump operators are Hermitian (such as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "k", "\[Dagger]"], 
    SubscriptBox["a", "k"]}], TraditionalForm]],ExpressionUUID->
  "6fb80bba-1c32-4429-a16b-cd9679537f35"],
 "), the Hermitian conjugate is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalL]", "\[Dagger]"], "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{"+", 
      RowBox[{"\[ImaginaryI]", "[", 
       RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "-", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "\[Mu]"], "\[ThinSpace]", "[", 
       "\[ThinSpace]", 
       RowBox[{
        SubscriptBox["L", "\[Mu]"], ",", 
        RowBox[{"[", 
         RowBox[{
          SubscriptBox["L", "\[Mu]"], ",", "\[Rho]"}], "]"}]}], "]"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"0db921bc-2ff5-4ee9-b5ab-8b9417045b6c"],
 " .\[LineSeparator]From this, it is clear that the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalL]", "\[Dagger]"], "(", "\[Rho]", ")"}], 
   TraditionalForm]],ExpressionUUID->"4c2e35be-04cd-4c12-ad43-885b2de334b6"],
 " is quadratic if ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "9b64d106-78e0-4c3c-9201-334387bc163c"],
 " are quadratic."
}], "Notes",
 CellID->1030785274,ExpressionUUID->"71182820-53dc-4515-99ec-9633e4e032c5"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

