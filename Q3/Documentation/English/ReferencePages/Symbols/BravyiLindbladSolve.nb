Cell[BoxData[{
 RowBox[{
  RowBox[{"gg", "=", 
   RowBox[{"Matrix", "[", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{"Multiply", ",", "aa", ",", 
       RowBox[{"Dagger", "[", "aa", "]"}]}], "]"}], ",", "aa"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", "theGreen", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"theGreen", "[", "t_", "]"}], ":=", 
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{"#", ".", 
       RowBox[{"rho", "[", "t", "]"}]}], "]"}], "&"}], ",", "gg", ",", 
    RowBox[{"{", "2", "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Clear", "[", "theNegativity", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sub", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"$L", "/", "2"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"theNegativity", "[", "t_", "]"}], ":=", 
  RowBox[{"BravyiLogarithmicNegativity", "[", 
   RowBox[{
    RowBox[{"theGreen", "[", "t", "]"}], ",", "sub"}], "]"}]}]}], "Input",
