Cell[BoxData[{
 RowBox[{
  RowBox[{"$\[Mu]", "=", "0.2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$J", "=", 
   RowBox[{"$\[CapitalDelta]", "=", "1."}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"$\[Gamma]", "=", "0.1"}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{"monitoring", " ", "rate"}], "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->210746937,ExpressionUUID->"7ae4896e-2fd6-4287-8a56-d6beac1d3e75"],

Cell[BoxData[{
 RowBox[{"Clear", "[", "KitaevChain", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"KitaevChain", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Mu]_", ",", "J_", ",", "\[CapitalDelta]_"}], "}"}], ",", 
    "\[Gamma]_", ",", "n_Integer"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"hrm", ",", "del", ",", "ham", ",", "msr"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"hrm", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "\[Mu]"}], "*", 
        RowBox[{"One", "[", "n", "]"}]}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"J", "/", "2"}], ")"}], "*", 
        RowBox[{"PlusTopple", "@", 
         RowBox[{"One", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"n", ",", "n"}], "}"}], ",", "1"}], "]"}]}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"del", "=", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"\[CapitalDelta]", "/", "2"}], ")"}]}], "*", 
       RowBox[{"One", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"n", ",", "n"}], "}"}], ",", "1"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"del", "=", 
      RowBox[{"del", "-", 
       RowBox[{"Transpose", "[", "del", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ham", "=", 
      RowBox[{"NambuHermitian", "[", 
       RowBox[{"{", 
        RowBox[{"hrm", ",", "del"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"msr", "=", 
      RowBox[{
       RowBox[{"Surd", "[", 
        RowBox[{"\[Gamma]", ",", "4"}], "]"}], "*", 
       RowBox[{"One", "[", 
        RowBox[{"{", 
         RowBox[{"n", ",", 
          RowBox[{"2", "*", "n"}]}], "}"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"msr", "=", 
      RowBox[{"NambuMeasurement", "[", "msr", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"ham", ",", "msr"}], "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->2130478080,ExpressionUUID->"46e60198-eee7-473a-ab16-b10f21148469"],

