 RowBox[{
  RowBox[{"gg", "=", 
   RowBox[{"Matrix", "[", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{"Multiply", ",", "aa", ",", 
       RowBox[{"Dagger", "[", "aa", "]"}]}], "]"}], ",", "aa"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", "theGreen", "]"}], ";"}], "\[IndentingNewLine]", 
