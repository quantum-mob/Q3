Cell[TextData[{
 "It suffices to examine the generators of the symmetric group. Note that ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Cycles"]], "paclet:ref/Cycles"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   StyleBox["\[Ellipsis]", "TR"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c4c7abbb-2ca7-4c88-a25c-05c69a19381e"],
 " directly acts on the vectors in the Specht basis while ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Permutation"]], "paclet:QuantumMob/Q3/ref/Permutation", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Cycles"]], "paclet:ref/Cycles"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     StyleBox["\[Ellipsis]", "TR"], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c8c93b68-4a78-45a6-a61a-3b5c0a27e21b"],
 " acts on the vectors in the Schur basis."
}], "ExampleText",
 CellID->1100408444,ExpressionUUID->"56fa5aee-4a4d-4267-a22c-02af8284d83c"],

