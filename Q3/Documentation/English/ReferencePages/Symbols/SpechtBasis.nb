Cell[TextData[{
 "Here, we examine ",
 StyleBox["Young's normal representation",
  FontSlant->"Italic"],
 " of the symmetric group. ",
 StyleBox["Young\[CloseCurlyQuote]s normal representation",
  FontSlant->"Italic"],
 " is associated with the ",
 StyleBox["Specht module",
  FontSlant->"Italic"],
 " corresponding to the Young shape \[Lambda]. We explicitly construct ",
 ButtonBox["Young's normal representation",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/RepresentationsOfTheSymmetricGroup#\
636042487"],
 " from the Specht basis."
}], "ExampleText",
 CellID->1023983710,ExpressionUUID->"cd247113-d93a-46e3-b144-572fb4e15244"],

