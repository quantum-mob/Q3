Cell[TextData[{
 "The Specht basis gives ",
 StyleBox["Young's normal representation",
  FontSlant->"Italic"],
 ". For the relation between the Specht basis and Young's normal \
representation, see ",
 ButtonBox["Representations of the Symmetric Group",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/RepresentationsOfTheSymmetricGroup#\
636042487"],
 "."
}], "Notes",
 CellID->2104201355,ExpressionUUID->"21daf80b-93df-47ea-9607-1e2e01b605d6"],

Cell[TextData[{
 "Young's ",
 StyleBox["normal",
  FontSlant->"Italic"],
 " representation is distinguished from Young\[CloseCurlyQuote]s ",
 StyleBox["natural",
  FontSlant->"Italic"],
 " representation (Sagan, 2001, Section 2.7) or Young\[CloseCurlyQuote]s ",
 StyleBox["seminormal",
  FontSlant->"Italic"],
 " representation (Sagan, 2001, Exercise 2.11)."
}], "Notes",
 CellID->951889003,ExpressionUUID->"956a3f03-672c-4403-bf69-cbc418aa02b2"],

Cell[TextData[{
 "Note that the resulting list is not in ",
 StyleBox["lexicographic order",
  FontSlant->"Italic"],
 ". For the lexicographic ordering of Young tableaux, see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GelfandOrder"]], "paclet:QuantumMob/Q3/ref/GelfandOrder", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "33b2442d-f422-49e3-bcf8-f180def0af79"],
 "."
}], "Notes",
 CellID->453454693,ExpressionUUID->"0d88dd85-e89f-4481-85f0-a2fd0c898996"]
