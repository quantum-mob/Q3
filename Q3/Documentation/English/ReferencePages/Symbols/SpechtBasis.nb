Cell[TextData[{
 StyleBox["Theorem",
  FontWeight->"Bold"],
 ": Let ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"808df76e-1d95-436c-84eb-5d8bbbc052e7"],
 " be an irreducible representation of the symmetric group. Let ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalV]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"cebd1d1d-61a4-4613-943d-70b32099426e"],
 " be the associated carrier space with basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"p"},
        "Ket"], "|", "p"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     SubscriptBox["d", "\[Lambda]"]}], "}"}], TraditionalForm]],
  ExpressionUUID->"ba6d907e-8b75-4c02-8ab8-31bb19ae3ca6"],
 ". Then, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPhi]"},
     "Ket"], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "p"], 
     RowBox[{
      TemplateBox[{"p"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"p"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c87bf295-503a-4373-a401-02d85955a329"],
 " is the ",
 StyleBox["unique",
  FontSlant->"Italic"],
 " (up to a global phase) vector in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalV]", "\[Lambda]"], "\[CircleTimes]", 
    SuperscriptBox["\[ScriptCapitalV]", "\[Lambda]"]}], TraditionalForm]],
  ExpressionUUID->"e3c9ecdf-dac5-4796-b715-a79eedc681da"],
 " that is invariant under the symmetric group."
}], "ExampleText",
 CellID->35185514,ExpressionUUID->"4f66e940-3da9-4863-805a-193f0bb5940c"],

