Cell["Here, we demonstrate the following theorem:", "ExampleText",
 CellID->804930873,ExpressionUUID->"ac093c1e-27df-4371-99a3-81afe6d456ea"],

Cell[TextData[{
 StyleBox["Theorem",
  FontWeight->"Bold"],
 ": Let ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"a5471dcd-e38d-49c5-a13a-fa956d79d44e"],
 " be an irreducible representation of the symmetric group. Let ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalV]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"25d9fec8-43ef-4ff0-9805-d00d6d2a33aa"],
 " be the associated carrier space with basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"p"},
        "Ket"], "|", "p"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     SubscriptBox["d", "\[Lambda]"]}], "}"}], TraditionalForm]],
  ExpressionUUID->"f04b1d41-5e5a-4471-983b-106eefd41796"],
 ". Then, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPhi]"},
     "Ket"], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "p"], 
     RowBox[{
      TemplateBox[{"p"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"p"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "cd6c79a2-a7b7-4a47-b856-dfb52e0e0163"],
 " is the ",
 StyleBox["unique",
  FontSlant->"Italic"],
 " (up to a global phase) vector in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalV]", "\[Lambda]"], "\[CircleTimes]", 
    SuperscriptBox["\[ScriptCapitalV]", "\[Lambda]"]}], TraditionalForm]],
  ExpressionUUID->"2d59854b-6b2f-433c-b10d-67bc177e50e2"],
 " that is invariant under the symmetric group."
}], "ExampleText",
 CellID->35185514,ExpressionUUID->"81c71fe1-dc21-4610-8c8c-7a84daccdd22"],

