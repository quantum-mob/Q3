Cell[TextData[{
 "Here, we demonstrate that the result from ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BosonBasis"]], "paclet:QuantumMob/Q3/ref/BosonBasis", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["b", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["b", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["b", "TI"], 
       StyleBox["m", "TI"]]}], "}"}], ",", 
    RowBox[{"{", 
     StyleBox["n", "TI"], "}"}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ddb1911a-d5ad-4816-bd8a-fbb54717132b"],
 " is consistent with the order of terms in expansion of the form\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["k", "1"], "=", "1"}], "m"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["k", "2"], "=", "1"}], "m"], "\[Ellipsis]", 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["k", "n"], "=", "1"}], "m"], 
     SubsuperscriptBox["a", 
      SubscriptBox["k", "1"], "\[Dagger]"], 
     SubsuperscriptBox["a", 
      SubscriptBox["k", "2"], "\[Dagger]"], "\[Ellipsis]", "\[VeryThinSpace]", 
     SubsuperscriptBox["a", 
      SubscriptBox["k", "n"], "\[Dagger]"], 
     TemplateBox[{"\[SpaceIndicator]"},
      "Ket"], 
     SubscriptBox["C", 
      RowBox[{
       SubscriptBox["k", "1"], 
       SubscriptBox["k", "2"], "\[Ellipsis]", "\[VeryThinSpace]", 
       SubscriptBox["k", "n"]}]]}]}], TraditionalForm]],ExpressionUUID->
  "ce18666f-1c98-4820-8201-7d08a0a628db"],
 "."
}], "ExampleText",
 CellID->1308876032,ExpressionUUID->"6f5008ba-db41-4e22-a37d-4bc54f410714"],

