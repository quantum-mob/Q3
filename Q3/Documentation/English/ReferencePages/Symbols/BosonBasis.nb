Cell[TextData[{
 StyleBox["Update Note (since Q3 v2.14.10)",
  FontWeight->"Bold"],
 ": The arrangement order of elements in the resulting basis has been changed \
so that ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BosonBasis"]], "paclet:QuantumMob/Q3/ref/BosonBasis", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["a", "TI"], 
       StyleBox["m", "TI"]]}], "}"}], ",", 
    RowBox[{"{", 
