 RowBox[{"kk", "=", 
  RowBox[{"{", 
   RowBox[{"1", ",", "3"}], "}"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->970678207,ExpressionUUID->"594cc26c-1025-4e99-9c25-f4a00c5dc087"],

