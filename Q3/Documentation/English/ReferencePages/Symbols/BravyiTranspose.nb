Cell[TextData[{
 "Suppose that the system consists of two parts ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "9f81fcd9-815f-4aeb-8859-eee54d5a247e"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "fb772c42-e0e6-485a-965a-66b557bb27f2"],
 ". The ",
 StyleBox["fermionic partial transposition",
  FontSlant->"Italic"],
 " with respect to part ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "1b630619-e788-4353-baaf-8c83f173401d"],
 " is defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["c", 
     SubscriptBox["T", "A"]], ":=", 
    TagBox[GridBox[{
       {"\[Piecewise]", GridBox[{
          {
           RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "c"}], 
           RowBox[{"c", "\[Element]", "A"}]},
          {"c", 
           RowBox[{"c", "\[NotElement]", "A"}]}
         },
         AllowedDimensions->{2, Automatic},
         Editable->True,
         GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
         GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
         GridBoxSpacings->{"Columns" -> {
             Offset[0.27999999999999997`], {
              Offset[0.84]}, 
             Offset[0.27999999999999997`]}, "Rows" -> {
             Offset[0.2], {
              Offset[0.4]}, 
             Offset[0.2]}},
         Selectable->True]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
      GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.35]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}],
     "Piecewise",
     DeleteWithContents->True,
     Editable->False,
     SelectWithContents->True,
     Selectable->False,
     StripWrapperBoxes->True]}], TraditionalForm]],ExpressionUUID->
  "7eb60095-5f07-4fa0-b529-83604a1a1ba2"],
 " \[LineSeparator]on Majorana operator ",
 Cell[BoxData[
  FormBox["c", TraditionalForm]],ExpressionUUID->
  "c055bb51-ab15-450e-b1a5-d5bd3ce6222e"],
 "."
}], "Notes",
 CellID->2052893415,ExpressionUUID->"7a3cbb3a-a55a-476f-a85d-7f48bd860be7"],

Cell[TextData[{
 "For two arbitrary operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "1"], TraditionalForm]],ExpressionUUID->
  "316b4e30-52b0-47f0-8c79-0bb064b9e5ef"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["O", "2"], TraditionalForm]],ExpressionUUID->
  "d05d16ac-6009-4ac2-b5d5-ad16a47f5cd2"],
 " on the Hilbert space ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "25433238-9955-4293-ab31-48b753cc08e9"],
 ", \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["O", "1"], 
       SubscriptBox["O", "2"]}], ")"}], 
     SubscriptBox["T", "A"]], ":=", 
    RowBox[{
     SubsuperscriptBox["O", "1", 
      SubscriptBox["T", "A"]], 
     SubsuperscriptBox["O", "2", 
      SubscriptBox["T", "A"]]}]}], TraditionalForm]],ExpressionUUID->
  "a73b3493-4104-4a78-b7a1-952559117ceb"],
 ".\[LineSeparator]Note that unlike matrix transpose, there is ",
 StyleBox["no",
  FontSlant->"Italic"],
 " reversed ordering."
}], "Notes",
 CellID->1622351535,ExpressionUUID->"552d6d6a-6e7b-4c33-ac27-63054dab5231"],

Cell[TextData[{
 "Note that the resulting covariance matrix is not real any longer (though \
still anti-symmetric), implying that the corresponding Gaussian operator is \
not Hermitian. See ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Bravyi (2005)"]], 
    "https://dl.acm.org/doi/abs/10.5555/2011637.2011640"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "f7d8e6d9-0f41-4cde-955c-be1f226cf7c4"],
 "."
}], "Notes",
 CellID->1096439608,ExpressionUUID->"3f4db94e-3af5-4ea1-8bc5-e6669e194d60"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

