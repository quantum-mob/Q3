Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PauliGroup"]], "paclet:QuantumMob/Q3/ref/PauliGroup", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4caeee08-0f72-4fca-ab3c-2ad78a9a5182"],
 " is a quotient group ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["FullPauliGroup"]], "paclet:QuantumMob/Q3/ref/FullPauliGroup",
       "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "/", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         StyleBox[
          RowBox[{"\[ImaginaryI]", 
           StyleBox["m",
            FontSlant->"Italic"], "\[Pi]"}]], "/", "2"}]], ":", "m"}], "=", 
      "0"}], ",", "1", ",", "2", ",", "3"}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "488a04d0-dd73-4358-80b4-22d3b32d5245"],
 "."
}], "Notes",
 CellID->1113436462,ExpressionUUID->"639d19c2-05b2-4718-af8a-f0c2ff5ea89d"],

Cell[TextData[{
 "The full Pauli group on ",
 StyleBox["n",
  FontSlant->"Italic"],
 " qubits, denoted by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"aec09d01-d711-49ec-89cf-5b5b4875d3a7"],
 ", is the group of tensor products of single-qubit Pauli operators. The \
center of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"7c016995-ceb7-4464-a85d-0c4a6c27d4ba"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalZ]", ":=", 
    RowBox[{"{", 
     RowBox[{"I", ",", " ", 
      RowBox[{"-", "I"}], ",", " ", 
      RowBox[{"\[ImaginaryI]", " ", "I"}], ",", " ", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "I"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"e917af48-44b7-47a7-a126-7b7d4988edd8"],
 ". The Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"4d6a38fb-0caa-4445-9fe8-7907c51cdddb"],
 " is the quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], ":=", 
    RowBox[{
     RowBox[{
      OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"98e17484-36b4-405a-934a-f9009de8e708"],
 ". The Pauli group is isomorphic to the Abelian group ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "11b6fcfd-5676-428d-aec0-f6c30ab082b8"],
 ", which can also be regarded as a vector space over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[DoubleStruckCapitalZ]", "2"], TraditionalForm]],
  ExpressionUUID->"f625d036-57d1-44bd-8cc3-03c5d91c44e6"],
 "."
}], "Notes",
 CellID->447549871,ExpressionUUID->"3f93cf7f-6b68-4363-be4e-e028d572c683"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

