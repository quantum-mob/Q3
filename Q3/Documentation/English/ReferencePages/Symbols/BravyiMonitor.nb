Cell["\<\
Construct approximate density matrices by taking averages of the covariance \
matrices in different trajectories, and calculate the logarithmic negativity \
(LN) between the subsystem and the rest in the \[LineSeparator]density \
matrices:\
\>", "ExampleText",
 CellID->1243375267,ExpressionUUID->"53e77a55-14e4-40f8-a8e7-56d97f7ae8b1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"BravyiMean", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"BravyiLogarithmicNegativity", "[", 
      RowBox[{"avg", ",", "sub"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->244743512,ExpressionUUID->"c9707812-b8c8-4d4d-a173-024d32e2b4ab"],

Cell[BoxData["1.155722`"], "EchoTiming",
 CellID->97044273,ExpressionUUID->"3b5fd873-20ff-46c3-a367-1c5735ad8488"]
}, Open  ]],

Cell["Check the logarithmic negativity as a function of time:", "ExampleText",
 CellID->495790548,ExpressionUUID->"edd6f12d-0279-4c42-b8e2-5413f9a08461"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", "negRho"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotMarkers", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<\[Gamma]\[VeryThinSpace]\[ThinSpace]t\>\"", 
      ",", "\"\<LN (L, L/2)\>\""}], "}"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
