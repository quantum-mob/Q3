  FontFamily->"Source Sans Pro",ExpressionUUID->
  "65eba62b-3f4b-4f16-8d01-226571fd6257"],
 " with ",
 Cell[BoxData[
  RowBox[{
   StyleBox["msr", "TI"], ":=", 
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["BravyiMeasurement"]], 
      "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "47186a31-0671-4b1a-a785-ffcb111f08a7"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", 
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "4"]}], 
   TraditionalForm]],ExpressionUUID->"0b147c79-e696-478e-8476-33ecfe22df1c"],
 " for each row ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f148b538-6aa0-473f-9df5-0525cf6ac128"],
 " of matrix ",
