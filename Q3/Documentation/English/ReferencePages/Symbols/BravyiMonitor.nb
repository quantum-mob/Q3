Cell["\<\
Calculate the logarithmic negativity of the mixed state (density matrix) by \
taking the convex linear superposition of state in different trajectories:\
\>", "ExampleText",
 CellID->1135458407,ExpressionUUID->"129f3f93-565c-4047-9933-2a0dddd3541f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"BravyiMean", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"BravyiLogarithmicNegativity", "[", 
      RowBox[{"avg", ",", "sub"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "negRho", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->1617529425,ExpressionUUID->"c5a08f63-986b-4745-8437-79ab103f50ee"],

Cell[BoxData["0.29198`"], "EchoTiming",
 CellID->745495427,ExpressionUUID->"58fb05ab-709a-4272-8716-69ce4edaa896"],

Cell[BoxData[
 RowBox[{"{", "201", "}"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->1122044991,ExpressionUUID->"5f42ca38-1094-47bb-85cb-6cd105e43338"]
}, Open  ]],

