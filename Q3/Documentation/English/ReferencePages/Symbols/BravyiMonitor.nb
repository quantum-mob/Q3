Cell["\<\
Let us now verify the above result by solving the corresponding Lindblad \
equation.\
\>", "ExampleText",
 CellID->1078683863,ExpressionUUID->"9762bea3-b13e-4bce-8b80-87f96d241dc1"],

Cell["Solve the quantum master equation:", "ExampleText",
 CellID->147415942,ExpressionUUID->"b8a16e57-bca9-4b13-9999-fcd978ca2743"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$dt", "=", "0.02"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"sol", "=", 
    RowBox[{"BravyiLindbladSolve", "[", 
     RowBox[{"ham", ",", "msr", ",", "in", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "$T", ",", "$dt"}], "}"}], ",", "True"}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "sol", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1571092203,ExpressionUUID->"099bc6c1-ea08-4724-82c2-cccc0e4f8853"],

Cell[BoxData["0.037148`"], "EchoTiming",
 CellID->48064094,ExpressionUUID->"c301b130-f6ef-4571-aeb9-5da954bdcfa3"],

Cell[BoxData[
 RowBox[{"{", "101", "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->359376586,ExpressionUUID->"d9db8745-83a2-4002-8451-ed92758d20fe"]
}, Open  ]],

Cell["Calculate the logarithmic negativity from the solution:", "ExampleText",
 CellID->528108209,ExpressionUUID->"f6917ab7-32b2-4cd5-9183-2841561ee302"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"negSol", "=", 
    RowBox[{"BravyiLogarithmicNegativity", "[", 
     RowBox[{"sol", ",", "sub"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->364755612,ExpressionUUID->"356edfea-c129-48c3-a119-5736966c6cb3"],

Cell[BoxData["0.044626`"], "EchoTiming",
 CellID->500111067,ExpressionUUID->"f899a0af-74d6-4651-8441-468e37d88b3b"]
}, Open  ]],

Cell["Compare the two results:", "ExampleText",
 CellID->26037440,ExpressionUUID->"014c2818-5787-468b-8bff-a944caee9924"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", 
    RowBox[{"{", 
     RowBox[{"negSol", ",", "negRho"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Joined", "->", 
    RowBox[{"{", 
     RowBox[{"True", ",", "False"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
