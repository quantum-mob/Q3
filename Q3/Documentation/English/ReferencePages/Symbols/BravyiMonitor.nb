Cell["\<\
Let us now verify the above result by solving the corresponding Lindblad \
equation.\
\>", "ExampleText",
 CellID->1078683863,ExpressionUUID->"9d3af557-c912-41fe-905c-efc7b06b776c"],

Cell["Solve the quantum master equation:", "ExampleText",
 CellID->147415942,ExpressionUUID->"620d10e5-68e7-4ae7-8f81-a0f5723afe9b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$dt", "=", "0.02"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"sol", "=", 
    RowBox[{"BravyiLindbladSolve", "[", 
     RowBox[{"ham", ",", "msr", ",", "in", ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "$T", ",", "$dt"}], "}"}], ",", "True"}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "sol", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1571092203,ExpressionUUID->"7251c176-c89c-431c-a2c5-eee14bb5c593"],

Cell[BoxData["0.037148`"], "EchoTiming",
 CellID->48064094,ExpressionUUID->"dce4b6e6-8a62-4623-b2f7-fa05559e9df0"],

Cell[BoxData[
 RowBox[{"{", "101", "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->359376586,ExpressionUUID->"2996dc9d-8338-4d76-9a07-b5df8a448168"]
}, Open  ]],

Cell["Calculate the logarithmic negativity from the solution:", "ExampleText",
 CellID->528108209,ExpressionUUID->"78b63aa2-bcd8-42a5-a146-0e0f28c303f8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"negSol", "=", 
    RowBox[{"BravyiLogarithmicNegativity", "[", 
     RowBox[{"sol", ",", "sub"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->364755612,ExpressionUUID->"4bbba82b-69ff-4e68-bde0-0ca34abd303c"],

Cell[BoxData["0.044626`"], "EchoTiming",
 CellID->500111067,ExpressionUUID->"2e9ff0e7-bfb3-4c4e-9a37-8a7af4fa562d"]
}, Open  ]],

Cell["Compare the two results:", "ExampleText",
 CellID->26037440,ExpressionUUID->"fc472668-ef98-40a4-b1be-2e7841452123"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", 
    RowBox[{"{", 
     RowBox[{"negSol", ",", "negRho"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Joined", "->", 
    RowBox[{"{", 
     RowBox[{"True", ",", "False"}], "}"}]}], ",", "\[IndentingNewLine]", 
