Cell[BoxData[{
 RowBox[{
  RowBox[{"cff", "=", 
   RowBox[{
    RowBox[{"One", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], "]"}], "+", 
    RowBox[{"I", "*", 
     RowBox[{"One", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"$n", "-", "1"}], ",", "$n"}], "}"}], ",", "1"}], 
      "]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cff", "=", 
   RowBox[{"ArrayFlatten", "@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"cff", ",", "0"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"0", ",", "cff"}], "}"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmp", "=", 
   RowBox[{"NambuMeasurement", "[", "cff", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"msr", "=", 
  RowBox[{"BravyiMeasurement", "[", 
   RowBox[{"Canonicalize", "@", "tmp"}], "]"}]}]}], "Input",
