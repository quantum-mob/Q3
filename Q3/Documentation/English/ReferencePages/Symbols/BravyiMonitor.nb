Cell[TextData[{
 "In ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMonitor"]], "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["in", "TI"], ",", 
