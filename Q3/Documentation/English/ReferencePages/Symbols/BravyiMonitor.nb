Cell["\<\
Construct approximate density matrices by taking averages of the covariance \
matrices in different trajectories, and calculate the logarithmic negativity \
(LN) between the subsystem and the rest in the \[LineSeparator]density \
matrices:\
\>", "ExampleText",
 CellID->1243375267,ExpressionUUID->"0bc10f90-89f6-4baf-8091-3812eb364d7b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"BravyiMean", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"BravyiLogarithmicNegativity", "[", 
      RowBox[{"avg", ",", "sub"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[4]:=",
 CellID->244743512,ExpressionUUID->"b6d923d7-807a-4bd4-af2c-377c89d8f6ca"],

Cell[BoxData["1.155722`"], "EchoTiming",
 CellID->97044273,ExpressionUUID->"da2597d9-1564-4716-9b8d-882ef97683a7"]
}, Open  ]],

Cell["Check the logarithmic negativity as a function of time:", "ExampleText",
 CellID->495790548,ExpressionUUID->"349e70b4-4c24-47c5-8010-55ee397ad405"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"Re", "@", "negRho"}], ",", "\[IndentingNewLine]", 
   RowBox[{"DataRange", "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "$T"}], "}"}]}], ",", "\[IndentingNewLine]", 
