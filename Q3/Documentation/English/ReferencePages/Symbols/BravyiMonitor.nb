Cell["\<\
Calculate the entanglement entropy (EE) between the subsystem and the rest:\
\>", "ExampleText",
 CellID->1756105721,ExpressionUUID->"f0a7d729-171d-4aeb-a50b-a337fe082139"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"ee", "=", 
    RowBox[{"Mean", "@", 
     RowBox[{"BravyiEntanglementEntropy", "[", 
      RowBox[{"data", ",", "sub"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "ee", "]"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
