Cell[TextData[{
 "Set the model parameters: \[Mu] is the chemical potential, ",
 StyleBox["t",
  FontSlant->"Italic"],
 " is the single-particle hopping amplitude, \[CapitalDelta] is the pairing \
potential, and \[Gamma] is the monitoring rate:"
}], "ExampleText",
 CellID->890113788,ExpressionUUID->"7cff8975-8c5c-493c-b869-cb166cb94388"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Gamma]", "=", "0.2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Mu]", "=", 
   RowBox[{"0.5", "/", "\[Gamma]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"J", "=", 
   RowBox[{"\[CapitalDelta]", "=", 
    RowBox[{"1.", "/", "\[Gamma]"}]}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1977081204,ExpressionUUID->"53fbc084-fd7e-489f-8150-f7e0bc96b713"],

Cell["Construct the BdG Hamiltonian:", "ExampleText",
 CellID->1989785603,ExpressionUUID->"08eb3b0e-6b27-4a92-9bb1-c93d48981a93"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ham", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "\[Mu]"}], "*", 
     RowBox[{"One", "[", "$n", "]"}]}], "-", 
    RowBox[{"J", "*", 
     RowBox[{"PlusTopple", "[", 
      RowBox[{"One", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"$n", ",", "$n"}], "}"}], ",", "1"}], "]"}], "]"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", 
   RowBox[{
    RowBox[{"-", "\[CapitalDelta]"}], "*", 
    RowBox[{"One", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"$n", ",", "$n"}], "}"}], ",", "1"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", 
   RowBox[{"del", "-", 
    RowBox[{"Transpose", "[", "del", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ham", "=", 
  RowBox[{"NambuHermitian", "[", 
   RowBox[{"{", 
    RowBox[{"ham", ",", "del"}], "}"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ham", "//", "ArrayShort"}], "\[IndentingNewLine]", 
 RowBox[{"ham", "=", 
  RowBox[{"BravyiHermitian", "[", "ham", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ham", "//", "ArrayShort"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1333775120,ExpressionUUID->"748c2d58-7cc6-403c-b403-226c64b4dbc8"],

