Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiMonitor"]], 
         "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3d8b33f7-040a-4042-b85c-25999f78f6cd"],
     "\[LineSeparator]solves the problem of continuous monitoring of a \
non-interacting many-fermion system by using the Monte Carlo simulation \
method. The model is specified by the single-particle Hamiltonian ",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "cbf2102e-853d-40ce-a082-15d73d825a03"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiHermitian"]], 
        "paclet:QuantumMob/Q3/ref/BravyiHermitian", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "baae7e18-f3ec-4523-a46c-fe27a906e382"],
     " form, and the dressed fermion modes the occupation numbers of which to \
be monitored are specified by measurement ",
     Cell[BoxData[
      StyleBox["msr", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "37664503-643c-44e1-bccf-3323ae5f9284"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a2f6104b-0616-4db4-aa49-fe805f3f8d54"],
     " form. The simulation starts from the initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1b52668a-b07f-46b9-9a7e-62e8f67e851e"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "2b423c8c-3d16-43bf-aa3b-2a601a37e1de"],
     " form at time 0 and runs to time ",
     Cell[BoxData[
      StyleBox["tau", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "2f3f274c-ef68-4b81-b16f-6f795ddceeee"],
     " in steps of size ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "5a304fd9-49dc-4103-8aec-1f4060cc2afd"],
     "."
    }],ExpressionUUID->"57abe630-2024-4d4a-80ea-1b7c3943f410"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiMonitor"]], 
         "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "ba9c6ad7-71d9-4314-a015-e9ffd414011c"],
     "\[LineSeparator]assumes continuous monitoring of the occupation numbers \
of the bare fermion modes; that is , it is equivalent to ",
     Cell[BoxData[
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           TemplateBox[{
             Cell[
              TextData["BravyiMonitor"]], 
             "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
             "QuantumMob Package Symbol"},
            "PackageLink",
            BaseStyle->"InlineFormula"], "[", 
           RowBox[{
            StyleBox["in", "TI"], ",", 
            StyleBox["ham", "TI"], ",", 
            RowBox[{
             TemplateBox[{
               Cell[
                TextData["BravyiMeasurement"]], 
               "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
               "QuantumMob Package Symbol"},
              "PackageLink",
              BaseStyle->"InlineFormula"], "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", 
                StyleBox["n", "TI"]}], "}"}], ",", 
              StyleBox["n", "TI"]}]}]}]}], "}"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d0decdfd-87bd-487e-8f24-6b5ea743488f"],
     "."
    }],ExpressionUUID->"29c94d3d-4453-4560-ade5-547845b22adc"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiMonitor"]], 
         "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "4a623bba-d222-4ae5-b2f7-6e300031fd5b"],
     " or ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiMonitor"]], 
         "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6715065a-5649-44ab-aafa-f2a8116f71f3"],
     "\[LineSeparator]collects states in steps of ",
     Cell[BoxData[
      RowBox[{
       StyleBox["k", "TI"], "\[Times]", 
       StyleBox["dt", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "772553d5-4364-4dd5-b801-fdaa4c0304d9"],
     " (rather than ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a097e1d2-4e78-41a1-af36-0dd69c968611"],
     "), where ",
     Cell[BoxData[
      StyleBox["k", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "7084bed8-806f-4a18-8ed0-ecdf99ef7e23"],
     " must be an integer or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["All"]], "paclet:ref/All"},
       "RefLink",
       BaseStyle->{"InlineFormula"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "10e9ea11-d212-4227-9209-618a726c527a"],
     "."
    }],ExpressionUUID->"8d1b9f24-d48b-4faa-aff5-7492a9e78f09"]}
  }]], "Usage",
