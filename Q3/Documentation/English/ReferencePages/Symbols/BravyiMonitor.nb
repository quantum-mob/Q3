Cell[TextData[{
 "Set the model parameters: \[Mu] is the chemical potential, ",
 StyleBox["t",
  FontSlant->"Italic"],
 " is the single-particle hopping amplitude, \[CapitalDelta] is the pairing \
potential, and \[Gamma] is the monitoring rate:"
}], "ExampleText",
 CellID->890113788,ExpressionUUID->"8315abe0-a76d-45b1-b196-2d1352441a60"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Gamma]", "=", "0.2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Mu]", "=", 
   RowBox[{"0.5", "/", "\[Gamma]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"J", "=", 
   RowBox[{"\[CapitalDelta]", "=", 
    RowBox[{"1.", "/", "\[Gamma]"}]}]}], ";"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1977081204,ExpressionUUID->"a91caa2c-93fb-4c62-aa43-308fee1ee24f"],

Cell["Construct the BdG Hamiltonian:", "ExampleText",
 CellID->1989785603,ExpressionUUID->"ade90025-218b-4139-91ac-acfe829eebce"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ham", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "\[Mu]"}], "*", 
     RowBox[{"One", "[", "$n", "]"}]}], "-", 
    RowBox[{"J", "*", 
     RowBox[{"PlusTopple", "[", 
      RowBox[{"One", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"$n", ",", "$n"}], "}"}], ",", "1"}], "]"}], "]"}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", 
   RowBox[{
    RowBox[{"-", "\[CapitalDelta]"}], "*", 
    RowBox[{"One", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"$n", ",", "$n"}], "}"}], ",", "1"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", 
   RowBox[{"del", "-", 
    RowBox[{"Transpose", "[", "del", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"ham", "=", 
  RowBox[{"NambuHermitian", "[", 
   RowBox[{"{", 
    RowBox[{"ham", ",", "del"}], "}"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ham", "//", "ArrayShort"}], "\[IndentingNewLine]", 
 RowBox[{"ham", "=", 
  RowBox[{"BravyiHermitian", "[", "ham", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"ham", "//", "ArrayShort"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->1333775120,ExpressionUUID->"9274ccce-30f7-455c-a7ed-2285bf85271d"],

