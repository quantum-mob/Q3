Cell[TextData[{
 "Construct approximate density matrices, and calculate the ",
 ButtonBox["logarithmic negativity",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity"],
 " (LN) between the subsystem and the rest."
}], "ExampleText",
 CellID->1198129299,ExpressionUUID->"89850cf2-bd72-4d7e-a2c6-fd8d7015ca93"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avg", "=", 
     RowBox[{"BravyiMean", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"negRho", "=", 
     RowBox[{"BravyiLogarithmicNegativity", "[", 
      RowBox[{"avg", ",", "sub"}], "]"}]}]}], "\[IndentingNewLine]", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "negRho", "]"}]}], "Input",
