Cell["Construct the single-particle Hamiltonian matrix.", "ExampleText",
 CellID->304832203,ExpressionUUID->"0257e365-0792-4382-941d-549b81d54a80"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"$J", "=", "2"}], ";"}], " ", 
