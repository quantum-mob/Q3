Cell[TextData[{
 "Let us take the Hatano-Nelson model. To check the consistency, it will be \
useful to compare the results from the",
 Cell[BoxData[
  RowBox[{" ", "WickMonitor"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
