Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiMonitor"]], 
         "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "80cb1215-53d6-43ef-a389-3f25f7dd190e"],
     "\[LineSeparator]solves the problem of continuous monitoring of a \
non-interacting many-fermion system by using the Monte Carlo simulation \
method. The model is specified by the single-particle Hamiltonian ",
     Cell[BoxData[
      StyleBox["ham", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "83dea11c-6369-4c32-8f7f-f1911e4f38df"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiHermitian"]], 
        "paclet:QuantumMob/Q3/ref/BravyiHermitian", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "40b262f4-8e0a-42a5-b283-20782e6db264"],
     " form, and the dressed fermion modes the occupation numbers of which to \
be monitored are specified by measurement ",
     Cell[BoxData[
      StyleBox["msr", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d015cf02-cbf0-41d4-a159-5a96718bbfc7"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiMeasurement"]], 
        "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "54b68294-3151-44d9-8f97-acd4b85269b5"],
     " form. The simulation starts from the initial state ",
     Cell[BoxData[
      StyleBox["in", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "b004f1df-5e1b-4bc1-8bcb-24d4b0c7e8e3"],
     " in the ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["BravyiState"]], "paclet:QuantumMob/Q3/ref/BravyiState", 
        "QuantumMob Package Symbol"},
       "PackageLink",
       BaseStyle->"InlineFormula"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e755c63b-a3bf-4c53-b731-77b7d9f20785"],
     " form at time 0 and runs to time ",
     Cell[BoxData[
      StyleBox["tau", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1d5a9330-b843-4bd6-b891-291dcdedf085"],
     " in steps of size ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "0ea16dd4-eede-485b-b7ff-c4c4b2e827bb"],
     "."
    }],ExpressionUUID->"f94bc9b3-d041-4237-9336-eec153afa100"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiMonitor"]], 
         "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "36d9c9b6-6798-4d5d-a7f5-dd6a34e632c8"],
     "\[LineSeparator]assumes continuous monitoring of the occupation numbers \
of the bare fermion modes; that is , it is equivalent to ",
     Cell[BoxData[
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           TemplateBox[{
             Cell[
              TextData["BravyiMonitor"]], 
             "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
             "QuantumMob Package Symbol"},
            "PackageLink",
            BaseStyle->"InlineFormula"], "[", 
           RowBox[{
            StyleBox["in", "TI"], ",", 
            StyleBox["ham", "TI"], ",", 
            RowBox[{
             TemplateBox[{
               Cell[
                TextData["BravyiMeasurement"]], 
               "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
               "QuantumMob Package Symbol"},
              "PackageLink",
              BaseStyle->"InlineFormula"], "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", 
                StyleBox["n", "TI"]}], "}"}], ",", 
              StyleBox["n", "TI"]}]}]}]}], "}"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TI"], ",", 
          StyleBox["dt", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "0013f184-5db3-44b9-8a44-37a3e4536712"],
     "."
    }],ExpressionUUID->"d4618bf0-f54d-4a52-93e1-0d529217b8e0"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiMonitor"]], 
         "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "11a93e7b-ad53-4a39-94b8-0d4631f7ea24"],
     " or ",
     Cell[BoxData[
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["BravyiMonitor"]], 
         "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{
        StyleBox["in", "TI"], ",", 
        StyleBox["ham", "TI"], ",", 
        StyleBox["msr", "TI"], ",", 
        RowBox[{"{", 
         RowBox[{
          StyleBox["\[Tau]", "TR"], ",", 
          StyleBox["dt", "TI"], ",", 
          StyleBox["k", "TI"]}], "}"}]}], "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "942d7b80-0ea1-41f2-96c1-8c261313b56f"],
     "\[LineSeparator]collects states in steps of ",
     Cell[BoxData[
      RowBox[{
       StyleBox["k", "TI"], "\[Times]", 
       StyleBox["dt", "TI"]}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f1b9a9fb-736d-49ad-9451-fb47170ea18c"],
     " (rather than ",
     Cell[BoxData[
      StyleBox["dt", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "2e2da93c-3dbe-4de9-8708-44e83ca389c7"],
     "), where ",
     Cell[BoxData[
      StyleBox["k", "TI"]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f16c88a6-9627-42f3-8f9e-3d10a0c9ad7d"],
     " must be an integer or ",
     Cell[BoxData[
      TemplateBox[{
        Cell[
         TextData["All"]], "paclet:ref/All"},
       "RefLink",
       BaseStyle->{"InlineFormula"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "25fd1b4a-f6d9-4c85-8615-4e18d3faeeda"],
     "."
    }],ExpressionUUID->"47e1c35a-e2db-42a9-ae33-1d2ed5921661"]}
  }]], "Usage",
 CellID->452342775,ExpressionUUID->"30323563-c6ff-400e-8c34-84bde5fd24a6"]
