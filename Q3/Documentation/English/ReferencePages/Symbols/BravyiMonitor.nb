Cell["Construct the single-particle Hamiltonian matrix.", "ExampleText",
 CellID->304832203,ExpressionUUID->"179e0a4f-52b8-4de7-8b60-9503933708b8"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"$J", "=", "2"}], ";"}], " ", 
