Cell["Simulate the model:", "ExampleText",
 CellID->2045784221,ExpressionUUID->"2f371634-500a-4c5f-a7c4-2aea782f8ccd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "370", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->131644593,ExpressionUUID->"21d75e25-7805-467e-863b-e58ea5e4b25b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"BravyiMonitor", "[", 
     RowBox[{"in", ",", "ham", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"$T", "=", "2"}], ",", 
        RowBox[{"$dt", "=", "0.01"}]}], "}"}], ",", 
      RowBox[{"\"\<Samples\>\"", "->", "200"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"data", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->260746012,ExpressionUUID->"9f433270-8ea8-4744-8174-7aaefe933306"],

