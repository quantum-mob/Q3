Cell["Simulate the model:", "ExampleText",
 CellID->2045784221,ExpressionUUID->"5de8f9ca-4e2c-4077-a719-dc80eb02c5cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "370", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->131644593,ExpressionUUID->"ba21b408-bdb7-4f5e-956e-d195afa43291"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
   RowBox[{"data", "=", 
    RowBox[{"BravyiMonitor", "[", 
     RowBox[{"in", ",", "ham", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"$T", "=", "2"}], ",", 
        RowBox[{"$dt", "=", "0.01"}]}], "}"}], ",", 
      RowBox[{"\"\<Samples\>\"", "->", "200"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"data", "//", "Dimensions"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
