Cell["Let us evaluate the QSP polynomial at the Chebyshev points:", \
"ExampleText",
 CellID->789353421,ExpressionUUID->"7fd8c922-e404-4ade-9343-1a49b158ed21"],

Cell[BoxData[
 RowBox[{
  RowBox[{"xx", "=", 
   RowBox[{"ChebyshevPoints", "[", 
    RowBox[{"$n", "->", "$parity"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->210476177,ExpressionUUID->"1563f778-1a53-4e14-94be-592d1ef1b612"],

Cell["With the reduced phase vector, it is reasonably fast:", "ExampleText",
 CellID->1365905885,ExpressionUUID->"4b43d01f-53ba-439f-a0b9-49b7822acb15"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", 
  RowBox[{
   RowBox[{"val", "=", 
    RowBox[{"fun", "[", "xx", "]"}]}], ";"}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->192749570,ExpressionUUID->"e622efce-65d8-4a7f-80b6-a64775351d83"],

Cell[BoxData["2.552696`"], "EchoTiming",
 CellID->174425340,ExpressionUUID->"58d2de8c-980d-450a-bc2c-21c4fae8b54d"]
}, Open  ]],

Cell["With the full phase vector, it takes much longer:", "ExampleText",
 CellID->988870704,ExpressionUUID->"c6629efa-c403-47f9-b3b9-dcc7d421f7e0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", 
  RowBox[{
   RowBox[{"new", "=", 
    RowBox[{"gun", "[", "xx", "]"}]}], ";"}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->482833766,ExpressionUUID->"fc6ad950-2a7b-41a9-b069-595e2480d958"],

Cell[BoxData["7.976981`"], "EchoTiming",
 CellID->1091917207,ExpressionUUID->"89e2bf9f-3b48-4d22-86fc-384cee83545c"]
}, Open  ]],

Cell["Nevertheless, the result must be the same:", "ExampleText",
 CellID->603496782,ExpressionUUID->"2c323c2e-4bd0-4489-a5a6-d6dfec057c34"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DeleteCases", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"val", "-", "new"}], "//", "Chop"}], ",", "0"}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->857850345,ExpressionUUID->"1e191b6d-8d27-4c1d-a326-47bc12d9cb9c"],

Cell[BoxData[
 RowBox[{"{", "}"}]], "Output",
 CellLabel->"Out[8]=",
 CellID->2115701346,ExpressionUUID->"8b4a42a4-e975-4bb7-b847-705b37ef71f7"]
}, Open  ]]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "ExampleSection", "3"}, 
  Closed]]]]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "PrimaryExamplesSection"}, 
  Closed]]]],

