      StyleBox["\[Phi]", "TR"], 
      StyleBox["j", "TI"]]}], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3c4e5e07-2205-4c8c-9ecb-fb64840ae118"],
 "."
}], "Notes",
 CellID->1931150725,ExpressionUUID->"c116c848-03f7-4546-be35-2b03826a595a"],

