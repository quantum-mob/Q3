Cell["Construct a QSP with the reduced phase vector:", "ExampleText",
 CellID->263062639,ExpressionUUID->"6409aadb-c5b1-4b51-ac94-0e0b408d06dc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"$phi", "=", 
    RowBox[{"RandomReal", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "1"}], "}"}], "*", 
       RowBox[{"Pi", "/", "2"}]}], ",", "$n"}], "]"}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"reduced", " ", "phase", " ", "vector"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"$post", "=", 
  RowBox[{"RandomChoice", "[", 
   RowBox[{"{", 
    RowBox[{"Re", ",", "Im"}], "}"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"fun", "=", 
  RowBox[{"QSP", "[", 
   RowBox[{
    RowBox[{"$phi", "->", "$parity"}], ",", "$post"}], "]"}]}]}], "Input",
