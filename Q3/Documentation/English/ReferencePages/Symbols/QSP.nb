      StyleBox["\[Phi]", "TI"], 
      StyleBox["i", "TI"]]}], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "027e7083-53f6-4cd1-88b1-613a9f8442f8"],
