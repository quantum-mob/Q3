     SubscriptBox[
      StyleBox["\[Phi]", "TR"], 
      StyleBox["j", "TI"]]}], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5259b415-c745-4816-aad8-046c5f6b643b"],
 "."
}], "Notes",
