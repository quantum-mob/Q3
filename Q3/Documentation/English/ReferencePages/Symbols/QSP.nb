Cell["Let us evaluate the QSP polynomial at the Chebyshev points:", \
"ExampleText",
 CellID->789353421,ExpressionUUID->"878cd22e-56c3-4f29-bdbc-04820168b6e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"xx", "=", 
   RowBox[{"ChebyshevPoints", "[", 
    RowBox[{"$n", "->", "$parity"}], "]"}]}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[5]:=",
 CellID->210476177,ExpressionUUID->"47c72a0c-225b-4896-a6a7-f952f2f5afd6"],

Cell["With the reduced phase vector, it is reasonably fast:", "ExampleText",
 CellID->1365905885,ExpressionUUID->"6e78b7cc-ab00-4043-8bcf-83c2afe8bf9c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", 
  RowBox[{
   RowBox[{"val", "=", 
    RowBox[{"fun", "[", "xx", "]"}]}], ";"}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[6]:=",
 CellID->192749570,ExpressionUUID->"ab66a466-2ecd-4a4b-ae4f-85e3a9744fcc"],

Cell[BoxData["2.552696`"], "EchoTiming",
 CellID->174425340,ExpressionUUID->"1dcc6ef2-0001-4d1b-8c82-3a51f2d8d1a5"]
}, Open  ]],

Cell["With the full phase vector, it takes much longer:", "ExampleText",
 CellID->988870704,ExpressionUUID->"32b903a7-bf5e-4e78-8b52-24628ebe10c8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", 
  RowBox[{
   RowBox[{"new", "=", 
    RowBox[{"gun", "[", "xx", "]"}]}], ";"}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[7]:=",
 CellID->482833766,ExpressionUUID->"0e6bf47b-c6bf-4835-9852-5ccf90ce614c"],

Cell[BoxData["7.976981`"], "EchoTiming",
 CellID->1091917207,ExpressionUUID->"a19c9232-e7db-4d81-8bc5-958012920da1"]
}, Open  ]],

Cell["Nevertheless, the result must be the same:", "ExampleText",
 CellID->603496782,ExpressionUUID->"cca46c5f-a91e-406b-b1fa-43638d34995a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DeleteCases", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"val", "-", "new"}], "//", "Chop"}], ",", "0"}], "]"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
 CellID->857850345,ExpressionUUID->"dd9a8216-7e19-4b2c-b7b9-6326ce7e0eaf"],

Cell[BoxData[
 RowBox[{"{", "}"}]], "Output",
 CellLabel->"Out[8]=",
 CellID->2115701346,ExpressionUUID->"e209930a-2de6-41b4-a1b3-3d73f0f2e0a9"]
}, Open  ]]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "ExampleSection", "3"}, 
  Closed]]]]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "PrimaryExamplesSection"}, 
