Cell[TextData[{
 "The computational cost of quantum Schur transform (the transformation from \
the tensor-product basis to the Schur basis) is high. If one has to construct \
Schur bases for several different ",
 Cell[BoxData[
  StyleBox["n", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3baac4ec-a946-41e9-994d-938d0b1b45aa"],
 "s, then it is far more efficient to use the last form, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["SchurBasis"]], "paclet:QuantumMob/Q3/ref/SchurBasis", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["bs", "TI"], ",", " ", 
    StyleBox["spec", "TI"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2599b77d-bd9e-4a71-a5ec-c5824f63e1ef"],
 ", and save the resulting bases."
}], "Notes",
 CellID->435196750,ExpressionUUID->"7982804b-6c1c-4130-bae9-9a577413fddc"],

Cell[TextData[{
 "Each element of Schur basis gives the explicit expression of basis state ",
 Cell[BoxData[
  TemplateBox[{
    RowBox[{
      SubscriptBox[
       RowBox[{"(", "\[NoBreak]", 
         GridBox[{{"\[Lambda]"}, {
            SubscriptBox[
             StyleBox["y", FontSlant -> "Italic"], "\[Lambda]"]}}], 
         "\[NoBreak]", ")"}], 
       StyleBox["n", FontSlant -> "Italic"]], ",", 
      SubscriptBox[
       RowBox[{"(", "\[NoBreak]", 
         GridBox[{{"\[Lambda]"}, {
            SubscriptBox[
             StyleBox["w", FontSlant -> "Italic"], "\[Lambda]"]}}], 
         "\[NoBreak]", ")"}], 
       StyleBox["d", FontSlant -> "Italic"]]}]},
   "Ket"]],ExpressionUUID->"5fb50988-9049-40f9-9e32-f83cc1ab8329"],
 "\nlabelled by two Gelfand patterns ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"\[Lambda]"},
      {
       SubscriptBox[
        StyleBox["y",
         FontSlant->"Italic"], "\[Lambda]"]}
     }], "\[NoBreak]", ")"}], 
   StyleBox["n",
    FontSlant->"Italic"]]],ExpressionUUID->
  "9fb4413a-07ca-43ca-a7b7-213564d16f04"],
 " and ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"\[Lambda]"},
      {
       SubscriptBox[
        StyleBox["w",
         FontSlant->"Italic"], "\[Lambda]"]}
     }], "\[NoBreak]", ")"}], 
   StyleBox["d",
    FontSlant->"Italic"]]],ExpressionUUID->
  "600a836c-50b7-4229-b84b-1b38d4c5024c"],
 "."
}], "Notes",
 CellID->1220631744,ExpressionUUID->"48b9229f-04b0-4414-b541-3bd0ec66abdf"],

Cell[TextData[{
 "Gelfand pattern ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"\[Lambda]"},
      {
       SubscriptBox[
        StyleBox["y",
         FontSlant->"Italic"], "\[Lambda]"]}
     }], "\[NoBreak]", ")"}], 
   StyleBox["n",
    FontSlant->"Italic"]]],ExpressionUUID->
  "3531a290-28a8-4cca-87d4-b426db79a97d"],
 " of order ",
 StyleBox["n",
  FontSlant->"Italic"],
 " corresponds to a standard Young tableau of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " letters while Gelfand pattern ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"\[Lambda]"},
      {
       SubscriptBox[
        StyleBox["w",
         FontSlant->"Italic"], "\[Lambda]"]}
     }], "\[NoBreak]", ")"}], 
   StyleBox["d",
    FontSlant->"Italic"]]],ExpressionUUID->
  "34039925-050f-492c-b99c-08b8eaea5f4c"],
 " of order ",
 StyleBox["d",
  FontSlant->"Italic"],
 " corresponds to a Weyl tableau of ",
 StyleBox["d",
  FontSlant->"Italic"],
 " letters. In Gelfand pattern ",
 Cell[BoxData[
  SubscriptBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"\[Lambda]"},
      {
       SubscriptBox[
        StyleBox["y",
         FontSlant->"Italic"], "\[Lambda]"]}
     }], "\[NoBreak]", ")"}], 
   StyleBox["n",
    FontSlant->"Italic"]]],ExpressionUUID->
  "296a36a9-9380-420b-b452-adc6ec3ddbc5"],
 ", it should be understood that the top row \[Lambda] is padded by zeros to \
have total length ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["y", "1"], ",", 
      SubscriptBox["y", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["y", "d"], ",", "0", ",", "\[Ellipsis]", ",", "0"}], 
     ")"}]}], TraditionalForm]],ExpressionUUID->
  "7fbb478d-f947-4c73-85b5-abbc82e2967d"],
 ", when ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[LessEqual]", "n"}], TraditionalForm]],ExpressionUUID->
  "22df792a-ae4a-4d09-9472-8941d1b6503c"],
 "."
}], "Notes",
 CellID->440727526,ExpressionUUID->"2846c985-d981-4fb6-8850-123f103d4300"],

Cell[TextData[{
 "Under a group element ",
 StyleBox["S",
  FontSlant->"Italic"],
 " of symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "0b577407-ff6d-488f-9b4d-25bab3f418b0"],
 ", the basis elements transform as \t\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["\[CapitalPi]", "^"], "(", "S", ")"}], 
     TemplateBox[{
       RowBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "   "}]}, {
                RowBox[{"(", 
                  SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
          TraditionalForm], ",", 
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "x"], 
     TemplateBox[{
       RowBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "   "}]}, {
                RowBox[{"(", 
                  SubscriptBox["x", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
          TraditionalForm], ",", 
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalPi]", 
       StyleBox["xy",
        FontSlant->"Italic"], "\[Lambda]"], "(", "S", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"9f25b46f-e44d-4ee0-93ac-da16909a9b69"],
 " ,\[LineSeparator] where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalPi]", 
     StyleBox["xy",
      FontSlant->"Italic"], "\[Lambda]"], "(", "S", ")"}], TraditionalForm]],
  ExpressionUUID->"fff104a9-5e0f-42c3-b58f-37dfd9761eff"],
 " is the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[VeryThinSpace]", 
    SuperscriptBox["y", "th"]}], TraditionalForm]],ExpressionUUID->
  "7218a74f-4463-4666-8f96-fe329953e3ce"],
 "matrix element of the irreducible representation \[Lambda] of ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "27fdd1c0-0792-4f52-a14d-310474c390fc"],
 ". This means that a group element ",
 StyleBox["S",
  FontSlant->"Italic"],
 " is represented by a matrix of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[CapitalPi]", "^"], "(", "S", ")"}], "\[DotEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Lambda]"], " ", 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[CapitalPi]", 
        RowBox[{
         SubscriptBox["N", "Y"], "\[Times]", 
         SubscriptBox["N", "Y"]}], "\[Lambda]"], "(", "S", ")"}], "\[CircleTimes]", 
      SubsuperscriptBox["I", 
       SubscriptBox["N", "W"], "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"42471ff3-e300-4d92-816a-52ebe81a7667"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["N", "Y", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "7cec2a9b-11ae-4a2f-8a58-02e3b93d3699"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["N", "W", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "a870a9d6-46dd-410b-9601-d3ae3b57f094"],
 " are the number of standard Young tableaux and Weyl tableaux, respectively, \
for shape \[Lambda] (in the above equation, superscript \[Lambda] has been \
omitted as it is clear from context). If an operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "025592da-144f-4747-9966-84112e528e06"],
 " is invariant under the symmetric group, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      OverscriptBox["H", "^"], ",", 
      RowBox[{
       OverscriptBox["\[CapitalPi]", "^"], "(", "S", ")"}]}], "]"}], "=", 
    "0"}], TraditionalForm]],ExpressionUUID->
  "8809de8c-467a-4c2a-b2f1-5462313b1ee0"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Element]", 
    SubscriptBox["\[ScriptCapitalS]", "n"]}], TraditionalForm]],
  ExpressionUUID->"6161f6ca-080e-408e-9be3-94c2f7887421"],
 ", then the matrix representation of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "ba67dd3d-211d-45b3-ac55-f75a54d425a7"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "\[DotEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Lambda]"], " ", 
     RowBox[{
      SubsuperscriptBox["I", 
       SubscriptBox["N", "Y"], "\[Lambda]"], "\[CircleTimes]", 
      SubsuperscriptBox["H", 
       RowBox[{
        SubscriptBox["N", "W"], "\[Times]", 
        SubscriptBox["N", "W"]}], "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"1741793a-51a9-4c16-9a9e-c637d4f48a77"],
 " ."
}], "Notes",
 CellID->213589296,ExpressionUUID->"0555585c-9f71-4a80-ace3-0fb6a10cdfb9"],

Cell[TextData[{
 "Under a group element ",
 StyleBox["U",
  FontSlant->"Italic"],
 " of symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalU]", "d"], TraditionalForm]],ExpressionUUID->
  "6c80f835-917b-455d-a305-9465712aa586"],
 ", the basis elements transform as \n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["\[CapitalOmega]", "^"], "(", "U", ")"}], 
     TemplateBox[{
       RowBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "   "}]}, {
                RowBox[{"(", 
                  SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
          TraditionalForm], ",", 
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "v"], 
     TemplateBox[{
       RowBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "   "}]}, {
                RowBox[{"(", 
                  SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
          TraditionalForm], ",", 
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["v", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalOmega]", 
       StyleBox["vw",
        FontSlant->"Italic"], "\[Lambda]"], "(", "U", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"36f71186-4749-4cbb-8d3e-6fa062848ec7"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalOmega]", 
     StyleBox["vw",
      FontSlant->"Italic"], "\[Lambda]"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"a66f78b5-d11a-4ead-a4b8-0dc990bbbe28"],
 " is the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[VeryThinSpace]", 
    SuperscriptBox["w", "th"]}], TraditionalForm]],ExpressionUUID->
  "bc39bcaa-60d7-4da0-a067-6d8d847455a2"],
 " matrix element of the irreducible representation \[Lambda] of the group \
element ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "90646421-92fa-4fc9-a314-fa33b28f4530"],
 ". This means that a group element ",
 StyleBox["U",
  FontSlant->"Italic"],
 " is represented for the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[CapitalOmega]", "^"], "(", "U", ")"}], "\[DotEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Lambda]"], " ", 
     RowBox[{
      SubsuperscriptBox["I", 
       SubscriptBox["N", "Y"], "\[Lambda]"], "\[CircleTimes]", 
      RowBox[{
       SubsuperscriptBox["\[CapitalOmega]", 
        RowBox[{
         SubscriptBox["N", "W"], "\[Times]", 
         SubscriptBox["N", "W"]}], "\[Lambda]"], "(", "U", ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"afa89052-a204-4d22-913c-96f5ee11ecfd"],
 " ,\[LineSeparator]where, again, ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["N", "Y", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "f0e1e6af-3fed-4b75-b015-a919138da099"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["N", "W", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "a187f3fc-398b-4c66-999f-bba6f87dde7d"],
 " are the number of standard Young tableaux and Weyl tableaux, respectively, \
for shape \[Lambda] (in the above equation, superscript \[Lambda] has been \
omitted). If an operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "faf73b12-7ff0-4eb2-abd5-68cf80a70236"],
 " is invariant under the unitary group, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      OverscriptBox["H", "^"], ",", 
      RowBox[{
       OverscriptBox["\[CapitalOmega]", "^"], "(", "U", ")"}]}], "]"}], "=", 
    "0"}], TraditionalForm]],ExpressionUUID->
  "9d56696b-7048-46ec-8280-47677fc8135d"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "\[Element]", 
    SubscriptBox["\[ScriptCapitalU]", "d"]}], TraditionalForm]],
  ExpressionUUID->"fad83e6b-3fec-4695-9d93-8b916664fe8f"],
 ", then the matrix representation of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "a422b41e-a127-4fb7-a554-76c9c3c9f05f"],
 " is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "\[DotEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Lambda]"], " ", 
     RowBox[{
      SubsuperscriptBox["H", 
       RowBox[{
        SubscriptBox["N", "W"], "\[Times]", 
        SubscriptBox["N", "W"]}], "\[Lambda]"], "\[CircleTimes]", 
      SubsuperscriptBox["I", 
       SubscriptBox["N", "Y"], "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"5cb47205-a9bd-4841-a95d-02c586462ab4"],
 " ."
}], "Notes",
