Cell["\<\
Here, we consider a system of \[CapitalLambda]-atoms (atoms with \
\[CapitalLambda]-type level structure) interacting with each other and driven \
by a laser. The two ground-state levels in each atom are denoted respectively \
by Ket[0] and Ket[1], and the excited-state level is denoted by Ket[2]. The \
atoms (effectively) interact with each other through which one atom makes a \
transition from Ket[0] to Ket[2] while the other makes a transition from \
Ket[2] to Ket[0]. An external laser drives the transition of atoms from \
Ket[1] to Ket[2]. The resulting Rabi transition amplitude is denoted by \
\[CapitalOmega].\
\>", "ExampleText",
 CellID->1325606527,ExpressionUUID->"7bad8c87-294b-4f0e-b51a-a2aa4e9ef57e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Let", "[", 
   RowBox[{"Qudit", ",", "A", ",", 
    RowBox[{"Dimension", "->", "3"}]}], "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"\[CapitalLambda]", "-", "atoms"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Let", "[", 
   RowBox[{"Complex", ",", "\[CapitalOmega]"}], "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Rabi", " ", "transition", " ", "amplitude"}], " ", 
   "*)"}]}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->1319161242,ExpressionUUID->"c691ec6c-592b-493a-b984-45a60309b2f0"],

