Cell[TextData[{
 "The implications of the permutation symmetry in the system may be seen in \
another way by grouping the elements of the Schur basis by the ",
 StyleBox["standard Young tableaux",
  FontSlant->"Italic"],
 "."
}], "ExampleText",
 CellID->635409493,ExpressionUUID->"ac6b790a-1a4f-435c-b70f-3f0b27de9f1b"],

