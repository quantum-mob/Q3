Cell[TextData[{
 "The invariance of the Hamiltonian under permutations is reflected in the \
block identity matrices in the Schur basis that is grouped by the ",
 StyleBox["Weyl tableaux",
  FontSlant->"Italic"],
 " (i.e., ",
 StyleBox["semi-standard Young tableaux",
  FontSlant->"Italic"],
 "). This follows from Schur's lemma."
}], "ExampleText",
 CellID->2098077224,ExpressionUUID->"255798b1-ec01-4459-862b-f795fdc90ad2"],

