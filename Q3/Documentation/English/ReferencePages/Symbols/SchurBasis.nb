Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"bmat", "=", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Outer", "[", 
        RowBox[{"Multiply", ",", 
         RowBox[{"Dagger", "@", 
          RowBox[{"db", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], ",", 
         RowBox[{"HH", "**", 
          RowBox[{"db", "[", 
           RowBox[{"[", "j", "]"}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "@", "db"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", 
         RowBox[{"Length", "@", "db"}]}], "}"}]}], "]"}], "//", 
     "Simplify"}]}], ";"}], "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Map", "[", 
   RowBox[{"MatrixForm", ",", "bmat", ",", 
    RowBox[{"{", "2", "}"}]}], "]"}], "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[8]:=",
