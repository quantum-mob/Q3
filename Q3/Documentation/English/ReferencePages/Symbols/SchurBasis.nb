Cell["\<\
Due to the permutation symmetry of the Hamiltonian, the Schur basis \
block-diagonalizes the Hamiltonian.\
\>", "ExampleText",
 CellID->156557182,ExpressionUUID->"986ba47f-a840-4e6e-a87b-c0611033863f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"EchoTiming", "[", 
  RowBox[{
   RowBox[{"bmat", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Outer", "[", 
       RowBox[{
        RowBox[{"Simplify", "@*", "Multiply"}], ",", 
        RowBox[{"Dagger", "@", 
         RowBox[{"bb", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], ",", 
        RowBox[{"HH", "**", 
         RowBox[{"bb", "[", 
          RowBox[{"[", "j", "]"}], "]"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "@", "bb"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", 
        RowBox[{"Length", "@", "bb"}]}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Map", "[", 
   RowBox[{"MatrixForm", ",", "bmat", ",", 
    RowBox[{"{", "2", "}"}]}], "]"}], "//", "MatrixForm"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[10]:=",
