Cell[TextData[{
 "The term ",
 StyleBox["Clifford group",
  FontSlant->"Italic"],
 " was introduced by Daniel Gottesman (1998) in his stabilizer formulation of \
quantum error-correction codes."
}], "Notes",
 CellID->1067943069,ExpressionUUID->"754f5208-b052-42ff-b58c-86d13d4d9156"],

Cell[TextData[{
 "The full Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["C", "~"], "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"af752fe2-121b-4710-a2b0-c115361cb203"],
 " is the normalizer of the full Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"66e551d0-38e9-4fb9-9c39-8068881372f9"],
 ", that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{"U", ":", 
      RowBox[{
       RowBox[{"U", " ", "P", " ", 
        SuperscriptBox["U", "\[Dagger]"]}], "\[Element]", 
       RowBox[{
        RowBox[{
         OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "  ", 
        "for", " ", "all", " ", "P"}], "\[Element]", 
       RowBox[{
        OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}]}]}], "}"}]}],
    TraditionalForm]],ExpressionUUID->
  "9e35c5d3-0c9c-429b-acf7-55b6437bc170"],
 "."
}], "Notes",
 CellID->1836205616,ExpressionUUID->"3f75597f-8f35-4778-8d2d-20cf6fa0c022"],

Cell[TextData[{
 StyleBox["Gottesman Theorem",
  FontWeight->"Bold"],
 ": The (full) Clifford group is generated by the Hadamard gates and the \
quadrant phase gates on individual qubits and the CNOT (CZ) gates on pairs of \
qubits."
}], "Notes",
 CellID->1029202184,ExpressionUUID->"81b3548a-c365-4a9a-9abf-b9468bc47c3c"],

Cell[TextData[{
 "The Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"cdb75b80-8191-41f6-a770-3eed25df248a"],
 " is a quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], ":=", 
    RowBox[{
     RowBox[{
      OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"8a3f1c9d-9708-409f-a54e-4466242bb3e3"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["C", "~"], "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"717945ab-7c9c-4e11-baec-732596c94e85"],
 " is the full Clifford group and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalZ]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"i", " ", "m", " ", 
          RowBox[{"\[Pi]", "/", "4"}]}]], ":", "m"}], "=", "0"}], ",", "1", ",",
       "2", ",", "\[Ellipsis]", ",", "7"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"a5d9caa6-e407-443e-b34e-e91c47dc1464"],
 ". That is, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["CliffordGroup"]], "paclet:QuantumMob/Q3/ref/CliffordGroup", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["n", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8aa7a1a3-ac6c-4421-aef2-54a1a0ce5bc9"],
 " is a quotient group ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["FullCliffordGroup"]], 
      "paclet:QuantumMob/Q3/ref/FullCliffordGroup", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"], "[", 
    StyleBox["n", "TI"], "]"}], "/", 
   FormBox[
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "m", "\[VeryThinSpace]", 
          RowBox[{
          "\[Pi]", "\[VeryThinSpace]", "/", "\[VeryThinSpace]", "4"}]}]], ":",
         "m"}], "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      "7"}], "}"}],
    TraditionalForm]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e2b295df-d3c8-4ddd-b3a8-7c490bd84013"],
 "."
}], "Notes",
 CellID->1413575425,ExpressionUUID->"673f2952-dd6d-4b20-9ac9-67280100d8af"],

Cell[TextData[{
 "The Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"f1d94f1a-8e6d-4c4b-8884-b1699923c423"],
 " is equivalent to the ",
 ButtonBox["binary symplectic group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BinarySymplecticGroup"],
 ", alias ",
 ButtonBox["Gottesman group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalG]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"9586668c-5476-4313-9767-acf0671a749f"],
 ", up to the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"0b78c969-e3a4-4354-8ea6-ea2094c14933"],
 "; ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}], "\[TildeEqual]", 
    RowBox[{"\[ScriptCapitalG]", "(", "n", ")"}], "\[Congruent]", 
    RowBox[{"Sp", "(", 
     RowBox[{
      RowBox[{"2", "n"}], ",", 
      SubscriptBox["\[DoubleStruckCapitalZ]", "2"]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"d46efd5b-84a5-4f11-a9a6-ccda76139ccb"],
 "."
}], "Notes",
 CellID->1023764637,ExpressionUUID->"b0620198-519d-45cb-ae6d-1d21b32bc59c"],

Cell[TextData[{
 "The order of the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "27cbdc15-507d-4511-a72c-098127a3d119"],
 "-qubit full Clifford group is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", 
     RowBox[{
      SuperscriptBox["n", "2"], "+", 
      RowBox[{"2", "n"}], "+", "3"}]], 
    RowBox[{
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "n"], "(", 
     RowBox[{
      SuperscriptBox["4", "k"], "-", "1"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"a8e3722b-c409-4df5-b3b1-d8dbfcc5c83b"],
 "."
}], "Notes",
 CellID->1790747771,ExpressionUUID->"3b406468-ac67-4055-a1d6-4eb04b050794"]
}, Dynamic[CurrentValue[
