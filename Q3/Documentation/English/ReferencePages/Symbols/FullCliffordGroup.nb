  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e3df55ac-480f-48ec-8f51-392695fb64f2"],
 " is a quotient group ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    TemplateBox[{
      Cell[
       TextData["FullCliffordGroup"]], 
