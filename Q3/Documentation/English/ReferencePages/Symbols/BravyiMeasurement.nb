Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMeasurement"]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["mat", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9be5540a-5467-4d9b-82e1-a28f0b648806"],
 " handles the individual dressed ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " modes associated with different rows of matrix ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1eefdc3f-ee5e-4e2e-b7fa-ebde885b3009"],
 " separately. It does ",
 StyleBox["not",
  FontSlant->"Italic"],
 " require different dressed modes to be orthogonal to each other. \
Nevertheless, each row ",
 Cell[BoxData[
  StyleBox["v", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6304d364-4b22-44e8-b9b7-eb80a49c3fe3"],
 " must satisfy the condition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
    "\[LeftDoubleBracketingBar]", "x", "\[RightDoubleBracketingBar]"}], "=", 
    RowBox[{
    "\[LeftDoubleBracketingBar]", "y", "\[RightDoubleBracketingBar]"}]}], 
   TraditionalForm]],ExpressionUUID->"2b7a12d3-4045-4c65-9064-69ee11b8874d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "\[CenterDot]", "y"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"64a8d834-f288-4371-8ae6-236405f8a258"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ":=", 
    RowBox[{"Re", "[", "v", "]"}]}], TraditionalForm]],ExpressionUUID->
  "12993593-83cb-45fd-b0b9-f127b280c014"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", ":=", 
    RowBox[{"Im", "[", "v", "]"}]}], TraditionalForm]],ExpressionUUID->
  "eccff9cc-4686-4bca-bb06-d51e61e986c2"],
 ", to construct a proper dressed ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " mode ",
 Cell[BoxData[
  RowBox[{
   StyleBox["b", "TI"], ":=", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalSigma]", "TR"], 
     StyleBox["j", "TI"]], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["v", "TI"], 
     StyleBox["j", "TI"]], "\[ThinSpace]", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["j", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7b650628-d48d-4b30-b1ea-e37fec9107c7"],
 " consisting of bare ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " modes ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["c", "TI"], 
   StyleBox["j", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6a093423-05ab-43fa-8922-a5a18996c2da"],
 " and satisfy the fundamental anti-commutation relations; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", 
      SuperscriptBox["b", "\[Dagger]"]}], "}"}], "=", 
    RowBox[{
     RowBox[{"2", 
      SuperscriptBox[
       RowBox[{
       "\[LeftDoubleBracketingBar]", "v", "\[RightDoubleBracketingBar]"}], 
       "2"]}], "=", 
     RowBox[{
      RowBox[{"4", 
       SuperscriptBox[
        RowBox[{
        "\[LeftDoubleBracketingBar]", "x", "\[RightDoubleBracketingBar]"}], 
        "2"]}], "=", 
      RowBox[{"4", 
       SuperscriptBox[
        RowBox[{
        "\[LeftDoubleBracketingBar]", "y", "\[RightDoubleBracketingBar]"}], 
        "2"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "a17815e3-f157-4214-b59c-eb25c914eb7b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"b", ",", "b"}], "}"}], "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox["b", "\[Dagger]"], ",", 
       SuperscriptBox["b", "\[Dagger]"]}], "}"}], "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"d6714d62-a4a0-406c-ae47-ef0f64cd9503"],
 "."
}], "Notes",
 CellID->457815461,ExpressionUUID->"ff07ea1a-9830-4d5e-a7e6-30858a056d4a"],

Cell[TextData[{
 "More restricted case requires that all dressed ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " modes be orthogonal to each other satisfying the canonical \
anti-commutation relations: Suppose that matrix ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "95f8c32a-5310-4d22-b528-33d23674921a"],
 ", which is in the block form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", ":=", 
    RowBox[{"(", GridBox[{
       {"u", "v"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "7825835a-562f-4d91-900a-47a806522218"],
 ", describes a sequence of ",
 StyleBox["mutually orthogonal",
  FontSlant->"Italic"],
 " dressed Dirac fermion modes\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "i"], ":=", 
    RowBox[{
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"j", "=", "1"}], "n"], 
      SubscriptBox["u", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
      SubscriptBox["a", "j"]}], "+", 
     RowBox[{
      SubscriptBox["v", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"fec1e48b-b2eb-4b1c-94c5-c97786f9ec27"],
 ". \[LineSeparator]Note that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["b", "k"], TraditionalForm]],ExpressionUUID->
  "bc935bcd-ca88-46cc-97d8-b0307c7238ce"],
 " form a orthogonal set of ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " modes only when \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"u", "\[VeryThinSpace]", 
      SuperscriptBox["u", "\[Dagger]"]}], "+", 
     RowBox[{"v", "\[VeryThinSpace]", 
      SuperscriptBox["v", "\[Dagger]"]}]}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"1cae5833-f05e-4e83-9a11-b1145ee250ce"],
 "   and   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"u", "\[VeryThinSpace]", 
      SuperscriptBox["v", "T"]}], "+", 
     RowBox[{"v", "\[VeryThinSpace]", 
      SuperscriptBox["u", "T"]}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"d5e9281b-161b-49a3-b40a-8a23c0aa4066"],
 ". \[LineSeparator]If the ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "302bdf9f-f007-446c-843f-acea34514bb6"],
 " are expressed in terms of ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     RowBox[{"2", "k"}], "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "00241fd3-ff4e-47d4-a8e4-4c124994f6bf"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{"2", "k"}]], TraditionalForm]],ExpressionUUID->
  "9faaa300-808c-48e2-8640-d5f882292614"],
 ", then the dressed modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["b", "k"], TraditionalForm]],ExpressionUUID->
  "eb523f05-fc30-4c95-a996-1be5447a103f"],
 " read as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], "[", 
     RowBox[{
      RowBox[{
       SubscriptBox[
        RowBox[{"(", 
         RowBox[{"Re", "\[VeryThinSpace]", "m"}], ")"}], 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["c", "j"]}], "+", 
      RowBox[{
       SubscriptBox[
        RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "(", 
         RowBox[{"Im", "\[VeryThinSpace]", "m"}], ")"}], 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["c", "j"]}]}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "52351fa0-96be-455d-8c18-face4b09aac8"],
 " .\[LineSeparator]This defines dressed ",
 StyleBox[ButtonBox["Majorana fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MajoranaFermions"],
  FontSlant->"Italic"],
 " modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", 
    RowBox[{
     RowBox[{"2", "i"}], "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "613d2929-720b-4c77-9ce8-201b1dc71667"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", 
    RowBox[{"2", "i"}]], TraditionalForm]],ExpressionUUID->
  "233a6dd3-a399-428d-b64b-8c0291f057db"],
 " by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", 
     RowBox[{
      RowBox[{"2", "i"}], "-", "1"}]], ":=", 
    RowBox[{
     SubscriptBox[
      RowBox[{
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"j", "=", "1"}], 
        RowBox[{"2", "n"}]], "(", 
       RowBox[{"Re", "\[VeryThinSpace]", "m"}], ")"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "2957a21b-b90f-425d-a6d2-ce051c016064"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", 
     RowBox[{"2", "i"}]], ":=", 
    RowBox[{
     SubscriptBox[
      RowBox[{
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"j", "=", "1"}], 
        RowBox[{"2", "n"}]], "(", 
       RowBox[{"Im", "\[VeryThinSpace]", "m"}], ")"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "dd38e903-3ca4-4362-b273-984b05df6377"],
 " .\[LineSeparator]Furthermore, the previous conditions are equivalent to \
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"w", "\[VeryThinSpace]", 
     SuperscriptBox["w", "T"]}], "=", "I"}], TraditionalForm]],ExpressionUUID->
  "38e489cd-84c4-4674-8c95-c3f5ede70e1b"],
 "    with    ",
 Cell[BoxData[
  FormBox[
   RowBox[{"w", ":=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{"Re", "\[VeryThinSpace]", "m"}]},
       {
        RowBox[{"Im", "\[VeryThinSpace]", "m"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6110bf2a-9727-402e-9c42-686fbfae9b76"],
 " ."
}], "Notes",
 CellID->1847349677,ExpressionUUID->"042e2b15-5e14-40f6-9607-b01019d87051"],

Cell[TextData[{
 "The dressed ",
 StyleBox[ButtonBox["Dirac fermion",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fermion"],
  FontSlant->"Italic"],
 " modes associated with ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMeasurement"]], 
     "paclet:QuantumMob/Q3/ref/BravyiMeasurement", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   StyleBox["m", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3b785d7f-f72e-4b5e-85b7-be5596cfab11"],
 " for a matrix ",
 Cell[BoxData[
  StyleBox["m", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "41647daa-3e17-4e9f-b90d-6d7a83ab7b94"],
 " may be ",
 StyleBox["unnormalized",
  FontSlant->"Italic"],
 ". That is, the dressed Dirac fermion modes ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["i", "TI"]], ":=", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalSigma]", "TR"], 
     StyleBox["j", "TI"]], "\[VeryThinSpace]", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["ij", "TI"]], "\[VeryThinSpace]", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["j", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f607aeec-d071-4f80-8c40-81121b4412d5"],
 " may have additional factor ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["f", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b42df676-31cc-4a47-a4f2-5a4d92cdcf70"],
 " in the anti-commutation relations, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["b", "TI"], 
      StyleBox["i", "TI"]], ",", 
     SubsuperscriptBox[
      StyleBox["b", "TI"], 
      StyleBox["j", "TI"], "\[Dagger]"]}], "}"}], "=", 
   RowBox[{
    SubscriptBox[
     StyleBox["f", "TI"], 
     StyleBox["i", "TI"]], "\[VeryThinSpace]", 
    SubscriptBox[
     StyleBox["\[Delta]", "TR"], 
     StyleBox["ij", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "03dd0859-cf10-4ea3-87b1-b3664138ee97"],
 ". In order for ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["f", "TI"], 
    StyleBox["i", "TI"]], "=", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d3223ae8-dfc4-41d0-b719-68c8e8242566"],
 ", each row ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["m", "TI"], 
    StyleBox["i", "TI"]], ":=", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["m", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["1", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     SubscriptBox[
      StyleBox["m", "TI"], 
      StyleBox[
       RowBox[{
        StyleBox["i", "TI"], 
        StyleBox["2", "TR"]}],
       ZeroWidthTimes->True]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["m", "TI"], 
      StyleBox[
       RowBox[{"i", ",", 
        RowBox[{"2", "n"}]}], "TI"]]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1fac142e-9757-49b6-8ed7-e2bf8b41dbe4"],
 " must be normalized such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"], "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "dd181039-781f-4c2d-b62c-a9b24422b089"],
 " (",
 StyleBox["not",
  FontSlant->"Italic"],
 " 1)."
}], "Notes",
 CellID->1083981116,ExpressionUUID->"b7f39891-ce30-464c-a3bb-b37a028f88db"],

Cell[TextData[{
 "The normalization of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["msr", "TI"], ":=", 
   RowBox[{"BravyiMeasurement", "[", 
    StyleBox["m", "TI"], "]"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c2a05cf8-b89c-4746-8a41-02b716c7c742"],
 " does not affect the measurement process ",
 Cell[BoxData[
  RowBox[{
   StyleBox["msr", "TI"], "[", 
   StyleBox["ws", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c43e8f31-ac8c-4024-9836-da5f0f022ac8"],
 " for a Bravyi state ",
 Cell[BoxData[
  StyleBox["ws", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d271677b-600e-4ba1-a552-82809fbe2ef9"],
 ". In ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiSimulate"]], "paclet:QuantumMob/Q3/ref/BravyiSimulate", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["\[Ellipsis]", "TR"], ",", 
    StyleBox["msr", "TI"], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "51c6a26b-8430-4e06-99cf-8e6179ff0284"],
 " or ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiMonitor"]], "paclet:QuantumMob/Q3/ref/BravyiMonitor", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["\[Ellipsis]", "TR"], ",", 
    StyleBox["msr", "TI"], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1403c1ac-4f95-47c0-8192-6064eb915591"],
 ", however, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", 
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "4"]}], 
   TraditionalForm]],ExpressionUUID->"42f72ed6-165a-4e63-854b-0e26ce766159"],
 " (notice the power of 4 rather than 2), gives the decoherence rate of the \
quantum jump operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "i"], ":=", 
    RowBox[{
     SubsuperscriptBox["b", "i", "\[Dagger]"], 
     SubscriptBox["b", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "b8b17652-c9a7-4847-9e8d-771193a6b07f"],
 " association with the dressed Fermion mode\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "i"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], 
      RowBox[{"2", "n"}]], 
     SubscriptBox["m", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "e5ac2033-5a84-4398-9330-9f5663d3035e"],
 " (unnormalized)."
}], "Notes",
 CellID->813108630,ExpressionUUID->"71855e0d-5422-4a32-8942-b0356d717963"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Normalize"]], "paclet:ref/Normalize"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"BravyiMeasurement", "[", 
    TemplateBox[{
      Cell[
       TextData["m"]], "paclet:QuantumMob/Q3/ref/m"},
     "RefLink",
     BaseStyle->{"InlineFormula", "TI"}], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1bd82ae2-ea81-4f41-973c-80a54618e1ba"],
 " normalizes each row ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["m", "TI"], 
   StyleBox["i", "TI"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "10bbbcb7-d590-4bdc-a9fc-2f29ff6922d2"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftDoubleBracketingBar]", 
      SubscriptBox["m", "i"], "\[RightDoubleBracketingBar]"}], "2"], "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "ac18e0c8-7df9-45e1-abfc-8e6d7b9349fc"],
 " (",
 StyleBox["not",
  FontSlant->"Italic"],
 " 1)."
}], "Notes",
 CellID->38269443,ExpressionUUID->"937e1a57-f8c2-4b02-90e5-d2830d28b964"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"BravyiMeasurement", "[", 
    StyleBox["m", "TI"], "]"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "85a0b944-8989-43a3-89f7-233e463b95ea"],
 " returns a list of the matrix representations of the (unnormalized) \
projection operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["b", "i", "\[Dagger]"], 
    SubscriptBox["b", "i"]}], TraditionalForm]],ExpressionUUID->
  "6e05b3ca-c297-41ac-9473-3ad6f4872b01"],
 " associated with the (unnormalized) dressed Dirac fermion modes ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["b", "TI"], 
    StyleBox["i", "TI"]], ":=", 
   RowBox[{
    SubscriptBox[
     StyleBox["\[CapitalSigma]", "TR"], 
     StyleBox["j", "TI"]], "\[VeryThinSpace]", 
    SubscriptBox[
     StyleBox["m", "TI"], 
     StyleBox["ij", "TI"]], "\[VeryThinSpace]", 
    SubscriptBox[
     StyleBox["c", "TI"], 
     StyleBox["j", "TI"]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "89d7aee9-e5fc-445c-b19a-60fb6b1a0f2b"],
 "."
}], "Notes",
 CellID->940895214,ExpressionUUID->"8ed47984-f88a-4325-92e5-9997a0965f81"],

Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "24170330-62cb-4f55-8d32-759ae86f4aeb"],
 " and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiJump"]], "paclet:QuantumMob/Q3/ref/BravyiJump", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fc2bca51-28cf-4b8a-bf58-c46460b48d6a"],
 " and share the common data format. However, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "717c6ade-1ab2-41d3-9f14-c536e7d625a4"],
 " requires an additional condition for its input matrix (see the \"Details \
and Options\" section of ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d0c4bfae-342b-4498-8e72-320b8795ae20"],
 ")."
}], "Notes",
 CellID->1966580318,ExpressionUUID->"f20fff8f-db54-4e77-81ec-de9fc3c0dd3b"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

