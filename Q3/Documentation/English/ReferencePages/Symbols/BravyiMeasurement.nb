    "history" -> {"14.1", "14.3", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {
     "fermionic quantum computation", "fermionic Gaussian state"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "BravyiMeasurement[m] represents a sequence of measurements of \
b_i^\\[Dagger] bi, where bi := \\[CapitalSigma]j mij cj are dressed Dirac \
fermion modes consisting of bare Majorana fermion modes cj. \
BravyiMeasurement[{k1, k2, ..., km}, n] assumes a sequence of measurements on \
Dirac fermion modes k1, k2, ..., km of total n modes, and returns the \
equivalent BravyiMeasurement[m]. BravyiMeasurement[k, n] is equivalent to \
BravyiMeasurement[{k}, n]. BravyiMeasurement[spec][ws] simulates the \
measurement on Bravyi state ws, and returns the post-measurement state.", 
    "synonyms" -> {}, "tabletags" -> {}, "title" -> "BravyiMeasurement", 
    "titlemodifier" -> "", "metadescription" -> "", "windowtitle" -> 
    "BravyiMeasurement", "type" -> "Symbol", "uri" -> 
    "QuantumMob/Q3/ref/BravyiMeasurement"}},
