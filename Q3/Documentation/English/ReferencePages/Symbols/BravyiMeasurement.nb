 CellLabel->"In[1]:=",
 CellID->1943623144,ExpressionUUID->"e0fc6ab9-2fdb-4a66-a55a-5cfb265648bf"],

Cell[TextData[{
 "Construct the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiMeasurement"]], 
    "paclet:QuantumMob/Q3/ref/BravyiMeasurement", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e0ff43af-169a-450c-87ac-03ba014e9a97"],
 ", which here will be used to describe the projective quantum jump operators \
rather than the measurement processes:"
}], "ExampleText",
 CellID->664356365,ExpressionUUID->"54d74914-a2e1-4abc-a2fc-163970ff6d02"],

