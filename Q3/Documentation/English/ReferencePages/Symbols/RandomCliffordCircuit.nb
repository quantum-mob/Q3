TaggingRules->{
 "ModificationHighlight" -> False, "ColorType" -> "", "LinkTrails" -> "", 
  "ExampleCounter" -> 1, 
  "Openers" -> {
   "PrimaryExamplesSection" -> Open, "ExampleSection" -> {"0" -> Open}, 
    "AllOptsTable" -> Closed, "NotesSection" -> Closed}, "NewStyles" -> True, 
  "CitationPopupData" -> $Failed, "ShowCitation" -> False, "HasOptions" -> 
  True, "RootCaptions" -> "", "HeaderCoreAreaLink" -> {}, 
  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 57, 20.020750}", 
    "history" -> {"14.1", "14.2", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {}, "specialkeywords" -> {}, 
    "tutorialcollectionlinks" -> {}, "index" -> True, "label" -> 
    "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> "QuantumMob/Q3",
     "status" -> "None", "summary" -> 
    "RandomCliffordCircuit[{n, t}, p] generates a Clifford circuit of depth 3 \
t on n qubits with alternating layers of randomly selected two-qubit Clifford \
unitary gates (circuit elements of CliffordUnitary) and single-qubit Pauli \
measurements in the computational basis (i.e., Pauli Z; see circuit elements \
of PauliMeasurement), where each qubit is measured in the computational basis \
with probability p. RandomCliffordCircuit[{n, t}, {p, q}] gives a mixed \
Clifford circuit, in the non-unitary layers of which each qubit undergoes the \
Pauli measurement in the computational basis (see PauliMeasurement), a Pauli \
decoherence channel in the computational basis (see PauliDecoherence), or \
nothing randomly with probabilities p, q, and 1 - p - q, respectively. \
RandomCliffordCircuit[{n, t}, {{p1, p2, p3}, {q1, q2, q3}}] specifies the \
probabilities p1, p2, p3 for Pauli X, Y, Z measurements, respectively, and \
probabilities q1, q2, q3 for Pauli X, Y, Z decoherence channels, \
respectively. RandomCliffordCircuit[{n, t}, ...] assumes the conventional \
initial state Ket[{0, 0, ...}].", "synonyms" -> {}, "tabletags" -> {}, 
    "title" -> "RandomCliffordCircuit", "titlemodifier" -> "", 
    "metadescription" -> "", "windowtitle" -> "RandomCliffordCircuit", "type" -> 
    "Symbol", "uri" -> "QuantumMob/Q3/ref/RandomCliffordCircuit"}},
