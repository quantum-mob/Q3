Cell[TextData[{
 "Generate a quantum circuit where the non-unitary layers are mixtures of \
Pauli measurements and Pauli decoherence channels ",
 StyleBox["with both in the computational basis",
  FontSlant->"Italic"],
 "."
}], "ExampleText",
 CellID->474502569,ExpressionUUID->"c1893c73-a93c-41a0-a5c4-0a68ed1b9993"],

