Cell[TextData[{
 "Internally, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiLogarithmicNegativity"]], 
    "paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8717dd26-2bf8-447f-a19e-fea2d0912f2c"],
 " treats the cases with and without pairing (anomalous Green's functions) \
differently, though essential ideas are the same. Here, the two different \
methods are compared."
}], "ExampleText",
 CellID->1279730119,ExpressionUUID->"507fdb3a-f075-40d1-9c43-4235143f9544"],

Cell["Consider some fermion modes.", "ExampleText",
 CellID->1601225008,ExpressionUUID->"9d1d555f-a0c8-4186-9d7d-a7a54def0a91"],

