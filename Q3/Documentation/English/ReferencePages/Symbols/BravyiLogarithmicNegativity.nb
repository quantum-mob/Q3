Cell[TextData[{
 "The (normal) Green\[CloseCurlyQuote]s function of fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "5d3e8320-888b-4417-9472-b1eeba882417"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubsuperscriptBox["c", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"2a9fa29a-f084-485d-8543-7e9b27020003"],
 ". The matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "2e3baac5-c966-4baf-bbd7-aab40ac96abf"],
 " is Hermitian, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["G", "\[Dagger]"], "=", "G"}], TraditionalForm]],
  ExpressionUUID->"c4e6a614-feaa-4eea-92e3-24d9f8ff20dc"],
 ". The ",
 StyleBox["correlation matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       SubsuperscriptBox["c", "i", "\[Dagger]"], 
       SubscriptBox["c", "j"]}], "\[RightAngleBracket]"}], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{"I", "-", 
        SuperscriptBox["G", "T"]}], ")"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"3590b4f4-c447-4871-b2d1-e985e21f45b5"],
 " has equivalent information and is also frequently used."
}], "Notes",
 CellID->348061621,ExpressionUUID->"cb1bd550-6c4d-4439-8322-08de4d761fc3"],

Cell[TextData[{
 "The anomalous Green\[CloseCurlyQuote]s function of fermion modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "8d17b0d6-ba46-4aae-885f-7095c23d00e9"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["c", "i"], 
      SubscriptBox["c", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"33b12596-59a4-46b9-8478-b51884421c51"],
 ". The matrix ",
 Cell[BoxData[
  FormBox["F", TraditionalForm]],ExpressionUUID->
  "40321141-0b69-47c3-a431-981168826ad2"],
 " is skew-symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["F", "T"], "=", 
    RowBox[{"-", "F"}]}], TraditionalForm]],ExpressionUUID->
  "882cdcae-bf87-4e8f-be1e-f146a082223d"],
 "."
}], "Notes",
 CellID->1383491325,ExpressionUUID->"c68f3cc7-f073-4800-9cd9-810b02045e00"],

Cell[TextData[{
 "In the Nambu notation, the full Green\[CloseCurlyQuote]s function is \
defined to be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["G", "_"], ":=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{
       UnderscriptBox["c", "_"], 
       SuperscriptBox[
        UnderscriptBox["c", "_"], "\[Dagger]"]}], "\[RightAngleBracket]"}], "=", 
     RowBox[{
      RowBox[{"(", GridBox[{
         {"G", "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], 
          RowBox[{"I", "-", 
           SuperscriptBox["G", "T"]}]}
        }], ")"}], "=", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"I", "-", 
           SuperscriptBox["C", "T"]}], "F"},
         {
          SuperscriptBox["F", "\[Dagger]"], "C"}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "83944bab-d3ec-49a6-8bf4-21ef0a08a24c"],
 ", where  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     UnderscriptBox["c", "_"], "\[Dagger]"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["c", "1", "\[Dagger]"], ",", "\[Ellipsis]", ",", 
      SubsuperscriptBox["c", "n", "\[Dagger]"], ",", 
      SubscriptBox["c", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["c", "n"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d7b96b69-f6b2-4ab1-8787-f074ed5e2c8b"],
 "."
}], "Notes",
 CellID->795234925,ExpressionUUID->"1e11a489-792a-4a0c-8e10-0ac5f77e95b4"],

Cell[TextData[{
 "When the Green's function is given in the Nambu form with the off-diagonal \
block of anomalous Green's functions, ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["BravyiLogarithmicNegativity"]], 
    "paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "efeaab24-3410-4e29-b96c-74ad8664f35d"],
 " uses a method based on the coherent-state representation of fermionic \
Gaussian states (",
 ButtonBox["Shapourian and Ryu, 2017",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevB.95.165101"], None}],
 "; ",
 ButtonBox["Shapourian and Ryu, 2019a",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.99.022310"], None}],
 "). The current implementation is unstable when any eigenvalue of the matrix \
of Green's functions approaches 1 (corresponding to an empty single-particle \
level). ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["BravyiLogarithmicNegativity"]], 
     "paclet:QuantumMob/Q3/ref/BravyiLogarithmicNegativity", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{
    StyleBox["\[Ellipsis]", "TR"], ",", 
    RowBox[{"\"\<Epsilon\>\"", "\[Rule]", 
     StyleBox["\[Epsilon]", "TR"]}]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "7198f92e-b386-4029-a574-d9032e71c139"],
 " shifts ",
 Cell[BoxData[
  RowBox[{
   StyleBox["G", "TI"], "\[RightArrow]", 
   RowBox[{
    StyleBox["G", "TI"], "+", 
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     StyleBox["\[Epsilon]", "TR"]}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3657683a-5fae-47d5-ab09-f2675037de3f"],
 " to tame this instability. The default setting is ",
 Cell[BoxData[
  RowBox[{"\"\<Epsilon\>\"", "\[Rule]", 
   RowBox[{"1.25", "\[Times]", 
    SuperscriptBox["10", 
     RowBox[{"-", "5"}]]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "060daf72-afbb-4716-a2f1-8d1bae4bd6cf"],
 ". This option may be unnecessary when the program code is updated to better \
handle trivial Green's functions."
}], "Notes",
 CellID->522646582,ExpressionUUID->"8781f0aa-d802-4345-8da2-a4f851682602"],

Cell[TextData[{
 "On the other hand, when the Green's functions are given in the normal form, \
the internal method is technically different although essentially the same; \
see ",
 ButtonBox["Eisert, Eisler and Zimbor\[AAcute]s (2018)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevB.97.165123"], None}],
 " and ",
 ButtonBox["Shapourian and Ryu (2019b)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1088/1742-5468/ab11e0"], None}],
 "."
}], "Notes",
 CellID->1605923748,ExpressionUUID->"161b5e5f-a09c-450d-bf29-f33301f68e95"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

