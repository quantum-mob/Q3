Cell["\<\
Construct a matrix of Green's functions. Note that we are deliberately \
avoiding the case where the matrix of Green's functions has an eigenvalue of \
unity; see below.\
\>", "ExampleText",
 CellID->28224962,ExpressionUUID->"b7e9f6ef-11fa-4be0-921a-d70823f4d05e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SeedRandom", "[", "358", "]"}], ";"}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->672106451,ExpressionUUID->"77f00150-d587-4b52-a3ea-3fa9316ecad7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"grn", "=", 
   RowBox[{"RandomPositive", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"grn", "/=", 
   RowBox[{"Max", "[", 
    RowBox[{"Eigenvalues", "[", "grn", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"grn", "=", 
   RowBox[{
    RowBox[{"One", "[", "$n", "]"}], "-", "grn"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Eigenvalues", "[", "grn", "]"}], "//", "Chop"}]}], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->295946352,ExpressionUUID->"0f763a2f-50ca-4bdc-9bbe-4cea67fe68ab"],

