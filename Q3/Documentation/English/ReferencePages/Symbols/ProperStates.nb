Cell[BoxData[
 PanelBox[
  TagBox[
   TagBox[GridBox[{
      {
       RowBox[{
        RowBox[{"\[ImaginaryI]", " ", 
         RowBox[{"Ket", "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}], "]"}]}], "+", 
        RowBox[{"Ket", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", "1"}], "}"}], "]"}], "-", 
        RowBox[{"\[ImaginaryI]", " ", 
         RowBox[{"Ket", "[", 
          RowBox[{"{", 
           RowBox[{"1", ",", "0"}], "}"}], "]"}]}], "+", 
        RowBox[{"Ket", "[", 
         RowBox[{"{", 
          RowBox[{"1", ",", "1"}], "}"}], "]"}]}]},
      {
       RowBox[{
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", 
         RowBox[{"Ket", "[", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}], "]"}]}], "-", 
        TemplateBox[{
