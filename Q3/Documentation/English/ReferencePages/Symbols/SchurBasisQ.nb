Cell[TextData[{
 "Schur basis is an association of the form ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     StyleBox["yt", "TI"], ",", 
     StyleBox["wt", "TI"]}], "}"}], "\[RightArrow]", 
   StyleBox["v", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6da0af7b-4328-416d-b146-5a947069a6b5"],
 " or ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     StyleBox["yt", "TI"], ",", 
     StyleBox["wt", "TI"]}], "}"}], "\[RightArrow]", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["v", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f23d04c9-9397-4f66-af82-c8b76be45f13"],
 ", where ",
 Cell[BoxData[
  StyleBox["yt", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c1f7200c-f8e6-4503-9115-0d54c8b4d1dc"],
 " and ",
 Cell[BoxData[
  StyleBox["wt", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "50a09450-6eaa-49be-8bf5-fb56fcdf518c"],
 " are Gelfand patterns corresponding to a standard Young and Weyl tableaux, \
respectively."
}], "Notes",
 CellID->577603911,ExpressionUUID->"a8274505-be33-4b84-8c72-ff6b86f2f806"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

