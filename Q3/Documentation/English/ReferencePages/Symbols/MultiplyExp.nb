Cell["It is raised to the power of \[ExponentialE].", "ExampleText",
 CellID->484684192,ExpressionUUID->"b5639bb0-bc14-47c2-9fe8-bf94e61e77ef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"opU", "=", 
  RowBox[{"MultiplyExp", "[", 
   RowBox[{
    RowBox[{"-", "I"}], " ", "opH"}], "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->943074702,ExpressionUUID->"3f00919b-84ef-4186-a4e2-3190386f5376"],

Cell[BoxData[
 InterpretationBox[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], " ", 
    RowBox[{"(", 
     RowBox[{
      InterpretationBox[
       RowBox[{"\<\"X\"\>", "\[CircleTimes]", "\<\"X\"\>"}],
       Q3`Pauli[{1, 1}]], "+", 
      InterpretationBox[
       RowBox[{"\<\"Y\"\>", "\[CircleTimes]", "\<\"Z\"\>"}],
       Q3`Pauli[{2, 3}]]}], ")"}]}]],
  Q3`MultiplyExp[
  Complex[0, -1] (Q3`Pauli[{1, 1}] + Q3`Pauli[{2, 3}])]]], "Output",
 CellLabel->"Out[3]=",
 CellID->599911261,ExpressionUUID->"5b5a5196-f8b1-4fef-8cbf-7a5edc7dd65e"]
}, Open  ]],

