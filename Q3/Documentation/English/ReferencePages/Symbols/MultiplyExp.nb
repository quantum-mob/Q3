Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox[
    RowBox[{"Cos", "[", "1", "]"}], "2"], " ", 
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", "\<\"I\"\>"}],
    Q3`Pauli[{0, 0}]]}], "-", 
  RowBox[{
   InterpretationBox[
    RowBox[{"\<\"Z\"\>", "\[CircleTimes]", "\<\"Y\"\>"}],
    Q3`Pauli[{3, 2}]], " ", 
   SuperscriptBox[
    RowBox[{"Sin", "[", "1", "]"}], "2"]}], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   InterpretationBox[
    RowBox[{"\<\"X\"\>", "\[CircleTimes]", "\<\"X\"\>"}],
    Q3`Pauli[{1, 1}]], " ", 
   RowBox[{"Sin", "[", "2", "]"}]}], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   InterpretationBox[
    RowBox[{"\<\"Y\"\>", "\[CircleTimes]", "\<\"Z\"\>"}],
    Q3`Pauli[{2, 3}]], " ", 
   RowBox[{"Sin", "[", "2", "]"}]}]}]], "Output",
 CellLabel->"Out[4]=",
 CellID->898098642,ExpressionUUID->"156a6be7-8a31-4ce1-aff1-c3cf21627902"]
}, Open  ]],

