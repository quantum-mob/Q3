Cell["Consider an operator on a system of unlabelled qubits.", "ExampleText",
 CellID->2131270468,ExpressionUUID->"60edde3b-9012-4fd2-ab27-229147ea78d7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"opH", "=", 
  RowBox[{
   RowBox[{"Pauli", "[", 
    RowBox[{"{", 
     RowBox[{"1", ",", "1"}], "}"}], "]"}], "+", 
   RowBox[{"Pauli", "[", 
    RowBox[{"{", 
     RowBox[{"2", ",", "3"}], "}"}], "]"}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[1]:=",
 CellID->925160218,ExpressionUUID->"b7747e57-f2ad-451b-b269-b1d5818c8c05"],

Cell[BoxData[
 RowBox[{
  InterpretationBox[
   RowBox[{"\<\"X\"\>", "\[CircleTimes]", "\<\"X\"\>"}],
   Q3`Pauli[{1, 1}]], "+", 
  InterpretationBox[
   RowBox[{"\<\"Y\"\>", "\[CircleTimes]", "\<\"Z\"\>"}],
   Q3`Pauli[{2, 3}]]}]], "Output",
 CellLabel->"Out[1]=",
 CellID->160126680,ExpressionUUID->"8af605b2-815e-4ac3-9e21-f50718421628"]
}, Open  ]],

