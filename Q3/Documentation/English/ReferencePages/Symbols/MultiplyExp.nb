Cell["\<\
For a simple example, consider an operator of the following form.\
\>", "ExampleText",
 CellID->511453335,ExpressionUUID->"f592afeb-a377-474e-9290-5172190a8903"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", 
  RowBox[{"op", "=", 
   RowBox[{
    RowBox[{"2", " ", "I", " ", 
     RowBox[{"z", "[", "1", "]"}], " ", 
     RowBox[{"c", "[", "1", "]"}]}], "+", 
    RowBox[{
     RowBox[{"z", "[", "2", "]"}], 
     RowBox[{"c", "[", "2", "]"}]}]}]}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[2]:=",
 CellID->1600947435,ExpressionUUID->"6643d87b-6028-45fd-89ca-afa7589aac61"],

Cell[BoxData[
 RowBox[{
  RowBox[{"2", " ", "\[ImaginaryI]", " ", 
   InterpretationBox[
    SubscriptBox["c", 
     TemplateBox[{",", "\",\"", "1"},
      "RowWithSeparators"]],
    $CellContext`c[1]], " ", 
   InterpretationBox[
    SubscriptBox["z", 
     TemplateBox[{",", "\",\"", "1"},
      "RowWithSeparators"]],
    $CellContext`z[1]]}], "+", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["c", 
     TemplateBox[{",", "\",\"", "2"},
      "RowWithSeparators"]],
    $CellContext`c[2]], " ", 
   InterpretationBox[
    SubscriptBox["z", 
     TemplateBox[{",", "\",\"", "2"},
      "RowWithSeparators"]],
    $CellContext`z[2]]}]}]], "Output",
 CellLabel->"Out[2]=",
 CellID->1389581327,ExpressionUUID->"5f47b8a1-afbc-4400-88fe-e440698bf2ca"]
}, Open  ]],

Cell["Exp[op] is quite simple in this case.", "ExampleText",
 CellID->1274725138,ExpressionUUID->"90540aa0-9952-4f12-b4e1-de4b6dd22428"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"expr1", "=", 
  RowBox[{"MultiplyExp", "[", "op", "]"}]}]], "Input",
 CellProlog:>Needs["QuantumMob`Q3`"],
 CellLabel->"In[3]:=",
 CellID->278579565,ExpressionUUID->"3a548dd9-2ee5-4b59-a145-e72a7cbaca8e"],

Cell[BoxData[
 InterpretationBox[
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"2", " ", "\[ImaginaryI]", " ", 
     InterpretationBox[
      SubscriptBox["c", 
       TemplateBox[{",", "\",\"", "1"},
        "RowWithSeparators"]],
      $CellContext`c[1]], " ", 
     InterpretationBox[
      SubscriptBox["z", 
       TemplateBox[{",", "\",\"", "1"},
        "RowWithSeparators"]],
      $CellContext`z[1]]}], "+", 
    RowBox[{
     InterpretationBox[
      SubscriptBox["c", 
       TemplateBox[{",", "\",\"", "2"},
        "RowWithSeparators"]],
      $CellContext`c[2]], " ", 
     InterpretationBox[
      SubscriptBox["z", 
       TemplateBox[{",", "\",\"", "2"},
        "RowWithSeparators"]],
      $CellContext`z[2]]}]}]],
  Q3`MultiplyExp[
  Complex[0, 2] $CellContext`c[1] $CellContext`z[1] + $CellContext`c[
     2] $CellContext`z[2]]]], "Output",
 CellLabel->"Out[3]=",
 CellID->104732974,ExpressionUUID->"be439b88-55fe-4419-bcb4-c985a1052ccc"]
}, Open  ]],

