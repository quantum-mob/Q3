Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       RowBox[{"Cos", "[", 
        FractionBox["b", "2"], "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", 
          FractionBox[
           RowBox[{"a", "+", "c"}], "2"], "]"}], "-", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"Sin", "[", 
           FractionBox[
            RowBox[{"a", "+", "c"}], "2"], "]"}]}]}], ")"}]}], 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Sin", "[", 
         FractionBox["b", "2"], "]"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", 
          FractionBox[
           RowBox[{"a", "-", "c"}], "2"], "]"}], "-", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"Sin", "[", 
           FractionBox[
            RowBox[{"a", "-", "c"}], "2"], "]"}]}]}], ")"}]}]},
     {
      RowBox[{
       RowBox[{"Sin", "[", 
        FractionBox["b", "2"], "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", 
          FractionBox[
           RowBox[{"a", "-", "c"}], "2"], "]"}], "+", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"Sin", "[", 
           FractionBox[
            RowBox[{"a", "-", "c"}], "2"], "]"}]}]}], ")"}]}], 
      RowBox[{
       RowBox[{"Cos", "[", 
        FractionBox["b", "2"], "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Cos", "[", 
          FractionBox[
           RowBox[{"a", "+", "c"}], "2"], "]"}], "+", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"Sin", "[", 
           FractionBox[
            RowBox[{"a", "+", "c"}], "2"], "]"}]}]}], ")"}]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {2, 2}, 0, {
     1, {{0, 2, 4}, {{1}, {2}, {2}, {1}}}, {
      Cos[Rational[1, 2] $CellContext`b] (
        Cos[Rational[1, 2] ($CellContext`a + $CellContext`c)] + 
        Complex[0, -1] 
         Sin[Rational[1, 2] ($CellContext`a + $CellContext`c)]), (-
        Sin[Rational[1, 2] $CellContext`b]) (
        Cos[Rational[1, 2] ($CellContext`a - $CellContext`c)] + 
        Complex[0, -1] Sin[Rational[1, 2] ($CellContext`a - $CellContext`c)]),
        Cos[Rational[1, 2] $CellContext`b] (
        Cos[Rational[1, 2] ($CellContext`a + $CellContext`c)] + 
        Complex[0, 1] Sin[Rational[1, 2] ($CellContext`a + $CellContext`c)]), 
       Sin[Rational[1, 2] $CellContext`b] (
        Cos[Rational[1, 2] ($CellContext`a - $CellContext`c)] + 
        Complex[0, 1] 
         Sin[Rational[
            1, 2] ($CellContext`a - $CellContext`c)])}}]]]]], "Output",
 CellLabel->"Out[2]//MatrixForm=",
 CellID->79573832,ExpressionUUID->"9063de0b-f1e7-412a-aa10-d979d8238a81"]
}, Open  ]],

