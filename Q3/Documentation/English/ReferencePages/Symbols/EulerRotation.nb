Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Cos", "[", 
    FractionBox["b", "2"], "]"}], " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"a", "+", "c"}], "2"], "]"}], " ", 
   InterpretationBox["\<\"I\"\>",
    QuantumMob`Q3`Pauli[{0}]]}], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"a", "-", "c"}], "2"], "]"}], " ", 
   InterpretationBox["\<\"Y\"\>",
    QuantumMob`Q3`Pauli[{2}]], " ", 
   RowBox[{"Sin", "[", 
    FractionBox["b", "2"], "]"}]}], "+", 
  RowBox[{"\[ImaginaryI]", " ", 
   InterpretationBox["\<\"X\"\>",
    QuantumMob`Q3`Pauli[{1}]], " ", 
   RowBox[{"Sin", "[", 
    FractionBox["b", "2"], "]"}], " ", 
   RowBox[{"Sin", "[", 
    FractionBox[
     RowBox[{"a", "-", "c"}], "2"], "]"}]}], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   RowBox[{"Cos", "[", 
    FractionBox["b", "2"], "]"}], " ", 
   InterpretationBox["\<\"Z\"\>",
    QuantumMob`Q3`Pauli[{3}]], " ", 
   RowBox[{"Sin", "[", 
    FractionBox[
     RowBox[{"a", "+", "c"}], "2"], "]"}]}]}]], "Output",
 CellLabel->"Out[1]=",
 CellID->694707453,ExpressionUUID->"4a57aece-4e69-4492-a703-78516801b131"]
}, Open  ]],

