  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["x", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["x", "n"]}], "}"}], "\[RightTeeArrow]", 
    TemplateBox[{
      RowBox[{
