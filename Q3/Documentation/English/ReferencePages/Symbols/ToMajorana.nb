    "ExampleSubsection" -> {"0" -> Closed, "1" -> Closed}}, "NewStyles" -> 
  True, "CitationPopupData" -> $Failed, "ShowCitation" -> False, "HasOptions" -> 
  True, "RootCaptions" -> "", "HeaderCoreAreaLink" -> {}, 
  "Metadata" -> {
   "built" -> "{2026, 4, 12, 17, 58, 28.118569}", 
    "history" -> {"12", "14.0", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {"Dirac fermion", "Majorana fermion"}, 
    "specialkeywords" -> {}, "tutorialcollectionlinks" -> {}, "index" -> True,
     "label" -> "Quantum Mob/ Q3 Symbol", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "ToMajorana[expr, {c1, ..., cn} -> {h1, ..., hn, h n + 1, ..., h 2 n}] or \
ToMajorana[expr, c1 -> {h1, h n + 1}, ..., c n -> {h n, h 2 n}] converts expr \
in the Dirac fermion operators c1, ..., cn into an equivalent form in terms \
of the Majorana fermion operators h1, ..., hn, h n + 1, ..., h 2 n. \
ToMajorana[{c1, ..., cn} -> {h1, ..., hn, h n + 1, ..., h 2 n}] or \
ToMajorana[c1 -> {h1, h n + 1}, ..., c n -> {h n, h 2 n}] returns a list of \
replacement rules so as to be used later. ToMajorana[vec] converts the \
coefficients vector vec in a linear combination of Dirac fermion annihilation \
and creation operators into coefficients of Majorana fermion operators. \
ToMajorana[mat] converts the coefficients matrix mat in a bilinear \
combination of Dirac fermion annihilation and creation operators into \
coefficients of Majorana fermion operators.", "synonyms" -> {}, 
    "tabletags" -> {}, "title" -> "ToMajorana", "titlemodifier" -> "", 
