Cell[TextData[{
 "The transformation rules between Dirac fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "5cedf85d-a3d1-45b2-8018-57a1cf16d529"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["a", "k", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "2bb1365e-10ee-46f4-93ac-4393adebac2b"],
 " and the Majorana fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "k"], TraditionalForm]],ExpressionUUID->
  "2ea2e91f-183d-4f7c-8ec3-8bd7b0650cfc"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{"n", "+", "k"}]], TraditionalForm]],ExpressionUUID->
  "0188aa13-e95b-4732-8c5c-b1639c92603f"],
 " are given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "k"], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "+", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"6a6da329-4ecc-49d5-9f36-2a0f5779faa4"],
 ", \[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubscriptBox["c", 
      RowBox[{"n", "+", "k"}]]}], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "-", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"9656b678-0668-4b03-af76-85f642538a31"],
 ".\[LineSeparator]Note that the Majorana operators are normalized as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["c", "i"], ",", 
      SubscriptBox["c", "j"]}], "}"}], "=", 
    RowBox[{"2", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"671b8993-a392-4fc6-86d3-7aa15f735500"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["c", "i", "2"], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"728da71a-368c-430a-b51b-2b92b15cdd81"],
 "."
}], "Notes",
 CellID->307824357,ExpressionUUID->"acd754d5-c460-4658-9b4b-05f9623afb13"],

