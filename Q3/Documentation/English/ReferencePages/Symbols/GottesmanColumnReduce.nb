Cell[TextData[{
 "Now, let get the column reduced form of the z-block. First, apply the \
Hadamard gates on all qubits. Here, note that applying the Hadamard gates is \
not the same as apply ",
 StyleBox["GottesmanFlip", "Input"],
 ", which does not change the phase bit."
}], "ExampleText",
 CellID->403666160,ExpressionUUID->"e2729e70-40d7-4533-a50d-80ca9e44469e"],

Cell[BoxData[{
 RowBox[{
