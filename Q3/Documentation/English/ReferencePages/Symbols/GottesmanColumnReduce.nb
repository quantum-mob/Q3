    RowBox[{"Range", "@", "$n"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"zin", "=", 
   RowBox[{"hdm", "[", "in", "]"}]}], ";"}]}], "Input",
