Cell[TextData[{
 "If you want to get the column reduced form of the Z-block of ",
 Cell[BoxData[
  StyleBox["mat", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "94262ac8-4331-46db-8a2c-2cd80ce63c45"],
 ", then first apply Hadamard gate on every qubit before and after applying \
",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanColumnReduce"]], 
    "paclet:QuantumMob/Q3/ref/GottesmanColumnReduce", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8de0c56d-5902-4d7b-9af2-edd131dfe36a"],
 "."
}], "Notes",
 CellID->1952778111,ExpressionUUID->"cbe75c37-064e-47a2-a549-18f93a625a04"],

Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["GottesmanColumnReduce"]], 
    "paclet:QuantumMob/Q3/ref/GottesmanColumnReduce", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1ce205e7-a0a3-46ce-98ad-416a02791e06"],
 " is typically used to find a Clifford circuit that transforms a ",
 ButtonBox["Clifford state",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordState"],
 " to a product state in the computational basis. Recall that a ",
 ButtonBox["Clifford state",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordState"],
 " (i.e., stabilizer state) is specified by an array of ",
 ButtonBox["full Gottesman vectors",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullGottesmanVector"],
 "."
}], "Notes",
 CellID->270332839,ExpressionUUID->"ef41e626-4bd0-437b-8b12-9ec5c76f61e8"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

