Cell[TextData[{
 "Build the overall quantum circuit in two steps indicated by the vertical \
dashed line. The first step corresponds to the preparation, and the second to \
the operation. Here, we use the abbreviated notation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "k"], ":=", 
    RowBox[{
     SubscriptBox["U", "Z"], "(", 
     SubscriptBox["\[Phi]", "k"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "ed3550cf-9bc1-4ad9-8875-67adaf8f94c7"],
 "."
}], "TechNoteMathCaption",
 CellID->1367301050,ExpressionUUID->"bc591e68-482b-404c-83bf-f57e205e6eff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"in", ",", 
    RowBox[{"Ket", "[", 
     RowBox[{"S", "@", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3", ",", "4"}], "}"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"S", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"2", ",", "3", ",", "4"}], "}"}], ",", "6"}], "]"}], ",", 
    RowBox[{"CZ", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", 
    RowBox[{"CZ", "[", 
     RowBox[{
      RowBox[{"S", "[", "2", "]"}], ",", 
      RowBox[{"S", "[", "3", "]"}]}], "]"}], ",", 
    RowBox[{"CZ", "[", 
     RowBox[{
      RowBox[{"S", "[", "3", "]"}], ",", 
      RowBox[{"S", "[", "4", "]"}]}], "]"}], ",", "\"\<Separator\>\"", ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Rotation", "[", 
     RowBox[{
      RowBox[{"\[Phi]", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "3"}], "]"}], ",", 
      RowBox[{"\"\<Label\>\"", 
       "\[Rule]", "\"\<\!\(\*SubscriptBox[\(U\), \(1\)]\)\>\""}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}], ",", 
    RowBox[{"Measurement", "[", 
     RowBox[{"S", "[", 
      RowBox[{"1", ",", "3"}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", 
    RowBox[{"Rotation", "[", 
     RowBox[{
      RowBox[{"\[Phi]", "[", "2", "]"}], ",", 
      RowBox[{"S", "[", 
       RowBox[{"2", ",", "3"}], "]"}], ",", 
      RowBox[{"\"\<Label\>\"", 
       "\[Rule]", "\"\<\!\(\*SubscriptBox[\(U\), \(2\)]\)\>\""}]}], "]"}], ",", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "6"}], "]"}], ",", 
    RowBox[{"Measurement", "[", 
     RowBox[{"S", "[", 
      RowBox[{"2", ",", "3"}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "2", "]"}], ",", 
      RowBox[{"S", "[", "3", "]"}]}], "]"}], ",", 
    RowBox[{"Rotation", "[", 
     RowBox[{
      RowBox[{"\[Phi]", "[", "3", "]"}], ",", 
      RowBox[{"S", "[", 
       RowBox[{"3", ",", "3"}], "]"}], ",", 
