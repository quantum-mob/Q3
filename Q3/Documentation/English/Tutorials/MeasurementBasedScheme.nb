Cell[CellGroupData[{

Cell["Graph States", "TechNoteSection",
 CellID->184730958,ExpressionUUID->"be8044db-540e-4a0e-9f45-72dbad528745"],

Cell[CellGroupData[{

Cell["Definition", "Subsection",
 CellID->1900676205,ExpressionUUID->"16b104d3-72e1-4d8c-81e5-b1163b0711f5"],

Cell[TextData[{
 "Measurement-based quantum computation requires a crucial resource. A \
typical example is the state prepared by the quantum circuit elements to the \
left of the vertical dashed line in ",
 ButtonBox["Figure 3",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MeasurementBasedScheme#1984883915"],
 ". Once the state is prepared, from then on, quantum logic gates can be \
implemented solely by measurements in rotated bases. Such a state is called a \
",
 ButtonBox["graph state",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GraphState"],
 ". Specifically, consider a graph ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "8bbe96a4-0131-4bef-bc32-4915b38c6244"],
 ", where a set of vertices are connected by edges. A qubit is located at \
each vertex. Let ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", 
    RowBox[{"a", "\[ThinSpace]", "b"}]], TraditionalForm]],ExpressionUUID->
  "7d539adc-e467-4b1c-a310-716b2b7dbcb4"],
 " denote the CZ gate on the two qubits located at  vertices ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "c473b4b5-2932-4593-9d7a-1d542961ed72"],
 " and ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "d7132d67-205d-4e9e-94cd-4b6998e6ddff"],
 ". To generate the graph state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[ScriptCapitalG]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "9e59819a-469b-43de-a9e5-927f1313bf01"],
 " associated with the graph ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "cacff3ef-97d2-4217-bc3e-de8e279a0fa3"],
 ", prepare each qubit first in the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"+"},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "+", 
       TemplateBox[{"1"},
        "Ket"]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "212e712e-dd62-41a5-a8fe-dcc01e48e208"],
 ". Then, for each pair ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[LeftAngleBracket]", 
    RowBox[{"a", "\[ThinSpace]", "b"}], "\[RightAngleBracket]"}], 
   TraditionalForm]],ExpressionUUID->"af2037af-9a7d-4170-ae9a-049a4c687a5b"],
 " of vertices ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "0b8db9e7-049f-4563-90e7-3fba8aff9cc6"],
 " and ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "8ce77f30-87f4-442e-8c2f-91aaa908d49f"],
 " connected by an edge, apply the CZ gate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", 
    RowBox[{"a", "\[ThinSpace]", "b"}]], TraditionalForm]],ExpressionUUID->
  "ea8d124e-450d-452c-88ab-7da44b304fc6"],
 " on the corresponding qubits. In short,"
}], "TechNoteText",
 CellID->2069374105,ExpressionUUID->"f35ef166-ace4-4835-95b7-1de4ccbc9d19"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[ScriptCapitalG]"},
     "Ket"], ":=", 
    RowBox[{
     UnderscriptBox["\[CapitalPi]", 
      RowBox[{"\[LeftAngleBracket]", 
       RowBox[{"a", "\[ThinSpace]", "b"}], "\[RightAngleBracket]"}]], 
     SubscriptBox["U", 
      RowBox[{"a", "\[VeryThinSpace]", "b"}]], 
     SuperscriptBox[
      TemplateBox[{"+"},
       "Ket"], 
      RowBox[{"\[CircleTimes]", "n"}]]}]}], TraditionalForm]],ExpressionUUID->
  "8d97c605-8cf4-47f0-8b22-6d51428fcedd"],
 " ,"
}], "TechNoteText",
 CellID->555577313,ExpressionUUID->"c7de4594-e162-4d4f-b811-ea26dd5f7718"],

Cell[TextData[{
 "where the product is over all edges in graph ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "e92d363c-6ca4-4964-9518-9447dea87f78"],
 " and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "775711d3-5aa7-45fb-969b-a03536d7c626"],
 " is the number of vertices of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "6b7c188e-eb66-41c3-be61-8013088a3897"],
 "."
}], "TechNoteText",
 CellID->1481753013,ExpressionUUID->"37ae9b25-944d-44f6-8a24-ed5b9f22d57a"],

