Cell[TextData[{
 "Calculate the output state. Below, the factor of ",
 Cell[BoxData[
  FormBox[
   SqrtBox["4"], TraditionalForm]],ExpressionUUID->
  "bdde1b5f-8797-420c-809f-34bd57850dce"],
 " is for normalization. The above quantum circuit involves a measurement, \
and normalization is not guaranteed for exact vectors. Note that the first \
qubit end up in different state every time the above quantum circuit is run; \
and yet, the state on the second qubit is all the same regardless of the \
state of the first three qubits."
}], "TechNoteMathCaption",
 CellID->1261625249,ExpressionUUID->"573ac97d-cb8e-4619-9702-01f104cb59aa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"out", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Elaborate", "[", 
     RowBox[{
      RowBox[{"Sqrt", "[", "2", "]"}], "*", "full"}], "]"}], "//", 
    "ExpToTrig"}], "//", "Garner"}]}]], "Input",
 CellLabel->"In[15]:=",
 CellID->2029513112,ExpressionUUID->"83bf7cd9-816a-4dbc-8b81-14dee82f7c4e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["c", 
     TemplateBox[{",", "\",\"", "0"},
      "RowWithSeparators"]],
    $CellContext`c[0]], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
