Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Elementary quantum circuit on which the measurement-based quantum \
computation is based. For the output, a summation over ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "=", "0"}], ",", "1"}], TraditionalForm]],ExpressionUUID->
  "5529196f-9233-4fec-bbef-a673d25ff793"],
 " is assumed."
}], "TechNoteCaption",
 CellID->992454319,ExpressionUUID->"64af663c-ceb0-43dc-b010-852a6c74177c"],

Cell["\<\
Accounting for the extra Hadamard gate that we applied, we obtain the output \
state\
\>", "TechNoteText",
 CellID->1537042705,ExpressionUUID->"bec1745f-315d-4174-9b16-74cc9a2ea059"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["1", 
     SqrtBox["2"]], 
    UnderscriptBox["\[CapitalSigma]", 
     RowBox[{
      RowBox[{"x", "=", "0"}], ",", "1"}]], 
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     RowBox[{"(", 
      RowBox[{"H", "\[VeryThinSpace]", 
       SuperscriptBox["Z", "x"], 
       SubscriptBox["U", "z"], 
       TemplateBox[{"\[Psi]"},
        "Ket"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "39a2ed8f-996f-4748-ac7f-0b7a9f4c6067"]
}], "TechNoteText",
 CellID->1116426107,ExpressionUUID->"b2668b12-897b-4567-a21a-f616e93b29b5"],

Cell[TextData[{
 "for the quantum circuit in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MeasurementBasedScheme#992454319"],
 ". This quantum circuit requires no quantum gates once an entanglement has \
been created by the ",
 ButtonBox["CZ gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CZ"],
 ", and only measurement is needed. The cost is that the Hadamard gate \
appears as a byproduct on the output qubit. However, we will see below that \
the trailing Hadamard gate on the second qubit plays an important role to \
achieve an arbitrary single-qubit rotation in the measurement-based scheme."
}], "TechNoteText",
 CellID->675240434,ExpressionUUID->"080174c8-66b0-42bf-a353-3588083e143b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Single-Qubit Rotations", "TechNoteSection",
 CellID->93421842,ExpressionUUID->"9adf0a5f-8c45-43b3-9235-c44a00047e7c"],

