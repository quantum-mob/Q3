Cell["Elementary Building Block", "TechNoteSection",
 CellID->1941831266,ExpressionUUID->"87f86ed0-63ca-4155-aef5-19066715575c"],

Cell["\<\
To get an idea of how the measurement-based scheme works, first consider a \
quantum circuit of the following simple form\
\>", "TechNoteText",
 CellID->238825560,ExpressionUUID->"fa2145ff-68c6-4c0a-85b1-361339004da4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  InterpretationBox[
   GraphicsBox[{
     {Dashing[{Small, Small}], LineBox[{}]}, 
     LineBox[{{{0, -1}, {3, -1}}, {{0, -2}, {3, -2}}}], {InsetBox[
       StyleBox[
        TemplateBox[{"\"\[Psi]\""},
         "Ket"],
        StripOnInput->False,
        FontSize->Scaled[0.10666666666666667`],
        FontWeight->"Light"], {-0.1, -1}, NCache[
       ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]]], InsetBox[
       StyleBox[
        TemplateBox[{"0"},
         "Ket"],
        StripOnInput->False,
        FontSize->Scaled[0.10666666666666667`],
        FontWeight->"Light"], {-0.1, -2}, NCache[
       ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]]]}, {
      LineBox[{{1, -1}, {1, -2}}], 
      DiskBox[{1, -1}, 0.09], {CircleBox[{1, -2}, 0.26666666666666666], 
       LineBox[{{{0.7333333333333334, -2}, {1.2666666666666666`, -2}}, {{
          1, -2.2666666666666666`}, {1, -1.7333333333333334`}}}]}}, {
      {GrayLevel[1], EdgeForm[None], RectangleBox[{1.6, -1.4}, {2.4, -0.6}]}, 
      LineBox[{{1.6, -1.4}, {2.4, -1.4}, {2.4, -0.6}, {1.6, -0.6}, {
       1.6, -1.4}}], InsetBox[
       StyleBox["\<\"H\"\>",
        StripOnInput->False,
        FontSize->Scaled[0.13333333333333333`],
        FontWeight->"Light",
        FontSlant->Italic], {2, -1}, NCache[
       ImageScaled[{Rational[1, 2], Rational[1, 2]}], 
        ImageScaled[{0.5, 0.5}]]]}},
    AxesStyle->Large,
    FrameStyle->Large,
    ImagePadding->{{23.400000000000002`, 23.400000000000002`}, {1, 1}},
    ImageSize->154.79999999999998`,
    PlotRange->NCache[{Full, {
        Rational[-5, 2], 
        Rational[-1, 2]}}, {Full, {-2.5, -0.5}}],
    PlotRangePadding->Scaled[0.025]],
   Q3`QuantumCircuit[
    Q3`QuantumCircuitIn[
     Q3`ProductState[<|$CellContext`S[1, Q3`$] -> {
         $CellContext`c[0], 
         $CellContext`c[1]}|>, "Label" -> Ket["\[Psi]"]], 
     Ket[<|$CellContext`S[2, Q3`$] -> 0|>]], 
    Q3`CNOT[{
       $CellContext`S[1, Q3`$]} -> {1}, {
      $CellContext`S[2, Q3`$]}], 
    $CellContext`S[1, 6]]]],ExpressionUUID->
  "4f13b7d6-81ba-4e26-ad9b-c03cb3dda008"],
 "."
}], "Picture",
 CellID->1000347896,ExpressionUUID->"452f7a0b-1df8-4867-aca5-ac61f22ae50f"],

Cell[TextData[{
 "Here, the input state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "3a157893-b9a0-47d5-9767-6b89f9ec5758"],
 " on the first qubit is arbitrary. Recall that the CNOT gate \
\[OpenCurlyDoubleQuote]copies\[CloseCurlyDoubleQuote] the computational basis \
states of the control qubit to the target qubit. It transforms the input \
state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{"0"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "9543c1c2-e07e-434b-b373-8d24359ca23f"],
 "  to "
}], "TechNoteText",
 CellID->324189609,ExpressionUUID->"063d6887-f660-4b50-9ccf-61bf6e949cb2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{"0"},
        "Ket"]}], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{"1"},
        "Ket"]}], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "3d2d5e8f-2961-4fe2-8d21-a5cfa5c14d8c"],
 ". "
}], "TechNoteText",
 CellID->1641618474,ExpressionUUID->"659a6487-88ca-4982-90f0-4125f3e6aafe"],

Cell["\<\
Then, the additional Hadamard gate on the first qubit leads to the final state\
\>", "TechNoteText",
 CellID->1149759981,ExpressionUUID->"255a1fc7-0002-430e-ac83-99af8a0c1e24"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["1", "2"], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{"\[Psi]"},
        "Ket"]}], "+", 
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], "\[CircleTimes]", 
       RowBox[{"(", 
        RowBox[{
         OverscriptBox["Z", "^"], 
         TemplateBox[{"\[Psi]"},
          "Ket"]}], ")"}]}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "d4f08e8e-7dbe-4355-9426-3d765f050a46"],
 " ."
}], "TechNoteText",
 CellID->1971660067,ExpressionUUID->"752b6582-d0f8-488c-bcdc-e52dadd69600"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->706304117,ExpressionUUID->"2e48dd47-47de-4970-a1d4-20aa30e39368"],

Cell[TextData[{
 "When the first qubit is measured, the state of the second qubit is set to \
different states depending on the measurement outcome. When the outcome is 0, \
the state is identical to the input state of the first qubit; and it is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "16b228af-c6aa-4f34-bac2-9f5449e21a88"],
 " if the outcome is 1. In any case, the state coming out on the second qubit \
can be set to the (unknown) input state of the first qubit by applying an \
additional operation ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "fcef2c4f-69dc-401a-a9fc-ca60a6b45fe1"],
 " if necessary as in the following quantum circuit"
}], "TechNoteText",
 CellID->1232469531,ExpressionUUID->"bdc33299-68e8-41c1-9032-09f7da064d2d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  InterpretationBox[
   GraphicsBox[{
     {Dashing[{Small, Small}], LineBox[{{{4, -1}, {6, -1}}}]}, 
     LineBox[{{{0, -1}, {4, -1}}, {{0, -2}, {6, -2}}}], {InsetBox[
       StyleBox[
        TemplateBox[{"\"\[Psi]\""},
         "Ket"],
        StripOnInput->False,
        FontSize->Scaled[0.05333333333333334],
        FontWeight->"Light"], {-0.1, -1}, NCache[
       ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]]], InsetBox[
       StyleBox[
        TemplateBox[{"0"},
         "Ket"],
        StripOnInput->False,
        FontSize->Scaled[0.05333333333333334],
        FontWeight->"Light"], {-0.1, -2}, NCache[
       ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]]]}, {
      LineBox[{{1, -1}, {1, -2}}], 
      DiskBox[{1, -1}, 0.09], {CircleBox[{1, -2}, 0.26666666666666666], 
       LineBox[{{{0.7333333333333334, -2}, {1.2666666666666666`, -2}}, {{
          1, -2.2666666666666666`}, {1, -1.7333333333333334`}}}]}}, {
      {GrayLevel[1], EdgeForm[None], RectangleBox[{1.6, -1.4}, {2.4, -0.6}]}, 
      LineBox[{{1.6, -1.4}, {2.4, -1.4}, {2.4, -0.6}, {1.6, -0.6}, {
       1.6, -1.4}}], InsetBox[
       StyleBox["\<\"H\"\>",
