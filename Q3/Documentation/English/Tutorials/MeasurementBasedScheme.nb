Cell[TextData[{
 "Again, the key point here is that the unitary operation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "z"], TraditionalForm]],ExpressionUUID->
  "a0dc4f38-835c-49a3-9130-07626fd684e8"],
 " and the Hadamard gate followed by a measurement in the standard basis on \
the first qubit can be regarded as a measurement in the rotated basis. In the \
end, we have achieved the state with unitary gate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "z"], TraditionalForm]],ExpressionUUID->
  "08d79961-ad05-4400-bc21-66d621ae2c48"],
 " applied on it by means of a (rotated) measurement."
}], "TechNoteText",
 CellID->1004604272,ExpressionUUID->"b786a58f-bc66-4b23-a661-9eb108dc3f54"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1711177450,ExpressionUUID->"c19a4785-1209-4ea7-9166-35c32f0a4995"],

Cell[TextData[{
 "Since the Inverse of the Hadamard gate equals to the Hadamard gate itself, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["H", "2"], "=", "I"}], TraditionalForm]],ExpressionUUID->
  "3331c701-f0d9-41d1-8fe2-3f78a9526c79"],
 ", one can remove the second Hadamard gate on the second qubit by applying \
the Hadamard gate. This leads to the quantum circuit in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MeasurementBasedScheme#992454319"],
 "."
}], "TechNoteText",
 CellID->11463807,ExpressionUUID->"91e9e3d5-623b-479f-bb4c-207322546645"],

