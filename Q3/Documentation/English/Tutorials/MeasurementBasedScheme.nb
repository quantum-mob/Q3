Cell[CellGroupData[{

Cell["Correlation Operator", "Subsection",
 CellID->451438009,ExpressionUUID->"63a68ea4-85b2-4722-b166-98daff514c52"],

Cell[TextData[{
 "The graph states are not only useful as a valuable resource for \
measurement- based quantum computations, but they are also interesting in \
their own right. Graph states exhibit a high degree of entanglement. They \
have been studied extensively for the structure of bi-partite and \
multi-partite entanglement. One can also construct a class of ",
 ButtonBox["quantum error-correction codes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumErrorCorrectionCodes"],
 " based on graph states. It allows for reliable storage and processing of \
quantum information in a fault-tolerant way."
}], "TechNoteText",
 CellID->714921328,ExpressionUUID->"69eadb6a-69ca-40b7-966e-ddf6ec440251"],

Cell[TextData[{
 "All these features of graph states can be attributed to the following \
property: For each vertex ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "2fa02f31-8aee-4587-b6d4-7ea14f980748"],
 " in a graph ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "b248d81e-e756-4e4d-b60b-4067d9e30d7d"],
 ", define an operator"
}], "TechNoteText",
 CellID->1137273780,ExpressionUUID->"41f14de1-e3e4-4b01-b921-bcd683de35fe"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "a"], ":=", 
    RowBox[{
     SubscriptBox["X", "a"], 
     UnderscriptBox["\[CapitalPi]", 
      RowBox[{"b", "\[Element]", 
       SubscriptBox["\[ScriptCapitalN]", "a"]}]], 
     SubscriptBox["Z", "b"]}]}], TraditionalForm]],ExpressionUUID->
  "79130b83-1e36-4987-8821-c5fab37a70df"],
 ","
}], "TechNoteText",
 CellID->901316693,ExpressionUUID->"9e0abd71-6a2d-4101-850b-871ad95e2874"],

Cell[TextData[{
 "where the product is over the set ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalN]", "a"], TraditionalForm]],ExpressionUUID->
  "7c078325-047a-45c9-8992-906b4b142d21"],
 " of all vertices ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "3875f563-05dd-4685-94dc-188d80c5b5a6"],
 " connected to ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "06b24148-1cd5-4f91-a1a3-acc23056642c"],
 ". ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "a"], TraditionalForm]],ExpressionUUID->
  "219e08ca-f2cc-4be4-948c-40a1e5f7d117"],
 " is often called the ",
 StyleBox["correlation operator",
  FontSlant->"Italic"],
 " of vertex ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "0e54cbce-754e-4339-9821-3d03e5338044"],
 ". The graph state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[ScriptCapitalG]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "64f0b05b-ce21-4787-9bb4-77fc22d49f52"],
 " associated with ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "2e4fc353-55b2-4e65-8982-1cdf72abf657"],
 " is the unique simultaneous eigenstate with eigenvalue +1 of every ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "a"], TraditionalForm]],ExpressionUUID->
  "7d501aed-2ba2-4e76-95fd-530aa6189a8a"],
 ". In other words,"
}], "TechNoteText",
 CellID->1404840192,ExpressionUUID->"cea07919-42f7-4ad5-878f-94ec0e863d5a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["C", "a"], 
     TemplateBox[{"\[ScriptCapitalG]"},
      "Ket"]}], "=", 
    TemplateBox[{"\[ScriptCapitalG]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "6de2255f-85d2-4c6f-b51a-f0d3d4921bf7"]
}], "TechNoteText",
 CellID->749559796,ExpressionUUID->"98d3be55-b633-4ea5-9037-87fff70f7031"],

Cell[TextData[{
 "for all vertices ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "8b619988-d095-40ee-aaf8-158539f0ec3d"],
 " in the graph ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "cb5610cc-2a6b-42cc-989b-f82daa65a840"],
 ". The operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "a"], TraditionalForm]],ExpressionUUID->
  "f6b9c7c5-05e5-43ba-9147-97ef57b31759"],
 " are said to stabilize the graph state. The ",
 ButtonBox["stabilizer formalism",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/StabilizerFormalism"],
 " provides powerful tools to exploit stabilizing operators."
}], "TechNoteText",
 CellID->2109866597,ExpressionUUID->"f8947955-049a-4982-bfb2-25a4c1f1e25e"],

