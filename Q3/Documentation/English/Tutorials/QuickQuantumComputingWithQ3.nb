Cell[CellGroupData[{

Cell["Measurements in Q3", "TechNoteSection",
 CellID->616516018,ExpressionUUID->"9920f1c5-b2fe-4b83-bf1a-aff2bdf2fda8"],

Cell["\<\
Q3 supports measurement of any Pauli operators (including tensor products of \
single-qubit Pauli operators).\
\>", "TechNoteText",
 CellID->176117751,ExpressionUUID->"fe288b7d-261e-439e-bbd3-fda9a0d9d906"],

Cell["\<\
As a simple example, consider a three-qubit system in the following state:\
\>", "TechNoteMathCaption",
 CellID->778575491,ExpressionUUID->"076259c0-2e23-4db9-a1e2-3e4ba0a02053"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"in", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Ket", "[", 
      RowBox[{
       RowBox[{"S", "@", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "->", "0"}], "]"}], "+", 
     
     RowBox[{"Ket", "[", 
      RowBox[{
       RowBox[{"S", "@", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "->", "1"}], "]"}]}], 
    ")"}], "/", 
   RowBox[{"Sqrt", "[", "2", "]"}]}]}]], "Input",
 CellLabel->"In[132]:=",
 CellID->900416066,ExpressionUUID->"6eff7348-da45-4d63-b5f7-b986924485bf"],

