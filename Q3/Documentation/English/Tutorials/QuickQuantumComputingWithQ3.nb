Cell[CellGroupData[{

Cell["Quantum States in Q3", "TechNoteSection",
 CellID->2114153471,ExpressionUUID->"5c54c3e8-77cb-4909-8a09-6c80b8d77e2e"],

Cell[TextData[{
 "A ",
 StyleBox["quantum bit",
  FontSlant->"Italic"],
 ", or ",
 StyleBox["qubit",
  FontSlant->"Italic"],
 " for short, is a quantum two-level system. It is the elementary unit of \
quantum computers. Each qubit is associated with a two-dimensional Hilbert \
space (\[TildeEqual] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalC]", "2"], TraditionalForm]],
  ExpressionUUID->"95632951-5871-471a-b35e-faf35e6e7fdb"],
 "). The computational basis of the Hilbert space is denoted by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], ",", 
     TemplateBox[{"1"},
      "Ket"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "6d227537-bb8a-4c12-95a6-10a19a81f7a8"],
 "."
}], "TechNoteText",
 CellID->83665415,ExpressionUUID->"39be8d3b-d146-46bb-bee3-fce9fa1a3cea"],

Cell[TextData[{
 "The Hilbert space associated with a system of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "abe2abd8-4c60-4f0b-9cf3-27ae8bce5267"],
 " qubits is constructed with the tensor product of the Hilbert spaces of \
individual qubits and is isomorphic to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[DoubleStruckCapitalC]", "2"], "\[CircleTimes]", 
     SuperscriptBox["\[DoubleStruckCapitalC]", "2"], "\[CircleTimes]", 
     "\[CenterEllipsis]", "\[CircleTimes]", 
     SuperscriptBox["\[DoubleStruckCapitalC]", "2"]}], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      SuperscriptBox["\[DoubleStruckCapitalC]", "2"], ")"}], 
     RowBox[{"\[CircleTimes]", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "2b2e0d41-2bec-4cdd-8089-65f794278fed"],
 ". The standard tensor-product basis of the Hilbert space is given by"
}], "TechNoteText",
 CellID->312963835,ExpressionUUID->"1870d427-3542-4741-bb48-31d2a92e2dc1"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["s", "1"]},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["s", "2"]},
        "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
       RowBox[{
        TemplateBox[{
          SubscriptBox["s", "n"]},
         "Ket"], ":", 
        SubscriptBox["s", "k"]}]}], "=", "0"}], ",", "1"}], "}"}], 
   TraditionalForm]],ExpressionUUID->"921a8b67-b2f3-4ea6-a3f1-b042ec7c3bfb"],
 "."
}], "DisplayMath",
 CellID->795723342,ExpressionUUID->"ba238fe9-4af4-4e9d-8fed-3eec6fa019ff"],

Cell[TextData[{
 "Any quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "39bc9a7f-b4de-4eb3-b8c4-aa174792afb6"],
 " in the Hilbert space can be expanded in this basis as"
}], "TechNoteText",
 CellID->1341539125,ExpressionUUID->"7f155225-7733-4a9f-9f76-aad7c058d88e"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[{"\[Psi]"},
    "Ket"], "=", 
   RowBox[{
    SubsuperscriptBox["\[Sum]", 
     RowBox[{
      SubscriptBox["s", "1"], "=", "0"}], "1"], 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{
       SubscriptBox["s", "2"], "=", "0"}], "1"], 
     RowBox[{"\[CenterEllipsis]", 
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{
         SubscriptBox["s", "n"], "=", "0"}], "1"], 
       RowBox[{
        RowBox[{
         TemplateBox[{
           SubscriptBox["s", "1"]},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{
           SubscriptBox["s", "2"]},
          "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
         TemplateBox[{
           SubscriptBox["s", "n"]},
          "Ket"]}], 
        SubscriptBox["c", 
         RowBox[{
          SubscriptBox["s", "1"], 
          SubscriptBox["s", "2"], 
          SubscriptBox["\[CenterEllipsis]s", "n"]}]]}]}]}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"54eb2fc6-d514-4ca7-aac4-0c695402a75e"]], \
"DisplayMath",
 CellID->817264022,ExpressionUUID->"df7f3b5b-ea4e-43f8-a289-9acb4546a7c6"],

Cell[TextData[{
 "for some complex coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     SubscriptBox["s", "1"], 
     SubscriptBox["s", "2"], 
     SubscriptBox["\[CenterEllipsis]s", "n"]}]], TraditionalForm]],
  ExpressionUUID->"0b765a16-72ed-4ea7-b128-dbb2b5d59c4b"],
 "."
}], "TechNoteText",
 CellID->451011542,ExpressionUUID->"1f5fe4d7-0b2b-4cb9-bd88-0f68a03c2499"],

Cell[TextData[{
 ButtonBox["Q3: Symbolic Quantum Simulation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 " provides two different ways to represent the computational basis states of \
an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cbce2ac3-09d4-4a2c-a9ba-52a03ae4c951"],
 "-qubit system."
}], "TechNoteText",
 CellID->1681196131,ExpressionUUID->"10a49b4a-9ac6-476f-9c50-51550c628f59"],

Cell[TextData[{
 "Using ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:ref/Ket"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["s", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["s", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    SubscriptBox[
     StyleBox["s", "TI"], 
     StyleBox["n", "TI"]]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a9580c61-4da5-493c-8e91-4de3347c849c"],
 " to represent tensor-product state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["s", "1"]},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{
      SubscriptBox["s", "2"]},
     "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
    TemplateBox[{
      SubscriptBox["s", "n"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "b767b265-33e9-460d-9764-130595e788c9"],
 ". Although it looks simple, this method becomes quickly tedious as the \
number of qubits increases. This method is suitable for a small system of \
qubits."
}], "Item",
 CellID->1421030138,ExpressionUUID->"b85e0511-c4e2-4973-8dcf-aa8fd74b7121"],

Cell[TextData[{
 "Using ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:ref/Ket"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["S"]], "paclet:QuantumMob/Q3/ref/S", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", "1", "]"}], "\[Rule]", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["1", "TR"]]}], ",", 
     RowBox[{
      RowBox[{"S", "[", "2", "]"}], "\[Rule]", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["2", "TR"]]}], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     RowBox[{
      RowBox[{"S", "[", 
       StyleBox["n", "TI"], "]"}], "\[Rule]", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["n", "TI"]]}]}], "|>"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9ef2ab52-e127-41ec-8845-715b6afe22dd"],
 " represent tensor-product state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["s", "1"]},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{
      SubscriptBox["s", "2"]},
     "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
    TemplateBox[{
      SubscriptBox["s", "n"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "e00c3915-d213-4e17-a254-79208a8bd037"],
 ". It may look complicated at the first glance but is more efficient for a \
larger system of qubits."
}], "Item",
 CellID->1087891079,ExpressionUUID->"d3c379ad-8a5e-46a8-8d71-7cd399a9ff44"],

Cell[CellGroupData[{

Cell[TextData[{
 "Method Using ",
 Cell[BoxData[
  RowBox[{"Ket", "[", 
   StyleBox["\[Ellipsis]", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c4cc2781-eebb-4fc8-b0d2-1c754bfce76f"]
}], "Subsection",
 CellID->509594195,ExpressionUUID->"80266833-063e-4723-94c6-397dc445df62"],

Cell[TextData[{
 "In this method, a computational basis state is represented by ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:ref/Ket"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["s", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["s", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "930ad68f-6c50-4700-a37c-0a16ce59136d"],
 "."
}], "TechNoteText",
 CellID->1206425442,ExpressionUUID->"a6087e06-302b-41b8-93f5-805bca678796"],

Cell["\<\
For example, consider a three-qubit system. Here is the standard \
tensor-product basis of the system:\
\>", "TechNoteMathCaption",
 CellID->1039439238,ExpressionUUID->"f84fc465-d466-4981-99ea-be28c7a22d26"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bs", "=", 
  RowBox[{"Basis", "[", "3", "]"}]}]], "Input",
 CellLabel->"In[87]:=",
 CellID->2120640671,ExpressionUUID->"827fc11f-27e2-4ee4-b13f-280a91041b7b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TemplateBox[{
     RowBox[{"0", ",", "0", ",", "0"}]},
    "Ket"], ",", 
   TemplateBox[{
     RowBox[{"0", ",", "0", ",", "1"}]},
    "Ket"], ",", 
   TemplateBox[{
     RowBox[{"0", ",", "1", ",", "0"}]},
    "Ket"], ",", 
   TemplateBox[{
     RowBox[{"0", ",", "1", ",", "1"}]},
    "Ket"], ",", 
   TemplateBox[{
     RowBox[{"1", ",", "0", ",", "0"}]},
    "Ket"], ",", 
   TemplateBox[{
     RowBox[{"1", ",", "0", ",", "1"}]},
    "Ket"], ",", 
   TemplateBox[{
     RowBox[{"1", ",", "1", ",", "0"}]},
    "Ket"], ",", 
   TemplateBox[{
     RowBox[{"1", ",", "1", ",", "1"}]},
    "Ket"]}], "}"}]], "Output",
 CellLabel->"Out[87]=",
 CellID->740725266,ExpressionUUID->"8e514da6-635c-492f-b902-6edb02ee330d"]
}, Open  ]],

Cell[TextData[{
 "Each state in the above basis is displayed in the bra-ket notation. \
Internally, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:ref/Ket"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", "\[Ellipsis]", "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ce6c1e1d-d1e8-4401-8040-104560f10355"],
 " is used:"
}], "TechNoteMathCaption",
 CellID->560272784,ExpressionUUID->"7892f9ee-c9e1-4125-810a-3ec7cc491493"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"InputForm", "[", "bs", "]"}]], "Input",
 CellLabel->"In[88]:=",
 CellID->1936372240,ExpressionUUID->"c4aa8f4a-8fbb-403d-952f-0a104045553b"],

Cell["\<\
{Ket[{0, 0, 0}], Ket[{0, 0, 1}], Ket[{0, 1, 0}], Ket[{0, 1, 1}], Ket[{1, 0, \
0}], 
 Ket[{1, 0, 1}], Ket[{1, 1, 0}], Ket[{1, 1, 1}]}\
\>", "Output",
 CellLabel->"Out[88]//InputForm=",
 CellID->406844003,ExpressionUUID->"c09da538-57dc-4d63-8a28-017c16984bf5"]
}, Open  ]],

Cell["\<\
A state vector is a linear superposition of the standard basis states:\
\>", "TechNoteMathCaption",
 CellID->1607205605,ExpressionUUID->"eb6fafa6-aa44-4f5b-8185-aa5263f16b44"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ket", "=", 
  RowBox[{
   RowBox[{"Ket", "[", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1", ",", "0"}], "}"}], "]"}], "-", 
   RowBox[{"I", "*", 
    RowBox[{"Ket", "[", 
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0"}], "}"}], "]"}]}]}]}]], "Input",
 CellLabel->"In[89]:=",
 CellID->1264528439,ExpressionUUID->"582e2bba-63c9-42ab-afda-c34efc6791ff"],

Cell[BoxData[
 RowBox[{
  TemplateBox[{
    RowBox[{"0", ",", "1", ",", "0"}]},
   "Ket"], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   TemplateBox[{
     RowBox[{"1", ",", "0", ",", "0"}]},
    "Ket"]}]}]], "Output",
 CellLabel->"Out[89]=",
 CellID->239226373,ExpressionUUID->"63b1f52c-9fee-48b2-a532-161be30faee4"]
}, Open  ]],

Cell["\<\
A state vector can be represented by a column vector in the standard \
tensor-product basis:\
\>", "TechNoteMathCaption",
 CellID->632902530,ExpressionUUID->"9d44f10a-2cc7-4f42-bd5f-8102f6f37a4a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vec", "=", 
   RowBox[{"Matrix", "[", "ket", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"vec", "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[90]:=",
 CellID->706318119,ExpressionUUID->"deea5b17-8330-4373-9e1a-3955d4e5d3b9"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", 
   TagBox[GridBox[{
      {"0"},
      {"0"},
      {"1"},
      {"0"},
      {
       RowBox[{"-", "\[ImaginaryI]"}]},
      {"0"},
      {"0"},
      {"0"}
     },
     GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
     GridBoxSpacings->{"Columns" -> {
         Offset[0.27999999999999997`], {
          Offset[0.5599999999999999]}, 
         Offset[0.27999999999999997`]}, "Rows" -> {
         Offset[0.2], {
          Offset[0.4]}, 
         Offset[0.2]}}],
    Column], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {8}, 0, {
     1, {{0, 2}, {{3}, {5}}}, {1, Complex[0, -1]}}]]]]], "Output",
 CellLabel->"Out[91]//MatrixForm=",
 CellID->588263827,ExpressionUUID->"5d971319-b895-416e-bde0-1ac1da5a7d3a"]
}, Open  ]],

