Cell[TextData[{
 "Suppose that you want to measure the Pauli ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "78d55e4e-e4bf-4e6b-8f8f-482beebe81ed"],
 " operator (i.e., S[1,3]) on qubit S[1,$]. From the above state, we expect \
two measurement outcomes 0 and 1 (corresponding to eigenvalues \[PlusMinus]1 \
of S[1,3]) and corresponding post-measurement states with equal probability:"
}], "TechNoteMathCaption",
 CellID->1568116595,ExpressionUUID->"adf1a362-768c-48d2-8d4f-3b52fcf5d3c5"],

