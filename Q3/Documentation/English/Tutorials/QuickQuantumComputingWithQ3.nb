Cell["\<\
In this method, you need to first choose a symbol, say, S, to refer to a set \
of qubits:\
\>", "TechNoteText",
 CellID->941665226,ExpressionUUID->"d17c17dc-b839-42ca-8512-95879a4e2bdb"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[94]:=",
 CellID->1003185436,ExpressionUUID->"e308e54c-0bb7-495c-bc9e-7b78edfcddd2"],

Cell[TextData[{
 "Symbol ",
 StyleBox["S", "Input"],
 " declared as qubit can take ",
 ButtonBox["flavor",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Flavors"],
 " indices in the form ",
 Cell[BoxData[
  RowBox[{"S", "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    StyleBox["\[Mu]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b68e4534-4214-4627-8e5f-1c967d0f466f"],
 ". The preceding flavor indices ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["j", "TI"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["j", "TI"], 
    StyleBox["2", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "83b2fd9e-821e-40b7-945a-a50d416f43b2"],
 " specifies a particular qubit in the class denoted by the symbol ",
 StyleBox["S", "Input"],
 ". The last flavor index ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    StyleBox["\[Mu]", "TR"], "=", "0"}], ",", "1", ",", "2", ",", "3", ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a6166d22-37ca-464c-b51d-b81acbac1346"],
 " refers to the ",
 StyleBox["Pauli operator",
  FontSlant->"Italic"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", ",", "X", ",", "Y", ",", "Z", ",", "\[Ellipsis]"}], 
   TraditionalForm]],ExpressionUUID->"e7c1bcff-6c34-4a1b-a7b8-abd90de79ea9"],
 ", respectively, to be discussed below) on the qubit specified by the \
preceding indices ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["j", "TI"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["j", "TI"], 
    StyleBox["2", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "14f69d2f-d1d6-460d-b726-cb94fe76e784"],
 ". An exceptional case is ",
 Cell[BoxData[
  RowBox[{
   StyleBox["\[Mu]", "TR"], "=", 
   TemplateBox[{
     Cell[
      TextData["$"]], "paclet:QuantumMob/Q3/ref/$", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d57ee3c9-026d-4d45-904e-4c856e59bdd3"],
 ", and ",
 Cell[BoxData[
  RowBox[{"S", "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    TemplateBox[{
      Cell[
       TextData["$"]], "paclet:QuantumMob/Q3/ref/$", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->"InlineFormula"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "054a5b54-5d8f-451a-a788-775e9fdf5945"],
 " refers to the qubit itself (rather than an operator) specified by the \
indices ",
 Cell[BoxData[
  RowBox[{
   SubscriptBox[
    StyleBox["j", "TI"], 
    StyleBox["1", "TR"]], ",", 
   SubscriptBox[
    StyleBox["j", "TI"], 
    StyleBox["2", "TR"]], ",", 
   StyleBox["\[Ellipsis]", "TR"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b6bacdbf-8f5c-4566-ad7e-12d93df3545b"],
 "."
}], "TechNoteText",
 CellID->1812584053,ExpressionUUID->"5395a0b9-5807-4e17-b094-04c2e98899b5"],

Cell["Now, a computational basis state is specified by ", "TechNoteText",
 CellID->982594352,ExpressionUUID->"5c6d7f2a-c2b0-494b-ac46-659b1f8b4442"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:ref/Ket"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         Cell[
          TextData["S"]], "paclet:QuantumMob/Q3/ref/S", 
         "QuantumMob Package Symbol"},
        "PackageLink",
        BaseStyle->"InlineFormula"], "[", 
       RowBox[{"1", ",", "$"}], "]"}], "\[Rule]", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["1", "TR"]]}], ",", 
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{"2", ",", "$"}], "]"}], "\[Rule]", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["2", "TR"]]}], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{
        StyleBox["n", "TI"], ",", "$"}], "]"}], "\[Rule]", 
      SubscriptBox[
       StyleBox["s", "TI"], 
       StyleBox["n", "TI"]]}]}], "|>"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "76b76d02-c996-4bcd-88f8-671101e61016"],
 ". "
}], "TechNoteText",
 CellID->1568302362,ExpressionUUID->"9dc278c6-c119-49c8-8508-f40fe8283ad0"],

Cell[TextData[{
 "For example, the logical basis for qubit ",
 StyleBox["S[1,$]", "Input"],
 " is comprised of these two states:"
