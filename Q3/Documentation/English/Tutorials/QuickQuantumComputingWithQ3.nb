Cell[TextData[{
 "As another example, let us now consider a collective measurement, say, the \
measurement of ",
 Cell[BoxData[
  RowBox[{"Z", "\[CircleTimes]", "Z"}]], "TraditionalForm",ExpressionUUID->
  "bb1e19e4-096d-4397-ae44-eaad16c0b694"],
 ". Suppose that a system of two qubits in the following state."
}], "TechNoteText",
 CellID->818807100,ExpressionUUID->"77273bf0-4d12-4541-aabb-8a924afae32a"],

