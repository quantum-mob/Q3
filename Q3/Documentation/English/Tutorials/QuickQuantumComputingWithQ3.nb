Cell["\<\
Some frequently used quantum circuit elements in the quantum circuit model of \
quantum computation.\
\>", "TechNoteCaption",
 CellID->325847676,ExpressionUUID->"4e26f816-4e33-4e1a-97d9-cf563504c2ff"],

Cell["Consider a simple example of quantum circuit:", "TechNoteMathCaption",
 CellID->2012491076,ExpressionUUID->"429fdad5-0f29-4bd8-a170-74c4c39f6212"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3"}], "}"}], ",", "6"}], "]"}], ",", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "2", "]"}], ",", 
      RowBox[{"S", "[", "3", "]"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[154]:=",
 CellID->1119594515,ExpressionUUID->"e3708dbe-39e3-449e-bed5-5597afd0ac0f"],

