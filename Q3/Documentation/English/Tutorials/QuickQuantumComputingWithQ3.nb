Cell[TextData[{
 "Analyse the possible measurement outcomes, the corresponding probabilities \
and post-measurement states. Here note that outcomes 0 and 1 refer to \
eigenvalues ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "03872921-ee35-4f3c-8dff-78a2265ff421"],
 " of ",
 Cell[BoxData[
  RowBox[{"Z", "\[CircleTimes]", "Z"}]], "TraditionalForm",ExpressionUUID->
  "1f581ce7-f558-49b4-9060-8a6176d380b3"],
 ", respectively. (Recall that any Pauli operator only has eigenvalues ",
 Cell[BoxData[
  RowBox[{"\[PlusMinus]", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1a517c8f-ac1b-4407-8525-18a599a27d95"],
 ".) It is also important to note that the post-measurement states maintains \
the phase coherence inherited from the input state."
}], "TechNoteMathCaption",
 CellID->2124507258,ExpressionUUID->"4445f67b-aae1-4a27-9220-3660922dfdf6"],

