Cell[TextData[{
 "Q3 provides many utilities and mechanism to facilitate the study of quantum \
computation and information. In this document, we explain some basic usages \
of ",
 ButtonBox["Q3: Symbolic Quantum Simulation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 " in the context of quantum computation and quantum information are \
explained."
}], "TechNoteText",
 CellID->1225151763,ExpressionUUID->"995a2d1c-d1db-4578-b655-a8e066e0503c"],

Cell[TextData[{
 "For more advanced applications of ",
 ButtonBox["Q3: Symbolic Quantum Simulation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 ", see the ",
 ButtonBox["Quantum Workbook (2022)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-3-030-91214-7"], None}],
 "."
}], "TechNoteText",
 CellID->1213803964,ExpressionUUID->"ef15bfba-9f2c-4eb9-a970-377992107613"],

