 Cell[BoxData[
  RowBox[{"S", "[", 
   RowBox[{
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["1", "TR"]], ",", 
    SubscriptBox[
     StyleBox["j", "TI"], 
     StyleBox["2", "TR"]], ",", 
    StyleBox["\[Ellipsis]", "TR"], ",", 
    TemplateBox[{
      Cell[
       TextData["Full"]], "paclet:ref/Full"},
