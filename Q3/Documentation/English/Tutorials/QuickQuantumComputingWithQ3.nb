Cell[TextData[{
 "Get the column-vector representation of it.  Here note that ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}], "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", "1", "]"}], ",", 
     RowBox[{"S", "[", "2", "]"}]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cc122ea3-54b6-44ac-ae96-443112b99e3b"],
 " is equivalent to ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", 
     TemplateBox[{
       Cell[
        TextData["$"]], "paclet:ref/$"},
      "RefLink",
      BaseStyle->{"InlineFormula"}]}], "]"}], "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"1", ",", 
       TemplateBox[{
         Cell[
          TextData["$"]], "paclet:ref/$"},
        "RefLink",
        BaseStyle->{"InlineFormula"}]}], "]"}], ",", 
     RowBox[{"S", "[", 
      RowBox[{"2", ",", 
       TemplateBox[{
         Cell[
          TextData["$"]], "paclet:ref/$"},
        "RefLink",
        BaseStyle->{"InlineFormula"}]}], "]"}]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3cd0202e-49ad-45d2-931b-df6a1353c7db"],
 " inside ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Matrix"]], "paclet:QuantumMob/Q3/ref/Matrix", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1f4e7fba-8211-4fd5-bdca-f3b5dcdd8520"],
 ":"
}], "TechNoteMathCaption",
 CellID->1728958045,ExpressionUUID->"15693460-94c9-4c5e-8e1d-f214b614d607"],

