daa008fe50a3"],

Cell[TextData[{
 "The no-cloning theorem dictates that it is impossible to make a copy of an ",
 StyleBox["unknown",
  FontSlant->"Italic"],
 " quantum state. \[OpenCurlyDoubleQuote]You can clone a sheep, but not a \
quantum state,\[CloseCurlyDoubleQuote] Zurek (2000) once declared. (Here, the \
sheep refers to Dolly, cloned by a research group; see Wilmut ",
 StyleBox["et al",
  FontSlant->"Italic"],
 ". (1997).) The theorem was discovered by Wootters and Zurek (1982)."
}], "TechNoteText",
 CellID->2109754189,ExpressionUUID->"0f3b71a6-d8e3-40ae-bcb4-01446e61ade9"],

Cell[TextData[{
 "See also Section 1.3 of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "45bdf7e1-c272-4f6d-adac-517b026a9a75"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"77e66d7d-808c-4b66-8e4a-990c35eed78a"],

Cell[CellGroupData[{

Cell["A Proof", "TechNoteSection",
 CellID->1055628231,ExpressionUUID->"c78fff2f-7084-4345-83ec-29353a5ebb70"],

Cell["\<\
Why is it impossible to make a copy of an unknown quantum state?\
\>", "TechNoteText",
 CellID->971730044,ExpressionUUID->"78967f29-0e43-4f9d-b0be-07ecd57aa887"],

Cell[TextData[{
 "\tSuppose we have a machine that can clone a given unknown quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2f7f223b-c252-4ca6-94d2-705432dbe505"],
 ". The machine would have two quantum registers, the input and target \
registers. The input register is prepared in  ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2aedbc40-f8fb-4617-8eee-07e8f1e6d607"],
 ", and the target register in a reference state, say, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "340a76ff-04c9-4883-bf1e-0f5aa1faca6f"],
 ". The overall state of the total system is a tensor-product state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{"0"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "631aa7f1-4e4a-4076-963b-02a91551e89c"],
 ". Let ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "1ba2a720-749a-46bd-9ee6-53a38bbb6963"],
 " be the unitary operator corresponding to the operation of the copying \
operation. By the hypothesis, we expect that"
}], "TechNoteText",
 CellID->1252526483,ExpressionUUID->"4c5fa7c6-0a2a-4baa-b896-a6ceb26faae7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", 
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}], ")"}], "=", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"\[Psi]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "82874bcc-87d3-408d-9c96-c6005a2ac3b0"],
 " ."
}], "TechNoteText",
 CellID->1278858692,ExpressionUUID->"448c4f4d-fb7d-478e-98fc-705c8ae25ed7"],

Cell[TextData[{
 "Let us apply the operation to two orthogonal states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Alpha]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "5a37ab23-68b2-4bb1-9316-10da374d5f36"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Beta]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "586788b3-9403-449b-aeb7-92e87dc61f6d"],
 ". We have"
}], "TechNoteText",
 CellID->1761697268,ExpressionUUID->"74681eb7-12c7-4087-891a-b376ae3bc8d8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", 
     RowBox[{
      TemplateBox[{"\[Alpha]"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}], ")"}], "=", 
    RowBox[{
     TemplateBox[{"\[Alpha]"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"\[Alpha]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "c9270672-068a-417d-8cde-3cd8d96fb303"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", 
     RowBox[{
      TemplateBox[{"\[Beta]"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}], ")"}], "=", 
    RowBox[{
     TemplateBox[{"\[Beta]"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"\[Beta]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "ef9cab2b-482c-4dea-a5f8-07b5add0447c"],
 " ."
}], "TechNoteText",
 CellID->1488942087,ExpressionUUID->"2ac5033f-5f7e-4982-8803-f02fc04aa761"],

Cell["So far nothing is wrong.", "TechNoteText",
 CellID->22717718,ExpressionUUID->"5a99744d-29de-49a7-9e86-d05b99f1bb0f"],

Cell[TextData[{
 "\tNow, let us apply the operation to a linear superposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"\[Alpha]"},
      "Ket"], "a"}], "+", 
    RowBox[{
     TemplateBox[{"\[Beta]"},
      "Ket"], "b"}]}], TraditionalForm]],ExpressionUUID->
  "f0b698fa-efef-49e9-8b6d-520e2690d208"],
 " with arbitrary (and unknown) complex numbers ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "7ab78a86-28f9-45ae-a55a-6467d7abce1f"],
 " and ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "5872ddce-d819-432d-a4f0-65fcaf4c1908"],
 ". From the linearity of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "858f7516-a43f-464f-b501-903d888d0c03"],
 ", we have"
}], "TechNoteText",
 CellID->1712080907,ExpressionUUID->"2969cd11-2155-43fc-9cdc-a8421e8a075e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         TemplateBox[{"\[Alpha]"},
          "Ket"], "a"}], "+", 
        RowBox[{
         TemplateBox[{"\[Beta]"},
          "Ket"], "b"}]}], ")"}], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}], "]"}], "=", 
    RowBox[{
     RowBox[{"U", "(", 
      RowBox[{
       RowBox[{
        RowBox[{
         TemplateBox[{"\[Alpha]"},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{"0"},
          "Ket"]}], "a"}], "+", 
       RowBox[{
        RowBox[{
         TemplateBox[{"\[Beta]"},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{"0"},
          "Ket"]}], "b"}]}], ")"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        TemplateBox[{"\[Alpha]"},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{"\[Alpha]"},
         "Ket"]}], "a"}], "+", 
      RowBox[{
       RowBox[{
        TemplateBox[{"\[Beta]"},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{"\[Beta]"},
         "Ket"]}], "b"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "6d87e941-c98d-4c3d-9e20-11a9e33fafcb"],
 " ."
}], "TechNoteText",
 CellID->810417796,ExpressionUUID->"c5abd128-d116-4259-9758-8a22ab23dd40"],

Cell["Clearly, the result is different from what we expect,", "TechNoteText",
 CellID->1350608098,ExpressionUUID->"30346caa-0c4d-45d3-9642-c8ae65133d48"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       TemplateBox[{"\[Alpha]"},
        "Ket"], "a"}], "+", 
      RowBox[{
       TemplateBox[{"\[Beta]"},
        "Ket"], "b"}]}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       TemplateBox[{"\[Alpha]"},
        "Ket"], "a"}], "+", 
      RowBox[{
       TemplateBox[{"\[Beta]"},
        "Ket"], "b"}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "24247bbb-9584-4894-b7c0-98c61f99ebcc"],
 " ,"
}], "TechNoteText",
 CellID->768154296,ExpressionUUID->"5d01e070-6775-4a44-8324-6d09398b6b40"],

Cell[TextData[{
 "unless either ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "b86434d0-1180-49dc-9310-d4181a9f50f7"],
 " or ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]],ExpressionUUID->
  "e225893a-4e5a-4876-aeeb-f5423940b871"],
 " vanishes. Therefore, we conclude that it is impossible to copy a quantum \
state."
}], "TechNoteText",
 CellID->1845050755,ExpressionUUID->"222469cb-c6c8-42c2-a3e1-f796f84d8496"],

Cell["\<\
\tThe crucial point in the proof is the linearity of quantum mechanics.\
\>", "TechNoteText",
 CellID->104176605,ExpressionUUID->"7cf9b634-2fe0-49ee-bfff-7806b648d250"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Physical Implications", "TechNoteSection",
 CellID->945263909,ExpressionUUID->"e9d5aa8b-1a15-42df-a92d-545d21a2b29b"],

Cell["\<\
The no-cloning theorem implies various counter-intuitive natures of quantum \
physics.\
\>", "TechNoteText",
 CellID->1630004237,ExpressionUUID->"294c6ebc-89ec-4f03-a51d-6cbcd0e0ac24"],

Cell[TextData[{
 "\tFirst of all, if it were possible, one could produce a bunch of identical \
copies of the same quantum state. Then, measurements of different \
incompatible observables (such as conjugate variables) on the copies would \
reveal precise information regarding the quantum state, violating the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["uncertainty principle"]], 
    "https://en.wikipedia.org/wiki/Uncertainty_principle"},
   "WebLink",
   BaseStyle->{"TechNoteText", FontSlant -> "Italic"}]],ExpressionUUID->
  "0e4f2d66-d44a-44f4-974e-4fe2c0b66614"],
 "."
}], "TechNoteText",
 CellID->342734891,ExpressionUUID->"258c223c-1467-4065-8407-f2810a8e9bd0"],

Cell["\<\
\tCloning of an (unknown) quantum state would also allow faster-than- light \
communication. Furthermore, the no-cloning nature of quantum states is one of \
the key features of quantum mechanics that provide unconditional security in \
quantum communication.\
\>", "TechNoteText",
 CellID->1356795085,ExpressionUUID->"989ad899-f7fb-4838-a0ee-0407d1e26b9b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparison with the CNOT Gate", "TechNoteSection",
 CellID->980962998,ExpressionUUID->"162a07ae-35ae-4280-8b5a-d7b1c989097f"],

Cell[TextData[{
 "One commonly cited feature of the CNOT gate is to \"copy\" computational ",
 StyleBox["basis states",
  FontSlant->"Italic"],
 " of one qubit to other qubits. This sometimes confuses people and they \
think the non-cloning theorem is violated. Here, we illustrate that this is \
not the case."
}], "TechNoteText",
 CellID->1469184494,ExpressionUUID->"9fad4a84-c4f0-4f51-a848-019dc27960e2"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[116]:=",
 CellID->1876547676,ExpressionUUID->"acc9729b-c857-49d9-9b9d-30953e83896b"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", " ", "S"}], "]"}]], "Input",
 CellLabel->"In[117]:=",
 CellID->1959577979,ExpressionUUID->"d7b10b17-5b0a-4ceb-b389-fb47372808bf"],

Cell["\<\
Consider the following quantum circuit consisting of a single CNOT gate.\
\>", "TechNoteMathCaption",
 CellID->20906346,ExpressionUUID->"3c511d8b-4e52-4853-ae85-298adcd6fd72"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{"S", "@", 
      RowBox[{"{", "2", "}"}]}], "]"}], ",", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[118]:=",
 CellID->1328844902,ExpressionUUID->"16c065e6-6989-4252-990c-9e3317d59ba9"],

Cell[BoxData[
 InterpretationBox[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {2, -1}}, {{0, -2}, {2, -2}}}], InsetBox[
     TemplateBox[{"0"},
