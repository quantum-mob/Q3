  QuantumMob`Q3`QuantumCircuit[
   QuantumMob`Q3`PortIn[
    Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 0|>]], 
   QuantumMob`Q3`CNOT[{$CellContext`S[1, QuantumMob`Q3`$] -> 1}, {
     $CellContext`S[2, QuantumMob`Q3`$]}]]]], "Output",
