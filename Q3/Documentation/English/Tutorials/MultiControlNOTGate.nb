     0, -4}, {2, -4}}, {{0, -6}, {2, -6}}, {{0, -7}, {2, -7}}, {{0, -8}, {
     2, -8}}}], {LineBox[{{1, -1}, {1, -2}, {1, -3}, {1, -4}, {1, -8}}], 
     DiskBox[{1, -1}, 0.09], DiskBox[{1, -2}, 0.09], DiskBox[{1, -3}, 0.09], 
