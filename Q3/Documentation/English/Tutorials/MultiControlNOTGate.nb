Cell["\<\
Calculate the quantum circuit elements required for the implementation.\
\>", "TechNoteText",
 CellID->1129767582,ExpressionUUID->"21d7abc1-623c-49e2-8fda-9a15cc336843"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tofa", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Toffoli", "[", 
      RowBox[{
       RowBox[{"S", "[", 
        RowBox[{"$n", "-", "j", "+", "1"}], "]"}], ",", 
       RowBox[{"S", "[", 
        RowBox[{"$n", "+", "$m", "-", "j", "+", "1"}], "]"}], ",", 
       RowBox[{"S", "[", 
        RowBox[{"tt", "-", "j", "+", "1"}], "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "$m"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tofb", "=", 
   RowBox[{"Toffoli", "[", 
    RowBox[{
     RowBox[{"S", "[", "1", "]"}], ",", 
     RowBox[{"S", "[", "2", "]"}], ",", 
     RowBox[{"S", "[", 
      RowBox[{"$n", "+", "1"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tofc", "=", 
   RowBox[{"Rest", "@", "tofa"}]}], ";"}]}], "Input",
 CellLabel->"In[128]:=",
 CellID->1456813865,ExpressionUUID->"57998680-8632-426a-9553-2e3510b4b268"],

Cell["\<\
Here is the quantum circuit representation of the implementation. The second \
part after the vertical dashed line is to restore the additional qubits to \
their original states.\
\>", "TechNoteText",
 CellID->1842901266,ExpressionUUID->"fae76011-4d54-44a4-a54c-6d1a39c1a7cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"new", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"Sequence", "@@", 
    RowBox[{"Flatten", "@", 
     RowBox[{"{", 
      RowBox[{"tofa", ",", "tofb", ",", 
       RowBox[{"Reverse", "@", "tofa"}], ",", "\"\<Separator\>\"", ",", 
       "tofc", ",", "tofb", ",", 
       RowBox[{"Reverse", "@", "tofc"}]}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[131]:=",
 CellID->21678645,ExpressionUUID->"e1f980d5-a92b-4805-8b21-4ae83d33cc31"],

