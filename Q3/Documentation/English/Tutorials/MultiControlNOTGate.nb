Cell[CellGroupData[{

Cell["Implementations", "TechNoteSection",
 CellID->1310796799,ExpressionUUID->"02e9d444-ca36-44ab-8578-e93ff4343ee7"],

Cell["\<\
Let us now discuss how to implement the multi-control NOT gate in terms of \
the elementary gates. Here we introduce two methods that scale quadratically \
and linearly, respectively, with the number of qubits.\
\>", "TechNoteText",
 CellID->1318441602,ExpressionUUID->"1fc0cbdc-f71c-486d-a63a-2041012f1930"],

Cell[TextData[{
 "\tFirst, let us generalize the implementation in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#219567465"],
 " and ",
 ButtonBox["Figure 3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#444082079"],
 " of the Toffoli gate. Consider an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ef4ee240-e7df-4766-b1ad-ea5e9d32341c"],
 "-control NOT gate, and examine the quantum circuit on the right-hand side \
of ",
 ButtonBox["Figure 4",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#1325443976"],
 ". In the center piece between the dashed vertical lines of the quantum \
circuit, the unitary gate ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "f4b03979-3362-4079-870d-feca4c4a3c1f"],
 " operates only when either (not both) of all the first ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Minus]", "1"}], TraditionalForm]],ExpressionUUID->
  "ab529976-745b-41c8-b2c3-8e2746d874ca"],
 " control qubits or the last control qubit is set to |1\:27e9. Therefore, \
putting ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", ":=", 
    SqrtBox["X"]}], TraditionalForm]],ExpressionUUID->
  "45a2081f-9eac-467a-9168-a14ed2703209"],
 " and combining this piece of quantum circuit with a controlled-",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "66bdae0b-c987-478f-97ce-8cca94658c20"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"n", "\[Minus]", "1"}], ")"}], TraditionalForm]],ExpressionUUID->
  "4d5beea3-4dde-4ab2-a432-e4c590259615"],
 "-control ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "3a27a68d-b236-47e8-b697-f3bc195e1e6e"],
 " gate lead to the desired ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "51ae54de-3467-4dce-acca-6494e975e8d9"],
 "-control NOT gate. This implementation includes two ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"n", "\[Minus]", "1"}], ")"}], TraditionalForm]],ExpressionUUID->
  "87999caa-8602-404b-a5cd-d556be8a41e2"],
 "-control NOT gates, each of which requires, at least, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"dab683a4-a541-4b22-8a66-82ad5b7a58b5"],
 " elementary gates. It should recursively implement an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"n", "\[Minus]", "1"}], ")"}], TraditionalForm]],ExpressionUUID->
  "08d8ee1b-fefa-4a94-b8ae-78d4ad1ea90c"],
 "-control ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "4512d942-c322-471f-8678-803358721a4a"],
 " gate as well, which requires, at least, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"cd13eed8-f55f-4957-80a4-3ae1e986adca"],
 " elementary gates at each recursion. Overall, this implementation requires ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    SuperscriptBox["n", "2"], ")"}], TraditionalForm]],ExpressionUUID->
  "ea455136-9996-4508-9009-0832a2d243d3"],
 " elementary gates."
}], "TechNoteText",
 CellID->1019079269,ExpressionUUID->"aabdb257-8d7e-482f-9a2a-0dd9e6c21882"],

Cell[TextData[{
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {2, -1}}, {{0, -2}, {2, -2}}, {{0, -3}, {2, -3}}, {{
     0, -4}, {2, -4}}, {{0, -6}, {2, -6}}}], {
     LineBox[{{1, -1}, {1, -2}, {1, -3}, {1, -4}, {1, -6}}], 
     DiskBox[{1, -1}, 0.09], DiskBox[{1, -2}, 0.09], DiskBox[{1, -3}, 0.09], 
