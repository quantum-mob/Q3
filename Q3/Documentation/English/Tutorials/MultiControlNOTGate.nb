Cell[TextData[{
 "The multi - control NOT gate is similar to the ",
 ButtonBox["CNOT gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/TwoQubitGates#1585062394"],
 " on two qubits, but it is controlled by a register of multiple qubits \
rather than by a single qubit . Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"c"},
     "Ket"], "\[Congruent]", 
    TemplateBox[{
      RowBox[{
        SubscriptBox["c", "1"], 
        SubscriptBox["c", "2"], 
        SubscriptBox["\[CenterEllipsis]c", "n"]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "fb81dc3c-ae0c-4fb8-80ca-b70476640751"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"t"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "68ad0e0f-2f51-4b27-bd97-dfde8b2b79b6"],
 " be the computational basis states of the control register and the target \
qubit, respectively . Under the multi-control NOT gate, they transform as"
}], "TechNoteText",
 CellID->1939700080,ExpressionUUID->"d33ae0e0-2259-44fd-9c46-726b34f728b6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"c"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"t"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"c"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["c", "1"], 
             SubscriptBox["c", "2"], 
             SubscriptBox["\[CenterEllipsis]c", "n"]}], ")"}], 
         "\[CirclePlus]", "t"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "704cb88e-be8f-4946-ba01-650a959e52ea"]
}], "TechNoteText",
 CellID->2119921909,ExpressionUUID->"f52977d4-34f1-4d2b-bf90-33b49a225c71"],

Cell["or  equivalently,", "TechNoteText",
 CellID->17795684,ExpressionUUID->"ca17fb6d-2a2e-4f91-894c-c79bfc5b5429"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"c"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"t"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"c"},
      "Ket"], "\[CircleTimes]", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["X", 
        RowBox[{
         SubscriptBox["c", "1"], 
         SubscriptBox["c", "2"], 
         SubscriptBox["\[CenterEllipsis]c", "n"]}]], 
       TemplateBox[{"t"},
        "Ket"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "b573ef46-529f-42e2-bb98-bcd66e04c03c"]
}], "TechNoteText",
 CellID->1363028051,ExpressionUUID->"52f30f35-3e69-4850-906f-475df767e030"],

Cell["\<\
The logical bit value of the target qubit flips if and only if every qubit in \
the control register is set to |1\:27e9. In the quantum circuit model, a \
multi-control NOT gate is depicted as\
\>", "TechNoteText",
 CellID->697796650,ExpressionUUID->"670d9a60-cccd-4fec-ab8c-bc0c42e713bd"],

Cell[BoxData[
 GraphicsBox[{
   {Dashing[{Small, Small}], LineBox[{}]}, 
   LineBox[{{{0, -1}, {2, -1}}, {{0, -2}, {2, -2}}, {{0, -3}, {2, -3}}, {{
    0, -4}, {2, -4}}}], {LineBox[{{1, -1}, {1, -2}, {1, -3}, {1, -4}}], 
    DiskBox[{1, -1}, 0.09], DiskBox[{1, -2}, 0.09], 
    DiskBox[{1, -3}, 0.09], {CircleBox[{1, -4}, 0.26666666666666666], 
     LineBox[{{{0.7333333333333334, -4}, {1.2666666666666666`, -4}}, {{
        1, -4.266666666666667}, {1, -3.7333333333333334`}}}]}}},
  AxesStyle->Large,
  FrameStyle->Large,
  ImagePadding->{{23.400000000000002`, 23.400000000000002`}, {5, 5}},
  ImageSize->118.8,
  PlotRangePadding->Scaled[0.025]]], "TechNoteText",
 TextAlignment->-0.5,
 CellID->1081043462,ExpressionUUID->"db2859a4-b3ff-4cc9-877b-8eefa684dc3d"],

Cell[TextData[{
 "Evidently, the multi-control NOT gate is a special case of the ",
 ButtonBox["multi-control unitary gates",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlUnitaryGates"],
 ", but it is worth a separate discussion for a couple of reasons. First of \
all, efficient implementations of ",
 ButtonBox["multi-control unitary gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlUnitaryGates"],
 " heavily rely on implementation of the multi-control NOT gate. Furthermore, \
the multi-control NOT gate plays a key role when one converts the ",
 ButtonBox["two-level unitary transformation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GivensRotation"],
 " on more than two qubits. This is due to the column and row exchange \
feature of the multi-control NOT gate."
}], "TechNoteText",
 CellID->1063994936,ExpressionUUID->"168d4a31-a3c6-4dd9-bfaa-2d903a85aa21"],

Cell[TextData[{
 "See also Section 2.3 of the ",
