     LineBox[{{1, -1}, {1, -2}, {1, -3}}], DiskBox[{1, -1}, 0.09], 
     LineBox[{{{0.91, -2.09}, {1.09, -1.91}}, {{0.91, -1.91}, {
      1.09, -2.09}}}], 
     LineBox[{{{0.91, -3.09}, {1.09, -2.91}}, {{0.91, -2.91}, {
      1.09, -3.09}}}]}},
   AxesStyle->Large,
   FrameStyle->Large,
