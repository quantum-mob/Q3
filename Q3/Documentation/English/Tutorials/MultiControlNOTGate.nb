   "WebLink",
   BaseStyle->{"Text"}]],ExpressionUUID->
  "df6db854-0192-4e22-87f3-8c8002f6a29d"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"32ca5a6d-28a6-4de3-9f3b-0f6454295aff"],

