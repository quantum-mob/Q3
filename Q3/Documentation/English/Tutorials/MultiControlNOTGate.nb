Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". A quantum circuit to get the cumulative products of bit values of \
qubits."
}], "TechNoteCaption",
 CellID->68440578,ExpressionUUID->"071522c3-b0fc-4449-9ee8-15c1d15360ec"],

Cell[TextData[{
 "\tAn interesting application of the Toffoli gate is to achieve the \
cumulative products (or bit-wise AND) of the bit values of qubits (to be \
compared with the sum (or bit-wise OR) of bit values using the ",
 ButtonBox["CNOT gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/TwoQubitGates#977674470"],
 "). Consider a control register of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "7a7b3904-e10a-4e92-850f-313098fee46c"],
 " qubits and a target register of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Minus]", "1"}], TraditionalForm]],ExpressionUUID->
  "9bc00739-c84f-43ae-8a67-8c8c5c9d707c"],
 " qubits, and denote the respective computational basis states by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["x", "2"], ",", "\[CenterEllipsis]", ",", 
       SubscriptBox["x", "n"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "fd45d99a-d272-4725-9c53-691efee0f7ae"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox["y", "1"], ",", 
       SubscriptBox["y", "2"], ",", "\[CenterEllipsis]", ",", 
       SubscriptBox["y", 
        RowBox[{"n", "-", "1"}]]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "4479fd4f-0a75-4277-8cc7-1d7115c1700e"],
 ". Combine the Toffoli gates consecutively as in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#68440578"],
 ". By definition of the Toffoli gate, the logical value ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "1"], TraditionalForm]],ExpressionUUID->
  "1646ead3-e481-44b4-996c-ef1583cfda48"],
 " of the first target qubit is flipped if and only if both the first and \
second control qubit are set to |1\:27e9, that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["x", "1"], 
     SubscriptBox["x", "2"]}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "a4bda66f-b616-4e3a-bd15-40b8d2366227"],
 ". On the other hand, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "2"], TraditionalForm]],ExpressionUUID->
  "a1daba48-f39c-4708-81c6-466aeec141ce"],
 " is flipped only when the first three qubits in the control register are \
all set to |1\:27e9, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["x", "1"], 
     SubscriptBox["x", "2"], 
     SubscriptBox["x", "3"]}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "54bbb5e0-1ed4-4135-93cb-e81c828d9445"],
 ". This pattern continues down the target register so that"
}], "TechNoteText",
 CellID->165756236,ExpressionUUID->"8697de62-acad-453f-b1b4-79ad5d2b97b7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["y", "k"]},
     "Ket"], "\[RightTeeArrow]"}], TraditionalForm]],ExpressionUUID->
  "4c28abb1-eb0c-4226-afa9-bf59c277fa57"],
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       RowBox[{
         SubscriptBox["x", "1"], 
         SubscriptBox["x", "2"], 
         SubscriptBox["\[CenterEllipsis]x", "n"]}], "\[CirclePlus]", 
       SubscriptBox["y", "k"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "d536e27e-839b-4d0a-a11c-8f16f83c54b7"]
}], "TechNoteText",
 CellID->614877646,ExpressionUUID->"f4315426-6e83-45fb-b2f8-1cfbb5721546"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", " ", 
    RowBox[{"n", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "6dc30cde-1c37-488c-82dd-e7bfc37a16ea"],
 " as in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#68440578"],
 ". This feature of the Toffoli gate provides a powerful method to \
efficiently implement multi-control NOT gates with a larger control register \
(see below)."
}], "TechNoteText",
 CellID->1610480617,ExpressionUUID->"c040bf1f-db05-4de3-9223-4409c5f7c934"],

Cell[TextData[{
 "\tApparently, the Toffoli gate is a three-qubit unitary gate. How can one \
implement it using only single-qubit or two-qubit elementary gates? Consider \
the quantum circuit in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#219567465"],
 " consisting of two CNOT gates and a controlled-unitary gate,"
}], "TechNoteText",
 CellID->1661355694,ExpressionUUID->"f9af739c-74b6-4d0c-958c-3f263a944c40"],

Cell[TextData[{
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {4, -1}}, {{0, -2}, {4, -2}}, {{0, -3}, {4, -3}}}], {
     LineBox[{{1, -1}, {1, -2}}], 
     DiskBox[{1, -1}, 0.09], {CircleBox[{1, -2}, 0.26666666666666666], 
      LineBox[{{{0.7333333333333334, -2}, {1.2666666666666666`, -2}}, {{
         1, -2.2666666666666666`}, {1, -1.7333333333333334`}}}]}}, {
     LineBox[{{2, -2}, {2, -3}}], DiskBox[{2, -2}, 0.09], 
     {GrayLevel[1], EdgeForm[GrayLevel[0]], 
      RectangleBox[{1.6, -3.4}, {2.4, -2.6}]}, InsetBox[
      StyleBox["\<\"\\!\\(\\*SuperscriptBox[\\(V\\), \\(\[Dagger]\\)]\\)\"\>",
       
       StripOnInput->False,
       FontSize->Scaled[0.1],
       FontWeight->"Light",
       FontSlant->Italic], {2, -3}, ImageScaled[{0.5, 0.5}]]}, {
     LineBox[{{3, -1}, {3, -2}}], 
     DiskBox[{3, -1}, 0.09], {CircleBox[{3, -2}, 0.26666666666666666], 
      LineBox[{{{2.7333333333333334`, -2}, {3.2666666666666666`, -2}}, {{
         3, -2.2666666666666666`}, {3, -1.7333333333333334`}}}]}}},
   AxesStyle->Large,
   FrameStyle->Large,
   ImagePadding->{{23.400000000000002`, 23.400000000000002`}, {5, 5}},
   ImageSize->190.79999999999998`,
   PlotRangePadding->Scaled[0.025]]],ExpressionUUID->
  "f88a7df1-79ae-4a48-a8f6-9551e8fe991e"],
 "."
}], "Picture",
 TextAlignment->-0.5,
 CellID->1123608559,ExpressionUUID->"345ab5ee-0c58-4519-9811-8f754066adf7"],

Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ". Conditional-unitary gate. The unitary operator ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "01d5eecf-7b58-4993-a6f1-6c2c2a6cdd44"],
 " takes effects only if either (but not both) of the first and second qubit \
is set to ",
 Cell[BoxData[
  TemplateBox[{"1"},
   "Ket"]],ExpressionUUID->"04536150-3fa2-4096-a89f-aaf165cee5f6"],
 "."
}], "TechNoteCaption",
 CellID->219567465,ExpressionUUID->"eccf521b-cd33-4dc1-b75a-5ab9b97fb4bd"],

Cell[TextData[{
 "The unitary operator ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "a437d80e-faff-48a1-a4ad-2cc01af2c078"],
 " takes effect only when either (but not both) of the two control qubits is \
set to |1\:27e9. Therefore, combining this quantum circuit with two \
controlled-",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "274e283b-c91e-47e9-aa7d-a16ddde1b5b0"],
 " gates controlled by the first and second control qubit, respectively, \
leads to the two-control ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", "2"], TraditionalForm]],ExpressionUUID->
  "c2f03d20-fd2f-42d4-a0f4-c3d523b56ccf"],
 " gate, where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", "2"], TraditionalForm]],ExpressionUUID->
  "0364c3ad-89b6-4529-9edc-871fb5d5c3df"],
 " operates only when both control qubits are set to |1\:27e9, as in ",
 ButtonBox["Figure 3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#444082079"],
 "."
}], "TechNoteText",
 CellID->1533653083,ExpressionUUID->"efdf7883-ee4f-46e9-88b9-870fbedfbf39"],

Cell[TextData[{
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {8, -1}}, {{0, -2}, {8, -2}}, {{0, -3}, {8, -3}}}], {
     LineBox[{{1, -2}, {1, -3}}], DiskBox[{1, -2}, 0.09], 
     {GrayLevel[1], EdgeForm[GrayLevel[0]], 
      RectangleBox[{0.6, -3.4}, {1.4, -2.6}]}, InsetBox[
      StyleBox["\<\"V\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.05],
       FontWeight->"Light",
       FontSlant->Italic], {1, -3}, ImageScaled[{0.5, 0.5}]]}, 
    {Dashing[{0, Small}], 
     LineBox[NCache[{{2, Rational[-7, 2]}, {2, Rational[-1, 2]}}, {{
        2, -3.5}, {2, -0.5}}]]}, {LineBox[{{3, -1}, {3, -2}}], 
     DiskBox[{3, -1}, 0.09], {CircleBox[{3, -2}, 0.26666666666666666], 
      LineBox[{{{2.7333333333333334`, -2}, {3.2666666666666666`, -2}}, {{
         3, -2.2666666666666666`}, {3, -1.7333333333333334`}}}]}}, {
     LineBox[{{4, -2}, {4, -3}}], DiskBox[{4, -2}, 0.09], 
     {GrayLevel[1], EdgeForm[GrayLevel[0]], 
      RectangleBox[{3.6, -3.4}, {4.4, -2.6}]}, InsetBox[
      StyleBox["\<\"\\!\\(\\*SuperscriptBox[\\(V\\), \\(\[Dagger]\\)]\\)\"\>",
       
       StripOnInput->False,
       FontSize->Scaled[0.05],
       FontWeight->"Light",
       FontSlant->Italic], {4, -3}, ImageScaled[{0.5, 0.5}]]}, {
     LineBox[{{5, -1}, {5, -2}}], 
     DiskBox[{5, -1}, 0.09], {CircleBox[{5, -2}, 0.26666666666666666], 
      LineBox[{{{4.733333333333333, -2}, {5.266666666666667, -2}}, {{
         5, -2.2666666666666666`}, {5, -1.7333333333333334`}}}]}}, 
    {Dashing[{0, Small}], 
     LineBox[NCache[{{6, Rational[-7, 2]}, {6, Rational[-1, 2]}}, {{
        6, -3.5}, {6, -0.5}}]]}, {LineBox[{{7, -1}, {7, -3}}], 
