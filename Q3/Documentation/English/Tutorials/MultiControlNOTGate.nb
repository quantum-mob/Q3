Cell[TextData[{
 StyleBox["Figure 5",
  FontWeight->"Bold"],
 ". An implementation of the four-control NOT gate using eight Toffoli gates. \
For an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b20c5deb-0b7a-44d1-a134-6caf43966789"],
 "-control NOT gate, it requires ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"fde68820-092e-4b51-87d7-af1f17623030"],
 " elementary gates, and there must be ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Minus]", "2"}], TraditionalForm]],ExpressionUUID->
  "84815def-a100-4a70-83ed-f99fbd8df1b9"],
 " other qubits available."
}], "TechNoteCaption",
 CellID->469427665,ExpressionUUID->"d8ba5a8b-13a8-4bc8-81ff-95c33b256d74"],

Cell[TextData[{
 "\tThe latter implementation of a multi-control NOT gate uses additional \
qubits not directly involved in the gate operation itself. It is emphasized \
that the quantum states of the extra qubits should not be confused with the \
so-called \[OpenCurlyDoubleQuote]ancillary qubits\[CloseCurlyDoubleQuote] in \
the sense that they do not have to be initialized in a certain fixed quantum \
state and their state is not altered. The desired gate operation is performed \
properly regardless of the initial state of the extra qubits and their \
quantum state is restored after the gate operation. This is because we have \
put the second part after the vertical dashed line in the quantum circuit in ",
 ButtonBox["Figure 5",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#469427665"],
 "."
}], "TechNoteText",
 CellID->648856388,ExpressionUUID->"040509e6-ccb7-4bc8-b2fc-5e3ee7deaf7d"],

Cell[CellGroupData[{

Cell["Demonstration", "Subsection",
 CellID->1532488944,ExpressionUUID->"cbbc727d-8750-445e-87d3-d3e4de881fcf"],

Cell["\<\
For demonstration, consider an implementation of a 5-control NOT gate using 3 \
additional qubits.\
\>", "TechNoteText",
 CellID->1225558842,ExpressionUUID->"38b2adc8-b95f-4fc3-bddc-9b077e3bd4fd"],

