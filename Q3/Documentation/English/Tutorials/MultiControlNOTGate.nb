    $CellContext`S[3, QuantumMob`Q3`$]], 
   QuantumMob`Q3`CNOT[{$CellContext`S[3, QuantumMob`Q3`$] -> 1}, {
     $CellContext`S[2, QuantumMob`Q3`$]}]]]], "Output",
 CellLabel->"Out[118]=",
