 CellID->1451799117,ExpressionUUID->"68fc206e-1254-4854-9dbd-7020bac5140e"],

Cell["This is the quantum circuit of a 5-control NOT gate.", "TechNoteText",
 CellID->1953296438,ExpressionUUID->"bd5b7a30-5b20-4f34-ba5e-4db7c4e523c3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "cc", "]"}], ",", 
      RowBox[{"S", "[", "tt", "]"}]}], "]"}], ",", 
    RowBox[{"\"\<Visible\>\"", "\[Rule]", 
     RowBox[{"S", "[", "aa", "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[127]:=",
 CellID->678562205,ExpressionUUID->"2a647a99-01ee-429a-a5b1-772f3c6d1524"],

Cell[BoxData[
 InterpretationBox[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {2, -1}}, {{0, -2}, {2, -2}}, {{0, -3}, {2, -3}}, {{
     0, -4}, {2, -4}}, {{0, -5}, {2, -5}}, {{0, -6}, {2, -6}}, {{0, -7}, {
     2, -7}}, {{0, -8}, {2, -8}}, {{0, -9}, {2, -9}}}], {
     LineBox[{{1, -1}, {1, -2}, {1, -3}, {1, -4}, {1, -5}, {1, -9}}], 
     DiskBox[{1, -1}, 0.09], DiskBox[{1, -2}, 0.09], DiskBox[{1, -3}, 0.09], 
     DiskBox[{1, -4}, 0.09], 
