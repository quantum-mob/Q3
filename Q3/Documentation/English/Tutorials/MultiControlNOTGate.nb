      RectangleBox[{0.6, -3.4}, {1.4, -2.6}]}, InsetBox[
      StyleBox["\<\"\\!\\(\\*SuperscriptBox[\\(V\\), \\(2\\)]\\)\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.2],
       FontWeight->"Light",
       FontSlant->Italic], {1, -3}, ImageScaled[{0.5, 0.5}]]}},
