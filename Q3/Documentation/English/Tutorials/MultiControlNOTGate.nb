        2, -6.5}, {2, -0.5}}]]}, {
     LineBox[{{3, -1}, {3, -2}, {3, -3}, {3, -4}}], DiskBox[{3, -1}, 0.09], 
     DiskBox[{3, -2}, 0.09], 
     DiskBox[{3, -3}, 0.09], {CircleBox[{3, -4}, 0.26666666666666666], 
      LineBox[{{{2.7333333333333334`, -4}, {3.2666666666666666`, -4}}, {{
         3, -4.266666666666667}, {3, -3.7333333333333334`}}}]}}, {
     LineBox[{{4, -4}, {4, -6}}], DiskBox[{4, -4}, 0.09], 
     {GrayLevel[1], EdgeForm[GrayLevel[0]], 
      RectangleBox[{3.6, -6.4}, {4.4, -5.6}]}, InsetBox[
      StyleBox["\<\"\\!\\(\\*SuperscriptBox[\\(V\\), \\(\[Dagger]\\)]\\)\"\>",
       
       StripOnInput->False,
       FontSize->Scaled[0.05],
       FontWeight->"Light",
       FontSlant->Italic], {4, -6}, ImageScaled[{0.5, 0.5}]]}, {
     LineBox[{{5, -1}, {5, -2}, {5, -3}, {5, -4}}], DiskBox[{5, -1}, 0.09], 
     DiskBox[{5, -2}, 0.09], 
     DiskBox[{5, -3}, 0.09], {CircleBox[{5, -4}, 0.26666666666666666], 
      LineBox[{{{4.733333333333333, -4}, {5.266666666666667, -4}}, {{
         5, -4.266666666666667}, {5, -3.7333333333333334`}}}]}}, 
    {Dashing[{0, Small}], 
     LineBox[NCache[{{6, Rational[-13, 2]}, {6, Rational[-1, 2]}}, {{
        6, -6.5}, {6, -0.5}}]]}, {
     LineBox[{{7, -1}, {7, -2}, {7, -3}, {7, -6}}], DiskBox[{7, -1}, 0.09], 
     DiskBox[{7, -2}, 0.09], DiskBox[{7, -3}, 0.09], 
     {GrayLevel[1], EdgeForm[GrayLevel[0]], 
      RectangleBox[{6.6, -6.4}, {7.4, -5.6}]}, InsetBox[
      StyleBox["\<\"V\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.05],
       FontWeight->"Light",
       FontSlant->Italic], {7, -6}, ImageScaled[{0.5, 0.5}]]}},
   AxesStyle->Large,
   FrameStyle->Large,
   ImagePadding->{{23.400000000000002`, 23.400000000000002`}, {1, 1}},
   ImageSize->334.8,
   PlotRange->NCache[{
      Rational[-13, 2], 
      Rational[-1, 2]}, {-6.5, -0.5}],
   PlotRangePadding->Scaled[0.025]]],ExpressionUUID->
  "52a3303d-32f4-4a8b-ac35-63078d1e546b"]
}], "Picture",
 PageWidth->DirectedInfinity[1],
 CellID->403969849,ExpressionUUID->"85c7e7fa-7083-4487-bef2-f01f95f377c4"],

Cell[TextData[{
 StyleBox["Figure 4",
  FontWeight->"Bold"],
 ". An implementation of the four-control NOT gate, where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", ":=", 
    SqrtBox["X"]}], TraditionalForm]],ExpressionUUID->
  "64a2dd8d-dc20-4d5a-a2b6-035c0ba4739b"],
 ". For an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "601190e7-665a-45a7-bf0f-252455dbb433"],
 "-control NOT gate, it requires ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    SuperscriptBox["n", "2"]}], TraditionalForm]],ExpressionUUID->
  "7bc88c2d-ecd9-49a5-a141-e946c5315fb2"],
 ") elementary gates."
}], "TechNoteCaption",
 CellID->1325443976,ExpressionUUID->"e6ff990b-e803-404d-b909-b05dd497adaa"],

Cell[TextData[{
 "\tNext, suppose that in the register, there are ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Minus]", "2"}], TraditionalForm]],ExpressionUUID->
  "ae1fa053-7038-4fb3-b474-b194bf21de8d"],
 " or more additional qubits that are not directly involved in the gate \
operation itself. In this case, one can use the properties of the Toffoli \
gate illustrated previously in Figure 1 and efficiently implement the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "2c2a5a38-2321-417c-8ee5-ad4cf4942633"],
 "-control NOT gate using ",
 Cell[BoxData[
  FormBox[
   RowBox[{"4", 
    RowBox[{"(", 
     RowBox[{"n", "\[Minus]", "2"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"0879ba31-4c4e-4847-9daf-087c82b2f1d2"],
 " Toffoli gates. This is shown in the quantum circuit on the right-hand side \
of ",
 ButtonBox["Figure 5",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/MultiControlNOTGate#469427665"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "4"}], TraditionalForm]],ExpressionUUID->
  "42ff3658-bc9f-411a-ac17-cd6dbcb021c0"],
 " (Barenco et al., 1995). Since each Toffoli gate requires 5 elementary \
gates, the overall cost of this implementation scales as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", 
    RowBox[{"(", "n", ")"}]}], TraditionalForm]],ExpressionUUID->
  "dc6e716b-5bb2-493b-b66e-6932092fa9d9"],
 "."
}], "TechNoteText",
 CellID->479179652,ExpressionUUID->"c12b1703-0327-49b1-87a8-eb62925de794"],

