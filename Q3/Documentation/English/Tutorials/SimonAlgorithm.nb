 CellID->1834146860,ExpressionUUID->"8d9e4e39-069a-4363-ad32-5879fbfc850b"],

Cell["\<\
This is a function consistent with the above secrete bit string:\
\>", "TechNoteText",
 CellID->1526006982,ExpressionUUID->"18645166-cf08-496a-aaaa-1bb6cc03844f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "f", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "0", "]"}], "=", 
   RowBox[{
    RowBox[{"f", "[", "6", "]"}], "=", "3"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "1", "]"}], "=", 
   RowBox[{
    RowBox[{"f", "[", "7", "]"}], "=", "7"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "2", "]"}], "=", 
   RowBox[{
    RowBox[{"f", "[", "4", "]"}], "=", "4"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "3", "]"}], "=", 
   RowBox[{
    RowBox[{"f", "[", "5", "]"}], "=", "1"}]}], ";"}]}], "Input",
 CellLabel->"In[104]:=",
 CellID->1756430455,ExpressionUUID->"6ac74d73-9482-45ea-ae24-6c2a8350546b"],

Cell["\<\
Here is an implementation of the corresponding quantum oracle:\
\>", "TechNoteText",
 CellID->221853317,ExpressionUUID->"17d216f4-3ac8-4f90-989d-0e2a4c517231"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cc", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
