Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". A quantum circuit to implement Simon's algorithm."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->1144344941,ExpressionUUID->"78d1e8b0-b4b0-4935-9433-454fe31d3248"],

Cell[TextData[{
 "The quantum circuit in Figure 1 summarizes Simon\[CloseCurlyQuote]s \
algorithm. The first ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "87db414e-ad16-437b-92dc-657d83455f8e"],
 " gate on the native register transforms the input state of the whole system \
as"
}], "TechNoteText",
 CellID->435207388,ExpressionUUID->"eda844fe-2867-41d4-861f-13d03da6cb57"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], 
    OverscriptBox["\[RightArrow]", 
     SuperscriptBox["H", 
      RowBox[{"\[CircleTimes]", "n"}]]], 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "8332c528-13d4-4448-9d0b-ffcdda8d2b62"],
 "."
}], "TechNoteText",
 CellID->1976242829,ExpressionUUID->"4132483e-4219-4deb-9418-39a35988e468"],

Cell[TextData[{
 "The ",
 ButtonBox["quantum oracle",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle"],
 " makes a copy of the image ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"f", "(", "x", ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8f6050e2-e2cf-4d92-ab22-e7994e513e41"],
 " of the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"x"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "4ea34787-c2ff-4570-9a65-67b0596cdca1"],
 " of the native register to the ancillary register, and leads to"
}], "TechNoteText",
 CellID->1731142501,ExpressionUUID->"1adf8587-6a07-4462-80e3-8389bd8e5d52"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["1", 
     SuperscriptBox["2", 
      RowBox[{"n", "/", "2"}]]], 
    UnderoverscriptBox["\[CapitalSigma]", 
     RowBox[{"x", "=", "0"}], 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]], 
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"f", "(", "x", ")"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "3be66170-4add-4913-b23d-bce6f38c1a64"],
 " ."
}], "TechNoteText",
 CellID->1203564751,ExpressionUUID->"65d66968-273e-4795-874c-e888f7a3b1ee"],

Cell[TextData[{
 "Finally, the second set of ",
 ButtonBox["Hadamard gates",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Hadamard"],
 " on the native register maps the above state into"
}], "TechNoteText",
 CellID->1164298964,ExpressionUUID->"0e45ddeb-a38a-4dfe-815e-92b021541be4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderoverscriptBox["\[CapitalSigma]", 
     RowBox[{"y", "=", "0"}], 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]], 
    RowBox[{
     TemplateBox[{"y"},
      "Ket"], "\[CircleTimes]", 
     FractionBox["1", 
      SuperscriptBox["2", "n"]]}], 
    UnderoverscriptBox["\[CapitalSigma]", 
     RowBox[{"x", "=", "0"}], 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]], 
    SuperscriptBox[
     RowBox[{
      TemplateBox[{
        RowBox[{"f", "(", "x", ")"}]},
       "Ket"], "(", 
      RowBox[{"-", "1"}], ")"}], 
     RowBox[{"x", "\[CenterDot]", "y"}]]}], TraditionalForm]],ExpressionUUID->
  "d0e7cc2f-fb5d-4eed-82fe-7f77eedbfe3a"],
 " ."
}], "TechNoteText",
 CellID->501696484,ExpressionUUID->"a86d63ba-9438-46a1-8310-fabfb92cd4d7"],

Cell[TextData[{
 "The measurement on the native register yields an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "0af4761e-18f9-47a1-a1b4-3a7d7ea2761c"],
 "-bit string y. The probability for a particular string ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "9b67c2ef-02c3-47be-8a6a-20bf36e99d38"],
 " is determined by the squared norm, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "y"], "=", 
    TemplateBox[{
      SubscriptBox["\[Psi]", "y"], 
      SubscriptBox["\[Psi]", "y"]},
     "BraKet"]}], TraditionalForm]],ExpressionUUID->
  "ede45ed3-e73a-47e4-807f-775b9665db96"],
 ", of the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "99acab44-8455-4a4e-977e-f5aa58133ade"],
 "-dependent state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Psi]", "y"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "025bb014-4df4-4387-84ef-ee9f327a10b4"],
 " of the ancillary register"
}], "TechNoteText",
 CellID->992008466,ExpressionUUID->"5982f6c9-d10f-4e93-8c4c-b21e744d2c76"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Psi]", "y"]},
     "Ket"], ":=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", "n"]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{
         RowBox[{"f", "(", "x", ")"}]},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"x", "\[CenterDot]", "y"}]]}]}], TraditionalForm]],
  ExpressionUUID->"d6285972-88ef-4c96-bdd5-c2eb20eb0f29"],
 " ."
}], "TechNoteText",
 CellID->1770736401,ExpressionUUID->"fcc9c806-d5f6-4a62-b28a-425ac88e60b2"],

Cell[TextData[{
 "\tLet us then examine different cases. First, suppose that the secret \
string ",
 Cell[BoxData[
  FormBox[
   RowBox[{"s", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "3e77191e-832e-432b-9fdb-651b71272094"],
 ". In this case, the function f is one-to-one, and the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Psi]", "y"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6efa32ed-1338-41ec-b8b6-8840ccfb3083"],
 " simply consists of terms that are a rearrangement of the logical basis \
states"
}], "TechNoteText",
 CellID->938311481,ExpressionUUID->"49167da4-ae99-4479-9114-be6861bb0aed"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Psi]", "y"]},
     "Ket"], ":=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", "n"]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"z", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"z"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"x", "\[CenterDot]", 
       RowBox[{
        SuperscriptBox["f", 
         RowBox[{"-", "1"}]], "(", "z", ")"}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"47b8cd8b-6a2f-43ce-83c0-661ed2347027"],
 " ,"
}], "TechNoteText",
 CellID->1228641246,ExpressionUUID->"24a7584b-8304-474d-a791-b4493839fc08"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["f", 
    RowBox[{"-", "1"}]], TraditionalForm]],ExpressionUUID->
  "d0fcaf41-935f-45f8-b19e-e711ed9b9c95"],
 " is the inverse of ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "1bd9167c-f053-4a20-bd84-7f5f7244e681"],
 ", and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "y"], "=", 
    SuperscriptBox["2", 
     RowBox[{"-", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "543c450b-a33f-4b9e-a936-f99fe8a5f916"],
 " for all ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "f8486298-5c2a-4844-ad25-f26fae7d79da"],
 ". In other words, for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"s", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "91fc587b-e639-49ad-9eaa-5bdca5409e66"],
 ", the measurement produces a random bit string ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "1cf455da-29d9-4b5b-823a-e1de8207cd39"],
 " with uniform probability."
}], "TechNoteText",
 CellID->1718155617,ExpressionUUID->"44db0c48-d980-4d8f-b091-eb8b8c331ee8"],

Cell[TextData[{
 "\tNow, suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"s", "\[NotEqual]", "0"}], TraditionalForm]],ExpressionUUID->
  "06498894-3709-42de-95ac-4358d9eed738"],
 ". In this case, the function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "54d76768-a0b4-4914-8045-cfa266edb50f"],
 " is two-to-one such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{"f", "(", 
     RowBox[{"x", "\[CirclePlus]", "s"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"e0c8d235-ca08-4647-8eb4-677549758ae8"],
 ". The terms in state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Psi]", "y"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "5b8b36b4-60c9-4fe6-895c-2538e830bc50"],
 " appear in pairs giving the same state, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"f", "(", "x", ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ba99eff1-76bc-4228-8f3c-7446f7e9129e"],
 "=",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"f", "(", 
       RowBox[{"x", "\[CirclePlus]", "s"}], ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "62ddee86-6391-4eaf-90cc-da7256f27768"],
 ". To be more explicit, let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalB]", ":=", 
    RowBox[{"f", "(", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"], ")"}]}], TraditionalForm]],
  ExpressionUUID->"207bb086-aff8-4597-8f39-1d303867fedd"],
 " be the image of ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "245cf896-a745-4c41-b8a3-b7be1d2a1e00"],
 ". Then,"
}], "TechNoteText",
 CellID->1976337357,ExpressionUUID->"578f62ce-4607-4770-aa3a-76447556d52a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Psi]", "y"]},
     "Ket"], ":=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", "n"]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"z", "\[Element]", "\[ScriptCapitalB]"}]], 
     TemplateBox[{"z"},
      "Ket"], 
     RowBox[{"{", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"y", "\[CenterDot]", 
         SubscriptBox["a", "z"]}]], "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"y", "\[CenterDot]", 
         SubscriptBox["b", "z"]}]]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"07425924-4c5c-42ec-a735-7ad395ad5e19"],
 " ,"
}], "TechNoteText",
 CellID->1172390950,ExpressionUUID->"119a817c-d68c-4bf3-b019-9dfa2d353596"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "z"], TraditionalForm]],ExpressionUUID->
  "2dae71dd-7c6e-4b4b-8c5b-21487eb37c06"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["b", "z"], TraditionalForm]],ExpressionUUID->
  "e3724b11-9563-48a0-a9ab-bb044bfbbe81"],
 " are the elements in the preimage (or inverse image) of ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "fb7a2f3c-e52d-4ad0-957d-2fa869c721e1"],
 " under ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "56f6b5a7-115c-4bdb-ab1b-cdac5eb5de35"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     SubscriptBox["a", "z"], ")"}], "=", 
    RowBox[{
     RowBox[{"f", "(", 
      SubscriptBox["b", "z"], ")"}], "=", "z"}]}], TraditionalForm]],
  ExpressionUUID->"e8f973bd-b299-4983-bb1c-74ff8a9678f3"],
 ". Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "z"], "=", 
    RowBox[{
     SubscriptBox["a", "z"], " ", "\[CirclePlus]", "s"}]}], TraditionalForm]],
  ExpressionUUID->"aea48b9f-fb24-4669-897e-b9085f4223e2"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["a", "z"], " ", "\[CirclePlus]", "s"}], ")"}], "\[CenterDot]",
      "y"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["a", "z"], " ", "\[CenterDot]", "y"}], ")"}], "\[CirclePlus]", 
     RowBox[{"(", 
      RowBox[{"s", "\[CirclePlus]", "y"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"5eacac7a-dab8-4b69-94e9-ba4571572b1c"],
 ", it follows that"
}], "TechNoteText",
 CellID->1212235425,ExpressionUUID->"ea28413b-fb85-4d66-9c1c-065deac28c8e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"y", "\[CenterDot]", 
        SubscriptBox["a", "z"]}]], "+", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"y", "\[CenterDot]", 
        SubscriptBox["b", "z"]}]]}], "}"}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"y", "\[CenterDot]", 
       SubscriptBox["a", "z"]}]], 
     RowBox[{"{", 
      RowBox[{"1", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"y", "\[CenterDot]", "s"}]]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"6bc59a6b-c465-437b-ac69-891ecdcf0de1"],
 " ."
}], "TechNoteText",
 CellID->863428886,ExpressionUUID->"3a3658ab-10b5-4f5d-8f7b-25e8acfc569e"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[CenterDot]", "s"}], TraditionalForm]],ExpressionUUID->
  "e69c8b9a-4b29-4466-a4d2-f32b9ad5ac46"],
 " is odd, that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"y", "\[CenterDot]", "s"}], "=", 
    RowBox[{"1", " ", 
     RowBox[{"(", 
      RowBox[{"mod", " ", "2"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "822c9086-0240-4907-8e1b-175ef0306124"],
 ", then ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Psi]", "y"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a5379e93-e2bd-41b6-8fe4-5ff5f1613e97"],
 " is a null vector, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "y"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "4987b3f5-6107-4a63-a7a7-96f30f178a20"],
 " for such a bit string ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "a230f49b-1c61-4835-8a11-6636a9bd1313"],
 ". On the other hand, if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[CenterDot]", "s"}], TraditionalForm]],ExpressionUUID->
  "e4f7118a-4130-40d1-92d2-b2cf92300865"],
 " is even, that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"y", "\[CenterDot]", "s"}], "=", 
    RowBox[{"0", " ", 
     RowBox[{"(", 
      RowBox[{"mod", " ", "2"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "4086f729-a873-4b28-8325-f3cff514e9e8"],
 ", then ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Psi]", "y"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "49baba6f-73f9-41f8-a86a-bd4556133c8d"],
 " is a finite vector and is independent of ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "928e91a7-5dd9-4239-9ebf-35f2c007980d"],
 ". That is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "y"], "=", 
    SuperscriptBox["2", 
     RowBox[{"1", "-", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "50189875-548c-4959-ba57-169148c8659f"],
 " regardless of ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "8440633c-e225-4611-acbd-e657ba5903bc"],
 " as long as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[CenterDot]", "s"}], TraditionalForm]],ExpressionUUID->
  "261350d7-9d8a-4931-b058-bf640bcda8d5"],
 " is even."
}], "TechNoteText",
 CellID->1102284223,ExpressionUUID->"146a862b-c1af-44ed-a0f1-57bcf3ecadaa"],

Cell[TextData[{
 "\tIn short, the bit string ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "36d836ad-f15e-49b4-bae2-cf5bc27ff876"],
 " resulting from the measurement on the native (first) register always \
satisfies ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"y", "\[CenterDot]", "s"}], "=", 
    RowBox[{"0", " ", 
     RowBox[{"(", 
      RowBox[{"mod", " ", "2"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "fac949ba-8208-4cb4-bd57-c95fac4f31de"],
 " for any secret bit string ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "cdc52661-fa3e-4aad-ad5e-ff6a96961884"],
 ". To find ",
 Cell[BoxData[
  FormBox[
   RowBox[{"s", "\[Congruent]", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["s", "1"], 
       SubscriptBox["s", "2"], 
       SubscriptBox["\[CenterEllipsis]s", "n"]}], ")"}], "2"]}], 
   TraditionalForm]],ExpressionUUID->"459697c2-6038-4688-8740-60b14a2a0b8d"],
 ", one needs to run the algorithms repeatedly to get ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"n", "\[Minus]", "1"}], ")"}], TraditionalForm]],ExpressionUUID->
  "9f13ee0b-3d26-415b-9614-f9bb2d031a13"],
 " linearly independent bit strings ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["y", 
     RowBox[{"(", "i", ")"}]], "\[Congruent]", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["y", "1", 
        RowBox[{"(", "i", ")"}]], 
       SubsuperscriptBox["y", "1", 
        RowBox[{"(", "i", ")"}]], 
       SubsuperscriptBox["\[CenterEllipsis]y", "n", 
        RowBox[{"(", "i", ")"}]]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"0625e6ae-a317-40a4-84a3-1e15dc02ca12"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"i", "=", "1"}], ",", "2", ",", 
     RowBox[{".", " ", ".", " ", "."}], " ", ",", 
     RowBox[{"n", " ", "\[Minus]", " ", "1"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"4d2b8d41-da66-43ae-a3d3-907cd551c9e6"],
 ", and then solve the set of equations"
}], "TechNoteText",
 CellID->1896996939,ExpressionUUID->"8e9f4f61-0f72-41e5-a80e-add74d835ce5"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], "n"], 
     RowBox[{
      SubsuperscriptBox["y", "j", 
       RowBox[{"(", "i", ")"}]], 
      SubscriptBox["s", "j"]}]}], "=", 
    RowBox[{"0", "  ", 
     RowBox[{"(", 
      RowBox[{"mod", " ", "2"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "1dd52577-c7c2-40b1-84a5-25e7347a0341"],
 "."
}], "TechNoteText",
 CellID->1285330411,ExpressionUUID->"b3093805-a517-43f8-b1fe-82830c70d5bb"],

Cell[TextData[{
 "It can be argued that the probability to get ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Minus]", "1"}], TraditionalForm]],ExpressionUUID->
  "7a2d92fe-bc8e-491f-b29d-3052eabed9f3"],
 " linearly independent bit strings out of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "1c59c0a2-836c-4174-bb51-8658218ca3bd"],
 " runs is slightly larger than 1/4. Therefore, the required number of \
queries to the quantum oracle is in the order of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "a38960b4-5706-4a73-9fd5-611279e5ca33"],
 ", exponentially smaller than for the classical algorithm."
}], "TechNoteText",
 CellID->1010212504,ExpressionUUID->"ed4bd703-2d22-45b6-9dd4-3a85b3bbdae8"]
}, Open  ]],

