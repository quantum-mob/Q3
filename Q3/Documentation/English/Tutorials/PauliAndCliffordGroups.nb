Cell[TextData[{
 "\tIn the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"8f476907-3808-40c1-82a8-96857adfbeb0"],
 ", eight different global phase factors appear, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", "m", " ", 
      RowBox[{"\[Pi]", "/", "4"}]}]], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      "7"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "5fb8016f-bbce-4d2d-8a25-7485fbbe39e5"],
 ". In many cases, these factors play no role and it is pointless to \
distinguish Clifford operators differing only by these factors. \
Mathematically, as in the full Pauli group, one can ignore these factors by \
introducing a quotient group"
}], "TechNoteText",
 CellID->438101802,ExpressionUUID->"301174d0-a821-40d9-97aa-52d6fed14142"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], ":=", 
    RowBox[{
     RowBox[{
      OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"e1d0a116-3bf1-4130-96b4-1b208f2d4b61"],
 ","
}], "DisplayMath",
 CellID->1603044298,ExpressionUUID->"8294ffaf-b658-46fd-b1a2-0f9c5ba06101"],

Cell["where", "TechNoteText",
 CellID->35681224,ExpressionUUID->"46b13a09-1cfe-4f26-a40d-6659c483d569"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "m", " ", 
          RowBox[{"\[Pi]", "/", "4"}]}]], 
        RowBox[{
         SuperscriptBox["I", 
          RowBox[{"\[CircleTimes]", "n"}]], ":", "m"}]}], "=", "0"}], ",", 
      "1", ",", "2", ",", "\[Ellipsis]", ",", "7"}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"4a87a058-0315-4508-89e8-59e673cff5a7"],
 "."
}], "DisplayMath",
 CellID->546394255,ExpressionUUID->"6c30a192-412e-47bf-b29a-638ae9290c68"],

Cell[TextData[{
 "is the center of the full Clifford group. This quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"8fd0c853-f557-4ed8-b0e6-cfc37373d329"],
 " is called the ",
 StyleBox[ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->608169213,ExpressionUUID->"1d62f23b-c694-43bb-9158-b1e20fbd26e7"],

