Cell[TextData[{
 "\tSince the group isomorphism between ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"aa87fac5-67f4-46cf-b663-1f222ccac1f6"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "98acc877-de33-445b-95e5-56e918fd3d85"],
 " preserves group multiplication, the multiplication of Pauli operators \
corresponds to addition modulo 2 (as the group multiplication in ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "1ade2fd6-258f-454e-8e8b-0a190740b3f3"],
 ")."
}], "TechNoteText",
 CellID->27264667,ExpressionUUID->"a3cd4c57-ac96-4d39-9b7f-2b12e39eb634"],

