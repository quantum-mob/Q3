 RowBox[{"elm", "=", 
  RowBox[{"GroupElements", "[", 
   RowBox[{"grp", ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", 
      RowBox[{"11520", "+", "1"}], ",", 
      RowBox[{"11520", "+", "2"}]}], "}"}]}], "]"}]}]}], "Input",
