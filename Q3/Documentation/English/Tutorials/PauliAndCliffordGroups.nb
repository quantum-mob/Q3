Cell[CellGroupData[{

Cell["The Gottesman-Knill Theorem", "Subsection",
 CellID->970307550,ExpressionUUID->"06dbb12d-851f-47d4-968a-422b0ac0728c"],

Cell[TextData[{
 "The peculiarity of the Clifford group is most pronounced in the ",
 ButtonBox["Gottesman-Knill theorem",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/StabilizerFormalism#970307550"],
 " (Gottesman, 1999). It states that any ",
 StyleBox[ButtonBox["stabilizer circuits",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/CliffordQuantumCircuits"],
  FontSlant->"Italic"],
 ", quantum circuits consisting of Clifford operators and Pauli measurements, \
can be efficiently simulated on a classical computer."
}], "TechNoteText",
 CellID->2115661179,ExpressionUUID->"a0082ac6-c4ef-46bb-b7fb-7438da83e007"]
}, Open  ]]
}, Open  ]],

