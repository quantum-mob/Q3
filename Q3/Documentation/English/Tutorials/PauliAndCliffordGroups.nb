 RowBox[{
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{"1", ",", "1"}], "]"}], "**", 
   RowBox[{"S", "[", 
    RowBox[{"1", ",", "2"}], "]"}]}], "/.", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"_", "?", "CommutativeQ"}], "*", "op_"}], ":>", "op"}], 
   "}"}]}]], "Input",
 CellLabel->"In[237]:=",
 CellID->823241458,ExpressionUUID->"65ac192e-e733-45d8-926e-ba10af2d73a1"],

