Cell[TextData[{
 "\tIgnoring the phase factors leads to a drastically simple structure of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"39cba0ea-5442-498e-a2a1-f0c68d380a9b"],
 ", compared to the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"372278dc-7e97-4fc1-a2b3-4e62928d8e34"],
 ". For example, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", " ", "Y"}], TraditionalForm]],ExpressionUUID->
  "24510c4f-d12a-448b-8a82-853b9565c9a8"],
 " is now equal to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", " ", "X"}], TraditionalForm]],ExpressionUUID->
  "94959de2-1a27-4db7-8a93-df422051e20c"],
 ", that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", "X\[ScriptCapitalZ]", ")"}], 
     RowBox[{"(", "Y\[ScriptCapitalZ]", ")"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"X", " ", "Y"}], ")"}], "\[ScriptCapitalZ]"}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Y", " ", "X"}], ")"}], "\[ScriptCapitalZ]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"73702015-148e-4c9e-9cbe-293371d53df8"],
 ". This means that unlike the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"97727cd5-745c-421d-a30c-bd3c83211620"],
 ", the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"81c42125-a189-452a-ae76-d1e53296749c"],
 " is ",
 StyleBox["Abelian",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->360346922,ExpressionUUID->"ab826c6a-c393-4b13-b0f5-e2a8311aa6bd"],

Cell[TextData[{
 "\tMoreover, since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"X", " ", "Z"}], "=", 
    RowBox[{
     RowBox[{"Z", " ", "X"}], "=", "Y"}]}], TraditionalForm]],ExpressionUUID->
  "f40bdc35-e627-4e9a-9b29-58fd8e7ff824"],
 " in the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"f63393dc-623c-49d2-a5c7-0d8801fa32b7"],
 ", the latter is isomorphic to ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "a9b3bab3-2c77-4343-9883-60c1213f3d52"],
 " with group multiplication given by addition modulo 2."
}], "TechNoteText",
 CellID->446833514,ExpressionUUID->"26cf2fea-fea7-435c-9250-b8b692e4108e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gottesman Vectors", "Subsection",
 CellID->180556239,ExpressionUUID->"bc6c1724-4912-4e81-9aca-0459f78e9243"],

Cell[TextData[{
 "Let us examine the above mentioned isomorphism ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], "\[TildeEqual]", 
    SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
     RowBox[{"2", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "0c66af21-89a6-42a6-bef1-08950119fb49"],
 " between the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"0c91c9bc-36ac-48b8-a32c-530b3d6ef5a4"],
 " and the binary Abelian group ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "a8ecdcb9-b4d1-4684-95e9-78c920efad4b"],
 " more closely. By inspection, it is clear that the following correspondence \
yields an isomorphism between ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], " "}], TraditionalForm]],
  ExpressionUUID->"2306e7e3-54ad-4b81-a092-db7d6d12d06d"],
 "and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "4e580266-0502-4734-a742-17e5e89323de"],
 ":"
}], "TechNoteText",
 CellID->214315662,ExpressionUUID->"830634e9-f050-4462-a56f-11d92c52feaa"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"X", "\[LeftRightArrow]", 
    RowBox[{"(", 
     RowBox[{"1", ",", "0"}], ")"}]}], ",", " ", 
   RowBox[{"Z", "\[LeftRightArrow]", 
    RowBox[{"(", 
     RowBox[{"0", ",", "1"}], ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"cce56294-67c7-4306-8231-feb9574236a8"]], \
"DisplayMath",
 CellID->673255215,ExpressionUUID->"9e8f357b-972f-4e1f-b882-ba5acda8d9cf"],

Cell[TextData[{
 "The correspondence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", "<->", 
    RowBox[{"(", 
     RowBox[{"1", ",", "1"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "bb2d8cc9-89ea-4362-a8bd-37f71c24247e"],
 " follows automatically from the group multiplication (between cosets)."
}], "TechNoteText",
 CellID->309062462,ExpressionUUID->"43b5e996-08b1-44cd-9472-23fba74f91f4"],

Cell["Equivalently, a Pauli operator of the form", "TechNoteText",
 CellID->1797340388,ExpressionUUID->"81d025ab-a61b-4e5c-b024-d7564839daac"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"P", "=", 
   RowBox[{
    RowBox[{
     SuperscriptBox["X", 
      SubscriptBox["x", "1"]], 
     RowBox[{
      SuperscriptBox["Z", 
       SubscriptBox["z", "1"]], "\[CircleTimes]", 
      SuperscriptBox["X", 
       SubscriptBox["x", "2"]]}], 
     RowBox[{
      SuperscriptBox["Z", 
       SubscriptBox["z", "2"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
      SuperscriptBox["X", 
       SubscriptBox["x", "n"]]}], 
     SuperscriptBox["Z", 
      SubscriptBox["z", "n"]]}], "\[Element]", 
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"63186d2e-02a2-4902-9b66-f61afd49a842"]], \
"DisplayMath",
 CellID->1394922414,ExpressionUUID->"b1069f73-e23e-4cef-a132-ba11172bdc59"],

Cell["corresponds to the vector", "TechNoteText",
