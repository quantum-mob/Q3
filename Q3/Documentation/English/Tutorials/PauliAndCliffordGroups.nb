Cell[TextData[{
 "\tThe number of elements quickly increases with the number of qubits, and \
it is more convenient to describe the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 " in terms of ",
 ButtonBox["generators",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/GroupGenerators"],
 ". The ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "94e42137-3e69-419c-8421-ab24778603b0"],
 " qubits is generated by tensor products of the Pauli operators acting \
non-trivially on one and only one qubit. For example, the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 " on two qubits is given by "
}], "TechNoteText",
 CellID->543395374,ExpressionUUID->"9e705054-2b6e-4cdf-8d20-a61878f3fcaf"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"X", "\[CircleTimes]", "I"}], ",", " ", 
       RowBox[{"Y", "\[CircleTimes]", "I"}], ",", " ", 
       RowBox[{"Z", "\[CircleTimes]", "I"}], ",", " ", 
       RowBox[{"I", "\[CircleTimes]", "X"}], ",", " ", 
       RowBox[{"I", "\[CircleTimes]", "Y"}], ",", 
       RowBox[{"I", "\[CircleTimes]", "Z"}]}], "}"}], 
     "\[RightAngleBracket]"}]}], TraditionalForm]],ExpressionUUID->
  "4741e88d-f749-4a75-b10d-55b2f351e1aa"],
 "."
}], "DisplayMath",
 CellID->1745583774,ExpressionUUID->"b39c1128-37c7-4dcc-b231-e8b0fc6a3f43"],

