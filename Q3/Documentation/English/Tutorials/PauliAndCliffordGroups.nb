            "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
           $CellContext`S[2, 1]]}, "RowWithSeparators"]},
       "RowDefault"],
      Q3`Multiply[
       $CellContext`S[1, 1], 
       $CellContext`S[2, 1]]], 
     RowBox[{"2", " ", 
      SqrtBox["2"]}]], "+", 
    FractionBox[
     InterpretationBox[
      TemplateBox[{
        TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
          InterpretationBox[
           TemplateBox[{"S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"], 
