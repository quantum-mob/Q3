Cell[TextData[{
 "\tSince they generate the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 ", the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "99f98470-26ec-497e-80b2-bcdc1217e9aa"],
 ", ",
 ButtonBox["quadrant",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/quadrant"],
 " phase, and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CNOT"]], "paclet:QuantumMob/Q3/ref/CNOT", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fabc3048-8d2a-4756-b8dc-6ef8cc19224a"],
 " gates are called the ",
 StyleBox["elementary Clifford gates",
  FontSlant->"Italic"],
 " or simply Clifford gates. Quantum circuits consisting of elementary \
Clifford gates are called ",
 StyleBox["Clifford circuits",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->995340567,ExpressionUUID->"01b56ca5-3fbe-4849-9903-c8ceab97bb67"],

Cell[TextData[{
 "\tFor a proof of the Gottesman theorem, we refer the readers to Gottesman\
\[CloseCurlyQuote]s original paper (",
 ButtonBox["Gottesman, 1998",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.57.127"], None}],
 "), ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Nielsen and Chuang (2022)"]], 
    "https://doi.org/10.1017/CBO9780511976667"},
   "WebLink",
   BaseStyle->{"TechNoteText", FontSlant -> "Plain"}]],ExpressionUUID->
  "45c61ecc-bffe-4906-98a6-b319b4b22025"],
 ", or the ",
 ButtonBox["Quantum Workbook",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-3-030-91214-7"], None}],
 "."
}], "TechNoteText",
 CellID->1938783086,ExpressionUUID->"b5148a0a-7053-4457-893c-3e871618b7c6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Clifford Group", "Subsection",
 CellID->1357950471,ExpressionUUID->"1e8dbca6-9f2b-42af-91d5-d35a4adc5f97"],

Cell[TextData[{
 "As in the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 ", elements in the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 " appear redundantly and differ only in global phase factors."
}], "TechNoteText",
 CellID->1764849428,ExpressionUUID->"870587db-0826-48fa-9d71-b2cc2998153e"],

Cell[TextData[{
 "\tFor example, this shows four elements of the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 " on two qubits. The last two elements are different from the first two only \
by a global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]\[Pi]", "/", "4"}]], TraditionalForm]],
  ExpressionUUID->"08151215-c830-4d70-9a33-10d81a221fc0"],
 "."
}], "TechNoteText",
 CellID->780204032,ExpressionUUID->"ed7cb698-3276-4c8e-8788-2352a69516cd"],

