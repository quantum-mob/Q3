Cell["\<\
\tIt would be pointless to use the Gottesman inner product just to examine \
the commutation and anti-commutation of Pauli operators. However, the \
relation between the commutation/anti-commutation and the Gottesman inner \
product plays an important role in the Clifford group to be discussed below.\
\>", "TechNoteText",
 CellID->389193666,ExpressionUUID->"139242b9-600f-4cec-8588-6a648e9e6a95"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Clifford Group", "TechNoteSection",
 CellID->2090239347,ExpressionUUID->"50875ee5-fe75-48b8-b974-b649c6f6401d"],

Cell["\<\
The Clifford group was first introduced in 1998 by Daniel Gottesman \
(Gottesman, 1998) when he reformulated the quantum error-correction codes in \
terms of stabilizers. The Clifford group is useful since stabilizers remain \
subgroups of the Pauli group under conjugation by its elements.\
\>", "TechNoteText",
 CellID->2115207403,ExpressionUUID->"9b269f33-5786-4bd8-a34b-6c434e246911"],

Cell[CellGroupData[{

Cell["The Full Clifford Group", "Subsection",
 CellID->846529783,ExpressionUUID->"76bf9734-8d77-4e35-a4cf-3cdc128d1de2"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["C", "~"], "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"66763439-0416-4c46-9bdb-68b1a8fd9092"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "0f6b67cd-0f83-485e-a83c-b71dc688bf43"],
 " qubits is the group of unitary operators ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "03869190-4e90-4843-b39a-99e0d7827751"],
 " that leave the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"c32ede65-721a-433b-b5c5-5172156840a5"],
 " invariant under conjugation, that is,"
}], "TechNoteText",
 CellID->546901506,ExpressionUUID->"196afd74-500d-4357-97c8-e973ab23ac2f"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{"U", ":", 
      RowBox[{
       RowBox[{"U", " ", "P", " ", 
        SuperscriptBox["U", "\[Dagger]"]}], "\[Element]", 
       RowBox[{
        RowBox[{
         OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "  ", 
        "for", " ", "all", " ", "P"}], "\[Element]", 
       RowBox[{
        OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}]}]}], "}"}]}],
    TraditionalForm]],ExpressionUUID->
  "a25e43f4-8942-40f0-8687-75f2aa6b782b"],
 "."
}], "DisplayMath",
 CellID->543602182,ExpressionUUID->"095df8c6-f03c-49cf-b6d6-224fc13bd1ff"],

Cell[TextData[{
 "Mathematically, the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 " is the normalizer of the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 " in unitary group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalU]", "(", 
    RowBox[{"2", "n"}], ")"}], TraditionalForm]],ExpressionUUID->
  "891e3201-ce1e-4996-84c1-d5e07068528a"],
 ". The elements of the full Clifford group on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "30beee5d-042f-4322-ac59-2ef9ac0918a2"],
 " qubits are called ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "875b9803-86a1-4ca7-873b-a72a5f0ed3c9"],
 "-qubit Clifford operators."
}], "TechNoteText",
 CellID->926438536,ExpressionUUID->"9e30fae1-1ba3-4aaf-ad24-e897464f4b6a"],

Cell["\tThe full Clifford group is huge.", "TechNoteText",
 CellID->1396033802,ExpressionUUID->"f86e7686-cb6b-4393-b570-02f440f662f1"],

