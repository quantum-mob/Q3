Cell["\<\
\tPauli operators (i.e., elements in the full Pauli group) have two extremely \
useful properties that eventually determine the group-theoretical structure \
of the stabilizers and stabilizer codes .\
\>", "TechNoteText",
 CellID->1397068210,ExpressionUUID->"b0c0f648-a51d-4a74-9543-5843617051db"],

Cell["\<\
Any two elements of the full Pauli group either commute or anti-commute with \
each
other. The rule is also simple that allows to determine which elements \
commute and which elements anti-commute. \
\>", "Item",
 CellID->2086692819,ExpressionUUID->"2cab4089-f8a2-409f-9bfe-9e59f43fdd7d"],

Cell[CellGroupData[{

Cell[TextData[{
 "Every element of the Pauli group squares to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "I"}], TraditionalForm]],ExpressionUUID->
  "13652bc8-6b99-4ebd-a000-528a645498a5"],
 " . The elements that square to ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "b38ba9d0-353d-49b4-8325-6b13a03779a2"],
 " have eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "2cb3d433-b792-4080-983c-ffb24be1c305"],
 " whereas those that square to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Minus]", "I"}], TraditionalForm]],ExpressionUUID->
  "4fa28295-801a-4585-ba53-d4b3b657500c"],
 " have eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], TraditionalForm]],
  ExpressionUUID->"811b7b58-b90a-428a-ac7d-7b3ca5504d5d"],
 "."
}], "Item",
 CellID->490769776,ExpressionUUID->"2a5a6072-9df7-4c42-b565-e6c2d4af8117"],

Cell["\tFor example, consider two-qubit Pauli operators.", "TechNoteText",
 CellID->1216862877,ExpressionUUID->"98e4a687-0b84-41c3-b67a-11a6c19789df"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ops", "=", 
   RowBox[{
    RowBox[{"Multiply", "@@@", 
     RowBox[{"Tuples", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"S", "[", 
         RowBox[{"1", ",", "Full"}], "]"}], ",", 
        RowBox[{"S", "[", 
         RowBox[{"2", ",", "Full"}], "]"}]}], "}"}]}]}], "//", 
    "Elaborate"}]}], ";", 
  RowBox[{"mat", "=", 
   RowBox[{"Outer", "[", 
    RowBox[{"GottesmanTest", ",", "ops", ",", "ops"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"TableForm", "[", 
  RowBox[{"mat", ",", 
   RowBox[{"TableHeadings", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PauliForm", "@", "ops"}], ",", 
      RowBox[{"PauliForm", "@", "ops"}]}], "}"}]}], ",", 
   RowBox[{"TableAlignments", "\[Rule]", "Right"}]}], "]"}]}], "Input",
 CellLabel->"In[218]:=",
 CellID->1883110354,ExpressionUUID->"211dde6b-92c9-411e-aa65-37695dd36c9f"],

