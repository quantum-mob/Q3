Cell[CellGroupData[{

Cell["The Pauli Group", "Subsection",
 CellID->1087575174,ExpressionUUID->"c6f66a53-2839-4eb8-90e0-e4aeeee2882c"],

Cell[TextData[{
 "In most applications of the Pauli group, an explicit multiplication table \
is not necessary, commutation (or anti-commutation) of the elements is \
sufficient. As long as the commutation of the elements is concerned, one can \
ignore the phase factors ",
 StyleBox["\[PlusMinus]1", "Input"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], TraditionalForm]],
  ExpressionUUID->"096587bc-2acd-4b71-bec3-f7e128047aca"],
 " in the elements of the full Pauli group. Mathematically, this can be \
achieved by considering the ",
 StyleBox["quotient group",
  FontSlant->"Italic"]
}], "TechNoteText",
 CellID->1642629801,ExpressionUUID->"08cf1cb0-2ce8-41b7-ba61-40a75809e642"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], ":=", 
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "/", 
    RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"b3511a47-12ce-4faa-8889-a1ee2348c2a3"]], \
"DisplayMath",
 CellID->1776783222,ExpressionUUID->"f5c81225-39f4-41fe-af28-a58f5cb61451"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[PlusMinus]", 
       SuperscriptBox["I", 
        RowBox[{"\[CircleTimes]", "n"}]]}], ",", " ", 
      RowBox[{
       RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", 
       SuperscriptBox["I", 
        RowBox[{"\[CircleTimes]", "n"}]]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"6cf5cabe-d730-443b-9f4a-3d18a55f221b"],
 " is the center (the largest Abelian invariant subgroup) of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"228e4a91-59ce-4543-84fc-f6b4a189dca6"],
 ". "
}], "TechNoteText",
 CellID->1635500619,ExpressionUUID->"c2781b9f-3bea-496c-ac96-abe72ca370f9"],

Cell[TextData[{
 "\tThis quotient group is called the ",
 StyleBox[ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
  FontSlant->"Italic"],
 StyleBox[".",
  FontSlant->"Italic"],
 " In the literature, the precise meaning of the term \
\[OpenCurlyDoubleQuote]Pauli group\[CloseCurlyDoubleQuote] varies widely and \
must be figured out from the context; some refer to the full Pauli group \
while others the quotient group. In Q3, the parent group is always referred \
to as the ",
 StyleBox[ButtonBox["full",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
  FontSlant->"Italic"],
 ButtonBox[" Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 "."
}], "TechNoteText",
 CellID->68221933,ExpressionUUID->"5e1d9c89-29c5-4b33-8349-ea13caf477ee"],

Cell[TextData[{
 "\tAs a quotient group, the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " is a group of ",
 StyleBox["cosets",
  FontSlant->"Italic"],
 ", and the elements of the same meaning belong to the same coset. For \
example, in the single-qubit Pauli group, there are four cosets"
}], "TechNoteText",
 CellID->1997244080,ExpressionUUID->"654fc9b0-3959-4f9a-ad00-de3d0e32d799"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalP]", "(", "1", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[PlusMinus]", "I"}], ",", 
        RowBox[{
         RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "I"}]}], "}"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[PlusMinus]", "X"}], ",", 
        RowBox[{
         RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "X"}]}], "}"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[PlusMinus]", "Y"}], ",", 
        RowBox[{
         RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "Y"}]}], "}"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[PlusMinus]", "Z"}], ",", 
        RowBox[{
         RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "Z"}]}], "}"}]}], 
     "}"}]}], TraditionalForm]],ExpressionUUID->
  "a6a37128-96e9-4f39-b976-9e0e621903df"],
 "."
}], "DisplayMath",
 CellID->364366303,ExpressionUUID->"01f95243-c796-4559-a8cf-4005bed938d4"],

Cell[TextData[{
 "Belonging to the same coset ",
 Cell[BoxData[
  FormBox["X\[ScriptCapitalZ]", TraditionalForm]],ExpressionUUID->
  "1b78079b-3b20-4e2e-8b40-69591f2c136c"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "X"}], TraditionalForm]],ExpressionUUID->
  "3770cafb-8317-4798-828b-6a5d20da56b2"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "X"}], TraditionalForm]],
  ExpressionUUID->"bcf8284a-0120-41f4-9a88-5eeb1a774765"],
 " are not distinguished any longer. "
}], "TechNoteText",
 CellID->1428576924,ExpressionUUID->"cd715a51-1241-44c2-85c1-5965adf667ce"],

Cell[TextData[{
 "\tIn Q3, cosets in the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " are denoted by their representatives."
}], "TechNoteText",
 CellID->1225188208,ExpressionUUID->"47ba9a98-11c0-44c2-8ed1-447e0d04fdbe"],

