     TemplateBox[{"\"X\""},
      "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
    $CellContext`S[1, 1]], 
   RowBox[{"2", " ", 
    SqrtBox["2"]}]], "+", 
  FractionBox[
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{
      TemplateBox[{"\"X\""},
       "RowDefault"], "\[CircleTimes]", 
      TemplateBox[{"\"Y\""},
       "RowDefault"]}],
     Q3`Multiply[
      $CellContext`S[1, 1], 
      $CellContext`S[2, 2]]]}], 
   RowBox[{"2", " ", 
    SqrtBox["2"]}]], "-", 
  FractionBox[
   InterpretationBox[
    RowBox[{
