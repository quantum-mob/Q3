Cell[TextData[{
 "The additional phase factors ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "edf9e030-49ff-4f00-a1e0-c6d4f14ad0da"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], TraditionalForm]],
  ExpressionUUID->"cd3e8046-3072-4a25-80c1-a251bf65227f"],
 " are required because the product of two Pauli operators gives another \
Pauli operator accompanied by factor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], TraditionalForm]],
  ExpressionUUID->"0f51bfc4-1d7c-4b65-afe1-9e6f037281d3"],
 ". Otherwise, the underlying set is not closed under the group \
multiplication ."
}], "TechNoteText",
 CellID->1795692308,ExpressionUUID->"affc6e18-4c68-418e-9dcf-d46e82877d79"],

Cell[TextData[{
 "\tThe ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"1abce9f1-151e-4456-ac9a-c4948b2819cc"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "8d1a3bfb-0390-411b-b118-98cf3b42c750"],
 " qubits is given by"
}], "TechNoteText",
 CellID->1612929265,ExpressionUUID->"00c4548c-8050-49ea-92a1-42d5592d2747"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[PlusMinus]", "1"}], ",", 
       RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}]}], "}"}], "\[Times]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"I", ",", "X", ",", "Y", ",", "Z"}], "}"}], 
      RowBox[{"\[CircleTimes]", "n"}]]}]}], TraditionalForm]],ExpressionUUID->
  "a333162f-9eaa-4ab4-8801-e4bb959ca49c"],
 "."
}], "DisplayMath",
 CellID->816080774,ExpressionUUID->"de3d9641-10f8-419c-ae98-36043895d28c"],

