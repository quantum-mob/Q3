     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], ",", 
       SubscriptBox["z", "1"], ",", 
       SubscriptBox["x", "2"], ",", 
       SubscriptBox["z", "2"], ",", "\[Ellipsis]", ",", "\[Ellipsis]", ",", 
       SubscriptBox["x", "n"], ",", 
       SubscriptBox["z", "n"]}], ")"}], "\[Element]", 
     SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
      RowBox[{"2", "n"}]]}]}], TraditionalForm]],ExpressionUUID->
  "e41953c2-4c9e-4bbb-8e0e-d1aabcb92e52"],
 "."
}], "DisplayMath",
 CellID->2080666910,ExpressionUUID->"6a578e92-2347-4b73-aa54-9821df295302"],

