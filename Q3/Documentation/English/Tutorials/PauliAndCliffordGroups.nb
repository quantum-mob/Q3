             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            $CellContext`S[2, 1]]}, "RowWithSeparators"]},
        "RowDefault"],
       Q3`Multiply[
        $CellContext`S[1, 2], 
        $CellContext`S[2, 1]]]}], 
     RowBox[{"2", " ", 
      SqrtBox["2"]}]], "+", 
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
           InterpretationBox[
            TemplateBox[{"S", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"], 
              TemplateBox[{",", "\",\"", "\"Y\""}, "RowWithSeparators"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            $CellContext`S[1, 2]], 
           InterpretationBox[
            TemplateBox[{"S", 
              TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"], 
              TemplateBox[{",", "\",\"", "\"Z\""}, "RowWithSeparators"]}, 
             "Subsuperscript", SyntaxForm -> SubsuperscriptBox], 
            $CellContext`S[2, 3]]}, "RowWithSeparators"]},
        "RowDefault"],
       Q3`Multiply[
        $CellContext`S[1, 2], 
        $CellContext`S[2, 3]]]}], 
     RowBox[{"2", " ", 
      SqrtBox["2"]}]], "-", 
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
           InterpretationBox[
            TemplateBox[{"S", 
              TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"], 
