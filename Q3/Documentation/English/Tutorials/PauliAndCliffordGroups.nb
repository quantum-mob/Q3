Cell["\<\
\tIt is thus useful to describe it in terms of group generators: \
\>", "TechNoteText",
 CellID->54862276,ExpressionUUID->"1534049b-5b6b-4675-a37a-0c1a3c3840b3"],

Cell[TextData[{
 StyleBox["Gottesman Theorem",
  FontWeight->"Bold"],
 ": The full Clifford group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n"}], TraditionalForm]],
  ExpressionUUID->"d74d73b5-74ab-4190-ab9e-355fa53936c1"],
 ") is generated by ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f1a6c906-f845-4328-b56c-dd2e4943777d"],
 " gates and ",
 ButtonBox["quadrant",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/quadrant"],
 " phase gates on individual qubits, and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CNOT"]], "paclet:QuantumMob/Q3/ref/CNOT", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "085633f2-7a92-4f3c-90a1-6abfe11c3cd4"],
 " (or equivalently ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CZ"]], "paclet:QuantumMob/Q3/ref/CZ", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5ed050e0-85ce-4b52-8851-0d615c780519"],
 ") gates on all pairs of qubits."
}], "TechNoteText",
 CellID->1593515931,ExpressionUUID->"8b73988b-7f15-47dc-8365-a581a18d5e93"],

