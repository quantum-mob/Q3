    SqrtBox["2"]}]], "+", 
  FractionBox[
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"Y\""},
      "RowDefault"], "\[CircleTimes]", 
     TemplateBox[{"\"Z\""},
      "RowDefault"]}],
    Q3`Multiply[
     $CellContext`S[1, 2], 
