Cell[CellGroupData[{

Cell["The Full Pauli Group", "Subsection",
 CellID->1079734725,ExpressionUUID->"2049da6f-7cbf-417f-83a6-f12a7cdf5a9c"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
  FontSlant->"Italic"],
 " on a single qubit consists of the single-qubit Pauli operators . Enlisting \
the elements, it consists of 16 elements, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalP]", "~"], "(", "1", ")"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[PlusMinus]", "I"}], ",", 
      RowBox[{
       RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "I"}], ",", " ", 
      RowBox[{"\[PlusMinus]", "X"}], ",", 
      RowBox[{
       RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "X"}], ",", " ", 
      RowBox[{"\[PlusMinus]", "Y"}], ",", 
      RowBox[{
       RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "Y"}], ",", " ", 
      RowBox[{"\[PlusMinus]", "Z"}], ",", 
      RowBox[{
       RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", "Z"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"68e09af5-ae6a-4c44-8b40-2f31b426c3da"],
 ", with ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "3b1869a2-6340-404f-9991-064fceb51771"],
 ", ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "979fffc7-9e4f-41f8-b441-1731719be5e0"],
 ", ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "970749f0-3bc1-4ee4-beec-2e87e801b82e"],
 ", and ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "a60e5831-4c06-4182-bb63-0da832355f00"],
 " associated with the 2\[Times]2 matrices"
}], "TechNoteText",
 CellID->864705925,ExpressionUUID->"427e7c5a-d4b4-41ce-abe8-b98360b37d0d"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"I", "=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", "1"}
      }], ")"}]}], ",", " ", 
   RowBox[{"X", "=", 
    RowBox[{"(", GridBox[{
       {"0", "1"},
       {"1", "0"}
      }], ")"}]}], ",", " ", 
   RowBox[{"Y", "=", 
    RowBox[{"(", GridBox[{
       {"0", 
        RowBox[{"-", "\[ImaginaryI]"}]},
       {"\[ImaginaryI]", "0"}
      }], ")"}]}], ",", " ", 
   RowBox[{"Z", "=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"1", "0"},
        {"0", 
         RowBox[{"-", "1"}]}
       }], ")"}], "."}]}]}], 
  TraditionalForm]],ExpressionUUID->"ad4380bd-64be-4804-b8c8-f28b1e2a204e"]], \
"DisplayMath",
 CellID->1090642226,ExpressionUUID->"df311b94-6a83-4258-946c-5e801278fce5"],

