Cell[TextData[{
 ButtonBox["Generalized measurements",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MeasurementsOnQuantumStates#406380704"],
 " can be regarded as a special case of quantum operations. Suppose that a \
measurement is described by a set of measurement operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "m"], TraditionalForm]],ExpressionUUID->
  "e06c72cb-70b7-4688-81cb-caef466215d6"],
 " corresponding to measurement outcomes ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "f9449bf4-93c7-4d2b-b7f1-829a09681f43"],
 ". The mapping ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalF]", "m"], TraditionalForm]],ExpressionUUID->
  "1367d7aa-5d41-46f3-ba45-acb1627ae5c1"],
 " from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], 
   TraditionalForm]],ExpressionUUID->"67b1e9d1-bf27-4b19-8685-18b3f10f43b0"],
 " onto ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], 
   TraditionalForm]],ExpressionUUID->"ed10a5e7-56af-4bce-af07-ef2b82836e32"],
 " defined by"
}], "TechNoteText",
 CellID->1248806161,ExpressionUUID->"99292b6c-3cec-4c9c-8144-64aa9e3d9af8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[ScriptCapitalF]", "m"], "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     SubscriptBox["M", "m"], "\[Rho]", " ", 
     SubsuperscriptBox["M", "m", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"63e3d2f6-baec-4f68-894e-784db21aa255"]
}], "TechNoteText",
 CellID->1202869479,ExpressionUUID->"9035067b-c665-4a9b-8d1e-d6464cf1e26b"],

Cell[TextData[{
 "for each ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "4fe889a1-859c-41cd-b26e-7ee1956f94e6"],
 " is obviously a quantum operation. This is natural since the measurement \
process involves the interaction of the system with the measuring devices. \
Note that the quantum operation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalF]", "m"], TraditionalForm]],ExpressionUUID->
  "1a89c78f-03a3-4487-87eb-a5c0b52f52ef"],
 " does not preserve the trace in general,"
}], "TechNoteText",
 CellID->779276993,ExpressionUUID->"bf8104a1-3c66-4389-9b6a-ef2927eb4725"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    RowBox[{"Tr", "\[VeryThinSpace]", "[", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalF]", "m"], "(", "\[Rho]", ")"}], "]"}], "\[LessEqual]",
     "1"}], TraditionalForm]],ExpressionUUID->
  "a74b49f7-4ca7-4936-9542-a3f4a162c784"],
 " ."
}], "TechNoteText",
 CellID->1605430227,ExpressionUUID->"d5efc24a-39b5-493b-ac4b-870704c51b5e"],

Cell[TextData[{
 "Physically, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Tr", "\[VeryThinSpace]", "[", 
    RowBox[{
     SubscriptBox["\[ScriptCapitalF]", "m"], "(", "\[Rho]", ")"}], "]"}], 
   TraditionalForm]],ExpressionUUID->"07d922cb-6c77-45c0-bcfa-d395782ac1cf"],
 " gives the probability to get outcome ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "86a43908-a46a-4744-9236-8e15934cc61e"],
 " from the measurement process."
}], "TechNoteText",
 CellID->1061982162,ExpressionUUID->"d8eb85e2-78a7-47f9-9278-a6f6d1ca1103"],

Cell[TextData[{
 "\tThe measurement given above is a ",
 StyleBox["selective measurement",
  FontSlant->"Italic"],
 ". This physically involves separating an ensemble into subensembles that \
are distinguished by the measurement outcome. Schwinger (1959) conceived a \
new notion corresponding to the measurement process prior to the selection \
stage. It is denominated as a ",
 StyleBox["non-selective measurement",
  FontSlant->"Italic"],
 ". One can also regard a non-selective measurement as remixing the \
subensembles after the measurement with the probabilities ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "m"], ":=", 
    RowBox[{"Tr", "\[VeryThinSpace]", "[", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalF]", "m"], "(", 
      OverscriptBox["\[Rho]", "^"], ")"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"d4a42713-50f2-4bfe-8e6e-aa838aec3ace"],
 ". A non-selective measurement is thus represented by the quantum operation"
}], "TechNoteText",
 CellID->1835702410,ExpressionUUID->"24ceb180-0cd5-4ce7-a326-770e5ab2423b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "m"], 
      RowBox[{
       SubscriptBox["\[ScriptCapitalF]", "m"], "(", "\[Rho]", ")"}]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "m"], 
      SubscriptBox["M", "m"], "\[Rho]", " ", 
      SubsuperscriptBox["M", "m", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"14fa8194-f702-493f-89dc-3684c132696b"],
 " ."
}], "TechNoteText",
 CellID->664071991,ExpressionUUID->"8095478e-0857-48f0-842a-0fd9b93fa821"],

Cell[TextData[{
 "In this case, the trace is preserved: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "\[ThinSpace]", "[", 
     RowBox[{
      SubscriptBox["\[ScriptCapitalF]", "m"], "(", "\[Rho]", ")"}], "]"}], "=",
     "1"}], TraditionalForm]],ExpressionUUID->
  "9c0f2390-5cbf-4f1a-b50b-4e6968f9d00c"],
 " for any density operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Rho]", "^"], TraditionalForm]],ExpressionUUID->
  "bfa41375-0507-490f-84de-198a9213022a"],
 ". This follows from the completeness relation, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Sum]", "m"], 
     RowBox[{
      SubsuperscriptBox["M", "m", "\[Dagger]"], 
      SubscriptBox["M", "m"]}]}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"9fba61c3-a472-4738-bde2-8fc6dd39fdc7"],
 ", satisfied by the measurement operators."
}], "TechNoteText",
 CellID->1378203053,ExpressionUUID->"5a58675a-718f-4b6d-8788-f0c49f268473"]
}, Open  ]],

