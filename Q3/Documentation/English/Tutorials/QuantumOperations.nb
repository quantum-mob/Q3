Cell[TextData[{
 "Specify the phase damping process by two Kraus elements, where ",
 StyleBox["p",
  FontSlant->"Italic"],
 " is the probability for the phase to be flipped:"
}], "TechNoteMathCaption",
 CellID->819867225,ExpressionUUID->"15b145d4-c609-4ff3-9c80-cef30e9bfdd0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Real", ",", "p"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ops", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", "-", "p"}], "]"}]}], ")"}], "/", "2"}], "]"}], ",", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", "-", "p"}], "]"}]}], ")"}], "/", "2"}], "]"}], "*", 
      RowBox[{"S", "[", "3", "]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ops", "//", "PauliForm"}], "\[IndentingNewLine]", 
 RowBox[{"spr", "=", 
  RowBox[{"Supermap", "[", "ops", "]"}]}]}], "Input",
 CellLabel->"In[137]:=",
 CellID->786981066,ExpressionUUID->"ca336941-01c6-49d9-a921-321e2f30d5e4"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    FractionBox[
     RowBox[{"\<\"I\"\>", " ", 
      SqrtBox[
       RowBox[{"1", "+", 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}]]}], 
     SqrtBox["2"]],
    2^Rational[-1, 2] (1 + (1 - $CellContext`p)^Rational[1, 2])^
     Rational[1, 2]], ",", 
   FractionBox[
    RowBox[{
     SqrtBox[
      RowBox[{"1", "-", 
       SqrtBox[
        RowBox[{"1", "-", "p"}]]}]], " ", 
     InterpretationBox[
      TemplateBox[{"\"Z\""},
       "RowDefault"],
      $CellContext`S[3]]}], 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->"Out[139]=",
 CellID->1847930486,ExpressionUUID->"35c28101-0fab-4af8-9d7e-f49f80db796b"],

