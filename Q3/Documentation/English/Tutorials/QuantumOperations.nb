Cell["\<\
Set the parameters to specific values, and apply the supermap repeatedly to \
see how the supermap transforms the state in the Bloch sphere:\
\>", "TechNoteMathCaption",
 CellID->1292861483,ExpressionUUID->"2c61790b-c5eb-4c8c-9c73-74b95ae289e6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Rho]", ",", "p", ",", "pts"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Rho]", "[", "1", "]"}], ",", 
       RowBox[{"\[Rho]", "[", "2", "]"}], ",", 
       RowBox[{"\[Rho]", "[", "3", "]"}]}], "}"}], "=", 
     RowBox[{"Normalize", "@", 
      RowBox[{"{", 
       RowBox[{"2", ",", "0", ",", "1"}], "}"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p", "=", "0.2"}], ";", "\[IndentingNewLine]", 
    RowBox[{"pts", "=", 
     RowBox[{
      RowBox[{"BlochVector", "/@", 
       RowBox[{"NestList", "[", 
        RowBox[{"spr", ",", "rho", ",", "10"}], "]"}]}], "//", "Chop"}]}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"BlochSphere", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Bead", "/@", "pts"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<SphereStyle\>\"", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.25", "]"}], ",", "Cyan"}], "}"}]}]}], 
     "]"}]}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"In[164]:=",
 CellID->790487399,ExpressionUUID->"ca5af653-ce4f-4b68-84ba-6e19c1c52d32"],

