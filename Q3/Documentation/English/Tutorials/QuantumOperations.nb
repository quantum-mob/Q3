Cell[CellGroupData[{

Cell["Amplitude Damping", "Subsection",
 CellID->1374125471,ExpressionUUID->"fc4674c9-2bff-4a69-b1d3-c6e0568e247f"],

Cell[TextData[{
 "The amplitude damping process describes the spontaneous decay of the \
\[OpenCurlyDoubleQuote]excited state\[CloseCurlyDoubleQuote] ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "53e0e230-ef48-4817-bae8-222780874ff2"],
 " of the system to the \[OpenCurlyDoubleQuote]ground state\
\[CloseCurlyDoubleQuote] ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "1e17bd2b-b64c-4481-84bd-8926ad154350"],
 ". The decay is accompanied by the emission of a photon. One can regards \
that the photon \[OpenCurlyDoubleQuote]observes\[CloseCurlyDoubleQuote] the \
system and the information of the system acquired by the photon leads to \
decoherence."
}], "TechNoteText",
 CellID->1468986105,ExpressionUUID->"689d952d-6680-4c74-8e39-3525b17aee31"],

Cell["\<\
In the unitary representation, the process is described by the overall \
unitary operator such that\
\>", "TechNoteText",
 CellID->9922291,ExpressionUUID->"bed2d567-1d3d-4da4-8a21-321e9e339304"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "6f7b978d-e291-4e61-88f7-628fd545d1b6"],
 " ,"
}], "TechNoteText",
 CellID->1912570403,ExpressionUUID->"cbfe4265-c467-436d-8105-dd5de3b86942"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"1"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["\[Epsilon]", "0"]},
        "Ket"]}], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}], "+", 
     RowBox[{
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["\[Epsilon]", "1"]},
        "Ket"]}], 
      SqrtBox["p"]}]}]}], TraditionalForm]],ExpressionUUID->
  "0da04c34-399e-4b45-b5b5-ab17d47a3915"],
 " ,"
}], "TechNoteText",
 CellID->1035534925,ExpressionUUID->"19574335-947b-4e64-a4af-2a7dbd39fd2e"],

Cell[TextData[{
 "Thus, the decay occurs with probability ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "f33452bd-4507-4d0e-99e4-d19185b4c0e7"],
 " provided that the system is in the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b5326bd4-879d-4399-841f-0682a2d38c9b"],
 ". The Kraus elements are given by"
}], "TechNoteText",
 CellID->1894395181,ExpressionUUID->"4a217fce-b801-4194-83b3-a3123fccda8d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "0"], "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e3e08b65-2bfe-44d7-b0ea-2e24c074f9fc"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "1"], "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"0", 
        SqrtBox["p"]},
       {"0", "0"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e58134b4-55a4-4026-acae-34e9822aa929"],
 " ."
}], "TechNoteText",
 CellID->77939065,ExpressionUUID->"effdca44-214e-4915-b8c3-3fb5d09fe020"],

Cell["\<\
They are already orthogonal to each other. The quantum operation describing \
the amplitude damping process reads as\
\>", "TechNoteText",
 CellID->591321275,ExpressionUUID->"05b9be87-b99d-4f07-bab1-3ddc55f92838"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["F", "0"], "\[Rho]", "\[VeryThinSpace]", 
      SubsuperscriptBox["F", "0", "\[Dagger]"]}], "+", 
     RowBox[{
      SubscriptBox["F", "1"], "\[Rho]", "\[VeryThinSpace]", 
      SubsuperscriptBox["F", "1", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"c032843f-c071-48ee-8ccf-761c56def0c0"],
 " ."
}], "TechNoteText",
 CellID->831285078,ExpressionUUID->"e0d5b539-1d20-4fd9-9170-7e2185349d58"],

Cell["With the expansion of the density operator \[Rho],", "TechNoteText",
 CellID->1488653171,ExpressionUUID->"2ace345f-6436-475b-8870-9dbbd2fa1536"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "I"}], "+", 
     RowBox[{"x", "\[VeryThinSpace]", "X"}], "+", 
     RowBox[{"y", "\[VeryThinSpace]", "Y"}], "+", 
     RowBox[{"z", "\[VeryThinSpace]", "Z"}]}]}], TraditionalForm]],
  ExpressionUUID->"9d9fbfcc-60e6-4792-8551-7fa89fd624d3"],
 " ,"
}], "TechNoteText",
 CellID->1175215891,ExpressionUUID->"cf571beb-316b-40da-979c-c70468f5b322"],

Cell["the above operation reads as", "TechNoteText",
 CellID->2007486241,ExpressionUUID->"de0736c8-2c5e-4eb8-ab72-8872a4db5bcc"],

Cell[TextData[{
 "\t",
