Cell[CellGroupData[{

Cell["Depolarizing", "Subsection",
 CellID->1489289463,ExpressionUUID->"36ff080f-62c8-4c53-b364-253a9f14d530"],

Cell[TextData[{
 "In the depolarizing process, the decoherence occurs symmetrically, and \
there is no distinction of the specific types of actual decoherence \
processes. The system undergoes an incoherent process with probability ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "3c7452f8-e751-4c1c-943c-69f43a8ff6e3"],
 " and remains intact with probability ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[Minus]", "p"}], TraditionalForm]],ExpressionUUID->
  "2b873469-8f6a-4d5c-a4bb-91b0aba0ac73"],
 ". The incoherent process may cause the system to flip the bit value, the \
phase, or both with equal probability."
}], "TechNoteText",
 CellID->1603231678,ExpressionUUID->"ea981b8e-81a2-42d2-a195-527b31034f04"],

Cell[TextData[{
 "The situation can be best described in the unitary representation. Suppose \
that the system and the environment is in the product state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{
      SubscriptBox["\[Epsilon]", "0"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "a48cb0c5-8501-470b-85e1-43c86c25d650"],
 ". The decoherence process causes the transition"
}], "TechNoteText",
 CellID->2114426748,ExpressionUUID->"fb186fb4-6874-4bbb-8345-0d5a1a57cfad"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"\[Psi]"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["\[Epsilon]", "0"]},
        "Ket"]}], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"X", 
           TemplateBox[{"\[Psi]"},
            "Ket"]}], ")"}], "\[CircleTimes]", 
         TemplateBox[{
           SubscriptBox["\[Epsilon]", "1"]},
          "Ket"]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Y", 
           TemplateBox[{"\[Psi]"},
            "Ket"]}], ")"}], "\[CircleTimes]", 
         TemplateBox[{
           SubscriptBox["\[Epsilon]", "2"]},
          "Ket"]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Z", 
           TemplateBox[{"\[Psi]"},
            "Ket"]}], ")"}], "\[CircleTimes]", 
         TemplateBox[{
           SubscriptBox["\[Epsilon]", "3"]},
          "Ket"]}]}], ")"}], 
      SqrtBox[
       RowBox[{"p", "/", "3"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "05e5750b-78bb-40c2-b7a1-67780f752282"],
 " ."
}], "TechNoteText",
 CellID->815905882,ExpressionUUID->"5e7c699c-b646-4f2e-8dc7-54f37c898886"],

Cell[TextData[{
 "The environment evolves to one of the four mutually orthogonal states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e0524bf1-3b71-43ff-aabc-0b41fa4ef498"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "1"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2c70320a-3328-4abd-892e-2e07ef7c3ffc"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "2"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "53c9a273-5a68-48ed-b8bd-b7040211b57b"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "3"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ed7fd664-90be-4940-ac18-9f7d8aa2d773"],
 ". The final states of the environment enables recognizing the process that \
has occurred (bit flip, phase flip, or both). This causes decoherence on the \
state of the system."
}], "TechNoteText",
 CellID->1288108061,ExpressionUUID->"a39dc075-8702-45c4-800e-4aba39c8191e"],

Cell["\<\
From the above unitary representation, we can get the Kraus elements\
\>", "TechNoteText",
 CellID->181729108,ExpressionUUID->"9699c735-d482-44c5-bf8b-6f4de4be097f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "0"], "=", 
    RowBox[{
     SqrtBox[
