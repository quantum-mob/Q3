Cell["\<\
The Kraus elements are already orthogonal to each other. One can also check \
that they satisfy the completeness relation\
\>", "TechNoteText",
 CellID->825963182,ExpressionUUID->"bfd2ef6d-7f42-4537-a1a1-77b6f315969d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubsuperscriptBox["F", "0", "\[Dagger]"], 
      SubscriptBox["F", "0"]}], "+", 
     RowBox[{
      SubsuperscriptBox["F", "1", "\[Dagger]"], 
      SubscriptBox["F", "1"]}], "+", 
     RowBox[{
      SubsuperscriptBox["F", "2", "\[Dagger]"], 
      SubscriptBox["F", "2"]}], "+", 
     RowBox[{
      SubsuperscriptBox["F", "3", "\[Dagger]"], 
      SubscriptBox["F", "3"]}]}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"5b8e29ad-0061-473b-b12b-adf55a29f717"]
}], "TechNoteText",
 CellID->550496414,ExpressionUUID->"5567771c-dbab-4e17-b917-97d8a03f8db3"],

Cell["\<\
as they should. In the Kraus representation with the above Kraus elements, a \
density operator \[Rho]\:02c6 is transformed under the decoherence process as\
\
\>", "TechNoteText",
 CellID->1854461868,ExpressionUUID->"eddaa1ba-401c-4651-a75b-cdc8fc19caf6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "p"}], ")"}], "\[Rho]"}], "+", 
     RowBox[{
      FractionBox["p", "3"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"X", "\[VeryThinSpace]", "\[Rho]", "\[VeryThinSpace]", "X"}], 
        "+", 
        RowBox[{"Y", "\[VeryThinSpace]", "\[Rho]", "\[VeryThinSpace]", "Y"}], 
        "+", 
        RowBox[{
        "Z", "\[VeryThinSpace]", "\[Rho]", "\[VeryThinSpace]", "Z"}]}], 
       ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "24bbe19d-0de2-4b19-8378-8c30433a3ec3"],
 " ."
}], "TechNoteText",
 CellID->1395801356,ExpressionUUID->"c1f9bcb4-38e2-40e0-9eb0-212c627438d6"],

Cell["In terms of the components in the expansion", "TechNoteText",
 CellID->806392446,ExpressionUUID->"05488e05-f2da-4a38-b3e2-34f4649e3e1f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "I"}], "+", 
     RowBox[{"x", "\[VeryThinSpace]", "X"}], "+", 
     RowBox[{"y", "\[VeryThinSpace]", "Y"}], "+", 
     RowBox[{"z", "\[VeryThinSpace]", "Z"}]}]}], TraditionalForm]],
  ExpressionUUID->"5c8c5e0b-0702-4094-a482-34b67fca491b"],
 " ,"
}], "TechNoteText",
 CellID->1596229089,ExpressionUUID->"a08dbd25-c59a-4a55-8b86-9cadb92d3f0e"],

Cell[TextData[{
 "it reads as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", 
     RowBox[{"(", "\[Rho]", ")"}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"1", "/", "2"}], " ", "I"}], " ", "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        FractionBox[
         RowBox[{"4", "p"}], "3"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "\[VeryThinSpace]", "X"}], "+", 
        RowBox[{"y", "\[VeryThinSpace]", "Y"}], "+", 
        RowBox[{"z", "\[VeryThinSpace]", "Z"}]}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"4c41083f-445e-4fe3-9798-850742af40d2"],
 " ."
}], "TechNoteText",
 CellID->272213343,ExpressionUUID->"d2e03421-478e-4652-a564-1d0120e073cf"],

Cell[TextData[{
 "This implies that under the process, the \[OpenCurlyDoubleQuote]spin\
\[CloseCurlyDoubleQuote] polarization (i.e., the ",
 ButtonBox["Bloch vector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BlochVector"],
 " corresponding to the resulting density operator)"
}], "TechNoteText",
 CellID->1671734852,ExpressionUUID->"78144051-63fa-4c6c-80bf-720441b37f5b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
