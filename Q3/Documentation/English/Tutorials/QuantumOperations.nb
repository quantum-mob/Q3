Cell[CellGroupData[{

Cell["Definition", "TechNoteSection",
 CellID->339532637,ExpressionUUID->"9bc80af0-5863-4565-905f-99d6bcb118bf"],

Cell[TextData[{
 "A ",
 StyleBox["supermap",
  FontSlant->"Italic"],
 " is a linear mapping of linear operators. Recall that linear operators on a \
vector space \[ScriptCapitalV] themselves form a vector space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], 
   TraditionalForm]],ExpressionUUID->"968cffd8-63de-4a11-acf6-95eff39a114c"],
 ". A considerable amount of interest in supermaps came with the booming of \
quantum information theory in the 1990s when it became clear that supermaps \
are important in the study of entanglement. Since then, mathematical theories \
on supermaps have been developed at a notably fast pace and applied to a wide \
range of subjects in quantum computation and quantum information."
}], "TechNoteText",
 CellID->964304217,ExpressionUUID->"64c3f173-22c8-4b17-8d2e-7644189f1bd9"],

Cell[TextData[{
 "\tA quantum operation is a special kind of supermap. Let \[ScriptCapitalV] \
and \[ScriptCapitalW] be vector spaces. Suppose that ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "ae00376d-2c34-47c8-9b3f-7824179682de"],
 " is a supermap from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], 
   TraditionalForm]],ExpressionUUID->"31be4378-e3f0-4186-8fb5-dbbc9cd47e17"],
 " onto ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalW]", ")"}], 
   TraditionalForm]],ExpressionUUID->"4cff3587-82b3-4aa7-b3e0-fb174163dc69"],
 ". ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "88905c04-10a8-48b6-8a86-dccef00e3cda"],
 " is called a ",
 StyleBox["quantum operation",
  FontSlant->"Italic"],
 " if it satisfies the following three axioms."
}], "TechNoteText",
 CellID->1049079936,ExpressionUUID->"a59f413c-15ea-4c47-bbb8-29904e2aeec8"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "75a85a19-25bc-454f-a19e-fed59283d1ee"],
 " never increases the trace. That is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    RowBox[{"Tr", "[", " ", 
     RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "]"}], "\[LessEqual]",
     "1"}], TraditionalForm]],ExpressionUUID->
  "54a8309a-1264-49a3-9ab0-e0d65487a0f5"],
 " for any ",
 StyleBox["density operator",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "0b0a05cc-c9c2-4536-8d04-16995ea31d8a"],
 "."
}], "TechNoteText",
 CellDingbat->Cell["(a)", "Text"],
 CellMargins->{{48, Inherited}, {Inherited, Inherited}},
 CellID->1105000924,ExpressionUUID->"0a959648-b1a1-4267-acc1-7a0d9dfc530c"],

Cell[TextData[{
 " ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "914eca03-fb0c-45f0-93fb-8e8261d609f9"],
 " is ",
 StyleBox["convex linear",
  FontSlant->"Italic"],
 ". That is, for any probabilities ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "j"], TraditionalForm]],ExpressionUUID->
  "f25a91bc-76ec-424c-9573-02000432bb92"],
 " and density operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "j"], TraditionalForm]],ExpressionUUID->
  "3f72b50b-11fb-446c-8a22-af069975ad4e"],
 " on \[ScriptCapitalV],"
}], "TechNoteText",
 CellDingbat->Cell["(b)", "Text"],
 CellMargins->{{48, Inherited}, {Inherited, Inherited}},
 CellID->92439615,ExpressionUUID->"e0fafaed-0adf-41cc-9d90-3117c5ed4f57"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", 
     RowBox[{
      SubscriptBox["\[Sum]", "j"], 
      RowBox[{
       SubscriptBox["\[Rho]", "j"], 
       SubscriptBox["p", "j"]}]}], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "j"], 
     RowBox[{
      RowBox[{"\[ScriptCapitalF]", "(", 
       SubscriptBox["\[Rho]", "j"], ")"}], 
      SubscriptBox["p", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "4bb6ee85-95d5-49a9-a8db-389dcd45c4cb"],
 "."
}], "TechNoteText",
 CellID->1185374639,ExpressionUUID->"ec01f3c7-31af-4e9f-8687-c8af8db98ef1"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "feae58fd-5926-4881-b2d0-cfe653082efd"],
 " is a ",
 StyleBox["completely positive supermap",
  FontSlant->"Italic"],
 ". That is, not only ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], TraditionalForm]],
  ExpressionUUID->"ea9d81ee-9fa4-43cc-9e9f-3ed72c79ac65"],
 " itself is positive for any positive operator ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "c86faeaf-76c7-407e-8694-d2a29d76c216"],
 " on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "e6a45f08-f857-44b5-9b0d-5f81a2edb8b0"],
 ", but ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"\[ScriptCapitalF]", "\[CircleTimes]", "\[ScriptCapitalI]"}], 
     ")"}], 
    RowBox[{"(", "\[Rho]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "149a5ada-8394-4ede-b042-96e23af1a0d6"],
 " is also positive for any positive operator on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", "\[CircleTimes]", "\[ScriptCapitalE]"}], 
   TraditionalForm]],ExpressionUUID->"29f32b65-be54-4754-b59d-5acd73dc8594"],
 " with an arbitrary vector space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "e6d04883-6a4e-4c1e-ab1a-1fe5719778b7"],
 "."
}], "TechNoteText",
 CellDingbat->Cell["(c)", "Text"],
 CellMargins->{{48, Inherited}, {Inherited, Inherited}},
 CellID->1352792706,ExpressionUUID->"9aff8148-a396-4e04-858a-3f872118f59a"],

Cell[TextData[{
 "\tPhysically, the vector space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "d1ac1acc-56e4-4427-b40d-8298523c3fca"],
 " in (c) above is associated with an environment. ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", "\[CircleTimes]", "\[ScriptCapitalI]"}], 
   TraditionalForm]],ExpressionUUID->"ee46a0d5-7a15-4b36-af01-aaee304856e9"],
 " acts non-trivially only on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "10929c82-0b8c-4874-8686-e32f06bec196"],
 " associated with the system but trivially on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "15d41b70-2f69-4d4b-baa2-843ea259897d"],
 ". To be physically meaningful, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", "\[CircleTimes]", "\[ScriptCapitalI]"}], 
   TraditionalForm]],ExpressionUUID->"963e0648-98fb-466d-a417-ee9b97a06e22"],
 " is expected to preserve the properties, especially positivity, of density \
operators ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "1a5ba463-31c0-4bc3-a327-f5be81347c85"],
 " on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", "\[CircleTimes]", "\[ScriptCapitalE]"}], 
   TraditionalForm]],ExpressionUUID->"e1d40579-7035-488e-a323-892334e71783"],
 ". Note that ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "62dbb6f7-6a2b-4b74-8c2d-32e5e86ca283"],
 " may contain a considerable amount of entanglement due to prior \
interactions between the system and environment."
}], "TechNoteText",
 CellID->253059528,ExpressionUUID->"ad6ada0b-b979-4a58-be08-3f8fe4d9edca"],

Cell[TextData[{
 "\tMost quantum operations preserve the trace. That is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", " ", 
     RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "]"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"a1c58f6d-5800-4652-a0fc-f4c33aa85de3"],
 " for all density operators ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "d3439e56-615e-42dc-9ddd-deb3360f945a"],
 ". An important exception is the process associated with a (generalized \
selective) measurement. When the trace is not preserved, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", " ", 
     RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "]"}], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"b0e58104-d478-48d6-8c95-59fe9398c241"],
 " gives the probability for the dynamical process ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "6ba704ff-2fa8-466f-8fbe-cdd848924768"],
 " to occur."
}], "TechNoteText",
 CellID->261140628,ExpressionUUID->"175fc540-c7ab-4ec6-b8f2-02cec24e58ba"],

Cell["\<\
\tIn quantum information theory, quantum operations preserving trace, i.e., \
completely positive and trace-preserving supermaps, are called quantum \
channels. Physically, these describe communication channels that can transmit \
quantum information, as well as classical information.\
\>", "TechNoteText",
 CellID->1336314412,ExpressionUUID->"9df1eb67-f46e-43af-be6d-37b8f9e35a1d"],

Cell["\<\
\tAnother important class of physical phenomena described by quantum \
operations is quantum decoherence or just decoherence for short, referring to \
the loss of quantum coherence. We have briefly introduced this effect in the \
previous section through toy models. Quantum operations offer a complete and \
general description of decoherence.\
\>", "TechNoteText",
 CellID->1895202055,ExpressionUUID->"5248bf85-703b-4e77-9079-7e414253a128"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Kraus Representation", "TechNoteSection",
 CellID->982874389,ExpressionUUID->"753546fd-8435-48dc-92e9-df0b72985143"],

Cell[TextData[{
 "A quantum operation is a restricted form of ",
 StyleBox["completely positive ",
  FontSlant->"Italic"],
 StyleBox[ButtonBox["supermap",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Supermap"],
  FontSlant->"Italic"],
 ". Accordingly, for any quantum operation ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "994e43b6-95d7-4558-8687-97a62f81d7d7"],
 " from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], 
   TraditionalForm]],ExpressionUUID->"1965922f-e13c-4ba5-9995-fe27511c5729"],
 " onto ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalW]", ")"}], 
   TraditionalForm]],ExpressionUUID->"856bfe72-c4e4-40a8-9310-800641e81a8f"],
 ", there exist linear maps  from ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "65606d8c-a24d-42fb-a3ef-a6ab97e8a558"],
 " onto ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "d467c1ff-6acc-42dd-a8f5-c693556367df"],
 " such that"
}], "TechNoteText",
 CellID->900050528,ExpressionUUID->"3f2f2a1f-c146-46e5-a34a-f9af7761c408"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     SubscriptBox["F", "\[Mu]"], "\[Rho]", " ", 
     SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"ec012c33-d8e9-4156-9423-96f6496d1559"]
}], "TechNoteText",
 CellID->909584588,ExpressionUUID->"8285f7fa-50e1-49e6-8d07-0dbe2fb88a5c"],

Cell[TextData[{
 "for all linear operators (not necessarily density operators) ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "97861a85-f0b9-4bea-a7fa-90a8fc1700d8"],
 " on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "4737d63f-20be-45cb-a35e-63666242825f"],
 ". The linear maps ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "c11c2508-e24a-496b-9730-5c5d3ccb7776"],
 " are called the Kraus elements or the Kraus maps of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "1f28655b-44e4-4c0b-8d9a-699cea51e70c"],
 ". Then, the trace-decreasing condition in ",
 ButtonBox["axiom (a",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOperations#1105000924"],
 ")  imposes the inequalities"
}], "TechNoteText",
 CellID->27220770,ExpressionUUID->"4debac4a-1718-4f78-a039-34c203bc883c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["F", "\[Mu]"]}], "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"f42441fa-2156-4f0f-aa49-e553a5336bd2"],
 "."
}], "TechNoteText",
 CellID->1250058084,ExpressionUUID->"04789fd2-8f0f-4f8b-b71c-c1f617b7389d"],

Cell[TextData[{
 "One can always choose Kraus elements that are mutually orthogonal with \
respect to the ",
 ButtonBox["Hilbert-Schmidt inner product",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/HilbertSchmidtProduct"],
 ", that is,"
}], "TechNoteText",
 CellID->1298966276,ExpressionUUID->"ca4f73b2-5f82-4a0f-be1f-7c1eafb07d7d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", 
     RowBox[{
      SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"], 
      SubscriptBox["F", "\[Nu]"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"f485d9f3-257f-473c-9f84-2546bf514d14"]
}], "TechNoteText",
 CellID->242964381,ExpressionUUID->"9993af24-028a-47ee-a291-2bb01d967ca8"],

Cell[TextData[{
 "whenever ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "\[Nu]"}], TraditionalForm]],
  ExpressionUUID->"328e90cc-570c-4a76-8f42-157d882d3715"],
 ". Through the procedure of choosing orthogonal Kraus elements, one can \
drastically optimize Kraus elements (see below)."
}], "TechNoteText",
 CellID->1436238417,ExpressionUUID->"ebde6864-0747-4cee-a286-47019ae51fc5"],

Cell["\<\
\tThe simplest example of the Kraus representation is of the form\
\>", "TechNoteText",
 CellID->624876106,ExpressionUUID->"f17261b6-fd56-4e2c-b57a-c79ef4d0ad22"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", 
     OverscriptBox["\[Rho]", "^"], ")"}], "=", 
    RowBox[{"U", "\[VeryThinSpace]", "\[Rho]", " ", 
     SuperscriptBox["U", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "cc5e1410-bba5-4765-aec3-01439d611526"],
 ","
}], "TechNoteText",
 CellID->1542953728,ExpressionUUID->"d6f1ce08-d8df-47df-a0d9-0f55028a0078"],

Cell["\<\
involving a single unitary operator. Naturally it describes the unitary \
dynamics of a closed system. Note that if there are more than one Kraus \
elements involved in the Kraus representation, the associated dynamics is not \
unitary even if the Kraus elements are all unitary. For example, consider a \
supermap\
\>", "TechNoteText",
 CellID->1139052237,ExpressionUUID->"b1ced672-c518-46d8-bae4-4ee239ec1802"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "p"}], ")"}], "\[Rho]"}], "+", 
      RowBox[{
       FractionBox["p", "3"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"X", "\[VeryThinSpace]", "\[Rho]", "\[VeryThinSpace]", "X"}],
          "+", 
         RowBox[{"Y", "\[VeryThinSpace]", "\[Rho]", "\[VeryThinSpace]", "Y"}],
          "+", 
         RowBox[{
         "Z", "\[VeryThinSpace]", "\[Rho]", "\[VeryThinSpace]", "Z"}]}], 
        ")"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "5ab0bb8f-fa69-490d-854f-fac7b13bf1e2"],
 "."
}], "TechNoteText",
 CellID->1926524887,ExpressionUUID->"ce7cd0a5-09c6-4e64-bc4b-caa2f1ca31e9"],

Cell[TextData[{
 "Here, all Kraus elements (",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", ",", "X", ",", "Y", ",", "Z"}], TraditionalForm]],
  ExpressionUUID->"13a7b2e0-65a1-4faa-8694-fb9af0b81f6b"],
 " up to normalization factors) are unitary. However, ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "2efcd7e5-b4b9-46a7-aa18-0db66883bc51"],
 " causes depolarization in ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "cdd3a907-76d1-4c0d-a1be-09c87cbb479d"],
 " for any non-zero value of ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "98df6181-4e5b-4141-b588-8a638747943e"],
 "."
}], "TechNoteText",
 CellID->1822151804,ExpressionUUID->"1e1d6c5e-f144-4def-bbc1-3afa750f5362"],

Cell["\<\
\tThe Kraus representation of a quantum operation as a sum of operators \
provides powerful tools to analyze the quantum operation. However, at this \
stage, the Kraus representation follows from a mathematical theorem for \
completely positive supermap. How does the Kraus representation arise \
physically?\
\>", "TechNoteText",
 CellID->32693929,ExpressionUUID->"9f61ff27-f514-4c9d-8a5b-fb79595fc723"],

Cell[TextData[{
 "\tTo see how the Kraus representation arises physically, let us consider a \
system interacting with its environment. We denote with ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "d209bc6a-dc95-4683-b6f8-8a38c835d9d9"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "695129bb-aae4-4ced-aee7-5f2f7d219aea"],
 " the Hilbert spaces associated with the system and environment, \
respectively. For simplicity, we assume that the total system is initially in \
the product state ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[CircleTimes]", "\[Sigma]"}], TraditionalForm]],
  ExpressionUUID->"58ddedee-dd76-4b8e-8dc9-ba847060e21f"],
 ". The total system is a closed system, and the dynamical process afterwards \
due to the system-environment interaction is described with an overall \
unitary operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "9984de42-2578-406c-880b-d34e5d67eaab"],
 " acting on the total system, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "\[CircleTimes]", " ", "\[Sigma]"}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"U", "(", 
      RowBox[{"\[Rho]", "\[CircleTimes]", " ", "\[Sigma]"}], ")"}], 
     SuperscriptBox["U", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "c8a092f8-d35f-4c1f-ad67-0b658be4bf06"],
 ". Without access to the environment, one has to take a partial trace of the \
final state over the environment to obtain the state of the system. Putting \
it all together, the quantum operation ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "bb757b75-003b-4eee-a818-74f88559178b"],
 " describing the process is written as"
}], "TechNoteText",
 CellID->224328286,ExpressionUUID->"43fa6ca8-e881-4c81-983b-cf94653f0ee3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["Tr", "\[ScriptCapitalE]"], "[", 
      RowBox[{
       RowBox[{"U", "(", 
        RowBox[{"\[Rho]", "\[CircleTimes]", " ", "\[Sigma]"}], ")"}], 
       SuperscriptBox["U", "\[Dagger]"]}], "]"}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "i"], 
      TemplateBox[{
        SubscriptBox["\[CurlyEpsilon]", "i"]},
       "Bra"], 
      RowBox[{"U", "(", 
       RowBox[{"\[Rho]", "\[CircleTimes]", " ", "\[Sigma]"}], ")"}], 
      SuperscriptBox["U", "\[Dagger]"], 
      TemplateBox[{
        SubscriptBox["\[CurlyEpsilon]", "i"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "739d7839-d984-48ae-93af-2722aa189113"],
 ","
}], "TechNoteText",
 CellID->999013742,ExpressionUUID->"af599943-427a-4aed-973e-6e7961c0bbbc"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["\[CurlyEpsilon]", "i"]},
        "Ket"], "|", "i"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     SubscriptBox["d", "\[ScriptCapitalE]"]}], "}"}], TraditionalForm]],
  ExpressionUUID->"9c25f276-b34c-43fc-9724-ee16341783aa"],
 " is an orthonormal basis of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "7cf2cf1f-5d64-492b-8a7a-c36128dd36c5"],
 " of dimension ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["d", "\[ScriptCapitalE]"], TraditionalForm]],ExpressionUUID->
  "de11eaff-76b1-49b6-8614-369736fb2b79"],
 ". On the right-hand side of the above equation, the Hermitian product is \
applied partially and only on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "74ffb01c-9b9d-499c-8a5d-6620daade9cb"],
 ", and the expression still remains as an operator on \[ScriptCapitalV]. To \
construct the Kraus elements, we first take the spectral decomposition of ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]],ExpressionUUID->
  "8956fa1a-4612-4059-a3ca-652ad9da43a8"]
}], "TechNoteText",
 CellID->300876422,ExpressionUUID->"f323d99e-ce87-47dc-b657-33c26bff8913"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], "r"], 
     TemplateBox[{
       SubscriptBox["s", "j"]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox["s", "j"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "4871c1d0-706d-4c11-8fe6-00e3e3e68ea1"],
 ","
}], "TechNoteText",
 CellID->163388462,ExpressionUUID->"9a4ce974-ed9d-48df-a1cb-79d1d3bcc145"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "ab512853-e6e0-4fc9-82cf-c9ddea38e8a3"],
 " is the rank of ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]],ExpressionUUID->
  "c0ec8b54-69bd-47e8-943b-3ad68175e2b5"],
 ", and the eigenvectors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["s", "j"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2b3eb73d-f441-4a07-aed0-81064f498a41"],
 " of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["\[Sigma]", "^"], TraditionalForm]],ExpressionUUID->
  "4eb41b36-84ec-4078-92ea-a77e62ed0ae2"],
 " have been normalized by their own eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "j"], "=", 
    TemplateBox[{
      SubscriptBox["s", "j"], 
      SubscriptBox["s", "j"]},
     "BraKet"]}], TraditionalForm]],ExpressionUUID->
  "e7ced4e2-e64e-4a59-aba6-f38576afa66b"],
 " since ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]],ExpressionUUID->
  "21866b97-e9cd-4f58-b5fe-dc67115e04e4"],
 " is a positive semidefinite operator. We then define linear maps ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":", 
    RowBox[{"\[ScriptCapitalV]", "\[RightTeeArrow]", "\[ScriptCapitalW]"}]}], 
   TraditionalForm]],ExpressionUUID->"24c2d010-6df7-4ca7-9bba-65e1d4e15f7d"],
 " for each ",
 StyleBox["i",
  FontSlant->"Italic"],
 " and ",
 StyleBox["j",
  FontSlant->"Italic"],
 " by"
}], "TechNoteText",
 CellID->498651953,ExpressionUUID->"a802b647-21c9-4a96-ad36-5fc7e33ddd9c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["Tr", "\[ScriptCapitalE]"], "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"I", "\[CircleTimes]", 
           TemplateBox[{
             SubscriptBox["\[CurlyEpsilon]", "i"]},
            "Ket"]}], 
          TemplateBox[{
            SubscriptBox["s", "j"]},
           "Bra"]}], ")"}], "\[Dagger]"], "U"}], "]"}], "=", 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[CurlyEpsilon]", "i"]},
       "Bra"], "U", 
      TemplateBox[{
        SubscriptBox["s", "j"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "773654b5-f073-4739-b4ab-96bf6f360b39"],
 " ."
}], "TechNoteText",
 CellID->53268147,ExpressionUUID->"f3aa85c1-bbcd-4e31-a7c4-1e9abb3e1ead"],

Cell[TextData[{
 "In the quantum circuit model, ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOperations#1325880530"],
 " depicts the above definition. Physically,  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],ExpressionUUID->
  "44afb134-6894-4245-8895-b7e054fc75af"],
 " describes the dynamics of the system under the condition that the \
environment has made a transition from the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["s", "j"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "4b5826ed-1990-4088-9345-8e2335853e95"],
 " to state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[CurlyEpsilon]", "i"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6a02e96f-cd50-444e-a350-da03dd56a4de"],
 " under the unitary interaction between the system and environment. We \
finally regard ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{"i", ",", "j"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "71b4b351-de90-479a-88b8-f7a9c41e3218"],
 " as a collective index and identify ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "\[Mu]"], "\[Congruent]", 
    SubscriptBox["F", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]]}], TraditionalForm]],
  ExpressionUUID->"6a8d5bd3-900c-4db6-928e-c95e4544d847"],
 " to be the desired Kraus elements. Clearly, they satisfy the closure \
relation"
}], "TechNoteText",
 CellID->682491,ExpressionUUID->"ecdd36f0-940a-4295-8cd2-2b250bf52776"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["F", "\[Mu]"]}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"03f1c9a4-556f-4db5-9da2-5ead168f7059"],
 "."
}], "TechNoteText",
 CellID->560219235,ExpressionUUID->"669d3eaa-303f-4bea-ad60-5d1ca277f189"],

Cell[TextData[{
 "Putting this equation to the expression for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], TraditionalForm]],
  ExpressionUUID->"cdd4195e-7d0c-48fc-942b-b30f437d6e3f"],
 ", we arrive at the representation"
}], "TechNoteText",
 CellID->861639425,ExpressionUUID->"3db06c33-5956-4f24-86fa-3f20c9aef527"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     SubscriptBox["F", "\[Nu]"], "\[Rho]", " ", 
     SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"29407d5b-8959-44bb-87ac-670a5d847aea"],
 " ."
}], "TechNoteText",
 CellID->1380274610,ExpressionUUID->"fa28a7e3-f184-4e9d-910b-faac2da8fdc3"],

Cell[BoxData[
 InterpretationBox[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {4, -1}}, {{0, -2}, {4, -2}}}], InsetBox[
     TemplateBox[{"\"\[Psi]\""},
      "Ket"], {-0.2, -1.}, NCache[
     ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1, 
     0}], InsetBox[
     TemplateBox[{
       SubscriptBox["s", "j"]},
      "Ket"], {-0.2, -2.}, NCache[
     ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1, 
     0}], {
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -2.4}, {1.4, -0.6}]}, InsetBox[
      StyleBox["\<\"U\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.1],
       FontWeight->"Light",
       FontSlant->Italic], {1., -1.5}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}, 
    {LightDarkSwitched[
      GrayLevel[1]], EdgeForm[Opacity[1]], 
     PolygonBox[{{3.4, -1.8}, {2.6, -1.6}, {2.6, -2.4}, {3.4, -2.2}}]}, 
    InsetBox[
     RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(F\\), \\(i\[VeryThinSpace]j\\)]\\)\
\"\>", " ", 
      TemplateBox[{"\"\[Psi]\""},
       "Ket"]}], {4.2, -1.}, NCache[
     ImageScaled[{0, Rational[1, 2]}], ImageScaled[{0, 0.5}]], Automatic, {1, 
     0}], InsetBox[
     TemplateBox[{
      "\"\\!\\(\\*SubscriptBox[\\(\[CurlyEpsilon]\\), \\(i\\)]\\)\""},
      "Ket"], {4.2, -2.}, NCache[
     ImageScaled[{0, Rational[1, 2]}], ImageScaled[{0, 0.5}]], Automatic, {1, 
     0}]},
   ImagePadding->{{38.160000000000004`, 56.160000000000004`}, {7.2, 7.2}},
   ImageSize->234.,
   PlotRange->{{0, 4}, {-2.5, -0.5}},
   PlotRangePadding->Scaled[0.025]],
  QuantumMob`Q3`QuantumCircuit[
   QuantumMob`Q3`PortIn[{
     Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 0|>], "Label" -> 
     Ket[{"\[Psi]"}]}, {
     Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 0|>], "Label" -> Ket[{
        Subscript[$CellContext`s, $CellContext`j]}]}], {$CellContext`S[
     1, 1] + $CellContext`S[2, 1], "Label" -> "U"}, "Spacer", 
   QuantumMob`Q3`Projector[
    Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 1|>], {
     $CellContext`S[2, QuantumMob`Q3`$]}], 
   QuantumMob`Q3`PortOut[{
     Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 1|>], "Label" -> 
     "\!\(\*SubscriptBox[\(F\), \(i\[VeryThinSpace]j\)]\)" Ket[{"\[Psi]"}]}, {
    
     Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 1|>], "Label" -> 
     Ket[{"\!\(\*SubscriptBox[\(\[CurlyEpsilon]\), \(i\)]\)"}]}], 
   "PortSize" -> {1, 1.5}]]], "TechNoteText",
 TextAlignment->-0.5,
 CellID->1325880530,ExpressionUUID->"2af0646d-5b1b-4749-934c-d09b93b410e7"],

Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Quantum circuit describing the Kraus element ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],ExpressionUUID->
  "00ff9c4b-034b-40e1-8ad4-d2fbf2024e00"],
 " corresponding to the dynamics of the system on condition that the \
environment has made a transition from the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["s", "j"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ff960a71-10af-4171-a729-48330cec7f54"],
 " to state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[CurlyEpsilon]", "i"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "409a07df-2724-4c43-a6d8-3f1ab0e537da"],
 " under the unitary interaction ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "3275db73-171b-4587-b21e-ba1ef2059ddf"],
 " between the system and environment."
}], "TechNoteCaption",
 CellID->1146376630,ExpressionUUID->"80917de9-bda1-437b-bb7f-75d8d15f924d"],

Cell[TextData[{
 "\tIn the above arguments, we have derived a Kraus representation for a \
quantum operation based on a system-plus-environment model. While it provides \
a useful physical picture of quantum operations, the resulting representation \
does not look particularly useful at first glance. The Kraus elements ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "57c06d24-4f2b-4f8d-be06-035c87fe1b73"],
 " are not orthogonal to each other with respect to the Hilbert-Schmidt inner \
product. Even worse, the number of Kraus elements is equal to the dimension \
of the environmental Hilbert space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "cbacc81b-01a8-4f71-be70-f6aa55a2dd38"],
 " and may be huge given that the dimension of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "4c2f8c9f-2871-41ef-9ba8-90fd17681475"],
 " is infinite for any realistic environment. However, neither raises a \
significant problem. A formal representation in the form of the Kraus \
representation already facilitates analysis of the quantum operation. \
Moreover, one can optimize the Kraus elements by reconstructing orthogonal \
Kraus elements as we see in the next section."
}], "TechNoteText",
 CellID->443425371,ExpressionUUID->"57bcc1a4-ea6d-4246-9739-e64ed0dd28ed"],

Cell[CellGroupData[{

Cell["Optimization of Kraus Representation", "Subsection",
 CellID->394417576,ExpressionUUID->"911ffb2b-d114-4d4d-ad04-233e802a174d"],

Cell[TextData[{
 "Given a set of Kraus elements, how can one actually choose new Kraus \
elements that are mutually orthogonal. Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["E", "\[Mu]"], "}"}], TraditionalForm]],ExpressionUUID->
  "ef7e5060-edb7-40f2-a5ab-f881ca296798"],
 " be a basis of the space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", 
    RowBox[{"\[ScriptCapitalV]", ",", "\[ScriptCapitalW]"}], ")"}], 
   TraditionalForm]],ExpressionUUID->"cd339dbd-3b02-44ed-a22a-686d1a3e35f3"],
 " of all linear maps from ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "16b20988-498e-44e7-9baf-dd1ce03ba6c4"],
 " to ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "8f91b790-69d4-4df0-bd5d-dde8f4e70751"],
 ". We expand ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "dac3a7ba-cbfe-45fd-aa4f-cfcecf6b6f2e"],
 " in this basis"
}], "TechNoteText",
 CellID->1951588523,ExpressionUUID->"b26129a6-0ba0-458f-a340-5c70d068553e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "\[Nu]"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     SubscriptBox["E", "\[Mu]"], 
     SubscriptBox["M", 
      RowBox[{"\[Mu]", "\[ThinSpace]", "\[Nu]"}]]}]}], TraditionalForm]],
  ExpressionUUID->"787b5d47-eebe-4d1a-910e-ef8a0d8989b4"],
 " ,"
}], "TechNoteText",
 CellID->1453137690,ExpressionUUID->"1ee867a4-6a8c-4e1f-b181-fa573cd2abaf"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "079c430f-74bc-4850-a9ae-53bad685ab92"],
 " is the matrix of the expansion coefficients. Putting it back to the Kraus \
representation, we have"
}], "TechNoteText",
 CellID->1704633450,ExpressionUUID->"eb87390f-20a3-4b24-980a-6d00937d9ed6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "\[ThinSpace]", "\[Nu]"}]], 
     SubscriptBox["E", "\[Mu]"], "\[Rho]", " ", 
     SubscriptBox[
      RowBox[{
       SubsuperscriptBox["E", "\[Nu]", "\[Dagger]"], "(", 
       RowBox[{"M", "\[VeryThinSpace]", 
        SuperscriptBox["M", "\[Dagger]"]}], ")"}], 
      RowBox[{"\[Mu]", "\[ThinSpace]", "\[Nu]"}]]}]}], TraditionalForm]],
  ExpressionUUID->"f681edf9-3482-4a37-8f9a-1f6ca16e4cd4"],
 "."
}], "TechNoteText",
 CellID->541838477,ExpressionUUID->"651b2414-c849-4870-8337-fc758c30b942"],

Cell[TextData[{
 "The square matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "\[VeryThinSpace]", 
    SuperscriptBox["M", "\[Dagger]"]}], TraditionalForm]],ExpressionUUID->
  "99406fc0-4b3f-4faf-9064-fbdee24d41f4"],
 " of size ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"dim", " ", "\[ScriptCapitalV]"}], ")"}], "\[Times]", 
    RowBox[{"(", 
     RowBox[{"dim", " ", "\[ScriptCapitalW]"}], ")"}], " "}], 
   TraditionalForm]],ExpressionUUID->"3e4d2304-6e06-4a77-9b0e-a15d57280cce"],
 " is positive semidefinite, and can be decomposed into ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"M", "\[ThinSpace]", 
     SuperscriptBox["M", "\[Dagger]"]}], "=", 
    RowBox[{"V", "\[ThinSpace]", "\[CapitalLambda]", "\[ThinSpace]", 
     SuperscriptBox["V", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "d0b8029d-067b-4e50-b08d-8ecef4fbae3a"],
 ", where ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "2d71e313-ce00-45b8-88d6-919215533d95"],
 " is a unitary matrix and \[CapitalLambda] is a diagonal matrix with all \
elements non-negative. We now define new Kraus elements"
}], "TechNoteText",
 CellID->1136483731,ExpressionUUID->"f172e1ff-3397-4cf7-8484-a0ae40ad2e41"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["F", "\[Nu]", "\[Prime]"], ":=", 
    SubscriptBox[
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "\[Mu]"], "(", 
      RowBox[{"V", 
       SqrtBox["\[CapitalLambda]"]}], ")"}], 
     RowBox[{"\[Mu]", "\[ThinSpace]", "\[Nu]"}]]}], TraditionalForm]],
  ExpressionUUID->"6a2bff83-66ae-42e2-a29e-dfcc96647a6c"],
 " ."
}], "TechNoteText",
 CellID->705333036,ExpressionUUID->"15551d2a-8819-4d82-a0bc-7c7d2291c72e"],

Cell["\<\
Then, it is clear that they are mutually orthogonal. Furthermore,\
\>", "TechNoteText",
 CellID->673854178,ExpressionUUID->"fed66144-084c-4824-ac34-8328f0c012c3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     SubsuperscriptBox["F", "\[Nu]", "\[Prime]"], "\[Rho]", " ", 
     SubsuperscriptBox["F", "\[Mu]", "\[Prime]\[Dagger]"]}]}], 
   TraditionalForm]],ExpressionUUID->"688bbc0d-491e-4ad9-8d58-9f5ce7a6c9d2"],
 " ,"
}], "TechNoteText",
 CellID->1531905680,ExpressionUUID->"b9bff67b-d355-4f74-9f66-3e0c1fe835d8"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "\[LessEqual]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"dim", " ", "\[ScriptCapitalV]"}], ")"}], "\[Times]", 
     RowBox[{"(", 
      RowBox[{"dim", " ", "\[ScriptCapitalW]"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"c6fa6bbb-c8c8-455c-a26b-60f858fa41eb"],
 ". Therefore, it is noted that a set of mutually orthogonal Kraus elements \
is optimal in the sense that it has no more elements than ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"dim", "\[ThinSpace]", "\[ScriptCapitalV]"}], ")"}], "\[Times]", 
    
    RowBox[{"(", 
     RowBox[{"dim", "\[ThinSpace]", "\[ScriptCapitalW]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"660a94ae-c89c-41b2-b464-8886cf584493"],
 "."
}], "TechNoteText",
 CellID->1137795090,ExpressionUUID->"420e6cb2-1fbe-446e-bf67-bb0c24c4f041"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Unitary Freedom of Kraus Elements", "Subsection",
 CellID->1069865523,ExpressionUUID->"09ffd04d-06c1-43fa-990c-bf19ee147fa1"],

Cell["(to be completed)", "TechNoteText",
 CellID->2083285698,ExpressionUUID->"e3aea6d4-4f2a-48cf-b477-5aef8b104f96"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Choi Isomorphism", "TechNoteSection",
 CellID->2111356922,ExpressionUUID->"8f9b8926-898a-42e1-9541-498a4f611108"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["Choi isomorphism",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ChoiIsomorphism"],
  FontSlant->"Italic"],
 " is a one-to-one correspondence between supermaps and (usual) operators. It \
allows us to inspect a supermap in terms of the corresponding operator. It \
can reveal additional properties of the supermap that is not immediately \
clear from the supermap itself. "
}], "TechNoteText",
 CellID->968800451,ExpressionUUID->"7b76ae90-0791-4b58-9a6c-435224c76f5c"],

Cell[TextData[{
 "\tOne can also use it for physically-motivated proofs of the Kraus \
representation theorem discussed above in terms of the ",
 ButtonBox["quantum gate teleportation protocol",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ChoiIsomorphism#359402829"],
 ". For those proofs, we refer interested readers to  Section 5.2.2 of the ",
 ButtonBox["Quantum Workbook (2022)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-3-030-91214-7"], None}],
 "."
}], "TechNoteText",
 CellID->1689931507,ExpressionUUID->"033279ca-270c-4891-9975-09c3351dc620"],

Cell[TextData[{
 "\tAnother interesting application of the Choi isomorphism is a rigorous \
proof of the unitary freedom of Kraus  elements mentioned above. It is not \
explicitly provided in this document. We refer interested readers to Section \
5.2.2 of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "f5bb271c-9102-4f22-91f6-18e02d71f867"],
 "."
}], "TechNoteText",
 CellID->983344595,ExpressionUUID->"09e0109b-9f72-47a1-949a-c9a399855819"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Unitary Representation", "TechNoteSection",
 CellID->1215528911,ExpressionUUID->"1841c69f-8598-4cb6-b9ee-dc12908890c3"],

Cell["\<\
A quantum operation can always be regarded as a unitary operator on an \
extended system, which involves an \[OpenCurlyDoubleQuote]environment\
\[CloseCurlyDoubleQuote] in addition to the original \
\[OpenCurlyDoubleQuote]system\[CloseCurlyDoubleQuote]. Although it is not \
particularly useful for practical applications, the unitary representation \
provides a clear physical insight into the underlying physical processes \
described by the quantum operation.\
\>", "TechNoteText",
 CellID->900806841,ExpressionUUID->"21e62db2-df02-4ee5-9e46-6fa2a410e33c"],

Cell[TextData[{
 "\tSuppose that we are given a quantum operation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", ":", 
    RowBox[{
     RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], "\[RightArrow]", 
     RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"681b1e71-d863-4cc5-a967-cdd8b8de5962"],
 " specified by the Kraus representation in terms of the Kraus elements ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "1a5d4920-358e-4184-9a8a-ca5ca31d1ed1"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Mu]", " ", "=", "0"}], ",", "1", ",", 
    RowBox[{".", " ", ".", " ", "."}], " ", ",", 
    RowBox[{"m", "\[Minus]", "1"}]}], TraditionalForm]],ExpressionUUID->
  "006c9c3f-4a1f-4b0e-b009-126850953f6a"],
 "). As such, we want to construct a system-plus-environment\nmodel that \
produces the same effect as ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "811cfacc-1422-4a6e-9b08-98bc4f444b43"],
 " when the environment is traced out. Therefore, we need to find a proper \
vector space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "7f532bfa-a24c-4dcb-b17d-c313ac7fd631"],
 " for the environment and an overall unitary operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "4550011a-b1b5-48f9-b7d7-314071c67a87"],
 " acting on the total system ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", "\[CircleTimes]", "\[ScriptCapitalE]"}], 
   TraditionalForm]],ExpressionUUID->"faf63750-904a-4a38-b5fa-706a33f562af"],
 " such that"
}], "TechNoteText",
 CellID->1077265708,ExpressionUUID->"41379c77-62c2-4702-b32b-37ada7d200fc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], " ", "=", 
    RowBox[{
     UnderscriptBox["Tr", "\[ScriptCapitalE]"], " ", "[", 
     RowBox[{
      RowBox[{"U", "(", 
       RowBox[{
        RowBox[{"\[Rho]", "\[CircleTimes]", 
         TemplateBox[{
           SubscriptBox["\[Epsilon]", "0"]},
          "Ket"]}], 
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "0"]},
         "Bra"]}], ")"}], 
      SuperscriptBox["U", "\[Dagger]"]}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"6ebfd7a2-ff2a-4f0f-844e-1ab4fc2becf8"]
}], "TechNoteText",
 CellID->1353395088,ExpressionUUID->"e479b26c-0ef8-4453-8df3-b7f42fbee5ec"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "59ff6df7-aa98-459b-a2af-17bad85ba4ac"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalV]", ")"}], 
   TraditionalForm]],ExpressionUUID->"6f832a10-cace-4e88-8512-29339a4de733"],
 " and a particular state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "fdd252bd-cc6f-4fce-bb1f-75f9f7c9fbcf"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "388af5b3-cd11-4863-9828-7fa2af2c0737"],
 ". The choice of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e3f832df-6c1f-443c-92fb-08d5ab06018c"],
 " is completely arbitrary, and one can even choose a mixed state."
}], "TechNoteText",
 CellID->223923010,ExpressionUUID->"cb122c7e-d769-4d25-9ee0-778a6000d05a"],

Cell[TextData[{
 "\tWe first construct the vector space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "889962e9-9a9c-4dbb-98c0-bd6aad7c6f32"],
 " associated with the environment by choosing an orthonormal basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"], ",", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "1"]},
      "Ket"], ",", "\[Ellipsis]", ",", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", 
        RowBox[{"m", "-", "1"}]]},
      "Ket"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "2f20e61c-ce15-4ae6-be04-b3f7582796f4"],
 ". Here, just for convenience, we have chosen the basis so as for it to \
include the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b6096636-fb34-4215-bd36-5e5ddf22524d"],
 ", but it is not necessary. Note that the required dimension ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "419000d6-4446-4c30-a222-1c82e6584fce"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "9a2a6119-3e61-44f1-8f97-59f97d464462"],
 " is the same as the number of the Kraus elements ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["F", "^"], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "8a0462ee-ef95-496a-a796-dbc2b9d0de29"],
 " in the Kraus representation and is no larger than ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"dim", "\[VeryThinSpace]", "\[ScriptCapitalV]"}], ")"}], "2"], 
   TraditionalForm]],ExpressionUUID->"97b82c11-1df8-4c98-ace9-5b0f43d092a0"],
 ". "
}], "TechNoteText",
 CellID->315034206,ExpressionUUID->"5bb997e9-664f-4db6-ad43-bd1193656b16"],

Cell[TextData[{
 "\tDefine a unitary operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "b94d9225-b575-4c01-b916-0528a2d1b483"],
 " on ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", "\[CircleTimes]", "\[ScriptCapitalE]"}], 
   TraditionalForm]],ExpressionUUID->"b3f4c179-16c9-43cb-bb2c-15b1b3b42ce8"],
 " by requiring that"
}], "TechNoteText",
 CellID->1273644297,ExpressionUUID->"eb3a0398-cfd5-4321-bce8-b6cdfe51b710"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", 
     RowBox[{
      TemplateBox[{"\[Psi]"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["\[Epsilon]", "0"]},
       "Ket"]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "\[Mu]"], "(", 
      RowBox[{"U", 
       TemplateBox[{"\[Psi]"},
        "Ket"]}], ")"}], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "\[Mu]"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "51cd94c0-da0f-4367-9339-5c078d8f536b"]
}], "TechNoteText",
 CellID->884141549,ExpressionUUID->"cf34cf63-0272-4a52-8e5a-c409e3bf0840"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "1beb0ebb-b855-4f20-8645-baf29875676b"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "9444c78b-3654-41fb-a8aa-6956c53cfdf0"],
 ". Clearly, taking the partial trace over the environment reproduces ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", "(", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], 
     TemplateBox[{"\[Psi]"},
      "Bra"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "61e31f73-da43-48d3-beca-6e08406a3964"],
 " as one can see from an explicit evaluation"
}], "TechNoteText",
 CellID->1624115362,ExpressionUUID->"2af249a9-5ee7-4b09-8dd5-6ef878bf2ded"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["Tr", "\[ScriptCapitalE]"], " ", "[", 
     RowBox[{
      RowBox[{"U", "(", 
       RowBox[{
        TemplateBox[{"\[Psi]"},
         "Ket"], 
        RowBox[{
         TemplateBox[{"\[Psi]"},
          "Bra"], "\[CircleTimes]", 
         TemplateBox[{
           SubscriptBox["\[Epsilon]", "0"]},
          "Ket"]}], 
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "0"]},
         "Bra"]}], ")"}], 
      SuperscriptBox["U", "\[Dagger]"]}], "]"}], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
      RowBox[{
       UnderscriptBox["Tr", "\[ScriptCapitalE]"], "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["F", "\[Mu]"], 
           TemplateBox[{"\[Psi]"},
            "Ket"], 
           TemplateBox[{"\[Psi]"},
            "Bra"], 
           SubsuperscriptBox["F", "\[Nu]", "\[Dagger]"]}], ")"}], "\[CircleTimes]", 
         TemplateBox[{
           SubscriptBox["\[Epsilon]", "\[Mu]"]},
          "Ket"]}], 
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "\[Nu]"]},
         "Bra"]}], "]"}]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
      SubscriptBox["F", "\[Mu]"], 
      TemplateBox[{"\[Psi]"},
       "Ket"], 
      TemplateBox[{"\[Psi]"},
       "Bra"], 
      SubsuperscriptBox["F", "\[Nu]", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"ecee966a-2270-420e-9862-2b4aafeed5d0"],
 " ."
}], "TechNoteText",
 CellID->785717990,ExpressionUUID->"95414f09-f8e5-4ae1-9935-6d53ecd8d476"],

Cell[TextData[{
 "This relation is linear and holds for an arbitrary vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "44bf8134-07cc-48cf-a6eb-1a097d2e5bd2"],
 ", and hence it should holds for any mixed state \t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "j"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[Psi]", "j"]},
       "Ket"], 
      SubscriptBox["p", "j"], 
      TemplateBox[{
        SubscriptBox["\[Psi]", "j"]},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "678f644c-b158-4876-9bfc-3999515abafa"],
 "."
}], "TechNoteText",
 CellID->112683358,ExpressionUUID->"21d55f3c-c870-41be-a153-114541c61074"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples", "TechNoteSection",
 CellID->269244870,ExpressionUUID->"5056c8fa-01bf-4027-b1f9-657f3c331a7c"],

Cell["\<\
So far, we discussed a general description of quantum noisy processes in \
terms of the corresponding quantum operations. Let us now present some \
examples for a single qubit. We consider some limiting cases that allow us to \
easily grasp the physical meaning of the Kraus elements.\
\>", "TechNoteText",
 CellID->1071258735,ExpressionUUID->"c9b57db6-b78d-4b63-9955-1c00af25572d"],

Cell[CellGroupData[{

Cell["Phase Damping", "Subsection",
 CellID->142662697,ExpressionUUID->"9aa34bad-e3aa-4c89-9e0f-49424946060c"],

Cell[TextData[{
 "The phase damping process is a decoherence process without involving any \
relaxation of energy or change in the population over the states. In this \
sense, it may be regarded as a pure decoherence process without involving any \
energy relaxation. For this reason, it is also referred to as a ",
 StyleBox["dephasing",
  FontSlant->"Italic"],
 " process."
}], "TechNoteText",
 CellID->1140198427,ExpressionUUID->"5bcd9450-e55f-4fe1-8d76-14812280d7e5"],

Cell["\<\
The unitary representation of a phase damping process in a single-qubit \
system is given by\
\>", "TechNoteText",
 CellID->1318380408,ExpressionUUID->"85efb6e3-6f82-44df-af7d-57d302fd5954"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "42daee29-2aaf-43f9-8da7-2e83e42f45ca"],
 " ,"
}], "TechNoteText",
 CellID->283247510,ExpressionUUID->"7ae2f7dd-e743-4f08-b660-953e2aeca58d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"1"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["\[Epsilon]", "0"]},
        "Ket"]}], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}], "+", 
     RowBox[{
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["\[Epsilon]", "1"]},
        "Ket"]}], 
      SqrtBox["p"]}]}]}], TraditionalForm]],ExpressionUUID->
  "7b2ad548-aced-4ad2-9ca2-28f98aa8fcec"],
 " ,"
}], "TechNoteText",
 CellID->1717138818,ExpressionUUID->"6de4155a-3f29-449a-b0dc-3fbd5e64d22c"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"], ",", " ", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "1"]},
      "Ket"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "eff7fc11-2724-4fdc-b247-d96683453bbe"],
 " is an orthonormal basis of the vector space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "d4fe7155-a03f-4310-8b04-2fc55831faa2"],
 " associated with the environment. It indicates that when and only when the \
system is in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3164662d-dfdb-4f57-b4a0-fba01647579e"],
 ", the environment changes its state from the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2785989c-8e42-460c-a575-cece20ba405e"],
 " to another orthogonal state |\[CurlyEpsilon]1\:27e9 with probability ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "ea2226a4-3730-41b9-a9e1-8b8c1b3023ac"],
 ". Note that the system remains in the same state in both cases. The key \
point is that the environment nevertheless \[OpenCurlyDoubleQuote]knows\
\[CloseCurlyDoubleQuote] which state the system is in and this knowledge \
leads to a loss of coherence in the state of the system."
}], "TechNoteText",
 CellID->2066865740,ExpressionUUID->"e00c77f8-7a24-4195-bfb2-70f06ced7992"],

Cell[TextData[{
 "Indeed, the total unitary operator is a controlled-",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "251125c7-a2fa-4d5a-899f-87a0b36b6455"],
 " operator with"
}], "TechNoteText",
 CellID->117018308,ExpressionUUID->"a9830b7c-401c-4edd-ae5b-684c8243602e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {
        SqrtBox[
         RowBox[{"1", "-", "p"}]], 
        RowBox[{"-", 
         SqrtBox["p"]}]},
       {
        SqrtBox["p"], 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "bbd29efb-d291-4569-89c4-5ce99bb7d4d7"]
}], "TechNoteText",
 CellID->1779165551,ExpressionUUID->"cd8039c3-1010-4d4d-9453-594a827b2ccb"],

Cell[TextData[{
 "in the basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"], ",", " ", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "1"]},
      "Ket"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "d05c7553-2075-4574-ac2e-292c3d4be285"],
 ". As a result, when the system is prepared in a coherent superposition, the \
controlled-",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "4db5f087-cce9-449f-8dd5-0ea76b5b3f67"],
 " operator creates an entanglement between the system and the environment"
}], "TechNoteText",
 InitializationCell->True,
 CellID->873114829,ExpressionUUID->"5c4de809-6296-438e-9d9f-2c83d9ff59b8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], 
        SubscriptBox["c", "0"]}], "+", 
       RowBox[{
        TemplateBox[{"1"},
         "Ket"], 
        SubscriptBox["c", "1"]}]}], ")"}], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["\[Epsilon]", "0"]},
        "Ket"]}], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], "\[CircleTimes]", 
      RowBox[{"(", 
       RowBox[{"U", 
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "1"]},
         "Ket"]}], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "659af31e-2a07-4817-afa8-62a8a5a94255"],
 " "
}], "TechNoteText",
 CellID->685171052,ExpressionUUID->"bde2ee18-f861-46d6-92e5-d58ba5dcd00f"],

Cell["or, more explicitly,", "TechNoteText",
 CellID->862555750,ExpressionUUID->"afc03cb8-8900-44da-849d-5bd31a11db9f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], 
        SubscriptBox["c", "0"]}], "+", 
       RowBox[{
        TemplateBox[{"1"},
         "Ket"], 
        SubscriptBox["c", "1"]}]}], ")"}], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Epsilon]", "0"]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], 
         SubscriptBox["c", "0"]}], "+", 
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], 
         SubscriptBox["c", "1"], 
         SqrtBox[
          RowBox[{"1", "-", "p"}]]}]}], ")"}], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["\[Epsilon]", "0"]},
       "Ket"]}], "+", 
     RowBox[{
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["\[Epsilon]", "1"]},
        "Ket"]}], 
      SubscriptBox["c", "1"], 
      SqrtBox["p"]}]}]}], TraditionalForm]],ExpressionUUID->
  "72b22331-09f9-44b2-9765-c8f6741e1200"],
 " . "
}], "TechNoteText",
 CellID->1459873000,ExpressionUUID->"7fd983e9-de98-4943-adaa-7a8479092e22"],

Cell["\<\
Due to the entanglement, the final state of the system alone cannot be a pure \
state and coherence in the initial state has been lost through the process. \
With the prescription above, the Kraus elements are given by\
\>", "TechNoteText",
 CellID->1084844025,ExpressionUUID->"92b36097-9cc8-4aca-b9b0-c188e95a0583"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "0"], "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "3a86ee67-6dbc-4beb-b7de-de1c0f2892d2"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "1"], "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"0", "0"},
       {"0", 
        SqrtBox["p"]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "3c4ceb8a-8de2-4e5c-8b7d-75aa03e479af"]
}], "TechNoteText",
 CellID->837365145,ExpressionUUID->"8623d31e-3b85-4fdb-8d6c-8ca29dda1884"],

Cell["and the corresponding quantum operation is given by", "TechNoteText",
 CellID->1135653224,ExpressionUUID->"e3d604d4-de03-4dca-bbd4-2915aa308a41"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["E", "0"], "\[Rho]", "\[VeryThinSpace]", 
      SubsuperscriptBox["E", "0", "\[Dagger]"]}], "+", 
     RowBox[{
      SubscriptBox["E", "1"], "\[Rho]", "\[VeryThinSpace]", 
      SubsuperscriptBox["E", "1", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"2cdd3e9c-24bd-4ff5-9aaf-0054e51131b4"],
 " ."
}], "TechNoteText",
 CellID->89081232,ExpressionUUID->"d5f1dcf7-6288-47f6-ac10-749d3285d932"],

Cell["Note  that  they  are  not  orthogonal,", "TechNoteText",
 CellID->392164265,ExpressionUUID->"dbf9f047-5bf8-4dac-92b2-78e51429c0ae"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", 
     RowBox[{
      SubsuperscriptBox["E", "0", "\[Dagger]"], 
      SubscriptBox["E", "1"]}], "]"}], "=", 
    RowBox[{
     SqrtBox[
      RowBox[{"p", "(", 
       RowBox[{"1", "-", "p"}], ")"}]], "\[NotEqual]", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"36ae719a-3cf7-42e9-9167-b49d06cf8956"],
 "."
}], "TechNoteText",
 CellID->477489212,ExpressionUUID->"0d6d0b27-f922-4314-b6c6-cfb219f9c81d"],

Cell["\<\
It is therefore more convenient and efficient to choose mutually orthogonal \
Kraus elements\
\>", "TechNoteText",
 CellID->14797245,ExpressionUUID->"bd2ffe47-7fa9-444a-afed-b041ba075792"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "0"], "=", 
    RowBox[{
     FractionBox[
      SqrtBox[
       RowBox[{"1", "+", 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}]], "2"], "I"}]}], TraditionalForm]],
  ExpressionUUID->"62877ece-d747-4ab1-9627-3fc24af5ae5f"],
 " ,     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "1"], "=", 
    RowBox[{
     FractionBox[
      SqrtBox[
       RowBox[{"1", "-", 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}]], "2"], "Z"}]}], TraditionalForm]],
  ExpressionUUID->"f14881f5-cc86-4cdf-86d1-c9816c8f49e0"]
}], "TechNoteText",
 CellID->1736677310,ExpressionUUID->"41e3b776-ac54-400a-a050-9667e6b82bc8"],

Cell["\<\
In short, the quantum operation for the phase damping process is written as\
\>", "TechNoteText",
 CellID->1885302793,ExpressionUUID->"253193c7-7043-4d95-b42c-f5e744bd3844"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"1", "+", 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}], "2"], "\[Rho]"}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{"1", "-", 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}], "2"], "Z", "\[VeryThinSpace]", "\[Rho]", 
      "\[VeryThinSpace]", "Z"}]}]}], TraditionalForm]],ExpressionUUID->
  "ab38fa43-64f6-4cf3-a676-89875dd99bd0"]
}], "TechNoteText",
 CellID->162830466,ExpressionUUID->"ab0196f1-13a6-4a6f-9cc7-056e64de2c18"],

Cell["It is also convenient to expand the density operator into", \
"TechNoteText",
 CellID->797475784,ExpressionUUID->"84c13cbe-3ec7-4cee-85e4-063419675cee"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "I"}], "+", 
     RowBox[{"x", "\[VeryThinSpace]", "X"}], "+", 
     RowBox[{"y", "\[VeryThinSpace]", "Y"}], "+", 
     RowBox[{"z", "\[VeryThinSpace]", "Z"}]}]}], TraditionalForm]],
  ExpressionUUID->"15e459d1-7940-410e-93dc-bf6fb112ee6f"],
 " ,"
}], "TechNoteText",
 CellID->730060761,ExpressionUUID->"521e26ef-c7e2-4162-aad0-58877535bb32"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "afd057a8-d82a-41e1-92b6-04642aada0c6"],
 ", ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "8590ed57-365f-4af8-8b5b-d29c1ae3749f"],
 ", and ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "0ea0612b-4079-44ba-9a5d-b370b5bb189b"],
 " are real parameters. Then, the quantum operation ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "6b9b3f08-6bd0-4109-a6ba-bdabac8e2e7a"],
 " gives "
}], "TechNoteText",
 CellID->1557134816,ExpressionUUID->"ff6b7175-3348-43ad-80ce-fd294e6d3993"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "I"}], "+", 
     RowBox[{"x", 
      SqrtBox[
       RowBox[{"1", "-", "p"}]], "\[VeryThinSpace]", "X"}], "+", 
     RowBox[{"y", 
      SqrtBox[
       RowBox[{"1", "-", "p"}]], "\[VeryThinSpace]", "Y"}], "+", 
     RowBox[{"z", "\[VeryThinSpace]", "Z"}]}]}], TraditionalForm]],
  ExpressionUUID->"8edd5a3f-c147-4241-80c3-428fe46202b7"],
 " ,"
}], "TechNoteText",
 CellID->1529130170,ExpressionUUID->"e19b13f8-79b2-4da2-90c4-77cbfff82536"],

Cell[TextData[{
 "Note that the coefficient in ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "cdfb5039-b6e7-45d9-a339-10c4448be0f0"],
 " does not change. It asserts that the populations in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "5c45d9be-79be-4044-b5cd-c22e8a654309"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "9ef22b10-f7f0-48d9-a18a-ab1029f3f4a9"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"1", "/", "2"}], "+", "z"}], TraditionalForm]],ExpressionUUID->
  "b0e0735b-a85a-42b0-a036-479d010342a0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"1", "/", "2"}], "-", "z"}], TraditionalForm]],ExpressionUUID->
  "2d85530d-aa14-410b-9258-f56fcdaaeb96"],
 " , do not change. The phase damping process only causes pure dephasing. In \
particular, at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "\[RightArrow]", "1"}], TraditionalForm]],ExpressionUUID->
  "4771145c-d8c7-4b9e-893c-36ce9b55bfea"],
 ", the new density operator approaches,"
}], "TechNoteText",
 CellID->1153963541,ExpressionUUID->"75d57385-1704-48df-9445-f0dc8635d1d0"],

