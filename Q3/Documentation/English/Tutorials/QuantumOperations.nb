Cell["\<\
Set the parameters to specific values, and apply the supermap repeatedly to \
see how the supermap transforms the state in the Bloch sphere:\
\>", "TechNoteMathCaption",
 CellID->1194830114,ExpressionUUID->"842178e0-f9bc-4fec-9d88-f8eea25a956e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Rho]", ",", "p", ",", "pts"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Rho]", "[", "1", "]"}], ",", 
       RowBox[{"\[Rho]", "[", "2", "]"}], ",", 
       RowBox[{"\[Rho]", "[", "3", "]"}]}], "}"}], "=", 
     RowBox[{"Normalize", "@", 
      RowBox[{"{", 
       RowBox[{"2", ",", "0", ",", "1"}], "}"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p", "=", "0.2"}], ";", "\[IndentingNewLine]", 
    RowBox[{"pts", "=", 
     RowBox[{
      RowBox[{"BlochVector", "/@", 
       RowBox[{"NestList", "[", 
        RowBox[{"spr", ",", "rho", ",", "10"}], "]"}]}], "//", "Chop"}]}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"BlochSphere", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Bead", "/@", "pts"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<SphereStyle\>\"", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.25", "]"}], ",", "Cyan"}], "}"}]}]}], 
     "]"}]}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"In[144]:=",
 CellID->1533862654,ExpressionUUID->"2c78ce7a-e344-45eb-a061-2b289bf61bbc"],

