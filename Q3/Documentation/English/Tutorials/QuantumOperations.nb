Cell["\<\
Set the parameters to specific values, and apply the supermap repeatedly to \
see how the supermap transforms the state in the Bloch sphere:\
\>", "TechNoteMathCaption",
 CellID->614666468,ExpressionUUID->"10c355ad-16ec-4883-88f1-e1ad8e20dd18"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Rho]", ",", "p", ",", "pts"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Rho]", "[", "1", "]"}], ",", 
       RowBox[{"\[Rho]", "[", "2", "]"}], ",", 
       RowBox[{"\[Rho]", "[", "3", "]"}]}], "}"}], "=", 
     RowBox[{"Normalize", "@", 
      RowBox[{"{", 
       RowBox[{"2", ",", "0", ",", "1"}], "}"}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"p", "=", "0.2"}], ";", "\[IndentingNewLine]", 
    RowBox[{"pts", "=", 
     RowBox[{
      RowBox[{"BlochVector", "/@", 
       RowBox[{"NestList", "[", 
        RowBox[{"spr", ",", "rho", ",", "10"}], "]"}]}], "//", "Chop"}]}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"BlochSphere", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Bead", "/@", "pts"}]}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\"\<SphereStyle\>\"", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Opacity", "[", "0.25", "]"}], ",", "Cyan"}], "}"}]}]}], 
     "]"}]}]}], "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"In[179]:=",
 CellID->947800971,ExpressionUUID->"624e3caa-e6af-42dc-8626-f306a35ae376"],

