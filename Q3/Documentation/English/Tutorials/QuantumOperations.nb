Cell[TextData[{
 "shrinks by the factor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"1", "\[Minus]", 
     RowBox[{"4", 
      RowBox[{"p", "/", "3"}]}]}], ")"}], TraditionalForm]],ExpressionUUID->
  "99174b52-650d-4ad3-afdd-6621d9724e41"],
 ". Hence the name of the process. The state becomes completely random for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"4", 
     RowBox[{"p", "/", "3"}]}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "36565691-f5d0-4f86-91ce-78506a3351f1"],
