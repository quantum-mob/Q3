      RowBox[{"S", "[", "All", "]"}]}], ",", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", "p"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ops", "//", "PauliForm"}], "\[IndentingNewLine]", 
 RowBox[{"spr", "=", 
  RowBox[{"Supermap", "[", "ops", "]"}]}]}], "Input",
 CellLabel->"In[171]:=",
