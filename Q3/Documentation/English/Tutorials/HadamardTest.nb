      RowBox[{"Im", "[", 
       RowBox[{
        TemplateBox[{"\[Psi]"},
         "Bra"], "U", 
        TemplateBox[{"\[Psi]"},
         "Ket"]}], "]"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "792c4f40-0f23-4ba3-8bd9-ea2656d3be27"],
