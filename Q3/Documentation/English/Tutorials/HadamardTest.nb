Cell[CellGroupData[{

Cell["Estimation of the Real Part", "TechNoteSection",
 CellID->1760709842,ExpressionUUID->"039cab60-d97f-4dba-b475-a1ae00ca8d4f"],

Cell[TextData[{
 "To estimate the real part of the expectation value ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Bra"], "U", 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "54d62baf-307b-45d3-aec2-9a6ef81c2970"],
 ", consider a quantum circuit in Figure 1. The probability to get 0 from the \
measurement is given by"
}], "TechNoteText",
 CellID->1883754708,ExpressionUUID->"0770babb-7c19-42ce-b21a-cbadb636fd1f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], "=", 
    RowBox[{
     FractionBox["1", "2"], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"Re", "[", 
       RowBox[{
        TemplateBox[{"\[Psi]"},
         "Bra"], "U", 
        TemplateBox[{"\[Psi]"},
         "Ket"]}], "]"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "affee80f-1f68-4908-8081-e707a74d5fc1"]
}], "TechNoteText",
 CellID->141849876,ExpressionUUID->"f1fb3b00-ef54-475c-aede-831a38b9b309"],

Cell[TextData[{
 "Therefore, by estimating the probability ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "0"], TraditionalForm]],ExpressionUUID->
  "5abc2717-4157-416e-8c56-b968fe6711b7"],
 " through repeated measurements, one can get the estimate of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Re", 
    TemplateBox[{"\[Psi]"},
     "Bra"], "U", 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "d30211a7-851a-4f18-b69b-62a91d01c108"],
 "."
}], "TechNoteText",
 CellID->810602242,ExpressionUUID->"cbea9913-3b8f-48cd-8685-2a01f660dc44"],

