Cell[TextData[{
 "To estimate the imaginary part of the expectation value ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Bra"], "U", 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "54861e37-4105-4e6b-be9d-12df8e697cc6"],
 ", we need to slightly modify the quantum circuit in Figure 1 to those in \
Figure 2. In this case, the probability to get 0 from the measurement is \
given by"
}], "TechNoteText",
 CellID->747985506,ExpressionUUID->"13292450-dafb-409c-9568-88de0e1ab32e"],

Cell[TextData[{
 "\t",
