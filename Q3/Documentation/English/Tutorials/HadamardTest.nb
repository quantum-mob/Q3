Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ". Two equivalent quantum circuits to estimate ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Im", 
    TemplateBox[{"\[Psi]"},
     "Bra"], "U", 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "76f70ba0-bced-41ce-826d-ce31ad179d62"],
 ". Here, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", "\[ImaginaryI]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "905214b1-eea0-4e76-815a-c97e4ceb8a87"],
 " is the quadrant phase gate."
}], "TechNoteText",
