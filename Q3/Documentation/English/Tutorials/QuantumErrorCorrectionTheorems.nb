Cell[BoxData[{
 RowBox[{
  RowBox[{"chk2", "=", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"Dagger", "[", 
       RowBox[{"lbs", "[", 
        RowBox[{"[", "1", "]"}], "]"}], "]"}], "**", "mm", "**", 
      RowBox[{"lbs", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Dagger", "[", 
