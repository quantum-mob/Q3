Cell[CellGroupData[{

Cell["Discretization of Errors", "TechNoteSection",
 CellID->209950438,ExpressionUUID->"f1cfc1e6-7801-4299-b8af-70df8fd2039c"],

Cell[TextData[{
 "Once a quantum code is proven to protect against a particular type of \
quantum noise in accordance with the quantum error-correction conditions, it \
is robust against a surprisingly wide class of types of quantum noise. In \
fact, it turns out that if a quantum noise operation ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "cf83c43c-b147-4bf0-ae1c-9781fbfe4b06"],
 " with error operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["E", "\[Mu]"], "}"}], TraditionalForm]],ExpressionUUID->
  "b23283b6-e2ce-4173-8d72-c2b3e01e39f7"],
 " can be corrected by a quantum code ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "72f5dd73-1692-4111-aa8e-f85bd328bde1"],
 ", then the code also protects against any quantum noise ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "12030850-4d61-4d1e-9f28-ee3505ee6680"],
 " with error operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["F", "\[Nu]"], "}"}], TraditionalForm]],ExpressionUUID->
  "8333ea3d-76f7-4990-8f71-e00b25be1210"],
 " that are linear superpositions of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["E", "\[Mu]"], "}"}], TraditionalForm]],ExpressionUUID->
  "147509fd-6081-42b2-98fe-793c286b4349"],
 ","
}], "TechNoteText",
 CellID->321379445,ExpressionUUID->"87f6fae9-c3a3-4a8e-aa94-41d35bd9f595"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "\[Nu]"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     RowBox[{
      SubscriptBox["E", "\[Mu]"], " ", 
      SubscriptBox["M", 
       RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"c317ec14-bb8e-4e23-ad77-092ce7ee4bfc"],
 " ,"
}], "TechNoteText",
 CellID->502959910,ExpressionUUID->"da5dc741-d6b0-45e0-9e7b-ea5566f42dce"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", 
    RowBox[{"\[Mu]", " ", "\[Nu]"}]], TraditionalForm]],ExpressionUUID->
  "d1706e30-bb37-4abd-ad66-762549c2572a"],
 " is a matrix of complex numbers."
}], "TechNoteText",
 CellID->751572778,ExpressionUUID->"4454be22-a1d5-44fb-aa73-1fd5757f709a"],

Cell[TextData[{
 "\tThe proof is simple. Given that the quantum noise ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "983acd7a-9937-4d4f-8b69-66b79c9d65b7"],
 " is correctable on code space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "5280e62d-e2a5-4beb-b452-3965fee455ce"],
 ", it must satisfy the quantum error-correction conditions"
}], "TechNoteText",
 CellID->184868192,ExpressionUUID->"735277d6-1ed1-41f8-8e6f-4e471d53e75d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", " ", 
     SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["E", "\[Nu]"], "P"}], "=", 
    RowBox[{
     SubscriptBox["A", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], "P"}]}], 
   TraditionalForm]],ExpressionUUID->"9161e6c6-d83f-4af7-8b4a-59b78697eec7"]
}], "TechNoteText",
 CellID->1818349382,ExpressionUUID->"2c6a932c-24d8-4a9e-bf41-5230cfe282c2"],

Cell[TextData[{
 "as discussed in the above section. Multiply equation with matrices ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["M", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "6d8806b1-1eac-4e85-ab06-31884e2b9cdb"],
 " and ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "4667c7a3-8420-4d96-a4dd-394b51b51492"],
 ","
}], "TechNoteText",
 CellID->158282817,ExpressionUUID->"7228d567-cacf-4317-be1c-74029b78ab7e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{
       RowBox[{"\[Mu]", "'"}], 
       RowBox[{"\[Nu]", "'"}]}]], "P", " ", 
     SubsuperscriptBox["M", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", 
       RowBox[{"\[Mu]", "'"}]}], "\[Dagger]"], 
     SubscriptBox["E", 
      RowBox[{"\[Mu]", "'"}]], 
     SubscriptBox["E", 
      RowBox[{"\[Nu]", "'"}]], 
     SubscriptBox["M", 
      RowBox[{"\[Nu]", "\[VeryThinSpace]", "\[Nu]"}]], "P"}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{
       RowBox[{"\[Mu]", "'"}], 
       RowBox[{"\[Nu]", "'"}]}]], 
     SubsuperscriptBox["M", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", 
       RowBox[{"\[Mu]", "'"}]}], "\[Dagger]"], 
     SubscriptBox["A", 
      RowBox[{
       RowBox[{"\[Mu]", "'"}], 
       RowBox[{"\[Nu]", "'"}]}]], 
     SubscriptBox["M", 
      RowBox[{
       RowBox[{"\[Nu]", "'"}], "\[Nu]"}]], "P"}]}], TraditionalForm]],
  ExpressionUUID->"94fff738-7c55-4915-aca1-feca1f236a06"],
 " ."
}], "TechNoteText",
 CellID->1674550333,ExpressionUUID->"a90ba76c-a56c-4ed3-a59d-6462cd8749b7"],

Cell["This leads to", "TechNoteText",
 CellID->1394252796,ExpressionUUID->"f54a02bb-f947-4582-8da7-7ca2d8e6e753"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", " ", 
     SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["F", "\[Nu]"], "P"}], "=", 
    RowBox[{
     SubscriptBox[
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["M", "\[Dagger]"], "A", " ", "M"}], ")"}], 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], "P"}]}], 
   TraditionalForm]],ExpressionUUID->"373a1e8e-b770-420d-9ec6-fcc9b1eaaeed"],
 " ,"
}], "TechNoteText",
 CellID->2012669955,ExpressionUUID->"3d8ab4a9-b58a-4bdd-8068-032ccf66f2d5"],

Cell[TextData[{
 "which is formally the same as the quantum error-correction conditions. \
Therefore, the quantum noise ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "fc8127a0-ec16-49e7-a69d-8bb2beeec4a7"],
 " must be correctable on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "d98a2a29-638d-45a8-8743-0ef1dc9b2616"],
 " as well."
}], "TechNoteText",
 CellID->1929009788,ExpressionUUID->"2670f9fe-7498-485a-90f0-7d1cfcdaa37b"],

Cell[TextData[{
 "\tAlthough quite simple to prove, the implication of the above statement is \
huge. Consider a class of errors on single qubits. Suppose that it is \
described by a quantum operation ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "a3a36a04-3ed1-4c8b-9f9e-a50313b5bf1f"],
 " specified by Kraus elements ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubsuperscriptBox["E", 
     RowBox[{"j", " "}], "\[Mu]"], "}"}], TraditionalForm]],ExpressionUUID->
  "384221a8-7e5e-42c6-938c-02bdbe9eb60c"],
 ", where the index ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "76567237-324f-4c3c-920d-4698f1b15d98"],
 " indicates the qubit subject to the error and \[Mu] denotes different error \
processes. Since ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["E", 
    RowBox[{"j", " "}], "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "3aa1c9ba-6e4f-48e2-a8ea-0df8b5404208"],
 " are operators on the single qubit ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "c1295234-61e3-41a4-b903-e2c56940cfad"],
 ", they can be expanded in terms of Pauli operators ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["S", "j", "0"], TraditionalForm]],ExpressionUUID->
  "076268fe-2c83-40f6-975c-17dcc9fca44a"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["S", "j", "X"], TraditionalForm]],ExpressionUUID->
  "b226902c-96bc-4120-ba91-ccaffbe2187e"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["S", "j", "Y"], TraditionalForm]],ExpressionUUID->
  "e1cef0b6-1a2b-4eba-adb8-9da53f848baa"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["S", "j", "Z"], TraditionalForm]],ExpressionUUID->
  "24d79246-a14b-4fc6-96fb-00e42ce864f9"],
 ". In order to check if a given quantum error-correction code protects \
against arbitrary single-qubit errors, one has only to inspect the condition"
}], "TechNoteText",
 CellID->306888157,ExpressionUUID->"5aaf33d2-ba73-47e1-a4ea-681b7d07db1b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", " ", 
     SubsuperscriptBox["S", "j", "\[Mu]"], 
     SubsuperscriptBox["S", "j", "\[Nu]"], "P"}], "=", 
    RowBox[{
     SubscriptBox["A", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], "P"}]}], 
   TraditionalForm]],ExpressionUUID->"be7b5f07-46f3-4863-852a-f1390d192ba7"]
}], "TechNoteText",
 CellID->1761018252,ExpressionUUID->"57895837-f701-44c3-9c7a-eb2edc488a12"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "14311712-b311-4431-8d87-a9c2fdd09019"],
 " and a Hermitian matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "22139075-b1af-4dbb-ac34-d8fdb8ec477e"],
 ". In other words, when one constructs a quantum error-correction code, it \
is sufficient to check a finite (and hence discrete) set of conditions to \
ensure that the code protects against arbitrary single-qubit errors."
}], "TechNoteText",
 CellID->814138410,ExpressionUUID->"711ae91a-67a9-457d-892a-2fa339ff813e"]
}, Open  ]],

Cell[BoxData[GridBox[{
   {
