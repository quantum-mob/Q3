}, Open  ]],

Cell[CellGroupData[{

Cell["Function Approximation", "TechNoteSection",
 CellID->1625771319,ExpressionUUID->"fd3fd320-92eb-4338-aa6e-bb4251d367ba"],

Cell[TextData[{
 "An idea for solving QLSP is approximately implementing the map ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[RightTeeArrow]", 
    SuperscriptBox["A", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "a9f24882-2a30-4c65-a64c-b563cd0bed0c"],
 ". Hence, in light of quantum signal processing (QSP), the implementation \
boils down to a scalar function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    SuperscriptBox["x", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "89958e03-412e-47e9-8ee9-1e0edf9d6911"],
 ". Without loss of generality, the matrix is assumed to be normalized so \
that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
     "\[LeftDoubleBracketingBar]", "A", "\[RightDoubleBracketingBar]"}], "2"],
     "\[LessEqual]", "1"}], TraditionalForm]],ExpressionUUID->
  "971fc5e1-8505-40db-b5ed-f5906b7fdae1"],
 ". Then, the condition number implies that the eigenvalues of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "91b362eb-0743-409a-831b-2b4a87a85d3a"],
 " lie in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["D", "\[Kappa]"], ":=", 
    RowBox[{
     RowBox[{"[", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "\[Kappa]"}]}], "]"}], "\[Union]", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"1", "/", "\[Kappa]"}], ",", "1"}], "]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"d88370ad-cd55-4524-81a9-25cad47f95ce"],
 ". Hence, we restrict ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "a0b59aeb-1bec-4534-8246-81a61fa11aa2"],
 " to the interval ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "k"], TraditionalForm]],ExpressionUUID->
  "33814171-7bba-4b1c-9e70-ca7644db8567"],
 ". This restriction is necessary to exclude the singularity of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "ff43f016-2c41-4afe-a735-488deb718ddb"],
 " at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "fd4f57a9-f823-413c-b7a4-045fd9107a7a"],
 "."
}], "TechNoteText",
 CellID->1665628258,ExpressionUUID->"926f6703-7d78-4af6-b53e-99a426ae2f1e"],

Cell["\<\
Set the (maximum) condition number of matrices of our concern:\
\>", "TechNoteMathCaption",
 CellID->1601702047,ExpressionUUID->"8339c99e-99b8-4dfa-b65f-248f1c734f30"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"$\[Kappa]", "=", "10"}]], "Input",
 CellLabel->"In[2]:=",
 CellID->194930823,ExpressionUUID->"55b33acf-5fa0-451d-a31a-71d9e9fe0a2d"],

Cell[BoxData["10"], "Output",
 CellLabel->"Out[2]=",
 CellID->533490604,ExpressionUUID->"fb2dc140-ec76-4831-adfc-f31fcef2b043"]
}, Open  ]],

Cell[TextData[{
 "Scale down the target function by a factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"1", "/", "2"}], "\[Kappa]"}], TraditionalForm]],ExpressionUUID->
  "262a23fc-c8f3-4a99-b544-ad7b3e3c53cd"],
 " so that"
}], "TechNoteMathCaption",
 CellID->2140260818,ExpressionUUID->"98265e90-2250-44fe-96f1-304c6b57a636"],

Cell[BoxData[
 RowBox[{
  RowBox[{"target", "[", "x_", "]"}], ":=", 
  RowBox[{"1", "/", 
   RowBox[{"(", 
    RowBox[{"2", "*", "$\[Kappa]", "*", "x"}], ")"}]}]}]], "Input",
 CellLabel->"In[3]:=",
 CellID->938980246,ExpressionUUID->"b7ea0e7e-2318-4459-9e3b-cf48f292cc0f"],

Cell["This improves the numerical stability.", "TechNoteMathCaption",
 CellID->2094550900,ExpressionUUID->"be9fc702-eb03-4681-bb5b-8f58c437bee0"],

Cell["Set the interval in accordance with the condition number:", \
"TechNoteMathCaption",
 CellID->1328462383,ExpressionUUID->"735d461f-6483-4779-b921-52a04e9d6507"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"$interval", "=", 
  RowBox[{"Interval", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1"}], ",", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "$\[Kappa]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "/", "$\[Kappa]"}], ",", "1"}], "}"}]}], "]"}]}]], "Input",\

 CellLabel->"In[4]:=",
 CellID->1611560705,ExpressionUUID->"844792a0-3d3f-40f4-a5cb-d6de16c0fe4c"],

Cell[BoxData[
 RowBox[{"Interval", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", 
     RowBox[{"-", 
      FractionBox["1", "10"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["1", "10"], ",", "1"}], "}"}]}], "]"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->632355203,ExpressionUUID->"5635d870-ca5d-4403-b824-e7f5f27b2181"]
}, Open  ]],

Cell["Plot the target function to see how it looks like:", \
"TechNoteMathCaption",
 CellID->1938438991,ExpressionUUID->"7f171d9d-ae00-4e40-9848-ebdc743c7640"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"target", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}]}], "]"}]], "Input",
