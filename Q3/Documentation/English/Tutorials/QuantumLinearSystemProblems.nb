Cell[BoxData["51"], "Output",
 CellLabel->"Out[8]=",
 CellID->1942443287,ExpressionUUID->"ea7c2009-454b-4de6-ba70-57e7dc17c99a"]
}, Open  ]],

Cell[TextData[{
 "Find a polynomial approximation of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "567caaac-81e7-4bb3-91e7-cca94b67fa44"],
 ":"
}], "TechNoteMathCaption",
 CellID->27171821,ExpressionUUID->"f82a2b47-fa31-445e-9438-58540e70e433"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fun", "=", 
  RowBox[{"ChebyshevApproximation", "[", 
   RowBox[{"target", ",", 
    RowBox[{"$n", "->", 
     RowBox[{"-", "1"}]}], ",", "$interval", ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<Parity\>\"", "->", "True"}], ",", "\[IndentingNewLine]", 
