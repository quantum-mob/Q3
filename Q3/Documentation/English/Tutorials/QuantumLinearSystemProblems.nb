Cell[CellGroupData[{

Cell["Polynomial Approximation", "TechNoteSection",
 CellID->434079351,ExpressionUUID->"f2b1b1a0-819f-43fe-96fd-c460e7210ed9"],

Cell[TextData[{
 "Let us now find a polynomial approximation to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "76671931-872d-4b43-ba60-434a01237716"],
 ". We note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "5555eae1-36bb-4937-a9d7-80673f3b6152"],
 " is odd, and hence we need to find an odd polynomial approximation to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "4d63b4d1-a8d3-413f-a339-59a5043262e2"],
 " on the interval ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "\[Kappa]"], TraditionalForm]],ExpressionUUID->
  "92fb6a57-7721-4bed-8f06-c286d88b9bc6"],
 "."
}], "TechNoteText",
 CellID->1419037092,ExpressionUUID->"b6edde12-8dc2-4cd8-a9d1-d7c026353215"],

Cell["Make sure to load Q3:", "TechNoteMathCaption",
 CellID->1296167482,ExpressionUUID->"d25674e0-bec3-44de-822c-562ad3ab4afc"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[6]:=",
 CellID->1552724342,ExpressionUUID->"9543415e-2a76-44d5-a739-0db087f51d65"],

Cell[TextData[{
 "Set the degree of the approximate polynomial. Note that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "=", 
   RowBox[{
    RowBox[{"2", 
     StyleBox["n", "TI"]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       StyleBox["p", "TI"]}], ")"}], "/", "2"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2ab77ca4-1f19-4a6d-8473-491ed2d58e43"],
 ":"
}], "TechNoteMathCaption",
 CellID->638710960,ExpressionUUID->"482c3404-cbf6-4236-8a3f-ace3a97bf63b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"$n", "=", "25"}], "\[IndentingNewLine]", 
 RowBox[{"$degree", "=", "51"}]}], "Input",
 CellLabel->"In[7]:=",
