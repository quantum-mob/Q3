 CellID->1553581759,ExpressionUUID->"e498c49e-43b3-46a9-bc78-bcd7ee07bdcf"],

Cell[BoxData["51"], "Output",
 CellLabel->"Out[8]=",
 CellID->1942443287,ExpressionUUID->"872e7de5-84f2-4c59-84d0-2624758dac44"]
}, Open  ]],

Cell[TextData[{
 "Find a polynomial approximation of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "3b715df3-391f-4403-9306-a4faf2cb0639"],
 ":"
}], "TechNoteMathCaption",
 CellID->27171821,ExpressionUUID->"515b1359-37e3-45c3-8c47-3cae95f3359f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fun", "=", 
  RowBox[{"ChebyshevApproximation", "[", 
   RowBox[{"target", ",", 
    RowBox[{"$n", "->", 
     RowBox[{"-", "1"}]}], ",", "$interval", ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<Parity\>\"", "->", "True"}], ",", "\[IndentingNewLine]", 
