Cell["\<\
Compare the target function, the approximate polynomial, and the QSP \
representation:\
\>", "TechNoteMathCaption",
 CellID->64649720,ExpressionUUID->"a38ebe09-2f1b-43e2-9481-79ef03c58605"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"target", "[", "x", "]"}], ",", 
     RowBox[{"fun", "[", "x", "]"}], ",", 
     RowBox[{"qsp", "[", "x", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{"Thick", ",", "Thick", ",", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", "Dashed"}], "}"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
