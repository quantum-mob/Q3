 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->1821346117,ExpressionUUID->"be06b50f-cd50-42cc-8d59-d688fbca7662"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Function Approximation", "TechNoteSection",
 CellID->1625771319,ExpressionUUID->"d1dafc67-821f-4267-8624-6c312dd48ad2"],

Cell[TextData[{
 "An idea for solving QLSP is approximately implementing the map ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[RightTeeArrow]", 
    SuperscriptBox["A", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "c726a468-c81d-48c4-86d7-2d2f321a2ace"],
 ". Hence, in light of quantum signal processing (QSP), the implementation \
boils down to a scalar function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    SuperscriptBox["x", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "0ba768c1-b8af-4ebc-b80f-6100eec212b5"],
 ". Without loss of generality, the matrix is assumed to be normalized so \
that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
     "\[LeftDoubleBracketingBar]", "A", "\[RightDoubleBracketingBar]"}], "2"],
     "\[LessEqual]", "1"}], TraditionalForm]],ExpressionUUID->
  "568d1934-352d-4080-a11a-ba19d5cd18df"],
 ". Then, the condition number implies that the eigenvalues of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "7ac00ae5-cf39-4bcb-99f1-5a3314b092f5"],
 " lie in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["D", "\[Kappa]"], ":=", 
    RowBox[{
     RowBox[{"[", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "\[Kappa]"}]}], "]"}], "\[Union]", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"1", "/", "\[Kappa]"}], ",", "1"}], "]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"13c28d1b-f27b-4b08-8e75-8022adce575b"],
 ". Hence, we restrict ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "9cea1812-9125-4d47-9ea9-6c41bdfa29db"],
 " to the interval ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "k"], TraditionalForm]],ExpressionUUID->
  "b91d07b5-5228-4263-99f9-2aac694526e3"],
 ". This restriction is necessary to exclude the singularity of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "ba4ce2b7-4704-4236-a0df-c7985fcb475a"],
 " at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "f3c70ff3-440f-4043-8147-5ba779aae3c4"],
 "."
}], "TechNoteText",
 CellID->1665628258,ExpressionUUID->"fe3b6a1b-ff44-4c5f-a096-a514bdb2c13f"],

Cell["\<\
Set the (maximum) condition number of matrices of our concern:\
\>", "TechNoteMathCaption",
 CellID->1601702047,ExpressionUUID->"2f14e41b-9653-4e08-9252-0c05046ff762"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"$\[Kappa]", "=", "10"}]], "Input",
 CellLabel->"In[2]:=",
 CellID->194930823,ExpressionUUID->"b4209418-8e7e-4694-b477-a637c5b4c9f6"],

Cell[BoxData["10"], "Output",
 CellLabel->"Out[2]=",
 CellID->533490604,ExpressionUUID->"06f5cdef-81ab-4d8e-a305-692bddd5dc6e"]
}, Open  ]],

Cell[TextData[{
 "Scale down the target function by a factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"1", "/", "2"}], "\[Kappa]"}], TraditionalForm]],ExpressionUUID->
  "c0eed88d-09c0-49d7-bb0e-f8b361d71c71"],
 " so that"
}], "TechNoteMathCaption",
 CellID->2140260818,ExpressionUUID->"cd78f47e-45c6-4c77-81df-60241d4cdaee"],

Cell[BoxData[
 RowBox[{
  RowBox[{"target", "[", "x_", "]"}], ":=", 
  RowBox[{"1", "/", 
   RowBox[{"(", 
    RowBox[{"2", "*", "$\[Kappa]", "*", "x"}], ")"}]}]}]], "Input",
 CellLabel->"In[3]:=",
 CellID->938980246,ExpressionUUID->"de990454-e43b-4165-a0d0-db3e14054977"],

Cell["This improves the numerical stability.", "TechNoteMathCaption",
 CellID->2094550900,ExpressionUUID->"922a0334-c5f0-40e1-bcd0-e3e02a7a08b6"],

Cell["Set the interval in accordance with the condition number:", \
"TechNoteMathCaption",
 CellID->1328462383,ExpressionUUID->"07bea53f-58e5-46de-8326-1692896a738c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"$interval", "=", 
  RowBox[{"Interval", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1"}], ",", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "$\[Kappa]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "/", "$\[Kappa]"}], ",", "1"}], "}"}]}], "]"}]}]], "Input",\

 CellLabel->"In[4]:=",
 CellID->1611560705,ExpressionUUID->"aee4bf84-8369-4422-b241-9d606c7f5629"],

Cell[BoxData[
 RowBox[{"Interval", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", 
     RowBox[{"-", 
      FractionBox["1", "10"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["1", "10"], ",", "1"}], "}"}]}], "]"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->632355203,ExpressionUUID->"bb417638-bcef-4fcd-a872-3a825d2d7fa9"]
}, Open  ]],

Cell["Plot the target function to see how it looks like:", \
"TechNoteMathCaption",
 CellID->1938438991,ExpressionUUID->"e1c5522b-551a-4c7a-a426-d299425f43a7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"target", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[5]:=",
