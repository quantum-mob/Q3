Cell[TextData[{
 "The ",
 StyleBox["quantum linear system problem",
  FontSlant->"Italic"],
 " (QLSP) is a quantum variant of the linear system problem "
}], "TechNoteText",
 CellID->1316506077,ExpressionUUID->"d0b75ed0-d7ad-4824-8eff-c930443d2995"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[VeryThinSpace]", "x"}], "=", "b"}], TraditionalForm]],
  ExpressionUUID->"3e0ad900-3dd4-44a6-842d-464c32c35547"]
}], "TechNoteText",
 CellID->1920006471,ExpressionUUID->"2d334588-fac8-4731-9708-a8c1f60fa858"],

Cell[TextData[{
 "Given the access to an invertible matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "624aced0-80f2-4df5-b94d-fbc537e0aa9b"],
 " and to a normalized quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"b"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "cdcdb178-cbd7-47d1-a195-fa945cb020fe"],
 ", QLSP asks a construction of the solution quantum state"
}], "TechNoteText",
 CellID->993621098,ExpressionUUID->"0e150d80-efef-4150-b9e3-e5e66af6b8d6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"x"},
     "Ket"], ":=", 
    RowBox[{
     SuperscriptBox["A", 
      RowBox[{"-", "1"}]], 
     RowBox[{
      TemplateBox[{"b"},
       "Ket"], " ", "/", " ", 
      SubscriptBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{
         SuperscriptBox["A", 
          RowBox[{"-", "1"}]], 
         TemplateBox[{"b"},
          "Ket"]}], "\[RightDoubleBracketingBar]"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"25b741a2-eb93-42dd-b91f-05dbe93861ca"]
}], "TechNoteText",
 CellID->1913001532,ExpressionUUID->"fa4f1339-ab8b-48d1-9206-751a0a6f6a26"],

Cell["with bounded error.", "TechNoteText",
 CellID->2016343379,ExpressionUUID->"355e6bc5-a8b2-42af-916b-021fa1396cd4"],

Cell[TextData[{
 "Suppose the condition number of the coefficient matrix is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", ":=", 
    RowBox[{
     SubscriptBox[
      RowBox[{
      "\[LeftDoubleBracketingBar]", "A", "\[RightDoubleBracketingBar]"}], 
      "2"], 
     SubscriptBox[
      RowBox[{"\[LeftDoubleBracketingBar]", 
       SuperscriptBox["A", 
        RowBox[{"-", "1"}]], "\[RightDoubleBracketingBar]"}], "2"]}]}], 
   TraditionalForm]],ExpressionUUID->"7409e7d6-5def-4dff-82db-58f32954e329"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalC]", 
     RowBox[{"N", "\[Times]", "N"}]]}], TraditionalForm]],ExpressionUUID->
  "aa201592-49f7-45d2-aef5-0f3e84f2b2e5"],
 ". Recently, some near-optimal quantum algorithms have been suggested for \
solving QLSP with bounded error ",
 Cell[BoxData[
  FormBox["\[Epsilon]", TraditionalForm]],ExpressionUUID->
  "a16f7901-03e6-408d-a052-c081430ad56a"],
 " and complexity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"\[Kappa]", "\[VeryThinSpace]", 
     RowBox[{"log", "(", 
      RowBox[{"1", "/", "\[Epsilon]"}], ")"}], 
     RowBox[{"polylog", "(", "N", ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"febaf063-33f7-45df-bd36-798e346015cf"],
 "."
}], "TechNoteText",
 CellID->1823228495,ExpressionUUID->"c45aa695-8281-412b-ac82-94732c8c52c7"],

Cell["\<\
This example provides a much simpler construction of the solution to QLSP.\
\>", "TechNoteText",
 CellID->714680654,ExpressionUUID->"0eadf541-2c65-447e-921f-8910df45072a"],

