Cell[TextData[{
 "The ",
 StyleBox["quantum linear system problem",
  FontSlant->"Italic"],
 " (QLSP) is a quantum variant of the linear system problem "
}], "TechNoteText",
 CellID->1316506077,ExpressionUUID->"5cb057c3-f763-47bc-9a58-00ea3bac1393"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[VeryThinSpace]", "x"}], "=", "b"}], TraditionalForm]],
  ExpressionUUID->"3ea92f7d-ee32-4630-87b0-cc795806d984"]
}], "TechNoteText",
 CellID->1920006471,ExpressionUUID->"55c63289-4526-4c1e-b269-6a1b8164c21e"],

Cell[TextData[{
 "Given the access to an invertible matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "260c6bdb-5b35-4856-818d-0cc22dbd0cbf"],
 " and to a normalized quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"b"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "0919d0a1-2999-4065-9b17-7f77d416d335"],
 ", QLSP asks a construction of the solution quantum state"
}], "TechNoteText",
 CellID->993621098,ExpressionUUID->"e4b097fd-5300-4511-9158-c1e19a57b54d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"x"},
     "Ket"], ":=", 
    RowBox[{
     SuperscriptBox["A", 
      RowBox[{"-", "1"}]], 
     RowBox[{
      TemplateBox[{"b"},
       "Ket"], " ", "/", " ", 
      SubscriptBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{
         SuperscriptBox["A", 
          RowBox[{"-", "1"}]], 
         TemplateBox[{"b"},
          "Ket"]}], "\[RightDoubleBracketingBar]"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"aa4235d2-980e-4c1e-b5fd-ce0f37eab62a"]
}], "TechNoteText",
 CellID->1913001532,ExpressionUUID->"432861c2-12e7-441e-8488-69e9ac51b3e3"],

Cell["with bounded error.", "TechNoteText",
 CellID->2016343379,ExpressionUUID->"f2e98320-6584-49d9-b8f4-1c36d75631c8"],

Cell[TextData[{
 "Suppose the condition number of the coefficient matrix is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", ":=", 
    RowBox[{
     SubscriptBox[
      RowBox[{
      "\[LeftDoubleBracketingBar]", "A", "\[RightDoubleBracketingBar]"}], 
      "2"], 
     SubscriptBox[
      RowBox[{"\[LeftDoubleBracketingBar]", 
       SuperscriptBox["A", 
        RowBox[{"-", "1"}]], "\[RightDoubleBracketingBar]"}], "2"]}]}], 
   TraditionalForm]],ExpressionUUID->"823264a3-af9b-498c-acec-f714e39680af"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalC]", 
     RowBox[{"N", "\[Times]", "N"}]]}], TraditionalForm]],ExpressionUUID->
  "b340e126-fe48-4001-a89d-04782d619a35"],
 ". Recently, some near-optimal quantum algorithms have been suggested for \
solving QLSP with bounded error ",
 Cell[BoxData[
  FormBox["\[Epsilon]", TraditionalForm]],ExpressionUUID->
  "57dd843f-d065-46bf-bc67-1d6ae4ebf2bb"],
 " and complexity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"\[Kappa]", "\[VeryThinSpace]", 
     RowBox[{"log", "(", 
      RowBox[{"1", "/", "\[Epsilon]"}], ")"}], 
     RowBox[{"polylog", "(", "N", ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"596ece86-014f-426d-b612-7830bad82243"],
 "."
}], "TechNoteText",
 CellID->1823228495,ExpressionUUID->"20cc1eae-7919-421e-a206-d9191ec310a5"],

Cell["\<\
This example provides a much simpler construction of the solution to QLSP.\
\>", "TechNoteText",
 CellID->714680654,ExpressionUUID->"d5fc1303-6db3-4b14-848f-621603f2bf91"],

