Cell[TextData[{
 "The ",
 StyleBox["quantum linear system problem",
  FontSlant->"Italic"],
 " (QLSP) is a quantum variant of the linear system problem "
}], "TechNoteText",
 CellID->1316506077,ExpressionUUID->"dade9ee4-8753-46ef-8e65-ea87a73664e5"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", "\[VeryThinSpace]", "x"}], "=", "b"}], TraditionalForm]],
  ExpressionUUID->"1f000e43-3743-4d40-a3d3-e5afe48ea5c0"]
}], "TechNoteText",
 CellID->1920006471,ExpressionUUID->"697fbea8-8f14-4bf9-b6bd-004736e627cc"],

Cell[TextData[{
 "Given the access to an invertible matrix ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "2fd8f1c7-1f11-4461-953b-e5e5df198cf3"],
 " and to a normalized quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"b"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "0d522043-15d6-4d6a-9950-cae0bf805e31"],
 ", QLSP asks a construction of the solution quantum state"
}], "TechNoteText",
 CellID->993621098,ExpressionUUID->"85c55d18-7925-453c-9e44-b51fd4dfe9c9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"x"},
     "Ket"], ":=", 
    RowBox[{
     SuperscriptBox["A", 
      RowBox[{"-", "1"}]], 
     RowBox[{
      TemplateBox[{"b"},
       "Ket"], " ", "/", " ", 
      SubscriptBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{
         SuperscriptBox["A", 
          RowBox[{"-", "1"}]], 
         TemplateBox[{"b"},
          "Ket"]}], "\[RightDoubleBracketingBar]"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"8835e7b5-8a28-4362-b407-c4bffe48ed0a"]
}], "TechNoteText",
 CellID->1913001532,ExpressionUUID->"05149f9a-6198-4f4f-8b76-b34b649b049f"],

Cell["with bounded error.", "TechNoteText",
 CellID->2016343379,ExpressionUUID->"f6ce92a6-76d1-4590-ad32-0b54290746ef"],

Cell[TextData[{
 "Suppose the condition number of the coefficient matrix is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", ":=", 
    RowBox[{
     SubscriptBox[
      RowBox[{
      "\[LeftDoubleBracketingBar]", "A", "\[RightDoubleBracketingBar]"}], 
      "2"], 
     SubscriptBox[
      RowBox[{"\[LeftDoubleBracketingBar]", 
       SuperscriptBox["A", 
        RowBox[{"-", "1"}]], "\[RightDoubleBracketingBar]"}], "2"]}]}], 
   TraditionalForm]],ExpressionUUID->"ffd43b3e-de62-420a-bd7c-dda4086aac6d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalC]", 
     RowBox[{"N", "\[Times]", "N"}]]}], TraditionalForm]],ExpressionUUID->
  "735aff34-931e-4a7b-8fdb-1fd190b738b9"],
 ". Recently, some near-optimal quantum algorithms have been suggested for \
solving QLSP with bounded error ",
 Cell[BoxData[
  FormBox["\[Epsilon]", TraditionalForm]],ExpressionUUID->
  "3828fbe6-9ebd-4b92-8aa8-c57c946c1fa1"],
 " and complexity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"\[Kappa]", "\[VeryThinSpace]", 
     RowBox[{"log", "(", 
      RowBox[{"1", "/", "\[Epsilon]"}], ")"}], 
     RowBox[{"polylog", "(", "N", ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"46bb164c-58f8-4c55-800c-658f3c0e4bb4"],
 "."
}], "TechNoteText",
 CellID->1823228495,ExpressionUUID->"e38e1fe3-91af-45f6-8944-513bb7b1beea"],

Cell["\<\
This example provides a much simpler construction of the solution to QLSP.\
\>", "TechNoteText",
 CellID->714680654,ExpressionUUID->"0b021f70-8b18-441a-887f-2a3840ddfad3"],

Cell[TextData[{
 "Based on a ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QSPPACK document"]], 
    "https://qsppack.gitbook.io/qsppack/examples/quantum-linear-system-\
problems"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "153bcd27-bcb9-45c8-9560-36aaaa6a0cdb"]
}], "TechNoteText",
 CellID->588668590,ExpressionUUID->"c321ff11-2638-46da-a4af-ac4643357c97"],

