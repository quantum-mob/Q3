}, Open  ]],

Cell[CellGroupData[{

Cell["Function Approximation", "TechNoteSection",
 CellID->1625771319,ExpressionUUID->"2e01ee85-b96e-4441-b065-f86253dcd70f"],

Cell[TextData[{
 "An idea for solving QLSP is approximately implementing the map ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[RightTeeArrow]", 
    SuperscriptBox["A", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "19f350ec-9cd5-4a16-9b02-421c06de3b56"],
 ". Hence, in light of quantum signal processing (QSP), the implementation \
boils down to a scalar function ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    SuperscriptBox["x", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "4625f750-2127-47c4-becc-85cb0d6cd65b"],
 ". Without loss of generality, the matrix is assumed to be normalized so \
that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{
     "\[LeftDoubleBracketingBar]", "A", "\[RightDoubleBracketingBar]"}], "2"],
     "\[LessEqual]", "1"}], TraditionalForm]],ExpressionUUID->
  "57138c54-23a1-418b-92b8-cc7dbbea76a0"],
 ". Then, the condition number implies that the eigenvalues of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "bd26e58e-f98f-40b3-b3c2-71ec86661dc0"],
 " lie in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["D", "\[Kappa]"], ":=", 
    RowBox[{
     RowBox[{"[", 
      RowBox[{
       RowBox[{"-", "1"}], ",", 
       RowBox[{
        RowBox[{"-", "1"}], "/", "\[Kappa]"}]}], "]"}], "\[Union]", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"1", "/", "\[Kappa]"}], ",", "1"}], "]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"0ebc1ff7-e323-4680-a6c3-b2b31987bf03"],
 ". Hence, we restrict ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "33714801-802f-4e2d-b202-4257d0f7b268"],
 " to the interval ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "k"], TraditionalForm]],ExpressionUUID->
  "3f066516-bc61-4487-8afd-ddfe8229367b"],
 ". This restriction is necessary to exclude the singularity of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "17b23df5-bac5-4f7d-8564-ac3ff8d0b226"],
 " at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "cf224503-d726-4206-8841-c63da57bab89"],
 "."
}], "TechNoteText",
 CellID->1665628258,ExpressionUUID->"554d7cd5-5659-4bd7-9b2e-43f8adaadb00"],

Cell["\<\
Set the (maximum) condition number of matrices of our concern:\
\>", "TechNoteMathCaption",
 CellID->1601702047,ExpressionUUID->"470ee6b5-3ed2-4d6d-8367-ca69139feb81"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"$\[Kappa]", "=", "10"}]], "Input",
 CellLabel->"In[2]:=",
 CellID->194930823,ExpressionUUID->"7cb16d22-6e12-4640-b904-43274f53ee1e"],

Cell[BoxData["10"], "Output",
 CellLabel->"Out[2]=",
 CellID->1225046320,ExpressionUUID->"6a3b1b6a-c225-46e1-83ca-464425a0e6c6"]
}, Open  ]],

Cell[TextData[{
 "Scale down the target function by a factor of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"1", "/", "2"}], "\[Kappa]"}], TraditionalForm]],ExpressionUUID->
  "da475f7a-191f-476e-a0e1-c86bf9e5e706"],
 " so that"
}], "TechNoteMathCaption",
 CellID->2140260818,ExpressionUUID->"49d63987-1ff6-46bd-acab-68de991fbc5b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"target", "[", "x_", "]"}], ":=", 
  RowBox[{"1", "/", 
   RowBox[{"(", 
    RowBox[{"2", "*", "$\[Kappa]", "*", "x"}], ")"}]}]}]], "Input",
 CellLabel->"In[3]:=",
 CellID->938980246,ExpressionUUID->"c3ccd196-ab36-4785-a296-ab5893ebca29"],

Cell["This improves the numerical stability.", "TechNoteMathCaption",
 CellID->2094550900,ExpressionUUID->"22efc4d5-e0bb-482c-bee9-e6d87f91bae0"],

Cell["Set the interval in accordance with the condition number:", \
"TechNoteMathCaption",
 CellID->1328462383,ExpressionUUID->"b1c9f43b-8988-4a9e-ab4c-75c743f1d572"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"$interval", "=", 
  RowBox[{"Interval", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1"}], ",", 
      RowBox[{
       RowBox[{"-", "1"}], "/", "$\[Kappa]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"1", "/", "$\[Kappa]"}], ",", "1"}], "}"}]}], "]"}]}]], "Input",\

 CellLabel->"In[4]:=",
 CellID->1611560705,ExpressionUUID->"eca91dd0-a5dc-488e-bcf0-1e9347109604"],

Cell[BoxData[
 RowBox[{"Interval", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "1"}], ",", 
     RowBox[{"-", 
      FractionBox["1", "10"]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     FractionBox["1", "10"], ",", "1"}], "}"}]}], "]"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->1506872621,ExpressionUUID->"1e086d78-86b7-497d-8ba4-95742b7a2793"]
}, Open  ]],

Cell["Plot the target function to see how it looks like:", \
"TechNoteMathCaption",
 CellID->1938438991,ExpressionUUID->"0234c3a1-526b-436e-b14e-0603ac436207"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"target", "[", "x", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<x\>\"", ",", "\"\<y\>\""}], "}"}]}]}], "]"}]], "Input",
 CellLabel->"In[5]:=",
