Cell[CellGroupData[{

Cell["Polynomial Approximation", "TechNoteSection",
 CellID->434079351,ExpressionUUID->"fe0a5c13-48f7-46ba-b651-48b1d0604135"],

Cell[TextData[{
 "Let us now find a polynomial approximation to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "b4b98d3f-4d0c-478e-a431-bc0c1477407e"],
 ". We note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "f786a4d3-ea16-4b99-bcc7-1e22cc521510"],
 " is odd, and hence we need to find an odd polynomial approximation to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "75cd908e-79a7-4150-a038-09f16be842e3"],
 " on the interval ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "\[Kappa]"], TraditionalForm]],ExpressionUUID->
  "f0261c8d-4433-4d76-83c2-2b87f5b0e3c0"],
 "."
}], "TechNoteText",
 CellID->1419037092,ExpressionUUID->"48da96ee-d754-489b-a5ac-aaadb0378924"],

Cell["Make sure to load Q3:", "TechNoteMathCaption",
 CellID->1296167482,ExpressionUUID->"cce431ef-12d7-4a7a-a8fb-1911ff5c1109"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[6]:=",
 CellID->1552724342,ExpressionUUID->"84f8f355-f5b6-46e8-aa07-c3f9e3c0d973"],

Cell[TextData[{
 "Set the degree of the approximate polynomial. Note that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "=", 
   RowBox[{
    RowBox[{"2", 
     StyleBox["n", "TI"]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       StyleBox["p", "TI"]}], ")"}], "/", "2"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "104864e6-0977-48e1-8c74-a623cb9d3437"],
 ":"
}], "TechNoteMathCaption",
 CellID->638710960,ExpressionUUID->"3dee2563-1178-46e7-8feb-a54510be4e7b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"$n", "=", "25"}], "\[IndentingNewLine]", 
 RowBox[{"$degree", "=", "51"}]}], "Input",
 CellLabel->"In[7]:=",
 CellID->1984291957,ExpressionUUID->"4e7e4ada-82af-4057-88b7-12fadebd540b"],

Cell[BoxData["25"], "Output",
 CellLabel->"Out[7]=",
