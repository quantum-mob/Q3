 CellID->1503745851,ExpressionUUID->"50829a93-8a6b-4277-a464-f937fa005cf1"]
}, Open  ]],

Cell[TextData[{
 "Find a polynomial approximation of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "41111f31-0153-4cac-8402-ea42116f474c"],
 ":"
}], "TechNoteMathCaption",
 CellID->27171821,ExpressionUUID->"b408cb37-f2e3-43a5-8129-5fe3f815841e"],

