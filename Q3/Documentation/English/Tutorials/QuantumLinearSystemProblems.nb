Cell[CellGroupData[{

Cell["Polynomial Approximation", "TechNoteSection",
 CellID->434079351,ExpressionUUID->"4f2b38ba-d819-478b-bce8-2b6053fe0850"],

Cell[TextData[{
 "Let us now find a polynomial approximation to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "57698d59-7020-44d7-b9f3-8ace96aebac3"],
 ". We note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "1f912dd5-a845-4149-8c48-b7fababe81b8"],
 " is odd, and hence we need to find an odd polynomial approximation to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "ed5dd51d-0190-420e-8d3f-d51e9bcd7083"],
 " on the interval ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["D", "\[Kappa]"], TraditionalForm]],ExpressionUUID->
  "db88a9a7-b097-4999-9bb5-2fc397764ce1"],
 "."
}], "TechNoteText",
 CellID->1419037092,ExpressionUUID->"d462448f-d739-469d-812f-f6063eb745db"],

Cell["Make sure to load Q3:", "TechNoteMathCaption",
 CellID->1296167482,ExpressionUUID->"1af319d1-129c-4f08-955f-aadf30bb0e3f"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[6]:=",
 CellID->1552724342,ExpressionUUID->"f3a6e3da-22a0-4665-a634-caa47b4677a4"],

Cell[TextData[{
 "Set the degree of the approximate polynomial. Note that ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d", "TI"], "=", 
   RowBox[{
    RowBox[{"2", 
     StyleBox["n", "TI"]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       StyleBox["p", "TI"]}], ")"}], "/", "2"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "940544ca-7760-427e-974a-15b4de973c1f"],
 ":"
}], "TechNoteMathCaption",
 CellID->638710960,ExpressionUUID->"f9249025-245c-4a51-b1c4-18169b4b16ff"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"$n", "=", "25"}], "\[IndentingNewLine]", 
 RowBox[{"$degree", "=", "51"}]}], "Input",
 CellLabel->"In[7]:=",
 CellID->1984291957,ExpressionUUID->"0672d955-87c2-4bd7-b56b-01754cde4e01"],

Cell[BoxData["25"], "Output",
