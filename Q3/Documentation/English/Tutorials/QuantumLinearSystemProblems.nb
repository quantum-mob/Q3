 CellID->1829545107,ExpressionUUID->"23204a76-fd4c-4f04-8057-1b739a0f0bd9"],

Cell["\<\
Finally, we find a QSP representation of the polynomial approximation.\
\>", "TechNoteText",
 CellID->624551187,ExpressionUUID->"f48d1323-bb13-4898-ae54-5874d2c99fc4"],

