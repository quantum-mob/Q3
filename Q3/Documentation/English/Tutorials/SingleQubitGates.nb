  FormBox["X", TraditionalForm]],ExpressionUUID->
  "436da3a5-e238-4e95-9113-f9472f42024c"],
 " and the phase-flip feature of ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "f569060e-2e8b-48d9-8b95-c8aaa87b6db6"],
 " to get"
}], "TechNoteText",
