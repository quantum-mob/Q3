 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Complex", ",", "c"}], "]"}]}], "Input",
 CellLabel->"In[231]:=",
 CellID->1355125567,ExpressionUUID->"a2f2283a-4a25-4233-a547-bb8fba97b2bf"],

Cell[TextData[{
 "The ",
 ButtonBox["Hadamard gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Hadamard"],
 " is one of the most frequently used elementary gates in many quantum \
algorithms. The Hadamard gate ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "faac9d34-1f21-4269-90f7-c54e8bf5373a"],
 " is defined by the mapping:"
}], "TechNoteText",
 CellID->668577281,ExpressionUUID->"ad7d3cd5-8abf-4ab8-861d-c56cb80fdd6c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", ":", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[RightTeeArrow]", 
     FractionBox[
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "+", 
       TemplateBox[{"1"},
        "Ket"]}], 
      SqrtBox["2"]]}]}], TraditionalForm]],ExpressionUUID->
  "10103b6c-be75-4501-bc0e-62101f8b9806"],
 ",     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"1"},
     "Ket"], "\[RightTeeArrow]", 
    FractionBox[
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "-", 
      TemplateBox[{"1"},
       "Ket"]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "a0f2ccf7-1664-4c09-8275-68256a86d016"],
 "."
}], "TechNoteText",
 CellID->1143920663,ExpressionUUID->"3ac01d34-c25d-4378-a88c-f587c807ee40"],

Cell[TextData[{
 "That is, it constructs linear superpositions of the two logical basis \
states, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "01abd7e5-63a1-4cc6-9eb9-2bd6c280ff36"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ab070342-e03b-4884-9782-1bf87bacf53b"],
 ". This feature makes the Hadamard gate so useful that it is exploited in a \
wide range of quantum algorithms. In the logical basis, it is represented by \
the 2 \[Times] 2 Hadamard matrix"
}], "TechNoteText",
 CellID->1600975097,ExpressionUUID->"4f4efcca-5026-4ecc-b71d-6bbebb2fde10"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "\[DotEqual]", 
    RowBox[{
     FractionBox["1", 
      SqrtBox["2"]], 
     RowBox[{"(", GridBox[{
        {"1", "1"},
        {"1", 
         RowBox[{"-", "1"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "088ae603-4044-4fa5-bcf3-8fab22e12146"],
 " ."
}], "TechNoteText",
 CellID->1765842016,ExpressionUUID->"48316397-4cfb-4559-88b3-9fa3eb873a45"],

Cell[TextData[{
 "In quantum circuit model, the Hadamard gate is depicted by an element with \
label \[OpenCurlyQuote]",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "abe37f2f-a744-411c-ae76-aecd06e5567c"],
 "\[CloseCurlyQuote]"
}], "TechNoteText",
 CellID->282761372,ExpressionUUID->"eb457133-fff9-484d-8cba-50f58c33d022"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"S", "[", "6", "]"}], "]"}]}]], "Input",
 CellLabel->"In[233]:=",
 CellID->2136552040,ExpressionUUID->"e1ef1251-341f-49e5-b306-112d05c055e6"],

Cell[BoxData[
 InterpretationBox[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, LineBox[{{{0, -1}, {2, -1}}}], {
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -1.4}, {1.4, -0.6}]}, InsetBox[
      StyleBox["\<\"H\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.2],
       FontWeight->"Light",
       FontSlant->Italic], {1., -1.}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}},
   ImagePadding->{{25.56, 25.56}, {7.2, 7.2}},
   ImageSize->118.8,
   PlotRange->{{0, 2}, {-1.5, -0.5}},
   PlotRangePadding->Scaled[0.025]],
  QuantumMob`Q3`QuantumCircuit[
   $CellContext`S[6]]]], "Output",
 CellLabel->"Out[233]=",
 CellID->1300002986,ExpressionUUID->"898ca0b0-bb0a-437e-b285-9cf1ecd4f422"]
}, Open  ]],

Cell["\<\
In passing, here are the demonstrations of the mapping of the logical basis \
states under the Hadamard gate,\
\>", "TechNoteText",
 CellID->1276399097,ExpressionUUID->"d64f3bf1-befc-46b4-8579-a5839b173003"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{"Basis", "[", "S", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"qc", "**", "in"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Thread", "[", 
   RowBox[{"in", "->", "out"}], "]"}], "//", "TableForm"}]}], "Input",
 CellLabel->"In[234]:=",
 CellID->1225473396,ExpressionUUID->"57201abb-4f07-4663-9041-8ce24f69260a"],

Cell[BoxData[
 TagBox[
  TagBox[GridBox[{
     {
      RowBox[{
       InterpretationBox[
        TemplateBox[{
          TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
            SubscriptBox["0", 
             TemplateBox[{",", "\",\"", 
               InterpretationBox["S", 
                $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
           "RowWithSeparators"]},
         "Ket"],
