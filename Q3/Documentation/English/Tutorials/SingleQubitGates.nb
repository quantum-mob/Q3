Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ": Illustration of the action of the Hadamard gate on the Bloch sphere. The \
Hadamard gate corresponds to a rotation around the axis (1,0,1) in the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[VeryThinSpace]", "z"}], TraditionalForm]],ExpressionUUID->
  "77e11f53-da13-4d44-8b0c-638f52839a18"],
 "-plane by angle \[Pi]."
}], "TechNoteCaption",
 CellID->893601925,ExpressionUUID->"f7b97332-49a9-4a22-942b-1b234487ff89"],

Cell[TextData[{
 "An obvious but very useful feature of the Hadamard gate is that it makes a \
linear superposition of all elements in the logical basis. Consider a quantum \
register consisting of n qubits. When applied to each qubit in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ec91f1d4-e7d4-4b7a-903d-09e4f50f2f61"],
 ", it generates a linear superposition of all states in the logical basis"
}], "TechNoteText",
 CellID->1414410004,ExpressionUUID->"3716ea5d-7db3-4b2a-865c-499eaddce3f2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["H", 
      RowBox[{"\[CircleTimes]", "n"}]], 
     SuperscriptBox[
      TemplateBox[{"0"},
       "Ket"], 
      RowBox[{"\[CircleTimes]", "n"}]]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}], "\[CircleTimes]", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "+", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["2"]], ")"}]}], "=", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", 
        RowBox[{"n", "/", "2"}]]], 
      RowBox[{
       SubsuperscriptBox["\[Sum]", 
        RowBox[{"x", "=", "0"}], 
        RowBox[{
         SuperscriptBox["2", "n"], "-", "1"}]], 
       TemplateBox[{"x"},
        "Ket"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "79270665-1725-43de-af38-61c3a6a6d9d6"],
 " ,"
}], "TechNoteText",
 CellID->1492448585,ExpressionUUID->"97929e67-9013-445b-a502-b5a9f88b15bb"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"x"},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["x", "1"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["x", "2"]},
      "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["x", "n"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "51f4dec6-ee4e-46b3-b461-84c0ab28ba05"],
 " for an integer ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "6d6ca142-0da5-4aef-a64f-0122d4a6e531"],
 " represented by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], 
       SubscriptBox["x", "2"], 
       SubscriptBox["\[CenterEllipsis]x", "n"]}], ")"}], "2"]}], 
   TraditionalForm]],ExpressionUUID->"6b0a128c-c352-40ef-9e1d-32cd53ac6176"],
 " in the binary digits. More generally, for an arbitrary state |y\:27e9 in \
the logical basis,"
}], "TechNoteText",
 CellID->974371135,ExpressionUUID->"d453fedb-05f2-4447-9b5e-e6cfd2033f72"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["H", 
      RowBox[{"\[CircleTimes]", "n"}]], 
     TemplateBox[{"y"},
      "Ket"]}], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"x", "=", "0"}], 
       RowBox[{
        SuperscriptBox["2", "n"], "-", "1"}]], 
      SuperscriptBox[
       RowBox[{
        TemplateBox[{"x"},
         "Ket"], "(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"x", "\[CenterDot]", "y"}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"d946f65d-ed17-4870-b3a5-121fc1a3c813"],
 " ,"
}], "TechNoteText",
 CellID->1692857570,ExpressionUUID->"9099cfc1-bc88-4914-a203-5f337f4ffbd1"],

Cell["where we have used a short-hand notation", "TechNoteText",
 CellID->1993823534,ExpressionUUID->"219b3ca8-4150-4a48-b70a-6129546a45a3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "\[CenterDot]", "y"}], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["x", "1"], 
      SubscriptBox["y", "1"]}], "+", 
     RowBox[{
      SubscriptBox["x", "1"], 
      SubscriptBox["y", "1"]}], "+", "\[CenterEllipsis]", "+", 
     RowBox[{
      SubscriptBox["x", "n"], 
      SubscriptBox["y", "n"], "   ", 
      RowBox[{"(", 
       RowBox[{"mod", " ", "2"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"1f207e7b-2ec2-41de-b9d5-1dec4c7bb35f"]
}], "TechNoteText",
 CellID->857308150,ExpressionUUID->"bdc32d2c-ae42-41c5-b487-ed76d74d4e26"],

Cell[TextData[{
 "for the bitwise dot product of two integers ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "b5ea9556-93a5-4bdc-a7b5-179dabb72ba9"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "2cb64436-c2ad-44a2-b40d-a40466201c88"],
 ". The properties of the Hadamard gate summarized in the above two equations \
are used ubiquitously in almost all quantum algorithms."
}], "TechNoteText",
 CellID->1310289327,ExpressionUUID->"c68435e7-88c8-4dd3-ab99-543393695a50"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->439647034,ExpressionUUID->"a9219a77-3489-45e8-bd8b-90ea7cf8fa4d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"S", "[", 
    RowBox[{"kk", ",", "6"}], "]"}], "]"}]}]}], "Input",
 CellLabel->"In[240]:=",
 CellID->1735402551,ExpressionUUID->"796832dd-5390-45e3-9eb3-a0984b6fb377"],

Cell[BoxData[
 InterpretationBox[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {2, -1}}, {{0, -2}, {2, -2}}, {{0, -3}, {2, -3}}}], {{
      {LightDarkSwitched[
        GrayLevel[1]], EdgeForm[Opacity[1]], 
       RectangleBox[{0.6, -1.4}, {1.4, -0.6}]}, InsetBox[
       StyleBox["\<\"H\"\>",
        StripOnInput->False,
