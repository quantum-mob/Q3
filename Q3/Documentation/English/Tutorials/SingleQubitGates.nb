Cell[TextData[{
 StyleBox["Figure 3",
  FontWeight->"Bold"],
 ": Visualization of the transformations of states under single-qubit \
operations. Up to a global phase factor, a single-qubit unitary operation is \
a rotation on the Bloch sphere. The rotation around the axis indicated by the \
black arrow is depicted by the blue arrow. The same rotation can be achieved \
by combining three rotations around the y- or z-axis depicted by the yellow \
arrows."
}], "TechNoteCaption",
 CellID->1797229158,ExpressionUUID->"1596dffb-4653-4581-863a-226aa22714b0"],

Cell[TextData[{
 "We will further denote the rotations around the \[Mu]-axis\[LongDash]",
 Cell[BoxData[
  FormBox[
   StyleBox["n",
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "98ef92df-1896-46e5-aa3f-ec3cb64c0f19"],
 " parallel to the \[Mu]-axis\[LongDash]of the Bloch sphere by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "\[Mu]"], "(", "\[Phi]", ")"}], TraditionalForm]],
  ExpressionUUID->"affdc5ac-dc8d-4620-a678-f2d1a997ab4e"],
 "."
}], "TechNoteText",
 CellID->1672963451,ExpressionUUID->"51fb019c-df80-4a27-81d5-ad39919f3be7"],

Cell[TextData[{
 "To see that the unitary operation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", 
     StyleBox["n",
      FontWeight->"Bold"]], "(", "\[Phi]", ")"}], TraditionalForm]],
  ExpressionUUID->"314b9c63-8c08-4a25-b7fd-1a7923d6517f"],
 " in (2.23) corresponds to a rotation, recall that the Pauli operators ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["S", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "02e22808-c016-445a-855b-97cbf49f9c99"],
 " are the spin angular momentum operators of spin 1/2. That is, they are the \
generators of rotations and satisfy the commutation relations"
}], "TechNoteText",
 CellID->493330786,ExpressionUUID->"599e629d-5c36-430c-a6ee-0b6a82391270"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SuperscriptBox["S", "\[Mu]"], ",", 
      SuperscriptBox["S", "\[Nu]"]}], "]"}], "=", 
    RowBox[{"2", "\[ImaginaryI]", 
     RowBox[{
      SubscriptBox["\[Sum]", "\[Lambda]"], 
      RowBox[{
       SuperscriptBox["S", "\[Lambda]"], 
       SubscriptBox["\[Epsilon]", 
        RowBox[{"\[Lambda]", " ", "\[Mu]", " ", "\[Nu]"}]]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"7b9c45e9-8a1d-4283-80a4-efdf8728214b"],
 " ,"
}], "TechNoteText",
 CellID->2123642882,ExpressionUUID->"e94e59ac-0439-41fe-9332-33b84b0de67a"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Epsilon]", 
    RowBox[{"\[Lambda]", " ", "\[Mu]", " ", "\[Nu]"}]], TraditionalForm]],
  ExpressionUUID->"1b6116b7-4cbd-4880-865b-8d97ef585d8c"],
 " is the ",
 ButtonBox["Levi-Civita symbol",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/LeviCivitaTensor"],
 ". For a demonstration with Q3, take the commutators between all pairs of \
the Pauli operators using ",
 StyleBox[ButtonBox["Outer",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Outer"], "Input"],
 " as follows."
}], "TechNoteText",
 CellID->887704634,ExpressionUUID->"30977d5c-ccd5-4189-a661-9030178c7f17"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1504135947,ExpressionUUID->"e20ce26a-8976-443e-9e0a-e349978d8f15"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[249]:=",
 CellID->1079023113,ExpressionUUID->"df9cb284-1038-45ff-9a7d-f8d576a5c7ee"],

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Complex", ",", "c"}], "]"}]}], "Input",
 CellLabel->"In[250]:=",
 CellID->1789544923,ExpressionUUID->"0a3e5fb6-99dc-4fed-aabc-2a00ce15342a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"op", "=", 
  RowBox[{"S", "[", "All", "]"}]}]], "Input",
 CellLabel->"In[252]:=",
 CellID->1082887929,ExpressionUUID->"4de01a57-9a7f-4184-bb7c-452f4103978a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"X\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[1]], ",", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Y\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[2]], ",", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Z\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[3]]}], "}"}]], "Output",
 CellLabel->"Out[252]=",
 CellID->40499835,ExpressionUUID->"aeb9845c-2bcb-451e-8a7b-363bb66f1e16"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{"Outer", "[", 
    RowBox[{
     RowBox[{"HoldForm", "@*", "Commutator"}], ",", "op", ",", "op"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"ReleaseHold", "[", "in", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Thread", "[", 
   RowBox[{
    RowBox[{"Flatten", "[", "in", "]"}], "\[Rule]", 
    RowBox[{"Flatten", "[", "out", "]"}]}], "]"}], "//", 
  "TableForm"}]}], "Input",
 CellLabel->"In[253]:=",
 CellID->2120842067,ExpressionUUID->"f53aa674-27a3-4226-8839-35cb5819a091"],

Cell[BoxData[
 TagBox[
  TagBox[GridBox[{
     {
      RowBox[{
       TagBox[
        RowBox[{"Commutator", "[", 
         RowBox[{
