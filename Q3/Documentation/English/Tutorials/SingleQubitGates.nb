Cell[CellGroupData[{

Cell["The Pauli Gates", "TechNoteSection",
 CellID->1574772109,ExpressionUUID->"611d01f3-f223-475a-8709-9f446073f906"],

Cell["\<\
The Pauli gate operations (or Pauli gates for short) are defined by the \
corresponding Pauli matrices\
\>", "TechNoteText",
 CellID->1606370335,ExpressionUUID->"03b47c25-b42b-4b56-9c9c-9db0decca979"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"0", "1"},
       {"1", "0"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "cd7fc74f-d842-4708-a6a2-b41fd1b4b687"],
 ",    ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"0", 
        RowBox[{"-", "\[ImaginaryI]"}]},
       {"\[ImaginaryI]", "0"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d5f96304-d7d8-4d8f-b2bf-632cf1d08b66"],
 ",    ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e5204b8d-1911-4bba-a59c-b82e04c5bda9"],
 "."
}], "TechNoteText",
 CellID->101810261,ExpressionUUID->"c619b984-9b40-4371-ad0c-c1286d4eb1e2"],

Cell[TextData[{
 "They form the most elementary single-qubit gate operations and are \
frequently used in many quantum algorithms. In this document, the Pauli gates \
will be denoted sometimes by ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "572ef818-9c54-441a-808c-276fd87245ed"],
 ", ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "7727e519-ba08-4a6a-9239-6332b41c6827"],
 ", and ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "1776c8a6-495c-4c73-bb70-778ea6644b31"],
 ", and other times by ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["S", "x"], TraditionalForm]],ExpressionUUID->
  "e721c1f6-aeee-4b05-a3d3-2aaeb30dbfaa"],
 ", ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["S", "y"], TraditionalForm]],ExpressionUUID->
  "810f03e6-30db-482d-b3bd-57314f700711"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["S", "z"], TraditionalForm]],ExpressionUUID->
  "d0491116-3a7e-486a-afde-3b89820ae635"],
 ", depending on the context. In quantum circuit model, they are typically \
depicted by the circuit elements"
}], "TechNoteText",
 CellID->1728073615,ExpressionUUID->"650e53b0-e846-426f-be01-7c8dab4dbbfe"],

