Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->775300962,ExpressionUUID->"0ec2bef6-2de2-4c6d-a388-e167eb465025"],

Cell[TextData[{
 "Two phase gates ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "471da4db-3e99-432e-9de3-f76c90fcd356"],
 " and ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "f10aa5a5-7444-43ef-88e8-0e29cb8764c0"],
 " by angles 2\[Pi]/4 and 2\[Pi]/8, respectively, are particularly popular \
(and important in the context of fault-tolerant quantum computation), and \
they are often called the ",
 StyleBox[ButtonBox["quadrant",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Quadrant"],
  FontSlant->"Italic"],
 " and ",
 StyleBox[ButtonBox["octant",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Octant"],
  FontSlant->"Italic"],
 " phase gate. In the logical basis, they are represented by the following \
diagonal matrices"
}], "TechNoteText",
 CellID->365591531,ExpressionUUID->"2c69cf32-18c4-47fb-a83a-d08feab7059e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", "\[ImaginaryI]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "669e7775-bdfc-4e3b-a5ce-c2543b04216e"],
 " ,\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "\[DotEqual]", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", 
          RowBox[{"\[Pi]", "/", "4"}]}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "f92d7252-81e8-4dc2-ae04-1ef6e3a342f4"],
 ","
}], "TechNoteText",
 CellID->546147450,ExpressionUUID->"f3b5dbbe-fca0-4f1c-805d-0167d30267bb"],

Cell[TextData[{
 "respectively. Obviously, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", "=", 
    SuperscriptBox["S", "2"]}], TraditionalForm]],ExpressionUUID->
  "c2b8afd6-ca96-438c-9f10-d4e559a32af8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "=", 
    SuperscriptBox["T", "2"]}], TraditionalForm]],ExpressionUUID->
  "48813afd-b641-4136-80af-6c138f1cf3ec"],
 ". In quantum circuits, they are typically denoted by the following quantum \
circuit elements,"
}], "TechNoteText",
 CellID->755084872,ExpressionUUID->"11ee9d3c-b29a-427a-9f2a-d6309e56f6dc"],

