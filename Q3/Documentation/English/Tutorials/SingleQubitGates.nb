Cell[CellGroupData[{

Cell["Rotations", "TechNoteSection",
 CellID->1113797362,ExpressionUUID->"8578036c-69eb-4926-82dd-911d508d427e"],

Cell[TextData[{
 "A unitary operator takes the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", "\[ImaginaryI]\[CurlyPhi]"], "U"}], 
   TraditionalForm]],ExpressionUUID->"4f4169e2-7f1c-47f4-8bd2-64d8827d65db"],
 " with a global phase \[CurlyPhi] and a special unitary operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "b23a710e-8da9-44f8-8aa8-c35c077a9290"],
 " (i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"det", " ", "U"}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "3d8b9f3b-3d8f-4ad7-8d23-ba6b0c93d643"],
 "). A global phase is physically irrelevant in quantum mechanics, so here we \
focus on special unitary operators."
}], "TechNoteText",
 CellID->269712677,ExpressionUUID->"17431b22-5976-43db-9a2e-196ec9c8270f"],

Cell[TextData[{
 "\tA special unitary operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "c147dad8-8195-462d-a342-a9a797e49596"],
 " can always be written in the form"
}], "TechNoteText",
 CellID->1870467169,ExpressionUUID->"e11eb924-f73e-461f-a70c-364b1900c970"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "H"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"a5f09dda-b036-42f0-91ab-1faeb013f1ba"],
 ","
}], "TechNoteText",
 CellID->2076084597,ExpressionUUID->"eb2d5781-ce15-4cdb-a4a4-8d790cb81e18"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "e487689b-b2a0-4d59-a332-6f7dc5f2bd82"],
 " is a traceless Hermitian operator (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", " ", "H"}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "f927c2ec-c419-455b-b721-6f4fb2326813"],
 ").  On a two-dimensional vector space associated with a qubit, any \
traceless Hermitian operator ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "65bf07c8-349f-4da2-9fa2-165145c25a48"],
 " can be expanded in terms of the Pauli operators ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["S", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "f47d6422-472a-4d9f-ab54-4e8f249c9477"],
 " as"
}], "TechNoteText",
 CellID->439525323,ExpressionUUID->"151928ca-6c0f-4947-a7b0-01cc244948ea"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["S", "x"], " ", 
      SubscriptBox["B", "x"]}], "+", 
     RowBox[{
      SuperscriptBox["S", "y"], " ", 
      SubscriptBox["B", "y"]}], "+", 
     RowBox[{
      SuperscriptBox["S", "z"], " ", 
      SubscriptBox["B", "z"]}]}]}], TraditionalForm]],ExpressionUUID->
  "4e0f1339-d5da-43db-a7ff-1c25d6eb919f"],
 " ,"
}], "TechNoteText",
 CellID->1905841628,ExpressionUUID->"845a5f55-fc43-4fc5-9704-b6728b849feb"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "x"], TraditionalForm]],ExpressionUUID->
  "e7dbc4ed-7587-4e0c-99d4-56b58de7e5cd"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "y"], TraditionalForm]],ExpressionUUID->
  "0479cbb7-0630-466d-bb9a-65a1c026eb18"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "z"], TraditionalForm]],ExpressionUUID->
  "b2a65b34-e79f-4384-9bc7-ad8ebba460d2"],
 " are real parameters. Regarding ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["B",
     FontWeight->"Bold"], " ", ":=", " ", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["B", "x"], ",", 
      SubscriptBox["B", "y"], ",", 
      SubscriptBox["B", "z"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "edc0e247-2f72-4973-984e-c23c95d313bd"],
 " as a three- dimensional vector, we consider the unit vector ",
 Cell[BoxData[
  FormBox[
   StyleBox["n",
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "9e903e04-7b85-472f-9f19-8dbb45298861"],
 " pointing to the same direction as ",
 Cell[BoxData[
  FormBox[
   StyleBox["B",
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "d565080f-a1e8-4775-9a36-fa33abf11e21"],
 " and a real parameter ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", " ", ":=", " ", 
    RowBox[{"2", 
     RowBox[{"\[LeftBracketingBar]", 
      StyleBox["B",
       FontWeight->"Bold"], "\[RightBracketingBar]"}]}]}], TraditionalForm]],
  ExpressionUUID->"79dfc6f0-4e68-4612-9ed0-3e91c600236c"],
 ", where the factor of 2 is for later convenience. In terms of these new \
parameterization, ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "0b847879-d01c-47b3-a452-0ab013815b99"],
 " reads as"
}], "TechNoteText",
 CellID->1761646791,ExpressionUUID->"9a70cac1-34d1-44b8-92eb-39a76f1c5eed"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{
      StyleBox["S",
       FontWeight->"Bold"], "\[CenterDot]", 
      StyleBox["n",
       FontWeight->"Bold"]}], " ", 
     RowBox[{"\[Phi]", "/", "2"}]}]}], TraditionalForm]],ExpressionUUID->
  "3b493d38-d3fc-4a04-844d-43c53505cdb9"],
 " ,"
}], "TechNoteText",
 CellID->640575148,ExpressionUUID->"3d650433-f3e7-49b0-a706-77fed34cc77b"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["S",
     FontWeight->"Bold"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SuperscriptBox["S", "x"], ",", 
      SuperscriptBox["S", "y"], ",", 
      SuperscriptBox["S", "z"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "cdb94146-9c48-4313-b44d-fea237ee59ec"],
 ". Putting this form of ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "a9cf27ee-e148-49b0-a1d2-d43b84db93aa"],
 " into the exponential function, we observe that any special unitary \
operator on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "e1c8af82-9b82-42d6-bb3b-3551541606d2"],
 " is of the form "
}], "TechNoteText",
 CellID->810990025,ExpressionUUID->"b87b564e-5f68-4f1c-8e5e-e658400da66c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["U", 
       StyleBox["n",
        FontWeight->"Bold"]], "(", "\[Phi]", ")"}], ":=", 
     RowBox[{"exp", "(", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", 
       RowBox[{
        StyleBox["S",
         FontWeight->"Bold"], "\[CenterDot]", 
        StyleBox["n",
         FontWeight->"Bold"]}], " ", 
       RowBox[{"\[Phi]", "/", "2"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"80014f06-7819-4680-986d-4d3e7e586315"],
 " ."
}], "TechNoteText",
 CellID->230642666,ExpressionUUID->"58877d7a-629a-47f1-96eb-29785b9b9cdd"],

Cell[TextData[{
 "Here we have attached the subscript of unit vector n and an argument of \
real parameter \[Phi] to indicate that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", 
     StyleBox["n",
      FontWeight->"Bold"]], "(", "\[Phi]", ")"}], TraditionalForm]],
  ExpressionUUID->"213af642-8155-45d7-a81c-9789f72ddacf"],
 " describes a rotation around the axis ",
 Cell[BoxData[
  FormBox[
   StyleBox["n",
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "befcee8c-1849-4516-ac7b-cd04131eaf1b"],
 " by the angle \[Phi]. The rotation here is not in the real \
three-dimensional world but on the Bloch sphere, as illustrated in ",
 ButtonBox["Figure 3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/SingleQubitGates#1797229158"],
 ", corresponding to the two-dimensional vector space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "2df02f20-54c2-49af-9a16-a11acaadd94d"],
 ". We will further denote by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "\[Mu]"], "(", "\[Phi]", ")"}], TraditionalForm]],
  ExpressionUUID->"dd676023-c091-4b60-a785-4f840ddfa1e2"],
 " the rotations around the \[Mu]-axis (i.e., ",
 Cell[BoxData[
  FormBox[
   StyleBox["n",
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "a080b099-4c50-424f-acb1-edb1f3ab8cc4"],
 " parallel to the \[Mu]-axis) of the Bloch sphere."
}], "TechNoteText",
 CellID->203304627,ExpressionUUID->"64bd25cd-e4ef-43a1-a419-9059a4fe81a8"],

