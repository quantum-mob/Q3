Cell["\<\
It is important to remember that like any other quantum gate operations, it \
can take a linear superposition as input and transform the two logical basis \
states \[OpenCurlyQuote]simultaneously\[CloseCurlyQuote],\
\>", "TechNoteText",
 CellID->1652822106,ExpressionUUID->"0597057f-ff43-498a-81bc-cb0080d53003"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"X", "(", 
     RowBox[{
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], 
       SubscriptBox["c", "0"]}], "+", 
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], 
       SubscriptBox["c", "1"]}]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "ca4c7c8a-9ed7-4836-8546-00f534a2056f"],
 " ,"
}], "TechNoteText",
 CellID->1280161597,ExpressionUUID->"c0d51b89-03da-4b67-a17a-f7bfcdb09670"],

Cell["which is not possible with the classical counterpart NOT.", \
"TechNoteText",
 CellID->37301486,ExpressionUUID->"a0c61f4d-6ca1-406b-ac9d-b8f211af5cb2"],

