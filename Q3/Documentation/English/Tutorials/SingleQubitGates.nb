        FractionBox[
         InterpretationBox[
          TemplateBox[{
            TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
              SubscriptBox["0", 
               TemplateBox[{",", "\",\"", 
                 InterpretationBox["S", 
                  $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
             "RowWithSeparators"]},
           "Ket"],
          Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 0|>]], 
         SqrtBox["2"]], "+", 
        FractionBox[
         InterpretationBox[
          TemplateBox[{
            TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
              SubscriptBox["1", 
               TemplateBox[{",", "\",\"", 
                 InterpretationBox["S", 
                  $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
             "RowWithSeparators"]},
           "Ket"],
          Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 1|>]], 
         SqrtBox["2"]]}]}]},
     {
      RowBox[{
       InterpretationBox[
        TemplateBox[{
          TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
            SubscriptBox["1", 
             TemplateBox[{",", "\",\"", 
               InterpretationBox["S", 
                $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
           "RowWithSeparators"]},
         "Ket"],
        Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 1|>]], "\[Rule]", 
       RowBox[{
        FractionBox[
         InterpretationBox[
          TemplateBox[{
            TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
              SubscriptBox["0", 
               TemplateBox[{",", "\",\"", 
                 InterpretationBox["S", 
                  $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
             "RowWithSeparators"]},
           "Ket"],
          Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 0|>]], 
         SqrtBox["2"]], "-", 
        FractionBox[
         InterpretationBox[
          TemplateBox[{
            TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
