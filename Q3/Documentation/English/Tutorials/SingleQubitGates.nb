    Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 1|>]]}]}]], "Output",
 CellLabel->"Out[209]=",
 CellID->1316459327,ExpressionUUID->"870b906b-3ad6-4a64-869c-8e91899f6ea1"]
}, Open  ]],

