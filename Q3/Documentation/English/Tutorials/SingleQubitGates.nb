      "Superscript"],
     $CellContext`S[3]]}], 
   SqrtBox["2"]]}]], "Output",
 CellLabel->"Out[239]=",
 CellID->63947761,ExpressionUUID->"5a86ca21-7d3a-46e8-908f-cc392c3da8a3"]
}, Open  ]],

