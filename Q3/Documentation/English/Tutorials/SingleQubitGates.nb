Cell["\<\
and the matrix representation of the Hadamard gate in the logical basis,\
\>", "TechNoteText",
 CellID->2014628431,ExpressionUUID->"c18412cb-693d-4533-acdb-4af1cbdab91b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Matrix", "[", "qc", "]"}], "//", "MatrixForm"}]], "Input",
 CellLabel->"In[237]:=",
 CellID->485377568,ExpressionUUID->"d674304d-6852-4272-a874-2c2f7c83cd74"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["1", 
       SqrtBox["2"]], 
      FractionBox["1", 
       SqrtBox["2"]]},
     {
      FractionBox["1", 
       SqrtBox["2"]], 
      RowBox[{"-", 
       FractionBox["1", 
        SqrtBox["2"]]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellLabel->"Out[237]//MatrixForm=",
 CellID->768695015,ExpressionUUID->"332267a9-8435-4c4e-a599-abf26566fa00"]
}, Open  ]],

Cell[TextData[{
 "Note that the output states ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[PlusMinus]"},
     "Ket"], ":=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "\[PlusMinus]", 
      TemplateBox[{"1"},
       "Ket"]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "4bb51f7a-7d60-4d04-a75b-64b2c096efac"],
 "are the eigenstates of the Pauli X operator. One can thus regard the \
Hadamard gate as a basis transformation from the logical basis to the \
eigenbasis of the Pauli X gate."
}], "TechNoteText",
 CellID->1522628755,ExpressionUUID->"2abd6053-9766-4ce3-9859-3458462ff6fe"],

Cell["\<\
To provide further insight, note that it can be regarded as a rotation by \
angle \[Pi] around the axis (1, 0, 1) on the Bloch sphere (up to a global \
phase factor). This can be seen from the following inspection\
\>", "TechNoteText",
 CellID->1406347633,ExpressionUUID->"19ba00e7-453c-435d-b508-deca52e5ddd0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Rotation", "[", 
   RowBox[{"Pi", ",", 
    RowBox[{"{", 
     RowBox[{"1", ",", "0", ",", "1"}], "}"}], ",", "S"}], "]"}], "//", 
  "Elaborate"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"-", "I"}], "*", 
   RowBox[{"S", "[", "6", "]"}]}], "//", "Elaborate"}]}], "Input",
 CellLabel->"In[238]:=",
 CellID->1279648949,ExpressionUUID->"a020f9b0-9017-47b8-a11b-5386da384b87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{"\[ImaginaryI]", " ", 
     InterpretationBox[
      TemplateBox[{"S", 
        TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"X\""}, 
         "RowWithSeparators"]},
       "Superscript"],
      $CellContext`S[1]]}], 
    SqrtBox["2"]]}], "-", 
  FractionBox[
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     TemplateBox[{"S", 
       TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Z\""}, 
        "RowWithSeparators"]},
      "Superscript"],
     $CellContext`S[3]]}], 
   SqrtBox["2"]]}]], "Output",
 CellLabel->"Out[238]=",
 CellID->195496753,ExpressionUUID->"bd3f7635-a500-402f-abbb-1b7f83bbe362"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    RowBox[{"\[ImaginaryI]", " ", 
     InterpretationBox[
      TemplateBox[{"S", 
        TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"X\""}, 
         "RowWithSeparators"]},
       "Superscript"],
      $CellContext`S[1]]}], 
    SqrtBox["2"]]}], "-", 
  FractionBox[
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     TemplateBox[{"S", 
       TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Z\""}, 
