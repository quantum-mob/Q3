Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Illustration of the actions of Pauli gates as rotations by angle \[Pi]. \
From the left, the actions of the Pauli X, Y, and Z operator, respectively."
}], "TechNoteCaption",
 CellID->1084598545,ExpressionUUID->"596b37c3-fe45-4477-a39a-6933072e838b"],

Cell["\<\
Indeed, explicit evaluations reveal that the Pauli operators are identical \
(up to an irrelevant global phase factor) to the corresponding rotations.\
\>", "TechNoteText",
 CellID->1436284590,ExpressionUUID->"748d44e6-a1cc-4678-bad3-a9565e00f8c7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Rotation", "[", 
   RowBox[{"Pi", ",", 
    RowBox[{"S", "[", "1", "]"}]}], "]"}], "//", "Elaborate"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rotation", "[", 
   RowBox[{"Pi", ",", 
    RowBox[{"S", "[", "2", "]"}]}], "]"}], "//", "Elaborate"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Rotation", "[", 
   RowBox[{"Pi", ",", 
    RowBox[{"S", "[", "3", "]"}]}], "]"}], "//", "Elaborate"}]}], "Input",
 CellLabel->"In[227]:=",
 CellID->1918911850,ExpressionUUID->"954b8b23-17d6-4ba0-b5bd-9175d1161f30"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "\[ImaginaryI]"}], " ", 
  InterpretationBox[
   TemplateBox[{"S", 
     TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"X\""}, 
      "RowWithSeparators"]},
    "Superscript"],
   $CellContext`S[1]]}]], "Output",
 CellLabel->"Out[227]=",
 CellID->560891238,ExpressionUUID->"3d2b909c-5807-4680-a6ae-f4d1cb2e4eeb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "\[ImaginaryI]"}], " ", 
  InterpretationBox[
   TemplateBox[{"S", 
     TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Y\""}, 
      "RowWithSeparators"]},
    "Superscript"],
   $CellContext`S[2]]}]], "Output",
 CellLabel->"Out[228]=",
 CellID->1593310383,ExpressionUUID->"2ea8e9d4-9d4d-4029-8b25-f14779faa7ee"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "\[ImaginaryI]"}], " ", 
  InterpretationBox[
   TemplateBox[{"S", 
     TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Z\""}, 
      "RowWithSeparators"]},
    "Superscript"],
   $CellContext`S[3]]}]], "Output",
 CellLabel->"Out[229]=",
 CellID->1794012638,ExpressionUUID->"9cb9af2e-8a80-4b6d-b048-a1d3e9dfecc2"]
}, Open  ]],

Cell["\<\
Here, we have mainly focused on the roles of the Pauli operators as unitary \
operators. However, the Pauli operators play another important role as \
orthogonal basis vectors of the vector space of all linear operators on a \
two-dimensional vector space.\
\>", "TechNoteText",
 CellID->326353369,ExpressionUUID->"34ee3e18-60a4-480d-86f3-a58145748af3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Hadamard Gate", "TechNoteSection",
 CellID->347838345,ExpressionUUID->"f294c61b-e46e-4a94-97dd-ff32f9432400"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[230]:=",
 CellID->1965399199,ExpressionUUID->"e943ffe9-af89-4d82-976c-532bc3e0f297"],

