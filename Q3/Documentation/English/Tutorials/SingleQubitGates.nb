      "RowWithSeparators"]],
    $CellContext`c[0]], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox["S", 
            $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 0|>]]}], "+", 
  RowBox[{
   InterpretationBox[
