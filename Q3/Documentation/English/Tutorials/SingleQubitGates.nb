Cell["\<\
The phase flip is meaningless on classical bits, but it makes a significant \
difference
on a superposition,\
\>", "TechNoteText",
 CellID->482100538,ExpressionUUID->"a19abae8-ea0e-4e4e-8667-117f27eab52d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Z", "(", 
     RowBox[{
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], 
       SubscriptBox["c", "0"]}], "+", 
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], 
       SubscriptBox["c", "1"]}]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "-", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "a16a53d4-5482-4cc3-8dcf-9e72d41641b3"],
 " ."
}], "TechNoteText",
 CellID->207942035,ExpressionUUID->"41f6cd6e-3f89-4f84-af71-10b33897870a"],

