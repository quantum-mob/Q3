 CellID->2049242167,ExpressionUUID->"bcf98ab3-acf7-44d2-b209-75aa58552b3d"],

Cell[TextData[{
 "In the Euclidean space ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[DoubleStruckCapitalR]", "3"], TraditionalForm]],
  ExpressionUUID->"c553aa2e-7d97-4f35-b68b-13d5dc4f8b76"],
 ", any 3 \[Times] 3 rotation matrix can be decomposed into three factors,"
}], "TechNoteText",
 CellID->1982655257,ExpressionUUID->"565b2012-b235-4300-9535-5806f7a886c0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{
     RowBox[{"R", "(", 
      RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], ")"}], ":=", 
     RowBox[{
      RowBox[{
       SubscriptBox["R", "z"], "(", "\[Alpha]", ")"}], 
      RowBox[{
       SubscriptBox["R", "y"], "(", "\[Beta]", ")"}], 
      RowBox[{
       SubscriptBox["R", "z"], "(", "\[Gamma]", ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"2b9d0641-ec43-4846-b4fd-bcec405345fd"],
 " ,"
}], "TechNoteText",
 CellID->2130637547,ExpressionUUID->"036f7ecf-eff5-424a-9ab4-d81926473080"],

Cell[TextData[{
 "where \[Alpha], \[Beta], \[Gamma] are the so-called ",
 StyleBox[ButtonBox["Euler angles",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/TheEulerAngles"],
  FontSlant->"Italic"],
 ", and such a combination of rotations is called the ",
 StyleBox[ButtonBox["Euler rotation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/EulerRotation"],
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->335438704,ExpressionUUID->"f2b0823c-bdce-4579-baaa-1d71aff097d6"],

Cell["\<\
\tIn the same manner, any special unitary operator on the two-dimensional \
Hilbert space \[ScriptCapitalV] associated with a single qubit  can also be \
written as\
\>", "TechNoteText",
 CellID->573724753,ExpressionUUID->"3056abcc-a07c-4018-8ea1-9aac6abdb8d3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     RowBox[{"U", "(", 
      RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], ")"}], ":=", 
     RowBox[{
      RowBox[{
       SubscriptBox["U", "z"], "(", "\[Alpha]", ")"}], 
      RowBox[{
       SubscriptBox["U", "y"], "(", "\[Beta]", ")"}], 
      RowBox[{
       SubscriptBox["U", "z"], "(", "\[Gamma]", ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"b2e7b3d7-c613-4899-9f0a-8f42605bba84"],
 " ,"
}], "TechNoteText",
 CellID->390348641,ExpressionUUID->"0a3342e7-74f7-4c53-b301-8d26d1c334d1"],

Cell[TextData[{
 "a combination of elementary \[OpenCurlyDoubleQuote]rotations\
\[CloseCurlyDoubleQuote] around the y- and z-axis. The combination is called \
the Euler rotation in the two-dimensional vector space \[ScriptCapitalV]. ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/SingleQubitGates#1797229158"],
 " illustrates an Euler rotation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{"U", "(", 
     RowBox[{
      RowBox[{"\[Pi]", "/", "3"}], ",", 
      RowBox[{
       RowBox[{"-", "\[Pi]"}], "/", "3"}], ",", 
      RowBox[{"\[Pi]", "/", "4"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"97731ed8-58d5-487a-885f-b6b9acc843bd"],
 ". It transforms ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"v"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "+", 
       TemplateBox[{"1"},
        "Ket"]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "1503a6fe-2d11-417b-8fc3-7f76a2b9fd4a"],
 " (the red dot in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/SingleQubitGates#1797229158"],
 ") into ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"w"},
     "Ket"], "=", 
    RowBox[{"U", 
     TemplateBox[{"v"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "0ef4ccc4-b7b2-4808-94ce-a27e3557414e"],
 " (the blue dot in Figure 2). The transformation is displayed by the blue \
arrow. The yellow dots and arrows depicts the transformations under ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "z"], "(", "\[Alpha]", ")"}], TraditionalForm]],
  ExpressionUUID->"cdf92429-93f1-426f-ac36-9a3e3e53d02d"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "y"], "(", "\[Beta]", ")"}], TraditionalForm]],
  ExpressionUUID->"970538f5-7832-4909-869c-50d6e9c745a9"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "z"], "(", "\[Gamma]", ")"}], TraditionalForm]],
  ExpressionUUID->"9eba787f-4a05-4bcb-b39b-6ffdaf8e3685"],
 ", which combine to reproduce ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "4e38cd7b-42e0-4b6e-b6d4-eec9b39f18a1"],
 "."
}], "TechNoteText",
 CellID->27067702,ExpressionUUID->"941594d2-7b7d-41cc-afa5-1bb83bc4af86"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1699981985,ExpressionUUID->"406aed01-292f-4aac-8292-171084d22b84"],

Cell["\<\
For demonstration, consider a special unitary operator represented by the \
following matrix.\
\>", "TechNoteMathCaption",
 CellID->1576375695,ExpressionUUID->"201dd713-9477-478a-bfe1-df9114087405"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"3", "-", 
         RowBox[{"I", " ", 
          RowBox[{"Sqrt", "[", "3", "]"}]}]}], ",", 
        RowBox[{"I", "-", 
         RowBox[{"Sqrt", "[", "3", "]"}]}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"I", "+", 
         RowBox[{"Sqrt", "[", "3", "]"}]}], ",", 
        RowBox[{"3", "+", 
         RowBox[{"I", " ", 
          RowBox[{"Sqrt", "[", "3", "]"}]}]}]}], "}"}]}], 
     "\[IndentingNewLine]", "}"}], "/", "4"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"mat", "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[264]:=",
 CellID->640552826,ExpressionUUID->"ea1fd3a0-88ca-421d-86a2-42fa15369015"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{
       FractionBox["1", "4"], " ", 
       RowBox[{"(", 
        RowBox[{"3", "-", 
         RowBox[{"\[ImaginaryI]", " ", 
          SqrtBox["3"]}]}], ")"}]}], 
      RowBox[{
       FractionBox["1", "4"], " ", 
       RowBox[{"(", 
        RowBox[{"\[ImaginaryI]", "-", 
         SqrtBox["3"]}], ")"}]}]},
     {
      RowBox[{
       FractionBox["1", "4"], " ", 
       RowBox[{"(", 
        RowBox[{"\[ImaginaryI]", "+", 
         SqrtBox["3"]}], ")"}]}], 
      RowBox[{
       FractionBox["1", "4"], " ", 
       RowBox[{"(", 
        RowBox[{"3", "+", 
         RowBox[{"\[ImaginaryI]", " ", 
          SqrtBox["3"]}]}], ")"}]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellLabel->"Out[265]//MatrixForm=",
 CellID->447962255,ExpressionUUID->"be8cd98c-aecf-417c-b8e1-4029de2cf333"]
}, Open  ]],

Cell["This gives its expression in terms of the Pauli operators.", \
"TechNoteMathCaption",
 CellID->435824171,ExpressionUUID->"962238db-a353-470a-8863-ca9feaea79f6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"op", "=", 
  RowBox[{"Elaborate", "@", 
   RowBox[{"ExpressionFor", "[", 
    RowBox[{"mat", ",", "S"}], "]"}]}]}]], "Input",
 CellLabel->"In[266]:=",
 CellID->1977605727,ExpressionUUID->"1d8a7961-aa2b-4f7f-aa81-6a142a224540"],

Cell[BoxData[
 RowBox[{
  FractionBox["3", "4"], "+", 
  RowBox[{
   FractionBox["1", "4"], " ", "\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"X\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[1]]}], "-", 
  RowBox[{
   FractionBox["1", "4"], " ", "\[ImaginaryI]", " ", 
   SqrtBox["3"], " ", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Y\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[2]]}], "-", 
  RowBox[{
   FractionBox["1", "4"], " ", "\[ImaginaryI]", " ", 
   SqrtBox["3"], " ", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Z\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[3]]}]}]], "Output",
 CellLabel->"Out[266]=",
 CellID->1971437050,ExpressionUUID->"903e0eb5-746f-4fa8-8529-f3ee7d21acb5"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Dagger", "[", "op", "]"}], "**", "op"}]], "Input",
 CellLabel->"In[267]:=",
 CellID->1015049070,ExpressionUUID->"730337b0-8dab-49f7-8956-03ab877629f0"],

Cell[BoxData["1"], "Output",
 CellLabel->"Out[267]=",
 CellID->417309787,ExpressionUUID->"7eb7a485-0f48-4fff-8bf0-56ec09c76727"]
}, Open  ]],

Cell["This gives the Euler angles of the unitary operator.", \
"TechNoteMathCaption",
 CellID->319627722,ExpressionUUID->"ad59035d-3ca7-40e3-9bac-dcf374883fa2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"angs", "=", 
  RowBox[{"TheEulerAngles", "[", "mat", "]"}]}]], "Input",
 CellLabel->"In[268]:=",
 CellID->1126522507,ExpressionUUID->"85c855d7-0b83-4fa3-8d23-8fc9296cfaf0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["\[Pi]", "3"], ",", 
   FractionBox["\[Pi]", "3"], ",", "0"}], "}"}]], "Output",
 CellLabel->"Out[268]=",
 CellID->43999007,ExpressionUUID->"c5aaea33-d5ac-4a1b-92f2-a53425a9074b"]
}, Open  ]],

Cell["\<\
Indeed, the Euler angles reproduces the original unitary operator.\
\>", "TechNoteMathCaption",
 CellID->1247943197,ExpressionUUID->"182ff0a7-789b-4e7e-bcce-0e0366ef427e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"new", "=", 
  RowBox[{
   RowBox[{"EulerRotation", "[", 
    RowBox[{"angs", ",", "S"}], "]"}], "//", "Elaborate"}]}]], "Input",
 CellLabel->"In[269]:=",
 CellID->1856015377,ExpressionUUID->"d6a8c3c4-7843-46de-80d2-73f827101dbb"],

Cell[BoxData[
 RowBox[{
  FractionBox["3", "4"], "+", 
  RowBox[{
   FractionBox["1", "4"], " ", "\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"X\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[1]]}], "-", 
  RowBox[{
   FractionBox["1", "4"], " ", "\[ImaginaryI]", " ", 
   SqrtBox["3"], " ", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Y\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[2]]}], "-", 
  RowBox[{
   FractionBox["1", "4"], " ", "\[ImaginaryI]", " ", 
   SqrtBox["3"], " ", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Z\""}, 
       "RowWithSeparators"]},
     "Superscript"],
    $CellContext`S[3]]}]}]], "Output",
 CellLabel->"Out[269]=",
 CellID->756936081,ExpressionUUID->"9d6a152d-a8e5-408c-ace2-977e7eac371b"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"op", "-", "new"}]], "Input",
 CellLabel->"In[270]:=",
 CellID->1204913835,ExpressionUUID->"841a43e3-1511-44c0-b8b4-6d2a11631e66"],

Cell[BoxData["0"], "Output",
 CellLabel->"Out[270]=",
 CellID->131588539,ExpressionUUID->"612f0483-a6a0-4192-a000-e92a2f764e54"]
}, Open  ]],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1269907791,ExpressionUUID->"aaf1ddf7-8f89-438c-b733-ac379d614441"],

Cell[TextData[{
 "Specifying an Euler rotation in the above, we have chosen a particular set \
of axes. As a matter of fact, the choice is far more general. Given a special \
unitary operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "4525c7a0-42fe-487f-bd04-9cca4d0a2a0a"],
 " and any two non-parallel (not necessarily mutually-orthogonal) unit \
vectors ",
 Cell[BoxData[
  FormBox[
   StyleBox["m",
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "5d8d1964-65a5-44b7-9765-a89ac0a30e95"],
 " and ",
 Cell[BoxData[
  FormBox[
   StyleBox["n",
    FontWeight->"Bold"], TraditionalForm]],ExpressionUUID->
  "90037f04-5a44-492c-a9ec-086f8d09f5c3"],
 ", there exist three angles \[Alpha], \[Beta], and \[Gamma] such that"
}], "TechNoteText",
 CellID->307617529,ExpressionUUID->"023c31b7-c0f5-41de-892d-6a4cb59ef3c3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["U", 
       StyleBox["m",
        FontWeight->"Bold"]], "(", "\[Alpha]", ")"}], 
     RowBox[{
      SubscriptBox["U", 
       StyleBox["n",
        FontWeight->"Bold"]], "(", "\[Beta]", ")"}], 
     RowBox[{
      SubscriptBox["U", 
       StyleBox["m",
        FontWeight->"Bold"]], "(", "\[Gamma]", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"c3f8cdd0-5666-417a-b33f-a0b3b0b6dda5"],
 " ,"
}], "TechNoteText",
 CellID->1134671574,ExpressionUUID->"c4d5220e-c2bc-4220-ad01-08a72016c498"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A Discrete Set of Universal Rotations", "TechNoteSection",
 CellID->179863498,ExpressionUUID->"4bbe9a81-3dfb-41cb-8629-e846fb65d34b"],

Cell["\<\
The decomposition of a special unitary operator into three rotations around \
fixed axes as above is extremely useful in quantum computation because it \
enables the quantum computer to be programmable in terms of a smaller fixed \
set of rotations . Nevertheless, the three angular parameters \[Alpha], \
\[Beta], and \[Gamma] are continuous, and it is highly non - trivial to \
control such continuous parameters to an infinite precision .\
\>", "TechNoteText",
 CellID->1456319557,ExpressionUUID->"7f7fe5db-ffe8-4204-abe0-0bbc940d8a2e"],

Cell[TextData[{
 "Fortunately, it turns out that a discrete and finite set of rotations is \
enough to generate any rotation on a single qubit to an arbitrary accuracy as \
long as (i) any two rotation axes are non-parallel and (ii) any rotation \
angle is an irrational multiple of 2\[Pi]. The first requirement is clear \
because if all the rotations are around the same axis, they can only generate \
the rotation around the particular axis. To understand the second \
requirement, consider a rotation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "(", "\[Theta]", ")"}], TraditionalForm]],ExpressionUUID->
  "73125f8f-bbd1-47dd-b57e-4984f8c20e8e"],
 " around a fixed axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", " ", "=", " ", 
    RowBox[{"2", "\[Pi]", " ", 
     RowBox[{"p", "/", "q"}]}]}], TraditionalForm]],ExpressionUUID->
  "9f0d31ce-0b0b-488c-973b-4996e59548cc"],
 " for mutually prime integers ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "e8e30312-7f19-4afb-ae3b-3bb6dbe66c5c"],
 " and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "82fb0836-29f2-4a63-8eb4-97ea5f24549b"],
 ". Given that"
}], "TechNoteText",
 CellID->1491669640,ExpressionUUID->"c69f0ae8-325c-44ae-921c-854f225d7031"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"U", "(", "\[Theta]", ")"}], ")"}], "q"], "=", 
    RowBox[{
     RowBox[{"U", "(", 
      RowBox[{"q", " ", "\[Theta]"}], ")"}], "=", "I"}]}], TraditionalForm]],
  ExpressionUUID->"537765ab-5329-4058-82b6-4a3c90aff5fa"],
 ","
}], "TechNoteText",
 CellID->767544402,ExpressionUUID->"31fc452c-e7c3-4928-9bc4-c1958c80d645"],

Cell[TextData[{
 "it can only generate rotations by ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "f1096ff1-40fd-4505-b959-900079d8a583"],
 " different angles spaced equally by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", " ", 
    RowBox[{"\[Pi]", "/", "q"}]}], TraditionalForm]],ExpressionUUID->
  "ab6ed60b-44a6-4a9b-b842-deadd28f09d7"],
 " but no in-between angles. "
}], "TechNoteText",
 CellID->184496885,ExpressionUUID->"50181d84-cf4a-4865-8512-07fc515c23d0"],

Cell[TextData[{
 "The set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"H", ",", " ", "T"}], "}"}], TraditionalForm]],ExpressionUUID->
  "c65557ab-2603-48dc-9041-796a1f33a15b"],
 " of the Hadamard gate ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "5c94ecd0-63c0-483d-9a46-4043289a96da"],
 " and the octant phase gate ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "fbb4c1c5-6e78-4dd4-8bd9-f916e724ff98"],
 " is a popular choice for such a ",
 StyleBox["discrete set of universal rotations",
  FontSlant->"Italic"],
 " on a single qubit (strictly speaking, ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "6d460199-7162-42c3-843c-6474c2a4a5a6"],
 " nor ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "595ab16e-8463-4849-b3f4-375646757677"],
 " is a special unitary operator; here we are ignoring global phase factors). \
Recall that ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "6836bc90-4860-431a-9f40-aeaffb9c0cbd"],
 " correspond to a rotation by \[Pi] around ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"1", ",", "0", ",", "1"}], ")"}], TraditionalForm]],
  ExpressionUUID->"a86d5b44-5583-4bc7-a790-7849cd51b226"],
 " and ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "5d6bde2f-29f7-4c90-a365-a46c4d963c86"],
 " to a rotation by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "/", "4"}], TraditionalForm]],ExpressionUUID->
  "e5b3fddf-647e-4171-a116-25be04b031d8"],
 " around the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "238fec2c-b7d9-4775-b19c-fc9123a052b8"],
 "- axis . It follows from the commutation relation of the angular momentum \
operators that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", " ", "T", " ", "H"}], TraditionalForm]],ExpressionUUID->
  "d81f9aef-71b6-47d0-a314-a15b0db28a8e"],
 " is a rotation by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "/", "4"}], TraditionalForm]],ExpressionUUID->
  "22f7f748-7bb5-464d-be39-383a0ae48bd5"],
 " around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "ab92d094-c932-4f90-bbfa-6ed3d6f015a9"],
 "-axis. Then, one can see that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", " ", "H", " ", "T", " ", "H"}], TraditionalForm]],
  ExpressionUUID->"9a0f1beb-4e04-4b9a-88dc-8e6e5f993469"],
 ", a rotation by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "/", "4"}], TraditionalForm]],ExpressionUUID->
  "5b57b4ac-3376-4c4a-8d68-989673868cd8"],
 " around the x-axis followed by a rotation by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "/", "4"}], TraditionalForm]],ExpressionUUID->
  "4ea56f2f-29a5-4d50-8d74-e4cecdcfd667"],
 " around the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "56d812ae-7b4b-4ce7-a743-515b9dcbae49"],
 "-axis, correspond to a rotation around ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"cos", " ", 
      RowBox[{"(", 
       RowBox[{"\[Pi]", "/", "8"}], ")"}]}], ",", 
     RowBox[{"sin", " ", 
      RowBox[{"(", 
       RowBox[{"\[Pi]", "/", "8"}], ")"}]}], ",", 
     RowBox[{"cos", " ", 
      RowBox[{"(", 
       RowBox[{"\[Pi]", "/", "8"}], ")"}]}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"54a72862-0d4c-4dc4-ae68-24b2e54b7a86"],
 " by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", " ", "=", " ", 
    RowBox[{"2", " ", "arccos", "  ", 
     RowBox[{"(", 
      RowBox[{"cos2", " ", 
       RowBox[{"(", 
        RowBox[{"\[Pi]", "/", "8"}], ")"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"03c0843f-6daf-4bb3-8522-59563bf8dcb6"],
 ", which is an irrational multiple of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Pi]", " "}], TraditionalForm]],ExpressionUUID->
  "fafd2449-ab18-4f28-b34b-099c0178fea3"],
 ". This confirms that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"H", ",", " ", "T"}], "}"}], TraditionalForm]],ExpressionUUID->
  "80ba8dce-0c4b-46ae-84eb-60934ec6c197"],
 " is a set of universal rotations although ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "50c8af36-3285-45f6-ac35-2573291a79a6"],
 " and ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "0a3cea1b-8a85-4e3b-97d0-9c20ec346188"],
 " themselves are rotations by rational (rather than irrational) multiples of \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Pi]"}], TraditionalForm]],ExpressionUUID->
  "bc55e46d-cb71-4d2f-8a6d-80b5ddad51b6"],
 "."
}], "TechNoteText",
 CellID->2113080602,ExpressionUUID->"f08e3390-54a0-4b60-8c20-1bc85adc020a"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1081726654,ExpressionUUID->"b1f13570-af3f-481a-a69c-2d3d9eef34aa"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[271]:=",
 CellID->270370183,ExpressionUUID->"11a624e2-b085-4a5f-9380-9eccb2407c60"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[272]:=",
 CellID->36268629,ExpressionUUID->"58d40e93-9c62-4b63-9580-b29d58acaec0"],

Cell[TextData[{
 "Let us demonstrate that the Hadamard gate ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "47e338e4-6342-46c4-af85-8fa85116c6b9"],
 " and the octant phase gate ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "06e3fcd2-9da0-49c1-b106-adfbb35914dd"],
 " form a discrete set of universal rotations. We work directly in the Bloch \
space."
}], "TechNoteMathCaption",
 CellID->698295987,ExpressionUUID->"9c685c36-fc82-4de0-9788-44626d0d7000"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"set", "=", 
   RowBox[{"SparseArray", "/@", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"a", "=", 
       RowBox[{"RotationMatrix", "[", 
        RowBox[{"Pi", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "0", ",", "1"}], "}"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"RotationMatrix", "[", 
       RowBox[{
        RowBox[{"Pi", "/", "4"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], "]"}]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "/@", "set"}]}], "Input",
 CellLabel->"In[273]:=",
 CellID->1821147709,ExpressionUUID->"267499a8-6a1d-4bb7-bcc1-971031ee055d"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"0", "0", "1"},
       {"0", 
        RowBox[{"-", "1"}], "0"},
       {"1", "0", "0"}
      },
      GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.7]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}], "\[NoBreak]", ")"}],
    Function[BoxForm`e$, 
     MatrixForm[
     SparseArray[
      Automatic, {3, 3}, 0, {
       1, {{0, 1, 2, 3}, {{3}, {2}, {1}}}, {1, -1, 1}}]]]], ",", 
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        FractionBox["1", 
         SqrtBox["2"]], 
        RowBox[{"-", 
         FractionBox["1", 
          SqrtBox["2"]]}], "0"},
       {
        FractionBox["1", 
         SqrtBox["2"]], 
        FractionBox["1", 
         SqrtBox["2"]], "0"},
       {"0", "0", "1"}
      },
      GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.7]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}], "\[NoBreak]", ")"}],
    Function[BoxForm`e$, 
     MatrixForm[
     SparseArray[
      Automatic, {3, 3}, 0, {
       1, {{0, 2, 4, 5}, {{1}, {2}, {1}, {2}, {3}}}, {
        2^Rational[-1, 2], -2^Rational[-1, 2], 2^Rational[-1, 2], 2^
         Rational[-1, 2], 1}}]]]]}], "}"}]], "Output",
 CellLabel->"Out[274]=",
 CellID->1847902210,ExpressionUUID->"06d90a5c-e516-4fd5-bfc6-bf36c21700bd"]
}, Open  ]],

Cell[TextData[{
 "Choose rotations randomly from the set. Apply the rotations consecutively \
on the Bloch vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"0", ",", "0", ",", "1"}], ")"}], TraditionalForm]],
  ExpressionUUID->"cce47140-dad8-42bc-84b2-d837affe6355"],
 " corresponding to the computational basis state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "00dc7706-59d4-489f-8d48-a69b35abb1d4"],
 ", recording the result from each step. Here we take the numerical values of \
the matrices; otherwise, Mathematica(R) tries to calculate the exact numbers, \
and it takes long to handle irrational numbers."
}], "TechNoteMathCaption",
 CellID->1059830915,ExpressionUUID->"d8c1e13f-11b7-402d-808b-0278ad809703"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"mats", "=", 
   RowBox[{"RandomChoice", "[", 
    RowBox[{"set", ",", "10000"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pts", "=", 
   RowBox[{"FoldList", "[", 
    RowBox[{"Dot", ",", 
     RowBox[{"SparseArray", "@", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ",", 
     RowBox[{"N", "@", "mats"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[275]:=",
 CellID->1124969114,ExpressionUUID->"5d8af6ae-150a-4fa1-9f6a-59a9e3f9fd4d"],

Cell["\<\
Plot the points (Bloch vectors) on the Bloch sphere. Observe that the points \
gradually fill up the whole Bloch sphere.\
\>", "TechNoteMathCaption",
 CellID->980301828,ExpressionUUID->"2efd369c-01f9-4051-91b4-875ed379df00"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Graphics3D", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Red", ",", 
     RowBox[{"Point", "@", 
      RowBox[{"Normal", "@", "pts"}]}]}], "}"}], ",", 
   RowBox[{"Boxed", "->", "False"}], ",", 
   RowBox[{"SphericalRegion", "\[Rule]", "True"}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "Medium"}]}], "]"}]], "Input",
 CellLabel->"In[277]:=",
 CellID->85460531,ExpressionUUID->"8ff4c084-7cf2-4845-8934-d8f77b35df8b"],

