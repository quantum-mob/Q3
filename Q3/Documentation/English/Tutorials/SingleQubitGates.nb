Cell["For a demonstration, consider the following quantum circuit.", \
"TechNoteMathCaption",
 CellID->199930786,ExpressionUUID->"5751b1e7-b5e7-4818-aad9-3053c0894c02"],

Cell[CellGroupData[{

Cell[BoxData[
