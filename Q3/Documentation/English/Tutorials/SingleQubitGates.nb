Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", ":", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[RightTeeArrow]", 
     RowBox[{"\[ImaginaryI]", 
      TemplateBox[{"1"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "743aca11-c2d2-4008-b28d-f9854d82810f"],
 ",     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"1"},
     "Ket"], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "8794ba7a-7c8a-4f13-8464-b3ab4d3b566f"],
 "."
}], "TechNoteText",
