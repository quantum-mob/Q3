Cell[TextData[{
 "The connection of unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "\[Lambda]"], "(", "\[Phi]", ")"}], TraditionalForm]],
  ExpressionUUID->"af764b0e-b8f7-4d54-a62f-72e4b571925e"],
 " to rotation is seen more explicitly in the equivalent relation"
}], "TechNoteText",
 CellID->1061202205,ExpressionUUID->"cf53dcf0-9d12-4c8d-9e00-3de8f680bec5"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["U", "\[Lambda]"], "(", "\[Phi]", ")"}], 
     SuperscriptBox["S", "\[Nu]"], 
     RowBox[{
      SubsuperscriptBox["U", "\[Lambda]", "\[Dagger]"], "(", "\[Phi]", 
      ")"}]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "\[Lambda]"], 
     SubscriptBox[
      RowBox[{
       SuperscriptBox["S", "\[Mu]"], "[", 
       RowBox[{
        SubscriptBox["R", "\[Lambda]"], "(", "\[Phi]", ")"}], "]"}], 
      RowBox[{"\[Mu]", " ", "\[Nu]"}]]}]}], TraditionalForm]],ExpressionUUID->
  "2607d760-e59c-46ea-9de2-2f027c47e3ed"],
 " ,"
}], "TechNoteText",
 CellID->773771100,ExpressionUUID->"fd9ee6b8-fe72-4dd9-953b-5955848a5f40"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["R", "\[Lambda]"], "(", "\[Phi]", ")"}], TraditionalForm]],
  ExpressionUUID->"5ce29ec2-5c7c-4c01-b044-beb31de37598"],
 " is the 3 \[Times] 3 orthogonal matrix describing the rotation of three- \
dimensional coordinates around the \[Lambda]-axis by angle \[Phi]."
}], "TechNoteText",
 CellID->1757395115,ExpressionUUID->"df1d2e62-d345-4395-a1d7-04c17614cd8b"],

Cell[TextData[{
 "A rotations ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "z"], "(", "\[Phi]", ")"}], TraditionalForm]],
  ExpressionUUID->"53bf3864-f089-4d3b-8855-effce31d605a"],
 " around the z-axis in the Bloch space induces the relative phase difference \
\[Phi] between the two computational basis states, |0\:27e9 and |1\:27e9. In \
this sense, such rotations are called (relative) ",
 ButtonBox["phase gates",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Phase"],
 " by phase angle \[Phi]."
}], "TechNoteText",
 CellID->49616967,ExpressionUUID->"a55770ca-19e8-43e8-9809-a11df6eabb6c"],

