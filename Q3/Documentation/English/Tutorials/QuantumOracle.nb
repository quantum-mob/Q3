Cell[TextData[{
 StyleBox["Figure 5",
  FontWeight->"Bold"],
 ". A quantum circuit to induces conditional phase shifts depending on \
function value ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "333dc4e9-40b8-419b-944e-b89de15512ac"],
 " at input value ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["x", "1"], ",", 
      SubscriptBox["x", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["x", "n"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "7f5c9918-0a5a-48a4-a6e4-5f7720e73556"],
 "."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->1188295865,ExpressionUUID->"5358c5b5-c625-4579-b42e-5711686d41b0"],

Cell[TextData[{
 "\tThe above feature is widely used in various quantum algorithms including \
the ",
 ButtonBox["Deutsch-Jozsa algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/DeutschJozsaAlgorithm"],
 ", ",
 ButtonBox["Bernstein-Vazirani algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BernsteinVaziraniAlgorithm"],
 ", ",
 ButtonBox["Simon's algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/SimonAlgorithm"],
 ", and ",
 ButtonBox["quantum search algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumSearchAlgorithm"],
 ". It is also possible to construct more  general conditional phase shifts."
}], "TechNoteText",
 CellID->1765281707,ExpressionUUID->"a8f14f03-8633-40a2-8a32-b91294ccce3f"]
}, Open  ]]
}, Open  ]],

