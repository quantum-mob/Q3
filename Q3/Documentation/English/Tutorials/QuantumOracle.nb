Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". A circuit diagram of classical oracle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "m"], "\[RightArrow]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"8fec39e6-0901-4089-adac-3584e133c395"],
 ". ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "2c90c399-94f7-459f-b11c-b4dd0bc05136"],
 " is an ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "4325736a-9a4a-4a28-9f62-5835362f278f"],
 "-bit string (",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], "m"]}], TraditionalForm]],
  ExpressionUUID->"df01ca89-8c07-44f6-be7a-1d8b4dc5406e"],
 "), and ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "4d246a88-996c-45e3-b931-c4f1c984ad7c"],
 " denotes the image of function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "5767baf7-c579-4fda-827d-5b84af390f77"],
 " at ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "a9a3ddc7-4b53-44bb-87e8-67ff6a429f53"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", 
    RowBox[{
     RowBox[{"f", "(", "x", ")"}], "\[Element]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"d96cf081-918e-4240-9da3-7d676b5e6191"],
 ")."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->1881272299,ExpressionUUID->"30d800af-a9e7-41f6-916b-370d1c9d0dfa"],

Cell[TextData[{
 "\tGiven a classical oracle ",
 StyleBox["f",
  FontSlant->"Italic"],
 ", a proper quantum implementation should operate on qubits and allow \
superposition in the input states. One naive approach is to define an \
operator ",
 Cell[BoxData[
  FormBox["O", TraditionalForm]],ExpressionUUID->
  "c7fc3a2e-b690-4867-9b72-b5f2a620bca0"],
 " by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"O", 
     TemplateBox[{"x"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"f", "(", "x", ")"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "fb0f95f4-ce8d-4a57-a373-a686f054656a"],
 " for any state in the computational basis of the ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "966e9d0f-238e-4b18-a912-42d4bf74adc7"],
 "-qubit register. This would not work because, as mentioned above, the \
function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "c0e3d122-15ed-4eac-a2db-211e45c985ad"],
 " is not invertible in general, and hence operator ",
 Cell[BoxData[
  FormBox["O", TraditionalForm]],ExpressionUUID->
  "f53df4f7-3d98-4007-b215-d0b1504a5358"],
 " cannot be unitary."
}], "TechNoteText",
 CellID->372455258,ExpressionUUID->"f2caae55-3a31-47b6-83b5-dfd867952f5c"],

Cell[TextData[{
 "\tTo overcome such an issue, first extend the mapping ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "7cbaff38-54d7-40bd-8860-cd7f80f02ae5"],
 " by adding an auxiliary register of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "0ff7aa7a-2233-4af2-af63-1fdc225b24e8"],
 " bits to the native register and keeping the original input value so that \
both the input and output registers have ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"m", "+", "n"}], ")"}], TraditionalForm]],ExpressionUUID->
  "5fce2368-dcd7-4342-9612-237b2ebda87d"],
 " bits. An extended mapping, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], 
     RowBox[{"m", "+", "n"}]], "\[RightArrow]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], 
     RowBox[{"m", "+", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "e63af3df-b879-4653-9d1b-a5b987260fb1"],
 ", is then defined by the association (see ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle#217811558"],
 ")"
}], "TechNoteText",
 CellID->2088173848,ExpressionUUID->"8384af12-9f02-4381-8209-265c75db8ba5"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"x", ",", "y"}], ")"}], "\[RightTeeArrow]", 
    RowBox[{"(", 
     RowBox[{"x", ",", 
      RowBox[{
       RowBox[{"f", "(", "x", ")"}], "\[CirclePlus]", "y"}]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"234956f8-d0b7-4e74-9e9f-a111d3c355ea"],
 " ,"
}], "DisplayMath",
 CellID->1760104062,ExpressionUUID->"55c894bc-8c6d-404e-8015-cc96bd8459d1"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}], "m"]}], TraditionalForm]],
  ExpressionUUID->"c6d2765a-42a6-4c69-97b4-b07a1a75c53a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}], "n"]}], TraditionalForm]],
  ExpressionUUID->"9eab5710-c4fc-4a5c-aa22-7ca18d27ecdc"],
 " are bit strings of the ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "2b0ad5bc-8495-45a5-8251-236ed29d8bdf"],
 "-bit native register and the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "1fd2be7c-37be-4356-9118-0c1f2ed6ea50"],
 "-bit auxiliary register, respectively."
}], "TechNoteText",
 CellID->481732609,ExpressionUUID->"343e647b-bcaf-4ee7-9450-f2e9b5bf0e7e"],

