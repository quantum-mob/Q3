Cell[CellGroupData[{

Cell["Conditional Phase Shifts", "Subsection",
 CellID->1627050678,ExpressionUUID->"16b46cec-479e-4ad8-af0e-fad7969fa5d3"],

Cell[TextData[{
 "This is an interesting twist of quantum oracle and provides a way to \
implement the phase shifts conditioned on a given function ",
 StyleBox["f",
  FontSlant->"Italic"],
 ". It is useful, for example, in the ",
 ButtonBox["Deutsch-Jozsa algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/DeutschJozsaAlgorithm"],
 ", ",
 ButtonBox["Bernstein-Vazirani algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BernsteinVaziraniAlgorithm"],
 ", and ",
 ButtonBox["quantum search algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumSearchAlgorithm"],
 "."
}], "TechNoteText",
 CellID->1634318849,ExpressionUUID->"48c7e448-c5bf-4870-ae7d-125ff87d8bf0"],

Cell[TextData[{
 "The classical oracle mark the solutions, ",
 StyleBox["{0,0}=1", "Input"],
 " and {",
 StyleBox["1,1}=1", "Input"],
 " in this particular case:"
}], "TechNoteMathCaption",
 CellID->1681050013,ExpressionUUID->"7954a244-9eab-4666-96c7-c57c4e65ad5b"],

