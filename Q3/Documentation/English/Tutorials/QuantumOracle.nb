Cell[CellGroupData[{

Cell["Copying the Image of a Function", "Subsection",
 CellID->1390583845,ExpressionUUID->"fafa5be0-d852-4ab4-94a2-3f91322fce36"],

Cell["\<\
Here is demonstrate the feature of quantum oracle that makes a copy of the \
image f(x) of the native register to the ancillary qubit.\
\>", "TechNoteText",
