   0.025]]],ExpressionUUID->"ebc8dd2f-003e-488e-882b-390e31a36f73"]], \
"Picture",
 TextAlignment->-0.5,
 CellID->653061625,ExpressionUUID->"2f8f0916-6d95-4fd4-a48e-0112e4fdc53a"],

Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ". A reversible version of classical oracle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "m"], "\[RightArrow]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"d057d6b9-a7f3-4bc0-ab5e-2169ccebf819"],
 ".  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], "m"]}], TraditionalForm]],
  ExpressionUUID->"6a87653e-7873-4864-8639-43033756a69f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], "n"]}], TraditionalForm]],
  ExpressionUUID->"4823e9d8-1ee3-4a84-9608-8f5f8bcf2d0c"],
 " are ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "42ba77ef-e7de-4c86-a882-1ab4b21a36f6"],
 "-bit and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ae02f0ee-740b-4594-9f5c-a8ada052cda1"],
 "-bit strings, respectively, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", 
    RowBox[{
     RowBox[{"f", "(", "x", ")"}], "\[Element]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"4aa90813-edd3-4fda-9120-1d4de248d089"],
 " denotes the image of ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "cf615d36-f7e9-4336-a185-12b38995ff19"],
 " at ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "ea5bd6ac-4a63-41fc-b40c-c33a1f6ff638"],
 "."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->217811558,ExpressionUUID->"fe87f0b9-662e-4103-b48f-60b7642ae2c2"],

Cell[TextData[{
 "\tAlthough the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "f1f799e8-3f13-42cf-8760-0c3a10859bfa"],
 " itself may not be invertible, the extended mapping above  is always \
one-to-one regardless of the function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "f4315771-d850-4c3d-b40a-1c7783b10df3"],
 ". Due to this property, the extended mapping  is widely used to convert a \
classical code to a form that is suitable for (classical) ",
 StyleBox["reversible computation",
  FontSlant->"Italic"],
 ". (For a complete reversible computation, there is another important step \
required to remove the \[OpenCurlyDoubleQuote]garbage\[CloseCurlyDoubleQuote] \
bits.)"
}], "TechNoteText",
 CellID->433572556,ExpressionUUID->"b031d8f4-6451-4c2a-9013-2059b9efeb75"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum Oracle", "TechNoteSection",
 CellID->466610273,ExpressionUUID->"e04e448f-81f8-4411-8d2a-09b36dd7602d"],

Cell[CellGroupData[{

Cell["Definition", "Subsection",
 CellID->803706057,ExpressionUUID->"7bd9d193-c918-4952-8f0a-975e7981fa1f"],

Cell["\<\
The quantum oracle corresponding to the classical oracle f is simply an \
implementation of the above extended mapping for reversible computation on \
quantum registers. It is a quantum gate operation defined by the association\
\>", "TechNoteText",
 CellID->1856063114,ExpressionUUID->"571d1279-95a9-4432-b801-36fcd8f8ff37"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "f"], ":", 
    RowBox[{
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"y"},
       "Ket"]}], "\[RightTeeArrow]", 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{
          RowBox[{"f", "(", "x", ")"}], "\[CirclePlus]", "y"}]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "2f37153a-8edf-4014-9485-258052cd1ac7"],
 " ,"
}], "DisplayMath",
 CellID->505300676,ExpressionUUID->"634a53c1-a86a-462b-a1f0-bd5895bf7da0"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"x"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "c4e863a3-5b42-464a-8a08-833046f3237f"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"y"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2185e225-e0d0-4340-a2e3-f94e33688d6b"],
 " are the computational basis states belonging to the native and auxiliary \
register of ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "6535226c-d277-4af8-b4e9-ae5c165e01a1"],
 " and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "2a0e48a9-62e1-4400-82a9-b380ad10657f"],
 " qubits, respectively. The values of the auxiliary qubits are flipped \
conditionally depending on the function value ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "109b26fa-bf9c-45cd-96bd-7cb28da2a8ed"],
 " at the corresponding bit value ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "8d8675cd-3926-43ce-8a58-5c324ac05d64"],
 " of the native qubits. In quantum circuit model, a quantum oracle is \
depicted diagrammatically as shown in ",
 ButtonBox["Figure 3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle#1860942115"],
 ". Since the extended mapping is one-to-one and the computational basis \
states are orthonormal, the operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "f"], TraditionalForm]],ExpressionUUID->
  "c2e890df-6d88-4ba8-8af1-95742451e636"],
 " is unitary. Recall that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "f"], TraditionalForm]],ExpressionUUID->
  "e0ff3492-4b43-4a3c-ae2c-7e01e79b8a06"],
 " is a linear operator and can act on any arbitrary superposition states."
}], "TechNoteText",
 CellID->1438121294,ExpressionUUID->"65547dfc-5e60-49d5-bd3a-43a7e0b30424"],

