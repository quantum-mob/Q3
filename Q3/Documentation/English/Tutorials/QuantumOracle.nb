Cell[TextData[{
 StyleBox["Figure 4",
  FontWeight->"Bold"],
 ". ",
 StyleBox["(left)",
  FontWeight->"Bold"],
 " A quantum circuit demonstrating the feature ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"f", "(", "x", ")"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "dced771a-a02c-410f-bb9c-3af4f10acf3e"],
 " of the quantum oracle corresponding to classical oracle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "m"], "\[RightArrow]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"3c47b227-ce09-429e-a262-c8b0b0586f5d"],
 ". ",
 StyleBox["(right)",
  FontWeight->"Bold"],
 " A quantum circuit demonstrating the feature ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"x"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "2a362a89-2735-4cac-ba2c-7c27b97a1a5c"],
 " of the CNOT gates."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->875137908,ExpressionUUID->"59c22b1e-6df6-4732-aea1-3089ad5f1b6d"],

Cell["\<\
\tFurthermore, suppose that a native quantum register is in the superposition\
\
\>", "TechNoteText",
 CellID->885337575,ExpressionUUID->"8616995b-1274-4bbf-b397-b6092fa704a9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["1", 
     SuperscriptBox["2", 
      RowBox[{"m", "/", "2"}]]], 
    UnderoverscriptBox["\[CapitalSigma]", 
     RowBox[{"x", "=", "0"}], 
     RowBox[{
      SuperscriptBox["2", "m"], "-", "1"}]], 
    TemplateBox[{"x"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "5d2596be-1608-4054-a99f-daa66d3797d6"]
}], "TechNoteText",
 CellID->410472809,ExpressionUUID->"31e4eaa8-d5df-48cf-a051-5713bfa2707d"],

Cell[TextData[{
 "and the ancillary quantum register in in the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], "\[Congruent]", 
    SuperscriptBox[
     TemplateBox[{"0"},
      "Ket"], 
     RowBox[{"\[CircleTimes]", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "5d456af2-9c35-4615-8778-3d4abb84c8d3"],
 ". The quantum oracle transforms the state as"
}], "TechNoteText",
 CellID->1227539147,ExpressionUUID->"1f7a26b3-b80f-4c1b-9835-88f46d6fa488"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"m", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "m"], "-", "1"}]], 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}]}], "\[RightTeeArrow]", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"m", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "m"], "-", "1"}]], 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"f", "(", "x", ")"}]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "97b69cb1-2f73-434a-a978-4c7d83b1e747"]
}], "TechNoteText",
 CellID->1451594267,ExpressionUUID->"5ca8b507-8065-4c71-8c99-81da363bcc42"],

Cell[TextData[{
 "Just like the CNOT gate, the above state from the quantum oracle is also \
entangled in general unless ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "6e2f931c-41d7-4a31-b41c-deccd199b5c1"],
 " is a constant or very special function. In this case, the entanglement is \
controlled by the (classical) oracle ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "8fde20ad-69ab-44c2-a51b-d183030ffec4"],
 "."
}], "TechNoteText",
 CellID->2079018916,ExpressionUUID->"56b049bc-2870-423f-8bcf-030a69723523"],

Cell[TextData[{
 "\tRecall that the controlled-unitary gate induces a phase shift on the \
control register (rather than on the target register) when the target \
register is in an eigenstate of the unitary operator. A similar method can be \
used to induce a phase shift conditionally on every term that satisfies a \
certain condition. For example, let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "1"}], "}"}], "n"], "\[RightArrow]", 
     RowBox[{"{", 
      RowBox[{"0", ",", " ", "1"}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"5ade2c0e-497e-4258-86d8-f8a613b5d3ba"],
 " be a classical oracle, and suppose that we are given a state"
}], "TechNoteText",
 CellID->1947437576,ExpressionUUID->"c95f24d9-b748-4edb-9587-8fc2601d417e"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[{"\[Psi]"},
    "Ket"], "=", 
   RowBox[{
    UnderoverscriptBox["\[CapitalSigma]", 
     RowBox[{"x", "=", "0"}], 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]], 
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], 
     SubscriptBox["\[Psi]", "x"]}]}]}], 
  TraditionalForm]],ExpressionUUID->"978577cc-f78e-4091-ac33-fe86c4da1014"]], \
"DisplayMath",
 CellID->785075905,ExpressionUUID->"3b6bb3a4-1787-4891-b34d-749fb053b377"],

Cell[TextData[{
 "on an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "0c099fdc-bdd2-4262-bda7-b7cc41bdb891"],
 "-qubit register. We want to get a new state where every term ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"x"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "bc5205f5-64c5-4515-a1d3-acab42a4602b"],
 " satisfying ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"08f2e9af-8114-43cb-aea7-0381649721ee"],
 " flips its amplitude ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Psi]", "x"], TraditionalForm]],ExpressionUUID->
  "7e77af51-bb9a-4bba-bcf6-19dea96f3569"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", 
    SubscriptBox["\[Psi]", "x"]}], TraditionalForm]],ExpressionUUID->
  "17c3826b-0bd6-4bce-a388-57c50dc373bc"]
}], "TechNoteText",
 CellID->631208167,ExpressionUUID->"0732d0b2-1d9c-48ec-b8d5-1610ceee3923"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SuperscriptBox["\[Psi]", "\[Prime]"]},
     "Ket"], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"x"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"f", "(", "x", ")"}]], 
     SubscriptBox["\[Psi]", "x"]}]}], TraditionalForm]],ExpressionUUID->
  "ed38b9c6-82c3-4278-9672-7ca02bf5ea34"],
 " ."
}], "DisplayMath",
 CellID->146446589,ExpressionUUID->"fa888163-be6c-4568-ae1c-650c1c2d4681"],

Cell["\<\
In other words, we want an effective quantum gate that maps the computational \
basis states as\
\>", "TechNoteText",
 CellID->311561861,ExpressionUUID->"b8b14ded-09e4-4361-bbac-fe695d28f495"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[{"x"},
    "Ket"], "\[RightTeeArrow]", 
   SuperscriptBox[
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "(", 
     RowBox[{"-", "1"}], ")"}], 
    RowBox[{"f", "(", "x", ")"}]]}], 
  TraditionalForm]],ExpressionUUID->"c71f5636-3b0e-4d26-adc9-d4adf21f5cfd"]], \
"DisplayMath",
 CellID->855066441,ExpressionUUID->"450f7bb3-256b-4966-98a0-c95a1dd68749"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{
     SuperscriptBox["2", "n"], "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "dbda79f1-8deb-476e-bdcc-51b3679ff481"],
 ". This can be achieved using the quantum oracle corresponding to the \
function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "40fa7fe0-2c4f-4c34-b834-13db6468af73"],
 " and preparing an auxiliary qubit in the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"-"},
     "Ket"], ":=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "-", 
      TemplateBox[{"1"},
       "Ket"]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "e42b1c44-0c18-4938-85c2-a2a40618ca39"],
 ", the eigenstate of the Pauli X operator belonging to the eigenvalue ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Minus]", "1"}], TraditionalForm]],ExpressionUUID->
  "26ab77b6-b4be-436e-aad6-a6e4243ece0f"],
 ", as depicted in the quantum circuit in ",
 ButtonBox["Figure 5",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle#1188295865"],
 ". Indeed, for a computational state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"x"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6b7e0eb1-5e27-4074-85e1-b6e231b367be"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"4a8b7b5e-cf88-4d00-bfe6-438043723d4a"],
 ","
}], "TechNoteText",
 CellID->141108163,ExpressionUUID->"d305fb4c-16dd-4795-b756-f9c8ba97af57"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"-"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{
         TemplateBox[{"x"},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{"0"},
          "Ket"]}], "-", 
        RowBox[{
         TemplateBox[{"x"},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{"1"},
          "Ket"]}]}], 
       SqrtBox["2"]], "\[RightTeeArrow]", 
      FractionBox[
       RowBox[{
        RowBox[{
         TemplateBox[{"x"},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{"1"},
          "Ket"]}], "-", 
        RowBox[{
         TemplateBox[{"x"},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{"0"},
          "Ket"]}]}], 
       SqrtBox["2"]]}], "=", 
     RowBox[{
      RowBox[{"-", 
       TemplateBox[{"x"},
        "Ket"]}], "\[CircleTimes]", 
      TemplateBox[{"-"},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "8697b7f1-3b14-4754-933e-d0c88cc4208c"],
 " ,"
}], "DisplayMath",
 CellID->2078687433,ExpressionUUID->"f1fc81a0-c387-4b80-a541-06f491a72aa0"],

Cell[TextData[{
 "while nothing happens for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"x"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "dbb2808c-849f-4104-9ef8-a19d58867b2f"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"f47a524d-caf5-467b-ba59-0b246ac847b9"],
 "."
}], "TechNoteText",
 CellID->1235717035,ExpressionUUID->"b8af13c5-5267-4f95-998c-c3af873b31e8"],

