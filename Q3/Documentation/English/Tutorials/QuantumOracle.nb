Cell[CellGroupData[{

Cell["Classical Oracle", "TechNoteSection",
 CellID->2114503066,ExpressionUUID->"8dbf2e01-3e36-487d-91a8-41bfa2456264"],

Cell[TextData[{
 "An oracle (more specifically, ",
 StyleBox["classical oracle",
  FontSlant->"Italic"],
 ", to be distinguished from quantum oracle) is typically described by a \
binary function"
}], "TechNoteText",
 CellID->1893639706,ExpressionUUID->"f2162d0d-2d02-4105-b82e-21ba7eb8f8fa"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "m"], "\[RightArrow]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"2ea44262-4e0a-4e6c-9d61-6e26922fa311"],
 ","
}], "DisplayMath",
 CellID->694890202,ExpressionUUID->"28bcc5db-38eb-47bf-a805-576b9d7d4721"],

Cell[TextData[{
 "that maps an ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "944fdfa4-8481-4ad1-b3f2-ff509014f406"],
 "-bit input to an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "2098d0d6-a8a5-45c2-ab21-e836b90c8269"],
 "-bit output, and is depicted diagrammatically  in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle#1881272299"],
 ". The query model of computation is to solve a problem on an unknown \
function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "adf0b1dd-214e-4478-adb2-d3726420d065"],
 ", and the oracle is the key entity of the model. Bear in mind that the \
function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "5a23c24b-c472-4c95-903e-8b3a6e1de73c"],
 " may not be invertible in general."
}], "TechNoteText",
 CellID->1003552628,ExpressionUUID->"c59c12fc-5295-4e78-a223-4e3c5590c63e"],

