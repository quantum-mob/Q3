Cell[TextData[{
 StyleBox["Figure 3",
  FontWeight->"Bold"],
 ". A quantum circuit for the quantum oracle corresponding to classical \
oracle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "m"], "\[RightArrow]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"ec0148cb-b93c-442b-a83d-72a8d0991c77"],
 "., which is a direct analogue of the classical reversible oracle in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle#217811558"],
 ".  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[Element]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], "m"]}], TraditionalForm]],
  ExpressionUUID->"d9d60697-9581-4f41-a909-1bc525f1e60d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[Element]", 
    SuperscriptBox[
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], "n"]}], TraditionalForm]],
  ExpressionUUID->"0bbc3a6b-0cb5-41e7-a0c2-263df00bce39"],
 " is ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "2764fe8e-a7ec-46f4-82fc-897f065c0486"],
 "-bit and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e68e08dc-0910-4f0c-a981-3b4bf20d1e1d"],
 "-bit strings, respectively, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", 
    RowBox[{
     RowBox[{"f", "(", "x", ")"}], "\[Element]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"c0449082-ab73-46e8-ba45-712d5bc95026"],
 " denotes the image of ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "1faa3364-4edb-42de-a114-3a73f255db83"],
 " at ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "613379fd-74d5-4bb9-a4fc-6efcb524756e"],
 "."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->1860942115,ExpressionUUID->"669107f4-55df-46b8-8190-cb4c0130171e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Properties", "Subsection",
 CellID->634708948,ExpressionUUID->"cf0fe343-623a-4eb4-b18b-5e01fa4e0e54"],

Cell[TextData[{
 "There are several interesting features of a quantum oracle that can be \
immediately noticed from the definition above. We note that the CNOT gate \
makes a copy of the computational basis state of the control register to the \
target register when the latter has been prepared initially in the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6b33412e-5dbe-4c1b-9604-896a370c8385"],
 ", "
}], "TechNoteText",
 CellID->1025596588,ExpressionUUID->"dcf8378b-100b-4a69-9c1e-a118c5192cb2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"x"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "bb9088f2-f7ab-4a90-9ec4-66b0f0077ceb"],
 "."
}], "TechNoteText",
 CellID->1669789983,ExpressionUUID->"8386a541-1c74-4349-b596-e11b417e5f0b"],

Cell[TextData[{
 "This property illustrated in ",
 ButtonBox["Figure 3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle#875137908"],
 " (right) is exploited in many applications, especially to generate \
entanglement."
}], "TechNoteText",
 CellID->1001387130,ExpressionUUID->"14f86617-63a2-46a2-b729-e1db8207183e"],

Cell[TextData[{
 "\tThe quantum oracle has a similar property, but it makes a copy of the \
image ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"f", "(", "x", ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "27fa3e6f-6594-4ecc-be78-76f842515698"],
 " rather than the input state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"x"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "dffc4a25-3984-4087-9895-1f8beb5b1098"],
 " itself of the native register to the ancillary register,"
}], "TechNoteText",
 CellID->1014164132,ExpressionUUID->"acc318ac-16a9-47d7-8229-ab22fde062eb"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"f", "(", "x", ")"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "4dc4cc32-d43f-46f9-aca4-5e5d6fd0879d"],
 "."
}], "TechNoteText",
 CellID->1559827404,ExpressionUUID->"92934298-fa33-4d38-ab14-b28f766cd15e"],

Cell[TextData[{
 "This is demonstrated in  in ",
 ButtonBox["Figure 4",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle#875137908"],
 " (left)."
}], "TechNoteText",
 CellID->300784034,ExpressionUUID->"6a5ee5c2-4b62-429a-9ce7-ae0243905388"],

