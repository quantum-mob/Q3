Cell[CellGroupData[{

Cell["Error-Correction Conditions", "TechNoteSection",
 CellTags->"Section11",
 CellID->800049997,ExpressionUUID->"4c3c1b87-c94a-4f71-b414-3261bdc385b5"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "1fb7b865-414c-4c4a-861b-ca3892326ed2"],
 " be the stabilizer of a code space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "c5d675e8-0d0b-44f8-91cf-727901bca4f2"],
 ". Suppose that \[ScriptCapitalV] is corrupted by an error operator ",
 Cell[BoxData[
  FormBox["E", TraditionalForm]],ExpressionUUID->
  "38afbc36-f02c-476f-865b-8ce0f1d973db"],
 " in the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"6560db71-7fd4-4438-9b11-eaa556d61a46"],
 ". What would happen to the code space? There are three distinctive cases:"
}], "TechNoteText",
 CellID->1045185712,ExpressionUUID->"25949822-c5ca-460a-a3b6-ce720beeda72"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["E", TraditionalForm]],ExpressionUUID->
  "e81f6d3d-fb0b-4609-b916-aa797dbec54e"],
 " anti-commutes with one of the generators, say ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "dce0ddc5-444d-4360-b372-d6a71db29a2e"],
 ", of the stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "a798654c-d8fe-425a-9763-4d94a32823cc"],
 ". In this case, ",
 Cell[BoxData[
  FormBox["E", TraditionalForm]],ExpressionUUID->
  "2599fddb-ed16-4320-b972-d87d2d3d3b94"],
 " takes the code space \[ScriptCapitalV] to a subspace orthogonal to \
\[ScriptCapitalV] (see the Quantum Workbook for a proof). Therefore, in this \
case, one can detect the error with proper measurement (see below), and \
correct it. "
}], "Item",
 CellID->20029124,ExpressionUUID->"c1719c24-e94c-42ac-9b93-441c5305ce8b"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["E", TraditionalForm]],ExpressionUUID->
  "c602b38e-2433-4beb-89e7-9de06dd0df25"],
 " belongs to the stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "08040d7b-a368-46f3-a744-e6bdbe65c9c0"],
 ". In this case, ",
 Cell[BoxData[
  FormBox["E", TraditionalForm]],ExpressionUUID->
  "26b15a9a-747e-4f10-af6f-84fc76bbe9c3"],
 " itself stabilizes the code space, and the code space remains intact \
without any corruption."
}], "Item",
 CellID->1622038136,ExpressionUUID->"fc7f86d8-09c0-4e0e-88ee-a6309f319bea"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox["E", TraditionalForm]],ExpressionUUID->
  "eb3ce56b-a05c-428d-a218-fe4d60e731de"],
 " commutes with all all elements of the stabilizer, but does not belong to \
the stabilizer. This is the most dangerous case. According to ",
 ButtonBox["stabilizer formalism",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/StabilizerFormalism"],
 " of measurement, measurement of such an operator ",
 Cell[BoxData[
  FormBox["E", TraditionalForm]],ExpressionUUID->
  "e30bdc35-a8e6-45ad-87e4-1abba7361634"],
 " would reveal some information of the quantum states in the code space. \
This implies that ",
 Cell[BoxData[
  FormBox["E", TraditionalForm]],ExpressionUUID->
  "7d94d18c-2d8d-47ab-81c2-a1a427f6dbda"],
 " breaks the code space, and the corruption cannot be corrected."
}], "Item",
 CellID->1437536734,ExpressionUUID->"c60958f3-94c7-410e-b84b-ccbe02ad7b8d"],

Cell["\<\
The above observation implies the following proposition on the \
error-correction conditions of stabilizer codes.\
\>", "TechNoteText",
 CellID->1488859588,ExpressionUUID->"346c0da3-d3b8-43c7-876d-ea1159d4eb93"],

Cell[TextData[{
 StyleBox["Proposition",
  FontWeight->"Bold"],
 ": Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "7fab01e5-5d13-48bc-84c4-b21ab1efb262"],
 " be the stabilizer of a code space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "b4e0e6d2-aacf-455e-a0fa-d5c9ab8cf695"],
 ". Suppose that the errors are described by a set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["E", "\[Mu]"], "}"}], TraditionalForm]],ExpressionUUID->
  "ffc35f3f-4ede-4899-8036-96403a273efc"],
 " of operators in the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"0c19bf6f-b1e6-42bf-a5fb-e15edda64b9e"],
 ". The necessary and sufficient condition for the code to correct the errors \
is that for all \[Mu] and \[Nu], ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"], 
    SubscriptBox["E", "\[Nu]"]}], TraditionalForm]],ExpressionUUID->
  "1b1085f4-34d3-4d71-80b0-3bc2e4c28584"],
 " either belongs to ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "0698a032-3156-41ae-ad28-bb5d4c1e9133"],
 " or anti-commutes with at least one generator of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "b57b9a16-5068-417e-b2ad-d573ded638d1"],
 "."
}], "TechNoteText",
 CellID->783640672,ExpressionUUID->"0c6f6ddd-8829-414e-830f-62bfaa910f31"],

Cell["\<\
Remember that the identity operator is always one of the error operators and \
thus the condition includes the above observation.\
\>", "TechNoteText",
 CellID->131567253,ExpressionUUID->"98cc81a5-a5c9-4891-aff9-c2ddb1ffd17b"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Error-Syndrome Detection and Recovery", "TechNoteSection",
 CellTags->"Section12",
 CellID->1490148408,ExpressionUUID->"66980ae0-e558-4653-9e23-5799f670e808"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["G", "1"], ",", 
     SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["G", "k"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "255d8f7e-5c6f-411c-94b0-574b8bc078c8"],
 " be a set of independent generators of the stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "20bf9f40-a24f-43e7-b884-917cf6053caa"],
 ". Suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["E", "\[Mu]"], "}"}], TraditionalForm]],ExpressionUUID->
  "9000ccae-b519-473e-9616-192e9e7f4aca"],
 " is the set of error operators that are correctable by the code."
}], "TechNoteText",
 CellID->970001942,ExpressionUUID->"ed7524f8-0e4a-4e44-812e-3a2581d24bc9"],

Cell[CellGroupData[{

Cell["Error Syndrome", "Subsection",
 CellTags->"Section13",
 CellID->1274274817,ExpressionUUID->"90dcc59c-6267-48b3-9144-48687a53c88f"],

Cell[TextData[{
 "The first step is to detect error syndrome. This is achieved by measuring \
the generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "1"], ",", 
    SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["G", "k"]}], TraditionalForm]],ExpressionUUID->
  "1e3f7c2d-21d2-41d2-a9bc-f116ba8b7070"],
 ". Each outcome ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "bc1fe41e-6ba5-4910-9101-4113b58b30ac"],
 " serves as a symptom of the errors. If an error ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["E", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "c79c9b1c-0e5b-4303-96a9-9d6c333a2b39"],
 " occurs, then it causes a syndrome ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Epsilon]", "\[Mu]"], ":=", 
    RowBox[{"(", 
     RowBox[{
      SubsuperscriptBox["\[Epsilon]", "1", "\[Mu]"], ",", 
      SubsuperscriptBox["\[Epsilon]", "2", "\[Mu]"], ",", "\[Ellipsis]", ",", 
      
      SubsuperscriptBox["\[Epsilon]", "k", "\[Mu]"]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"e1e1d76b-4df5-49ab-8def-03fde7e5ce54"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Epsilon]", "j", "\[Mu]"], "=", 
    RowBox[{"\[PlusMinus]", "1"}]}], TraditionalForm]],ExpressionUUID->
  "02276d94-6f74-4bb3-9f28-f8af7502c9d4"],
 ". The error and the syndrome are related by"
}], "TechNoteText",
 CellID->2029921435,ExpressionUUID->"fa671f59-69d7-4f60-9d81-1c3a62569a0e"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["E", "\[Mu]"], 
     SubscriptBox["G", "j"], 
     SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"]}], "=", 
    RowBox[{
     SubsuperscriptBox["\[Epsilon]", "j", "\[Mu]"], 
     SubscriptBox["G", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "03788403-9a96-45c1-9616-1e96f545f776"],
 "."
}], "DisplayMath",
 CellID->1964341803,ExpressionUUID->"dc243f42-5192-4839-a45f-2cae1f5bdf99"],

Cell[TextData[{
 "In short, detecting error-syndrome ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Epsilon]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "3d65de51-7383-43c8-8e96-3862c4028def"],
 " by measurement of the generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "1"], ",", 
    SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["G", "k"]}], TraditionalForm]],ExpressionUUID->
  "e5542b19-2752-4023-916a-c289693bcd35"],
 " enables one to identify the associated error ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "2280e24b-66e6-4b66-bd9e-fcfd60912532"],
 "."
}], "TechNoteText",
 CellID->1426577690,ExpressionUUID->"b3b59288-f153-47b0-955c-6070dd33b6fb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Recovery", "Subsection",
 CellTags->"Section14",
 CellID->1983800722,ExpressionUUID->"9c679b51-bea0-4266-9edc-9fb3eb248f10"],

Cell[TextData[{
 "When a syndrome ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Epsilon]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "0c429a63-48e3-4107-9d39-e1d3dfa2bac2"],
 " is associated with a single error ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "f890742b-abd0-43eb-abba-c0cd6c59d633"],
 ", one can correct it simply by applying ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"], TraditionalForm]],
  ExpressionUUID->"f189417f-a325-470b-b369-e1834b481508"],
 "."
}], "TechNoteText",
 CellID->2055114979,ExpressionUUID->"dca5a5ce-bbab-49c7-b16d-d0ffacd72b58"],

Cell[TextData[{
 "However, in general, two different errors ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "8612ffb5-161c-48b0-91f1-a76f8017577d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "4e32015b-9144-4236-b453-63088b27bc15"],
 " may cause the same syndrome, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Epsilon]", "\[Mu]"], "=", 
    SuperscriptBox["\[Epsilon]", "\[Nu]"]}], TraditionalForm]],ExpressionUUID->
  "54462d55-28ad-4b4f-a959-c22d12b4b32f"],
 ". In this case, we have"
}], "TechNoteText",
 CellID->190473705,ExpressionUUID->"f994ae80-2f41-4937-b3f4-20f2f1090933"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["E", "\[Mu]"], "P", " ", 
     SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"]}], "=", 
    RowBox[{
     SubscriptBox["E", "\[Nu]"], "P", " ", 
     SubsuperscriptBox["E", "\[Nu]", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"e017e67f-693e-4a25-82bb-50d201767f11"],
 ","
}], "DisplayMath",
 CellID->1540925905,ExpressionUUID->"f0137cc2-b3db-48e2-a3cf-03dc88fcbe5c"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "977892a4-92cf-4e04-be19-e9dadc11fad4"],
 " is the projection onto the code space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "66e63e6a-1159-4343-98e8-6f29572eace2"],
 ". This leads to"
}], "TechNoteText",
 CellID->1836386162,ExpressionUUID->"ffb91689-213d-4be8-825a-ee10c880125e"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"], 
       SubscriptBox["E", "\[Nu]"]}], ")"}], "P", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"], 
        SubscriptBox["E", "\[Nu]"]}], ")"}], "\[Dagger]"]}], "=", "P"}], 
   TraditionalForm]],ExpressionUUID->"1b5c33b5-a393-4cda-9fb5-0cc785f852ad"],
 " ."
}], "DisplayMath",
 CellID->507250050,ExpressionUUID->"6b114362-f7b6-4833-b701-e41bc042bf80"],

Cell[TextData[{
 "This means that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"], 
    SubscriptBox["E", "\[Nu]"]}], TraditionalForm]],ExpressionUUID->
  "7e0c0860-75d7-4056-b12a-f031ac374b5c"],
 " is a member of the stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "3a574e53-c0ad-4ed1-98a4-4dd5a6522f4b"],
 ". In other words, even if it was the error ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "6a0c0239-2772-4cc9-a888-2113fdf1b732"],
 " that actually occurred, it can still be corrected by applying ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"], TraditionalForm]],
  ExpressionUUID->"18bacb24-9154-4528-81ef-1a9cbb5c6ce8"],
 "."
}], "TechNoteText",
 CellID->1988995407,ExpressionUUID->"dcaa2088-153f-485b-9250-b76b9f6fb40f"],

Cell[TextData[{
 "In short, however many errors are associated with a given syndrome, one can \
choose any operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "18dfbef3-b62e-4dc0-a99c-79491887a536"],
 " among them to apply ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["E", "\[Mu]", "\[Dagger]"], TraditionalForm]],
  ExpressionUUID->"66cc5caf-7279-44e0-b380-1bff7962706f"],
 " to recover the original state."
}], "TechNoteText",
 CellID->1315356247,ExpressionUUID->"b8416b98-4c8b-4d8a-8965-8352894747bd"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Encoding", "TechNoteSection",
 CellTags->"Section15",
 CellID->995781111,ExpressionUUID->"d2ce48b6-5398-460a-a982-55ca8668b060"],

Cell[TextData[{
 "We want to prepare a system of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "5f670746-2e6d-4b72-b8f3-e8c449a7e396"],
 " physical qubits, say, in the logical basis state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       OverscriptBox["0", "_"], 
       OverscriptBox["0", "_"], "\[CenterEllipsis]", 
       OverscriptBox["0", "_"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "d65560cf-6b34-49dd-b426-c1b2304d2d6e"],
 ". This requires a procedure without referring to an explicit form of the \
logical basis states."
}], "TechNoteText",
 CellID->753071506,ExpressionUUID->"f69fa745-9959-40e6-ba48-4fab8cab6da8"],

Cell[TextData[{
 "Encoding and decoding a general stabilizer code using unitary gates are \
possible and explained in detail in ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Cleve and Gottesman (1997)"]], 
    "https://doi.org/10.1103/physreva.56.76"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "c3c53bb2-ea9f-4c9a-8f35-bf453f3bbc00"],
 ". Here, a measurement-based method is introduced as it is essentially the \
same as the error-syndrome detection and recovery procedure."
}], "TechNoteText",
 CellID->1751669571,ExpressionUUID->"b61e4f24-9e64-443f-a52b-e14c248eefe8"],

Cell[TextData[{
 "One of the simplest approaches is to measure the generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "1"], ",", 
    SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["G", "k"]}], TraditionalForm]],ExpressionUUID->
  "be14a534-4470-4143-8f27-3b966cb00173"],
 " and the logical Pauli operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["Z", "_"], "1"], ",", 
    SubscriptBox[
     OverscriptBox["Z", "_"], "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox[
     OverscriptBox["Z", "_"], 
     RowBox[{"n", "-", "k"}]]}], TraditionalForm]],ExpressionUUID->
  "9f6df3b3-c3a3-4305-ad6a-39b84bd43dc0"],
 ". Recall that the combined set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["G", "1"], ",", 
     SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["G", "k"], ",", 
     SubscriptBox[
      OverscriptBox["Z", "_"], "1"], ",", 
     SubscriptBox[
      OverscriptBox["Z", "_"], "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox[
      OverscriptBox["Z", "_"], 
      RowBox[{"n", "-", "k"}]]}], "}"}], TraditionalForm]],ExpressionUUID->
  "24fbcd33-4726-44e8-8562-b2b601fcd7d1"],
 " consists of all mutually commuting and independent operators. It thus \
generates a stabilizer subgroup stabilizing a one-dimensional subspace \
spanned by nothing but the desired state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       OverscriptBox["0", "_"], 
       OverscriptBox["0", "_"], "\[CenterEllipsis]", 
       OverscriptBox["0", "_"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "5c8e0d73-1302-4018-b51b-e393d4c6e991"],
 ". Therefore, one can regard a measurement of the generators and logical \
Pauli operators as the error syndrome detection. Then, an initialization to \
the desired state corresponds to the recovery procedure discussed above."
}], "TechNoteText",
 CellID->457163074,ExpressionUUID->"c30fe729-bb41-4b79-9628-4bc62391e443"],

Cell["\<\
Based on the above idea, one can take the encoding procedure in more explicit \
steps as follows. \
\>", "TechNoteText",
 CellID->1990779399,ExpressionUUID->"f4df5716-dae7-451f-9b43-2d07b7664bc8"],

Cell[TextData[{
 "Each measurement of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "1"], ",", 
    SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["G", "k"]}], TraditionalForm]],ExpressionUUID->
  "01d53721-5f42-4534-9f3d-2e331aec8dc3"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["Z", "_"], "1"], ",", 
    SubscriptBox[
     OverscriptBox["Z", "_"], "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox[
     OverscriptBox["Z", "_"], 
     RowBox[{"n", "-", "k"}]]}], TraditionalForm]],ExpressionUUID->
  "c7060e1a-6d27-4e36-99f6-5ea9a517fc3d"],
 " yields measurement outcome ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "0c2091f4-147c-4213-aa0c-17864ec624ae"],
 ". Depending on the measurement results, the final state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "deeff8c0-9211-4838-8fdf-001b2bed39c1"],
 " after all measurements is stabilized by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", 
     SubscriptBox["G", "1"]}], ",", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox["G", "2"]}], ",", "\[Ellipsis]", ",", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox["G", "k"]}], ",", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox[
      OverscriptBox["Z", "_"], "1"]}], ",", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox[
      OverscriptBox["Z", "_"], "2"]}], ",", "\[Ellipsis]", ",", 
    RowBox[{"\[PlusMinus]", 
     SubscriptBox[
      OverscriptBox["Z", "_"], 
      RowBox[{"n", "-", "k"}]]}]}], TraditionalForm]],ExpressionUUID->
  "aa065a5a-0682-449a-8109-b78dcf14571f"],
 ". We then recall from the properties of the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/PauliAndCliffordGroups"],
 " that there exists a Pauli operator ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "e0aac661-3f96-490a-8c29-16eb50c47d0c"],
 " that anti-commutes with only a particular one of the independent operators \
but commutes with all others. We find such a Pauli operator for each \
observable with measurement outcome ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Minus]", "1"}], TraditionalForm]],ExpressionUUID->
  "78e864b1-9745-4882-8d33-42ea6aef9b79"],
 ", and apply those Pauli operators on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8280e3aa-7b37-4255-bb04-0828b6fb10d0"],
 "."
}], "TechNoteText",
 CellID->1234138733,ExpressionUUID->"d593af67-c9bd-4dde-b6e8-a27beb2ce120"],

Cell[TextData[{
 "Once the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       OverscriptBox["0", "_"], 
       OverscriptBox["0", "_"], "\[CenterEllipsis]", 
       OverscriptBox["0", "_"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6bc4e7cd-a332-4bc9-98bb-900519377f19"],
 " has been encoded, other logical basis states can be obtained by applying \
the logical Pauli operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["X", "_"], "1"], ",", 
    SubscriptBox[
     OverscriptBox["X", "_"], "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox[
     OverscriptBox["X", "_"], 
     RowBox[{"n", "-", "k"}]]}], TraditionalForm]],ExpressionUUID->
  "ea873f41-ae22-4476-bd49-8862295c54df"],
 " as necessary."
}], "TechNoteText",
 CellID->1772622805,ExpressionUUID->"cc276e2f-316c-4cce-b592-4d1b05331d17"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples", "TechNoteSection",
 CellTags->"Section16",
 CellID->430848804,ExpressionUUID->"0490d243-09d3-4627-b644-ce4cc01486c2"],

Cell["\<\
Make sure that the Q3 package is loaded to use the demonstrations in this \
document.\
\>", "TechNoteMathCaption",
 CellID->461588114,ExpressionUUID->"3864245b-dc36-431e-ab76-bb79ee3b4e99"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->1200499034,ExpressionUUID->"4b70d135-3599-400e-bc28-ea43f24a4fdd"],

Cell[TextData[{
 "Throughout this document, symbol ",
 StyleBox["S", "Input"],
 " will be used to denote qubits and Pauli operators on them."
}], "TechNoteMathCaption",
 CellID->1178400873,ExpressionUUID->"00e268e8-0ceb-41bb-b08e-e0fccbf54e76"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[2]:=",
 CellID->1289279877,ExpressionUUID->"ca4249f6-2cf1-430b-a5ae-6d831429a0c1"],

Cell[CellGroupData[{

Cell["Bit-Flip Code", "Subsection",
 CellTags->"Section17",
 CellID->2108474791,ExpressionUUID->"1edab6a2-9d64-4556-bf6d-825bded8d4d7"],

Cell[TextData[{
 "Consider the bit-flip code. The stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "681551dc-eb24-4280-aaeb-bf685842a0a7"],
 " of the code space is generated by these generators."
}], "TechNoteMathCaption",
 CellID->601916435,ExpressionUUID->"b377d04c-8803-466d-b437-2b89c1a7f39f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"gnr", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "3"}], "]"}], "**", 
      RowBox[{"S", "[", 
       RowBox[{"2", ",", "3"}], "]"}]}], ",", 
     RowBox[{
      RowBox[{"S", "[", 
       RowBox[{"2", ",", "3"}], "]"}], "**", 
      RowBox[{"S", "[", 
       RowBox[{"3", ",", "3"}], "]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"gnr", "//", "PauliForm"}]}], "Input",
 CellLabel->"In[3]:=",
 CellID->99339714,ExpressionUUID->"8ee3f93e-dc96-4813-91a3-dbaf383fdbdf"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"Z\""},
      "RowDefault"], "\[CircleTimes]", 
     TemplateBox[{"\"Z\""},
      "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
    QuantumMob`Q3`Multiply[
     $CellContext`S[1, 3], 
     $CellContext`S[2, 3]]], ",", 
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", 
     TemplateBox[{"\"Z\""},
      "RowDefault"], "\[CircleTimes]", 
     TemplateBox[{"\"Z\""},
      "RowDefault"]}],
    QuantumMob`Q3`Multiply[
     $CellContext`S[2, 3], 
     $CellContext`S[3, 3]]]}], "}"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->1355232688,ExpressionUUID->"4cc0873e-648d-423c-a6cc-26e36027f9eb"]
}, Open  ]],

Cell[TextData[{
 "This is a set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["E", "\[Mu]"], "}"}], TraditionalForm]],ExpressionUUID->
  "89835ce4-c77f-41ec-b932-e242e1a823b4"],
 " of error operators correctable by the code."
}], "TechNoteMathCaption",
 CellID->509261491,ExpressionUUID->"e9dc7dee-deef-4c37-abc4-1e294f22ea95"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"err", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", 
     RowBox[{"S", "[", 
      RowBox[{"1", ",", "1"}], "]"}], ",", 
     RowBox[{"S", "[", 
      RowBox[{"2", ",", "1"}], "]"}], ",", 
     RowBox[{"S", "[", 
      RowBox[{"3", ",", "1"}], "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"err", "//", "PauliForm"}]}], "Input",
 CellLabel->"In[5]:=",
 CellID->1296505570,ExpressionUUID->"379c1850-1060-432d-87c5-8740a9c03af8"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", "\<\"I\"\>", 
     "\[CircleTimes]", "\<\"I\"\>"}],
    1], ",", 
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"X\""},
      "RowDefault"], "\[CircleTimes]", "\<\"I\"\>", 
     "\[CircleTimes]", "\<\"I\"\>"}],
    $CellContext`S[1, 1]], ",", 
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", 
     TemplateBox[{"\"X\""},
      "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
    $CellContext`S[2, 1]], ",", 
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", "\<\"I\"\>", "\[CircleTimes]", 
     TemplateBox[{"\"X\""},
      "RowDefault"]}],
    $CellContext`S[3, 1]]}], "}"}]], "Output",
 CellLabel->"Out[6]=",
 CellID->1184227134,ExpressionUUID->"64ce0ed6-c771-4b8c-ab18-c2cfe9c08d79"]
}, Open  ]],

Cell[TextData[{
