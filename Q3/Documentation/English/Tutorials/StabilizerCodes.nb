Cell[TextData[{
 "Stabilizer codes are a class of quantum codes with construction based on \
the ",
 ButtonBox["stabilizer formalism",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/StabilizerFormalism"],
 ". The idea was put forward by Gottesman (1996, 1997, 1998)."
}], "TechNoteText",
 CellID->1313103421,ExpressionUUID->"611d8125-3a7b-42d1-9e1a-30a73e7aad9f"],

Cell[TextData[{
 "See also Section 6.4 of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "08b2a3d3-914b-4685-9636-26bb9b58839b"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"6fa34fcb-b335-4ad5-abea-eefef4210452"],

