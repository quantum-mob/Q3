Cell["\<\
The most dangerous case is that the check operator commutes with all of the \
generators but does not belong to the stabilizer. To check if there is such \
case, we examine the check operators that commute with all of the generators.\
\
\>", "TechNoteMathCaption",
 CellID->1763929000,ExpressionUUID->"b0bcb32a-1931-44a8-ad74-219f89b8fd06"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"kk", "=", 
  RowBox[{"Catenate", "@", 
   RowBox[{"MapIndexed", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"ContainsOnly", "[", 
         RowBox[{"#1", ",", 
          RowBox[{"{", "1", "}"}]}], "]"}], ",", "#2", ",", "Nothing"}], 
       "]"}], "&"}], ",", "mat"}], "]"}]}]}]], "Input",
 CellLabel->"In[61]:=",
 CellID->342956165,ExpressionUUID->"cba37f42-40ad-4fbc-ab74-23f3fef559b7"],

