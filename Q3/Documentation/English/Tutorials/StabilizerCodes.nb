Cell[TextData[{
 "In the measurement-based method, we will perform measurement of the \
following extended set  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["G", "1"], ",", 
     SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["G", "4"], ",", 
     OverscriptBox["Z", "_"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "e0e9e24b-2a7d-4de8-b6f9-f261a1dd0005"],
 " of generators. This set generates a subgroup stabilizing the \
one-dimensional subspace, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["P", "1", "+"], 
    SubsuperscriptBox["P", "2", "+"], "\[CenterEllipsis]", " ", 
    SubsuperscriptBox["P", "5", "+"], "\[ScriptCapitalH]"}], 
   TraditionalForm]],ExpressionUUID->"08f42246-fb38-4ae1-b058-7a27576c7ed5"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["P", "j", "\[PlusMinus]"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"I", "\[PlusMinus]", 
       SubscriptBox["G", "j"]}], ")"}], "/", "2"}]}], TraditionalForm]],
  ExpressionUUID->"a5f85dde-caf9-48cb-87c8-61b09e065b8b"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "5"], "\[Congruent]", 
    OverscriptBox["Z", "_"]}], TraditionalForm]],ExpressionUUID->
  "07f4cd4c-b6b3-4598-b290-dd403a8bd064"],
 " are the projections and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "5aec582e-05ed-4f93-901c-f6e7a9781c13"],
 " is the Hilbert space associated with the five physical qubits.  Subspace \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["P", "1", "+"], 
    SubsuperscriptBox["P", "2", "+"], "\[CenterEllipsis]", " ", 
    SubsuperscriptBox["P", "5", "+"], "\[ScriptCapitalH]"}], 
   TraditionalForm]],ExpressionUUID->"a87e2679-ed2c-4f57-be39-5c9edd4099c2"],
 " is spanned by logical basis state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       OverscriptBox["0", "_"], 
       OverscriptBox["0", "_"], "\[CenterEllipsis]", 
       OverscriptBox["0", "_"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "0d5b8604-ab89-4715-a7c2-9701cea11fa2"],
 "."
}], "TechNoteMathCaption",
 CellID->1538355234,ExpressionUUID->"82b19848-eceb-4bd5-b847-246e32d6dd7a"],

