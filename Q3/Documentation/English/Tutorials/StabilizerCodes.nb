Cell[TextData[{
 "To bring the state from ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["P", "1", "-"], 
    SubsuperscriptBox["P", "2", "+"], "\[CenterEllipsis]", " ", 
    SubsuperscriptBox["P", "5", "+"], "\[ScriptCapitalH]"}], 
   TraditionalForm]],ExpressionUUID->"22ed507c-18cb-411a-a20d-8ad1db146b81"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["P", "1", "+"], 
    SubsuperscriptBox["P", "2", "+"], "\[CenterEllipsis]", " ", 
    SubsuperscriptBox["P", "5", "+"], "\[ScriptCapitalH]"}], 
   TraditionalForm]],ExpressionUUID->"4a03de24-db13-475d-88c9-27cd384645a2"],
 ", an additional operation is required. To do this, we note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
   "Z", "\[CircleTimes]", "I", "\[CircleTimes]", "Z", "\[CircleTimes]", "I", "\[CircleTimes]",
     "I"}], TraditionalForm]],ExpressionUUID->
  "ed7483ed-e262-4c10-80bb-f74d13bcb432"],
 " commutes with all but the first element of the extended set ",
 StyleBox["ext", "Input"],
 " of generators."
}], "TechNoteMathCaption",
 CellID->764805875,ExpressionUUID->"a458cec6-2fc4-4ede-bf2d-a2a9324d908f"],

