Cell[TextData[{
 "Now, measure every observable in the extended set ",
 StyleBox["ext", "Input"],
 " of generators. Instead of actually simulating the measurement procedure, \
here we will just assume that the measurement has yield an outcome ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1", ",", "1", ",", "1", ",", "1"}], ")"}], 
   TraditionalForm]],ExpressionUUID->"a86c1214-9576-49a8-b76f-3fac3e4d773a"],
 ". That is, the post-measurement state belongs to the subspace ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["P", "1", "-"], 
    SubsuperscriptBox["P", "2", "+"], "\[CenterEllipsis]", " ", 
    SubsuperscriptBox["P", "5", "+"], "\[ScriptCapitalH]"}], 
   TraditionalForm]],ExpressionUUID->"10f5c442-8693-40c0-b71f-71b52eac0bf8"],
 ", instead of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["P", "1", "+"], 
    SubsuperscriptBox["P", "2", "+"], "\[CenterEllipsis]", " ", 
    SubsuperscriptBox["P", "5", "+"], "\[ScriptCapitalH]"}], 
   TraditionalForm]],ExpressionUUID->"62332943-4a7d-473f-9137-248cc49ae5ac"],
 "."
}], "TechNoteMathCaption",
 CellID->687622178,ExpressionUUID->"567cadae-ec21-4656-9a45-3d00b784a8cd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"prj", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"First", "[", "ext", "]"}]}], ")"}], "/", "2"}], ")"}], "**", 
    
    RowBox[{"Apply", "[", 
     RowBox[{"Multiply", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"Rest", "[", "ext", "]"}]}], ")"}], "/", "2"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"KetNormalize", "[", 
    RowBox[{"prj", "**", "in"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"out", "//", "SimpleForm"}]}], "Input",
 CellLabel->"In[75]:=",
 CellID->1256441139,ExpressionUUID->"3ceb1384-786e-4fc4-88a0-9a9762aff3ff"],

