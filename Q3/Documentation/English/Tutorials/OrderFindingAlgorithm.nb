Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "d76f9b9d-8b8a-43dd-8a17-aff79d59292c"],
 " be the ",
 StyleBox[ButtonBox["modular exponentiation",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/PowerMod"],
  FontSlant->"Italic"],
 " defined by"
}], "TechNoteText",
 CellID->368467177,ExpressionUUID->"9b3e2c70-e776-431f-8afb-c9d577bf881c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     SuperscriptBox["a", "x"], " ", 
     RowBox[{"(", 
      RowBox[{"mod", "  ", "N"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "e41bcfd8-651d-4dc5-b099-cd7a6ccb8e0d"]
}], "TechNoteText",
 CellID->1632489538,ExpressionUUID->"52826ca5-e546-45ee-8860-547c06c7877e"],

Cell[TextData[{
 "for fixed positive integers ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "cf84b26c-6eab-484e-8a2a-419def70ab25"],
 " and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "0d0f047a-0867-469a-a2ce-2d4b431a8d03"],
 ". The two integers ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "f405371a-f45c-4900-9177-a83765a11985"],
 " and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "7539e95d-ffaf-45f7-9d7e-236805a9a209"],
 " are assumed to be coprime. The function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "5b817f36-9bd6-4bca-ab5b-85abab2fc8f5"],
 " is a periodic function (see ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/OrderFindingAlgorithm#335151889"],
 " for an illustration), such that"
}], "TechNoteText",
 CellID->1000591094,ExpressionUUID->"61c6e687-f03c-457d-b096-2a0854010b5e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["a", "r"], "=", 
    RowBox[{"1", "  ", 
     RowBox[{"(", 
      RowBox[{"mod", " ", "N"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "53fbbf75-f2aa-4966-b5a7-19b13bea9ae4"]
}], "TechNoteText",
 CellID->2137560848,ExpressionUUID->"4c6f8ecd-3954-48cc-972f-674ee9646755"],

Cell[TextData[{
 "for some integer ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "3ae9ca44-fc7d-48af-a3a8-0463c326c2c7"],
 ". The primary period (the smallest period) ",
 Cell[BoxData[
  FormBox["r", TraditionalForm]],ExpressionUUID->
  "62808da0-e22a-4e46-a24b-c3e8df9c1961"],
 " is called the order of ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "b1efb5bf-ab58-4a27-9711-4723796cd257"],
 " modulo ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "977efb4c-cac5-42c6-95b9-05334e4d713f"],
 "."
}], "TechNoteText",
 CellID->731241673,ExpressionUUID->"819c55a4-9a4f-4692-87d5-b87ce9c821ca"],

