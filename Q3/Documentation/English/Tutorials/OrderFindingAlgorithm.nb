   "WebLink",
   BaseStyle->{"Text"}]],ExpressionUUID->
  "2903aa4d-aa9d-4d01-919f-b785916ccf57"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"61e6e114-b2e8-4f6b-8396-4056e1ba7a2b"],

