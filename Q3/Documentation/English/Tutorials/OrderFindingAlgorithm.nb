Cell[TextData[{
 "From these phases, we conclude that the order of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "3"}], TraditionalForm]],ExpressionUUID->
  "b40e63fc-63cc-4584-992a-71bdecf78acd"],
 " modulo ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "=", "16"}], TraditionalForm]],ExpressionUUID->
  "90caf2cb-0a15-4b31-980a-e018fa848fcf"],
 " is 4, which is correct."
}], "TechNoteMathCaption",
 CellID->1257912421,ExpressionUUID->"35a99821-e5f7-4056-b94f-16b710979f52"],

