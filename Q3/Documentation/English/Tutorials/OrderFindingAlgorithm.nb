   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{"S", "@", "jj"}], "]"}], ",", 
    RowBox[{"Ket", "[", 
     RowBox[{
      RowBox[{"T", "@", "kk"}], "->", 
      RowBox[{"IntegerDigits", "[", 
       RowBox[{"1", ",", "2", ",", "$n"}], "]"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"S", "[", 
