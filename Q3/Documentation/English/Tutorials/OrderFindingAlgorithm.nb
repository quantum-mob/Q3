Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Plot of modular exponentiation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["a", "x"], " ", 
    RowBox[{"(", 
     RowBox[{"mod", " ", "N"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8e13d855-4ba9-47c2-9088-bccdc668e95b"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "3"}], TraditionalForm]],ExpressionUUID->
  "7602e973-158a-4e35-a2b4-25f239f3ab72"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "=", "16"}], TraditionalForm]],ExpressionUUID->
  "808006c1-fcae-4754-b29d-b994fa576c9c"],
 "."
}], "TechNoteCaption",
 CellID->335151889,ExpressionUUID->"44d94071-c56f-4f9a-a7aa-7ab2db86ca38"],

Cell[TextData[{
 "The order-fining problem is to determine the order for given ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "1a30a839-ebaf-433d-9c9a-6fa4b31921b5"],
 " and ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "556bdcdf-fb7d-4f07-84cc-facfa2bc6a5d"],
 ". It is known to be hard to solve classically. The order-finding algorithm \
is the central part of the ",
 ButtonBox["quantum factorization algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumFactorizationAlgorithm"],
 "."
}], "TechNoteText",
 CellID->1220233954,ExpressionUUID->"14c922a3-2017-4db3-8442-65a99d3d162d"],

