    RowBox[{"ControlledPower", "[", 
     RowBox[{
      RowBox[{"S", "[", "jj", "]"}], ",", 
      RowBox[{"ModMultiply", "[", 
       RowBox[{"$N", ",", "$a", ",", 
        RowBox[{"T", "[", "kk", "]"}]}], "]"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"QFT", "[", 
     RowBox[{"S", "@", "jj"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Measurement", "[", 
