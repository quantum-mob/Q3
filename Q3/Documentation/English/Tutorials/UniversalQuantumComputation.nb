Cell[CellGroupData[{

Cell["Decomposition into Two-Level Unitary Matrices", "TechNoteSection",
 CellID->1255432361,ExpressionUUID->"4c493859-26ee-4760-9d4f-218ba5d93287"],

Cell[TextData[{
 "Suppose that we want to implement an arbitrary unitary operation ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "c882cc20-213f-4894-8c1c-8645b48e0c46"],
 " on an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "81c729ca-44d2-49b7-ac5e-ba0da8d41c5a"],
 "-qubit register. We start by decomposing ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "49f748f7-4a3a-450e-8c53-686388844c79"],
 " into a set of two-level unitary transformations ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "k"], TraditionalForm]],ExpressionUUID->
  "a6e146a6-5f64-4bf5-ab93-f306368d9428"],
 ", that is,"
}], "TechNoteText",
 CellID->2093541217,ExpressionUUID->"df27750c-bd3f-4e85-a8bb-a0f78a9db6fd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     SubscriptBox["T", "L"], "\[CenterEllipsis]", " ", 
     SubscriptBox["T", "2"], 
     SubscriptBox["T", "1"]}]}], TraditionalForm]],ExpressionUUID->
  "0775a369-8025-450d-8c14-7a03b0683446"],
 " ."
}], "TechNoteText",
 CellID->330293091,ExpressionUUID->"3d63fae0-0707-4647-b3f7-eaeb738bfe44"],

Cell[TextData[{
 "The procedure is detailed for arbitrary two-qubit unitary gates in ",
 ButtonBox["Two-Qubit Gates",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/TwoQubitGates#1476129218"],
 ". To summarize the procedure, first  remove the off-diagonal element ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", 
    RowBox[{"1", " ", "n"}]], TraditionalForm]],ExpressionUUID->
  "f5ae98ab-01d3-41c4-91ef-7516feac1bb9"],
 " at the top-right corner of the matrix representation of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "78b0b4ad-8caa-4792-8c30-57a73a81afe2"],
 " by multiplying ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "c579977b-ec04-498e-8d78-0896b487f8b3"],
 " with a two-level unitary transformation ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["T", "1", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "630152b9-ee90-42ad-b144-f64ab685ba74"],
 " on the right, and repeat it along the top row and then the next \
consecutive rows to zero all off-diagonal elements and to set every diagonal \
element to unity, so that"
}], "TechNoteText",
 CellID->2138236589,ExpressionUUID->"207be695-d383-4028-8ec5-a5ce3e039ba9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", " ", 
     SubsuperscriptBox["T", "1", "\[Dagger]"], 
     SubsuperscriptBox["T", "2", "\[Dagger]"], "\[CenterEllipsis]", " ", 
     SubsuperscriptBox["T", "L", "\[Dagger]"]}], "=", "I"}], 
   TraditionalForm]],ExpressionUUID->"095e41bd-258d-4d9b-bce6-65d522f95c63"],
 " ."
}], "TechNoteText",
 CellID->1351002425,ExpressionUUID->"345dd4b7-79b2-4849-ab2f-f3ac7686ebb4"],

Cell[TextData[{
 "The decomposition of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "acc38636-c5ca-4e6e-85af-9d971befe705"],
 " is then given by"
}], "TechNoteText",
 CellID->953157244,ExpressionUUID->"2e5a793c-424c-4c28-9a87-fd2c462282de"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     SubscriptBox["T", "L"], "\[CenterEllipsis]", " ", 
     SubscriptBox["T", "2"], 
     SubscriptBox["T", "1"]}]}], TraditionalForm]],ExpressionUUID->
  "01479b34-7487-4ae4-8286-11b0d631980e"],
 " ."
}], "TechNoteText",
 CellID->1633276935,ExpressionUUID->"89f9b098-14c0-471e-be22-7b2b379d822b"],

Cell["as desired.", "TechNoteText",
 CellID->1349470591,ExpressionUUID->"27b93738-90cb-4a03-85f0-37401114a408"],

