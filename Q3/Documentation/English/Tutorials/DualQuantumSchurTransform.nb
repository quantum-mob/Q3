Cell[CellGroupData[{

Cell["Schur Basis", "TechNoteSection",
 CellID->954056626,ExpressionUUID->"5653ce4a-2d06-4638-98f9-89cbbc431fd6"],

Cell[TextData[{
 "Consider a system of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e0f8dc89-1ed9-496e-b6d8-7f603f26c663"],
 " identical particles, each of which is associated with a ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "45548782-4c10-4a4c-b292-f3c949fa8345"],
 "-dimensional Hilbert space ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", "d"], TraditionalForm]],ExpressionUUID->
  "6a006b74-1db7-431e-a153-bdb9d4ab91a5"],
 ". The Schur-Weyl duality assures that the tensor-product space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "05b7350a-b3ec-406b-b488-9a061706b1a8"],
 " may be decomposed as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"ee8f2410-1503-4fba-941b-39a10ff107ed"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"48703266-fa7b-4798-aa4d-0f66a0c1914b"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"3df9affd-9bec-4da3-b1d7-15a55879c866"],
 " are irreducible representation spaces associated with ",
 ButtonBox["integer partition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungShape"],
 " ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "d8cd6c95-14f8-4755-8057-df0b8738b520"],
 " of the symmetric and unitary groups, respectively. The ",
 ButtonBox["Schur basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/DualSchurBasis"],
 "\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{
          SubscriptBox["y", "\[Lambda]"], "\[VeryThinSpace]", 
          SubscriptBox["w", "\[Lambda]"]}]}]},
     "Ket"], " ", "}"}], TraditionalForm]],ExpressionUUID->
  "a5546942-67ff-4974-b616-a1bed60baac0"],
 "\[LineSeparator]is a basis of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "083d17b8-dc32-43b6-87d8-93512d0ca907"],
 " consistent with the above decomposition such that ",
 ButtonBox["standard Young tableaux",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungTableaux"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "6aea4994-fb25-47f6-bef5-1e4cc6b55a33"],
 " and ",
 ButtonBox["Weyl tableaux",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/WeylTableaux"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "e83c036d-8a47-4f8c-a6f0-af95c03f9480"],
 " label the basis vectors in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"0a232e82-c89f-41e0-9af6-e0fc09d3003b"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"506ada67-23d5-419f-9255-c280b2b8f8c1"],
 ", respectively."
}], "TechNoteText",
 CellID->1580417735,ExpressionUUID->"5fd8b99b-3ec9-41ef-870f-7b9bce8b5147"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Permutation Module", "TechNoteSection",
 CellID->1543514506,ExpressionUUID->"53619db3-0a5f-44ec-85ed-c5d0743be9e6"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"ac08db9b-ea1a-4111-867b-d0809bc6538a"],
 " be a permutation module of ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "a00a3b41-415b-4507-85ff-d857d34d9e96"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        TemplateBox[{
          RowBox[{
            SubscriptBox["i", "1"], ",", 
            SubscriptBox["i", "2"], ",", "\[Ellipsis]", ",", 
            SubscriptBox["i", "n"]}]},
         "Ket"], ":", 
        RowBox[{"content", "(", 
         RowBox[{"{", 
          RowBox[{
           SubscriptBox["i", "1"], ",", 
           SubscriptBox["i", "2"], ",", "\[Ellipsis]", ",", 
           SubscriptBox["i", "n"]}], "}"}], ")"}]}], "=", "\[Mu]"}], 
      "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "6daedf61-afd3-4db4-a825-6a9575d236fd"],
 ".\[LineSeparator]It can be rewritten in terms of permutations as\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalPi]", "(", "g", ")"}], 
       RowBox[{
        TemplateBox[{"\[Mu]"},
         "Ket"], ":", 
        RowBox[{"g", "\[Element]", 
         SubscriptBox["\[ScriptCapitalS]", "n"]}]}]}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"4d3625cf-e1c6-4fd5-848f-606b9a840580"],
 ",\[LineSeparator]where\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Mu]"},
     "Ket"], ":=", 
    TemplateBox[{
      RowBox[{
        UnderscriptBox[
         UnderscriptBox[
          RowBox[{"1", ",", "1", ",", "1"}], "\[UnderBrace]"], 
         SubscriptBox["\[Mu]", "1"]], ",", 
        UnderscriptBox[
         UnderscriptBox[
          RowBox[{"2", ",", "2", ",", "2"}], "\[UnderBrace]"], 
         SubscriptBox["\[Mu]", "2"]], ",", "\[Ellipsis]", ",", 
        UnderscriptBox[
         UnderscriptBox[
          RowBox[{"d", ",", "d", ",", "d"}], "\[UnderBrace]"], 
         SubscriptBox["\[Mu]", "d"]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "9dc27d1c-3b62-477e-be34-1eb4be844ad0"],
 " ."
}], "TechNoteText",
 CellID->1346838239,ExpressionUUID->"7f2054e3-0791-49d9-b1d6-adf71f223621"],

Cell[TextData[{
 "States ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPi]", "(", "g", ")"}], 
    TemplateBox[{"\[Mu]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "b0fa1a62-afe8-4cab-94c9-58adc7ef6127"],
 " for different group elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "556684f0-1263-48eb-89c3-399a9d481f12"],
 " are not always distinct. More specifically, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalPi]", "(", "f", ")"}], 
     TemplateBox[{"\[Mu]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{"\[CapitalPi]", "(", "g", ")"}], 
     TemplateBox[{"\[Mu]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "46116fab-8a2a-4716-863b-0964d14eda56"],
 " whenever ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "=", 
    RowBox[{"g", "\[VeryThinSpace]", "h"}]}], TraditionalForm]],
  ExpressionUUID->"745abd1c-d459-45fc-93df-93dff75301a3"],
 " for some element ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "823cef9d-b5e8-4667-8cf4-0d145b382b4e"],
 " of ",
 ButtonBox["Young subgroup",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungSubgroup"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"90584c11-eb10-499e-b04b-343215bae016"],
 ", that is, ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "6fa1e8e0-6c6f-422f-b9ea-a4508698f130"],
 " and ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "669343f4-cb28-4e3c-9484-074adbeee94a"],
 " belongs to the same left coset of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"570bd5b9-169a-491a-a906-15ab4c8ceb2a"],
 ". Therefore, it is convenient to consider a transversal ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["t", "1"], ",", 
      SubscriptBox["t", "2"], ",", "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["\[ScriptCapitalS]", "n"], "\[RightBracketingBar]"}], "/", 
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], 
        "\[RightBracketingBar]"}]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"5ba2f9e6-c6f7-4b29-a19d-3fa00d74d100"],
 " for the left cosets of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"15e3102a-7781-4af9-b466-33749d05d889"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "822de78b-e8f5-4d4d-a1bf-90e8292c823e"],
 ". Then, the permutation module is given by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalPi]", "(", "t", ")"}], 
       RowBox[{
        TemplateBox[{"\[Mu]"},
         "Ket"], ":", 
        RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}]}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"0b494943-3c84-4d8a-994b-dcc92886990e"],
 "."
}], "TechNoteText",
 CellID->47162978,ExpressionUUID->"4e1e2c8d-7c34-4435-857b-2348c0759be1"],

Cell[TextData[{
 "It is then evident that  permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"9a8b7f3d-7aaa-405f-a1f3-f0d941eb182d"],
 " is isomorphic to the left coset module\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{
     RowBox[{"Span", 
      RowBox[{"{", 
       RowBox[{
        TemplateBox[{
          RowBox[{"g", "\[VeryThinSpace]", 
            SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
         "Ket"], ":", 
        RowBox[{"g", "\[Element]", 
         SubscriptBox["\[ScriptCapitalS]", "n"]}]}], "}"}]}], "=", 
     RowBox[{"Span", 
      RowBox[{"{", 
       RowBox[{
        TemplateBox[{
          RowBox[{"t", "\[VeryThinSpace]", 
            SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
         "Ket"], ":", 
        RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}], "}"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"bf6dc64e-27bf-4f27-9bbf-ab04d42bacc1"],
 ",\nand hence an induced representation of the trivial representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"85885c25-25ac-49a3-8723-e39395c0c63b"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "2b67925e-e06a-456f-9427-592abc504a1c"],
 "."
}], "TechNoteText",
 CellID->1793598696,ExpressionUUID->"2863069e-b48c-44da-aeac-57ba455a5e16"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Irreducible Subspaces", "TechNoteSection",
 CellID->1029174584,ExpressionUUID->"bc95728c-7635-4e18-837b-0536356cc79e"],

Cell[TextData[{
 "To understand the motivation behind the dual Schur transform, recall that\n\
\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Mu]"], 
     SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"]}]}], TraditionalForm]],
  ExpressionUUID->"19e7b485-be32-41ef-b0f2-db3df83ab693"],
 "\nwhere ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"c3706060-8865-47de-a97d-6c6a6c12f6b5"],
 " is the ",
 StyleBox["permutation module",
  FontSlant->"Italic"],
 " associated with ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "d"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "a1b2e1fb-6cca-47ae-af16-6182d5b647e0"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Mu]", "1"], "+", 
     SubscriptBox["\[Mu]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Mu]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"49c1b879-81f4-44ff-bb9a-82f29018d8b5"],
 ". "
}], "TechNoteText",
 CellID->1223599087,ExpressionUUID->"899c5bc3-4b83-40b5-9259-031ba1d0b4da"],

Cell[TextData[{
 "Permutation module is reducible, and decomposes into ",
 StyleBox[ButtonBox["Specht module",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"c5af0606-c077-4d84-b85b-2620c3d41b54"],
 ", the basis elements of which are labeled by the standard Young tableaux of \
shape \[Lambda]:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", 
      RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
      SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"04d52512-455a-4270-9d35-d8f9383eb518"],
 " ,\nwhere the direct sum ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CirclePlus]", 
    RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
   TraditionalForm]],ExpressionUUID->"4b863a82-dc60-4e57-8a18-2b30163b9c03"],
 " is over partitions ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "a5100987-ca31-407b-a231-d6f5600bbd5e"],
 " that ",
 ButtonBox["dominate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/DominatesQ"],
 " ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "d0d6cae2-8642-43bf-9e9f-c4e07a04286f"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]}], 
   TraditionalForm]],ExpressionUUID->"117cbc39-5d90-40cd-a9fb-35f4f6ebe4fc"],
 "). The basis vectors of the multiplicity space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"], 
   TraditionalForm]],ExpressionUUID->"0eccae06-92b1-4ce8-bb67-6f44e1ef66a7"],
 " are labeled by Weyl tableaux of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "2395e491-40c1-4b8c-92a4-41a6f11b5f99"],
 " and content ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "99cef563-6304-4d93-9ab0-d37445f8408e"],
 ". Putting them together, the tensor product space is decomposed into\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CirclePlus]", "\[Mu]"], 
      SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CirclePlus]", "\[Mu]"], 
       RowBox[{
        SubscriptBox["\[CirclePlus]", 
         RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
        RowBox[{
         SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
         SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}]}]}], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
        RowBox[{
         SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[CirclePlus]", 
            RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
           SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}], 
          ")"}]}]}], "=", 
       RowBox[{
        SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
        RowBox[{
         SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
         SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"a6627404-4af8-4f87-9555-4f2d671b6560"],
 ",\[LineSeparator]where for the last equality, we have identified\
\[LineSeparator]\t",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], "=", 
   RowBox[{
    SubscriptBox["\[CirclePlus]", 
     RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
    SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}]}]],
  ExpressionUUID->"955cf32c-5c86-4efd-94c5-ee11e2c15905"],
 " \[LineSeparator]according to the Schur-Weyl duality."
}], "TechNoteText",
 CellID->494624109,ExpressionUUID->"878d3c18-b29c-4703-9c0f-22d7c47b64c2"],

Cell[TextData[{
 "It is then clear that the desired Schur basis can be found by \
block-diagonalizing the action of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "ff322ebd-497a-41c0-b145-b9104b84c8ff"],
 " on ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"a38ffce5-d86b-4f89-a278-c0aec5cafdc7"],
 " for all  ",
 Cell[BoxData["\[Mu]"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "efc15930-2de4-42e9-8581-550c840a362a"],
 ". This is the key idea behind the dual quantum Schur transform."
}], "TechNoteText",
 CellID->1819887037,ExpressionUUID->"678fe7cb-7fce-4748-8fd6-c930bb763ca9"],

Cell[CellGroupData[{

Cell["Remarks", "Subsection",
 CellID->1268898005,ExpressionUUID->"d82ee2e5-d6a1-4ba5-8e39-e97cbc3dabf6"],

Cell[TextData[{
 "Recall that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"], "\[TildeEqual]", 
    SubsuperscriptBox["\[ScriptCapitalW]", "\[Nu]", "\[Lambda]"]}], 
   TraditionalForm]],ExpressionUUID->"2ffb9cab-ec96-45b1-bdf4-0963fd53c672"],
 " for any contents ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "bf71dc46-7d15-4fc6-bd7e-ff5b6033a3c3"],
 " and ",
 Cell[BoxData[
  FormBox["\[Nu]", TraditionalForm]],ExpressionUUID->
  "886b1ed1-d505-4288-8529-e891962dbdb9"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"shape", "(", "\[Mu]", ")"}], "=", 
    RowBox[{"shape", "(", "\[Nu]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "d18d0832-b985-4314-9cc4-fc9edee458a6"],
 ". This means that the irreducible space of the unitary group is given by\n\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], "\[Congruent]", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
     SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}], "\[TildeEqual]", 
    RowBox[{
     SubsuperscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}], "\[Prime]"], 
     RowBox[{
      SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"], 
      SubscriptBox["m", "\[Mu]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "5e4ab6ec-4f6f-4267-b6de-8e353aff30d8"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "93e2ec1a-f0bb-410f-b959-a42d3ea751fc"],
 " is the number of distinct permutations of partition ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "56645693-c3fc-406b-b34b-5d32b37c9006"],
 " (assuming that has length ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "9df7fe2c-16fe-4210-97f3-c70bbccbe5d9"],
 " by padding it with 0 on the right if necessary), and the first direct sum ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CirclePlus]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "bd9da521-4047-43ad-af0d-ce88868fef15"],
 " is over contents ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "f3ad9261-8d10-461e-b6d4-081a3ee72f2e"],
 " (not necessarily partitions) of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "cd8c6fdd-441e-44ff-9b11-6221285fe277"],
 " whereas the second direct sum ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[CirclePlus]", "\[Mu]", "\[Prime]"], TraditionalForm]],
  ExpressionUUID->"91e13bce-9426-4825-bc5e-8b10a195dc0f"],
 " is over partitions ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "b98c58ac-dbe1-46af-91a8-fa1b1f3ae3fc"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f100c198-36bf-43c1-a930-fa6b6e636ecf"],
 ". The dimension of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"], 
   TraditionalForm]],ExpressionUUID->"b3a77ad6-df6f-43fd-94ff-c292423c9590"],
 " is given by the ",
 ButtonBox["Kostka number",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/KostkaNumber"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"675dbf90-259a-4aa0-8457-41765efe2a61"],
 ", the number of Weyl tableaux of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "e5e8c428-3559-4621-9ad5-65d472730be0"],
 " and content ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "55adab49-6e64-42bd-a610-49b5bfbc06fb"],
 " ,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", "\[VeryThinSpace]", 
     SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}], "=", 
    SubscriptBox["K", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]]}], TraditionalForm]],
  ExpressionUUID->"b8d0c78b-8144-4a86-96c1-cea08fbf6336"],
 ". Hence,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
    SubscriptBox["K", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], 
    SubscriptBox["m", "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "0291e672-5c51-4fad-847c-4f1d0e768a52"],
 " must equal the dimension of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"f5bac577-0b79-4e1f-9115-2ed019b110e8"],
 ", i.e., the number of Weyl tableaux of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "198d349a-f878-49bf-bd6a-047aabccf8ab"],
 " (of arbitrary content)."
}], "TechNoteText",
 CellID->833580814,ExpressionUUID->"a8c9119e-be45-4bf0-816a-760d3ddb21e7"],

Cell[TextData[{
 "According to the ",
 ButtonBox["Frobenius reciprocity theorem",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Frobenius_reciprocity"], None}],
 ", the multiplicity of the trivial representation of the Young subgroup ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"5b7ab923-d7e4-4374-942c-10cd11c3d78e"],
 " in the restriction of irreducible representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"6821ca9f-b6ae-4894-8592-b64d8757fae3"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "855982da-9d49-4044-a787-6e4e48e4c244"],
 "  to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"d6aeafaa-182f-41a6-8a89-99032a37cfad"],
 " equals the multiplicity of irreducible representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"84f14155-2cc2-4867-a35d-04833f0c69a6"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "8fd41937-7bb3-4486-b549-6bb8cbcfaa9f"],
 " in the induced representation of the trivial representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"a3b349d2-4238-4e3f-a298-fff1221c0b35"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "53e56a0f-3c6a-48ee-9651-2fdca4c29724"],
 ", i.e., the permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"cf83d300-9c04-4064-8abd-8439a4c84fd3"],
 ". Therefore, both multiplicity factor is given by the ",
 ButtonBox["Kostka number",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/KostkaNumber"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"a566f755-c221-40b5-9be9-5797b82f9968"],
 "."
}], "TechNoteText",
 CellID->325513803,ExpressionUUID->"2f1be013-4d9c-42b2-9478-d88305226173"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["QFT for Permutation Module", "TechNoteSection",
 CellID->197057484,ExpressionUUID->"5469e275-2e92-439e-89be-74204d3c86f0"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "0196b6b4-015d-4800-95fa-a8e3dace4ca6"],
 " be an integer content of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "fa882d65-8e51-4a36-aade-ccfdf6f9aebb"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "d4ad282d-4992-4612-be9b-3058e9946d80"],
 " its associated Young subgroup of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "a9d691a1-79aa-4b7c-a4b6-efc0c849b262"],
 ". The permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"fcbba24e-a924-4c21-b18a-7bc1d3b73b77"],
 " is the induced representation of the trivial representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"60c452ad-5273-4e97-8c68-a5f2e1efbafc"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "108d56aa-abd4-465f-a68e-61d8904a017c"],
 "; that is, \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{"1", 
     SubsuperscriptBox["\[UpArrow]", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], 
      SubscriptBox["\[ScriptCapitalS]", "n"]]}]}], TraditionalForm]],
  ExpressionUUID->"206c0960-2dbc-412d-8d73-c30b1c8d7158"],
 " ."
}], "TechNoteText",
 CellID->249215652,ExpressionUUID->"1b28562f-c2bd-403e-9189-0d2848eca8fb"],

Cell[TextData[{
 "A convenient choice of transversal ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalT]", TraditionalForm]],ExpressionUUID->
  "7e2de4e6-b189-40aa-ae88-24f8dc3a03df"],
 " for the cosets of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"3bbe31c4-8677-4000-b378-3e128a991d41"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "ad8eb0f3-eadb-4644-a07e-9d2dcdb707bb"],
 " is given by the set of permutations ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Pi]", "k"], TraditionalForm]],ExpressionUUID->
  "d81f9f6b-334d-4944-84e3-20f0ec1ec0ff"],
 "  that lead the tuple\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     UnderscriptBox[
      UnderscriptBox[
       RowBox[{"1", ",", "...", ",", "1"}], "\[UnderBrace]"], 
      SubscriptBox["\[Mu]", "1"]], ",", 
     UnderscriptBox[
      UnderscriptBox[
       RowBox[{"2", ",", "...", ",", "2"}], "\[UnderBrace]"], 
      SubscriptBox["\[Mu]", "2"]], ",", "\[Ellipsis]", ",", 
     UnderscriptBox[
      UnderscriptBox[
       RowBox[{"n", ",", "...", ",", "n"}], "\[UnderBrace]"], 
      SubscriptBox["\[Mu]", "n"]]}], "}"}], TraditionalForm]],ExpressionUUID->
  "6654b4e2-22ca-48cb-bd48-2b34449d024e"],
 "\[LineSeparator]into distinct tuples. In fact, this is how the permutation \
basis is constructed for ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "5ce505a0-0d18-4d64-bf65-ad84a2d4745a"],
 ", and thus the permutation module is isomorphic to the subspace spanned by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["\[Pi]", "k"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "6f746433-329a-4720-b70c-e7fc318389b5"],
 "."
}], "TechNoteText",
 CellID->261087420,ExpressionUUID->"ea99a772-1e06-4dd7-bc6d-12584628da68"],

Cell[TextData[{
 "The Fourier basis is given by\[LineSeparator]",
 Cell[BoxData[
  FormBox[
   RowBox[{"\t", 
    RowBox[{
     TemplateBox[{
       RowBox[{
         RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]], 
      TemplateBox[{
        RowBox[{"t", "\[VeryThinSpace]", "\[ScriptCapitalH]"}]},
       "Ket"], 
      SubsuperscriptBox[
       RowBox[{
        SqrtBox[
         FractionBox[
          SubscriptBox["d", "\[Lambda]"], 
          RowBox[{"|", "\[ScriptCapitalG]", "|", 
           RowBox[{"/", 
            RowBox[{"|", "\[ScriptCapitalH]", "|"}]}]}]]], "[", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "t", ")"}], 
         RowBox[{
          SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
          "\[ScriptCapitalH]", ")"}]}], "]"}], 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "*"], " "}]}]}], 
   TraditionalForm]],ExpressionUUID->"e79e2536-4d1c-4820-8312-c436334b4283"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "\[ScriptCapitalH]", 
    ")"}], TraditionalForm]],ExpressionUUID->
  "5229f681-76b6-4344-9440-642f64d42539"],
 " is the projection operator into the irreducible space of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "2f9948bc-df56-4840-87e9-4fcae7d031c3"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "\[ScriptCapitalH]",
      ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"|", "\[ScriptCapitalH]", "|"}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"3fb4290d-cfb5-4be5-aaaa-21d04f206a41"],
 ".\[LineSeparator]The ",
 ButtonBox["quantum Fourier transform",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/GeneralizedQuantumFourierTransform"],
 " (QFT) for the permutation module, i.e., the basis change from the \
computational to Fourier basis, can be implemented efficiently on a quantum \
computer for many non-Abelian groups. See the tech note titled \"",
 ButtonBox["Generalized Quantum Fourier Transform",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/GeneralizedQuantumFourierTransform"],
 "\"."
}], "TechNoteText",
 CellID->1825301940,ExpressionUUID->"4c44adab-67b5-49a6-bc9f-1cc5a6ebeb90"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum Implementation", "TechNoteSection",
 CellID->1892500224,ExpressionUUID->"6ce3d5d9-1715-4e73-9cd7-05e4a1c4f3df"],

Cell[TextData[{
 "Recall that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CirclePlus]", "\[Mu]"], 
      SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"]}], "=", 
     RowBox[{
      SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
      RowBox[{
       SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
       SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"933bf051-48ee-4940-ad53-b45df7da7020"],
 "\[LineSeparator]with \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], ":=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
     SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}]}], 
   TraditionalForm]],ExpressionUUID->"62019da2-370a-4e0a-99b6-235a36854b62"],
 " .\nThis means that the basis block-diagonalizing the permutation module \
automatically block-diagonalizes the symmetric and unitary groups on the \
tensor-product space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "48ee6730-4b24-4363-96eb-e133b701d4f1"],
 "."
}], "TechNoteText",
 CellID->673623048,ExpressionUUID->"d6549117-e690-4b02-986c-42524de8f4e5"],

Cell[TextData[{
 "Then, since the permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"19d50ce4-9ab0-4a18-bb38-8156dc37f439"],
 " is the induced representation of the trivial representation of the Young \
subgroup ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"d6625182-3aad-4a68-b9f1-4d62d795591a"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "256e2407-113d-4373-9ed4-c3c1230d7ac7"],
 ", the basis that block-diagonalizes it is obtained by the quantum Fourier \
transform for the permutation module."
}], "TechNoteText",
 CellID->535222336,ExpressionUUID->"a687f9d7-d606-4fb3-9333-f1f61f4127e0"],

Cell[TextData[{
 "Get the set of all compositions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ca26f9e2-9ead-419d-bc51-ac6dbc821b79"],
 " with length ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "c8df690d-7d08-4b93-8755-485f818e14a5"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Mu]", "\[Congruent]", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], ",", 
         RowBox[{
          SubscriptBox["\[Mu]", 
           RowBox[{"2", ","}]], "..."}], ",", 
         SubscriptBox["\[Mu]", "d"]}], ")"}]}], " ", ":", " ", 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "k"], 
       SubscriptBox["\[Mu]", "k"]}]}], "=", "n"}], "}"}], TraditionalForm]],
  ExpressionUUID->"7cea9c80-3a18-43a0-8d13-99a0fa0283e7"],
 ".\[LineSeparator]Call the compositions contents."
}], "ItemNumbered",
 CellID->365503015,ExpressionUUID->"48df00ab-9a96-4b8b-ad41-e2fbc6378662"],

Cell[TextData[{
 "For each content ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "e9d11f25-9ee0-40b3-b7bf-4e6aca02135f"],
 ", get the set of all partitions ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "9fa11ca0-0004-4280-91af-3bd1a65024d5"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "15090de2-7293-4328-ae71-e60521ed3ecc"],
 " with length ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "0135fab1-ac3d-43da-ad7e-faeda4f5a5a0"],
 " that dominates \[Mu],\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Lambda]", "\[RightTee]", "n"}], "|", 
     RowBox[{"d", " ", ":", " ", 
      RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"60a1733f-444c-4a03-844c-3b8d22275b03"],
 "."
}], "ItemNumbered",
 CellID->1047140541,ExpressionUUID->"a80036a2-63d1-41e2-aed9-df1db97dc781"],

Cell[TextData[{
 "For each \[Lambda], use the quantum Fourier transform for permutation \
module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"ea5d2b94-08fe-424d-80f1-90856f0e5f69"],
 " to get the Fourier basis ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", "y", ",", "w"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "eb49c022-8d82-410c-9cf0-5f180437da76"],
 " that block-diagonalizes ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"4ab0cf3d-ed65-429b-815c-f652304b6e04"],
 "."
}], "ItemNumbered",
 CellID->1826379949,ExpressionUUID->"545e4658-11e2-440b-8363-3c1771dafb52"]
}, Open  ]],

