Cell[CellGroupData[{

Cell["Schur Basis", "TechNoteSection",
 CellID->954056626,ExpressionUUID->"aeca2ed8-61e5-4c5b-9f4f-6518f692ea93"],

Cell[TextData[{
 "Consider a system of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ba5a0d55-1f2e-4bd9-a5b6-81c85d6b5aa6"],
 " identical particles, each of which is associated with a ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "527835fb-26f8-4b07-85fe-01527c9951b0"],
 "-dimensional Hilbert space ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", "d"], TraditionalForm]],ExpressionUUID->
  "ba219ae9-6369-49aa-a439-5ff29634202b"],
 ". The Schur-Weyl duality assures that the tensor-product space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "70e15630-90be-44d8-86b5-27724e07dc40"],
 " may be decomposed as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"6d2758cb-fa6e-4f7e-9419-60d372afc30d"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"0c6ee539-6125-4468-867a-86c2539b4c06"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"29fa9e6c-98ec-4843-b331-c610037d095e"],
 " are irreducible representation spaces associated with ",
 ButtonBox["integer partition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungShape"],
 " ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "37b258d3-782b-4358-8dbc-ecf702e9d261"],
 " of the symmetric and unitary groups, respectively. The ",
 ButtonBox["Schur basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/DualSchurBasis"],
 "\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{
          SubscriptBox["y", "\[Lambda]"], "\[VeryThinSpace]", 
          SubscriptBox["w", "\[Lambda]"]}]}]},
     "Ket"], " ", "}"}], TraditionalForm]],ExpressionUUID->
  "cb7ec3ea-a1c5-4271-a4b6-8e56830a8e6e"],
 "\[LineSeparator]is a basis of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "a73438bf-60f4-4a49-810a-1f8adadabc94"],
 " consistent with the above decomposition such that ",
 ButtonBox["standard Young tableaux",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungTableaux"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "3a22ec51-b920-472b-a4c9-9459e8f7388e"],
 " and ",
 ButtonBox["Weyl tableaux",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/WeylTableaux"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "018f24e6-485a-4c96-9e6d-c836a236151a"],
 " label the basis vectors in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"abeb5bdd-72bc-4d23-bac5-e8e4322a8cda"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"b9af1685-53c4-4afe-b5a5-198ee20dca33"],
 ", respectively."
}], "TechNoteText",
 CellID->1580417735,ExpressionUUID->"de992105-f69e-4b0f-b82d-63b4905c67f2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Permutation Module", "TechNoteSection",
 CellID->1543514506,ExpressionUUID->"33fbc9cf-c487-4445-8359-36bba13f296b"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"09d21323-3254-4c5e-a702-1b2fde892c8f"],
 " be a permutation module of ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "f78d29a8-6433-477e-9c67-33dcf1968114"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        TemplateBox[{
          RowBox[{
            SubscriptBox["i", "1"], ",", 
            SubscriptBox["i", "2"], ",", "\[Ellipsis]", ",", 
            SubscriptBox["i", "n"]}]},
         "Ket"], ":", 
        RowBox[{"content", "(", 
         RowBox[{"{", 
          RowBox[{
           SubscriptBox["i", "1"], ",", 
           SubscriptBox["i", "2"], ",", "\[Ellipsis]", ",", 
           SubscriptBox["i", "n"]}], "}"}], ")"}]}], "=", "\[Mu]"}], 
      "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "6e03c67e-eb62-4dcb-b417-77c89bda29a9"],
 ".\[LineSeparator]It can be rewritten in terms of permutations as\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalPi]", "(", "g", ")"}], 
       RowBox[{
        TemplateBox[{"\[Mu]"},
         "Ket"], ":", 
        RowBox[{"g", "\[Element]", 
         SubscriptBox["\[ScriptCapitalS]", "n"]}]}]}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"9a1d5672-996c-4efd-afca-413b03dc07f5"],
 ",\[LineSeparator]where\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Mu]"},
     "Ket"], ":=", 
    TemplateBox[{
      RowBox[{
        UnderscriptBox[
         UnderscriptBox[
          RowBox[{"1", ",", "1", ",", "1"}], "\[UnderBrace]"], 
         SubscriptBox["\[Mu]", "1"]], ",", 
        UnderscriptBox[
         UnderscriptBox[
          RowBox[{"2", ",", "2", ",", "2"}], "\[UnderBrace]"], 
         SubscriptBox["\[Mu]", "2"]], ",", "\[Ellipsis]", ",", 
        UnderscriptBox[
         UnderscriptBox[
          RowBox[{"d", ",", "d", ",", "d"}], "\[UnderBrace]"], 
         SubscriptBox["\[Mu]", "d"]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "228eeb91-6a8d-41cb-8dfb-5f6bee99384d"],
 " ."
}], "TechNoteText",
 CellID->1346838239,ExpressionUUID->"35d0cf16-37f4-4dc7-99c2-df38c2221405"],

Cell[TextData[{
 "States ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPi]", "(", "g", ")"}], 
    TemplateBox[{"\[Mu]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "717c1cee-8b6f-48b1-8cb2-74e44e4cae35"],
 " for different group elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "17630229-69a7-4592-8f31-973577dcee58"],
 " are not always distinct. More specifically, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalPi]", "(", "f", ")"}], 
     TemplateBox[{"\[Mu]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{"\[CapitalPi]", "(", "g", ")"}], 
     TemplateBox[{"\[Mu]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "d90cffbb-ecbf-42d6-9b39-9adb7a74d32f"],
 " whenever ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "=", 
    RowBox[{"g", "\[VeryThinSpace]", "h"}]}], TraditionalForm]],
  ExpressionUUID->"a54bdc31-2dfc-45de-8604-12934417db04"],
 " for some element ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "8a719ccb-ab4b-427b-89a1-41e9971f61e2"],
 " of ",
 ButtonBox["Young subgroup",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungSubgroup"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"06aae081-3959-4402-b97f-6e462b1d9229"],
 ", that is, ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "ddb1d1c5-7a4f-4809-b0a3-b28cfa422d51"],
 " and ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "6d4ec5cf-ccb0-484a-81e0-d349116cb18d"],
 " belongs to the same left coset of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"0485d45c-d3c9-4f70-b7aa-9da213577bcb"],
 ". Therefore, it is convenient to consider a transversal ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["t", "1"], ",", 
      SubscriptBox["t", "2"], ",", "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["\[ScriptCapitalS]", "n"], "\[RightBracketingBar]"}], "/", 
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], 
        "\[RightBracketingBar]"}]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"cf5e4d34-cbb4-4999-b083-b570aa710cc3"],
 " for the left cosets of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"248b1861-d1d7-4fa8-8018-29de7571c0fa"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "2bde107b-4b16-4f36-82a7-963340451eba"],
 ". Then, the permutation module is given by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{"Span", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[CapitalPi]", "(", "t", ")"}], 
       RowBox[{
        TemplateBox[{"\[Mu]"},
         "Ket"], ":", 
        RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}]}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"af2cbc3a-5b70-4ee4-8d26-5377e1e7af6c"],
 "."
}], "TechNoteText",
 CellID->47162978,ExpressionUUID->"a13fb22f-34fc-43f3-893e-44d8cf092a08"],

Cell[TextData[{
 "It is then evident that  permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"4cae819a-30ad-49a5-bcc7-77ed5aba1bcb"],
 " is isomorphic to the left coset module\[LineSeparator]\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{
     RowBox[{"Span", 
      RowBox[{"{", 
       RowBox[{
        TemplateBox[{
          RowBox[{"g", "\[VeryThinSpace]", 
            SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
         "Ket"], ":", 
        RowBox[{"g", "\[Element]", 
         SubscriptBox["\[ScriptCapitalS]", "n"]}]}], "}"}]}], "=", 
     RowBox[{"Span", 
      RowBox[{"{", 
       RowBox[{
        TemplateBox[{
          RowBox[{"t", "\[VeryThinSpace]", 
            SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
         "Ket"], ":", 
        RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}], "}"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"f638ea82-e5c7-45e1-bdfc-42139f4fd565"],
 ",\nand hence an induced representation of the trivial representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"0fbba9e2-64f6-4c75-9b02-2652585972e4"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "58a77491-b46a-4697-9688-10ace2090fd3"],
 "."
}], "TechNoteText",
 CellID->1793598696,ExpressionUUID->"68d2372f-93d2-4b2f-b46c-823c4bc0adf3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Irreducible Subspaces", "TechNoteSection",
 CellID->1029174584,ExpressionUUID->"2faa0256-e09a-4332-8d4e-38762fcdc08b"],

Cell[TextData[{
 "To understand the motivation behind the dual Schur transform, recall that\n\
\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Mu]"], 
     SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"]}]}], TraditionalForm]],
  ExpressionUUID->"03ce4db0-0a52-46f5-b71d-954cfed668ea"],
 "\nwhere ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"52721caf-27ed-4788-a171-a05295f9ddfa"],
 " is the ",
 StyleBox["permutation module",
  FontSlant->"Italic"],
 " associated with ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Mu]", "1"], ",", 
      SubscriptBox["\[Mu]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Mu]", "d"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "ea697c72-7e95-470c-a4e5-6153ee002bd3"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Mu]", "1"], "+", 
     SubscriptBox["\[Mu]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Mu]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"ce7a9140-a40e-4e81-8ec5-9baa647e5bf6"],
 ". "
}], "TechNoteText",
 CellID->1223599087,ExpressionUUID->"92aa0530-6308-4e4b-a613-8595872bca44"],

Cell[TextData[{
 "Permutation module is reducible, and decomposes into ",
 StyleBox[ButtonBox["Specht module",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"68b18b23-db16-43ed-9a1e-0ab1afb9b6a5"],
 ", the basis elements of which are labeled by the standard Young tableaux of \
shape \[Lambda]:\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", 
      RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
      SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"20fe5872-0c78-4f19-a15e-31f9bc5867f0"],
 " ,\nwhere the direct sum ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CirclePlus]", 
    RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
   TraditionalForm]],ExpressionUUID->"a74f4c93-537c-4fa0-8560-c14027eeec50"],
 " is over partitions ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "595097e2-6087-4990-975d-966ce3bd4695"],
 " that ",
 ButtonBox["dominate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/DominatesQ"],
 " ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "996c8bb1-0e21-4214-9093-094059b49dbb"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]}], 
   TraditionalForm]],ExpressionUUID->"f9ce584d-dae2-41c9-a0ca-ce3f0539cd4d"],
 "). The basis vectors of the multiplicity space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"], 
   TraditionalForm]],ExpressionUUID->"2b311b04-413f-4f24-9043-c5d93a45723e"],
 " are labeled by Weyl tableaux of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "6bc95928-f26c-4903-b4e1-d8857fad31cf"],
 " and content ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "eb7c1852-9088-440d-a597-722999ddaa46"],
 ". Putting them together, the tensor product space is decomposed into\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CirclePlus]", "\[Mu]"], 
      SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[CirclePlus]", "\[Mu]"], 
       RowBox[{
        SubscriptBox["\[CirclePlus]", 
         RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
        RowBox[{
         SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
         SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}]}]}], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
        RowBox[{
         SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[CirclePlus]", 
            RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
           SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}], 
          ")"}]}]}], "=", 
       RowBox[{
        SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
        RowBox[{
         SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
         SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"574d96f3-8925-4e51-9e3d-a1cd21ab6280"],
 ",\[LineSeparator]where for the last equality, we have identified\
\[LineSeparator]\t",
 Cell[BoxData[
  RowBox[{
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], "=", 
   RowBox[{
    SubscriptBox["\[CirclePlus]", 
     RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
    SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}]}]],
  ExpressionUUID->"75601da8-d69b-4f51-a21d-8484935f3e9e"],
 " \[LineSeparator]according to the Schur-Weyl duality."
}], "TechNoteText",
 CellID->494624109,ExpressionUUID->"77e193b1-2ea9-404d-9280-766804546a37"],

Cell[TextData[{
 "It is then clear that the desired Schur basis can be found by \
block-diagonalizing the action of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "2d575095-68bc-467e-82c6-c27fd799976f"],
 " on ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"521afdcc-a146-4420-b505-1898bdbaab72"],
 " for all  ",
 Cell[BoxData["\[Mu]"], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d8fde219-cdda-4c3d-b748-d17ba7363f95"],
 ". This is the key idea behind the dual quantum Schur transform."
}], "TechNoteText",
 CellID->1819887037,ExpressionUUID->"1a3253c4-bcd1-4ba1-aa21-e5e86fffefdb"],

Cell[CellGroupData[{

Cell["Remarks", "Subsection",
 CellID->1268898005,ExpressionUUID->"c009e3c0-6dcb-4467-9de9-a965a2e9269a"],

Cell[TextData[{
 "Recall that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"], "\[TildeEqual]", 
    SubsuperscriptBox["\[ScriptCapitalW]", "\[Nu]", "\[Lambda]"]}], 
   TraditionalForm]],ExpressionUUID->"b202619a-3b1e-4d67-9bb3-44672634219b"],
 " for any contents ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "8e21e517-2e9a-43fa-a632-7da510c3f132"],
 " and ",
 Cell[BoxData[
  FormBox["\[Nu]", TraditionalForm]],ExpressionUUID->
  "dfe044bd-44a5-4a9e-9224-bfbaae0a753b"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"shape", "(", "\[Mu]", ")"}], "=", 
    RowBox[{"shape", "(", "\[Nu]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "29965411-2c69-4063-b7ea-3999c640aa82"],
 ". This means that the irreducible space of the unitary group is given by\n\t\
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], "\[Congruent]", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
     SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}], "\[TildeEqual]", 
    RowBox[{
     SubsuperscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}], "\[Prime]"], 
     RowBox[{
      SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"], 
      SubscriptBox["m", "\[Mu]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "3927885c-73ee-463e-8b20-b52bc1e11da7"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "bd585be0-8c38-49d4-b9f3-7f8317676e36"],
 " is the number of distinct permutations of partition ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "d6493257-19ec-4020-8c89-dd2fa74def57"],
 " (assuming that has length ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "95bd377f-1338-4f32-8813-ce8aea92d307"],
 " by padding it with 0 on the right if necessary), and the first direct sum ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CirclePlus]", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "07d3e6c9-2a87-4a66-840c-ea5a66fa7908"],
 " is over contents ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "dbe2d81a-f1cc-4279-914b-3436bdb40914"],
 " (not necessarily partitions) of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f6ae9210-3d86-42a0-a4b1-66304130b3d8"],
 " whereas the second direct sum ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[CirclePlus]", "\[Mu]", "\[Prime]"], TraditionalForm]],
  ExpressionUUID->"5d2f58db-6e9d-447d-a12f-dc12b6e9b078"],
 " is over partitions ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "d71657f2-b347-4ddf-b7b6-6dc178c1d98b"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "520e68a5-212c-4b00-952f-dd2b0c67b2b8"],
 ". The dimension of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"], 
   TraditionalForm]],ExpressionUUID->"ef6ab302-3e08-42dc-8d8b-05472c622a67"],
 " is given by the ",
 ButtonBox["Kostka number",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/KostkaNumber"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"ca208de0-60bb-48e6-bcf0-719c9bc6b878"],
 ", the number of Weyl tableaux of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "bf4df171-17a3-4131-8c3d-cc1d034d31ed"],
 " and content ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "0d0d8346-2dda-4981-a4cf-3b50400463b2"],
 " ,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", "\[VeryThinSpace]", 
     SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}], "=", 
    SubscriptBox["K", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]]}], TraditionalForm]],
  ExpressionUUID->"17edfd15-6396-45cb-82ce-0da2a2891ec5"],
 ". Hence,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalSigma]", "\[Mu]"], 
    SubscriptBox["K", 
     RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], 
    SubscriptBox["m", "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "b166c75f-4fbd-4df2-82dd-d0528bec1a48"],
 " must equal the dimension of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"2e65330c-3edf-4f5e-870a-bfc66f98d343"],
 ", i.e., the number of Weyl tableaux of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "e8f2c696-cfc9-4c77-8ad7-6c8cda802f57"],
 " (of arbitrary content)."
}], "TechNoteText",
 CellID->833580814,ExpressionUUID->"30c04633-bc01-4943-8217-5acd72419aa0"],

Cell[TextData[{
 "According to the ",
 ButtonBox["Frobenius reciprocity theorem",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://en.wikipedia.org/wiki/Frobenius_reciprocity"], None}],
 ", the multiplicity of the trivial representation of the Young subgroup ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"caa94987-7301-4107-a450-c1d9fad12d97"],
 " in the restriction of irreducible representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"5e7c8321-058f-4209-b8bb-0c27d9f5769b"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "ad153e77-3a75-49f8-b182-22845b0d35ac"],
 "  to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"a47a0f74-5d78-404c-923a-bc7bae85995d"],
 " equals the multiplicity of irreducible representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"a7efd595-0152-40d3-bb9d-f2f5b6d7f079"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "f8ecce7c-e0b9-4d13-ab9f-efb1d82caebb"],
 " in the induced representation of the trivial representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"dd7a1893-aea4-4c12-8946-eaa6b611d18c"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "5621f44c-d617-4a36-9b5f-db31d1a9fd37"],
 ", i.e., the permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"8eb3f1e7-aff6-494e-9b35-8bcfabc74066"],
 ". Therefore, both multiplicity factor is given by the ",
 ButtonBox["Kostka number",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/KostkaNumber"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["K", 
    RowBox[{"\[Lambda]", "\[VeryThinSpace]", "\[Mu]"}]], TraditionalForm]],
  ExpressionUUID->"da9f94d1-c6c8-4633-8cfa-043ab4d2f6b1"],
 "."
}], "TechNoteText",
 CellID->325513803,ExpressionUUID->"510ebd90-24eb-4a64-8f8a-54276cdced54"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["QFT for Permutation Module", "TechNoteSection",
 CellID->197057484,ExpressionUUID->"a40a4de9-3be7-4c91-ac4a-c725d43c9b1c"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "090faa03-2d5f-4636-ac91-590b33301a00"],
 " be an integer content of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "50e2c2c8-b7a5-4340-b689-f08f7cd45dfa"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "3e2bd61f-46b7-45f1-9175-c78f1ec23063"],
 " its associated Young subgroup of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "33750cc3-e3d8-468a-a34a-a6340a492f39"],
 ". The permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"44ad8a86-4344-49bb-a258-52b9854fff1a"],
 " is the induced representation of the trivial representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"bd473124-7cfe-4615-baa3-096e6d6eca55"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "c9a2e870-152a-444b-a77d-cfc64e65208f"],
 "; that is, \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], "=", 
    RowBox[{"1", 
     SubsuperscriptBox["\[UpArrow]", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], 
      SubscriptBox["\[ScriptCapitalS]", "n"]]}]}], TraditionalForm]],
  ExpressionUUID->"e60833af-ec52-4e3d-b116-393c4ef2fe06"],
 " ."
}], "TechNoteText",
 CellID->249215652,ExpressionUUID->"7a2340eb-04f9-4abe-920c-0972b99b850a"],

Cell[TextData[{
 "A convenient choice of transversal ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalT]", TraditionalForm]],ExpressionUUID->
  "c0aeafd6-19d2-4ee7-bc89-5a81e6e2af93"],
 " for the (left) cosets of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"b8eb3b84-a6fe-4e32-8062-e7cf5e58e0dd"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "de26390f-551b-43b5-8241-cd45baa3657f"],
 " is given by the set of permutations ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Pi]", "k"], TraditionalForm]],ExpressionUUID->
  "6e91d0ae-85f9-442a-b8ce-be65f0cfca1b"],
 "  that lead the tuple\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     UnderscriptBox[
      UnderscriptBox[
       RowBox[{"1", ",", "...", ",", "1"}], "\[UnderBrace]"], 
      SubscriptBox["\[Mu]", "1"]], ",", 
     UnderscriptBox[
      UnderscriptBox[
       RowBox[{"2", ",", "...", ",", "2"}], "\[UnderBrace]"], 
      SubscriptBox["\[Mu]", "2"]], ",", "\[Ellipsis]", ",", 
     UnderscriptBox[
      UnderscriptBox[
       RowBox[{"n", ",", "...", ",", "n"}], "\[UnderBrace]"], 
      SubscriptBox["\[Mu]", "n"]]}], "}"}], TraditionalForm]],ExpressionUUID->
  "fa4cdaa8-defb-45bd-80b4-5c1392891c5d"],
 "\[LineSeparator]into distinct tuples. In fact, this is how the permutation \
basis is constructed for ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "2772cd74-69f5-4cec-b355-ecd2d2a99bfa"],
 ", and thus the permutation module is isomorphic to the subspace spanned by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["\[Pi]", "k"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "fad20428-99fa-432a-9d92-12242bf90fb7"],
 "."
}], "TechNoteText",
 CellID->261087420,ExpressionUUID->"1e2d9746-e1d7-42b9-8711-ad9b0f54c98a"],

Cell[TextData[{
 "The computational basis of the induced representation is give by\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{"t", "\[VeryThinSpace]", 
          SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}], "|", 
     RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"0454c753-df26-432b-bb5c-3e63f4dfe1fb"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b02c6d9a-c6f7-4d31-b91a-5e0a71dfaa7c"],
 " of the second register denotes the basis vector of the trivial \
representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"492f2d77-a29e-4a89-8c6f-c41995637bd2"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"|", 
        SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], "|"}]]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]], 
     TemplateBox[{"h"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "542dc50e-c1aa-48e0-9600-ecb5f3439784"],
 ".\[LineSeparator]The quantum Fourier transform over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", 
    RowBox[{"\[Mu]", " "}]], TraditionalForm]],ExpressionUUID->
  "96365be2-2727-40e6-aaad-1e610b961f4e"],
 " followed by the inverse quantum Fourier transform over ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "214e95cf-3cef-441e-b7c8-1fdcccd4f6c8"],
 " leads to\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"t", "\[VeryThinSpace]", 
         SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "\[Element]", 
        RowBox[{"[", "\[Lambda]", "]"}]}]}]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], 
     SubscriptBox[
      RowBox[{
       SqrtBox[
        FractionBox[
         SubscriptBox["d", "\[Lambda]"], 
         RowBox[{"|", 
          SubscriptBox["\[ScriptCapitalS]", "n"], "|", 
          RowBox[{"/", 
           RowBox[{"|", 
            SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], "|"}]}]}]]], "[", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "t", ")"}], 
        RowBox[{
         SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
         SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}]}], "]"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"0e0a59a6-0cec-49ae-8b9e-5adf94bb8d48"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", "\[Lambda]", "]"}], TraditionalForm]],ExpressionUUID->
  "35ffcb5e-564f-40cd-a18f-51796a10cdfa"],
 " denotes the set of all standard Young tableaux of shape \[Lambda], and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"4a20c2f5-8da8-4dc3-b33b-19f43638f207"],
 " is the ",
 ButtonBox["Young subgroup projector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungProjector"],
 " onto the irreducible space of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "39a85925-74ef-4cd5-818d-cdedc6b9f36f"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
     SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], ":=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"|", 
       SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], "|"}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", 
       SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"6b91330f-5cf7-44d9-923e-08bbe19b5d68"],
 "."
}], "TechNoteText",
 CellID->1542227521,ExpressionUUID->"f4a4f0c6-80d4-4f6a-a431-2dc4e2bb0a5a"],

Cell[TextData[{
 "In the ",
 ButtonBox["Specht basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"20810429-383f-4981-99df-0a7a5cf4aab6"],
 " is block-diagonal with respect to the ",
 ButtonBox["Gelfand-Tsetlin classes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandClasses"],
 ":\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", "y"}]},
      "Bra"], 
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"y", "'"}]}]},
      "Ket"]}], "=", 
    TagBox[GridBox[{
       {"\[Piecewise]", GridBox[{
          {
           RowBox[{
            TemplateBox[{
              RowBox[{"\[Lambda]", ",", "y"}]},
             "Bra"], 
            SubscriptBox["\[CapitalPi]", "w"], 
            TemplateBox[{
              RowBox[{"\[Lambda]", ",", 
                RowBox[{"y", "'"}]}]},
             "Ket"]}], 
           RowBox[{"y", ",", 
            RowBox[{
             RowBox[{"y", "'"}], "\[Element]", 
             RowBox[{"[", "w", "]"}]}]}]},
          {"0", "otherwise"}
         },
         AllowedDimensions->{2, Automatic},
         Editable->True,
         GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
         GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
         GridBoxSpacings->{"Columns" -> {
             Offset[0.27999999999999997`], {
              Offset[0.84]}, 
             Offset[0.27999999999999997`]}, "Rows" -> {
             Offset[0.2], {
              Offset[0.4]}, 
             Offset[0.2]}},
         Selectable->True]}
      },
      GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
      GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.35]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}],
     "Piecewise",
     DeleteWithContents->True,
     Editable->False,
     SelectWithContents->True,
     Selectable->False,
     StripWrapperBoxes->True]}], TraditionalForm]],ExpressionUUID->
  "d1a73659-9cac-40a6-8694-e0b1f8839b82"],
 "\nwhere each block ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalPi]", "w"], TraditionalForm]],ExpressionUUID->
  "d867e093-91bd-4fa1-b8b3-41cf7b533ee7"],
 " is a rank-1 projector and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", "w", "]"}], TraditionalForm]],ExpressionUUID->
  "0635ef60-c5b9-4e9e-aa62-483f8de10163"],
 " denotes the ",
 ButtonBox["Gelfand-Tsetlin class",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandClass"],
 " corresponding to the ",
 ButtonBox["Weyl tableau",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/WeylTableau"],
 " ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "d604fa12-d425-48fa-abcc-efb12854be4a"],
 " of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "4bb5441c-fb98-484b-8af2-2c4ffbbf3f5b"],
 " and ",
 ButtonBox["content",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungContent"],
 " ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "35156fdc-7798-44d0-ac20-c73fafc14af4"],
 ". The basis vector spanning the one-dimensional subspace can be obtained \
(up to a normalization constant) by applying ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"ff67e494-4936-4b3e-86be-74fb3a9a749f"],
 " on any vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", "Y"}]},
     "Ket"], "\[Element]", 
    RowBox[{"[", "w", "]"}]}], TraditionalForm]],ExpressionUUID->
  "cb7b1037-51ba-4775-bc78-437c2cb13a46"],
 ". Then, noting further that the Young subgroup projector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"988a89df-46b2-452a-b21b-bf53c3a7ef02"],
 " is real orthogonal (assuming Young\[CloseCurlyQuote]s normal \
representation), one can rewrite the above expression as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"t", "\[VeryThinSpace]", 
         SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], ":=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"y", "\[Element]", 
       RowBox[{"[", "\[Lambda]", "]"}]}]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"w", "\[Element]", 
       RowBox[{"[", 
        RowBox[{"y", "|", "\[Mu]"}], "]"}]}]], 
     TemplateBox[{
       SubsuperscriptBox["S", 
        RowBox[{"y", "\[VeryThinSpace]", "w"}], "\[Lambda]"]},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", 
        SubscriptBox["\[ScriptCapitalS]", "n"], "|", 
        RowBox[{"/", 
         RowBox[{"|", 
          SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], "|"}]}]}]]], 
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "\[Element]", 
       RowBox[{"[", "w", "]"}]}]], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"y", "\[VeryThinSpace]", "k"}], "\[Lambda]"], "(", "t", ")"}], 
     
     SqrtBox[
      RowBox[{
       SubsuperscriptBox["\[CapitalGamma]", 
        RowBox[{"k", "\[VeryThinSpace]", "k"}], "\[Lambda]"], "(", 
       SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}]]}]}], 
   TraditionalForm]],ExpressionUUID->"47a93649-3632-4049-9fab-9662edd56564"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"y", "|", "\[Mu]"}], "]"}], TraditionalForm]],ExpressionUUID->
  "4025848a-3399-4288-adbf-6435e29ea616"],
 " denotes the set of all Weyl tableaux of shape \[Lambda] and content \[Mu] \
(which one-to-one correspond to the Gelfand-Tsetlin classes of standard Young \
tableaux). Here, we have defined the Schur basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubsuperscriptBox["S", 
      RowBox[{"y", "\[VeryThinSpace]", "w"}], "\[Lambda]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "90990494-bc40-4482-866e-e48597989b41"],
 " for shape \[Lambda], standard Young tableau ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "e24b4832-c195-4ce9-a366-e4a30982b8ee"],
 " of shape \[Lambda] and Weyl tableaux ",
 Cell[BoxData[
  FormBox["w", TraditionalForm]],ExpressionUUID->
  "390255eb-8c85-4d67-bea4-af71cbd2eea3"],
 " of shape \[Lambda] and content \[Mu] by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubsuperscriptBox["S", 
       RowBox[{"y", "\[VeryThinSpace]", "w"}], "\[Lambda]"]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["\[CapitalGamma]", "^"], "\[Lambda]"], "(", 
      SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Lambda]", ",", 
          RowBox[{"y", "\[VeryThinSpace]", "k"}]}]},
       "Ket"], "/", 
      SqrtBox[
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"k", "\[VeryThinSpace]", "k"}], "\[Lambda]"], "(", 
        SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}]]}]}]}], 
   TraditionalForm]],ExpressionUUID->"874b753e-fe43-4781-b011-4b2e214f61f6"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[Element]", 
    RowBox[{"[", "w", "]"}]}], TraditionalForm]],ExpressionUUID->
  "491503f3-80bf-4edd-a71b-7bce5d58b574"],
 " and the Young subgroup projector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["\[CapitalGamma]", "^"], "\[Lambda]"], "(", 
    SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}], TraditionalForm]],
  ExpressionUUID->"a9527f2f-13a6-4cf1-ba3f-ea1916c9037a"],
 " acts on the Specht basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", "k"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6884e009-ce95-45eb-bde1-c85368ffb98d"],
 "."
}], "TechNoteText",
 InitializationCell->True,
 CellID->1484235684,ExpressionUUID->"ab3a116e-9928-4db9-85a7-ec9fb518f901"],

Cell[TextData[{
 "The inverse of the above relation leads to the required Schur basis\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubsuperscriptBox["S", 
       RowBox[{"y", "\[VeryThinSpace]", "w"}], "\[Lambda]"]},
     "Ket"], "=", 
    RowBox[{
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", 
        SubscriptBox["\[ScriptCapitalS]", "n"], "|", 
        RowBox[{"/", 
         RowBox[{"|", 
          SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], "|"}]}]}]]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{"t", "\[VeryThinSpace]", 
          SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
       "Ket"], "\[CircleTimes]", 
      RowBox[{
       SubsuperscriptBox[
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], " ", "[", 
         RowBox[{
          RowBox[{
           SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "t", ")"}], 
          RowBox[{
           SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", 
           SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}]}], "]"}], 
        RowBox[{"y", "\[VeryThinSpace]", "k"}], "*"], " ", "/", 
       SqrtBox[
        RowBox[{
         SubsuperscriptBox["\[CapitalGamma]", 
          RowBox[{"k", "\[VeryThinSpace]", "k"}], "\[Lambda]"], "(", 
         SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], ")"}]]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"fdcb0dcf-b161-454d-b1bb-6f2b911e6c17"],
 ",\[LineSeparator]where ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "667e283d-c5e2-4b4b-a0f9-2f0188dc2e2a"],
 " is any standard Young tableau belonging to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", "w", "]"}], TraditionalForm]],ExpressionUUID->
  "54aef236-aa1d-4c33-bee1-de7ff045dc37"],
 "."
}], "TechNoteText",
 CellID->1825301940,ExpressionUUID->"6ee31e67-7704-4182-aeab-5c814e4b867e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum Implementation", "TechNoteSection",
 CellID->1892500224,ExpressionUUID->"092ca1f6-db38-4d8d-bafc-c552883fe46c"],

Cell[TextData[{
 "Recall that\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CirclePlus]", "\[Mu]"], 
      SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"]}], "=", 
     RowBox[{
      SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
      RowBox[{
       SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
       SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"c511b6b8-41fd-41d1-b3ef-fb56226a0044"],
 "\[LineSeparator]with \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], ":=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "\[LeftTriangleEqual]", "\[Lambda]"}]], 
     SubsuperscriptBox["\[ScriptCapitalW]", "\[Mu]", "\[Lambda]"]}]}], 
   TraditionalForm]],ExpressionUUID->"cbb3ea7f-78c4-49a9-9ab8-f2477b7a10d5"],
 " .\nThis means that the basis block-diagonalizing the permutation module \
automatically block-diagonalizes the symmetric and unitary groups on the \
tensor-product space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "7642aa0e-25fa-4df3-bbf0-8dd89e15c9dc"],
 "."
}], "TechNoteText",
 CellID->673623048,ExpressionUUID->"480aa7d4-9ee2-4924-88b7-3717d27292c9"],

Cell[TextData[{
 "Then, since the permutation module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalM]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"78ab1dc6-e18c-412a-92eb-3e082736b65b"],
 " is the induced representation of the trivial representation of the Young \
subgroup ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"d7c1885a-045b-42b3-b7d5-63076ec7e151"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "eea85ecf-a9d7-4365-b470-c7f11b92e5d9"],
 ", the basis that block-diagonalizes it is obtained by the quantum Fourier \
transform for the permutation module."
}], "TechNoteText",
 CellID->535222336,ExpressionUUID->"d16981a2-b2c4-40e5-ac2c-e1ff02282593"],

Cell[TextData[{
 "Get the set of all compositions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "13017f57-bd20-44de-989b-97f6781ef702"],
 " with length ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "2715e131-b47f-47aa-b266-64a9cc2d7def"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Mu]", "\[Congruent]", 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Mu]", "1"], ",", 
         RowBox[{
          SubscriptBox["\[Mu]", 
           RowBox[{"2", ","}]], "..."}], ",", 
         SubscriptBox["\[Mu]", "d"]}], ")"}]}], " ", ":", " ", 
      RowBox[{
       SubscriptBox["\[CapitalSigma]", "k"], 
       SubscriptBox["\[Mu]", "k"]}]}], "=", "n"}], "}"}], TraditionalForm]],
  ExpressionUUID->"21608fea-917f-4c93-9368-a5f0521920e4"],
 ".\[LineSeparator]Call the compositions contents."
}], "ItemNumbered",
 CellID->365503015,ExpressionUUID->"23fd78da-17d8-488f-a348-a2fd2e18684d"],

Cell[TextData[{
 "For each content ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "a47ecacc-6bb4-4763-b034-4e7803e2afca"],
 ", get the set of all partitions ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "da29d8af-6c7c-4b30-9970-55181a4f0b4b"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "a159b476-9d76-4962-9084-b36e1870ac02"],
 " with length ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "53cd73d9-a224-4468-bfee-8d72a62da6be"],
 " that dominates \[Mu],\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Lambda]", "\[RightTee]", "n"}], "|", 
     RowBox[{"d", " ", ":", " ", 
      RowBox[{"\[Lambda]", "\[RightTriangleEqual]", "\[Mu]"}]}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"670d6f02-4015-4f59-a0fe-fad31c97a065"],
 "."
}], "ItemNumbered",
 CellID->1047140541,ExpressionUUID->"2ab128d7-3c2c-42e8-8e4d-663dd97a12dd"],

Cell[TextData[{
 "For each \[Lambda] and \[Mu], prepare two quantum register in the product \
state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"t", "\[VeryThinSpace]", 
        SubscriptBox["\[ScriptCapitalS]", "\[Mu]"]}]},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{"0"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "30a2fe37-f85f-4c85-85d5-f476b74bf25e"],
 " (see Figure 1)."
}], "ItemNumbered",
 CellID->1826379949,ExpressionUUID->"36961bfe-f08d-4659-bf48-e46e3cc1d081"],

Cell[TextData[{
 "On the second register, perform the quantum Fourier transform over the \
Young subgroup ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"74c71182-d3a3-4f8a-a273-69c4876fd09a"],
 "."
}], "ItemNumbered",
 CellID->117756948,ExpressionUUID->"68354b9e-a3c0-45e2-9930-47bae5e192a7"],

Cell[CellGroupData[{

Cell[TextData[{
 "On the combined register, perform the inverse quantum Fourier transform \
over the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "dae71c42-7463-42f6-badb-e466eaa92dc8"],
 "."
}], "ItemNumbered",
 CellID->1209420046,ExpressionUUID->"ad970c5f-fb0e-4f0a-bf63-8f95d88bf545"],

