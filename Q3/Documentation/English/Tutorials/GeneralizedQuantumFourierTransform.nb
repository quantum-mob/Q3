Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". The Bratteli diagram for the canonical tower of subgroups for the \
symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "4"], TraditionalForm]],ExpressionUUID->
  "6fa2ffb8-e69e-48a8-818c-190052c4cb67"],
 "."
}], "TechNoteCaption",
 CellID->2032447193,ExpressionUUID->"9c0d37df-b578-422d-b30f-2eb410d14a38"],

Cell[TextData[{
 "The edges out of a node ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "6f44d574-e435-451c-9ed0-9c56c46755b2"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "d30ed92d-3e78-4c79-bf73-b6d3a3287ea3"],
 " represent a complete set of orthogonal embeddings of the corresponding \
representation space into the representations ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "cd3708c5-d3a4-468f-852b-f4ee82ec3671"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "72361e75-a61c-4ad5-b438-49b4098b6c1d"],
 ". Conversely, the edges into a given representation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "559cc176-a1ed-4291-b59e-dcdfc88305b0"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "3533352f-a3cc-4d16-ae88-8b8d83ac97aa"],
 " index a set of mutually orthogonal subspaces of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", 
    SubscriptBox["\[Lambda]", "k"]], TraditionalForm]],ExpressionUUID->
  "e67f6587-3cc5-4be8-b9c2-84e9d42711ae"],
 " whose direct sum represents the decomposition of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", 
    SubscriptBox["\[Lambda]", "k"]], TraditionalForm]],ExpressionUUID->
  "bb3e76d4-77aa-4e75-a9c3-d65580becaa2"],
 " under the restriction of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "0fd0734b-7bfd-48e1-8c98-d66aaa72e059"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "6a701c9a-4f82-4ffa-afb4-fe169d0f3bc3"],
 "."
}], "TechNoteText",
 CellID->1847223333,ExpressionUUID->"c7bcbe66-d136-4e8b-a6b2-68ed3b98491c"],

Cell[TextData[{
 "More generally, the paths from the root node to a node \[Lambda] of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "78a01beb-3772-4d71-8bb6-eb74b3bf5ceb"],
 " index a basis of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"05c65e10-a30c-45eb-8bd5-dc22a61dd310"],
 " with following property: For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalG]", "k"], "\[Subset]", 
    "\[ScriptCapitalG]"}], TraditionalForm]],ExpressionUUID->
  "bada7f35-265b-4a47-9f89-8af9e0f4b771"],
 ", there is a partition of basis vectors of into subsets such that each \
subset spans an irreducible ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "f2fa742f-40e2-40d5-b9d8-c31131b4f3d0"],
 "-invariant subspace. Under this partition, the associated matrix \
representation restricted to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "64a52f33-406f-4231-b561-6869352eda9f"],
 " is block-diagonal, and the blocks corresponding to equivalent irreducible \
representations are identical. Such basis is called a subgroup-adapted basis \
or Gelfand-Tsetlin basis."
}], "TechNoteText",
 CellID->1796261742,ExpressionUUID->"59461f72-a7fc-4160-8325-78ee100213c6"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Definition", "TechNoteSection",
 CellID->48377149,ExpressionUUID->"dae2462c-4c15-46ba-b364-7d256269c569"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"7a1d4d07-9146-4fc7-a7ac-67268f4ff8ff"],
 " is the ",
 StyleBox["right regular basis",
  FontSlant->"Italic"],
 " of group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "4bd71f59-9822-4b01-b827-02c6fc799dc1"],
 ", i.e.,  the canonical basis of the vector space that carries the ",
 StyleBox["right regular representation",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "4e2fece0-6309-49fd-a26b-da62c3706af9"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "69e7b547-730a-4e0b-8858-9d42ba88c3b2"],
 ". For all elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "5c787efe-9700-4666-9c16-e8c93fefd6ff"],
 " and ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "295c22f2-4aa1-46d0-a84b-77437ba0ba16"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "8cb74198-578b-47b7-b423-6993ecea367d"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"h", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "bfdead84-7942-42fe-b85e-93b8656c553b"],
 " ."
}], "TechNoteText",
 CellID->1048209744,ExpressionUUID->"9b5446a8-d007-4ba2-81cd-9879f4f55663"],

Cell[TextData[{
 "The ",
 StyleBox["right Fourier basis",
  FontSlant->"Italic"],
 " of the right regular representation consists of vectors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Rho]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b2f9ac96-bf3b-4eb0-b5be-55a12ba665a0"],
 " defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Rho]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]], 
     TemplateBox[{"g"},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubscriptBox["\[Rho]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", "g", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"a4f43d82-7a33-4c8c-9c43-865d47caa4a9"],
 "\[LineSeparator]for each irreducible representation  ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "37966d08-8194-49bd-9595-6497bcb1a09f"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "1bb9f65c-8f71-470b-8dea-dce96b4690fc"],
 " and each index ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ",", 
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    SubscriptBox["d", "\[Rho]"]}], TraditionalForm]],ExpressionUUID->
  "03884bf7-132f-40d9-a3c7-d2b8f7f65459"],
 ". The basis change from the canonical to Fourier basis is called the ",
 StyleBox["quantum Fourier transform over group",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "1e4f5f37-bfd0-45d6-a042-1a7ac060a1ca"],
 " or simply the ",
 StyleBox["generalized quantum Fourier transform",
  FontSlant->"Italic"],
 ". The inverse transform gives\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"g"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Rho]", "\[Element]", 
       RowBox[{"[", "\[ScriptCapitalG]", "]"}]}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "\[Element]", 
        RowBox[{"[", "\[Rho]", "]"}]}]}]], 
     TemplateBox[{
       RowBox[{"\[Rho]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], " ", 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Rho]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubsuperscriptBox["\[Rho]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "*"], "(", "g", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"bfbbcdf4-8c1e-416e-93f3-a460e7b1ea50"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", "\[ScriptCapitalG]", "]"}], TraditionalForm]],ExpressionUUID->
  "0f0272cb-d2fc-457f-86cc-d1f82b08bed3"],
 " denotes the set of all inequivalent irreducible representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "7cf5637f-01d9-48a3-8e27-300e3d5db21a"],
 " whereas ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", "\[Rho]", "]"}], TraditionalForm]],ExpressionUUID->
  "3f8b9fe2-d7fb-4b54-8b75-23e328fd87b2"],
 " is the index set for the basis of ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "74882cd4-98b1-4d63-9365-152fc02a4d4d"],
 ". Note that the dimension of an irreducible representation ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "31066d3e-b120-4365-970b-483967da84dd"],
 " of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "a987bd1b-d0ee-43f0-b3ee-ec32131d27db"],
 " always divides the order of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "14892f76-c823-4136-bf01-c5fa95e81daf"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
     "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], "/", 
     SubscriptBox["d", "\[Rho]"]}], "\[Element]", "\[DoubleStruckCapitalZ]"}],
    TraditionalForm]],ExpressionUUID->
  "94a1c9d2-c646-4f9d-b54f-e542f6a19bc4"],
 "."
}], "TechNoteText",
 CellID->1790577104,ExpressionUUID->"e9861c2b-5c52-4c9b-8d8d-e3fcc2edcedc"],

Cell[TextData[{
 "Under the group action, the Fourier basis transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Rho]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "\[Element]", 
       RowBox[{"[", "\[Rho]", "]"}]}]], 
     TemplateBox[{
       RowBox[{"\[Rho]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubscriptBox["\[Rho]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}]], "(", "g", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"41fbba6e-0faf-46ff-9094-93f1437ff8d7"],
 "\[LineSeparator]with index ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "d69ec20c-0ef1-41a9-b54c-28d8bb3f0ecc"],
 " belongs to the multiplicity space. Note that every basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Rho]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "92235569-5e70-400a-98a4-0ef464ecfe50"],
 " transforms in the same way regardless of index ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d6cad9fc-7892-4582-a240-de8e610b6959"],
 ". That is to say, in the Fourier basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Rho]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "7f25f008-5fe2-41d7-97d9-8509004f8f05"],
 ", the right regular representation ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "54bd36d9-6d33-493b-acd6-c4be0e5f8a84"],
 " is block-diagonal in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "g", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Rho]"], "\[VeryThinSpace]", 
