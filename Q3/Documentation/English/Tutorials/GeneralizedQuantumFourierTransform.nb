Cell[CellGroupData[{

Cell["Quantum Implementation", "TechNoteSection",
 CellID->1540694772,ExpressionUUID->"981d4a70-17d3-4889-8d1f-60556c19f16d"],

Cell["\<\
We first find the relation between the computational and Fourier bases of the \
induced representation. Based on the relation, we then show how to implement \
the QFT efficiently on a quantum computer.\
\>", "TechNoteText",
 CellID->928984693,ExpressionUUID->"12746b44-b98c-4d3a-b4c1-f1f75e64a5d1"],

Cell[CellGroupData[{

Cell["Fourier Basis for Induced Representation", "Subsection",
 CellID->1799840078,ExpressionUUID->"c652ceed-5272-4e27-9961-e60da73ba1c1"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "d77bcdda-5795-4d34-aff7-d46cb044544f"],
 " be a subgroup of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "42bf6a1f-8839-4203-804a-3ea1a39b2ee4"],
 ". Consider an irreducible representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"d28aaa21-4c68-4ee8-8e77-c1f1e37e6021"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "d7e873e4-05d0-4b81-879f-c5de1292ca66"],
 ", and its induced representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Mu]"], 
    SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "04922181-b14f-41bd-9113-79d2a9826a57"],
 " into ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "7c62cd52-71a3-4406-b3c4-de9c10e88b28"],
 ". Note that an induced representation can be defined for any representation \
of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "af700516-21e3-47c8-80fb-425e62513772"],
 ", but the representation must be irreducible in order to define the QFT for \
its induced representation. We choose an irreducible basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], ":", 
     RowBox[{"j", "\[Element]", 
      RowBox[{"[", 
       SubscriptBox["d", "\[Mu]"], "]"}]}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"f3e935cd-93d6-45bb-b77d-20cd8534c600"],
 " for the representation space of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"42a149c6-fc60-4437-b42f-cc0b2c430e69"],
 " by fixing an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[Element]", 
    RowBox[{"[", 
     SubscriptBox["d", "\[Mu]"], "]"}]}], TraditionalForm]],ExpressionUUID->
  "8f556280-018d-4a48-b030-d7d3ad91ba05"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["\[CapitalGamma]", "^"], "\[Mu]"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Mu]"], "(", "g", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"1dca263a-2139-4d08-b60f-8ec044b9bf13"],
 "."
}], "TechNoteText",
 CellID->2084128042,ExpressionUUID->"318af968-d0e8-4c21-9d82-53eb76f23baa"],

Cell[TextData[{
 "The computational basis of the induced representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["\[CapitalGamma]", "^"], "\[Mu]"], 
    SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", "\[ScriptCapitalG]"], 
    RowBox[{"(", "g", ")"}]}], TraditionalForm]],ExpressionUUID->
  "f10ff931-3720-4090-bf78-8eaa301c6554"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Mu]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{
      RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "ec57a97d-f60f-4287-8d5b-8a404150251b"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["t", "i"], ":", "i"}], "=", "1"}], ",", "2", ",", 
      "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}],
        "/", 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
        "\[RightBracketingBar]"}]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"ad47a031-a333-4984-84b2-57ff2645cbe1"],
 " is a fixed transversal for the right cosets of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "158d6fe1-925e-40f8-ac0b-22b5429b17bc"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "3e27ffde-1a84-41a7-a264-f43a16234320"],
 " and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
      "Ket"], ":", 
     RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"3a3e9550-9eb9-465f-9d56-f9486f100fd1"],
 " is the canonical basis of the coset module (see above)."
}], "TechNoteText",
 CellID->696990997,ExpressionUUID->"89968264-6b5d-46ee-a30e-24f1c43918f8"],

Cell[TextData[{
 "The QFT for the induced representation gives a basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{
        RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
        RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "1c836dd4-36fd-4dd5-9332-9bd71cb4901c"],
 " in which the above representation is block diagonal. Here, ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "a9288076-d040-4117-a2b5-49494a0f06ca"],
 " labels the irreducible representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "d6cc35bd-19ae-4de3-922c-71097e865d86"],
 ", ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "4edb663e-9aab-4ce9-ad45-03131100b774"],
 " the multiplicity space and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "bc5f0f7e-6b69-4182-8580-d93eb497060f"],
 " the irreducible space."
}], "TechNoteText",
 CellID->1074001700,ExpressionUUID->"590299ea-fa56-4c84-880c-fcc1b2cc536f"],

Cell["The QFT is given by", "TechNoteText",
 CellID->1581754903,ExpressionUUID->"c8dcf23e-1f2e-4a54-8443-3ab28963bdb8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
        RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "\[Element]", 
       RowBox[{"[", 
        SubscriptBox["d", "\[Mu]"], "]"}]}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Mu]", ",", 
          RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
       "Ket"]}], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"\[VeryThinSpace]", 
        RowBox[{"|", "\[ScriptCapitalG]", "|"}]}]]], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Mu]"], 
       RowBox[{"|", "\[ScriptCapitalH]", "|", "\[VeryThinSpace]"}]]], 
     SuperscriptBox[
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", 
        RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Mu]"], "(", "h", ")"}], 
       "]"}], "*"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Lambda]"], "(", 
      RowBox[{"h", "\[VeryThinSpace]", "t"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"f6968f41-180c-411b-8604-3d696ea909df"],
 " ."
}], "TechNoteText",
 CellID->334235677,ExpressionUUID->"4ebc9fc1-b0d2-4ff8-b0aa-d8f96abda626"],

Cell[TextData[{
 "for a fixed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[Element]", 
    RowBox[{"[", 
     SubscriptBox["d", "\[Mu]"], "]"}]}], TraditionalForm]],ExpressionUUID->
  "9e81e32b-09db-4652-825d-f959ea825d70"],
 " referring to a multiplicity space of irreducible representation ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "1627992b-f521-4a68-8d3f-53b314b403df"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "78ad4bb1-aacf-4b76-a9ac-993d1282a2e3"],
 ".  One can show that this basis indeed block-diagonalizes the induced \
representation,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["\[CapitalGamma]", "^"], "\[Mu]"], 
      SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "g", ")"}]}], 
     TemplateBox[{
       RowBox[{
         RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", 
      RowBox[{"r", "\[Element]", 
       RowBox[{"[", 
        SubscriptBox["d", "\[Lambda]"], "]"}]}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{
          RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
          RowBox[{"p", "\[VeryThinSpace]", "r"}]}]},
       "Ket"], 
      RowBox[{
       SubsuperscriptBox["\[CapitalGamma]", 
        RowBox[{"r", "\[VeryThinSpace]", "q"}], "\[Lambda]"], "(", "g", 
       ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "791d08b2-0f24-44eb-9bc5-8a4072ab296a"],
 "."
}], "TechNoteText",
 CellID->962178780,ExpressionUUID->"d4c6c849-6eff-4ad2-9b95-1dd639ac2734"],

Cell["The inverse QFT is given by", "TechNoteText",
 CellID->1829286434,ExpressionUUID->"c74b30ed-793d-4cfa-9776-8237a951cdd2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Lambda]", "\[Element]", 
       SubscriptBox["\[ScriptCapitalC]", "\[Mu]"]}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"p", ",", 
       RowBox[{"q", "\[Element]", 
        RowBox[{"[", 
         SubscriptBox["d", "\[Lambda]"], "]"}]}]}]], 
     TemplateBox[{
       RowBox[{
         RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
      "Ket"], 
     SqrtBox[
      FractionBox[
       RowBox[{
        SubscriptBox["d", "\[Mu]"], 
        SubscriptBox["d", "\[Lambda]"]}], 
       RowBox[{
       "|", "\[ScriptCapitalH]", "|", "\[VeryThinSpace]", "|", 
        "\[ScriptCapitalG]", "|"}]]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], 
     SuperscriptBox[
      RowBox[{
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Mu]"], "(", "h", ")"}], 
       " ", "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Lambda]"], "(", 
        RowBox[{"h", "\[VeryThinSpace]", "t"}], ")"}], "]"}], "*"]}]}], 
   TraditionalForm]],ExpressionUUID->"5fd44993-cf8e-445e-bc16-94ef48c42f62"],
 " ,"
}], "TechNoteText",
 CellID->1441205786,ExpressionUUID->"3e535290-82bf-483f-80d1-08c52a7b0cf1"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "a7e72668-d0d1-4ec0-abe9-a55d1c222f09"],
 " is a fixed parameter referring to a multiplicity space of irreducible \
representation \[Mu] of \[ScriptCapitalH] and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalC]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"7153b4fc-bcd1-4d2b-9a84-3134a9e6c258"],
 " is the set of children of \[Mu] in the Bratteli diagram."
}], "TechNoteText",
 CellID->877590789,ExpressionUUID->"a060375b-8e9c-47d6-8447-278c24106b28"],

Cell[TextData[{
 "On quantum computers, the above QFT can be achieved by the QFT over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "28b0b940-0f19-47de-aacb-eea8a8cdeabc"],
 " and then the inverse QFT over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "c59763f9-d419-49c2-9b10-2448e0a443e3"],
 " (both using the right-right convention)."
}], "TechNoteText",
 CellID->1144548367,ExpressionUUID->"b72ee6ce-ed47-4f0a-abbd-66406a252b3b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Recursive Implementation", "Subsection",
 CellID->1680508545,ExpressionUUID->"6d7dc378-cc9f-4c08-8329-301eced0b88e"],

Cell[TextData[{
 "Now, to implement the generalized QFT, let us rewrite ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["v", "i"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3720e292-e45e-4ac0-965f-d6191a8949c2"],
 " as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Mu]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "48959ff9-85d7-486a-b2d0-077f45994b84"],
 " for a fixed ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "0ad7ccf9-83b0-4ff9-a3a1-247f78e13cdf"],
 " and the above equation as"
}], "TechNoteText",
 CellID->763469690,ExpressionUUID->"af247a1e-adce-4d78-a999-37400437392c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"t"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Lambda]", "\[Element]", 
       RowBox[{"\[ScriptCapitalR]", "(", "\[ScriptCapitalG]", ")"}]}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"p", ",", 
       RowBox[{"q", "\[Element]", "\[Lambda]"}]}]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
      "Ket"], 
     SqrtBox[
      FractionBox[
       RowBox[{
        SubscriptBox["d", "\[Mu]"], 
        SubscriptBox["d", "\[Lambda]"]}], 
       RowBox[{
       "|", "\[ScriptCapitalH]", "|", "\[VeryThinSpace]", "|", 
        "\[ScriptCapitalG]", "|"}]]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], 
     SuperscriptBox[
      RowBox[{
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Lambda]"], "(", 
        RowBox[{"t", "\[VeryThinSpace]", "h"}], ")"}], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Mu]"], "(", "h", ")"}], 
       "]"}], "*"]}]}], TraditionalForm]],ExpressionUUID->
  "3341d83d-815a-4879-b585-6db1b537dff6"],
 " ."
}], "TechNoteText",
 CellID->1915370142,ExpressionUUID->"ceac0d2a-53ff-4d7e-8397-0d50715dec8e"],

Cell["\<\
Using the great orthogonality theorem, one can rewrite the above equation as\
\>", "TechNoteText",
 CellID->109833868,ExpressionUUID->"fe8c319d-f45b-4190-962a-98af54124520"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"t"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", 
        RowBox[{"\[Lambda]", "\[Element]", 
         SubscriptBox["\[ScriptCapitalC]", "\[Mu]"]}]], "(", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          OverscriptBox["\[CapitalGamma]", "^"], "\[Lambda]"], "(", "t", 
         ")"}], "\[CircleTimes]", 
        OverscriptBox["I", "^"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{
          RowBox[{"\[Lambda]", ",", 
            SubscriptBox["i", "\[Lambda]"]}]},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{
          RowBox[{"\[Lambda]", ",", 
            SubscriptBox["j", "\[Lambda]"]}]},
         "Ket"]}], ")"}]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Lambda]", "\[Element]", 
        SubscriptBox["\[ScriptCapitalC]", "\[Mu]"]}]], 
      UnderscriptBox["\[CapitalSigma]", "k"], 
      TemplateBox[{
        RowBox[{"\[Lambda]", ",", 
          RowBox[{"k", ";", "\[Mu]"}], ",", "j"}]},
       "Ket"], 
      RowBox[{
       SubsuperscriptBox["\[CapitalGamma]", 
        RowBox[{"k", "\[VeryThinSpace]", 
         SubscriptBox["i", "\[Lambda]"]}], "\[Lambda]"], "(", 
       SubscriptBox["t", "i"], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "f2713e46-8663-4ec6-85b5-7d977da50b16"],
 " ,"
}], "TechNoteText",
 CellID->825024611,ExpressionUUID->"7e944626-57ac-4df0-86ce-af216e0f32b9"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["i", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "6b16f3c7-a0f0-45bb-bbe3-d6f2bd15de00"],
 " (and similarly ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["j", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "4f8f33a8-2172-45e7-957f-60ded36dcd48"],
 ") is the unique path in the Bratteli diagram such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["i", "\[Lambda]"], 
     SubscriptBox["|", 
      RowBox[{"n", "-", "1"}]]}], "=", "i"}], TraditionalForm]],
  ExpressionUUID->"dc630835-d400-4a5f-99ef-56c87cfea7ef"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalC]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"1b36c297-c6ce-4803-b4f2-f7b525c31a5f"],
 " is the set of children of ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "f6f87931-0c54-4f1d-8919-50390ca7301a"],
 " in the Bratteli diagram. This relation induces a basis change from ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"t"},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{
      RowBox[{"\[Mu]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "f1f78ad7-07f3-40c9-9623-39cb492fa1d2"],
 " to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"p", ";", "\[Mu]"}], ",", "q"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "9457716c-a43e-4665-884d-df747ef41a1a"],
 ", the ",
 ButtonBox["Young interim basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungInterimBasis"],
 " (or modified Young-Fourier basis). Another basis change from ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"p", ";", "\[Mu]"}], ",", "q"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6f58d2a8-4380-4979-ba88-9a85298b3347"],
 " to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "972d43b9-0fa3-4f33-9b74-fbb1a15e665e"],
 " is a simple rearrangement. Finally, the inverse transformation of the \
above is given by"
}], "TechNoteText",
 CellID->2026047036,ExpressionUUID->"3275ef52-7866-4e9a-8906-9ca9cc9ce09d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"p", ";", "\[Mu]"}], ",", "q"}]},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]], 
      UnderscriptBox["\[CapitalSigma]", "k"], 
      RowBox[{
       TemplateBox[{"t"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         RowBox[{"\[Mu]", ",", 
           RowBox[{"k", "\[VeryThinSpace]", "q"}]}]},
        "Ket"]}], 
      RowBox[{
       SubsuperscriptBox["\[CapitalGamma]", 
        RowBox[{
         SubscriptBox["k", "\[Lambda]"], "p"}], "\[Lambda]"], "(", "t", 
       ")"}]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]], 
      RowBox[{
       TemplateBox[{"t"},
        "Ket"], "\[CircleTimes]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          OverscriptBox["L", "^"], "(", "t", ")"}], 
         TemplateBox[{
           RowBox[{"\[Lambda]", ",", 
             RowBox[{"p", "\[VeryThinSpace]", 
               SubscriptBox["q", "\[Lambda]"]}]}]},
          "Ket"]}], ")"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "f5028f59-4626-41ed-b562-ac607b3bd862"],
 " ."
}], "TechNoteText",
 CellID->887299626,ExpressionUUID->"a104af8b-baa4-466a-a912-f603d89127ea"],

Cell[TextData[{
 "On a quantum computer, this may be regarded as the controlled-",
 Cell[BoxData[
  FormBox[
   OverscriptBox["L", "^"], TraditionalForm]],ExpressionUUID->
  "4e906d48-f439-4155-aaaa-bc0709f29d81"],
 " transformation on the embedded basis ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"p", "\[VeryThinSpace]", 
         SubscriptBox["q", "\[Lambda]"]}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "64781151-97f0-4f7a-80b8-3f37e46217e2"],
 ". Recall that the left regular representation is a native operator on the \
group algebra residing on the quantum register of the quantum computer."
}], "TechNoteText",
 CellID->699272628,ExpressionUUID->"18886357-8f62-4ee9-978b-1bd4df35039a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Basic Application for Restricted Representations", "TechNoteSection",
 CellID->422878995,ExpressionUUID->"245d9b05-c763-40b1-b2a9-0462014ef372"],

Cell[TextData[{
 "Consider a subgroup ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "71e12380-2a2e-4dd1-a632-72f1aab519f0"],
 " of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "b6434b3f-bd35-43e6-83be-f85202b33d0d"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"2beb84a5-9f73-4ff8-87fc-e4312b7492ef"],
 " be an irreducible representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5d1e0aeb-0b92-4a45-a1d8-a928a7ccb915"],
 " with basis \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{"\[Lambda]", ",", "i"}]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "\[Ellipsis]", ",", 
     SubscriptBox["d", "\[Lambda]"]}], "}"}], TraditionalForm]],
  ExpressionUUID->"00df7445-66b7-463c-84f8-00f717bd350d"],
 ".\[LineSeparator]We want to find a \[ScriptCapitalH]-adapted basis\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{
          RowBox[{"\[Lambda]", "\[DownArrow]", "\[Mu]"}], ",", 
          RowBox[{"k", "\[VeryThinSpace]", "l"}]}]},
       "Ket"], ":", 
      RowBox[{"\[Mu]", "\[Element]", 
       RowBox[{"\[ScriptCapitalR]", "(", "\[ScriptCapitalH]", ")"}]}]}], ",", 
     " ", 
     RowBox[{
      RowBox[{"\[Mu]", "\[Element]", 
       SubscriptBox["\[ScriptCapitalC]", "\[Lambda]"]}], ";", " ", 
      RowBox[{"k", "\[Element]", 
       RowBox[{"[", "\[Mu]", "]"}]}], ";", 
      RowBox[{"l", "=", "1"}]}], ",", "\[Ellipsis]", ",", 
     SubscriptBox["m", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Lambda]"}]]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"71112495-4919-4cca-bdad-4820dfb12bf6"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "\[DownArrow]", "\[Mu]"}], TraditionalForm]],
  ExpressionUUID->"75a9231e-da62-4f36-a72c-f29221498a0b"],
 " indicates the restriction of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "e6faa920-eba5-499c-85d7-3f9746e945c6"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalC]", "\[Lambda]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Mu]", "\[Element]", 
        RowBox[{"\[ScriptCapitalR]", "(", "\[ScriptCapitalH]", ")"}]}], ":", 
       "\[Mu]"}], "->", "\[Lambda]"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"34d6bc26-f7d8-4067-9cd5-967276f4a795"],
 "\[LineSeparator]with \[Mu]\[RightArrow]\[Lambda] indicating that ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "d7c94bf6-4c43-4ddd-9d2a-e9bfcb33b3c6"],
 " is a parent of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "679b6bd0-8122-4418-8cf1-e03dbea82955"],
 " in the Bratteli diagram, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", 
    RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Lambda]"}]], TraditionalForm]],
  ExpressionUUID->"1452ea57-8e2a-4c93-a672-c6e329976c40"],
 " is the multiplicity of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"3c0d6760-6449-4666-ab41-8cbb61e517d5"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "c995b3fa-eda5-4f3d-8964-922f76cf6cc4"],
 ". This basis transforms as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
      UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "h", ")"}]}], 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"q", "\[VeryThinSpace]", "l"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"p", "=", "1"}], 
      SubscriptBox["d", "\[Mu]"]], 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"p", "\[VeryThinSpace]", "l"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Mu]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"7b5ec347-292b-4200-988c-2a01840b8f03"],
 "\[LineSeparator]for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}], TraditionalForm]],
  ExpressionUUID->"10fb3cf1-5f63-46ee-9d76-5a08df26b192"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "f560ba6c-6157-4053-a1e9-087e5398fc7c"],
 " is block-diagonal in this basis. Such a basis is called the \
subgroup-adapted basis."
}], "TechNoteText",
 CellID->366095719,ExpressionUUID->"c37d58ba-9639-4ea8-84a5-7688284ed254"],

Cell[TextData[{
 "The ",
 StyleBox["computational",
  FontSlant->"Italic"],
 " (or ",
 StyleBox["canonical",
  FontSlant->"Italic"],
 ") ",
 StyleBox["basis",
  FontSlant->"Italic"],
 " of the restricted representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "57472846-57cc-432e-98f3-53f3b27920cf"],
 " is \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"h"},
      "Ket"], ":", 
     RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"fb732cd8-e9d8-461f-9fed-d17d679ae433"],
 ". \[LineSeparator]To use the quantum Fourier transform, we regard ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", "i"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "1672a122-1a6d-4bef-a086-c0886a0acdc5"],
 "  as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "0c859c59-80b9-452d-bc86-056a92218037"],
 "  for fixed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "\[Element]", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "92e6d907-c820-499f-bba5-57168e62d95a"],
 ", and extend the computational basis of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "2ec155a2-1434-48f0-92ce-ec1ad1d6ec8c"],
 " to\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      TemplateBox[{"h"},
       "Ket"], "\[CircleTimes]", 
      RowBox[{
       TemplateBox[{"t"},
        "Ket"], ":", 
       RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]}]}], ";", " ", 
     RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}], " ", "}"}], 
   TraditionalForm]],ExpressionUUID->"20d02df1-d0c3-4dd5-b442-3d8adde179ed"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalT]", TraditionalForm]],ExpressionUUID->
  "06c1e55f-f8d7-40ff-bd82-05f447b286d0"],
 " is a transversal for the left cosets of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "87384715-55cc-442c-9a96-66f3ef3caa9e"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "40d24ed0-c63c-4e93-bda9-d798dcdd8a6d"],
 ". The required ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "a362254f-6e68-4b92-98ae-a5cdb9efc560"],
 "-adapted basis has the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{"\[Mu]", ",", 
           RowBox[{"k", "\[VeryThinSpace]", "l"}]}]},
        "Ket"], "\[CircleTimes]", 
       RowBox[{
        TemplateBox[{"t"},
         "Ket"], ":", 
        RowBox[{"\[Mu]", "\[Element]", 
         RowBox[{"\[ScriptCapitalR]", "(", "H", ")"}]}]}]}], ";", " ", "k"}], 
     ",", 
     RowBox[{
      RowBox[{"l", "\[Element]", "\[Mu]"}], ";", " ", 
      RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}]}], " ", "}"}], 
   TraditionalForm]],ExpressionUUID->"c27756e8-faa0-4593-8970-7788432a69ac"],
 ".\[LineSeparator]Here, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"l", "\[Element]", "\[Mu]"}], TraditionalForm]],ExpressionUUID->
  "f1b0bd1e-8fe0-4ef2-ba19-3c30d74ecd27"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}], TraditionalForm]],
  ExpressionUUID->"6d9b51fd-ead0-4ac2-8eec-3dd1721935d9"],
 " together refer to the basis vectors of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", 
    RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Lambda]"}]], TraditionalForm]],
  ExpressionUUID->"b7d2df4e-7c3a-492e-b6c0-1bbf286cda83"],
 "-dimensional multiplicity space of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"bf5ae174-a071-422b-aed7-a183b4fbe583"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "52c7b08c-7d8e-411d-8895-7b4b72b72eb5"],
 ". Note that transversal elements are required because it may happen that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", 
     RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Lambda]"}]], ">", 
    SubscriptBox["d", "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "46c570ff-d9f1-4653-894f-336ad9df0d81"],
 ", and in such a case, ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],ExpressionUUID->
  "2fe9bf8d-06f7-4958-8960-d59b6b6f4ef4"],
 " alone cannot refer to all basis vectors of the multiplicity space. One \
drawback of this approach is that all pairs ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"l", ",", "t"}], ")"}], TraditionalForm]],ExpressionUUID->
  "829409af-4efc-4bf7-b072-443a767e71a6"],
 " may not be linearly independent; the resulting basis may have some \
redundancy."
}], "TechNoteText",
 CellID->2066817213,ExpressionUUID->"f475da23-1b05-4fa7-bd07-9c5a086d77ca"],

Cell[TextData[{
 "Now, performing the inverse quantum Fourier transform over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "5178bdfb-0166-4a75-8619-709bbc28207f"],
 " and successively quantum Fourier transform over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "61b365ac-ad56-4c55-88d2-aa5d2f7d95bd"],
 " leads to\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"k", "\[VeryThinSpace]", "l"}]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"t"},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "\[Element]", "\[Lambda]"}]}]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{
          "i", "\[VeryThinSpace]", "j", 
           "\[VeryThinSpace]\[VeryThinSpace]"}]}]},
      "Ket"], " ", 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalG]", 
        "\[RightBracketingBar]"}]]], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Mu]"], 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
        "\[RightBracketingBar]"}]]], 
     SuperscriptBox[
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", 
        RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"k", "\[VeryThinSpace]", "l"}], "\[Mu]"], "(", "h", ")"}], 
       "\[VeryThinSpace]", "]"}], "*"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", 
      RowBox[{"h", "\[VeryThinSpace]", "t"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"f1cfbe3a-fa39-42e2-8187-bb843f349e94"],
 "\nfor fixed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "\[Element]", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "23a40fed-1282-4398-938e-4dc277e4b5c7"],
 ". One can show that for fixed ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],ExpressionUUID->
  "761d8cd6-a044-47e5-9c34-ddf46d894bb2"],
 ", this Fourier basis transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
      UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "h", ")"}]}], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Mu]", ",", 
          RowBox[{"q", "\[VeryThinSpace]", "l"}]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"t"},
       "Ket"]}]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"p", "\[Element]", "\[Mu]"}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Mu]", ",", 
          RowBox[{"p", "\[VeryThinSpace]", "l"}]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"t"},
       "Ket"]}], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Mu]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"9c8a8122-3b0a-4d18-a474-396aaa7e28b0"],
 " ,\[LineSeparator]and hence it block-diagonalizes ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "879f15a8-280d-4582-a4db-319eaa832623"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalH]", "\[Subset]", "\[ScriptCapitalG]"}], 
   TraditionalForm]],ExpressionUUID->"f7fecd1e-f24d-409d-92ca-f535d9ec7f03"],
 ", meaning that the basis is indeed a subgroup-adapted basis, and the \
associated representation is called a ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "94efdfd8-4966-443d-923c-bb72eda15733"],
 "-adapted representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "d8b26847-ad0e-4344-9a7f-fb44ed4dced8"],
 "."
}], "TechNoteText",
 CellID->1175103296,ExpressionUUID->"b12fc879-ca11-40c1-905a-ba3d909df685"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Basic Application for Induced Representations", "TechNoteSection",
 CellID->295059906,ExpressionUUID->"9545d1a1-5f01-4946-a3e1-5911e0dffca3"],

Cell["\<\
This has already been seen in the quantum implementation of the generalized \
QFT. In fact, the implementation uses the QFT for the induced representation.\
\
\>", "TechNoteText",
 CellID->519577339,ExpressionUUID->"f55295d9-24e8-4605-a9e5-b544eb3ed2d6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Generalized Quantum Phase Estimation", "TechNoteSection",
 CellID->109423420,ExpressionUUID->"c77c4f71-96ad-438b-9910-69d421898baf"],

Cell["\<\
The generalized quantum phase estimation is an algorithm to find an \
irreducible representation in a reducible representation. It uses the \
generalized quantum Fourier transform.\
\>", "TechNoteText",
 CellID->2015731515,ExpressionUUID->"c6e46592-cfd1-48dd-9c59-b662fd9497c3"],

Cell["(to be completed later)", "TechNoteText",
