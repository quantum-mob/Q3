Cell["Restricted Representation", "Subsection",
 CellID->642671379,ExpressionUUID->"8dcbda53-73c7-4f9a-8e57-dfec4efde9c3"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "06b925d6-ca1f-48a2-9538-ee649e6157a1"],
 " be a subgroup of a group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "1c623957-89ba-4a1a-980e-b6e024fcf358"],
 ". Consider a representation ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "85140827-d004-45bd-9575-f368dff33a49"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "8c95e825-aba6-49ce-8ee0-0610b7924bd5"],
 ". The restriction (or restricted representation) of ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "237a5599-f07a-43e0-a5f0-2dc3ff0b5fc1"],
 " to ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "161b6f96-90ea-44d8-a3c7-402fda60f10f"],
 ", denoted by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalGamma]", 
    SubsuperscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "bed295e4-a968-4dc0-9bbf-4437f0748bbe"],
 ", is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalGamma]", 
     SubsuperscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
      "\[ScriptCapitalG]"], 
     RowBox[{"(", "h", ")"}]}], "=", 
    RowBox[{"\[CapitalGamma]", "(", "h", ")"}]}], TraditionalForm]],
  ExpressionUUID->"45bc9933-63a0-4828-8b27-9cbd94922ff2"],
 "\[LineSeparator]for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}], TraditionalForm]],
  ExpressionUUID->"1b169a81-31b7-40b9-862e-1b975f7e775e"],
 "."
}], "TechNoteText",
 CellID->1089892442,ExpressionUUID->"2e5819b6-cd5f-4cf7-bc90-4ccd76b087df"],

Cell[TextData[{
 "In general, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalGamma]", 
    SubsuperscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "aef7e1e4-70ba-46dc-8425-5e122d1fefab"],
 " is not irreducible for ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "dbfcc576-45ca-4656-8dcc-b3125d69d768"],
 " even if ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "5fc6dd11-0453-4e5d-91cd-6a34d0393799"],
 " is an irreducible representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "545cddf3-3a25-4fc8-8762-e7b9254af992"],
 "."
}], "TechNoteText",
 CellID->1134264984,ExpressionUUID->"fc84ea18-7019-40f2-973d-03809e84813f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Induced Representation", "Subsection",
 CellID->901900807,ExpressionUUID->"d0b39e8c-bc15-44b5-85f4-78254bd32a7c"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "a2c7a7b2-37af-4870-bd5c-34607963be96"],
 " be a subgroup of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "16763276-2ef2-4289-9662-97c373eea1c9"],
 ", and choose a transversal ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["t", "i"], ":", "i"}], "=", "1"}], ",", "2", ",", 
      "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}],
        "/", 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
        "\[RightBracketingBar]"}]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"79b1694c-8a83-49f5-8001-6ac086119024"],
 " for the right cosets of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "504d0777-d56a-45cd-9c42-b429ea3a8cc5"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "18660b12-7950-4276-bbf7-95cf6534b3ac"],
 ". Designate the canonical basis of the coset module by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["t", "i"]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     RowBox[{
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], 
      "/", 
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
       "\[RightBracketingBar]"}]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "95e5ea89-8598-47b6-95de-8b05794bfe20"],
 ", or more specifically, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", 
           SubscriptBox["t", "i"]}]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     RowBox[{
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], 
      "/", 
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
       "\[RightBracketingBar]"}]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "864b0dab-65d4-4b30-9bd9-46b43ba12f42"],
 ". The coset module is characterized by the transformation\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
      "Ket"]}], ":=", 
    TemplateBox[{
      RowBox[{
       "\[ScriptCapitalH]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "57c5e98e-765d-4e59-a981-e097e8f144cf"],
 "\[LineSeparator]for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}], TraditionalForm]],
  ExpressionUUID->"def5d6d7-e145-400b-8037-7f3397b7d05a"],
 "."
}], "TechNoteText",
 CellID->151365361,ExpressionUUID->"7ab44c7e-c5f0-4e3d-8c61-44eb3116150b"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "fbbf01dc-61ae-42df-aec8-3ac14a53aaf0"],
 " be a ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "f2df797d-e795-40a5-9a0e-3132c5d893e6"],
 "-dimensional representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "398934ec-c965-4266-8639-e4eb614b8024"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "j"]},
        "Ket"], ":", "j"}], "=", "1"}], ",", "\[Ellipsis]", ",", "d"}], "}"}],
    TraditionalForm]],ExpressionUUID->
  "ac78ab98-e217-4eb9-b598-cd3c7a2e197f"],
 " be the associated basis of representation ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "3a098a43-c4e9-4fcc-a834-a9c3e6bfc2a2"],
 ".   Then, its induced representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalGamma]", 
    SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "8889573b-d8aa-4451-a29a-f2edef34c2bb"],
 " into ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "9b985c21-a31a-496f-8471-554739cbe7ca"],
 " is defined by \n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["\[CapitalGamma]", "^"], 
      SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "g", ")"}]}], 
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "j"]},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
        "Ket"]}], ")"}]}], ":=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{
        OverscriptBox["\[CapitalGamma]", "^"], "(", 
        RowBox[{
         RowBox[{"t", "'"}], "\[VeryThinSpace]", "g", "\[VeryThinSpace]", 
         SuperscriptBox["t", 
          RowBox[{"-", "1"}]], 
         TemplateBox[{
           SubscriptBox["v", "j"]},
          "Ket"]}], ")"}], "\[CircleTimes]", 
       TemplateBox[{
         RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", 
           RowBox[{"t", "'"}]}]},
        "Ket"]}], "=", 
      RowBox[{
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"i", "=", "1"}], "d"], 
       RowBox[{
        TemplateBox[{
          SubscriptBox["v", "i"]},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{
          RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", 
            RowBox[{"t", "'"}]}]},
         "Ket"]}], 
       RowBox[{
        SubscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
        RowBox[{
         RowBox[{"t", "'"}], "g", "\[VeryThinSpace]", 
         SuperscriptBox["t", 
          RowBox[{"-", "1"}]]}], ")"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"5b1cf8ed-17f5-4c17-9c52-b5de11b43660"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "'"}], "\[Element]", "\[ScriptCapitalT]"}], 
   TraditionalForm]],ExpressionUUID->"327a8f25-e011-4b40-9644-55b39ba8e4ac"],
 " is the (unique) transversal element corresponding to the coset that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[VeryThinSpace]", 
    SuperscriptBox["g", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "52f1579f-9853-455a-bba2-b3a5de57b3f8"],
 " belongs to, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", 
     RowBox[{"t", "'"}]}], "=", 
    RowBox[{
    "\[ScriptCapitalH]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
     SuperscriptBox["g", 
      RowBox[{"-", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "6fa420ae-3d45-4efc-85c6-e51786435e76"],
 ". Here, recall that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "'"}], "\[NotEqual]", 
    RowBox[{"t", "\[VeryThinSpace]", 
     SuperscriptBox["g", 
      RowBox[{"-", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "c9d8e2cf-b4f2-45c9-b7f0-f56df0d6a7ab"],
 " in general; ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[VeryThinSpace]", 
    SuperscriptBox["g", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "b199e205-36ac-4042-ab7b-e319a0413a0a"],
 " may not even be an element of the transversal ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalT]", TraditionalForm]],ExpressionUUID->
  "42ee9f27-6a57-4e7c-a271-61ea0ea437b2"],
 "."
}], "TechNoteText",
 CellID->1493491788,ExpressionUUID->"7f9addc9-3469-4d14-aa4b-e37eff6ca8b4"],

Cell[TextData[{
 "Note that in this document, we are using the right cosets. One can also \
construct an induced representation using the left coset module by spanned by \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{
           SubscriptBox["t", "i"], "\[ScriptCapitalH]"}]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     RowBox[{
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], 
      "/", 
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
       "\[RightBracketingBar]"}]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "b1421d2f-6876-4c27-b691-476dec584d35"],
 " such that"
}], "TechNoteText",
 CellID->2052456620,ExpressionUUID->"dabb2afb-311f-4152-9404-1251ab640af6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"t", "\[VeryThinSpace]", "\[ScriptCapitalH]"}]},
      "Ket"]}], ":=", 
    TemplateBox[{
      RowBox[{
       "g", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
        "\[ScriptCapitalH]"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "9843d43d-027c-4380-ba58-28388a41695e"],
 ".\[LineSeparator]In this case, the induced representation is defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["\[CapitalGamma]", "^"], 
      SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "g", ")"}]}], 
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"t"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["v", "j"]},
        "Ket"]}], ")"}]}], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{"t", "'"}]},
       "Ket"], "\[CircleTimes]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         OverscriptBox["\[CapitalGamma]", "^"], "(", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"t", "'"}], 
           RowBox[{"-", "1"}]], "g", "\[VeryThinSpace]", "t"}], ")"}], 
        TemplateBox[{
          SubscriptBox["v", "j"]},
         "Ket"]}], ")"}]}], "=", 
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"i", "=", "1"}], "d"], 
      RowBox[{
       TemplateBox[{
         RowBox[{"t", "'"}]},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["v", "i"]},
        "Ket"]}], 
      RowBox[{
       SubscriptBox["\[CapitalGamma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"t", "'"}], 
         RowBox[{"-", "1"}]], "g", "\[VeryThinSpace]", "t"}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"06691183-03f3-449a-9c39-a771b324a774"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "'"}], "\[Element]", "\[ScriptCapitalT]"}], 
   TraditionalForm]],ExpressionUUID->"323f04cf-43d2-42c8-aac2-e27653e22999"],
 " is the (unique) transversal element corresponding to the coset that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[VeryThinSpace]", "t"}], TraditionalForm]],ExpressionUUID->
  "c56dcab9-7f02-4210-8d4a-b075c85f63d6"],
 " belongs to, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"g", "\[VeryThinSpace]", 
     SubscriptBox["t", "i"], "\[ScriptCapitalH]"}], "\[Element]", 
    RowBox[{
     RowBox[{"t", "'"}], "\[ScriptCapitalH]"}]}], TraditionalForm]],
  ExpressionUUID->"8ccf9d0b-9bc7-4cae-adcf-7c4b57de32d7"],
 ". In this document, we do not consider this construction because it will \
require the left-left convention of the QFT (see below). We want to stick to \
the right-right convention."
}], "TechNoteText",
 CellID->772190316,ExpressionUUID->"66cf0b49-26ba-4b93-83e4-f005539090e7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Subgroup Adapted Basis", "Subsection",
 CellID->1892872179,ExpressionUUID->"81a0b454-d510-424b-8244-75c73696c49d"],

Cell[TextData[{
 "Given a finite group or compact Lie group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "137d772c-0fa4-41f4-ac9b-d5348a0e87db"],
 ", let\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalG]", ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[ScriptCapitalG]", "m"], "\[Superset]", "\[Ellipsis]", "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "2"], "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "1"], "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "0"]}], ":=", 
     RowBox[{"{", "1", "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "68b8be0a-a95e-440c-a7d2-f56a03a131dd"],
 "\[LineSeparator]be a tower of subgroups of length ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "5264c362-ac68-46aa-bc32-63768e8906ba"],
 " for ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "f950c4b3-1b7c-48ce-88b0-73a049e7ec14"],
 ". The corresponding ",
 StyleBox["Bratteli diagram",
  FontSlant->"Italic"],
 " is a leveled graph whose nodes of level ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    "m"}], TraditionalForm]],ExpressionUUID->
  "5f0623c5-1f2f-41ce-944e-5f69cc03d595"],
 " are in one-to-one correspondence with the (inequivalent) irreducible \
representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "b3c75922-1189-47e6-922b-faf2950cec97"],
 ". Conventionally, the vertices in the diagram are referred to by the \
representation with which they are associated. The number of edges from an \
irreducible representation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "da75cc42-d4ee-4337-8948-cc7a65e0d703"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "eefd2fcd-e21a-48ff-af18-570414a680a1"],
 "  to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "e660223a-58e1-4935-89e2-5413411134fb"],
 "  of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "da787db7-91a0-453e-a005-f3a119d2dfe2"],
 " is equal to the ",
 StyleBox["multiplicity",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "29ed711b-5487-4b5b-9473-62228a66d626"],
 " of  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "53d54a18-ecaa-45f6-9f5a-26db79ac8e7b"],
 " in the restriction of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "31301920-f69d-4553-ac2a-7c0f684d5186"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "9a69c00c-204c-4f8e-bc17-0c10dbc8d17a"],
 ". A Bratteli diagram for a given tower is a rooted tree starting from a \
unique irreducible representation of the trivial group. If the branching for \
each ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "k"], "\[Superset]", 
    SubscriptBox["G", 
     RowBox[{"k", "-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "8436aab0-5e20-4e75-826f-c13e0656b1fe"],
 " is multiplicity-free (i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "k"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "8ec93327-189f-4a09-8824-732d3992f755"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "k"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "9a3d74ff-ea72-40eb-9345-88638256464a"],
 " for all ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "f048b415-6ed1-4bab-a7ad-b4385b99cdc3"],
 "), the Bratteli diagram is said to be ",
 StyleBox["multiplicity-free",
  FontSlant->"Italic"],
 " and the tower of subgroup is called ",
 StyleBox["canonical",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1643613333,ExpressionUUID->"c5fa65aa-ee4f-46a8-b1eb-e1727f015e7d"],

Cell[TextData[Cell[BoxData[
 GraphicsBox[
  NamespaceBox["NetworkGraphics",
   DynamicModuleBox[{Typeset`graph = HoldComplete[
     Graph[{
       QuantumMob`Q3`YoungShape[{1}], 
       QuantumMob`Q3`YoungShape[{2}], 
       QuantumMob`Q3`YoungShape[{1, 1}], 
       QuantumMob`Q3`YoungShape[{3}], 
       QuantumMob`Q3`YoungShape[{2, 1}], 
       QuantumMob`Q3`YoungShape[{1, 1, 1}], 
       QuantumMob`Q3`YoungShape[{4}], 
       QuantumMob`Q3`YoungShape[{3, 1}], 
       QuantumMob`Q3`YoungShape[{2, 2}], 
       QuantumMob`Q3`YoungShape[{2, 1, 1}], 
       QuantumMob`Q3`YoungShape[{1, 1, 1, 1}]}, {{{1, 2}, {1, 3}, {2, 4}, {2, 
       5}, {3, 5}, {3, 6}, {4, 7}, {4, 8}, {5, 8}, {5, 9}, {5, 10}, {6, 10}, {
       6, 11}}, Null}, {
