Cell[TextData[{
 "Transversal for Cosets of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "1bde1ebc-1b70-4988-91c5-e1920a035125"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "22dcde20-e322-4a96-8e86-983c7abbcd7d"]
}], "Subsection",
 CellID->1600974025,ExpressionUUID->"4525c5f9-89bf-45ff-bfa4-ff38349930be"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubsuperscriptBox["\[Pi]", 
         RowBox[{"12", "\[Ellipsis]", "\[VeryThinSpace]", "n"}], "k"], ":", 
        "k"}], "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{"n", "-", "1"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "87740b99-f0f5-458c-b9d6-87364416dcd0"],
 " is a transversal for the cosets of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "9947a4de-8aeb-46a0-b993-d8275b3bde76"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "0abf2cab-42f4-43f1-a487-58fcb9ee7ce0"],
 " as illustrated below. This transversal is useful to construct a subgroup \
adapted basis associated with the canonical tower of subgroups of the \
symmetric group."
}], "TechNoteText",
 CellID->1424062491,ExpressionUUID->"112c382c-83be-43ba-8405-f0ee794b1cfc"],

