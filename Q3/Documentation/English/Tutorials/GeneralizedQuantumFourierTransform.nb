Cell[TextData[{
 "Transversal for Cosets of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "f12e6e59-8f55-4286-bbb0-f31b69435718"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "cb726aec-6657-4780-a34f-a1f570d959b7"]
}], "Subsection",
 CellID->1600974025,ExpressionUUID->"9564e84d-a197-4071-9d5a-9ce512a326dc"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubsuperscriptBox["\[Pi]", 
         RowBox[{"12", "\[Ellipsis]", "\[VeryThinSpace]", "n"}], "k"], ":", 
        "k"}], "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      RowBox[{"n", "-", "1"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "cddfabf2-a030-4b04-9898-c8878dc109a5"],
 " is a transversal for the cosets of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "fa6fb3b0-dc27-4f6f-a994-5ca7843d1fb0"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "f6af8e97-0697-410e-b320-7412388b23f3"],
 " as illustrated below. This transversal is useful to construct a subgroup \
adapted basis associated with the canonical tower of subgroups of the \
symmetric group."
}], "TechNoteText",
 CellID->1424062491,ExpressionUUID->"247a635b-9a20-4a68-8354-37015fe47c14"],

