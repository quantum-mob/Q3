Cell["Restricted Representation", "Subsection",
 CellID->642671379,ExpressionUUID->"035f5301-fe42-472f-a6c1-f8c68f09c7ed"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "1e9e4543-ce65-4fc5-8291-6584c8145ee2"],
 " be a subgroup of a group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "551dc491-78e5-4087-86c0-4e4c87139487"],
 ". Consider a representation ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "d1d477ab-99de-4746-9aba-19871c381fc7"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "c73eff1a-33ea-42c8-97dc-a7567840bd59"],
 ". The restriction (or restricted representation) of ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "10ac28eb-ef50-4848-ab04-671ab88acbc3"],
 " to ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "95728ea3-e650-4228-a767-22259d20711f"],
 ", denoted by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"\[Rho]", "\[RightBracketingBar]"}], "\[ScriptCapitalH]"], 
   TraditionalForm]],ExpressionUUID->"73eef9f2-afdc-4600-a538-6e1a8cc578e2"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", 
    SubsuperscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "0cd17cbf-d0e9-402f-b446-ec8bfa2e8aa5"],
 ", is given by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"\[Rho]", "\[RightBracketingBar]"}], "\[ScriptCapitalH]"], 
     RowBox[{"(", "h", ")"}]}], "=", 
    RowBox[{"\[Rho]", "(", "h", ")"}]}], TraditionalForm]],ExpressionUUID->
  "88a95de8-1969-4c02-bfa9-162592c4aaf8"],
 "\[LineSeparator]for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}], TraditionalForm]],
  ExpressionUUID->"e1ebcf13-8afc-43a7-b365-f894ada0308a"],
 "."
}], "TechNoteText",
 CellID->1089892442,ExpressionUUID->"9059c450-a288-40af-8d3a-16e0f2073531"],

Cell[TextData[{
 "In general, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"\[Rho]", "\[RightBracketingBar]"}], "\[ScriptCapitalH]"], 
   TraditionalForm]],ExpressionUUID->"30b4ee8b-31e9-430b-bc17-237b3192056c"],
 " is not irreducible for ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "89cc5399-1efa-4e92-884b-1041e26bca4c"],
 " even if ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "63c44022-3bc6-4e43-b9aa-deef6fffc45d"],
 " is an irreducible representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "dfb94540-e586-405c-8e42-26512b9e723c"],
 "."
}], "TechNoteText",
 CellID->1134264984,ExpressionUUID->"8c3532cc-3a3e-4b4a-b7cd-773a519bffff"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Induced Representation", "Subsection",
 CellID->901900807,ExpressionUUID->"f57124cf-8205-4167-94f1-4e1e75a3dddf"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "5fc6a338-df09-4be6-a466-1ff2355ba6fb"],
 " be a subgroup of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "bcdfb6c9-27fc-40d4-8576-b7678ccc2f25"],
 ", and choose a transversal ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["t", "i"], ":", "i"}], "=", "1"}], ",", "2", ",", 
      "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}],
        "/", 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
        "\[RightBracketingBar]"}]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"ab061d22-4e35-43d0-be84-83fbd06288f2"],
 " for the right cosets of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "f9a78808-668e-41c0-85f7-1591abac103e"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "cc6dcd07-feaa-4b1b-b232-7cd1d5941493"],
 ". Designate the canonical basis of the coset module by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", 
           SubscriptBox["t", "i"]}]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     RowBox[{
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], 
      "/", 
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
       "\[RightBracketingBar]"}]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "ff6c2317-cc46-43be-a8e1-df77ffafab4a"],
 ". The coset module is characterized by the transformation\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
      "Ket"]}], ":=", 
    TemplateBox[{
      RowBox[{
       "\[ScriptCapitalH]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "d869b79b-845d-494d-ad1b-d753fa24ebe1"],
 "\[LineSeparator]for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}], TraditionalForm]],
  ExpressionUUID->"b43802aa-9b54-4313-a9d2-7c82462aa5c1"],
 "."
}], "TechNoteText",
 CellID->151365361,ExpressionUUID->"754b2997-9de5-4163-8a4b-710eb523c603"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "ffb809e8-91b9-434c-bcec-a09659ce9eed"],
 " be a ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "e89581f2-7b13-44d0-82f7-1aa14497f8ca"],
 "-dimensional representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "4f51395a-23c8-4c4f-9883-eca420f7a5a6"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "j"]},
        "Ket"], ":", "j"}], "=", "1"}], ",", "\[Ellipsis]", ",", "d"}], "}"}],
    TraditionalForm]],ExpressionUUID->
  "60a788bc-bdd4-4f0f-820a-1b0eda84f965"],
 " be the associated basis of representation ",
 Cell[BoxData[
  FormBox["\[CapitalGamma]", TraditionalForm]],ExpressionUUID->
  "ec957370-ae4c-4467-8567-2b9fcfd7ea92"],
 ".   Then, its induced representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalGamma]", 
    SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "567f764e-676c-4349-8341-165407b8fa25"],
 " into ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "257f8298-7fb2-439b-bf34-2e0d0951f68f"],
 " is defined by \n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["\[Rho]", "^"], 
      SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "g", ")"}]}], 
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "j"]},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
        "Ket"]}], ")"}]}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         OverscriptBox["\[Rho]", "^"], "(", 
         RowBox[{
          RowBox[{"t", "'"}], "\[VeryThinSpace]", "g", "\[VeryThinSpace]", 
          SuperscriptBox["t", 
           RowBox[{"-", "1"}]]}], ")"}], 
        TemplateBox[{
          SubscriptBox["v", "j"]},
         "Ket"]}], ")"}], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", 
          RowBox[{"t", "'"}]}]},
       "Ket"]}], "=", 
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"i", "=", "1"}], "d"], 
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "i"]},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", 
           RowBox[{"t", "'"}]}]},
        "Ket"]}], 
      RowBox[{
       SubscriptBox["\[CapitalGamma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
       RowBox[{
        RowBox[{"t", "'"}], "g", "\[VeryThinSpace]", 
        SuperscriptBox["t", 
         RowBox[{"-", "1"}]]}], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "f28dfbd4-9677-446c-a091-209842d1f72a"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "'"}], "\[Element]", "\[ScriptCapitalT]"}], 
   TraditionalForm]],ExpressionUUID->"1c31a84f-4d25-4377-a9eb-d3f924bc3b10"],
 " is the (unique) transversal element corresponding to the coset that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[VeryThinSpace]", 
    SuperscriptBox["g", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "de3dbe1d-9d09-40d9-9668-2d29bdae7008"],
 " belongs to, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", 
     RowBox[{"t", "'"}]}], "=", 
    RowBox[{
    "\[ScriptCapitalH]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
     SuperscriptBox["g", 
      RowBox[{"-", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "6c679f6a-0379-4d73-b421-25e463ade1d7"],
 ". Here, recall that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "'"}], "\[NotEqual]", 
    RowBox[{"t", "\[VeryThinSpace]", 
     SuperscriptBox["g", 
      RowBox[{"-", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "218ab4f1-66ca-447d-89d6-0ee719e2ef51"],
 " in general; ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[VeryThinSpace]", 
    SuperscriptBox["g", 
     RowBox[{"-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "6bb2ca85-ed66-48dc-b2f2-a86aaacade0d"],
 " may not even be an element of the transversal ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalT]", TraditionalForm]],ExpressionUUID->
  "392ea225-8f4d-476c-a11a-d970572a7db2"],
 "."
}], "TechNoteText",
 CellID->1493491788,ExpressionUUID->"82aab244-ef20-4e53-b413-325a62db4ceb"],

Cell[TextData[{
 "Remark: In this document, we are using the right coset module. One can also \
construct an induced representation using the left coset module by spanned by \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{
           SubscriptBox["t", "i"], "\[ScriptCapitalH]"}]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     RowBox[{
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], 
      "/", 
      RowBox[{
      "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
       "\[RightBracketingBar]"}]}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "57ed3749-d3fe-4774-8cda-028a92580349"],
 " such that"
}], "TechNoteText",
 CellFrame->{{0, 0}, {0, 0.5}},
 CellFrameColor->GrayLevel[0.75],
 FontSize->12,
 CellID->2052456620,ExpressionUUID->"7c8f3955-7245-4d3b-93fb-d3a356c08e19"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["L", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"t", "\[VeryThinSpace]", "\[ScriptCapitalH]"}]},
      "Ket"]}], ":=", 
    TemplateBox[{
      RowBox[{
       "g", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
        "\[ScriptCapitalH]"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "592a13d0-6098-4ec1-8aaf-91882057e719"],
 ".\[LineSeparator]In this case, the induced representation is defined by\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["\[CapitalGamma]", "^"], 
      SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "g", ")"}]}], 
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"t"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["v", "j"]},
        "Ket"]}], ")"}]}], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{"t", "'"}]},
       "Ket"], "\[CircleTimes]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         OverscriptBox["\[CapitalGamma]", "^"], "(", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"t", "'"}], 
           RowBox[{"-", "1"}]], "g", "\[VeryThinSpace]", "t"}], ")"}], 
        TemplateBox[{
          SubscriptBox["v", "j"]},
         "Ket"]}], ")"}]}], "=", 
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"i", "=", "1"}], "d"], 
      RowBox[{
       TemplateBox[{
         RowBox[{"t", "'"}]},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubscriptBox["v", "i"]},
        "Ket"]}], 
      RowBox[{
       SubscriptBox["\[CapitalGamma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", 
       RowBox[{
        SuperscriptBox[
         RowBox[{"t", "'"}], 
         RowBox[{"-", "1"}]], "g", "\[VeryThinSpace]", "t"}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"1f6be8c5-6e46-4b9c-a118-ece5eac85ac1"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "'"}], "\[Element]", "\[ScriptCapitalT]"}], 
   TraditionalForm]],ExpressionUUID->"b699b016-7cca-4bc5-93ce-ac1f3fe326dd"],
 " is the (unique) transversal element corresponding to the coset that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "\[VeryThinSpace]", "t"}], TraditionalForm]],ExpressionUUID->
  "0dfd23c7-ddd2-41cc-aebc-d0387830cadb"],
 " belongs to, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
    "g", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", "\[ScriptCapitalH]"}], "\[Element]", 
    RowBox[{
     RowBox[{"t", "'"}], "\[ScriptCapitalH]"}]}], TraditionalForm]],
  ExpressionUUID->"449dd769-ac40-4326-9698-b9c75412b67d"],
 ". In this document, we do not consider this construction because it will \
require the left-left convention of the QFT (see below). We want to stick to \
the right-right convention."
}], "TechNoteText",
 FontSize->12,
 CellID->772190316,ExpressionUUID->"ad11d809-889d-4611-bf55-88c864126fdc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Subgroup Adapted Basis", "Subsection",
 CellID->1892872179,ExpressionUUID->"6d51a409-a3c9-4411-a1a2-e0557d086903"],

Cell[TextData[{
 "Given a finite group or compact Lie group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "73257416-03c0-4377-a56e-3ac03371cc31"],
 ", let\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalG]", ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[ScriptCapitalG]", "m"], "\[Superset]", "\[Ellipsis]", "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "2"], "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "1"], "\[Superset]", 
      SubscriptBox["\[ScriptCapitalG]", "0"]}], ":=", 
     RowBox[{"{", "1", "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "c8c2cce1-7023-468b-9c63-e0f7e71bd12d"],
 "\[LineSeparator]be a tower of subgroups of length ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "5317c4b7-b252-48d1-9f53-54454667af1b"],
 " for ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5eb6bc62-8951-4bab-b0a5-051481614106"],
 ". The corresponding ",
 StyleBox["Bratteli diagram",
  FontSlant->"Italic"],
 " is a leveled graph whose nodes of level ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    "m"}], TraditionalForm]],ExpressionUUID->
  "b0fc8349-f77d-4b21-8fea-ba9bc03b6ef5"],
 " are in one-to-one correspondence with the (inequivalent) irreducible \
representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "8332261b-cc17-460a-a32d-e6fd80cf6c33"],
 ". Conventionally, the vertices in the diagram are referred to by the \
representation with which they are associated. The number of edges from an \
irreducible representation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "bc6b0ca5-b1d6-48a5-a754-ef4b38c66582"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "1d3766e5-f93d-4411-b9fd-1d4fa070856e"],
 "  to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "c0e208b7-db3d-4d30-986c-106a1a76c5ab"],
 "  of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "670ae698-12fc-4fed-9647-ec5e53f69c00"],
 " is equal to the ",
 StyleBox["multiplicity",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "372de498-de8f-49bb-8b96-7801fb1343b6"],
 " of  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "0e8b348c-e6db-4e7a-b2b9-a72c8c53ccab"],
 " in the restriction of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "3403b003-5437-4490-9242-7966e6779efa"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "767997fb-4754-4718-a5fc-233631d6fa26"],
 ". A Bratteli diagram for a given tower is a rooted tree starting from a \
unique irreducible representation of the trivial group. If the branching for \
each ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "k"], "\[Superset]", 
    SubscriptBox["G", 
     RowBox[{"k", "-", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "d1cd0006-b64a-4ca8-bf83-90fe0b2173b8"],
 " is multiplicity-free (i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "k"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "bea215ef-12f2-44ab-aee1-f89b59f5d014"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "k"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "500bf597-9d5e-4fb0-bf3f-501909d43a45"],
 " for all ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "6e202238-1b73-45e5-a163-3ce42b093a97"],
 "), the Bratteli diagram is said to be ",
 StyleBox["multiplicity-free",
  FontSlant->"Italic"],
 " and the tower of subgroup is called ",
 StyleBox["canonical",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1643613333,ExpressionUUID->"313c57ed-dc0f-429c-900f-d795423905e2"],

Cell[TextData[Cell[BoxData[
 GraphicsBox[
  NamespaceBox["NetworkGraphics",
   DynamicModuleBox[{Typeset`graph = HoldComplete[
     Graph[{
       QuantumMob`Q3`YoungShape[{1}], 
