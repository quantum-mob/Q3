Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". The Bratteli diagram for the canonical tower of subgroups for the \
symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "4"], TraditionalForm]],ExpressionUUID->
  "0f0f17ee-7692-48ec-8e0b-b8480b28d464"],
 "."
}], "TechNoteCaption",
 CellID->2032447193,ExpressionUUID->"4eb209c1-a658-4123-920c-3cb30b01e830"],

Cell[TextData[{
 "The edges out of a node ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "fe6884e3-d4bd-4cdb-85e8-d40558dbbf2e"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "644f33df-3c0f-4200-8d08-1c52e5880776"],
 " represent a complete set of orthogonal embeddings of the corresponding \
representation space into the representations ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "9ef2c856-50d3-4311-a43a-e66eecb0221b"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "c51ca307-c848-4c10-80be-351bcb8b64f9"],
 ". Conversely, the edges into a given representation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "22cab15a-da68-4601-b85c-49d50b3b6d4f"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "176ee0ba-6397-4a3a-98c4-ada23a8da0d3"],
 " index a set of mutually orthogonal subspaces of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", 
    SubscriptBox["\[Lambda]", "k"]], TraditionalForm]],ExpressionUUID->
  "6738892d-049b-468b-96f3-9694698c7cdb"],
 " whose direct sum represents the decomposition of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", 
    SubscriptBox["\[Lambda]", "k"]], TraditionalForm]],ExpressionUUID->
  "a8674506-7cf7-4c02-96b4-40288d0613d9"],
 " under the restriction of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "k"], TraditionalForm]],ExpressionUUID->
  "b876daad-80f4-4f65-8a3f-4f15f60fecc1"],
 " to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", 
    RowBox[{"k", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "6995d5d1-e5eb-4a67-a740-5d4df5006414"],
 "."
}], "TechNoteText",
 CellID->1847223333,ExpressionUUID->"f849034f-cc9b-4571-995e-7a07d9cd7cc5"],

Cell[TextData[{
 "More generally, the paths from the root node to a node \[Lambda] of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "cf69e5a7-c0e3-42a1-a1c7-982aceb6d823"],
 " index a basis of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"7f23605d-14b6-42b6-941d-547c95c411c0"],
 " with following property: For any ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalG]", "k"], "\[Subset]", 
    "\[ScriptCapitalG]"}], TraditionalForm]],ExpressionUUID->
  "99b8050e-1126-417c-a436-023811c03224"],
 ", there is a partition of basis vectors of into subsets such that each \
subset spans an irreducible ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "c5eb81c6-cdaa-4dd0-bd87-d4002793c216"],
 "-invariant subspace. Under this partition, the associated matrix \
representation restricted to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalG]", "k"], TraditionalForm]],ExpressionUUID->
  "56d138f2-8174-477f-80d0-fe003d5d02b5"],
 " is block-diagonal, and the blocks corresponding to equivalent irreducible \
representations are identical. Such basis is called a subgroup-adapted basis \
or Gelfand-Tsetlin basis."
}], "TechNoteText",
 CellID->1796261742,ExpressionUUID->"ca11fe3b-bfd6-4f15-b0fa-2a084580e92d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Definition", "TechNoteSection",
 CellID->48377149,ExpressionUUID->"dd138d3c-eb7b-4c3d-9c2b-c698c2a74ab6"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"g"},
      "Ket"], "|", 
     RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"c78029b9-b573-4a63-8b2a-9480e0d929dd"],
 " is the ",
 StyleBox["right regular basis",
  FontSlant->"Italic"],
 " of group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "7a7d153f-6a52-4d61-afc0-9e1ca89e3f6f"],
 ", i.e.,  the canonical basis of the vector space that carries the ",
 StyleBox["right regular representation",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "9ada785b-91e4-42ed-9657-9d99bd1cba7e"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "207d8613-ec58-4fb4-a536-fec7a1d9c66c"],
 ". For all elements ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "42f8a58a-6a6c-4419-89fa-a382fc1bc6d5"],
 " and ",
 Cell[BoxData[
  FormBox["h", TraditionalForm]],ExpressionUUID->
  "bced2ab6-fac2-4f27-90bf-dc092b631c35"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "b35cef1b-5601-48b0-ab16-3a32136007af"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{"h"},
      "Ket"]}], "=", 
    TemplateBox[{
      RowBox[{"h", "\[VeryThinSpace]", 
        SuperscriptBox["g", 
         RowBox[{"-", "1"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "053b7dfb-128c-466d-9f4b-e932714d56f8"],
 " ."
}], "TechNoteText",
 CellID->1048209744,ExpressionUUID->"16b416b9-0f97-4414-9ee2-ce1c73a9d3af"],

Cell[TextData[{
 "The ",
 StyleBox["right Fourier basis",
  FontSlant->"Italic"],
 " consists of vectors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f5a0a71c-be5a-42bd-81c5-64538ebf0638"],
 " defined by\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"g", "\[Element]", "\[ScriptCapitalG]"}]], 
     TemplateBox[{"g"},
      "Ket"], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "fffb2cd9-0cf6-4a8f-bbd1-3769042f416d"],
 "\[LineSeparator]for each irreducible representation  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"bb8c10e2-3721-486d-a98f-889eaca6ea72"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "f91c7b40-240a-4334-a71e-77149fb174f7"],
 " and each index ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", ",", 
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    SubscriptBox["d", "\[Lambda]"]}], TraditionalForm]],ExpressionUUID->
  "f4903d1b-4390-4ec8-8fd4-ae1e03c1e94d"],
 ". The basis change from the canonical to Fourier basis is called the ",
 StyleBox["quantum Fourier transform over group",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "f901d2c6-cbb4-4307-8415-f82835680d9c"],
 " or simply the ",
 StyleBox["generalized quantum Fourier transform",
  FontSlant->"Italic"],
 ". The inverse transform gives\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"g"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Lambda]"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "=", "1"}]}], 
      SubscriptBox["d", "\[Lambda]"]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], " ", 
     SuperscriptBox[
      RowBox[{
       SqrtBox[
        FractionBox[
         SubscriptBox["d", "\[Lambda]"], 
         RowBox[{"|", "\[ScriptCapitalG]", "|"}]]], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
        ")"}], "]"}], "*"]}]}], TraditionalForm]],ExpressionUUID->
  "47bf3dfa-2760-4be1-8735-6c39edf978ed"],
 " ,\nwhere the first summation is over all inequivalent irreducible \
representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "f0ac4f33-8fbb-4873-b634-02d64792e218"],
 ". Note that the dimension of an irreducible representation ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "384fac3b-2ed3-4b3b-ad4a-40278de42ef9"],
 " of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "2620e158-b566-4891-97a0-faeeccbe6230"],
 " always divides the order of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "55c9709f-f504-449f-adc4-f0aa866e4de5"],
 ", i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
     "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}], "/", 
     RowBox[{"dim", "(", "\[Lambda]", ")"}]}], "\[Element]", 
    "\[DoubleStruckCapitalZ]"}], TraditionalForm]],ExpressionUUID->
  "30cc1c0f-b649-4133-a98f-8c56a08cdb16"],
 "."
}], "TechNoteText",
 CellID->1790577104,ExpressionUUID->"7739ea0c-fe5e-48aa-aa05-8218787b5ff8"],

Cell[TextData[{
 "Under the group action, the Fourier basis transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["R", "^"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", "g", 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "069911f5-6e29-4dff-a530-25de9129ce6c"],
 "\[LineSeparator]with index ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "26b20a66-141c-4619-97e9-3c13c72de035"],
 " labeling the multiplicity space. Note that every basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "62d1551f-3664-4001-9e1a-6906798c0709"],
 " transforms in the same way regardless of index ",
 Cell[BoxData[
  StyleBox["i", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4b5ffdd6-d9a6-4ebf-85fc-b3e7723c7e8f"],
 ". That is to say, in the Fourier basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "7185afc2-c7a4-43ae-8686-bd9f3851a0f1"],
 ", the right regular representation ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "72baade2-8300-41e1-9327-24eb9f083af6"],
 " is block-diagonal in the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "(", "g", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], "\[VeryThinSpace]", 
     RowBox[{
      SubscriptBox["I", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"]}]}]}], TraditionalForm]],
