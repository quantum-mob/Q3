Cell[CellGroupData[{

Cell["Conventions", "Subsection",
 CellID->1959714211,ExpressionUUID->"ae024739-30f0-4903-b2fe-5c2c59ca396f"],

Cell["\<\
Depending on which of the left and right regular representations is assumed \
and on whether the representation space is put on the left or right side of \
the multiplicity space, we have four conventions.\
\>", "TechNoteText",
 CellID->305439758,ExpressionUUID->"30394f8e-6cf6-4d42-a229-98df76626d96"],

