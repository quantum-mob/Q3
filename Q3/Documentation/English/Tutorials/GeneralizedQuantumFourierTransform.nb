Cell[CellGroupData[{

Cell["Quantum Implementation", "TechNoteSection",
 CellID->1540694772,ExpressionUUID->"5b14f9b0-a0a0-4498-b1ca-fb0ad5e00c45"],

Cell["\<\
We first find the Fourier basis for the induced representation. Using the \
resulting basis, we then show how to implement the QFT efficiently on a \
quantum computer.\
\>", "TechNoteText",
 CellID->1186339691,ExpressionUUID->"6a5ada07-a11a-413b-9c9f-45644c54902a"],

Cell[CellGroupData[{

Cell["Fourier Basis for Induced Representation", "Subsection",
 CellID->1799840078,ExpressionUUID->"2d668295-eb1a-48df-9cc4-b4eab763a8ab"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "2a3d7b5b-d661-4d32-a345-42bcff8b2e4a"],
 " be a subgroup of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "8f9b853c-607d-40af-bee9-6f85fe085985"],
 ". Consider an irreducible representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"eb14e3f7-8595-4c47-97cd-a8110192eec2"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "a5d4d703-265e-4e23-bf6b-e5c4fbf0e7b7"],
 ", and its induced representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Mu]"], 
    SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "d8652e83-5707-4f3f-b882-d14496b5acfc"],
 " into ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "9bb7dbb0-9b30-4260-b979-5609ae46f0e5"],
 ". Note that an induced representation can be defined for any representation \
of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "62faf737-8172-442b-8f6e-1457f7c603a7"],
 ", but the representation must be irreducible in order to define the QFT for \
its induced representation. We choose an irreducible basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], ":", 
     RowBox[{"j", "\[Element]", 
      RowBox[{"[", 
       SubscriptBox["d", "\[Mu]"], "]"}]}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"4170a8f3-3adb-43e8-a2c4-16e333e2df8e"],
 " for the representation space of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"e9559d5f-5157-42f5-96f3-f44454a79e75"],
 " by fixing an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[Element]", 
    RowBox[{"[", 
     SubscriptBox["d", "\[Mu]"], "]"}]}], TraditionalForm]],ExpressionUUID->
  "9c714f1f-b576-441c-bbfd-ee36917c211b"],
 ",\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["\[CapitalGamma]", "^"], "\[Mu]"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "k"], 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "k"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"k", "\[VeryThinSpace]", "j"}], "\[Mu]"], "(", "g", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"8167189a-b983-433f-9638-82e8e4f0558b"],
 "."
}], "TechNoteText",
 CellID->2084128042,ExpressionUUID->"0a0a4594-1dd5-4928-830d-7e11d752f5c2"],

Cell[TextData[{
 "The computational basis of the induced representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     OverscriptBox["\[CapitalGamma]", "^"], "\[Mu]"], 
    SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", "\[ScriptCapitalG]"], 
    RowBox[{"(", "g", ")"}]}], TraditionalForm]],ExpressionUUID->
  "2eb9444a-43f9-4fcf-9d5a-e9ac9b816bc0"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Mu]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{
      RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "74f2103e-1c74-406c-8295-3f2de14e0234"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalT]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["t", "i"], ":", "i"}], "=", "1"}], ",", "2", ",", 
      "\[Ellipsis]", ",", 
      RowBox[{
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalG]", "\[RightBracketingBar]"}],
        "/", 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
        "\[RightBracketingBar]"}]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"d6ac1232-55b1-409a-ba11-fbf06f3692f5"],
 " is a fixed transversal for the right cosets of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "6662854e-6c0e-4bcf-8953-5141292da080"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "61e86b86-1012-4e55-b352-88fbec4adf95"],
 " and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
      "Ket"], ":", 
     RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"11fa2a8e-7c56-4372-bf1f-2eba89b3ecb6"],
 " is the canonical basis of the coset module (see above)."
}], "TechNoteText",
 CellID->696990997,ExpressionUUID->"e8d631ab-1455-4cc2-8e46-e63c91c0e70f"],

Cell[TextData[{
 "The QFT for the induced representation gives a basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{
        RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
        RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "eba6149b-89ba-42b8-89c3-ab98b08b83ce"],
 " in which the above representation is block diagonal. Here, ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "f86ff681-5af5-4bd1-8ae6-39183eefbdc5"],
 " labels the irreducible representations of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "6ab0220a-7131-4b14-bba9-5d9d22d80000"],
 ", ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "690ab5b1-8cf0-4a71-8907-24cd53eef954"],
 " the multiplicity space and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "b9e50792-8a4b-42a0-9faa-ffcc5754f3e5"],
 " the irreducible space."
}], "TechNoteText",
 CellID->1074001700,ExpressionUUID->"b6b51467-b336-439d-888b-06dc2b48682a"],

Cell["The QFT is given by", "TechNoteText",
 CellID->1581754903,ExpressionUUID->"ed09cf16-6534-4aa5-bd69-51811a2d7a63"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
        RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "\[Element]", 
       RowBox[{"[", 
        SubscriptBox["d", "\[Mu]"], "]"}]}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Mu]", ",", 
          RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
       "Ket"]}], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{"\[VeryThinSpace]", 
        RowBox[{"|", "\[ScriptCapitalG]", "|"}]}]]], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Mu]"], 
       RowBox[{"|", "\[ScriptCapitalH]", "|", "\[VeryThinSpace]"}]]], 
     SuperscriptBox[
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", 
        RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Mu]"], "(", "h", ")"}], 
       "]"}], "*"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Lambda]"], "(", 
      RowBox[{"h", "\[VeryThinSpace]", "t"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"e4947181-0d21-44fb-9741-5efc4457353d"],
 " ."
}], "TechNoteText",
 CellID->334235677,ExpressionUUID->"d70b056c-3d98-4a90-823a-fd5f994f81c0"],

Cell[TextData[{
 "for a fixed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[Element]", 
    RowBox[{"[", 
     SubscriptBox["d", "\[Mu]"], "]"}]}], TraditionalForm]],ExpressionUUID->
  "cb66628f-de59-4e0a-b353-e84c7e412cfc"],
 " referring to a multiplicity space of irreducible representation ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "5171d096-9d23-4485-92ea-124a94a355fc"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "05136ce8-dce7-45b3-ba2f-a73cc7849068"],
 ".  One can show that this basis indeed block-diagonalizes the induced \
representation,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["\[CapitalGamma]", "^"], "\[Mu]"], 
      SubsuperscriptBox["\[UpArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "g", ")"}]}], 
     TemplateBox[{
       RowBox[{
         RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", 
      RowBox[{"r", "\[Element]", 
       RowBox[{"[", 
        SubscriptBox["d", "\[Lambda]"], "]"}]}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{
          RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
          RowBox[{"p", "\[VeryThinSpace]", "r"}]}]},
       "Ket"], 
      RowBox[{
       SubsuperscriptBox["\[CapitalGamma]", 
        RowBox[{"r", "\[VeryThinSpace]", "q"}], "\[Lambda]"], "(", "g", 
       ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "622dff70-efe9-4bf8-a21e-f19ad493a72e"],
 "."
}], "TechNoteText",
 CellID->962178780,ExpressionUUID->"3a6d4205-160f-48b7-b7a2-aa350c890afe"],

Cell["The inverse QFT is given by", "TechNoteText",
 CellID->1829286434,ExpressionUUID->"114aaf2d-15f5-47b8-9352-c9a5273b332e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"\[ScriptCapitalH]", "\[VeryThinSpace]", "t"}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Lambda]", "\[Element]", 
       SubscriptBox["\[ScriptCapitalC]", "\[Mu]"]}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"p", ",", 
       RowBox[{"q", "\[Element]", 
        RowBox[{"[", 
         SubscriptBox["d", "\[Lambda]"], "]"}]}]}]], 
     TemplateBox[{
       RowBox[{
         RowBox[{"\[Mu]", ";", "\[Lambda]"}], ",", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
      "Ket"], 
     SqrtBox[
      FractionBox[
       RowBox[{
        SubscriptBox["d", "\[Mu]"], 
        SubscriptBox["d", "\[Lambda]"]}], 
       RowBox[{
       "|", "\[ScriptCapitalH]", "|", "\[VeryThinSpace]", "|", 
        "\[ScriptCapitalG]", "|"}]]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], 
     SuperscriptBox[
      RowBox[{
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Mu]"], "(", "h", ")"}], 
       " ", "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Lambda]"], "(", 
        RowBox[{"h", "\[VeryThinSpace]", "t"}], ")"}], "]"}], "*"]}]}], 
   TraditionalForm]],ExpressionUUID->"5fc76f0f-3f2c-4b89-844a-d55d91c2d26d"],
 " ,"
}], "TechNoteText",
 CellID->1441205786,ExpressionUUID->"43526f12-a99e-44d8-93d0-45e087328569"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "595466d2-b4dc-4369-9e1c-23c3841ec078"],
 " is a fixed parameter referring to a multiplicity space of irreducible \
representation \[Mu] of \[ScriptCapitalH] and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalC]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"b95000a3-205a-48c9-987a-ec81698ea28f"],
 " is the set of children of \[Mu] in the Bratteli diagram."
}], "TechNoteText",
 CellID->877590789,ExpressionUUID->"1e2030bc-a477-447c-bf88-bd6d55e53bf9"],

Cell[TextData[{
 "On quantum computers, the above QFT can be achieved by the QFT over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "e0b92ec7-85ef-4e46-a412-73125accfdbc"],
 " and then the inverse QFT over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "568bc5a7-95af-415d-8abd-f2449b529d7b"],
 " (both using the right-right convention)."
}], "TechNoteText",
 CellID->1144548367,ExpressionUUID->"1e0f79dc-7fc2-4dae-9159-386c375c3efe"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Recursive Implementation", "Subsection",
 CellID->1680508545,ExpressionUUID->"023d9629-9dae-4cab-9d25-d569797b8ff8"],

Cell[TextData[{
 "Now, to implement the generalized QFT, let us rewrite ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["v", "i"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "54dd0b4c-59ac-40b7-bf23-83637cf8a639"],
 " as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Mu]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "127c974d-2724-4b0c-b9d5-30a21560b6eb"],
 " for a fixed ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "c9156bfc-97d5-4193-8b7f-5c719eafd87d"],
 " and the above equation as"
}], "TechNoteText",
 CellID->763469690,ExpressionUUID->"8b97999c-0101-4358-9226-76a1be74833b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"t"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Lambda]", "\[Element]", 
       RowBox[{"\[ScriptCapitalR]", "(", "\[ScriptCapitalG]", ")"}]}]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"p", ",", 
       RowBox[{"q", "\[Element]", "\[Lambda]"}]}]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}]}]},
      "Ket"], 
     SqrtBox[
      FractionBox[
       RowBox[{
        SubscriptBox["d", "\[Mu]"], 
        SubscriptBox["d", "\[Lambda]"]}], 
       RowBox[{
       "|", "\[ScriptCapitalH]", "|", "\[VeryThinSpace]", "|", 
        "\[ScriptCapitalG]", "|"}]]], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], 
     SuperscriptBox[
      RowBox[{
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Lambda]"], "(", 
        RowBox[{"t", "\[VeryThinSpace]", "h"}], ")"}], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Mu]"], "(", "h", ")"}], 
       "]"}], "*"]}]}], TraditionalForm]],ExpressionUUID->
  "3c8b73d1-cbf6-4948-be17-17a77f270fd4"],
 " ."
}], "TechNoteText",
 CellID->1915370142,ExpressionUUID->"93a18825-370d-440c-ad41-c0adb01ff0e8"],

Cell["\<\
Using the great orthogonality theorem, one can rewrite the above equation as\
\>", "TechNoteText",
 CellID->109833868,ExpressionUUID->"99dc78c7-b45f-447e-a58f-620d66a298ae"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"t"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", 
        RowBox[{"\[Lambda]", "\[Element]", 
         SubscriptBox["\[ScriptCapitalC]", "\[Mu]"]}]], "(", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          OverscriptBox["\[CapitalGamma]", "^"], "\[Lambda]"], "(", "t", 
         ")"}], "\[CircleTimes]", 
        OverscriptBox["I", "^"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{
          RowBox[{"\[Lambda]", ",", 
            SubscriptBox["i", "\[Lambda]"]}]},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{
          RowBox[{"\[Lambda]", ",", 
            SubscriptBox["j", "\[Lambda]"]}]},
         "Ket"]}], ")"}]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Lambda]", "\[Element]", 
        SubscriptBox["\[ScriptCapitalC]", "\[Mu]"]}]], 
      UnderscriptBox["\[CapitalSigma]", "k"], 
      TemplateBox[{
        RowBox[{"\[Lambda]", ",", 
          RowBox[{"k", ";", "\[Mu]"}], ",", "j"}]},
       "Ket"], 
      RowBox[{
       SubsuperscriptBox["\[CapitalGamma]", 
        RowBox[{"k", "\[VeryThinSpace]", 
         SubscriptBox["i", "\[Lambda]"]}], "\[Lambda]"], "(", 
       SubscriptBox["t", "i"], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "d2069737-40e8-45b0-b6c1-0c280bc0b2ac"],
 " ,"
}], "TechNoteText",
 CellID->825024611,ExpressionUUID->"e9ca5c75-9f70-4f3c-8067-9631668da846"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["i", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "601526d3-9268-477f-bacb-2609ed956fd6"],
 " (and similarly ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["j", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "d29e881f-d542-4b7a-b99a-5b143a29860d"],
 ") is the unique path in the Bratteli diagram such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["i", "\[Lambda]"], 
     SubscriptBox["|", 
      RowBox[{"n", "-", "1"}]]}], "=", "i"}], TraditionalForm]],
  ExpressionUUID->"39d7fed1-9272-412d-aa97-c554c4f15681"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalC]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"a6737c76-4f0c-48ff-82b5-14826a739101"],
 " is the set of children of ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "8f3c9eb5-3298-41f5-abf3-a3de4dbd15de"],
 " in the Bratteli diagram. This relation induces a basis change from ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"t"},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{
      RowBox[{"\[Mu]", ",", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "37ff91cc-ce13-49ef-89b5-7f44c8715740"],
 " to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"p", ";", "\[Mu]"}], ",", "q"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6833eea2-23cd-41b2-8db5-d914014cf118"],
 ", the ",
 ButtonBox["Young interim basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungInterimBasis"],
 " (or modified Young-Fourier basis). Another basis change from ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"p", ";", "\[Mu]"}], ",", "q"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f68ba71b-d8fc-452d-9fb0-e5840ee4a25d"],
 " to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8e82ece4-7d8c-43c6-9fab-25d32858a8fc"],
 " is a simple rearrangement. Finally, the inverse transformation of the \
above is given by"
}], "TechNoteText",
 CellID->2026047036,ExpressionUUID->"c775aa17-25eb-4a3c-9dab-fc2516b7381c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", 
        RowBox[{"p", ";", "\[Mu]"}], ",", "q"}]},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]], 
      UnderscriptBox["\[CapitalSigma]", "k"], 
      RowBox[{
       TemplateBox[{"t"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         RowBox[{"\[Mu]", ",", 
           RowBox[{"k", "\[VeryThinSpace]", "q"}]}]},
        "Ket"]}], 
      RowBox[{
       SubsuperscriptBox["\[CapitalGamma]", 
        RowBox[{
         SubscriptBox["k", "\[Lambda]"], "p"}], "\[Lambda]"], "(", "t", 
       ")"}]}], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]], 
      RowBox[{
       TemplateBox[{"t"},
        "Ket"], "\[CircleTimes]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          OverscriptBox["L", "^"], "(", "t", ")"}], 
         TemplateBox[{
           RowBox[{"\[Lambda]", ",", 
             RowBox[{"p", "\[VeryThinSpace]", 
               SubscriptBox["q", "\[Lambda]"]}]}]},
          "Ket"]}], ")"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "59613e01-ad1f-4fe4-8d8a-c66646da6bb8"],
 " ."
}], "TechNoteText",
 CellID->887299626,ExpressionUUID->"04bf3327-0eed-4f2a-8c3d-80ea38968233"],

Cell[TextData[{
 "On a quantum computer, this may be regarded as the controlled-",
 Cell[BoxData[
  FormBox[
   OverscriptBox["L", "^"], TraditionalForm]],ExpressionUUID->
  "11d246c9-321d-41d2-a0f1-e035cafaf12b"],
 " transformation on the embedded basis ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"p", "\[VeryThinSpace]", 
         SubscriptBox["q", "\[Lambda]"]}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "58892e4a-66db-49b4-b449-1039b0b963b0"],
 ". Recall that the left regular representation is a native operator on the \
group algebra residing on the quantum register of the quantum computer."
}], "TechNoteText",
 CellID->699272628,ExpressionUUID->"4499034d-7086-4204-a09a-b4de85646de4"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Basic Application for Restricted Representations", "TechNoteSection",
 CellID->422878995,ExpressionUUID->"1135f07c-cb10-411e-be14-92c2befe8e85"],

Cell[TextData[{
 "Consider a subgroup ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "7f1e1cd0-a659-4193-893c-63ffa9c32eb1"],
 " of a finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "b33894cb-8c70-4ce6-88ee-10207a7cba1c"],
 ". Let ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"cf48141e-3e13-402a-888e-f5b258ec84e2"],
 " be an irreducible representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "a4990af8-9d23-4852-92ae-a05d66115904"],
 " with basis \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{"\[Lambda]", ",", "i"}]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "\[Ellipsis]", ",", 
     SubscriptBox["d", "\[Lambda]"]}], "}"}], TraditionalForm]],
  ExpressionUUID->"bb17ae6e-bd8e-40fa-8576-00d4b43d3b70"],
 ".\[LineSeparator]We want to find a \[ScriptCapitalH]-adapted basis\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{
          RowBox[{"\[Lambda]", "\[DownArrow]", "\[Mu]"}], ",", 
          RowBox[{"k", "\[VeryThinSpace]", "l"}]}]},
       "Ket"], ":", 
      RowBox[{"\[Mu]", "\[Element]", 
       RowBox[{"\[ScriptCapitalR]", "(", "\[ScriptCapitalH]", ")"}]}]}], ",", 
     " ", 
     RowBox[{
      RowBox[{"\[Mu]", "\[Element]", 
       SubscriptBox["\[ScriptCapitalC]", "\[Lambda]"]}], ";", " ", 
      RowBox[{"k", "\[Element]", "\[Mu]"}], ";", 
      RowBox[{"l", "=", "1"}]}], ",", "\[Ellipsis]", ",", 
     SubscriptBox["m", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Lambda]"}]]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"656420f8-7864-4a74-be13-1afb5fb163c1"],
 " ,\nwhere ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "\[DownArrow]", "\[Mu]"}], TraditionalForm]],
  ExpressionUUID->"a649c160-5859-43fd-939d-8fcf13cfa83c"],
 " indicates the restriction of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "3c105f02-bd2f-4d32-b18d-80c9d75ab84f"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalC]", "\[Lambda]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Mu]", "\[Element]", 
        RowBox[{"\[ScriptCapitalR]", "(", "\[ScriptCapitalH]", ")"}]}], ":", 
       "\[Mu]"}], "->", "\[Lambda]"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"8c67a026-adc2-481f-9093-5a67fbf5b6bc"],
 "\[LineSeparator]with \[Mu]\[RightArrow]\[Lambda] indicating that ",
 Cell[BoxData[
  FormBox["\[Mu]", TraditionalForm]],ExpressionUUID->
  "330876e6-241a-4d24-be9a-87dae2308899"],
 " is a parent of ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "fb05278a-e940-4cb4-873e-984a55f7184c"],
 " in the Bratteli diagram, and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", 
    RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Lambda]"}]], TraditionalForm]],
  ExpressionUUID->"ed68ac12-9eb4-4583-ad9e-638e56cfe7c2"],
 " is the multiplicity of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"ed803d97-c0e2-4ae2-9b73-4e2e9a74a646"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "c4a2f5d6-fd48-4a1d-98e9-16450d2db7da"],
 ". This basis transforms as\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
      UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "h", ")"}]}], 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"q", "\[VeryThinSpace]", "l"}]}]},
      "Ket"]}], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"p", "=", "1"}], 
      SubscriptBox["d", "\[Mu]"]], 
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"p", "\[VeryThinSpace]", "l"}]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Mu]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"2f2713ed-88ed-414e-9c46-9901fc7604c1"],
 "\[LineSeparator]for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}], TraditionalForm]],
  ExpressionUUID->"56d04c4c-b0e9-4008-8574-85f5817d8417"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "c4a5e6d2-cabe-4ce8-8ac7-db9c3fe05123"],
 " is block-diagonal in this basis. Such a basis is called the \
subgroup-adapted basis."
}], "TechNoteText",
 CellID->366095719,ExpressionUUID->"cb0335e7-edf2-4e5b-ad64-d3fb051bc4f8"],

Cell[TextData[{
 "The ",
 StyleBox["computational",
  FontSlant->"Italic"],
 " (or ",
 StyleBox["canonical",
  FontSlant->"Italic"],
 ") ",
 StyleBox["basis",
  FontSlant->"Italic"],
 " of the restricted representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "f9563dba-bd08-4c6d-b317-ed0fb13456e0"],
 " is \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{"h"},
      "Ket"], ":", 
     RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]}], "}"}], 
   TraditionalForm]],ExpressionUUID->"18197b56-e1b3-447b-967f-3b7f089c2a5c"],
 ". \[LineSeparator]To use the quantum Fourier transform, we regard ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", "i"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "385b18a0-ddbb-4442-857f-8c39616d3917"],
 "  as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "eeb48210-e854-44d3-a6c8-a02a0a17a6ea"],
 "  for fixed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "\[Element]", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "35f39e46-2d55-4311-bec9-e2f6fe29a37f"],
 ", and extend the computational basis of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "8a4d65b1-bc8d-4a56-913b-8122a829f948"],
 " to\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      TemplateBox[{"h"},
       "Ket"], "\[CircleTimes]", 
      RowBox[{
       TemplateBox[{"t"},
        "Ket"], ":", 
       RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]}]}], ";", " ", 
     RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}], " ", "}"}], 
   TraditionalForm]],ExpressionUUID->"1f2c13c2-5451-4558-a10d-4c59ace623d1"],
 ",\nwhere ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalT]", TraditionalForm]],ExpressionUUID->
  "d8355040-1dec-4e36-b879-ed766d4af549"],
 " is a transversal for the left cosets of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "7b71a657-417f-474a-a619-7baa6c8bc664"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "a2b0c20f-067a-4ed6-bfea-5aae4dec8794"],
 ". The required ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "a67f1e91-99ca-4cae-9aad-e6f67f243670"],
 "-adapted basis has the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{"\[Mu]", ",", 
           RowBox[{"k", "\[VeryThinSpace]", "l"}]}]},
        "Ket"], "\[CircleTimes]", 
       RowBox[{
        TemplateBox[{"t"},
         "Ket"], ":", 
        RowBox[{"\[Mu]", "\[Element]", 
         RowBox[{"\[ScriptCapitalR]", "(", "H", ")"}]}]}]}], ";", " ", "k"}], 
     ",", 
     RowBox[{
      RowBox[{"l", "\[Element]", "\[Mu]"}], ";", " ", 
      RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}]}]}], " ", "}"}], 
   TraditionalForm]],ExpressionUUID->"2873ad2e-d212-4f3c-a749-de339dba1490"],
 ".\[LineSeparator]Here, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"l", "\[Element]", "\[Mu]"}], TraditionalForm]],ExpressionUUID->
  "244aeb3e-02ec-4cf9-a95d-6e0c7ad873e8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "\[Element]", "\[ScriptCapitalT]"}], TraditionalForm]],
  ExpressionUUID->"8ffcbdd7-5d9d-4ffa-bdc5-c08aff109113"],
 " together refer to the basis vectors of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", 
    RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Lambda]"}]], TraditionalForm]],
  ExpressionUUID->"281c0ed3-ba64-4341-b438-e5b2df9e2d3f"],
 "-dimensional multiplicity space of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]],
  ExpressionUUID->"35b331f7-b216-4afa-949e-5673610b4bc6"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "3a5949c1-5027-4ae5-8eac-7add2dd95c1e"],
 ". Note that transversal elements are required because it may happen that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", 
     RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Lambda]"}]], ">", 
    SubscriptBox["d", "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "9c76866b-f116-4bf6-bfea-533ea021e0c0"],
 ", and in such a case, ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],ExpressionUUID->
  "eb477373-e591-4769-ab95-95d76d6b382e"],
 " alone cannot refer to all basis vectors of the multiplicity space. One \
drawback of this approach is that all pairs ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"l", ",", "t"}], ")"}], TraditionalForm]],ExpressionUUID->
  "bcd02d4b-787b-472b-b5ea-51530bcab2ac"],
 " may not be linearly independent; the resulting basis may have some \
redundancy."
}], "TechNoteText",
 CellID->2066817213,ExpressionUUID->"76f5e160-dd78-483c-8f76-7ccb1a84f9fe"],

Cell[TextData[{
 "Now, performing the inverse quantum Fourier transform over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "f866f041-0d57-44e0-94ae-70a8d0fd9f20"],
 " and successively quantum Fourier transform over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5e8d7e85-3892-4daf-8d79-437e01b37eeb"],
 " leads to\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Mu]", ",", 
         RowBox[{"k", "\[VeryThinSpace]", "l"}]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"t"},
      "Ket"]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", 
       RowBox[{"j", "\[Element]", "\[Lambda]"}]}]], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         RowBox[{
          "i", "\[VeryThinSpace]", "j", 
           "\[VeryThinSpace]\[VeryThinSpace]"}]}]},
      "Ket"], " ", 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Lambda]"], 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalG]", 
        "\[RightBracketingBar]"}]]], 
     SqrtBox[
      FractionBox[
       SubscriptBox["d", "\[Mu]"], 
       RowBox[{
       "\[LeftBracketingBar]", "\[ScriptCapitalH]", 
        "\[RightBracketingBar]"}]]], 
     SuperscriptBox[
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", 
        RowBox[{"h", "\[Element]", "\[ScriptCapitalH]"}]], "[", 
       RowBox[{
        SubsuperscriptBox["\[CapitalGamma]", 
         RowBox[{"k", "\[VeryThinSpace]", "l"}], "\[Mu]"], "(", "h", ")"}], 
       "\[VeryThinSpace]", "]"}], "*"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", 
      RowBox[{"h", "\[VeryThinSpace]", "t"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"7817dbad-a00a-437e-adba-426862f6205e"],
 "\nfor fixed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "\[Element]", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "9a5cb8a8-a00f-4445-a4ce-5c1dc259bd05"],
 ". One can show that for fixed ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],ExpressionUUID->
  "43a60275-bff3-44a6-a528-48186a11d9db"],
 ", this Fourier basis transforms as\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
      UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
       "\[ScriptCapitalG]"], 
      RowBox[{"(", "h", ")"}]}], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Mu]", ",", 
          RowBox[{"q", "\[VeryThinSpace]", "l"}]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"t"},
       "Ket"]}]}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{"p", "\[Element]", "\[Mu]"}]], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Mu]", ",", 
          RowBox[{"p", "\[VeryThinSpace]", "l"}]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"t"},
       "Ket"]}], 
     RowBox[{
      SubsuperscriptBox["\[CapitalGamma]", 
       RowBox[{"p", "\[VeryThinSpace]", "q"}], "\[Mu]"], "(", "h", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"1c0e5043-521d-4450-9f9b-91036c9873df"],
 " ,\[LineSeparator]and hence it block-diagonalizes ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], 
    UnderoverscriptBox["\[DownArrow]", "\[ScriptCapitalH]", 
     "\[ScriptCapitalG]"]}], TraditionalForm]],ExpressionUUID->
  "fba10649-24b8-41d3-9314-51aa5227213a"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalH]", "\[Subset]", "\[ScriptCapitalG]"}], 
   TraditionalForm]],ExpressionUUID->"f1fc6b39-440b-4ae6-aee0-eeeb1fe183e7"],
 ", meaning that the basis is indeed a subgroup-adapted basis, and the \
associated representation is called a ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "b610e335-6aae-46bc-be49-fa0d598b2222"],
 "-adapted representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "c890309c-b564-488a-8ab7-05e091f86e3c"],
 "."
}], "TechNoteText",
 CellID->1175103296,ExpressionUUID->"589550a4-a7a7-44cf-a56e-78311af657e9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Basic Application for Induced Representations", "TechNoteSection",
 CellID->295059906,ExpressionUUID->"dd26356e-2aa2-4e4b-85ab-ee56dae08b85"],

Cell["\<\
This has already been seen in the quantum implementation of the generalized \
QFT. In fact, the implementation uses the QFT for the induced representation.\
\
\>", "TechNoteText",
 CellID->519577339,ExpressionUUID->"4333b9a0-d30b-48bc-81d9-1db3eca16ff5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Generalized Quantum Phase Estimation", "TechNoteSection",
 CellID->109423420,ExpressionUUID->"4f744664-4370-4b1d-ba21-225a70c67c58"],

Cell["\<\
The generalized quantum phase estimation is an algorithm to find an \
irreducible representation in a reducible representation. It uses the \
generalized quantum Fourier transform.\
\>", "TechNoteText",
 CellID->2015731515,ExpressionUUID->"513d3044-04de-4e4c-a25e-c71169b8fb68"],

Cell["(to be completed later)", "TechNoteText",
