Cell["\<\
To verify that it is indeed a transversal, get the left and right cosets from \
the transversal:\
\>", "TechNoteText",
 CellID->896081908,ExpressionUUID->"5fddce8a-6f06-48e3-a058-aa2f70a26dca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"left", "=", 
   RowBox[{"Sort", "/@", 
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"PermutationProduct", "[", 
        RowBox[{"#2", ",", "#1"}], "]"}], "&"}], ",", "trs", ",", "sub"}], 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Thread", "[", 
    RowBox[{"trs", "->", "left"}], "]"}], "//", "PermutationForm"}], "//", 
  "TableForm"}]}], "Input",
 CellLabel->"In[8]:=",
 CellID->375199477,ExpressionUUID->"44d540b8-5a73-446f-88af-12c073316372"],

