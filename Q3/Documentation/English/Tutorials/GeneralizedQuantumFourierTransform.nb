P4amDrt9hOS/45SHhROq/Qj3EpKH8WHyAHqboxE=
         "], 0.02956393075586808]}, 
       {Hue[0.6, 0.5, 1.], EdgeForm[{GrayLevel[0], Opacity[
        0.7]}], {
         DiskBox[{1.998095539958495, 2.179740589045631}, 0.02956393075586808],
          InsetBox[
          StyleBox[
           FormBox[
            InterpretationBox[
             TagBox[GridBox[{
                {
                 ItemBox["\<\" \"\>",
                  Frame->True,
                  StripOnInput->False]}
               },
               AutoDelete->False,
               
               GridBoxItemSize->{
                "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
              "Grid"],
             QuantumMob`Q3`YoungShape[{1}]],
            TraditionalForm],
           StripOnInput->False,
           FontSize->Medium], 
          Offset[{0, 2}, {1.998095539958495, 2.209304519801499}], 
          ImageScaled[{0.5, 0}],
          BaseStyle->"Graphics"]}, {
         DiskBox[{1.0898702945228156`, 1.4531603926970875`}, 
          0.02956393075586808], InsetBox[
