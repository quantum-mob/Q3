Cell["\<\
To verify that it is indeed a transversal, get the left and right cosets from \
the transversal:\
\>", "TechNoteText",
 CellID->896081908,ExpressionUUID->"cb6aa06f-6225-4248-b0c9-031e176645b4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"left", "=", 
   RowBox[{"Sort", "/@", 
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"PermutationProduct", "[", 
        RowBox[{"#2", ",", "#1"}], "]"}], "&"}], ",", "trs", ",", "sub"}], 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Thread", "[", 
