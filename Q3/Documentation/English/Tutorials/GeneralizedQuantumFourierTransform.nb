         RowBox[{"Range", "@", "$n"}], "}"}]}], ",", "k"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "0", ",", 
       RowBox[{"$n", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"trs", "//", "PermutationForm"}]}], "Input",
 CellLabel->"In[6]:=",
