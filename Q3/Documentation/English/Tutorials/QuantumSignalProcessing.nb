Cell[CellGroupData[{

Cell["Quantum Signal Processing Theorem", "TechNoteSection",
 CellID->1988062027,ExpressionUUID->"96fc3136-a075-4204-9f91-0493d0a58bd3"],

Cell[TextData[{
 StyleBox["Theorem",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(GSLWiebe, 2019)"]], "https://doi.org/10.1145/3313276.3316366"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "92512503-5c18-42f1-aab3-f561c9bb5024"],
 ": There exists a set of phases ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[Phi]", "0"], ",", 
       SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Phi]", "d"]}], "}"}], "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", 
      RowBox[{"d", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "a6a1e8f2-dbb1-455e-a76a-5ecdeb0159b5"],
 " such that the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Times]", "2"}], TraditionalForm]],ExpressionUUID->
  "9d9ea53b-c9ed-4485-be42-873d90eaf9b2"],
 " unitary matrix"
}], "TechNoteText",
 CellID->1701303988,ExpressionUUID->"d72062c2-6178-4847-b8d9-9ea3b76fed87"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"Q", "(", "x", ")"}], 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["x", "2"]}]]}]},
        {
         RowBox[{"\[VeryThinSpace]", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
           RowBox[{
            SuperscriptBox["Q", "*"], "(", "x", ")"}], 
           SqrtBox[
            RowBox[{"1", "-", 
             SuperscriptBox["x", "2"]}]]}]}], 
         RowBox[{
          SuperscriptBox["P", "*"], "(", "x", ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "57b99ba6-2e7f-4919-8a7c-7a1483650ff4"],
 " "
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->71366511,ExpressionUUID->"0fff25c0-4a5a-453b-a0dc-b48b7db30e25"],

Cell["with", "TechNoteText",
 CellID->1161075351,ExpressionUUID->"c32cedda-3aa8-4a96-9670-eae4ab6a7ca5"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "93064578-cfdb-430e-82be-3411394ede29"],
 " ,        \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", "(", "x", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"x", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}], "x"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d998fb7c-5708-4785-bcce-03f5d8b98cf3"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->9523968,ExpressionUUID->"3eb8bdb5-00e9-45a8-b48a-7a4ff7e44f3d"],

Cell[TextData[{
 StyleBox["if and only if",
  FontSlant->"Italic"],
 " polynomials ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "88cbcceb-5a55-40b4-be3c-5d852ce07125"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "e3748e89-4277-4af2-b2cf-f3c05e3072dd"],
 " satisfy"
}], "TechNoteText",
 CellID->297671935,ExpressionUUID->"65d4318c-ea37-4bb7-ab9c-27526fc97b9d"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "f5c6ae49-e84a-433f-85b5-948abf709128"],
 " is of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "b96d21f6-8691-496f-b656-75f2c2275c7d"],
 " or less, and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "6a745e4a-a93f-402d-aec7-a069887f4c59"],
 " is degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "5af2c83e-0a3c-4325-8577-07857eb0c086"],
 " or less;"
}], "ItemNumbered",
 CellID->1198257659,ExpressionUUID->"0891030a-52af-4ce9-9b7f-99f9ce7766b8"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "259d81aa-dadd-4397-bbf2-aee25f308dd6"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"f3371de3-ff01-4a16-a7d5-d9fe8f776314"],
 ", and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "a85a5e3d-5bf3-4fbb-acbe-9f8f5e4bb705"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", "-", 
       RowBox[{"1", " ", "mod", " ", "2"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"c20da1b7-a425-4cad-bc0a-738c8025fb0f"],
 "; and"
}], "ItemNumbered",
 CellID->687775779,ExpressionUUID->"81453d09-82ea-48bd-a08c-132fd4c82363"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"P", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"Q", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["x", "2"]}], ")"}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"cba8af1a-36a5-408d-bd27-0a77dcb39ec8"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "3ba2bb7d-a39e-46e6-a8f2-621a39e64884"],
 " in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "aa01a43c-f454-4366-b07c-e99a565ccbf7"],
 "."
}], "ItemNumbered",
 CellID->1964879951,ExpressionUUID->"d7c09264-2f0b-4009-8eb8-642520814aac"],

Cell[TextData[{
 "An ",
 StyleBox["even",
  FontSlant->"Italic"],
 " and ",
 StyleBox["odd",
  FontSlant->"Italic"],
 " function has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "5500b581-1f6f-4edd-9ca2-b37d214bb52a"],
 ", respectively. Polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "0810dfdc-904b-44a5-879c-ca5c4f3be2bf"],
 " is said to be of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], TraditionalForm]],ExpressionUUID->
  "166c96de-290b-4db5-9235-7810fe5262f8"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Q", "(", "x", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"3ee7763d-46b7-4a95-be04-007d7f38359e"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "d94a648a-3ac8-4b07-912b-5bfdbd64e8ba"],
 ". "
}], "TechNoteText",
 CellID->1043059083,ExpressionUUID->"04b738ef-e11a-459b-9941-48c06121f8c3"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Symmetric Quantum Signal Processing", "TechNoteSection",
 CellID->1845451401,ExpressionUUID->"41a11fd1-2ae8-4c31-8a95-b2033bb90f00"],

Cell[CellGroupData[{

Cell["Real Quantum Signal Processing", "Subsection",
 CellID->716095192,ExpressionUUID->"88748fb7-ebb0-470c-8b08-1ad23493e0f4"],

Cell[TextData[{
 "Dealing with both polynomials ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "7c1e2a47-3b73-47c2-a628-76991619f8e7"],
 " and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "9af748c3-23e6-4859-8b5e-29bf19910281"],
 " requires a strong normalization constraint (3) in the above theorem. \
Fortunately, we are often interested only in ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "dcfacb4b-bdc8-4639-a95d-873e26095f2d"],
 " with ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "7be2679f-a523-4af4-8027-ff848347ec7a"],
 " out of concern. Moreover, in many practical applications, the target \
polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"37bcc9f5-111f-44aa-8d4f-2452cb82f317"],
 " is real valued."
}], "TechNoteText",
 CellID->1638814136,ExpressionUUID->"b90bb20a-8b1a-49eb-a29a-d4f7c995a267"],

Cell[TextData[{
 StyleBox["Corollary",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(GSLWiebe, 2019)"]], "https://doi.org/10.1145/3313276.3316366"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "7128f632-27ee-4d80-8a70-c69bdac99803"],
 ": Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"4ea3ba26-2b99-4c40-9db8-8b67a2116dcb"],
 " be a real-valued polynomial of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[GreaterEqual]", "1"}], TraditionalForm]],ExpressionUUID->
  "6debaf2b-680a-4df7-80c0-8a5e27ec83fc"],
 " such that."
}], "TechNoteText",
 CellID->1657749463,ExpressionUUID->"95043cba-6126-4868-bf80-dc2ac6238369"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "target"], TraditionalForm]],ExpressionUUID->
  "44f4f06a-af37-4452-ba48-16abb8351d6a"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"e5a592d9-e8d3-4cc5-aec3-d1889bf988ce"],
 "; and"
}], "ItemNumbered",
 CellID->1633062763,ExpressionUUID->"777c9fc8-7b44-4575-85e1-8f528e6a4953"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       SubscriptBox["P", "target"], "(", "x", ")"}], 
      "\[RightBracketingBar]"}], "2"], "\[LessEqual]", "1"}], 
   TraditionalForm]],ExpressionUUID->"c059a282-21a4-4457-8a16-203a982dc204"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "36bc6526-17d7-4e20-bfec-3b0567f98f4e"],
 " in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "4d5e6deb-d40b-4f7e-9f21-c8db492a5d36"],
 "."
}], "ItemNumbered",
 CellID->76705129,ExpressionUUID->"523e8470-efbc-40ab-99e1-9ab8b621d571"],

Cell[TextData[{
 "Then, there exists complex-valued polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "d0188f63-8292-4115-9645-be2e8ad26f61"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "5206f6de-cfac-4c2d-aa64-6b74f4995fca"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalR]", 
     RowBox[{"d", "+", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "8a47af7f-e827-4bb6-8fac-334af7cabc62"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{"Re", "[", 
     RowBox[{"P", "(", "x", ")"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "a67f2a82-935f-44b5-be27-d766070cafb7"],
 " and"
}], "TechNoteText",
 CellID->758900752,ExpressionUUID->"2c85baa0-c135-4383-ba2d-6c9dc386293f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], "*"},
        {
         RowBox[{"\[VeryThinSpace]", "*"}], "*"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "ce6b7e74-f0da-4988-ad15-4d8bfccbd6a5"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1679183788,ExpressionUUID->"2dd5ea66-c6e6-4238-9de0-69e74a3bba38"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["*", TraditionalForm]],ExpressionUUID->
  "d525aaac-e350-4e54-a8c1-48371be498d9"],
 " indicates that the corresponding matrix elements are irrelevant."
}], "TechNoteText",
 InitializationCell->True,
 CellID->134043131,ExpressionUUID->"3112d4c0-e0d4-4a48-b132-7f8bbcdfce06"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Symmetric Quantum Signal Processing", "Subsection",
 CellID->1913603881,ExpressionUUID->"07ab844c-0c3e-4d27-af3d-03d32c143a05"],

Cell[TextData[{
 "Expanding a real polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"475c3824-7518-4482-a907-7a6acaf0e3d0"],
 " of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", " "}], TraditionalForm]],ExpressionUUID->
  "6d9796c3-f776-4d57-860a-284eab5182c1"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"fcaa49f2-3944-4139-a914-7b3f2a4dbe95"],
 " in the Chebyshev polynomials ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "50cc24c8-3fd1-4505-8b3c-5f129d1d4c6b"],
 ","
}], "TechNoteText",
 CellID->1190696816,ExpressionUUID->"8e80bfab-7afc-44e4-9a93-765c6b437d5b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "0"}], "d"], 
     SubscriptBox["c", "k"], 
     RowBox[{
      SubscriptBox["T", "k"], "(", "x", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"a1b84cba-59a7-4374-baa6-d629e95c9343"],
 ","
}], "TechNoteText",
 CellID->541777561,ExpressionUUID->"eb1d0660-283f-4639-be3c-c9619addb987"],

Cell[TextData[{
 "requires only ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "d"], ":=", 
    RowBox[{"\[LeftCeiling]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"d", "+", "1"}], ")"}], "/", "2"}], "\[RightCeiling]"}]}], 
   TraditionalForm]],ExpressionUUID->"14946b91-b792-4bd6-8ac8-df17fc665224"],
 "real coefficients with the rest being identically zero. This implies that \
there are unnecessarily many variables in the phase vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"b2d30750-08df-44ce-8d71-83df8d818bd9"],
 ". It turns out to be useful to impose the symmetry, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "d"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "1"], ",", 
      SubscriptBox["\[Phi]", "0"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"b9684c1b-d28c-4519-ad38-87ce11d0b215"],
 ", which leaves only ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "d"], TraditionalForm]],ExpressionUUID->
  "b2d63500-11eb-4aa0-a2d1-3041c4cbb740"],
 " independent phase variables ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "efb627e5-0962-4e64-b3ff-b3925bcdea87"],
 ". Such a quantum signal processing with symmetric phase vector is said to \
be ",
 StyleBox["symmetric",
  FontSlant->"Italic"],
 ". A symmetric quantum signal processing has its characteristic unitary \
matrix symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"], "T"], "(", "x", ")"}]}], 
   TraditionalForm]],ExpressionUUID->"7ac46c85-50a0-4c93-b0bf-e58a8644a8ba"],
 ", and the polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "6298629e-3cf4-48d9-9ef6-0adbc8068eb0"],
 " is real ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021: Theorem 2)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "6f99388b-59a2-4150-8017-bce366dc21aa"],
 "."
}], "TechNoteText",
 CellID->2103131023,ExpressionUUID->"2b85ad95-28a0-4055-a1c7-b9d87c191909"],

Cell[TextData[{
 "Given a ",
 StyleBox["reduced",
  FontSlant->"Italic"],
 " set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[CurlyPhi]", "0"], ",", 
     SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["\[CurlyPhi]", 
      RowBox[{
       SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], TraditionalForm]],
  ExpressionUUID->"bcd85a43-314d-45de-8738-5e9ae7d07771"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "d"], TraditionalForm]],ExpressionUUID->
  "129af914-3f5c-4ad3-81d6-f3c497b49f0a"],
 " independent phase variables and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"\[PlusMinus]", "1"}]}], TraditionalForm]],ExpressionUUID->
  "1562fdb1-327a-4fbc-b121-02ed271a3d58"],
 " for a symmetric quantum signal processing, one can recover the ",
 StyleBox["full vector",
  FontSlant->"Italic"],
 " of phase variables as follows:"
}], "TechNoteText",
 CellID->1062312889,ExpressionUUID->"0afb0781-cd90-4dee-ba26-a249177b0b71"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{
     RowBox[{"+", "1"}], "\[RightTeeArrow]", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       RowBox[{"2", 
        SubscriptBox["\[CurlyPhi]", 
         RowBox[{
          SubscriptBox["n", "d"], "-", "1"}]]}], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", 
       SubscriptBox["\[CurlyPhi]", "0"]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"5dac1e9f-9a32-4e38-9184-66a5166c7fc9"],
 " (notice the factor of 2 for technical convenience),"
}], "TechNoteText",
 CellID->943846728,ExpressionUUID->"8feedb66-da81-4026-a2d4-bd147c23d3fc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{
     RowBox[{"-", "1"}], "\[RightTeeArrow]", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]], ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", 
       SubscriptBox["\[CurlyPhi]", "0"]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"190b7b61-e4d1-4b58-9731-f911894916fb"],
 "."
}], "TechNoteText",
 CellID->875354969,ExpressionUUID->"71202c4d-3211-4542-9e36-546e1604a041"],

Cell[TextData[{
 "The pair ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{"(", 
     RowBox[{"p", "=", 
      RowBox[{"\[PlusMinus]", "1"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"94ba6ba1-8ff0-4a34-b3ad-08ec19eaf117"],
 " is called the ",
 StyleBox["reduced phase vector",
  FontSlant->"Italic"],
 " to be distinguished from the ",
 StyleBox["full phase vector",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1012750098,ExpressionUUID->"ae00e239-84c0-4f11-9d3d-4c721c1fbbc7"],

Cell[TextData[{
 "The correspondence between the reduced and full phase vector is closely \
related to that between the ",
 ButtonBox["reduced and full Chebyshev coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevCoefficients"],
 " list."
}], "TechNoteText",
 CellID->980635044,ExpressionUUID->"cae3cc8b-1b5e-4a3e-8524-daeaf03a599c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Finding Quantum Signal Processing", "TechNoteSection",
 CellID->945509203,ExpressionUUID->"5d577a91-97af-4bad-aeae-3c7a58723d0e"],

Cell[TextData[{
 "Given a real-valued target polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"5eecb8a2-f8a4-4b3f-9fdb-f2846942d9b5"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "9e613bb0-ff84-47a7-b34b-138677db776b"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      RowBox[{"(", 
       RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"a2a27428-ebd9-438c-b00b-7f97896226a0"],
 ", the reduced phase vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], ",", 
     RowBox[{"p", "=", 
      RowBox[{"\[PlusMinus]", "1"}]}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"15aeaf95-8fe0-49cb-b13f-187086fa02d8"],
 " can be found by using the recursion relation in the proof of Corollary ",
 ButtonBox["(GSLWiebe, 2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1145/3313276.3316366"], None}],
 ". Unfortunately, this method is numerically unstable, and it was pointed \
out that this method requires ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"d", "\[VeryThinSpace]", 
     RowBox[{"log", "(", 
      RowBox[{"d", "/", "\[Epsilon]"}], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"8479852d-3be2-4c98-93da-7e0e547e3cda"],
 " bits of precision, where ",
 Cell[BoxData[
  FormBox["\[Epsilon]", TraditionalForm]],ExpressionUUID->
  "a04ebd62-74f8-424a-b529-568c727687da"],
 " is the admitted tolerance ",
 ButtonBox["(Haah, 2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.22331/q-2019-10-07-190"], None}],
 "."
}], "TechNoteText",
 CellID->935659944,ExpressionUUID->"a8b5868b-0011-4729-95a0-8f1ba0ca0b8e"],

Cell[TextData[{
 "Later, a new optimization-based method was proposed to find a quantum \
signal processing given a target polynomial ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "0249fc19-351e-499b-9142-840961ab1e4d"],
 ". "
}], "TechNoteText",
 CellID->1695259150,ExpressionUUID->"3ea56e65-09c8-482d-a31e-af325805c429"],

Cell[TextData[{
 ButtonBox["Q3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 " follows ",
 ButtonBox["Dong, Meng, Whaley and Lin (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.103.042419"], None}],
 ", and provides an implementation using the built-in local optimizer ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FindMinimum"]], "paclet:ref/FindMinimum"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1bc2b0ff-29bf-40c8-8e51-61aff4fc8828"],
 " as well as the original implementations in ",
 ButtonBox["QSPPACK",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/qsppack/QSPPACK"], None}],
 " by Dong, Wang, Meng, Ni and Lin; see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QSPFind"]], "paclet:QuantumMob/Q3/ref/QSPFind", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "063ccc69-977e-4d7e-bad2-38b839629d67"],
 " for more details."
}], "TechNoteText",
 CellID->1819995317,ExpressionUUID->"3df338ab-6d09-46c4-9b40-94fe8ac3b407"],

Cell[TextData[{
 "Note that the target polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"f396da86-57a0-485d-8736-0275e43c94ae"],
 " is specified in terms of the ",
 ButtonBox["Chebyshev coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevCoefficients"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"59d8183f-0542-42ec-beee-f1f91cd16c75"],
 " is assumed to be expanded in the ",
 ButtonBox["Chebyshev series",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevSeries"],
 ". This is natural because\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"[", 
      RowBox[{"W", "(", "x", ")"}], "]"}], "k"], "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{
         SubscriptBox["T", "k"], "(", "x", ")"}], 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]], 
         RowBox[{
          SubscriptBox["U", 
           RowBox[{"k", "-", "1"}]], "(", "x", ")"}]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]], 
         RowBox[{
          SubscriptBox["U", 
           RowBox[{"k", "-", "1"}]], "(", "x", ")"}]}], 
        RowBox[{
         SubscriptBox["T", "k"], "(", "x", ")"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "07a44bb9-dfc6-40bb-a125-a6280ac3fafa"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "b94ab7d3-63bc-4a79-af28-d700389d2540"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "3b67cbbf-582f-47e8-a21c-55213e0fe8c6"],
 " are the Chebyshev polynomials of the first and second kinds, respectively,\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["T", "k"], "(", "x", ")"}], ":=", 
    RowBox[{"cos", "(", 
     RowBox[{"k", "\[VeryThinSpace]", "\[Theta]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"748d45cf-5d42-462e-9a94-26aa130f95e3"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "k"], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{"sin", "(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"k", "+", "1"}], ")"}], "\[Theta]"}], ")"}], "/", 
     RowBox[{"sin", "(", "\[Theta]", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"c0bd22a5-7ce7-4372-9786-435ab7cdc162"],
 "\[LineSeparator]with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "(", "\[Theta]", ")"}], ":=", "x"}], TraditionalForm]],
  ExpressionUUID->"3a1ad182-97dc-461f-9408-b1c9c1c960df"],
 "."
}], "TechNoteText",
 CellID->44302011,ExpressionUUID->"7b7d0f27-cbf5-44b7-8751-2fbf73457e21"]
}, Open  ]],

