Cell[TextData[{
 "The quantum signal processing (QSP) of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "c7a4afb4-546b-4332-aa71-ece466e30f6f"],
 " with phases ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"7101d20c-db0e-4238-b5be-a04a2c5fe9b8"],
 " is a parameterized representation of a polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "c2d5eed9-5bd6-4574-9d11-a509de507aac"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "7adac9fc-f947-4de3-9482-57167f35ed25"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"0ba452cd-fff8-4854-8eaa-74b93bf8a659"],
 ", through the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Times]", "2"}], TraditionalForm]],ExpressionUUID->
  "b96dbe76-9724-42c8-979b-af663cb5ccd2"],
 " unitary matrix"
}], "TechNoteText",
 CellID->1149534814,ExpressionUUID->"8b638073-ce9a-432b-a84c-52e80988711d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"Q", "(", "x", ")"}], 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["x", "2"]}]]}]},
        {
         RowBox[{"\[VeryThinSpace]", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
           RowBox[{
            SuperscriptBox["Q", "*"], "(", "x", ")"}], 
           SqrtBox[
            RowBox[{"1", "-", 
             SuperscriptBox["x", "2"]}]]}]}], 
         RowBox[{
          SuperscriptBox["P", "*"], "(", "x", ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "2a0f79b5-1a69-4baf-bb0d-8a151f342626"],
 " ,"
}], "TechNoteText",
 CellID->1855416719,ExpressionUUID->"d0c9c7b1-5b19-4b53-bfba-53c37bb95d35"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "7cde34ba-8340-4b79-9265-9f4280a3ebde"],
 " is the Pauli-",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "f5f9c34f-dfd8-4d5e-a30d-8804e73300f4"],
 " matrix,"
}], "TechNoteText",
 CellID->1468730486,ExpressionUUID->"5e32f492-8d0f-49d9-a6f4-53f164cde9c9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "d827f9ac-5673-4cb1-92c5-9f02d9b43b35"],
 " ,"
}], "TechNoteText",
 CellID->1299284453,ExpressionUUID->"e3b54f06-6909-42c8-91b4-99ae9e2b4bd1"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "2913b6d5-d27d-4f33-93ff-ecb1d0904a38"],
 " is a rotation in the Bloch space around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "18314e6f-9c4d-4f06-b4fa-444551caf337"],
 "-axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "2"}], 
    RowBox[{"arccos", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "a4a90c89-e7ed-4ce5-af97-626834ac9043"],
 ","
}], "TechNoteText",
 CellID->2081288426,ExpressionUUID->"4dfc7317-2f4c-40e0-afd3-1885f73e1011"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", "(", "x", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"x", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}], "x"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "000d7874-5627-4a20-8cbb-689c3770a910"],
 " ,"
}], "TechNoteText",
 CellID->548308726,ExpressionUUID->"d91cd3b4-6838-4c26-aed9-593cbdd22841"],

Cell[TextData[{
 "and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "93bda80c-f422-477b-8b70-da01b3e7201c"],
 " is a polynomial of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "98d6d8cb-8bb4-4164-b58f-41b23143a48b"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", "-", 
       RowBox[{"1", " ", "mod", " ", "2"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"18ce18ff-769f-4b61-adad-ec1b64557e19"],
 " satisfying the unitarity constraint "
}], "TechNoteText",
 CellID->269137797,ExpressionUUID->"7e797d40-62a6-436f-adb8-7486562c3e34"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"P", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"Q", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["x", "2"]}], ")"}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"36c69fc3-dc72-4fa2-b0a5-16c86380fff5"],
 "."
}], "TechNoteText",
 CellID->1969969023,ExpressionUUID->"25052ff8-b60a-4483-b89b-f72fbac99f04"],

Cell[TextData[{
 "Quantum signal processing builds a foundation of ",
 StyleBox["quantum eigenvalue transform",
  FontSlant->"Italic"],
 ", ",
 StyleBox["quantum singular value transform",
  FontSlant->"Italic"],
 " and other related methods that provide a general approach to implement \
functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"F", "(", "A", ")"}], TraditionalForm]],ExpressionUUID->
  "c5dc3cbe-656e-486f-9a21-55e43708197d"],
 " of matrices ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "0925d3bb-a251-40a3-ac88-b4473795bf0b"],
 " on a quantum computer."
}], "TechNoteText",
 CellID->806727323,ExpressionUUID->"ebe211ba-7ffa-4f9b-a24a-66cb6ac92b59"],

