Cell[TextData[{
 "The quantum signal processing (QSP) of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "11567dda-dd41-4ba2-b10f-8fa3d03ebd4d"],
 " with phases ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"7d2f4267-4a4e-4f1a-9a33-9357fbd1986f"],
 " is a parameterized representation of a polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "10296b5f-651a-4dfd-a19e-b553c7e3e7d7"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "cec1fd98-7822-456d-8186-d08b9dbf667a"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"f7a04966-b099-4552-97e4-2314cc103de0"],
 ", through the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Times]", "2"}], TraditionalForm]],ExpressionUUID->
  "c32946d2-825b-426d-933f-013f5c914004"],
 " unitary matrix"
}], "TechNoteText",
 CellID->1149534814,ExpressionUUID->"887787a5-5b33-44e8-848b-44732bbe124e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"Q", "(", "x", ")"}], 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["x", "2"]}]]}]},
        {
         RowBox[{"\[VeryThinSpace]", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
           RowBox[{
            SuperscriptBox["Q", "*"], "(", "x", ")"}], 
           SqrtBox[
            RowBox[{"1", "-", 
             SuperscriptBox["x", "2"]}]]}]}], 
         RowBox[{
          SuperscriptBox["P", "*"], "(", "x", ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "d7993a5c-9590-4769-b4ed-e7834e21769f"],
 " ,"
}], "TechNoteText",
 CellID->1855416719,ExpressionUUID->"bb0a0995-114d-427a-b863-9b3dbe378243"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "6b9c7899-87b0-4451-a73e-525a980463cf"],
 " is the Pauli-",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "15e023fa-e010-4eaf-b90b-a3a8d9165963"],
 " matrix,"
}], "TechNoteText",
 CellID->1468730486,ExpressionUUID->"03186ebd-fd4a-469d-8ba4-d1a53ddbec4b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "3a8447c2-533d-4f34-b87c-bcfb4dab2383"],
 " ,"
}], "TechNoteText",
 CellID->1299284453,ExpressionUUID->"2fbec0eb-9332-4d07-9c8d-885adf93486b"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "d9a64eb3-51b8-48a9-8f3a-fd2492e7aa6f"],
 " is a rotation in the Bloch space around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "0924f099-0fad-4cb2-b6cc-6cfb0f12fb3e"],
 "-axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "2"}], 
    RowBox[{"arccos", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "25e9b4d7-0dc3-41f2-b879-3878e2307cd4"],
 ","
}], "TechNoteText",
 CellID->2081288426,ExpressionUUID->"484a0896-6038-479f-8714-129bcb30dc7b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", "(", "x", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"x", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}], "x"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "5b04032c-af5d-43aa-bd6d-f379c028d7e0"],
 " ,"
}], "TechNoteText",
 CellID->548308726,ExpressionUUID->"fd1a9674-27de-4950-9806-ac29b2cad043"],

Cell[TextData[{
 "and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "464092ba-5802-4d35-865f-259c8df8c219"],
 " is a polynomial of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "941793d6-fb7d-437f-ba6d-60bea6b0e900"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", "-", 
       RowBox[{"1", " ", "mod", " ", "2"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"fdd4ee43-3454-48ff-881c-a749769a7ab2"],
 " satisfying the unitarity constraint "
}], "TechNoteText",
 CellID->269137797,ExpressionUUID->"8ad511bb-d033-43f0-9900-4ec7153b569f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"P", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"Q", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["x", "2"]}], ")"}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"fd10b920-ebe4-421b-b51d-4165e9cbda68"],
 "."
}], "TechNoteText",
 CellID->1969969023,ExpressionUUID->"db033974-dba8-4a86-bbe0-af234330a59d"],

Cell[TextData[{
 "Quantum signal processing builds a foundation of ",
 StyleBox["quantum eigenvalue transform",
  FontSlant->"Italic"],
 ", ",
 StyleBox["quantum singular value transform",
  FontSlant->"Italic"],
 " and other related methods that provide a general approach to implement \
functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"F", "(", "A", ")"}], TraditionalForm]],ExpressionUUID->
  "c0b0453d-4c6a-47df-adaf-6c7f79a4cce4"],
 " of matrices ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "362154f9-7e3c-4def-92a6-7e347c093aea"],
 " on a quantum computer."
}], "TechNoteText",
 CellID->806727323,ExpressionUUID->"ff667bd0-e5b5-4a8c-9e7a-d7f874742df5"],

