Cell[CellGroupData[{

Cell["Quantum Signal Processing Theorem", "TechNoteSection",
 CellID->1988062027,ExpressionUUID->"5234e70b-3d67-4d6c-b0f1-3e0087f34b82"],

Cell[TextData[{
 StyleBox["Theorem",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(GSLWiebe, 2019)"]], "https://doi.org/10.1145/3313276.3316366"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "44f0c046-6aec-4d30-9372-b5e036756257"],
 ": There exists a set of phases ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[Phi]", "0"], ",", 
       SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Phi]", "d"]}], "}"}], "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", 
      RowBox[{"d", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "58ba36af-4b1d-4ad2-9434-8dc0bfeaae2e"],
 " such that the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Times]", "2"}], TraditionalForm]],ExpressionUUID->
  "c9d6d09d-a77b-46ae-aeb9-89425643825f"],
 " unitary matrix"
}], "TechNoteText",
 CellID->1701303988,ExpressionUUID->"d956ac59-cd90-48e8-83c6-a8f2df9a2db2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"Q", "(", "x", ")"}], 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["x", "2"]}]]}]},
        {
         RowBox[{"\[VeryThinSpace]", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
           RowBox[{
            SuperscriptBox["Q", "*"], "(", "x", ")"}], 
           SqrtBox[
            RowBox[{"1", "-", 
             SuperscriptBox["x", "2"]}]]}]}], 
         RowBox[{
          SuperscriptBox["P", "*"], "(", "x", ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "59162c13-29e2-4c98-961f-11bc1620bc03"],
 " "
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->71366511,ExpressionUUID->"d6deac39-dcf4-4d37-83ad-13b143854878"],

Cell["with", "TechNoteText",
 CellID->1161075351,ExpressionUUID->"f9b15339-97ff-40fc-b09a-2f56faa0bdf7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "c8e4f4d3-d994-4c7a-8e70-af8210152b70"],
 " ,        \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", "(", "x", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"x", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}], "x"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "b10ada68-a2dc-455c-be13-4e3104bee355"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->9523968,ExpressionUUID->"b339a1b1-67e1-46f8-bb2a-9469f85ae08f"],

Cell[TextData[{
 StyleBox["if and only if",
  FontSlant->"Italic"],
 " polynomials ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "6f54d20c-d401-4f84-9df5-66d8335ccd20"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "6a14b4d4-ab89-4ebd-9285-9ab376dad9d6"],
 " satisfy"
}], "TechNoteText",
 CellID->297671935,ExpressionUUID->"d7b50ad9-387d-4ef2-92ac-6a21583c931a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "d1e2f50d-5a5f-4d1c-9fa7-b837a90279d6"],
 " is of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "cf7d77dc-86ab-4419-b630-17c03edc9284"],
 " or less, and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "76d03311-1212-4b72-82b0-8868af379c7a"],
 " is degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "6be39d11-7c34-444c-937f-3d3a7479ae68"],
 " or less;"
}], "ItemNumbered",
 CellID->1198257659,ExpressionUUID->"78c0893b-5c80-489d-9889-ac618aea6e1e"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "1cb39b8c-4108-4f3a-a913-bf05c3fdc817"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"03bc301d-6a76-434f-ae5f-cfee06b1e16e"],
 ", and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "ba38d136-6d51-482e-a77e-f8b82a2701fb"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", "-", 
       RowBox[{"1", " ", "mod", " ", "2"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"2fccaae0-2978-4e43-bceb-ad7e0cb48c3f"],
 "; and"
}], "ItemNumbered",
 CellID->687775779,ExpressionUUID->"b0329fd9-dde9-4642-ab5b-edb5f271ca17"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"P", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"Q", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["x", "2"]}], ")"}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"ef5196ea-f7b8-4836-a38c-bbb7c80e361d"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "d9ebdf40-0561-4eab-858a-97109c366bc0"],
 " in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "57a084da-ede5-4d53-b2da-27aa253fcc27"],
 "."
}], "ItemNumbered",
 CellID->1964879951,ExpressionUUID->"692081ae-cad1-46d3-a9d8-cf8d38cac977"],

Cell[TextData[{
 "An ",
 StyleBox["even",
  FontSlant->"Italic"],
 " and ",
 StyleBox["odd",
  FontSlant->"Italic"],
 " function has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "ad27e899-2399-4ec2-8b63-3309fff04752"],
 ", respectively. Polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "68555a55-c4ed-4b32-9188-c00471550a12"],
 " is said to be of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], TraditionalForm]],ExpressionUUID->
  "9bd3e50c-1818-4d25-92ff-8975d2423091"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Q", "(", "x", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"e515e8db-5454-429d-8c31-fa8a3de95801"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "2327974c-c03b-4a90-b7f8-375f1fc7e5c3"],
 ". "
}], "TechNoteText",
 CellID->1043059083,ExpressionUUID->"9e3d33e2-d896-47e5-86c8-c3806b644f75"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Symmetric Quantum Signal Processing", "TechNoteSection",
 CellID->1845451401,ExpressionUUID->"36e475ea-8b71-49a5-9131-29ba73fc2796"],

Cell[CellGroupData[{

Cell["Real Quantum Signal Processing", "Subsection",
 CellID->716095192,ExpressionUUID->"5217fc29-b042-43d2-bddf-066dc5c1912a"],

Cell[TextData[{
 "Dealing with both polynomials ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "a7cddc39-2c2f-46f0-8462-a0511a8a6aa0"],
 " and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "b7247801-3306-4205-a2a0-1a097b9a2b17"],
 " requires a strong normalization constraint (3) in the above theorem. \
Fortunately, we are often interested only in ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "e76e6674-83ec-472e-b9d0-3bb925a6cb88"],
 " with ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "9203773c-29fe-400e-9d77-9b0fc75b6787"],
 " out of concern. Moreover, in many practical applications, the target \
polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"54ececb4-239a-4e61-b8ab-5959ce4af679"],
 " is real valued."
}], "TechNoteText",
 CellID->1638814136,ExpressionUUID->"4c79254a-dc94-4750-a10d-963252984817"],

Cell[TextData[{
 StyleBox["Corollary",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(GSLWiebe, 2019)"]], "https://doi.org/10.1145/3313276.3316366"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "e8931a01-c0d1-4fba-8dbb-40b0992f98f9"],
 ": Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"54205113-7d88-40f7-971d-43a6502a4900"],
 " be a real-valued polynomial of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[GreaterEqual]", "1"}], TraditionalForm]],ExpressionUUID->
  "93e98039-54b4-4a6c-89b5-34f72928167c"],
 " such that."
}], "TechNoteText",
 CellID->1657749463,ExpressionUUID->"d8ca8e58-3804-4691-9a81-f46528781374"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "target"], TraditionalForm]],ExpressionUUID->
  "4b4783f0-c183-474a-a680-34aec704d364"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"be65cad2-5e37-4348-bb56-a11ddaced8c4"],
 "; and"
}], "ItemNumbered",
 CellID->1633062763,ExpressionUUID->"1a6767b1-192b-4242-8052-c062b179b0da"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       SubscriptBox["P", "target"], "(", "x", ")"}], 
      "\[RightBracketingBar]"}], "2"], "\[LessEqual]", "1"}], 
   TraditionalForm]],ExpressionUUID->"8e7b16c2-35c7-41ed-9451-e0a75b894d1c"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "9f8c0f58-640e-4e8f-8018-667bc41ccf5f"],
 " in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "97cada24-12e0-41d7-9ba0-0bff88fa2aeb"],
 "."
}], "ItemNumbered",
 CellID->76705129,ExpressionUUID->"02b1fa6d-3eff-4cbe-b5cd-ee836006a46d"],

Cell[TextData[{
 "Then, there exists complex-valued polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "9c1853ab-6fef-4d06-b6c3-827f6e45f605"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "fcc42955-ec73-4b62-99cd-91006dc90363"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalR]", 
     RowBox[{"d", "+", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "9c40c889-0d72-406c-8303-f345aa9ca2b5"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{"Re", "[", 
     RowBox[{"P", "(", "x", ")"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "31b5ed32-71ff-4cb6-8bac-8d5541343389"],
 " and"
}], "TechNoteText",
 CellID->758900752,ExpressionUUID->"24ca0cee-ab3b-4ebb-a832-55c87d0cf10d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], "*"},
        {
         RowBox[{"\[VeryThinSpace]", "*"}], "*"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "7503a0bb-d06d-46e0-abf8-f2455e2d6357"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1679183788,ExpressionUUID->"fd9db2c7-bf1b-402f-a706-bb0ef150748b"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["*", TraditionalForm]],ExpressionUUID->
  "10eda63f-3436-485d-8acc-fcaed8664b35"],
 " indicates that the corresponding matrix elements are irrelevant."
}], "TechNoteText",
 InitializationCell->True,
 CellID->134043131,ExpressionUUID->"c037f1e7-25a3-4c4b-a555-f1b2e6860c09"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Symmetric Quantum Signal Processing", "Subsection",
 CellID->1913603881,ExpressionUUID->"ccf8603e-8cbc-4da8-a6a2-1a54414e160e"],

Cell[TextData[{
 "Expanding a real polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"6ad72eba-6b75-4158-b694-75dc3a26783b"],
 " of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", " "}], TraditionalForm]],ExpressionUUID->
  "ea8cae8b-e85d-4a2d-86fe-9449e5cf21ab"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"c2ee307c-cde9-4b6f-8b8e-562f26e27c4f"],
 " in the Chebyshev polynomials ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "008e38a4-936b-4d3b-a041-7281a6384626"],
 ","
}], "TechNoteText",
 CellID->1190696816,ExpressionUUID->"93248d7e-3f30-4576-9b6c-dd07d028a636"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "0"}], "d"], 
     SubscriptBox["c", "k"], 
     RowBox[{
      SubscriptBox["T", "k"], "(", "x", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"5ea5cccc-7c1d-4836-bb2f-0f98015fb14a"],
 ","
}], "TechNoteText",
 CellID->541777561,ExpressionUUID->"93d34a5c-753c-4401-a4c1-a7c0b4ba5bda"],

Cell[TextData[{
 "requires only ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "d"], ":=", 
    RowBox[{"\[LeftCeiling]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"d", "+", "1"}], ")"}], "/", "2"}], "\[RightCeiling]"}]}], 
   TraditionalForm]],ExpressionUUID->"b3375573-04b0-4139-8e45-575cdf788af2"],
 "real coefficients with the rest being identically zero. This implies that \
there are unnecessarily many variables in the phase vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"a4fb0a89-59cc-458b-a3b3-32033f21f5ea"],
 ". It turns out to be useful to impose the symmetry, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "d"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "1"], ",", 
      SubscriptBox["\[Phi]", "0"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"4e445501-f90a-4b37-a3dc-52f22eb82dd9"],
 ", which leaves only ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "d"], TraditionalForm]],ExpressionUUID->
  "268d8790-430d-4971-9e30-99a3436ab0d4"],
 " independent phase variables ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "827a19e6-19a8-47bc-8739-1977e2727989"],
 ". Such a quantum signal processing with symmetric phase vector is said to \
be ",
 StyleBox["symmetric",
  FontSlant->"Italic"],
 ". A symmetric quantum signal processing has its characteristic unitary \
matrix symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"], "T"], "(", "x", ")"}]}], 
   TraditionalForm]],ExpressionUUID->"40e4036d-32e9-415b-be1e-8fa29f144bef"],
 ", and the polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "6088a645-27ec-4d95-96ef-8e037de2737c"],
 " is real ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021: Theorem 2)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "f5ae98b4-b7c4-430e-ba6c-4e4980a12444"],
 "."
}], "TechNoteText",
 CellID->2103131023,ExpressionUUID->"8f14d9de-5051-466b-afe9-0e2c49b07498"],

Cell[TextData[{
 "Given a ",
 StyleBox["reduced",
  FontSlant->"Italic"],
 " set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[CurlyPhi]", "0"], ",", 
     SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["\[CurlyPhi]", 
      RowBox[{
       SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], TraditionalForm]],
  ExpressionUUID->"4a65bc5e-3906-4adf-ba89-d351a2108abc"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "d"], TraditionalForm]],ExpressionUUID->
  "abc4dd69-28ff-4f82-a28e-b2599ba10f17"],
 " independent phase variables and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"\[PlusMinus]", "1"}]}], TraditionalForm]],ExpressionUUID->
  "edae048c-1bae-45d7-905a-8705e4f901da"],
 " for a symmetric quantum signal processing, one can recover the ",
 StyleBox["full vector",
  FontSlant->"Italic"],
 " of phase variables as follows:"
}], "TechNoteText",
 CellID->1062312889,ExpressionUUID->"127f00fe-2150-4536-a439-214c12edce62"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{
     RowBox[{"+", "1"}], "\[RightTeeArrow]", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       RowBox[{"2", 
        SubscriptBox["\[CurlyPhi]", 
         RowBox[{
          SubscriptBox["n", "d"], "-", "1"}]]}], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", 
       SubscriptBox["\[CurlyPhi]", "0"]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"024dc167-83d4-43a2-a2d3-d69e82d3a575"],
 " (notice the factor of 2 for technical convenience),"
}], "TechNoteText",
 CellID->943846728,ExpressionUUID->"868f44c2-d0bf-4c56-8579-29591e51f8bc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{
     RowBox[{"-", "1"}], "\[RightTeeArrow]", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]], ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", 
       SubscriptBox["\[CurlyPhi]", "0"]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"bfdb5cdf-8d41-4276-8dc2-f9de0f8bd424"],
 "."
}], "TechNoteText",
 CellID->875354969,ExpressionUUID->"f315a532-122b-444c-8bec-e1a9fbabe730"],

Cell[TextData[{
 "The pair ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{"(", 
     RowBox[{"p", "=", 
      RowBox[{"\[PlusMinus]", "1"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"3cc527ca-c364-4bc3-8c3f-6fcc47ce6be9"],
 " is called the ",
 StyleBox["reduced phase vector",
  FontSlant->"Italic"],
 " to be distinguished from the ",
 StyleBox["full phase vector",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1012750098,ExpressionUUID->"08a9f87b-f87d-4dcd-808c-0a340bfceaad"],

Cell[TextData[{
 "The correspondence between the reduced and full phase vector is closely \
related to that between the ",
 ButtonBox["reduced and full Chebyshev coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevCoefficients"],
 " list."
}], "TechNoteText",
 CellID->980635044,ExpressionUUID->"76e05f36-0ff5-4d34-a1b5-f2fa008914a7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Finding Quantum Signal Processing", "TechNoteSection",
 CellID->945509203,ExpressionUUID->"e69d9594-9442-4cfd-9357-ac0e2585b11a"],

Cell[TextData[{
 "Given a real-valued target polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"834ecf80-ee56-4d40-9e7a-2e14fe58440b"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "7e719be7-e5b2-4c19-8b1e-a0f2c4addc44"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      RowBox[{"(", 
       RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"fdd3a794-2fd8-4929-a20b-d38c064e8390"],
 ", the reduced phase vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], ",", 
     RowBox[{"p", "=", 
      RowBox[{"\[PlusMinus]", "1"}]}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"c3739f4a-d46c-4455-bf26-38c46afa2144"],
 " can be found by using the recursion relation in the proof of Corollary ",
 ButtonBox["(GSLWiebe, 2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1145/3313276.3316366"], None}],
 ". Unfortunately, this method is numerically unstable, and it was pointed \
out that this method requires ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"d", "\[VeryThinSpace]", 
     RowBox[{"log", "(", 
      RowBox[{"d", "/", "\[Epsilon]"}], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"18f79377-b741-462e-9450-e48c333fba32"],
 " bits of precision, where ",
 Cell[BoxData[
  FormBox["\[Epsilon]", TraditionalForm]],ExpressionUUID->
  "ac356b2c-51ca-4c38-86ed-45f8577eb766"],
 " is the admitted tolerance ",
 ButtonBox["(Haah, 2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.22331/q-2019-10-07-190"], None}],
 "."
}], "TechNoteText",
 CellID->935659944,ExpressionUUID->"7dbe4e36-a3f8-4577-a115-85fdd115b67a"],

Cell[TextData[{
 "Later, a new optimization-based method was proposed to find a quantum \
signal processing given a target polynomial ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "d5d2064d-e4f1-4f71-89e3-fce083afda30"],
 ". "
}], "TechNoteText",
 CellID->1695259150,ExpressionUUID->"3a0f55ad-dfc5-440f-beb5-7eba4671357d"],

Cell[TextData[{
 ButtonBox["Q3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 " follows ",
 ButtonBox["Dong, Meng, Whaley and Lin (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.103.042419"], None}],
 ", and provides an implementation using the built-in local optimizer ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FindMinimum"]], "paclet:ref/FindMinimum"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c2864d89-dfb1-46b6-9dfc-6593fbf1bb2e"],
 " as well as the original implementations in ",
 ButtonBox["QSPPACK",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/qsppack/QSPPACK"], None}],
 " by Dong, Wang, Meng, Ni and Lin; see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QSPFind"]], "paclet:QuantumMob/Q3/ref/QSPFind", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b7c15383-dd05-4931-b57c-8a1dca50951c"],
 " for more details."
}], "TechNoteText",
 CellID->1819995317,ExpressionUUID->"f1ddc63b-c832-45d6-b88b-ac7ef3b84f10"],

Cell[TextData[{
 "Note that the target polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"de67654e-bec9-4385-8b88-64dbc169e446"],
 " is specified in terms of the ",
 ButtonBox["Chebyshev coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevCoefficients"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"da366428-b546-4c76-a93f-9181683e6982"],
 " is assumed to be expanded in the ",
 ButtonBox["Chebyshev series",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevSeries"],
 ". This is natural because\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"[", 
      RowBox[{"W", "(", "x", ")"}], "]"}], "k"], "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{
         SubscriptBox["T", "k"], "(", "x", ")"}], 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]], 
         RowBox[{
          SubscriptBox["U", 
           RowBox[{"k", "-", "1"}]], "(", "x", ")"}]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]], 
         RowBox[{
          SubscriptBox["U", 
           RowBox[{"k", "-", "1"}]], "(", "x", ")"}]}], 
        RowBox[{
         SubscriptBox["T", "k"], "(", "x", ")"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "b1844c7e-239a-45ed-9a85-de5e0b6be733"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "7d5edb9f-78e7-41c8-9be6-e9a7f6cf4ef0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "94ac6a16-54b4-423e-a132-e8f7ccf1d663"],
 " are the Chebyshev polynomials of the first and second kinds, respectively,\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["T", "k"], "(", "x", ")"}], ":=", 
    RowBox[{"cos", "(", 
     RowBox[{"k", "\[VeryThinSpace]", "\[Theta]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"9a88c9a9-5930-4982-9ece-1cf268e7e9cf"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "k"], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{"sin", "(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"k", "+", "1"}], ")"}], "\[Theta]"}], ")"}], "/", 
     RowBox[{"sin", "(", "\[Theta]", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"44d177c9-bee7-468d-9891-868a757bc49c"],
 "\[LineSeparator]with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "(", "\[Theta]", ")"}], ":=", "x"}], TraditionalForm]],
  ExpressionUUID->"52ee349b-bdc4-4136-82e6-e12f794370df"],
 "."
}], "TechNoteText",
 CellID->44302011,ExpressionUUID->"80c2182b-1501-434b-b93a-331f137c1b9a"]
}, Open  ]],

