Cell[TextData[{
 "The quantum signal processing (QSP) of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "b2373abf-14b6-45cd-9508-eaa9c087a31a"],
 " with phases ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"f3386299-1c42-4a80-9b85-4a6773f2c2cf"],
 " is a parameterized representation of a polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "3117d9f7-185a-4b9b-9574-03efd87bae79"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "cc88dce0-1209-44c6-bd5c-f5c34decd9fc"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"03edfb54-5858-4767-92af-04ae37da514a"],
 ", through the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Times]", "2"}], TraditionalForm]],ExpressionUUID->
  "ef4409bb-4788-454c-8b05-8207b8da6b31"],
 " unitary matrix"
}], "TechNoteText",
 CellID->1149534814,ExpressionUUID->"495a1649-2911-42e8-a72f-f9ae821a4f08"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"Q", "(", "x", ")"}], 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["x", "2"]}]]}]},
        {
         RowBox[{"\[VeryThinSpace]", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
           RowBox[{
            SuperscriptBox["Q", "*"], "(", "x", ")"}], 
           SqrtBox[
            RowBox[{"1", "-", 
             SuperscriptBox["x", "2"]}]]}]}], 
         RowBox[{
          SuperscriptBox["P", "*"], "(", "x", ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "aa736980-28d2-4b0f-a3e2-134ee30aba52"],
 " ,"
}], "TechNoteText",
 CellID->1855416719,ExpressionUUID->"0aef38b5-bace-4a3f-a6a8-fe0f9157ec90"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "bd9fbb85-a31e-4c4e-b080-ba410c581bdd"],
 " is the Pauli-",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "a73cda3d-778d-4d96-896d-a53eee3d8926"],
 " matrix,"
}], "TechNoteText",
 CellID->1468730486,ExpressionUUID->"3b0f9a4f-c2cd-4567-ac70-47e0b959bf53"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "aab33e4e-dd07-429a-879e-c07848bc443f"],
 " ,"
}], "TechNoteText",
 CellID->1299284453,ExpressionUUID->"75e3813b-9d72-42fc-8f6f-6c6ed2ad7550"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"W", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "03564c37-1d01-4b3c-9e15-1ae648a5e3ba"],
 " is a rotation in the Bloch space around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "d9e93f87-8f81-466f-9164-d30880b21028"],
 "-axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "2"}], 
    RowBox[{"arccos", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "a08a7695-d1bb-41db-9c9a-a62c87cf7720"],
 ","
}], "TechNoteText",
 CellID->2081288426,ExpressionUUID->"0c6f9849-3b2c-45f0-b3de-43a75d7c6cea"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", "(", "x", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"x", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}], "x"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "f2b257e4-9e3e-45ec-93ae-b51bce54bdd4"],
 " ,"
}], "TechNoteText",
 CellID->548308726,ExpressionUUID->"b77f803e-2705-4d1b-9f15-92b149afc7f2"],

Cell[TextData[{
 "and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "acecd8e5-e67e-47cc-acdd-2e7e955c6d0c"],
 " is a polynomial of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "b6ba1e86-b62c-44eb-b717-ad74ca4515ba"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", "-", 
       RowBox[{"1", " ", "mod", " ", "2"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"8962cc5d-8a0c-4fb4-9f27-2679d3f5b336"],
 " satisfying the unitarity constraint "
}], "TechNoteText",
 CellID->269137797,ExpressionUUID->"9078550b-172d-4811-8570-df4dd7a32b1d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"P", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"Q", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["x", "2"]}], ")"}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"f2c48f15-43b5-498a-93f4-eb996fddb196"],
 "."
}], "TechNoteText",
 CellID->1969969023,ExpressionUUID->"f613834a-a3bd-4c17-a233-3137cf972b06"],

Cell[TextData[{
 "Quantum signal processing builds a foundation of ",
 StyleBox["quantum eigenvalue transform",
  FontSlant->"Italic"],
 ", ",
 StyleBox["quantum singular value transform",
  FontSlant->"Italic"],
 " and other related methods that provide a general approach to implement \
functions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"F", "(", "A", ")"}], TraditionalForm]],ExpressionUUID->
  "0f98b5bb-d129-419b-a8a9-ac7fc6b28476"],
 " of matrices ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "168f6f07-750a-47ee-a9fa-398d968a004a"],
 " on a quantum computer."
}], "TechNoteText",
 CellID->806727323,ExpressionUUID->"b8d9842d-af69-4f4b-87ee-3867d920fa86"],

