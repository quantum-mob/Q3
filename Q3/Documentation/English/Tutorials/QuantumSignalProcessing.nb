Cell[CellGroupData[{

Cell["Quantum Signal Processing Theorem", "TechNoteSection",
 CellID->1988062027,ExpressionUUID->"e5d27626-1cd2-4ee3-8686-e7c4c9675c11"],

Cell[TextData[{
 StyleBox["Theorem",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(GSLWiebe, 2019)"]], "https://doi.org/10.1145/3313276.3316366"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "d2f1423e-5b2d-4d9c-af55-b80a12966384"],
 ": There exists a set of phases ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[Phi]", "0"], ",", 
       SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Phi]", "d"]}], "}"}], "\[Element]", 
     SuperscriptBox["\[DoubleStruckCapitalR]", 
      RowBox[{"d", "+", "1"}]]}]}], TraditionalForm]],ExpressionUUID->
  "b58f5b3e-7db4-4258-9e06-ba65bc07dc7a"],
 " such that the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Times]", "2"}], TraditionalForm]],ExpressionUUID->
  "4cac93d8-1447-4266-b500-39f9da1ba594"],
 " unitary matrix"
}], "TechNoteText",
 CellID->1701303988,ExpressionUUID->"b54a9d68-c486-489e-8e60-b276cddf2487"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"Q", "(", "x", ")"}], 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["x", "2"]}]]}]},
        {
         RowBox[{"\[VeryThinSpace]", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
           RowBox[{
            SuperscriptBox["Q", "*"], "(", "x", ")"}], 
           SqrtBox[
            RowBox[{"1", "-", 
             SuperscriptBox["x", "2"]}]]}]}], 
         RowBox[{
          SuperscriptBox["P", "*"], "(", "x", ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "ee8b4892-9306-4698-aa67-18f5412a33f3"],
 " "
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->71366511,ExpressionUUID->"d4c96ebe-d43e-47ca-bbd6-8b743003daae"],

Cell["with", "TechNoteText",
 CellID->1161075351,ExpressionUUID->"767303df-a77c-4a92-bf94-5d1185b7c25f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        RowBox[{"-", "1"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "86093d13-c188-4175-818c-5ff156846bd4"],
 " ,        \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", "(", "x", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"x", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]]}], "x"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "515445c2-2d4e-4408-baa1-d61a79c428d6"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->9523968,ExpressionUUID->"91bee910-5820-4044-982c-39e520ead0bf"],

Cell[TextData[{
 StyleBox["if and only if",
  FontSlant->"Italic"],
 " polynomials ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "86900f9f-2773-46d4-a99f-2972d9ccf00f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "442b030d-69d4-4ef8-b3c4-5cd4625d4705"],
 " satisfy"
}], "TechNoteText",
 CellID->297671935,ExpressionUUID->"770703a0-5fd9-434d-9663-70340f62aee3"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "36e1877b-501a-4cfa-af5b-18113cc560ff"],
 " is of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "9e153982-412f-4ef0-88e0-63c6f4db5bb9"],
 " or less, and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "f4f917a0-1b5b-4728-b98b-39b4785b0362"],
 " is degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "ca453c1b-cb59-4495-a3c0-9cdc81a7a52a"],
 " or less;"
}], "ItemNumbered",
 CellID->1198257659,ExpressionUUID->"d0d10928-2e77-42a3-9299-b14ce50b79be"],

Cell[TextData[{
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "7b4cc882-3f4d-477b-a161-1c029139259e"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"955d44c7-1054-4d59-a486-fa7d0e426317"],
 ", and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "fd6cea49-2a35-4482-bc47-ae922cd0f439"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", "-", 
       RowBox[{"1", " ", "mod", " ", "2"}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"4e4e45d2-fb1e-4732-8c55-ed0e7e44b250"],
 "; and"
}], "ItemNumbered",
 CellID->687775779,ExpressionUUID->"87474f81-8799-4a9f-a2d0-a753cd280d9b"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"P", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"Q", "(", "x", ")"}], "\[RightBracketingBar]"}], "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        SuperscriptBox["x", "2"]}], ")"}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"9d4bb454-f395-4e1f-a66c-0785f2089984"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "654b79e2-a04d-41b8-b2b8-90ac99d536cd"],
 " in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "0b708775-2d02-4994-b791-5d9cd121e864"],
 "."
}], "ItemNumbered",
 CellID->1964879951,ExpressionUUID->"55cfcee9-d0ea-4700-9aa9-2311a754ac92"],

Cell[TextData[{
 "An ",
 StyleBox["even",
  FontSlant->"Italic"],
 " and ",
 StyleBox["odd",
  FontSlant->"Italic"],
 " function has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "a3203dd1-2f71-4c4d-9ab0-dd18806592b2"],
 ", respectively. Polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "d4721f4e-1993-4e38-9255-20b914e29638"],
 " is said to be of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], TraditionalForm]],ExpressionUUID->
  "98fd76c8-2df6-491f-a986-3cbdc3ed4a69"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Q", "(", "x", ")"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"5bf7ac1d-879a-4632-beb6-bf78c6a94740"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "37d1e767-4ed3-4e8e-94a2-24dfe1f1e26c"],
 ". "
}], "TechNoteText",
 CellID->1043059083,ExpressionUUID->"f1e29e41-28ea-4815-a36f-08e995052ae6"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Symmetric Quantum Signal Processing", "TechNoteSection",
 CellID->1845451401,ExpressionUUID->"f9c87b7b-0278-42c2-b1b9-64ee1b86b9d7"],

Cell[CellGroupData[{

Cell["Real Quantum Signal Processing", "Subsection",
 CellID->716095192,ExpressionUUID->"6bc9eaee-3924-4998-a844-403959c0bb1f"],

Cell[TextData[{
 "Dealing with both polynomials ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "e265011c-2ae4-4c93-ade5-8d5b4c0aa23d"],
 " and ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "43397449-b1a8-45de-83e4-38736b9cc6d0"],
 " requires a strong normalization constraint (3) in the above theorem. \
Fortunately, we are often interested only in ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "3a880bd2-8719-4322-952b-04d51d1036d6"],
 " with ",
 Cell[BoxData[
  FormBox["Q", TraditionalForm]],ExpressionUUID->
  "564bee24-5f1b-45bb-8714-f793c071e37c"],
 " out of concern. Moreover, in many practical applications, the target \
polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"5cd7430d-65f3-4eb7-aaf0-dbac8bb7e14e"],
 " is real valued."
}], "TechNoteText",
 CellID->1638814136,ExpressionUUID->"ed4653fe-ce92-4d85-8a23-16a7e805f6a5"],

Cell[TextData[{
 StyleBox["Corollary",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(GSLWiebe, 2019)"]], "https://doi.org/10.1145/3313276.3316366"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "20249074-5ccc-4db6-abd4-c6e9f5eb2ff8"],
 ": Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"e6997045-80cb-461a-83e9-0bce3d77c591"],
 " be a real-valued polynomial of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "\[GreaterEqual]", "1"}], TraditionalForm]],ExpressionUUID->
  "d0e2ad56-a7d8-4e85-ade8-541fb4b008e1"],
 " such that."
}], "TechNoteText",
 CellID->1657749463,ExpressionUUID->"a4bf2868-84df-49e6-93e1-9d133e34c219"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "target"], TraditionalForm]],ExpressionUUID->
  "63b860ee-b1fb-4406-b418-6097fb788240"],
 " has parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"8ab8b236-ed5f-497d-a5a5-af2ca6a402c6"],
 "; and"
}], "ItemNumbered",
 CellID->1633062763,ExpressionUUID->"58a5fd1a-cf0a-4aac-845d-afae54322676"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{
       SubscriptBox["P", "target"], "(", "x", ")"}], 
      "\[RightBracketingBar]"}], "2"], "\[LessEqual]", "1"}], 
   TraditionalForm]],ExpressionUUID->"505d5393-706e-49b0-9af7-57c4f423291e"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "79fe3359-0ea9-4deb-af02-702dc5153ecc"],
 " in the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"-", "1"}], ",", "1"}], "]"}], TraditionalForm]],ExpressionUUID->
  "78990564-452b-4128-8178-1e673fa70158"],
 "."
}], "ItemNumbered",
 CellID->76705129,ExpressionUUID->"6fe78646-09ca-4c23-863f-fc576fbf07af"],

Cell[TextData[{
 "Then, there exists complex-valued polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "58fa5ba4-c7c1-488b-ad3c-75cfc3c62490"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "419afd81-b366-482f-842c-a6393205943e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "\[Element]", 
    SuperscriptBox["\[DoubleStruckCapitalR]", 
     RowBox[{"d", "+", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "2dec38d2-7554-4d9a-97e7-da25d1b374a7"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{"Re", "[", 
     RowBox[{"P", "(", "x", ")"}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "874ca963-f0b9-42af-81a0-eb1c84b12ad9"],
 " and"
}], "TechNoteText",
 CellID->758900752,ExpressionUUID->"e0dd6fdf-22e9-46c8-aa60-9215723fdd86"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["\[Phi]", "0"], "Z"}]], 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{"k", "=", "1"}], "d"], "[", 
       RowBox[{
        RowBox[{"W", "(", "x", ")"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          SubscriptBox["\[Phi]", "k"], "Z"}]]}], "]"}]}], "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"P", "(", "x", ")"}], "*"},
        {
         RowBox[{"\[VeryThinSpace]", "*"}], "*"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "ca724198-c2fa-4319-a3d1-504d1640a284"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1679183788,ExpressionUUID->"a807f24e-c6e7-430b-a452-64ebe2978921"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["*", TraditionalForm]],ExpressionUUID->
  "84c97eb3-6f38-4c11-9115-568c2d38e07c"],
 " indicates that the corresponding matrix elements are irrelevant."
}], "TechNoteText",
 InitializationCell->True,
 CellID->134043131,ExpressionUUID->"85434f03-694e-43ee-9a27-d30d938c2777"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Symmetric Quantum Signal Processing", "Subsection",
 CellID->1913603881,ExpressionUUID->"eb6275a9-0c2a-4f36-adbe-6fcb620977c9"],

Cell[TextData[{
 "Expanding a real polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"c283bb15-aeea-44be-947a-2c5e2bc1127b"],
 " of degree ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", " "}], TraditionalForm]],ExpressionUUID->
  "e3529188-a5af-49a7-bb0c-da8b2fcc5baf"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "-", 
    RowBox[{"2", 
     RowBox[{"(", 
      RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"802acb60-ef28-4ed2-bdf4-6ec07a97e3ca"],
 " in the Chebyshev polynomials ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "13e2af6c-5cf6-4a84-adc7-60de04231469"],
 ","
}], "TechNoteText",
 CellID->1190696816,ExpressionUUID->"465b3a4e-63a8-46ea-840e-316e70d733bd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "target"], "(", "x", ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"k", "=", "0"}], "d"], 
     SubscriptBox["c", "k"], 
     RowBox[{
      SubscriptBox["T", "k"], "(", "x", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"96c50dd7-92d7-4b46-b4f5-7101f18d3751"],
 ","
}], "TechNoteText",
 CellID->541777561,ExpressionUUID->"32e57fbd-9cd7-4103-906a-5e9fdd17a967"],

Cell[TextData[{
 "requires only ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "d"], ":=", 
    RowBox[{"\[LeftCeiling]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"d", "+", "1"}], ")"}], "/", "2"}], "\[RightCeiling]"}]}], 
   TraditionalForm]],ExpressionUUID->"c6bcb8ef-5df9-426d-9531-a73e26d05efe"],
 "real coefficients with the rest being identically zero. This implies that \
there are unnecessarily many variables in the phase vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[Phi]", "\[RightVector]"], ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"11347826-0705-48e7-b951-dd6c6708b12a"],
 ". It turns out to be useful to impose the symmetry, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "0"], ",", 
      SubscriptBox["\[Phi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "d"]}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Phi]", "d"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Phi]", "1"], ",", 
      SubscriptBox["\[Phi]", "0"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"910c5ff8-111f-4ca2-aa9c-195a45a032cb"],
 ", which leaves only ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "d"], TraditionalForm]],ExpressionUUID->
  "916feebb-8161-4f55-9eee-57b1d91aeba1"],
 " independent phase variables ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "c0951ef8-94d7-4e0a-b40b-33d6602b9cf3"],
 ". Such a quantum signal processing with symmetric phase vector is said to \
be ",
 StyleBox["symmetric",
  FontSlant->"Italic"],
 ". A symmetric quantum signal processing has its characteristic unitary \
matrix symmetric, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"]], "(", "x", ")"}], "=", 
    RowBox[{
     SubsuperscriptBox["U", 
      OverscriptBox["\[Phi]", "\[RightVector]"], "T"], "(", "x", ")"}]}], 
   TraditionalForm]],ExpressionUUID->"295111c6-8d75-4344-ac3d-ea382fddf02e"],
 ", and the polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "a0ef7fad-29ee-4fc9-9473-48b677c05a88"],
 " is real ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021: Theorem 2)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "58002dd1-fc53-4357-a0e0-e5c3ae6805b8"],
 "."
}], "TechNoteText",
 CellID->2103131023,ExpressionUUID->"32ddf03b-038a-48fa-930c-81bf5d54ddc9"],

Cell[TextData[{
 "Given a ",
 StyleBox["reduced",
  FontSlant->"Italic"],
 " set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[CurlyPhi]", "0"], ",", 
     SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["\[CurlyPhi]", 
      RowBox[{
       SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], TraditionalForm]],
  ExpressionUUID->"57ef8661-b199-4a28-b26d-d8acb6e4e925"],
 " of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["n", "d"], TraditionalForm]],ExpressionUUID->
  "3f25f9bf-2a22-4b39-b879-406305739053"],
 " independent phase variables and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"\[PlusMinus]", "1"}]}], TraditionalForm]],ExpressionUUID->
  "43ac3227-7e12-4643-8acc-f2f646ea49ea"],
 " for a symmetric quantum signal processing, one can recover the ",
 StyleBox["full vector",
  FontSlant->"Italic"],
 " of phase variables as follows:"
}], "TechNoteText",
 CellID->1062312889,ExpressionUUID->"0a39febb-e27d-4b91-8841-5bcae61f3f9e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{
     RowBox[{"+", "1"}], "\[RightTeeArrow]", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       RowBox[{"2", 
        SubscriptBox["\[CurlyPhi]", 
         RowBox[{
          SubscriptBox["n", "d"], "-", "1"}]]}], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", 
       SubscriptBox["\[CurlyPhi]", "0"]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"4227985e-1da7-4c26-bb37-41f74da8e110"],
 " (notice the factor of 2 for technical convenience),"
}], "TechNoteText",
 CellID->943846728,ExpressionUUID->"12ee2728-d4a5-442b-9f70-3ec1fc4e0ec6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{
     RowBox[{"-", "1"}], "\[RightTeeArrow]", 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]], ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", 
       SubscriptBox["\[CurlyPhi]", "0"]}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"11ef8649-3438-4adb-bc36-b728601fdb83"],
 "."
}], "TechNoteText",
 CellID->875354969,ExpressionUUID->"89c971e0-e143-48e8-8d95-c81cdb6c3be2"],

Cell[TextData[{
 "The pair ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[CurlyPhi]", "0"], ",", 
      SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[CurlyPhi]", 
       RowBox[{
        SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], "\[Rule]", 
    RowBox[{"(", 
     RowBox[{"p", "=", 
      RowBox[{"\[PlusMinus]", "1"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"cf73cf62-3c4b-4587-8e93-7ec9fe001f96"],
 " is called the ",
 StyleBox["reduced phase vector",
  FontSlant->"Italic"],
 " to be distinguished from the ",
 StyleBox["full phase vector",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1012750098,ExpressionUUID->"85e9e573-342f-4bf6-b96d-bd8e6fb90f30"],

Cell[TextData[{
 "The correspondence between the reduced and full phase vector is closely \
related to that between the ",
 ButtonBox["reduced and full Chebyshev coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevCoefficients"],
 " list."
}], "TechNoteText",
 CellID->980635044,ExpressionUUID->"ad135049-6fa4-42e7-9070-151077100195"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Finding Quantum Signal Processing", "TechNoteSection",
 CellID->945509203,ExpressionUUID->"ae753a6c-94f7-441b-b22c-3457809f061d"],

Cell[TextData[{
 "Given a real-valued target polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"7571a79f-a633-4687-b618-d5ea0c7c9f4f"],
 " of degree ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "6c448023-4860-404c-8a46-b0fe6b05ce38"],
 " and parity ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      RowBox[{"(", 
       RowBox[{"d", " ", "mod", " ", "2"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"cb05acef-b935-457a-b8b8-a80bf89a9af6"],
 ", the reduced phase vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       SubscriptBox["\[CurlyPhi]", "0"], ",", 
       SubscriptBox["\[CurlyPhi]", "1"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[CurlyPhi]", 
        RowBox[{
         SubscriptBox["n", "d"], "-", "1"}]]}], "}"}], ",", 
     RowBox[{"p", "=", 
      RowBox[{"\[PlusMinus]", "1"}]}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"36821cc0-d65e-4d6f-9939-6efb999f3633"],
 " can be found by using the recursion relation in the proof of Corollary ",
 ButtonBox["(GSLWiebe, 2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1145/3313276.3316366"], None}],
 ". Unfortunately, this method is numerically unstable, and it was pointed \
out that this method requires ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    RowBox[{"d", "\[VeryThinSpace]", 
     RowBox[{"log", "(", 
      RowBox[{"d", "/", "\[Epsilon]"}], ")"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"eb2d8c66-4f2e-4478-ab57-90c4a3200124"],
 " bits of precision, where ",
 Cell[BoxData[
  FormBox["\[Epsilon]", TraditionalForm]],ExpressionUUID->
  "52a8fa3c-7bd7-49be-9c8c-cd854c9680d4"],
 " is the admitted tolerance ",
 ButtonBox["(Haah, 2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.22331/q-2019-10-07-190"], None}],
 "."
}], "TechNoteText",
 CellID->935659944,ExpressionUUID->"8d551a44-728a-457d-9b81-53f8472ad6db"],

Cell[TextData[{
 "Later, a new optimization-based method was proposed to find a quantum \
signal processing given a target polynomial ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["(Dong, Meng, Whaley and Lin, 2021)"]], 
    "https://doi.org/10.1103/PhysRevA.103.042419"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "b9db62b4-7831-42fe-849f-d2d90ad04a8b"],
 ". "
}], "TechNoteText",
 CellID->1695259150,ExpressionUUID->"77d4c637-4f09-4e3f-a7e9-75029e65c600"],

Cell[TextData[{
 ButtonBox["Q3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 " follows ",
 ButtonBox["Dong, Meng, Whaley and Lin (2021)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/PhysRevA.103.042419"], None}],
 ", and provides an implementation using the built-in local optimizer ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["FindMinimum"]], "paclet:ref/FindMinimum"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e0bd94d9-2c70-4239-80cf-32eb8ca51173"],
 " as well as the original implementations in ",
 ButtonBox["QSPPACK",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://github.com/qsppack/QSPPACK"], None}],
 " by Dong, Wang, Meng, Ni and Lin; see ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QSPFind"]], "paclet:QuantumMob/Q3/ref/QSPFind", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c6e63fb4-aa6e-4f0c-8c53-4bdfa00e993f"],
 " for more details."
}], "TechNoteText",
 CellID->1819995317,ExpressionUUID->"33816bed-ac4f-4842-8864-b46cf9875460"],

Cell[TextData[{
 "Note that the target polynomial ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"1091f589-6ef9-43e7-ad62-483159c3721f"],
 " is specified in terms of the ",
 ButtonBox["Chebyshev coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevCoefficients"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "target"], "(", "x", ")"}], TraditionalForm]],
  ExpressionUUID->"c23ad765-11cd-401b-8c17-d385799348cb"],
 " is assumed to be expanded in the ",
 ButtonBox["Chebyshev series",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ChebyshevSeries"],
 ". This is natural because\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{"[", 
      RowBox[{"W", "(", "x", ")"}], "]"}], "k"], "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{
         SubscriptBox["T", "k"], "(", "x", ")"}], 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]], 
         RowBox[{
          SubscriptBox["U", 
           RowBox[{"k", "-", "1"}]], "(", "x", ")"}]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["x", "2"]}]], 
         RowBox[{
          SubscriptBox["U", 
           RowBox[{"k", "-", "1"}]], "(", "x", ")"}]}], 
        RowBox[{
         SubscriptBox["T", "k"], "(", "x", ")"}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "4b345359-da07-48dd-ba93-6961f13eef5d"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "a9f897da-e258-4464-90ed-196a78f3a5a3"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "k"], "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "0ce1e1d1-1d7c-4dff-ae2a-4ec92ea8d79c"],
 " are the Chebyshev polynomials of the first and second kinds, respectively,\
\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["T", "k"], "(", "x", ")"}], ":=", 
    RowBox[{"cos", "(", 
     RowBox[{"k", "\[VeryThinSpace]", "\[Theta]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"fb01035d-7f3d-4053-8bab-d7a7921fd5ee"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "k"], "(", "x", ")"}], ":=", 
    RowBox[{
     RowBox[{"sin", "(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"k", "+", "1"}], ")"}], "\[Theta]"}], ")"}], "/", 
     RowBox[{"sin", "(", "\[Theta]", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"4949e15a-99f3-4ef8-82ee-851b3f89c158"],
 "\[LineSeparator]with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "(", "\[Theta]", ")"}], ":=", "x"}], TraditionalForm]],
  ExpressionUUID->"de8b285a-36f0-422c-b137-f72a17504233"],
 "."
}], "TechNoteText",
 CellID->44302011,ExpressionUUID->"8106d0a0-5a06-4336-96f4-cbb11f5f228f"]
}, Open  ]],

