     "7c9062a5-ebb0-4d1e-87dc-f3f78c01c1c9"]},
   {
    TemplateBox[{
      Cell[
       TextData["ChebyshevApproximation"]], 
      "paclet:QuantumMob/Q3/ref/ChebyshevApproximation", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->{"DefinitionBox", CellFrame -> 0}], Cell["\<\
Finds the Chebyshev expansion coefficients of a polynomial approximating a \
given function\
\>", "TechNoteTableText",ExpressionUUID->
     "269579b7-b036-480a-ad1f-fd5520aa92c4"]}
  }]], "DefinitionBox",
 CellID->44031775,ExpressionUUID->"7ae89dd3-a955-4f9b-aab0-cfa283bf33ac"],

Cell["Q3 functions related to quantum signal processing.", "TechNoteCaption",
 CellID->1307667857,ExpressionUUID->"40f8af75-4ec1-47d4-b31b-875bf7c57e3f"],

Cell["The examples here require Q3:", "TechNoteMathCaption",
 CellID->626029201,ExpressionUUID->"31f59068-da48-413c-96fa-5f254825f649"],

