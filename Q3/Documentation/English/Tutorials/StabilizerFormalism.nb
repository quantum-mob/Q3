Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->411747686,ExpressionUUID->"736697ea-dd47-4e6f-90a2-e203467e1938"],

Cell[TextData[{
 "In the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"60e751f6-494d-4078-99f3-a8c4226b7953"],
 ", eight different global phase factors appear, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[ImaginaryI]", " ", "m", " ", 
      RowBox[{"\[Pi]", "/", "4"}]}]], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
      "7"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "f4b22044-1dac-43aa-9410-63831354b345"],
 ". In many cases, these factors play no role and it is pointless to \
distinguish Clifford operators differing only by these factors. \
Mathematically, as in the full Pauli group, one can ignore these factors by \
introducing a quotient group"
}], "TechNoteText",
 CellID->81583927,ExpressionUUID->"1743fb45-fe10-4f3f-b064-46e9b541a869"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], ":=", 
    RowBox[{
     RowBox[{
      OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], "/", 
     RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"cb2a22c9-51c4-4be9-a3ac-928104e07e6b"],
 ","
}], "DisplayMath",
 CellID->1086494303,ExpressionUUID->"344f5fa7-4520-43a2-b8d4-d533a58d2d2b"],

Cell["where", "TechNoteText",
 CellID->656300080,ExpressionUUID->"6261a7e3-8903-4b05-9ec1-c1345677c574"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "m", " ", 
          RowBox[{"\[Pi]", "/", "4"}]}]], 
        RowBox[{
         SuperscriptBox["I", 
          RowBox[{"\[CircleTimes]", "n"}]], ":", "m"}]}], "=", "0"}], ",", 
      "1", ",", "2", ",", "\[Ellipsis]", ",", "7"}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"cbcd86e4-d230-48c9-8eaa-2c9984189450"],
 "."
}], "DisplayMath",
 CellID->959433568,ExpressionUUID->"f1f4e6f9-1861-4bcf-a7ea-359e384d0486"],

Cell[TextData[{
 "is the center of the full Clifford group. This quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"ee96547a-2532-48f9-a4be-3d40951158d2"],
 " is called the ",
 StyleBox[ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1892755700,ExpressionUUID->"54c47dff-875c-45ab-8329-96bdd23e204d"],

