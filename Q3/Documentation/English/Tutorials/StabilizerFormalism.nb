      Ket[<|$CellContext`S[3, QuantumMob`Q3`$] -> 0|>] + 
      Ket[<|$CellContext`S[3, QuantumMob`Q3`$] -> 1|>]]], 
    RowBox[{"2", " ", 
     SqrtBox["2"]}]]}], "}"}]], "Output",
 CellLabel->"Out[598]=",
 CellID->1023989973,ExpressionUUID->"1fdf586b-dc29-4931-b6be-5d80e0f06fe4"]
