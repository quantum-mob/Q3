      TemplateBox[{"\"Y\""},
       "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
     $CellContext`S[1, 2]]}], ",", 
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{"\<\"I\"\>", "\[CircleTimes]", 
      TemplateBox[{"\"X\""},
       "RowDefault"]}],
     $CellContext`S[2, 1]]}], ",", 
