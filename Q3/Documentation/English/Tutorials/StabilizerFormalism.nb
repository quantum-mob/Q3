Cell[BoxData[{
 RowBox[{
  RowBox[{"G1", "=", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "1"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"3", ",", "1"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G2", "=", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "3"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"3", ",", "3"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"PauliForm", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"G1", ",", "G2"}], "}"}], ",", 
    RowBox[{"ss", "=", 
     RowBox[{"S", "@", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}]}]}], "]"}], "//", 
