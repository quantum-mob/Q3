   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", 
     TemplateBox[{"\"Y\""},
      "RowDefault"]}],
    $CellContext`S[2, 2]], ",", 
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"X\""},
      "RowDefault"], "\[CircleTimes]", 
     TemplateBox[{"\"Y\""},
      "RowDefault"]}],
    QuantumMob`Q3`Multiply[
     $CellContext`S[1, 1], 
     $CellContext`S[2, 2]]], ",", 
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"Z\""},
      "RowDefault"], "\[CircleTimes]", 
     TemplateBox[{"\"Y\""},
      "RowDefault"]}],
    QuantumMob`Q3`Multiply[
     $CellContext`S[1, 3], 
