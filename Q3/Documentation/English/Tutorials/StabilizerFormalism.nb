Cell[CellGroupData[{

Cell["Gottesman Vectors", "Subsection",
 CellTags->"Section14",
 CellID->1944777498,ExpressionUUID->"e512e591-6993-47c9-81fa-c4210b4884f8"],

Cell[TextData[{
 "Ignoring the phase factors leads to a drastically simple structure of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"b5a9fa5e-0752-4cff-b892-fd5ba730caf2"],
 ", compared to the full Pauli group  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"aba24373-7d7e-46f6-89b0-69bdc302bdd4"],
 ". For example, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", " ", "Y"}], TraditionalForm]],ExpressionUUID->
  "9e7ca400-5e06-4582-b4cb-7e16b5c813bd"],
 " is now equal to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", " ", "X"}], TraditionalForm]],ExpressionUUID->
  "7af97708-5220-4d8b-8a78-3145d8ec491a"],
 ", that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", "X\[ScriptCapitalZ]", ")"}], 
     RowBox[{"(", "Y\[ScriptCapitalZ]", ")"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"X", " ", "Y"}], ")"}], "\[ScriptCapitalZ]"}], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Y", " ", "X"}], ")"}], "\[ScriptCapitalZ]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"f08e337f-c40c-446c-a736-3bda03c0e2e9"],
 ". This means that unlike the full Pauli group  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"e0bd34b6-a704-4811-9d03-d0101c2ec25f"],
 ", the Pauli group  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"f103fa97-b4b6-43b2-b055-82cf295d4f57"],
 " is ",
 StyleBox["Abelian",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1174301546,ExpressionUUID->"505da8a8-a973-4a9b-93f7-4cad089fc9e5"],

Cell[TextData[{
 "Moreover, since ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"X", " ", "Z"}], "=", 
    RowBox[{
     RowBox[{"Z", " ", "X"}], "=", "Y"}]}], TraditionalForm]],ExpressionUUID->
  "0e4d2c37-b2f1-4510-a9d1-bcda3161f604"],
 " in the Pauli group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"7b55503a-e423-4547-8a39-ea06620329e1"],
 ", the latter is isomorphic to ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "fe7b03a3-e262-470f-9a4f-7249b4291096"],
 " with group multiplication given by addition modulo 2. By inspection, it is \
clear that the following correspondence yields an isomorphism between ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], " "}], TraditionalForm]],
  ExpressionUUID->"e319ae27-f70a-4dba-be54-28e4e72d20f9"],
 "and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", 
    RowBox[{"2", "n"}]], TraditionalForm]],ExpressionUUID->
  "ffeaf4bc-11b6-4195-bad2-1a841dc9e1cc"],
 ":"
}], "TechNoteText",
 CellID->1111367692,ExpressionUUID->"808a47dd-5675-4f71-8369-29338466a815"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"X", "<->", 
    RowBox[{"(", 
     RowBox[{"1", ",", "0"}], ")"}]}], ",", " ", 
   RowBox[{"Z", "<->", 
    RowBox[{"(", 
     RowBox[{"0", ",", "1"}], ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"2bffcdda-bf4d-4135-8cd2-1e4d021422e9"]], \
"DisplayMath",
 CellID->2091521485,ExpressionUUID->"da0ca021-fcf3-40e1-948f-a2a0148e9a9c"],

Cell[TextData[{
 "The correspondence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Y", "<->", 
    RowBox[{"(", 
     RowBox[{"1", ",", "1"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8f7046c1-ccc2-4e26-956b-f678f67f84de"],
 " follows automatically from the group multiplication (between cosets)."
}], "TechNoteText",
 CellID->41780652,ExpressionUUID->"69a654de-539e-426f-8746-32c74f80f86b"],

Cell["Equivalently, a Pauli operator of the form", "TechNoteText",
 CellID->2127749242,ExpressionUUID->"7ad963ea-9f4a-4923-b07a-e477582ec497"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["X", 
       SubscriptBox["x", "1"]], 
      RowBox[{
       SuperscriptBox["Z", 
        SubscriptBox["z", "1"]], "\[CircleTimes]", 
       SuperscriptBox["X", 
        SubscriptBox["x", "2"]]}], 
      RowBox[{
       SuperscriptBox["Z", 
        SubscriptBox["z", "2"]], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
       SuperscriptBox["X", 
        SubscriptBox["x", "n"]]}], 
      SuperscriptBox["Z", 
       SubscriptBox["z", "n"]]}], "\[Element]", 
     RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"3a540565-7725-4709-84d8-276d249abbdb"]
}], "TechNoteText",
 CellID->1183820450,ExpressionUUID->"aad4714f-1e37-4c36-9d6e-5504a3b2171e"],

Cell["corresponds to the vector", "TechNoteText",
 CellID->34313695,ExpressionUUID->"2b3cdc22-61d7-4987-b6b2-181ac45ee0af"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "=", 
