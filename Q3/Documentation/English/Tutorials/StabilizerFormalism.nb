Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->964472172,ExpressionUUID->"9ba793f5-3d4d-495a-bef0-5d32363532d3"],

Cell[TextData[{
 "In most applications of Pauli operators, an explicit multiplication table \
is not necessary, commutation (or anti-commutation) of the elements is \
sufficient. As long as the commutation of the elements is concerned, one can \
ignore the phase factors ",
 StyleBox["\[PlusMinus]1", "Input"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], TraditionalForm]],
  ExpressionUUID->"1dd24c8f-37ba-4987-b7a7-cc46c5f86f25"],
 " in the elements of the full Pauli group. Mathematically, this can be \
achieved by considering the ",
 StyleBox["quotient group",
  FontSlant->"Italic"]
}], "TechNoteText",
 CellID->217137121,ExpressionUUID->"269c50b2-871e-4616-adaa-67eba6ac9628"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], ":=", 
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "/", 
    RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}]}]}], 
  TraditionalForm]],ExpressionUUID->"922bd5f4-b537-42c4-b129-a6bc2550d895"]], \
"DisplayMath",
 CellID->848876394,ExpressionUUID->"99e93c77-9d16-45e1-a3f3-4139efa8dced"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalZ]", "(", "n", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[PlusMinus]", 
       SuperscriptBox["I", 
        RowBox[{"\[CircleTimes]", "n"}]]}], ",", " ", 
      RowBox[{
       RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], " ", 
       SuperscriptBox["I", 
        RowBox[{"\[CircleTimes]", "n"}]]}]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"32c3fb01-1a60-4d57-9dca-1822a3754e17"],
 " is the center (the largest Abelian invariant subgroup) of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"9c5a6df1-0343-4e10-b3b8-59841db78eaa"],
 ".  This quotient group is called the ",
 StyleBox[ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
  FontSlant->"Italic"],
 StyleBox[".",
  FontSlant->"Italic"]
}], "TechNoteText",
 CellID->1331686937,ExpressionUUID->"06779a33-47a9-4359-9a0d-dacd6171cb54"],

Cell[TextData[{
 "As a quotient group, the Pauli group is a group of ",
 StyleBox["cosets",
  FontSlant->"Italic"],
 ", and the elements of the same meaning belong to the same coset."
}], "TechNoteText",
 CellID->587781125,ExpressionUUID->"96b9d8ea-0d08-4909-a728-e84143880f8f"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1630420175,ExpressionUUID->"39c486d3-82a8-46ed-880f-632ce73e1d69"],

Cell[TextData[{
 "In Q3, cosets in the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " are denoted by their representatives."
}], "TechNoteMathCaption",
 CellID->412591675,ExpressionUUID->"946c3b65-e6c2-4ccf-9893-b2f2f331c665"],

