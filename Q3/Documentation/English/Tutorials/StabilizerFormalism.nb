Cell[TextData[{
 "Recall that the ",
 ButtonBox["Hadamard",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Hadamard"],
 " and ",
 ButtonBox["quadrant",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/quadrant"],
 " phase gates are represented by the following respective matrices."
}], "TechNoteMathCaption",
 CellID->1012720437,ExpressionUUID->"38ea2499-78e2-4639-99a2-0dbd5395bd8f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}], "//", "Matrix"}], "//", "MatrixForm"}], 
  " ", 
  RowBox[{"(*", 
   RowBox[{"the", " ", "Hadarmard", " ", "gate"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{"1", ",", "7"}], "]"}], "//", "Matrix"}], "//", "MatrixForm", " ", 
  RowBox[{"(*", 
   RowBox[{"the", " ", "quadrant", " ", "phase", " ", "gate"}], 
   "*)"}]}]}], "Input",
 CellLabel->"In[641]:=",
 CellID->1984482184,ExpressionUUID->"49e3d546-5be4-4a66-ae3b-1835aa4f50da"],

