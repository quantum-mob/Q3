Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->224472179,ExpressionUUID->"b829eb5e-5b36-46b5-a662-d5b0351f26e3"],

Cell[TextData[{
 "Since they generate the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 ", the ",
 ButtonBox["Hadamard",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Hadamard"],
 ", ",
 ButtonBox["quadrant",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/quadrant"],
 " phase, and ",
 ButtonBox["CNOT",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CNOT"],
 " gates are called the ",
 StyleBox["elementary Clifford gates",
  FontSlant->"Italic"],
 " or simply Clifford gates. Quantum circuits consisting of elementary \
Clifford gates are called ",
 StyleBox["Clifford circuits",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->67910332,ExpressionUUID->"5db0b00f-8be2-49ab-ad9f-b497260d7e91"],

Cell[TextData[{
 "As in the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 ", elements in the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 " appear redundantly and differ only in global phase factors."
}], "TechNoteText",
 CellID->1055133367,ExpressionUUID->"b5cf65f2-f837-4704-868f-af91333ed65e"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1236306268,ExpressionUUID->"b7411318-cb95-4202-9fdd-ae85fdff8c82"],

Cell[TextData[{
 "For example, this shows four elements of the ",
 ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
 " on two qubits. The last two elements are different from the first two only \
by a global phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]\[Pi]", "/", "4"}]], TraditionalForm]],
  ExpressionUUID->"391d937b-c03b-4c62-8331-0ff166751f2a"],
 "."
}], "TechNoteMathCaption",
 CellID->1854025890,ExpressionUUID->"d0ec80f8-6ca1-4a31-899c-0f9d023bbf70"],

