Cell["\<\
Each time, the final state on the first qubit is the same regardless of the \
outcome of the measurements on the second and third qubit.\
\>", "TechNoteText",
 CellID->12088970,ExpressionUUID->"1f90d4c7-348e-4080-8ea1-f45a15a42612"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Remote Implementation of CNOT", "Subsection",
 CellTags->"Section28",
 CellID->2044878396,ExpressionUUID->"1ec35dbc-92a3-4581-abd9-d8f94e23cd2c"],

Cell[TextData[{
 "The second example is a remote implementation of the ",
 ButtonBox["CNOT",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CNOT"],
 " gate using the pre-shared entangled pair of qubits."
}], "TechNoteText",
 CellID->2090398631,ExpressionUUID->"e47496b0-4c04-4883-a65c-fbd57af9a974"],

Cell["\<\
Suppose that Alice and Bob are located far away from each other, and there is \
no quantum channel available between them. Fortunately, they had shared and \
are maintaining a maximally entangled pair of qubits, and there is a \
classical channel available for communication between them.\
\>", "TechNoteText",
 CellID->497326297,ExpressionUUID->"c288470d-15a4-4328-a55f-aba264e3fa2c"],

Cell[TextData[{
 "Alice wants to implement a ",
 ButtonBox["CNOT",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CNOT"],
 " gate targeted on Bob's qubit, not the one involved in the shared entangled \
pair, controlled by her own qubit. The protocol is summarized in the \
following quantum circuit."
}], "TechNoteText",
 CellID->556719555,ExpressionUUID->"f54e3297-cb49-4f42-9ff1-f97eeb2753f4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Let", "[", 
   RowBox[{"Binary", ",", "x", ",", "m"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{"KetRegulate", "[", 
    RowBox[{
     RowBox[{"Ket", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"S", "[", "1", "]"}], "->", 
        RowBox[{"x", "[", "1", "]"}]}], ",", 
       RowBox[{
        RowBox[{"S", "[", "4", "]"}], "->", 
        RowBox[{"x", "[", "4", "]"}]}]}], "]"}], ",", 
     RowBox[{"S", "@", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2", ",", "3", ",", "4"}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"Ket", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], "->", 
      RowBox[{"x", "[", "1", "]"}]}], ",", 
     RowBox[{
      RowBox[{"S", "@", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3"}], "}"}]}], "->", 
      RowBox[{"m", "@", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3"}], "}"}]}]}], ",", 
     RowBox[{
      RowBox[{"S", "[", "4", "]"}], "->", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"x", "[", "1", "]"}], "+", 
         RowBox[{"x", "[", "4", "]"}]}], ",", "2"}], "]"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"core", "=", 
   RowBox[{"QuantumCircuit", "[", 
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"2", ",", "6"}], "]"}], ",", 
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "2", "]"}], ",", 
       RowBox[{"S", "[", "3", "]"}]}], "]"}], ",", "\"\<Separator\>\"", 
     ",", "\"\<Spacer\>\"", ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"CNOT", "[", 
        RowBox[{
         RowBox[{"S", "[", "1", "]"}], ",", 
         RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", 
       RowBox[{"CNOT", "[", 
        RowBox[{
         RowBox[{"S", "[", "3", "]"}], ",", 
         RowBox[{"S", "[", "4", "]"}]}], "]"}]}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"Measurement", "[", 
      RowBox[{"S", "[", 
       RowBox[{"2", ",", "3"}], "]"}], "]"}], ",", 
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "2", "]"}], ",", 
       RowBox[{"S", "@", 
        RowBox[{"{", 
         RowBox[{"3", ",", "4"}], "}"}]}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"S", "[", 
      RowBox[{"3", ",", "6"}], "]"}], ",", 
     RowBox[{"Measurement", "[", 
      RowBox[{"S", "[", 
       RowBox[{"3", ",", "3"}], "]"}], "]"}], ",", 
     RowBox[{"ControlledGate", "[", 
      RowBox[{
       RowBox[{"S", "[", "3", "]"}], ",", 
       RowBox[{"S", "[", 
        RowBox[{"1", ",", "3"}], "]"}]}], "]"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[711]:=",
 CellID->1510762017,ExpressionUUID->"db240aba-dd79-411a-bd02-1ea715e27c06"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"in", ",", "core", ",", "out", ",", 
