Cell[CellGroupData[{

Cell["Stabilizers: Concept", "TechNoteSection",
 CellTags->"Section11",
 CellID->1514564784,ExpressionUUID->"ef37f4c0-1f8c-4d54-bb17-3a5420a4fe0f"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5f3c4d79-36fc-4cd0-ac9f-2c4415d1bf0f"],
 " be a group of operators acting on the quantum states of a quantum system. \
In quantum computation, the most relevant group is the unitary group ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalU]", "(", 
    SuperscriptBox["2", "n"], ")"}], TraditionalForm]],ExpressionUUID->
  "ab1ea7fd-bec8-4e62-9071-843a90b0f48f"],
 " of quantum logic gate operators on n qubits. "
}], "TechNoteText",
 CellID->1166656797,ExpressionUUID->"894e5d6f-f1ac-43e2-b401-01f431173e57"],

Cell[CellGroupData[{

Cell["Stabilizer of a quantum state", "Subsection",
 CellTags->"Section12",
 CellID->1475090069,ExpressionUUID->"bd831bf0-973b-4077-bc94-fd9e8baee289"],

Cell[TextData[{
 "Suppose that |\[Psi]\:27e9 is a quantum state. When it remains unchanged \
under an operator ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "c49a441d-4cbe-4fb4-8259-10137d46cfea"],
 " in the group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "2f160611-37ad-48e3-86c3-2a7b879909f7"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"G", 
     TemplateBox[{"\[Psi]"},
      "Ket"]}], "=", 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "7fa70b5e-5023-4426-ac1f-c8d1fa75ffad"],
 ", the state is said to be stabilized by ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "fb4acecb-4043-4061-859f-9bf07cdb214c"],
 ", or equivalently, ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "ed4f43c5-7692-44d4-b12e-ca2111ddd423"],
 " is said to stabilize ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8ef8e40d-8c9c-4aa3-822c-c6d0cc2726c5"],
 "."
}], "TechNoteText",
 CellID->1287568715,ExpressionUUID->"f3fe712e-06e6-421e-9297-04faff17f0d0"],

Cell[TextData[{
 "For example, Bell state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPhi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"00"},
        "Ket"], "+", 
       TemplateBox[{"11"},
        "Ket"]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "da00e6d5-4103-48f0-a4fc-1a6efd7070ae"],
 "is stabilized by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "\[CircleTimes]", "X"}], TraditionalForm]],ExpressionUUID->
  "ad3ed4ed-2b0b-44ff-89e5-2dad2645ef55"],
 "."
}], "TechNoteText",
 CellID->2122165833,ExpressionUUID->"236fd956-13cb-4235-bc2b-97018899caa3"],

