Cell[CellGroupData[{

Cell["The Clifford Group", "Subsection",
 CellTags->"Section15",
 CellID->2090860113,ExpressionUUID->"3e9cdddc-706a-4183-9405-c33946ea871c"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["full Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullCliffordGroup"],
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["C", "~"], "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"e8a83eac-b267-4d73-a470-b8b1ba530d54"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ef89b240-9285-41b0-b80d-d2c66c561eaf"],
 " qubits is the group of unitary operators ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "9f8af7c5-3b95-4077-9b4c-185b657f2bdf"],
 " that leave the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], 
   TraditionalForm]],ExpressionUUID->"c96bea27-1d2a-4ff7-a12e-414690421a38"],
 " invariant under conjugation, that is,"
}], "TechNoteText",
 CellID->1811003330,ExpressionUUID->"148995bd-b982-44f4-b420-432c8d17bb63"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n", ")"}], ":=", 
    RowBox[{"{", 
     RowBox[{"U", ":", 
      RowBox[{
       RowBox[{"U", " ", "P", " ", 
        SuperscriptBox["U", "\[Dagger]"]}], "\[Element]", 
       RowBox[{
        RowBox[{
         OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}], "  ", 
        "for", " ", "all", " ", "P"}], "\[Element]", 
       RowBox[{
        OverscriptBox["\[ScriptCapitalP]", "~"], "(", "n", ")"}]}]}], "}"}]}],
    TraditionalForm]],ExpressionUUID->
  "e387243d-aef1-406d-80de-20cf98a3b42a"],
 "."
}], "DisplayMath",
 CellID->1247238379,ExpressionUUID->"69ae4347-3c8c-4c1d-b84d-cead6cc543b6"],

Cell[TextData[{
 "The elements of the full Clifford group on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "3729bc40-749b-41d7-b4c6-1f503278ca3e"],
 " qubits are called (",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "8a7a1032-6fde-41b2-9fc0-68fb8f9461a9"],
 "-qubit) ",
 StyleBox["Clifford operators",
  FontSlant->"Italic"],
 ". The Clifford group was first introduced in 1998 by Daniel Gottesman \
(Gottesman, 1998) when he reformulated the quantum error-correction codes in \
terms of stabilizers. The Clifford group is useful since stabilizers remain \
subgroups of the Pauli group under conjugation by its elements."
}], "TechNoteText",
 CellID->747557486,ExpressionUUID->"dc5e4812-5fd3-464b-8670-350bf5a4cc69"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->2025193890,ExpressionUUID->"de5a5903-45ec-427d-9d94-7a437f0be26d"],

Cell["The full Clifford group is huge.", "TechNoteMathCaption",
 CellID->1419332252,ExpressionUUID->"e9aa9428-0770-47d1-b0cf-6bf030cdade5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"grp", "=", 
  RowBox[{"FullCliffordGroup", "[", 
   RowBox[{"S", "@", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"GroupOrder", "[", "grp", "]"}]}], "Input",
 CellLabel->"In[637]:=",
 CellID->468808488,ExpressionUUID->"4330d66e-2cd0-49f0-9d1f-ed04dd9b82a6"],

Cell[BoxData[
 RowBox[{"FullCliffordGroup", "[", 
  RowBox[{"{", 
   RowBox[{
    InterpretationBox[
     SubscriptBox["S", 
      TemplateBox[{",", "\",\"", "1"},
       "RowWithSeparators"]],
     $CellContext`S[1, QuantumMob`Q3`$]], ",", 
    InterpretationBox[
     SubscriptBox["S", 
      TemplateBox[{",", "\",\"", "2"},
       "RowWithSeparators"]],
     $CellContext`S[2, QuantumMob`Q3`$]]}], "}"}], "]"}]], "Output",
 CellLabel->"Out[637]=",
 CellID->1875152316,ExpressionUUID->"56e0928e-ce4e-4154-99ea-93b340a1cb74"],

Cell[BoxData["92160"], "Output",
 CellLabel->"Out[638]=",
 CellID->1362455287,ExpressionUUID->"15a5f8bd-af6e-4930-8cba-90b6101cfbc7"]
}, Open  ]],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->388449927,ExpressionUUID->"a2546a7a-9b7e-47aa-89f7-90ab3db91368"],

Cell[TextData[{
 "It is thus useful to describe it in terms of generators. The full Clifford \
group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[ScriptCapitalC]", "~"], "(", "n"}], TraditionalForm]],
  ExpressionUUID->"8fb7fdc1-2702-4a7c-bc24-5cc241e39bf5"],
 ") is generated by ",
 ButtonBox["Hadamard",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Hadamard"],
 " gates and ",
 ButtonBox["quadrant phase",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Quadrant"],
 " gates on individual qubits, and ",
 ButtonBox["CNOT",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CNOT"],
 " (or equivalently ",
 ButtonBox["CZ",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CZ"],
 ") gates on pairs of qubits.We refer to it as the ",
 StyleBox["Gottesman theorem",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1337895988,ExpressionUUID->"5628b3bc-7a5e-4ee2-b26f-d9b60627e7cb"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->555327188,ExpressionUUID->"09e60ac9-f66c-4c04-af70-5b1b5b229555"],

