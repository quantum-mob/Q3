Cell[TextData[{
 "Next, we measure observable ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "a68e569e-875f-46da-b471-d7682e851fcd"],
 " on qubit ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "060b8a78-dcee-498d-8145-c86dcc731876"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"I", "\[CircleTimes]", "X", "\[CircleTimes]", "I"}]}], 
   TraditionalForm]],ExpressionUUID->"754f2baf-6efa-4e28-bb2e-81cd5a63b306"],
 ". Note that ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "3e219adf-46df-4bf7-8e77-2be1689c7b06"],
 " anti-commutes with the second generator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "2"], TraditionalForm]],ExpressionUUID->
  "db2720ac-b592-49df-ad0b-3d61962474a0"],
 " while it commutes with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "1"], TraditionalForm]],ExpressionUUID->
  "47270706-2cb8-4cfa-adc1-1763ea0b0968"],
 "."
}], "TechNoteMathCaption",
 CellID->120468585,ExpressionUUID->"a0b3ef20-3ce5-4735-afbd-116bbefb7282"],

