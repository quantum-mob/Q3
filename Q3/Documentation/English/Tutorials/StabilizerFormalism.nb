Cell[TextData[{
 "However, the classically-conditioned operation of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "3de8e427-3a1b-4230-a0fb-921a570658dc"],
 " on the third qubit right before the measurement of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "da768b1c-abff-4510-aac3-fd326b720fff"],
 " does not affect the result. On the other hand, the classically-conditioned \
operation of ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "9989dac8-dd35-4c61-b9a1-f0bd745519b3"],
 " on the second qubit is meaningless because the qubit has already been \
measured."
}], "TechNoteMathCaption",
 CellID->124923454,ExpressionUUID->"04b2717e-0208-48fe-be32-931a6f30dd5c"],

