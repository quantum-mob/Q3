Cell[CellGroupData[{

Cell["Properties of Stabilizers", "TechNoteSection",
 CellTags->"Section21",
 CellID->1536912246,ExpressionUUID->"9dfeb5da-0f72-49dd-8292-9a68f945210b"],

Cell[TextData[{
 "The simple structure and useful properties of the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " enable us to inspect many aspects of the stabilizers without peculiar \
specifications. Here we discuss and summarize the general properties of \
stabilizers that are to be exploited repeatedly later."
}], "TechNoteText",
 CellID->950812406,ExpressionUUID->"65d04fd3-5de4-46a7-8a95-84f4bd018dfe"],

Cell[TextData[{
 "An immediate consequence of the properties of the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 ", in particular that any two elements of a Pauli group either commutes or \
anti-commutes, is that all elements of a stabilizer must commute with each \
other. That is, any stabilizer is an Abelian subgroup of the Pauli group. \
Also recall that every element of a Pauli group squares to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "I"}], TraditionalForm]],ExpressionUUID->
  "aa5a2248-688c-4eca-aff6-c932d4544fa4"],
 ". If an operator in the Pauli group squares to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Minus]", "I"}], TraditionalForm]],ExpressionUUID->
  "727e4496-4c28-4f17-9b3d-2d94cb31378c"],
 ", then its eigenvalue must be ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], TraditionalForm]],
  ExpressionUUID->"0bff4ce4-f95b-4cbe-a6ce-ea5b56a5dace"],
 " and it can stabilize no state. Putting these observations together, we can \
set down the necessary conditions  in a compact form"
}], "TechNoteText",
 CellID->878290315,ExpressionUUID->"868bc69c-e87c-4c7a-840d-906001398f0e"],

Cell[TextData[{
 "All elements of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "b6a5a4ad-b9b7-48a8-8657-0763674673cb"],
 " commute."
}], "Item",
 CellID->1770218374,ExpressionUUID->"6e35b053-01ce-4f0f-b4d7-ae9098072485"],

Cell[CellGroupData[{

Cell[TextData[{
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "f29a1e79-d5cb-472a-88b6-05a079ed35b1"],
 " does not include ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Minus]", "I"}], TraditionalForm]],ExpressionUUID->
  "5370ada3-0ef4-4a86-9a23-c99cd992bb2c"],
 " as an element."
}], "Item",
 CellID->821766280,ExpressionUUID->"1db0abf1-c8eb-4a25-94e5-e5cca5148314"],

Cell[TextData[{
 "for a subgroup ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "67227ccc-a4f4-4591-9838-fa7d86264e10"],
 " of the Pauli group to stabilize a non-trivial subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "ff16200f-0516-424e-8628-ac313e2bd6e8"],
 "."
}], "TechNoteText",
 CellID->1793492531,ExpressionUUID->"31f47640-c143-4a56-9c60-835b3fe7eba3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Logical Subspace", "Subsection",
 CellTags->"Section169",
 CellID->958534103,ExpressionUUID->"409d591a-4162-462d-b384-470524a74eee"],

Cell[TextData[{
 "Let us now inspect the relation between a stabilizer and the subspace \
stabilized by it more closely. Suppose that ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "f2c5729c-8308-4e24-9f2d-db57823a255f"],
 " is a stabilizer on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "dfba4d0c-7920-4091-ab4f-28045dce0682"],
 " qubits generated by ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "fe2949d9-6c31-4acb-9011-bc9c63cbdb90"],
 " independent operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "1"], ",", 
    SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["G", "k"]}], TraditionalForm]],ExpressionUUID->
  "edb20cb1-1a12-485c-a1e5-19543c6c5f6c"],
 "."
}], "TechNoteText",
 CellID->1807832974,ExpressionUUID->"0ee6ba0d-eec5-49da-a9ab-b9393b640e7f"],

Cell[TextData[{
 "Since all elements in the stabilizer commute each other and square to ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "f71d75df-7c03-484e-a694-47c37026a2a7"],
 ", ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "8df7e4a0-aa89-45fc-9b41-23a424221f57"],
 " is essentially the same as ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", "k"], TraditionalForm]],
  ExpressionUUID->"1c27f2af-d073-4b91-a303-e183063cf643"],
 ". "
}], "TechNoteText",
 CellID->1650156262,ExpressionUUID->"13cf8da3-3fb4-4500-93d2-1dd5ebf95847"],

Cell[CellGroupData[{

Cell[TextData[{
 "Mathematically, ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "b69a6054-5f56-4fad-bd98-d366a4e66e4a"],
 " is isomorphic to the Abelian group ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[DoubleStruckCapitalZ]", "2", "k"], TraditionalForm]],
  ExpressionUUID->"2141740f-93eb-442b-9b83-3d5718f830e9"],
 " with the group multiplication given by addition modulo 2."
}], "Item",
 CellID->1572478076,ExpressionUUID->"edf367b6-f32f-4c99-8f90-5dfb7d9d2085"],

Cell[TextData[{
 "The states stabilized by ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "19de236e-551d-4a4c-8a0c-99263115ace8"],
 " are simultaneous eigenvectors of the generators of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "508f8ec5-2de6-4d83-89c4-f47a0a4124e3"],
 ". The more generators ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "f4843214-006e-41fc-8a8a-62e27cc19602"],
 " has, the more constraints the states have to satisfy. Naturally, a bigger \
number of generators of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "ccd4ee88-86ac-44d0-a144-c61b1d2cd7a0"],
 " results in a smaller dimension of the subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "936864cc-7398-4e56-95a2-f1ee5b1031ef"],
 " stabilized by ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "32fcfd87-7081-4e64-8c28-fc549d43f932"],
 "."
}], "TechNoteText",
 CellID->1705263350,ExpressionUUID->"74b315e4-9031-4d38-ac17-2f303a77f345"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The dimension of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "c15c3657-c32a-45c5-96eb-22cb82c69f48"],
 " is equal to ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", 
    RowBox[{"n", "\[Minus]", "k"}]], TraditionalForm]],ExpressionUUID->
  "e38f824c-e0c3-4122-a477-04a44f024ad0"],
 ". In other words, the subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "36df8d87-378b-4b98-bc83-6d58375ad936"],
 " can encode ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"n", "\[Minus]", "k"}], ")"}], TraditionalForm]],ExpressionUUID->
  "7bb52fce-1b55-4b2a-9353-a9c54fb85e06"],
 " logical qubits."
}], "Item",
 CellID->44370588,ExpressionUUID->"83ee84c3-a0ab-4607-b01e-5a0df11d9f94"],

Cell[TextData[{
 "This is one of the most basic properties that enable stabilizer codes. For \
a proof of this proposition, interested readers are referred to the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "4181204b-2e2b-4781-953c-7b4f1f1a1dcb"],
 "."
}], "TechNoteText",
 CellID->559647007,ExpressionUUID->"1efd237e-6c0e-46a9-a44c-3397e496fe2e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Logical Operators", "Subsection",
 CellTags->"Section170",
 CellID->8872789,ExpressionUUID->"58a0add0-2b1c-438f-bb29-b75aec3dcfbb"],

Cell[TextData[{
 "We have seen above that a subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "debc3db4-2bdb-4054-8e04-8b6e79d81f71"],
 " can be identified by its stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "22b20de1-97c4-4bf2-ac45-d7916bbeb7d5"],
 ". For quantum information processing within the subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "8dcc576f-257e-4b85-a0ab-d4aada16cc16"],
 ", one also needs to specify a logical basis of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "b0b46ac2-7abf-4df9-8afc-4a2faea1c26e"],
 ". In stabilizer formalism, logical basis states are specified indirectly \
through ",
 StyleBox["logical Pauli operators",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->948593080,ExpressionUUID->"74db144e-68cc-4c96-95f5-f8c3b5b32e3d"],

Cell[TextData[{
 "Let us first take an example. Consider again the subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "78634818-4d41-49b4-b7a3-26c732ff0f6f"],
 " stabilized by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalS]", " ", "=", " ", 
    RowBox[{"\:27e8", " ", 
     RowBox[{"{", 
      RowBox[{"Z", "\[CircleTimes]", "Z"}], "}"}], " ", "\:27e9"}]}], 
   TraditionalForm]],ExpressionUUID->"ebf177fb-5d54-4f89-872b-e182fd79ce94"],
 ". Suppose that we choose the two states"
}], "TechNoteText",
 CellID->85300232,ExpressionUUID->"28eab6db-72dc-414e-ae52-64a62ec547bf"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      OverscriptBox["0", "_"]},
     "Ket"], "=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"00"},
       "Ket"], "+", 
      TemplateBox[{"11"},
       "Ket"]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "b1d8d137-1255-49d4-a6f8-a0c95968715e"],
 ",    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      OverscriptBox["1", "_"]},
     "Ket"], "=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"00"},
       "Ket"], "-", 
      TemplateBox[{"11"},
       "Ket"]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "b6c323c0-505c-4aa6-a357-dce4433d15ed"]
}], "DisplayMath",
 CellID->1269406675,ExpressionUUID->"ea6229f9-5faf-47b4-aa0d-34c7b570a0c3"],

Cell[TextData[{
 "as the logical basis states. Within ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "5286c7ca-ff8e-4d54-8c64-cac7778cd0c5"],
 ", the operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "\[CircleTimes]", "X"}], TraditionalForm]],ExpressionUUID->
  "ed8caaef-aa5c-430a-889a-e4f5e7a60f29"],
 " has eigenstates ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["0", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "587d1f72-3573-4eb1-80f6-dfcdce414df9"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["1", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e465d2a3-0fa5-4156-b974-7a775c996022"],
 " with eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "3b5a23be-614a-4320-b03d-838b33b35e56"],
 ", respectively, and hence behaves like the Pauli Z operator on a single \
qubit. In this sense, we put ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["Z", "_"], "=", 
    RowBox[{"X", "\[CircleTimes]", "X"}]}], TraditionalForm]],ExpressionUUID->
  "5deb7797-4777-41dd-8033-8532486638cf"],
 " and regard it as the logical Pauli Z operator. On the other hand, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", "\[CircleTimes]", "I"}], TraditionalForm]],ExpressionUUID->
  "66e8d401-1a80-4f1a-909a-a481dfb668eb"],
 " flips ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["0", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f59c3130-946b-4336-842f-65c9b13bdbad"],
 " to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["1", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3836a4cc-807c-434a-acac-5f15a78738c3"],
 " and vice versa. Furthermore, it fixes the relative phase between the \
logical basis states. In theses senses, it behaves like the Pauli X operator \
on a single qubit. Thus, we put ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["X", "_"], "=", " ", 
    RowBox[{"Z", "\[CircleTimes]", "I"}]}], TraditionalForm]],ExpressionUUID->
  "6e5fdaef-2883-4062-9df6-b2480a627b5f"],
 " and regard it as the logical Pauli X operator. Note that ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["Z", "_"], TraditionalForm]],ExpressionUUID->
  "3bcaa3bc-120e-4284-9cda-8cf2bd4b1028"],
 "and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["X", "_"], TraditionalForm]],ExpressionUUID->
  "cc908e6f-0463-448a-96c4-f7e9a9038b66"],
 "  commute with all elements of the stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "3e2a6e97-d5e1-4a8a-b750-11e68df5aac8"],
 " and hence preserve the stabilized subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "5cc79a36-86e2-469c-bc0c-0ddde7f14cb5"],
 ". Nevertheless, unlike the operators in the stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "a44a3569-9581-458a-a2aa-d4d11b76df2d"],
 ", they act non-trivially on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "b5c98c0d-9574-44be-b4b9-bee887b569b2"],
 " and move around the quantum states inside ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "5221d9ea-5fbb-444f-8e83-5deac21ce148"],
 "."
}], "TechNoteText",
 CellID->1815437427,ExpressionUUID->"e35c9f4c-8d77-41de-993a-21ac1871b574"],

Cell[TextData[{
 "More generally, the logical basis states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["x", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "0db18a0e-8fc7-4ec4-9cd7-2bbf6d49ecb0"],
 " associated with binary strings ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["x", "_"], ":=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox[
        OverscriptBox["x", "_"], "1"], ",", 
       SubscriptBox[
        OverscriptBox["x", "_"], "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox[
        OverscriptBox["x", "_"], 
        RowBox[{"n", "-", "k"}]]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"20cb7e0c-a9e0-4b33-861c-d39d53327b35"],
 " can be designated by two sets of logical Pauli operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["Z", "_"], "1"], ",", 
    SubscriptBox[
     OverscriptBox["Z", "_"], "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox[
     OverscriptBox["Z", "_"], 
     RowBox[{"n", "-", "k"}]]}], TraditionalForm]],ExpressionUUID->
  "136c04b1-5df7-4f15-8d18-bf852a38f884"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["X", "_"], "1"], ",", 
    SubscriptBox[
     OverscriptBox["X", "_"], "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox[
     OverscriptBox["X", "_"], 
     RowBox[{"n", "-", "k"}]]}], TraditionalForm]],ExpressionUUID->
  "5c5207f8-b955-45b3-b55b-2c5597523491"],
 ". While a measurement of the logical Pauli Z operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["Z", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "d81d6a2d-0fce-4dd1-b9dc-7230168dd4dd"],
 " distinguishes the logical basis states, that is,"
}], "TechNoteText",
 CellID->609179013,ExpressionUUID->"16235fde-6b67-410c-a347-77a3937cfd3f"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox[
      SubscriptBox["Z", "j"], "_"], 
     TemplateBox[{
       OverscriptBox["x", "_"]},
      "Ket"]}], ":=", 
    RowBox[{
     SubscriptBox["x", "j"], 
     TemplateBox[{
       OverscriptBox["x", "_"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "8713e7b3-c70a-42ca-8058-49d071452b43"],
 ","
}], "DisplayMath",
 CellID->1417126242,ExpressionUUID->"ed3d5e51-b035-49c2-83c5-af1fe11a07d8"],

Cell[TextData[{
 "the logical Pauli X operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["X", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "488a251f-1786-4174-92a3-5b8916304070"],
 " fix the relative phases of the logical basis states by imposing"
}], "TechNoteText",
 CellID->2047104064,ExpressionUUID->"a5bf1719-2f6d-4962-92c5-a2c0900da827"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      OverscriptBox["X", "_"], "j"], 
     TemplateBox[{
       RowBox[{
         SubscriptBox[
          OverscriptBox["x", "_"], "1"], ",", "\[Ellipsis]", ",", 
         SubscriptBox[
          OverscriptBox["x", "_"], "j"], ",", "\[Ellipsis]", ",", 
         SubscriptBox[
          OverscriptBox["x", "_"], 
          RowBox[{"n", "-", "k"}]]}]},
      "Ket"]}], ":=", 
    TemplateBox[{
      RowBox[{
        SubscriptBox[
         OverscriptBox["x", "_"], "1"], ",", "\[Ellipsis]", ",", 
        RowBox[{
          SubscriptBox[
           OverscriptBox["x", "_"], "j"], "\[CirclePlus]", "1"}], ",", 
        "\[Ellipsis]", ",", 
        SubscriptBox[
         OverscriptBox["x", "_"], 
         RowBox[{"n", "-", "k"}]]}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "7096f4ba-7f7c-4022-8285-c0bb6adbf4db"],
 "."
}], "DisplayMath",
 CellID->842495061,ExpressionUUID->"b7428fb4-4ce6-4057-bcff-204fdb1e96b0"],

Cell[TextData[{
 "Given a stabilizer, one can construct logical Pauli operators without \
referring to the logical basis states. One necessary condition is that the \
logical Pauli operators should preserve the given subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "0a761b6a-84cd-444c-8117-8cce7a54a8f1"],
 ", transforming states within \[ScriptCapitalV]. This implies that any \
logical Pauli operator, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["Z", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "f15ba36d-0a0c-4245-b7df-f104b1568e9d"],
 " or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["X", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "b086f8c8-067a-4f60-83d4-0ccff7b3e914"],
 ", must commute with all generators of stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "f13e7412-e89a-40a7-a50a-be5f632b0901"],
 ". Nevertheless, the logical Pauli operators must not belong to the \
stabilizer and should be independent of the generators of the stabilizer. \
Otherwise, their operations on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "f0f998bb-2834-4e09-b9f2-d1eec89ee413"],
 " are all trivial. Furthermore, the logical Pauli operators must fix the \
logical bit and phase values of the logical basis states as explained above. \
This implies that the pair of logical Pauli operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["Z", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "de7aeb4d-d2ae-4de4-9ff7-197119704d6b"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["X", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "d5e6a38f-51c8-4f43-a622-92b98b0a796f"],
 " for each ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "94a7c11d-f48e-4e24-81c3-3fc67761b482"],
 " must anti-commute with each other while ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["Z", "_"], "i"], TraditionalForm]],ExpressionUUID->
  "b6b42e1c-0c96-4d50-acfa-00262e5d410f"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["X", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "8f040ed2-037b-4d2e-aa72-31183ebe5f4d"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "\[NotEqual]", "j"}], TraditionalForm]],ExpressionUUID->
  "29c24672-9568-4db5-a7ee-262cc14ceb70"],
 " should commute."
}], "TechNoteText",
 CellID->1454805556,ExpressionUUID->"a852543d-de3c-434f-80e1-30cf1f0a8055"],

Cell["\<\
Note that for a given logical basis, the choice of the logical Pauli \
operators is not unique. For example, for the same logical basis states\
\>", "TechNoteText",
 CellID->1815658597,ExpressionUUID->"5674e124-f76e-4695-950b-805e08018c86"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      OverscriptBox["0", "_"]},
     "Ket"], "=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"00"},
       "Ket"], "+", 
      TemplateBox[{"11"},
       "Ket"]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "f19661ba-9a8a-4e07-933e-73ea3ff2068c"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      OverscriptBox["1", "_"]},
     "Ket"], "=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"00"},
       "Ket"], "-", 
      TemplateBox[{"11"},
       "Ket"]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "aaadb376-2c9d-4c0d-88e3-048c08528b0a"],
 ","
}], "DisplayMath",
 CellID->31415909,ExpressionUUID->"6614c877-f404-45ba-a7f9-cf2d87045b86"],

Cell[TextData[{
 "one can choose ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["Z", "_"], "=", 
    RowBox[{
     RowBox[{"-", "Y"}], "\[CircleTimes]", "Y"}]}], TraditionalForm]],
  ExpressionUUID->"31ec00c2-906c-4ece-8f6f-58e3fef2e005"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["X", "_"], "=", " ", 
    RowBox[{"I", "\[CircleTimes]", "Z"}]}], TraditionalForm]],ExpressionUUID->
  "5426ad99-c027-4491-a315-a79428998138"],
 " instead of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["Z", "_"], "=", 
    RowBox[{"X", "\[CircleTimes]", "X"}]}], TraditionalForm]],ExpressionUUID->
  "df457495-2d86-4ebf-b3d8-3be2c2661b13"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["X", "_"], "=", " ", 
    RowBox[{"Z", "\[CircleTimes]", "I"}]}], TraditionalForm]],ExpressionUUID->
  "85179840-aeda-4f43-8754-5bcbc6402aba"],
 ". Mathematically, equivalent logical Pauli operators belong to the same \
coset with respect to ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "33232754-a194-4d68-96e6-ea6e03505992"],
 "."
}], "TechNoteText",
 CellID->1873689048,ExpressionUUID->"8a6bc8c0-0823-4bc6-accb-1bef2565cb68"],

Cell[TextData[{
 "Given a set of independent generators of the stabilizer, there is a \
systematic method to construct logical Pauli operators utilizing Gottesman \
vectors. We refer interested readers to ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Cleve and Gottesman (1997)"]], 
    "https://doi.org/10.1103/physreva.56.76"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "4ff0a820-a49b-4937-a106-a495667204fa"],
 "."
}], "TechNoteText",
 CellID->391630128,ExpressionUUID->"87f31f01-9c2d-4678-b974-f0e428952f56"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Stabilizer Circuits", "TechNoteSection",
 CellTags->"Section22",
 CellID->90183241,ExpressionUUID->"6dd3a20d-95cb-44fb-b19b-b7d270b97d0a"],

Cell[TextData[{
 "A quantum circuit consisting of Pauli measurements and Clifford gates \
(possible conditioned on the outcome of Pauli measurements) only is called a ",
 StyleBox["stabilizer circuit",
  FontSlant->"Italic"],
 ". It is simple to analyse and useful since any stabilizer subgroup in the \
Pauli group remains in the Pauli group throughout the quantum circuit."
}], "TechNoteText",
 CellID->1733760352,ExpressionUUID->"bba86e98-a5f6-4f60-938c-beafec99553d"],

Cell[TextData[{
 "Although stabilizer circuit is not universal for quantum computation (the \
Gottesman-Knill theorem), it plays an central role in quantum \
error-correction codes. The use of random elements of the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " also has numerous applications in many other areas including finding \
bounds of quantum capacities, and randomized benchmarking, data hiding."
}], "TechNoteText",
 CellID->104629921,ExpressionUUID->"db0d753e-2d71-4322-9c54-d8b788458f7d"],

Cell[CellGroupData[{

Cell["Clifford Gates", "Subsection",
 CellTags->"Section23",
 CellID->1873459001,ExpressionUUID->"0d3b07ea-a84f-4f0f-9489-2ce4015f289d"],

Cell[TextData[{
 "As mentioned earlier, under any unitary gate ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "da74bf94-963d-4a6b-afd4-f95ab143455c"],
 ", a stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "f6b7825a-6536-4852-a780-acc3fc8bcfbc"],
 " transforms as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", " ", "\[ScriptCapitalS]", " ", 
    SuperscriptBox["U", "\[Dagger]"]}], TraditionalForm]],ExpressionUUID->
  "d0afbac4-345d-42ea-96d1-72bc324789b9"],
 ". When ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "41753f5b-1aec-4adc-a4fc-b4b4537154db"],
 " is a Clifford gate, the new stabilizer ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", " ", "\[ScriptCapitalS]", " ", 
    SuperscriptBox["U", "\[Dagger]"]}], TraditionalForm]],ExpressionUUID->
  "a2afaa0d-a519-465a-aa14-71c228a7b7fd"],
 " is still a subgroup of the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 ". "
}], "TechNoteText",
 CellID->820197493,ExpressionUUID->"8b91e7eb-85f6-4770-b1b9-5686700477af"],

Cell[TextData[{
 "This means that generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "1"], ",", 
    SubscriptBox["G", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["G", "k"]}], TraditionalForm]],ExpressionUUID->
  "f9471d45-4afa-4f6e-a06b-d33a4c2123aa"],
 " of the stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "2fa4be40-52f7-4aed-9d21-ea9452d23b73"],
 " transform under conjugation by ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "0ee9fc27-8db4-4333-886f-611fd4e558ac"],
 " to the generators of the new stabilizer ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", " ", "\[ScriptCapitalS]", " ", 
    SuperscriptBox["U", "\[Dagger]"]}], TraditionalForm]],ExpressionUUID->
  "16498a66-df2e-42bb-84ec-138bf53aa565"],
 " as"
}], "TechNoteText",
 CellID->361734758,ExpressionUUID->"d2f6750b-36de-4069-b8ee-3d571c3f4bde"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "j"], "\[RightTeeArrow]", 
    RowBox[{"U", " ", 
     SubscriptBox["G", "j"], 
     SuperscriptBox["U", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "9da06416-1402-47a4-8460-19b5e292d6a8"],
 "."
}], "DisplayMath",
 CellID->149873049,ExpressionUUID->"d546fa75-6e62-4ea1-a7e1-c82d85ae99ff"],

Cell["\<\
Similarly, the logical Pauli operators on the stabilized subspace \
\[ScriptCapitalV] transform as\
\>", "TechNoteText",
 CellID->2065500259,ExpressionUUID->"3452c9b7-d47a-4163-8788-dec468a58ff3"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["X", "_"], "j"], "\[RightTeeArrow]", 
    RowBox[{"U", " ", 
     SubscriptBox[
      OverscriptBox["X", "_"], "j"], 
     SuperscriptBox["U", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "8dd157c0-aa35-466a-8f37-439761317a69"],
 ","
}], "DisplayMath",
 CellID->789699258,ExpressionUUID->"8291ff3d-2a0e-467f-a38a-91506d925fcf"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["Z", "_"], "j"], "\[RightTeeArrow]", 
    RowBox[{"U", " ", 
     SubscriptBox[
      OverscriptBox["Z", "_"], "j"], 
     SuperscriptBox["U", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "97a8816d-114c-40c1-b823-eaeb3458a121"],
 "."
}], "DisplayMath",
 CellID->1026490746,ExpressionUUID->"6d84dbec-b464-47c0-843d-ebe375318329"],

Cell[TextData[{
 "Recall that all these transformations under conjugation by Clifford gates \
are completely characterized by the way Pauli operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["X", "j"], TraditionalForm]],ExpressionUUID->
  "ae1e0311-4f34-4910-a504-927ee485c9da"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Z", "j"], TraditionalForm]],ExpressionUUID->
  "74885037-9e92-4e62-8803-1bdd9b3d697b"],
 " on ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "th"], TraditionalForm]],ExpressionUUID->
  "1d46a90d-356c-41ee-872f-aad63ab9fb49"],
 " qubit transform,"
}], "TechNoteText",
 CellID->1493831671,ExpressionUUID->"8662d8e2-bba4-4a9c-816e-1a9d4a40d0f3"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"U", " ", 
    SubscriptBox["X", "j"], 
    SuperscriptBox["U", "\[Dagger]"]}], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], 
     SubscriptBox["p", "j"]], 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["a", 
        RowBox[{"i", " ", "j"}]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["b", 
        RowBox[{"i", " ", "j"}]]]}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"8fe759f1-357e-4398-981b-9f5a1902e913"]], \
"DisplayMath",
 CellID->597577420,ExpressionUUID->"301f1316-74d1-4711-841c-209f883507a8"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"U", " ", 
    SubscriptBox["Z", "j"], 
    SuperscriptBox["U", "\[Dagger]"]}], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], 
     SubscriptBox["q", "j"]], 
    RowBox[{
     SubsuperscriptBox["\[Product]", 
      RowBox[{" ", 
       RowBox[{"i", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{
      SubsuperscriptBox["X", "i", 
       SubscriptBox["c", 
        RowBox[{"i", " ", "j"}]]], 
      SubsuperscriptBox["Z", "i", 
       SubscriptBox["d", 
        RowBox[{"i", " ", "j"}]]]}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"1603bd6d-44ae-4b7d-98dc-67a19d0f370c"]], \
"DisplayMath",
 CellID->1850164568,ExpressionUUID->"1f69df3e-1872-4fdf-9da4-f567d9e94e4d"],

Cell[TextData[{
 "with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "j"], ",", " ", 
    SubscriptBox["q", "j"], ",", " ", 
    SubscriptBox["a", 
     RowBox[{"i", " ", "j"}]], ",", " ", 
    SubscriptBox["b", 
     RowBox[{"i", " ", "j"}]], ",", " ", 
    SubscriptBox["c", 
     RowBox[{"i", " ", "j"}]], ",", " ", 
    RowBox[{
     SubscriptBox["d", 
      RowBox[{"i", " ", "j"}]], "\[Element]", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "dab452d7-c96f-46ce-b098-b90c63d8591f"],
 "."
}], "TechNoteText",
 CellID->152685816,ExpressionUUID->"81a910b9-fe0d-49dd-a394-fd0fb6291b20"],

Cell[TextData[{
 "\tAmong the binary coefficients, coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "j"], TraditionalForm]],ExpressionUUID->
  "eab89b18-faf1-4889-a850-68a5f846822a"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["q", "j"], TraditionalForm]],ExpressionUUID->
  "06efd975-9689-43e0-be71-40e782ef8d46"],
 " come from the factor of Pauli operators and  the rest coefficients ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", 
     RowBox[{"i", " ", "j"}]], ",", " ", 
    SubscriptBox["b", 
     RowBox[{"i", " ", "j"}]], ",", " ", 
    SubscriptBox["c", 
     RowBox[{"i", " ", "j"}]], ",", " ", 
    SubscriptBox["d", 
     RowBox[{"i", " ", "j"}]]}], TraditionalForm]],ExpressionUUID->
  "20543577-861a-4bf5-8221-635fd80fafe1"],
 " are attributed to the quotient group ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalC]", "(", "n", ")"}], "/", 
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}], TraditionalForm]],
  ExpressionUUID->"8c132b03-b99a-444e-a99c-4e47deb93600"],
 ". The latter coefficients are conveniently described in terms of ",
 ButtonBox["Gottesman matrices",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GottesmanMatrix"],
 "."
}], "TechNoteText",
 CellID->2095034994,ExpressionUUID->"00774c60-6e13-4777-8cdb-f5c6c5db6267"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pauli Measurements", "Subsection",
 CellTags->"Section24",
 CellID->1111267946,ExpressionUUID->"fafe24f6-18c2-4a79-9144-817e20e08cdb"],

Cell[TextData[{
 "Upon the measurement of an observable ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "40f51acd-8555-4579-88e4-7af32a3613e1"],
 ", a quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "355fced9-c98b-41e0-b5e7-e6ff67382ddd"],
 " \[OpenCurlyDoubleQuote]collapses\[CloseCurlyDoubleQuote] to one of the \
eigenstates of ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "ddc3ce5b-b320-4554-8423-950c63483d9f"],
 ". When ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "9866239e-6158-42a8-80c7-b870ca6d5183"],
 " is a tensor product of the Pauli operators, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "\[Element]", 
    RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}]}], TraditionalForm]],
  ExpressionUUID->"f7cc631d-fa57-49d7-a729-174c3129e1b5"],
 ", it has two eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "ed4cae29-6771-4c7e-bbac-12b7e675b790"],
 ". The measurement process is described by the projectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "\[PlusMinus]"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "\[PlusMinus]", "M"}], ")"}], "/", "2"}]}], 
   TraditionalForm]],ExpressionUUID->"c62113e5-2ee2-4ec2-a476-458e4ffb736b"],
 " onto the eigenspaces belonging to eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "a5395848-8b2c-4eda-b73c-ad18d978767f"],
 ". The description so far has been in the Schr\[ODoubleDot]dinger picture. \
Here we examine how the stabilizer and the logical Pauli operators change \
under the measurement."
}], "TechNoteText",
 CellID->415090463,ExpressionUUID->"bb1e2fd6-f879-490f-b1e1-90ed788338b3"],

Cell[TextData[{
 "Suppose that ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "e0bc9216-95f4-4ab2-b793-9db4a19f1112"],
 " is the stabilizer of a subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "7c4063f7-b831-4245-a9f1-0c26cceb232e"],
 " of interest. Recall that since the observable ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "0d77719b-ae53-4d54-aaaa-e8f84d9e9967"],
 " is a member of the ",
 ButtonBox["Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PauliGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalP]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"2108746e-61bd-4258-931a-7fdcbaaa1449"],
 ", it either commutes or anti-commutes with any specific operator in \
stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "3c96a813-3cb5-44fb-8782-2cdfd0fd13c2"],
 ". This leaves two possibilities, ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "8f814061-d2a9-404c-b231-5e315f0cbd0e"],
 " either anti-commutes with some elements of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "7fb7fc24-34a8-4033-bb9b-edf5a024aaf4"],
 " or commutes with every element of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "2ca06444-c787-4756-b0b8-f25a9151b41e"],
 ". Let us first examine the former case. We designate by ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "6c7196e2-c328-4c12-ac90-0a52cb614026"],
 " one of the elements that anti-commute with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "970ebef3-3ac7-436c-a67a-8fa2282444f3"],
 ". For any quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "47dfdb5c-2023-4b10-a3a0-9765b487b7cd"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "82fe342d-203d-4990-bd6a-8193fa33c671"],
 ", the measurement gives outcomes ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "bd87cc5c-d072-4ffd-b8a9-4e5fbcc63b58"],
 " with equal probability 1/2, and the post-measurement state becomes ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "\[PlusMinus]"], 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "9d0c0d64-bf25-41ff-a493-6f65abb03f14"],
 " depending on the respective outcome \[PlusMinus]1. That is, the \
post-measurement state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "\[PlusMinus]"], 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "7480f92e-522a-4626-8f45-6b0ba46750e1"],
 " is an eigenstate of ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "c043e2d6-1c55-4d53-8c4e-9cdad7d530a1"],
 " belonging to the eigenvalue ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "44720b66-263e-4466-bf44-f2700967e722"],
 ", respectively. This means that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "M"}], TraditionalForm]],ExpressionUUID->
  "a148b5ab-4792-4c0b-b200-729cf6dee00a"],
 " is an element of the stabilizer ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Prime]"], TraditionalForm]],
  ExpressionUUID->"43ec1001-f72f-45d4-bb21-27b4707cb98c"],
 " of the new subspace ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "\[PlusMinus]"], "\[ScriptCapitalV]"}], 
   TraditionalForm]],ExpressionUUID->"2fe12a22-89f1-4a69-9455-4321a705db66"],
 ", respectively. On the other hand, operator ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "af1db3d0-af19-4c69-a28c-d64f80b1d238"],
 " cannot belong to ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Prime]"], TraditionalForm]],
  ExpressionUUID->"9bf3efdd-8fe4-417d-b887-523f0edc13ce"],
 " any longer. Any other element of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "83aca123-0964-43cd-b720-9689db08ef67"],
 " is still a member of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Prime]"], TraditionalForm]],
  ExpressionUUID->"c00228fa-b32a-461f-9212-6f8ce2833954"],
 " as long as it commutes with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "11a08a50-8a72-4836-b2b3-9733e0fc8cf9"],
 ". If some element ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["G", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "ce17bbeb-149f-40c2-a5d9-422196218cea"],
 " in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "922a6684-265a-4d4c-b701-3b7c3b2d5cb9"],
 " does not commute with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "M"}], TraditionalForm]],ExpressionUUID->
  "b637fb6e-9990-48ac-a2ae-34d78cecf361"],
 ", then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", " ", 
    SuperscriptBox["G", "\[Prime]"]}], TraditionalForm]],ExpressionUUID->
  "05d3058c-3ff9-4923-965b-204eaf6aad51"],
 " does and hence is a member of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Prime]"], TraditionalForm]],
  ExpressionUUID->"98a1ff28-48ec-4353-a5dd-0ede7340aa01"],
 ". It is physically important to note that by construction, the observable \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "M"}], TraditionalForm]],ExpressionUUID->
  "82b9a5a2-7f12-430f-b83f-cd3a2043cd8d"],
 " commutes with all elements of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Prime]"], TraditionalForm]],
  ExpressionUUID->"5da19dc9-2e08-4547-83e8-bdcd31f94194"],
 "."
}], "TechNoteText",
 CellID->1398526185,ExpressionUUID->"ac21d508-9abd-48e6-ae24-4a856208cf8b"],

Cell["In passing, it is also interesting to note that", "TechNoteText",
 CellID->821074880,ExpressionUUID->"f7e529c9-e89e-4eab-84aa-db8e591b4e8c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"G", " ", 
     SubscriptBox["P", "-"], 
     TemplateBox[{"\[Psi]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"G", "(", 
       RowBox[{"1", "-", "M"}], ")"}], 
      TemplateBox[{"\[Psi]"},
       "Ket"]}], "=", 
     RowBox[{
      RowBox[{
       FractionBox["1", "2"], 
       RowBox[{"(", 
        RowBox[{"1", "+", "M"}], ")"}], "G", 
       TemplateBox[{"\[Psi]"},
        "Ket"]}], "=", 
      RowBox[{
       SubscriptBox["P", "+"], 
       TemplateBox[{"\[Psi]"},
        "Ket"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "45cf19ac-a229-4574-a4db-a9e4fc95f7c3"],
 "."
}], "DisplayMath",
 CellID->75592538,ExpressionUUID->"534e8adc-5eae-4268-83ef-28c8fec85273"],

Cell[TextData[{
 "This suggests that after the measurement of ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "17d54a68-308d-4ab4-945c-87858deea38f"],
 ", one can make it sure that the post-measurement state is always ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "+"], 
    TemplateBox[{"\[Psi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "e8e0d0ab-edd1-4755-8fb8-e66533fd4321"],
 ", if necessary, by applying ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "99446a7d-ca58-4ebd-99a4-2f6149d926a6"],
 ". With this correction in mind, the relevant subspace after the measurement \
is now ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "+"], "\[ScriptCapitalV]"}], TraditionalForm]],
  ExpressionUUID->"77398b5f-f979-49e4-8678-01ac692c7c34"],
 ". In this method, the update of the stabilizer generators does not depend \
on the measurement outcome; instead, the post-measurement state is \
\[OpenCurlyDoubleQuote]corrected\[CloseCurlyDoubleQuote] if the measurement \
outcome is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Minus]", "1"}], TraditionalForm]],ExpressionUUID->
  "a8b01172-0fd8-498a-87da-5d43f8fc031b"],
 ". "
}], "TechNoteText",
 CellID->1320240916,ExpressionUUID->"4b599eec-645d-4114-bcc2-74835a3e0242"],

Cell[TextData[{
 "Now, let us turn to the case where ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "ed02bf15-ff47-4ba7-b549-680d68cad2da"],
 " commutes with every member of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "cf717bb5-1774-4759-8d20-a960a11e1536"],
 ". We have to further distinguish two sub-cases. First, either ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "6e00a6c2-67c3-4217-999a-1413a9a873e4"],
 " itself or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "M"}], TraditionalForm]],ExpressionUUID->
  "3fd174d3-4346-4345-a32a-b3427695bc14"],
 " belongs to ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "696a16be-345a-4244-b1ff-a92c5a9bad3e"],
 ". In this case, the measurement of ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "b873872d-a06d-4d3c-839e-1ead1e72b09e"],
 " gives outcome ",
 Cell[BoxData[
  FormBox[
   RowBox[{"+", "1"}], TraditionalForm]],ExpressionUUID->
  "f6b38e9e-dee4-401b-b158-32343208bd53"],
 " or -1, respectively, with unit probability, and nothing happens to the \
quantum states nor the stabilizer."
}], "TechNoteText",
 CellID->533968037,ExpressionUUID->"5355b334-8243-4d8c-b823-802272e39a82"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1959900397,ExpressionUUID->"42ccad9b-b236-4cc6-a1ed-6b3ef7425707"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[656]:=",
 CellID->166857483,ExpressionUUID->"9f6fa9ed-f6a4-44b9-91b3-95fe5bac12a2"],

Cell["Consider a stabilizer group generated by these.", "TechNoteMathCaption",
 CellID->453594172,ExpressionUUID->"2cba45a5-76fb-4916-9a49-14394b01da11"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"gnr", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"1", ",", "3"}], "]"}], ",", 
     RowBox[{"-", 
      RowBox[{"S", "[", 
       RowBox[{"2", ",", "3"}], "]"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"gnr", "//", "PauliForm"}]}], "Input",
 CellLabel->"In[657]:=",
 CellID->1837374884,ExpressionUUID->"4836b420-fc93-4e01-aba0-67075c56c6cb"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"Z\""},
      "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
    $CellContext`S[1, 3]], ",", 
   RowBox[{"-", 
    RowBox[{"(", 
     InterpretationBox[
      RowBox[{"\<\"I\"\>", "\[CircleTimes]", 
       TemplateBox[{"\"Z\""},
        "RowDefault"]}],
      $CellContext`S[2, 3]], ")"}]}]}], "}"}]], "Output",
 CellLabel->"Out[658]=",
 CellID->2006639645,ExpressionUUID->"c9548ef4-1c81-4f10-94e0-e93cea7e9f46"]
}, Open  ]],

Cell["\<\
It stabilizes the one-dimensional subspace spanned by this state.\
\>", "TechNoteMathCaption",
 CellID->1600330005,ExpressionUUID->"5be14186-e111-426a-88d6-6fa017c2230d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"bs", "=", 
  RowBox[{"Ket", "[", 
   RowBox[{
    RowBox[{"S", "@", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}]}], "->", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[659]:=",
 CellID->965937872,ExpressionUUID->"562cb4b8-fd7a-4ed9-9715-e661643afb89"],

Cell[BoxData[
 InterpretationBox[
  TemplateBox[{
    TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
      SubscriptBox["0", 
       TemplateBox[{",", "\",\"", 
         InterpretationBox[
          SubscriptBox["S", 
           TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
          $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
      SubscriptBox["1", 
       TemplateBox[{",", "\",\"", 
         InterpretationBox[
          SubscriptBox["S", 
           TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
          $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
     "RowWithSeparators"]},
   "Ket"],
  Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
    0, $CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]], "Output",
 CellLabel->"Out[659]=",
 CellID->1509321027,ExpressionUUID->"9b442e5f-5124-42a6-ae31-a1c8706e8882"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"gnr", "**", "bs"}]], "Input",
 CellLabel->"In[660]:=",
 CellID->398427070,ExpressionUUID->"81947b2e-703c-4087-b674-62409f019a02"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      0, $CellContext`S[2, QuantumMob`Q3`$] -> 1|>]], ",", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      0, $CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]}], "}"}]], "Output",
 CellLabel->"Out[660]=",
 CellID->1081662425,ExpressionUUID->"271c1253-6312-4c41-9fa7-83ddd665291d"]
}, Open  ]],

Cell["Now, suppose that we measure this observable.", "TechNoteMathCaption",
 CellID->199409447,ExpressionUUID->"9a1236eb-0925-4b30-9bfe-ed5340ac0482"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"M", "=", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "3"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "3"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"M", "//", "PauliForm"}]}], "Input",
 CellLabel->"In[661]:=",
 CellID->1096474983,ExpressionUUID->"1f21fb93-be98-4ae6-9f38-bea6e65e91b8"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   TemplateBox[{"\"Z\""},
    "RowDefault"], "\[CircleTimes]", 
   TemplateBox[{"\"Z\""},
    "RowDefault"]}],
  QuantumMob`Q3`Multiply[
   $CellContext`S[1, 3], 
   $CellContext`S[2, 3]]]], "Output",
 CellLabel->"Out[662]=",
 CellID->1051305120,ExpressionUUID->"48d4c783-8884-4c31-b2ce-d48a145b4033"]
}, Open  ]],

Cell["Then, the measurement outcome is always -1.", "TechNoteMathCaption",
 CellID->1905547193,ExpressionUUID->"2385ea45-a3e2-4e44-a581-51d77da5065e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"M", "**", "bs"}]], "Input",
 CellLabel->"In[663]:=",
 CellID->1539893539,ExpressionUUID->"7bb3aed6-3d90-459f-9597-c28711974dc6"],

Cell[BoxData[
 RowBox[{"-", 
  InterpretationBox[
   TemplateBox[{
     TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
       SubscriptBox["0", 
        TemplateBox[{",", "\",\"", 
          InterpretationBox[
           SubscriptBox["S", 
            TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
           $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
       SubscriptBox["1", 
        TemplateBox[{",", "\",\"", 
          InterpretationBox[
           SubscriptBox["S", 
            TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
           $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
      "RowWithSeparators"]},
    "Ket"],
   Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
     0, $CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]}]], "Output",
 CellLabel->"Out[663]=",
 CellID->1937187971,ExpressionUUID->"590de249-63be-49db-8808-6afa4e41eea7"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"MeasurementOdds", "[", "M", "]"}], "[", "bs", "]"}]], "Input",
 CellLabel->"In[664]:=",
 CellID->1109008833,ExpressionUUID->"08a55274-2f8d-4557-8159-047d6f62c8c4"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"0", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "0"}], "}"}]}], ",", 
   RowBox[{"1", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
           SubscriptBox["0", 
            TemplateBox[{",", "\",\"", 
              InterpretationBox[
               SubscriptBox["S", 
                TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
               $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
           SubscriptBox["1", 
            TemplateBox[{",", "\",\"", 
              InterpretationBox[
               SubscriptBox["S", 
                TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
               $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
          "RowWithSeparators"]},
        "Ket"],
       Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
         0, $CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]}], "}"}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[664]=",
 CellID->318656430,ExpressionUUID->"46bd6748-b646-4b14-82e9-8c984dc53e6e"]
}, Open  ]],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1941794693,ExpressionUUID->"faa760f8-d01b-4cdd-bf4a-6ef5eab262b3"],

Cell[TextData[{
 "The remaining case is when ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "2fcfd8d6-a6b4-40f2-bd97-b79107f2fcec"],
 " commutes with all elements of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "5d623017-f4cb-439c-aa2d-a5d80a6e5e91"],
 " and yet does not belong to ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "7409434f-d4f5-42f5-86fb-b0188cddd69e"],
 ". In this case, measuring ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "165add41-b1fc-41b4-9299-3a7fdd956c86"],
 " reveals some information of the quantum state, and the subspace ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "4236eb56-58e3-407b-ac8b-36424f97d0fd"],
 " cannot maintain its structure, so the stabilizer formalism breaks down in \
some sense. For example, suppose that we measure one of the logical Pauli \
operators, say, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    OverscriptBox["Z", "_"]}], TraditionalForm]],ExpressionUUID->
  "6912af2d-1729-40bf-a33a-5a9591d097d0"],
 ".  For a state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        OverscriptBox["0", "_"]},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{
        OverscriptBox["1", "_"]},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "324334bb-a3f1-4200-854a-51b064c9b581"],
 ", measuring ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["Z", "_"], TraditionalForm]],ExpressionUUID->
  "9a531869-7fb2-47ae-a189-3d50be3b1d18"],
 " causes ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6c4755f4-d9ac-446d-82fa-d1ab551616c0"],
 " to collapse to either ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["0", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e4ecfa14-5a0c-437b-9163-32b7c6eb4272"],
 " or ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["1", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "11c9bf17-7ce4-493e-acd6-c55b6eaacd18"],
 ", breaking the encoding. Such a measurement must be performed only at the \
end of whole computation. Such an observable ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "84aade15-7e6b-4a37-b558-275b8da1e2c6"],
 " may occur as a Kraus element of the error process, rather than a pure \
measurement. Then it corresponds to an unrecoverable error."
}], "TechNoteText",
 CellID->1968986372,ExpressionUUID->"e674b914-397e-43ab-81d2-ac1aadeb2ab5"],

Cell[TextData[{
 "The new logical Pauli operators can be obtained in a similar way as for the \
new stabilizer generators. If they commute with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "9c38128f-ea2c-4d24-8536-f90080d3af16"],
 ", they remain unaffected. If there is any logical Pauli operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["L", "_"], TraditionalForm]],ExpressionUUID->
  "733b2eeb-f20a-457a-a2d6-2a28a4253e35"],
 " that does not commute with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "4c946a94-73d5-49b5-977d-e8fd13188f42"],
 ", then it can be replaced with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", 
    OverscriptBox["L", "_"]}], TraditionalForm]],ExpressionUUID->
  "75009c22-ebc4-4837-9441-b6a0fefcdc47"],
 " since the latter certainly commutes with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "0f2ca1af-d43c-4c5c-8442-b8b73c0abdc6"],
 ". The new logical Pauli operators constructed this way satisfy the same \
commutation relations as the original logical Pauli operators do, and they \
commute with all elements in the new stabilizer ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Prime]"], TraditionalForm]],
  ExpressionUUID->"2fb2c75c-1cfa-45b6-969c-2956726669b1"],
 "."
}], "TechNoteText",
 CellID->1372745471,ExpressionUUID->"3440972c-731c-49f6-bdc7-7195885399f0"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->12569113,ExpressionUUID->"8df8e336-8c9a-4106-b049-f32cc12c2cf1"],

Cell[TextData[{
 "In summary, one can track the evolution of the stabilizer and the logical \
Pauli operators of a given subspace under a measurement of an observable ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "a8908819-a35e-4aa5-a868-f791d50851e6"],
 " according to the following rules:"
}], "TechNoteText",
 CellID->1316311376,ExpressionUUID->"be52ced2-ccf2-42a0-a86e-8b026c75b18e"],

Cell[TextData[{
 "Identify a generator ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "fce7c975-d9e6-4678-9d5a-1a72d2040601"],
 " of the stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "a0ec3f71-29a0-41ff-8a4c-46079bd2976a"],
 " that anti-commutes with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "5cd64315-b8ef-438a-a778-1d5981f25561"],
 ". "
}], "Item",
 CellID->2016248685,ExpressionUUID->"ac49249c-3305-4c4f-b249-9c1b432c0ad2"],

Cell[TextData[{
 "Pick up a set of generators of the new stabilizer as follows. First, \
replace ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "15eb5b0a-8174-46e5-9878-babec3381ed4"],
 " with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "1ed0f4de-eab2-40a1-b754-2bd1d192dd49"],
 " in the list of generators of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "527898ea-288a-455e-8a40-318c6a99f34d"],
 ". Second, for each ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["G", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "8a2612c2-df7e-45f3-8c1c-131ae2b5f182"],
 " of other generators of S, keep it if it commutes with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "e29ff8ff-d39b-46ca-8ca8-3b2098d49119"],
 " and replace it with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", " ", 
    SuperscriptBox["G", "\[Prime]"]}], TraditionalForm]],ExpressionUUID->
  "81ca58f9-89b2-4298-88ef-1d6d1cc261fa"],
 "\[Prime] if it anti-commutes with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "c74fed6e-d40e-4b76-85b2-f4a537ec106d"],
 "."
}], "Item",
 CellID->1947182782,ExpressionUUID->"5ff676c5-e9b4-46af-b6a1-8d25e3b462d1"],

Cell[CellGroupData[{

Cell[TextData[{
 "Choose a new set of logical Pauli operators as follows. For each logical \
Pauli operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["L", "_"], TraditionalForm]],ExpressionUUID->
  "f85ce317-7c79-4839-b466-c789ce9e1099"],
 " (",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["Z", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "b015eec1-b8e9-4ff8-ac27-f812cbabf50d"],
 " or ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["X", "_"], "j"], TraditionalForm]],ExpressionUUID->
  "e6182b46-365e-4a78-8410-fb1e0ff043c7"],
 "), keep it if it commutes with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "80bb3aa6-3dfc-4f55-9065-dd9f8c63d36a"],
 ", but replace it with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", 
    OverscriptBox["L", "_"]}], TraditionalForm]],ExpressionUUID->
  "36e6617f-aafc-4ecb-9dc6-48c4163b7374"],
 " if it anti-commutes with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "3fd347da-e35c-4bbb-9800-9628d1fec7a0"],
 "."
}], "Item",
 CellID->797720441,ExpressionUUID->"2ce729dd-5355-4e22-84e7-ec435dbfaf6b"],

Cell[TextData[{
 "Recall that these rules assume that after measurement of the observable ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "20a9b22d-af17-42c0-ba81-8a4bc1c5dd24"],
 ", generator ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "d2cee209-a493-4cc4-af5a-6320f5661960"],
 " is operated on the system to \[OpenCurlyDoubleQuote]correct\
\[CloseCurlyDoubleQuote] the the post-measurement state when the outcome is \
\[Minus]1. Since the operation of ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "c580a103-0982-4e4c-b509-b9aa059a2b0b"],
 " is conditioned on classical data (the measurement outcome), it is \
analogous to classical feedback control. Of course, it is possible to avoid \
this semiclassical feedback control by replacing ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "a6a1d035-2cb1-4ff8-bb2d-4e6a74c0e0e3"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "M"}], TraditionalForm]],ExpressionUUID->
  "c36ed148-08d4-426b-9b9d-f8570682d625"],
 " depending on the measurement outcome when updating the stabilizer \
generators in Step 2 above."
}], "TechNoteText",
 CellID->1228203571,ExpressionUUID->"499a612d-f521-4674-9c04-e6ac7d74ca4c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The Gottesman-Knill Theorem", "Subsection",
 CellID->970307550,ExpressionUUID->"8af176af-b331-46ba-b13e-bab843495997"],

Cell[TextData[{
 "The peculiarity of the stabilizer circuits is most pronounced in the \
Gottesman-Knill theorem (Gottesman, 1999). It states that any ",
 StyleBox["stabilizer circuits",
  FontSlant->"Italic"],
 ", quantum circuits consisting of Clifford operators and Pauli measurements, \
can be efficiently simulated on a classical computer."
}], "TechNoteText",
 CellID->2115661179,ExpressionUUID->"f911ab47-a38a-4c71-8df9-0ce03fa93e05"],

Cell[TextData[{
 "Note that the Clifford operators are sufficient to generate a rich range of \
quantum effects including the Greenberger-Horne-Zeilinger (GHZ) experiment \
(Greenberger et al., 1989), quantum teleportation, and super dense coding. \
They are also sufficient to encode and decode quantum error-correction codes \
(Section 6.4 in the Quantum Workbook). Nevertheless, the theorem indicates \
that the Clifford group \"falls short of the full power of quantum \
computation.\" Indeed, we recall that in addition to Clifford gates, we need ",
 ButtonBox["octant phase gates",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Octant"],
 " or ",
 ButtonBox["Toffoli gates",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Toffoli"],
 " to implement an arbitrary unitary gate to an arbitrary accuracy (Section \
2.4 of the ",
 ButtonBox["Quantum Workbook",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-3-030-91214-7"], None}],
 ")."
}], "TechNoteText",
 CellID->2030692074,ExpressionUUID->"29ada4f3-66e2-4b59-8cca-9130dfb1dd0a"],

Cell[TextData[{
 "The key point is that ",
 ButtonBox["stabilizer formalism",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/StabilizerFormalism"],
 " tracks the generators of the stabilizer rather than the quantum states as \
in the usual methods. To follow the evolution of the quantum states, one \
needs to keep track of an exponential number of complex amplitudes. However, \
for a system of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "2a46c617-ed2b-4817-a970-40470714d7e5"],
 " qubits, there are an order of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ba4097b7-95e8-4155-a98e-5fdeb15e86ac"],
 " generators of the stabilizer because any finite group ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "5d20740a-5132-41da-80d8-d6a60de44c35"],
 " has a generating set of at most ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["log", "2"], "|", "\[ScriptCapitalG]", "|"}], 
   TraditionalForm]],ExpressionUUID->"3db62a0a-6e1b-4f44-bfd4-e7d302b3deed"],
 " elements. Each generator takes ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n"}], TraditionalForm]],ExpressionUUID->
  "11e93cda-2b4e-408c-a71b-326d9ddca3df"],
 " bits for the Pauli ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "ba392a54-c251-4512-8868-1efc362ae85d"],
 " or ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "058e186b-a150-4fd4-ac30-d312bc10184f"],
 " operators on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "992d2cfd-6410-4015-89bd-f217aaa5bf57"],
 " qubits and an additional bit for the phase factor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "c8da010d-8834-4930-b920-d29339a9e29b"],
 ". Overall, one needs an order of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["n", "2"], TraditionalForm]],ExpressionUUID->
  "d3b9f881-8b50-41d3-b59e-cd892eddf53e"],
 " bits to track the evolution of the stabilizer. We have seen that the ",
 ButtonBox["Clifford group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/CliffordGroup"],
 " is generated by the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ed02af89-1c23-4fb8-a428-8c3f2cc29142"],
 ", ",
 ButtonBox["quadrant",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/quadrant"],
 " phase, and ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["CNOT"]], "paclet:QuantumMob/Q3/ref/CNOT", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "106a4fb1-8b04-4ab2-a162-bf817ced04e0"],
 " gates and that the generators under conjugation by these elementary gates \
can be updated in polynomial time, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"O", 
    RowBox[{"(", "n", ")"}]}], TraditionalForm]],ExpressionUUID->
  "6f4386ad-e41d-43bc-911b-9263796ba3fb"],
 " time, for the gate."
}], "TechNoteText",
 CellID->2031569594,ExpressionUUID->"59ad5ef9-22a6-4ef1-ba39-5eda5b52179e"],

Cell[TextData[{
 "A specific algorithm to simulate stabilizer circuits was proposed in ",
 ButtonBox["Aaronson and Gottesman (2004)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/physreva.70.052328"], None}],
 ". Recently, a simulation algorithm was also proposed to conduct a fast \
simulation of the stabilizer circuits using graph states (",
 ButtonBox["Browne and Briegel, 2016",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1002/9783527805785.ch21"], None}],
 ")."
}], "TechNoteText",
 CellID->1747662705,ExpressionUUID->"54db986d-4514-4e05-8ecf-4c6f864c4930"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples", "TechNoteSection",
 CellTags->"Section25",
 CellID->785401655,ExpressionUUID->"05f644ec-e31e-4fe4-81b9-8e0bf2e4cfc4"],

Cell[TextData[{
 "The above analyses of unitary gates and measurements in stabilizer \
formalism are useful to analyze what happens upon combining specific \
measurements and operations. In particular, if a part of the quantum register \
starts in a known quantum state, for example, initialized in ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{"0"},
     "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
    TemplateBox[{"0"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "47d3d90f-debc-449d-ab48-59a70cc7aee6"],
 ", it can often be described by a stabilizer. Let us take two heuristic \
examples, which were worked out in detail in ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Gottesman (1999)"]], "http://arxiv.org/abs/quant-ph/9807006"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "aafc8977-eb65-451b-8358-13c531299ccc"],
 "."
}], "TechNoteText",
 CellID->1811121123,ExpressionUUID->"9ff12d8f-1bc0-4d61-8464-1b0f44f8d728"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[665]:=",
 CellID->1179083707,ExpressionUUID->"d42ebea3-01b9-43be-baa4-7be93e936dc9"],

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Complex", ",", "c"}], "]"}]}], "Input",
 CellLabel->"In[666]:=",
 CellID->1401182155,ExpressionUUID->"e3313e99-5de6-4d15-a884-108458c9fd92"],

Cell[CellGroupData[{

Cell["Quantum Teleportation in Stabilizer Formalism", "Subsection",
 CellTags->"Section27",
 CellID->1079501683,ExpressionUUID->"3959c473-ec21-4371-8a65-0bb90219230d"],

Cell[TextData[{
 "The first example is the ",
 ButtonBox["quantum teleportation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumTeleportation"],
 " and is summarized in the following quantum circuit"
}], "TechNoteText",
 CellID->1242936325,ExpressionUUID->"46b3331b-20e1-4a85-8987-f4dd6b61ea44"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{"ProductState", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", "3", "]"}], "->", 
      RowBox[{"c", "@", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}]}]}], ",", 
     RowBox[{"\"\<Label\>\"", "->", 
      RowBox[{"Ket", "[", "\[Psi]", "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"ProductState", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], "->", 
      RowBox[{"c", "@", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}]}]}], ",", 
     RowBox[{"\"\<Label\>\"", "->", 
      RowBox[{"Ket", "[", "\[Psi]", "]"}]}]}], "]"}]}], ";", 
  RowBox[{"qc", "=", 
   RowBox[{"QuantumCircuit", "[", 
    RowBox[{"in", ",", 
     RowBox[{"Ket", "[", 
      RowBox[{"S", "@", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}]}], "]"}], ",", 
     RowBox[{"S", "[", 
      RowBox[{"1", ",", "6"}], "]"}], ",", 
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "1", "]"}], ",", 
       RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", "\"\<Separator\>\"", 
     ",", "\"\<Spacer\>\"", ",", 
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "2", "]"}], ",", 
       RowBox[{"S", "[", "3", "]"}]}], "]"}], ",", 
     RowBox[{"S", "[", 
      RowBox[{"2", ",", "6"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Measurement", "[", 
        RowBox[{"S", "[", 
         RowBox[{"2", ",", "3"}], "]"}], "]"}], ",", 
       RowBox[{"Measurement", "[", 
        RowBox[{"S", "[", 
         RowBox[{"3", ",", "3"}], "]"}], "]"}]}], "}"}], 
     ",", "\"\<Separator\>\"", ",", 
     RowBox[{"ControlledGate", "[", 
      RowBox[{
       RowBox[{"S", "[", "2", "]"}], ",", 
       RowBox[{"S", "[", 
        RowBox[{"1", ",", "3"}], "]"}]}], "]"}], ",", 
     RowBox[{"ControlledGate", "[", 
      RowBox[{
       RowBox[{"S", "[", "3", "]"}], ",", 
       RowBox[{"S", "[", 
        RowBox[{"1", ",", "1"}], "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
     "out", ",", 
     RowBox[{"\"\<Invisible\>\"", "->", 
      RowBox[{"S", "[", "1.5", "]"}]}]}], "]"}]}]}]}], "Input",
 CellLabel->"In[668]:=",
 CellID->1457379906,ExpressionUUID->"a715630b-c295-4de8-a266-984b5cea77b7"],

