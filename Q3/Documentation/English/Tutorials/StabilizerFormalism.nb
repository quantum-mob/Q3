    $CellContext`S[1, 1]], 
   QuantumMob`Q3`PortOut[
    QuantumMob`Q3`ProductState[<|$CellContext`S[1, QuantumMob`Q3`$] -> {
        $CellContext`c[0], 
        $CellContext`c[1]}|>, "Label" -> Ket[$CellContext`\[Psi]]]], 
   "Invisible" -> $CellContext`S[1.5]]]], "Output",
 CellLabel->"Out[669]=",
 CellID->1981887039,ExpressionUUID->"31c4f63c-5a73-48ba-908f-db424ae7aeea"]
}, Open  ]],

Cell["\<\
It consists of three stages separated by the vertical dashed lines in the \
quantum circuit. The first stage is to share the entangled pair of qubits. \
The second in the middle corresponds to the Bell measurement. The final stage \
transmits the measurement outcomes to Alice, and Alice adjusts the state of \
her qubit according to the classical information.\
\>", "TechNoteText",
 CellID->1285395743,ExpressionUUID->"033e067b-c324-4258-8009-10489034a413"],

Cell[TextData[{
 "Rearrange the quantum circuit elements to reinterpret the ",
 ButtonBox["quantum teleportation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumTeleportation"],
 " protocol in stabilizer formalism."
}], "TechNoteMathCaption",
 CellID->1664416926,ExpressionUUID->"55eb2d33-ebc5-4e01-b526-1770d044d690"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc1", "=", 
   RowBox[{"QuantumCircuit", "[", 
    RowBox[{"in", ",", 
     RowBox[{"Ket", "[", 
      RowBox[{"S", "@", 
       RowBox[{"{", 
        RowBox[{"1", ",", "2"}], "}"}]}], "]"}], ",", 
     RowBox[{"S", "[", 
      RowBox[{"1", ",", "6"}], "]"}], ",", 
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "1", "]"}], ",", 
       RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", "\"\<Separator\>\"", 
     ",", "\"\<Spacer\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"qc2", "=", 
   RowBox[{"QuantumCircuit", "[", 
    RowBox[{"qc1", ",", 
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "2", "]"}], ",", 
       RowBox[{"S", "[", "3", "]"}]}], "]"}], ",", "\"\<Separator\>\""}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"qc3", "=", 
   RowBox[{"QuantumCircuit", "[", 
    RowBox[{"qc2", ",", 
     RowBox[{"S", "[", 
      RowBox[{"2", ",", "6"}], "]"}], ",", 
     RowBox[{"Measurement", "[", 
      RowBox[{"S", "[", 
       RowBox[{"2", ",", "3"}], "]"}], "]"}], ",", 
     RowBox[{"ControlledGate", "[", 
      RowBox[{
       RowBox[{"S", "[", "2", "]"}], ",", 
       RowBox[{"S", "[", 
        RowBox[{"1", ",", "3"}], "]"}]}], "]"}], ",", "\"\<Separator\>\""}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"qc4", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"qc3", ",", 
    RowBox[{"Measurement", "[", 
     RowBox[{"S", "[", 
      RowBox[{"3", ",", "3"}], "]"}], "]"}], ",", 
    RowBox[{"ControlledGate", "[", 
     RowBox[{
      RowBox[{"S", "[", "3", "]"}], ",", 
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "1"}], "]"}]}], "]"}], ",", 
    RowBox[{"\"\<Invisible\>\"", "->", 
     RowBox[{"S", "[", "1.5", "]"}]}]}], "]"}]}]}], "Input",
 CellLabel->"In[670]:=",
 CellID->252291168,ExpressionUUID->"8fb1fc5f-0a80-4042-b841-c9127711e1d6"],

