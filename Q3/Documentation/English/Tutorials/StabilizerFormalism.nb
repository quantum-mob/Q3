Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"G1", "=", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "1"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "1"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G2", "=", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "3"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "3"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"PauliForm", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"G1", ",", "G2"}], "}"}], ",", 
   RowBox[{"S", "@", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]}], "]"}]}], "Input",
 CellLabel->"In[674]:=",
 CellID->321014706,ExpressionUUID->"0c539ed4-0b7d-44f6-b86f-2a403ff74e0a"],

