Cell["\<\
A quantum circuit that more closely follows the above transformations would \
look like the following.\
\>", "TechNoteMathCaption",
 CellID->1658061337,ExpressionUUID->"25d70b00-7571-4272-878b-3f163f3a6797"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"new", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"in", ",", 
    RowBox[{"Ket", "[", 
     RowBox[{"S", "@", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}], ",", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", "\"\<Separator\>\"", 
    ",", "\"\<Spacer\>\"", ",", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "2", "]"}], ",", 
      RowBox[{"S", "[", "3", "]"}]}], "]"}], ",", "\"\<Separator\>\"", ",", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "6"}], "]"}], ",", 
    RowBox[{"Measurement", "[", 
     RowBox[{"S", "[", 
      RowBox[{"2", ",", "3"}], "]"}], "]"}], ",", 
    RowBox[{"ControlledGate", "[", 
     RowBox[{
      RowBox[{"S", "[", "2", "]"}], ",", 
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "3"}], "]"}]}], "]"}], ",", "\"\<Separator\>\"", ",", 
    RowBox[{"Measurement", "[", 
     RowBox[{"S", "[", 
      RowBox[{"3", ",", "3"}], "]"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"ControlledGate", "[", 
       RowBox[{
        RowBox[{"S", "[", "3", "]"}], ",", 
        RowBox[{"S", "[", 
         RowBox[{"1", ",", "1"}], "]"}]}], "]"}], ",", 
      RowBox[{"ControlledGate", "[", 
       RowBox[{
        RowBox[{"S", "[", "3", "]"}], ",", 
        RowBox[{"S", "[", 
         RowBox[{"2", ",", "1"}], "]"}]}], "]"}]}], "}"}], ",", 
    RowBox[{"\"\<Invisible\>\"", "->", 
     RowBox[{"S", "[", "1.5", "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[708]:=",
 CellID->1030134618,ExpressionUUID->"19ffadac-fb37-4288-8796-8ad974ef7815"],

