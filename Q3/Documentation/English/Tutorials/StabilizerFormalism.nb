 FontColor->GrayLevel[0.85],
 CellID->1288150479,ExpressionUUID->"cec3848a-6708-43e5-bbfc-55abb5406d39"],

Cell[TextData[{
 "Pauli operators (i.e., elements in the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 ") have two extremely useful properties that eventually determine the \
group-theoretical structure of the stabilizers and stabilizer codes."
}], "TechNoteText",
 CellID->245164751,ExpressionUUID->"30c64c7a-db41-4217-a27f-8d4a0c8e84d5"],

Cell["\<\
Any two elements of the full Pauli group either commute or anti-commute with \
each
other. The rule is also simple that allows to determine which elements \
commute and which elements anti-commute. \
\>", "Item",
 CellID->1610335111,ExpressionUUID->"73a98ade-6ffe-4564-9186-d2767152d7b5"],

Cell[CellGroupData[{

Cell[TextData[{
 "Every element of the Pauli group squares to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "I"}], TraditionalForm]],ExpressionUUID->
  "aeb03c8b-d9e0-41aa-871a-15cb5a23a948"],
 ". The elements that square to ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "9b596bd0-19e1-485e-928a-814547e593f5"],
 " have eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "1"}], TraditionalForm]],ExpressionUUID->
  "9d115e7a-3187-4613-a028-7f5c4d6adf39"],
 " whereas those that square to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Minus]", "I"}], TraditionalForm]],ExpressionUUID->
  "7a266bff-0973-4b39-a567-afecac5faeb5"],
 " have eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], TraditionalForm]],
  ExpressionUUID->"c8b8b8d0-a62b-400b-9648-43af4b4ea847"],
 "."
}], "Item",
 CellID->165807436,ExpressionUUID->"05c14e43-4620-48a0-9e8c-1b479bcbce06"],

