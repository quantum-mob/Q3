   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{"\<\"I\"\>", "\[CircleTimes]", 
      TemplateBox[{"\"I\""},
       "RowDefault"]}],
     $CellContext`S[2, 0]]}], ",", 
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{
      TemplateBox[{"\"X\""},
       "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
     $CellContext`S[1, 1]]}], ",", 
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{
      TemplateBox[{"\"Z\""},
       "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
