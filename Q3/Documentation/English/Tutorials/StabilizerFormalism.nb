 CellID->1732431148,ExpressionUUID->"09bb3166-3db9-4652-819c-059479cc8920"]
}, Open  ]],

Cell[TextData[{
 "We thus have to apply ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "2"], TraditionalForm]],ExpressionUUID->
  "1e0d6cc7-dc55-461b-992b-13a6f4c9a5fd"],
 " conditioned on the measurement outcome. We update ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "2"], TraditionalForm]],ExpressionUUID->
  "56c59951-9bca-4f70-b7fa-7d0f4f6bf171"],
 " by replacing it with ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "29fdd5ab-b701-48ba-b513-a94a90e9699c"],
 "."
}], "TechNoteMathCaption",
 CellID->750967279,ExpressionUUID->"fcb5358b-3a24-4a1a-afe4-0739b47785a2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"G1", "=", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "1"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "1"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"3", ",", "1"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G2", "=", "M"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"PauliForm", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"G1", ",", "G2"}], "}"}], ",", 
   RowBox[{"S", "@", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]}], "]"}]}], "Input",
 CellLabel->"In[694]:=",
 CellID->745664734,ExpressionUUID->"a6d21b64-1380-4a27-ba58-b0a1ec3adeee"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"X\""},
      "RowDefault"], "\[CircleTimes]", 
     TemplateBox[{"\"X\""},
      "RowDefault"], "\[CircleTimes]", 
     TemplateBox[{"\"X\""},
      "RowDefault"]}],
    QuantumMob`Q3`Multiply[
     $CellContext`S[1, 1], 
     $CellContext`S[2, 1], 
     $CellContext`S[3, 1]]], ",", 
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", 
     TemplateBox[{"\"X\""},
      "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
    $CellContext`S[2, 1]]}], "}"}]], "Output",
 CellLabel->"Out[696]=",
 CellID->1387018410,ExpressionUUID->"cb862090-bef8-44f5-8a72-4528d6a7fce5"]
}, Open  ]],

Cell[TextData[{
 "Note also that ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "6aee448e-cff0-4ce3-b37d-13cec9b3a7d7"],
 " anti-commutes with the logical Pauli operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["Z", "_"], TraditionalForm]],ExpressionUUID->
  "e360bee7-42a9-4c55-940f-201a760477f7"],
 " whereas it commutes with ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["X", "_"], TraditionalForm]],ExpressionUUID->
  "dc99a078-5f3a-43d1-b63c-1dc35b6b1d27"],
 ". We need to replace logical Pauli operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["Z", "_"], TraditionalForm]],ExpressionUUID->
  "681a437e-dbc8-4183-b159-d4cc6789005c"],
 " by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "2"], 
    OverscriptBox["Z", "_"]}], TraditionalForm]],ExpressionUUID->
  "43c38666-5bab-45a6-9f97-5f591d7db78d"],
 "."
}], "TechNoteMathCaption",
 CellID->1732423183,ExpressionUUID->"fb5a7c16-900a-407a-9cab-0f4ae2a41f17"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"LX", "=", "LX"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"LZ", "=", 
   RowBox[{"G", "**", "LZ"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"PauliForm", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"LX", ",", "LZ"}], "}"}], ",", 
   RowBox[{"S", "@", 
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]}], "]"}]}], "Input",
 CellLabel->"In[697]:=",
 CellID->1253150655,ExpressionUUID->"dfd7e4e7-30bc-4833-b6a2-bdc5b7190d2c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    RowBox[{"\<\"I\"\>", "\[CircleTimes]", "\<\"I\"\>", "\[CircleTimes]", 
     TemplateBox[{"\"X\""},
      "RowDefault"]}],
    $CellContext`S[3, 1]], ",", 
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"Z\""},
      "RowDefault"], "\[CircleTimes]", "\<\"I\"\>", "\[CircleTimes]", 
     TemplateBox[{"\"Z\""},
      "RowDefault"]}],
    QuantumMob`Q3`Multiply[
     $CellContext`S[1, 3], 
     $CellContext`S[3, 3]]]}], "}"}]], "Output",
 CellLabel->"Out[699]=",
 CellID->683428685,ExpressionUUID->"7d4e98e5-9ab5-4a03-a939-882d0c571b1f"]
}, Open  ]],

Cell[TextData[{
 "At this stage, it is safe to drop qubit ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "5ff5bd25-5f7c-44da-b801-4b3d84019155"],
 " off since its state does not change nor is used after the measurement \
outcome has been recorded."
}], "TechNoteMathCaption",
 CellID->792120840,ExpressionUUID->"75313180-28bc-48de-9526-daf53460ba28"],

Cell[TextData[{
 "Finally, we measure the observable ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "3f5f6d96-486a-422b-ba85-ccf3e74fa642"],
 " on qubit ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "e1a4d4b3-69a8-4245-9b51-a021a87f1567"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "Z"}]}], 
   TraditionalForm]],ExpressionUUID->"de08efb9-0aee-454f-9424-13a36cb25549"],
 ". We note that ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "193ae5f7-6938-4a6d-aba1-6df563a6c3d5"],
 " anti-commutes with generator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "1"], TraditionalForm]],ExpressionUUID->
  "7faa750d-76e8-4b98-a365-da457d5e1923"],
 " and logical Pauli operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["X", "_"], TraditionalForm]],ExpressionUUID->
  "f71df0a8-6ebe-4776-965c-2d11a9f0c92b"],
 "."
}], "TechNoteMathCaption",
 CellID->923830127,ExpressionUUID->"29fa81fe-f108-4271-a6ad-fff01df09933"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"M", "=", 
   RowBox[{"S", "[", 
    RowBox[{"3", ",", "3"}], "]"}]}], ";", 
  RowBox[{"PauliForm", "[", 
   RowBox[{"M", ",", 
    RowBox[{"S", "@", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "3"}], "}"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G", "=", "G1"}], ";"}]}], "Input",
 CellLabel->"In[700]:=",
 CellID->506176679,ExpressionUUID->"43227956-139d-48a5-832e-94e6d9d06151"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"I\"\>", "\[CircleTimes]", "\<\"I\"\>", "\[CircleTimes]", 
