      "RowDefault"], "\[CircleTimes]", "\<\"I\"\>"}],
    QuantumMob`Q3`Multiply[
     $CellContext`S[1, 1], 
     $CellContext`S[2, 1]]], ",", 
   InterpretationBox[
    RowBox[{
     TemplateBox[{"\"Z\""},
