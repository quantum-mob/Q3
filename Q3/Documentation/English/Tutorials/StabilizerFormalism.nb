       "RowDefault"]}],
     QuantumMob`Q3`Multiply[
      $CellContext`S[1, 3], 
      $CellContext`S[2, 1]]]}], ",", 
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{
      TemplateBox[{"\"Y\""},
       "RowDefault"], "\[CircleTimes]", 
      TemplateBox[{"\"X\""},
       "RowDefault"]}],
     QuantumMob`Q3`Multiply[
      $CellContext`S[1, 2], 
      $CellContext`S[2, 1]]]}], ",", 
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{"\<\"I\"\>", "\[CircleTimes]", 
