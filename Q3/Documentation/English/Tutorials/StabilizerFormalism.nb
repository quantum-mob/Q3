Cell[TextData[{
 "Moreover, the set of operators that stabilize a quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ae6546c1-342f-4287-966e-9a989a255256"],
 " forms a subgroup of ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "0767dfa7-7064-498b-b2ff-bce240b81232"],
 ". This subgroup is called the stabilizer subgroup or simply stabilizer of \
the quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f484ae7e-e85f-4be8-94e4-02de37c11778"],
 "."
}], "TechNoteText",
 CellID->382047774,ExpressionUUID->"de699ec7-ab98-487b-be66-40ac2ee56485"],

Cell[TextData[{
 "For example, the above Bell state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPhi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "61aad271-3b8f-464e-b13d-2b6012d7cca5"],
 " is also stabilized by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", "\[CircleTimes]", "Z"}], TraditionalForm]],ExpressionUUID->
  "cecbca55-45b8-494a-9726-cd249cf334e4"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "Y"}], "\[CircleTimes]", "Y"}], TraditionalForm]],
  ExpressionUUID->"a12d0011-8800-4c2f-a975-80bdf8840fd6"],
 " as well. These operators form a subgroup,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalS]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"I", "\[CircleTimes]", "I"}], ",", 
      RowBox[{"X", "\[CircleTimes]", "X"}], ",", 
      RowBox[{"Z", "\[CircleTimes]", "Z"}], ",", 
      RowBox[{
       RowBox[{"-", "Y"}], "\[CircleTimes]", "Y"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"7c35f19c-3c24-4d62-bae3-c8fa92ed886a"],
 ", of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalU]", "(", "4", ")"}], TraditionalForm]],
  ExpressionUUID->"01ed1726-f4be-436b-afb2-ed4ff8ea410d"],
 ". In other words, the subgroup \[ScriptCapitalS] is the stabilizer of Bell \
state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPhi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e453154a-878b-4523-b0b6-2f39df9b1559"],
 "."
}], "TechNoteText",
 CellID->100833088,ExpressionUUID->"d36d8347-7c8f-4fa5-8389-de5a8cb7c172"],

