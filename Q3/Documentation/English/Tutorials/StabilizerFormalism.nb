    "RowDefault"]}],
  $CellContext`S[3, 3]]], "Output",
 CellLabel->"Out[700]=",
 CellID->1643364639,ExpressionUUID->"63b9f350-f0f4-4684-99bd-36275cb4019e"]
}, Open  ]],

Cell[TextData[{
 "In accordance with the same prescription as above, we apply ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "1"], TraditionalForm]],ExpressionUUID->
  "3aeb6f2e-8999-4ff0-b606-e653de31f2ff"],
 " conditioned on the measurement outcome, and the generators and the logical \
Pauli operators are updated as follows"
}], "TechNoteMathCaption",
 CellID->1643498151,ExpressionUUID->"c20df457-9600-4449-aec9-7581481c0493"],

