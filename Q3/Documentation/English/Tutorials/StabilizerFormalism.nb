 "ModificationHighlight" -> False, "ColorType" -> "", "LinkTrails" -> "", 
  "ExampleCounter" -> 1, 
  "Openers" -> {
   "PrimaryExamplesSection" -> Open, "ExampleSection" -> {"0" -> Open}}, 
  "NewStyles" -> True, "CitationPopupData" -> {"2021", "2023"}, 
  "ShowCitation" -> False, "RootCaptions" -> "", "HeaderCoreAreaLink" -> {}, 
  "Metadata" -> {
   "built" -> "{2026, 4, 12, 18, 0, 25.584025}", 
    "history" -> {"13", "13.3", "", ""}, "context" -> "QuantumMob`Q3`", 
    "keywords" -> {
     "stabilizer formalism", "Gottesman-Knill theorem", 
      "quantum error-correction codes", "graph states", "Gottesman vectors", 
      "Gottesman matrix", "logical Pauli operators", 
      "Gottesman-Knill theorem"}, "specialkeywords" -> {}, 
    "tutorialcollectionlinks" -> {}, "index" -> True, "label" -> 
    "Quantum Mob/ Q3 Tech Note", "language" -> "en", "paclet" -> 
    "QuantumMob/Q3", "status" -> "None", "summary" -> 
    "Stabilizer formalism is a mathematical framework that describes and \
characterizes states on multiple qubits in a compact way in terms of \
operators preserving the states. It provides a powerful and elegant tool to \
construct quantum error-correction codes, to build and analyse various \
quantum algorithms, and to examine the properties of the graph states and \
one-way quantum computation, and to formulate topological quantum \
computation. Stabilizer formalism was first put forward by Gottesman (1996). \
This formalism is explained in great detail in Gottesman (1997) and is also \
presented in Nielsen & Chuang (2011) and the Quantum Workbook. Recently, \
stabilizer formalism has been extended to the measurement-based quantum \
computation scheme (Browne & Briegel, 2016). See also Section 6.3 of the \
Quantum Workbook (2022).", "synonyms" -> {}, "tabletags" -> {}, "title" -> 
    "Stabilizer Formalism", "titlemodifier" -> "", "metadescription" -> "", 
    "windowtitle" -> "Stabilizer Formalism", "type" -> "Tech Note", "uri" -> 
    "QuantumMob/Q3/tutorial/StabilizerFormalism"}},
