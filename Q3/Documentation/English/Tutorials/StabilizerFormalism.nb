Cell[TextData[{
 "Stabilizer formalism is a mathematical framework that describes and \
characterizes states on multiple qubits in a compact way in terms of \
operators preserving the states. It provides a powerful and elegant tool to \
construct ",
 ButtonBox["quantum error-correction codes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/StabilizerCodes"],
 ", to build and analyse various quantum algorithms, and to examine the \
properties of the graph states and one-way quantum computation, and to \
formulate topological quantum computation."
}], "TechNoteText",
 CellID->1426768759,ExpressionUUID->"c8c1b150-6973-4931-9c2a-ff38f86ab58d"],

Cell[TextData[{
 "Stabilizer formalism was first put forward by Gottesman (1996). This \
formalism is explained in great detail in Gottesman (1997) and is also \
presented in Nielsen & Chuang (2011) and the ",
 ButtonBox["Quantum Workbook",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-3-030-91214-7"], None}],
 ". Recently, stabilizer formalism has been extended to the measurement-based \
quantum computation scheme (",
 ButtonBox["Browne & Briegel, 2016",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1002/9783527805785.ch21"], None}],
 ")."
}], "TechNoteText",
 CellID->841140166,ExpressionUUID->"5c81be2c-a3ba-4a20-bd2b-8599973a5c3a"],

Cell[TextData[{
 "See also Section 6.3 of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "a578cbff-6a18-4935-a727-7a9aa5109e5d"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"10c3a325-ab10-4b40-81e4-3099fb960672"],

