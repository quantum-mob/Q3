Cell[TextData[{
 "However, the operation ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "47b1fabe-e68e-4c4e-b927-5ad2d76d71f5"],
 "on the second qubit is meaningless since the qubit was already measured. \
Therefore, the quantum circuit is equivalent to the standard one for quantum \
teleportation."
}], "TechNoteMathCaption",
 CellID->1878363073,ExpressionUUID->"3a9b6af9-d2bc-4417-a400-d7134cc0793d"],

Cell["\<\
To confirm it, we test the result by performing the quantum circuit model \
many times.\
\>", "TechNoteMathCaption",
 CellID->1518656460,ExpressionUUID->"49093a87-fd95-49e1-9895-53a0f9f4b07b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"ExpressionFor", "[", "qc4", "]"}], ",", 
      RowBox[{"{", "6", "}"}]}], "]"}], "/.", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"c", "[", "0", "]"}], "*", 
       RowBox[{"Conjugate", "[", 
        RowBox[{"c", "[", "0", "]"}], "]"}]}], "+", 
      RowBox[{
       RowBox[{"c", "[", "1", "]"}], "*", 
       RowBox[{"Conjugate", "[", 
        RowBox[{"c", "[", "1", "]"}], "]"}]}]}], "->", "1"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"KetFactor", "[", 
     RowBox[{"#", ",", 
      RowBox[{"S", "@", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3"}], "}"}]}]}], "]"}], "&"}], "/@", "out"}], "//",
