       "RowDefault"]}],
     QuantumMob`Q3`Multiply[
      $CellContext`S[1, 1], 
      $CellContext`S[2, 3]]]}], ",", 
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{
      TemplateBox[{"\"Z\""},
       "RowDefault"], "\[CircleTimes]", 
      TemplateBox[{"\"Z\""},
       "RowDefault"]}],
     QuantumMob`Q3`Multiply[
      $CellContext`S[1, 3], 
      $CellContext`S[2, 3]]]}], ",", 
   RowBox[{"\[ImaginaryI]", " ", 
    InterpretationBox[
     RowBox[{
      TemplateBox[{"\"Y\""},
       "RowDefault"], "\[CircleTimes]", 
