Cell[CellGroupData[{

Cell["Stabilizer of a subspace", "Subsection",
 CellTags->"Section13",
 CellID->2031863425,ExpressionUUID->"a921e924-b853-4654-ad2b-cf74ddffa002"],

Cell[TextData[{
 "The notion of stabilizer is extended to subspaces. Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "d4b5408b-b60e-44df-9095-b0a32389ff3c"],
 " be a subspace of the Hilbert space associated with a quantum system. The \
stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "f732cae4-509e-43d5-9128-89a885489f94"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "c9669b51-9137-4552-83bc-905f1a6e88f4"],
 " is the set of all operators G in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "9ceafef3-ad78-4b63-8933-e0281db4fc7d"],
 " that stabilize all quantum states in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "01b31093-ee7d-4290-8219-30c1cbd00c07"],
 "."
}], "TechNoteText",
 CellID->243629381,ExpressionUUID->"daac0761-911c-4a22-b283-2cbd1ad52f85"],

Cell[TextData[{
 "For example, consider the code space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "20e053d9-dad4-4dd4-88b7-9bd26f190c98"],
 " of the bit- flip correction code. ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "d35f173a-b845-41c3-af45-026d359cef57"],
 " is spanned by the two logical basis states | 000 \:27e9 and | 111 \:27e9. \
The stabilizer ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "7e30ef7c-6f24-40ed-86aa-3ec8dd992ca9"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "c1da01bd-5b58-4ebd-ac27-bb55017926a9"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalS]", ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ",", 
      RowBox[{"Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "I"}], ",", 
      RowBox[{"I", "\[CircleTimes]", "Z", "\[CircleTimes]", "Z"}], ",", 
      RowBox[{"Z", "\[CircleTimes]", "I", "\[CircleTimes]", "Z"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"7d74ef7f-b5e6-47e2-87cf-07fe180611a9"],
 "."
}], "TechNoteText",
 CellID->1575175285,ExpressionUUID->"346009d4-707a-41f9-8e47-e839d184d616"],

Cell["\t", "TechNoteText",
