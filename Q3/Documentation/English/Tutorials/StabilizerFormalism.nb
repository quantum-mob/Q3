Cell["\<\
At this stage, the generators are meaningless since the second and third \
qubits are now classical after the two measurements. If one followed the \
above steps of analysis faithfully, she would get a quantum circuit of the \
form\
\>", "TechNoteMathCaption",
 CellID->645604558,ExpressionUUID->"acca72b4-afb7-4b14-9c09-5c6195fec26a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"S", "[", 
    RowBox[{"2", ",", "6"}], "]"}], ",", 
   RowBox[{"CNOT", "[", 
    RowBox[{
     RowBox[{"S", "[", "2", "]"}], ",", 
     RowBox[{"S", "[", "3", "]"}]}], "]"}], ",", "\"\<Separator\>\"", ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "1", "]"}], ",", 
       RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", 
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "3", "]"}], ",", 
       RowBox[{"S", "[", "4", "]"}]}], "]"}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Measurement", "[", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "3"}], "]"}], "]"}], ",", 
   RowBox[{"CNOT", "[", 
    RowBox[{
     RowBox[{"S", "[", "2", "]"}], ",", 
     RowBox[{"S", "@", 
      RowBox[{"{", 
       RowBox[{"3", ",", "4"}], "}"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
   
   RowBox[{"S", "[", 
    RowBox[{"3", ",", "6"}], "]"}], ",", 
   RowBox[{"Measurement", "[", 
    RowBox[{"S", "[", 
     RowBox[{"3", ",", "3"}], "]"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"ControlledGate", "[", 
      RowBox[{
       RowBox[{"S", "[", "3", "]"}], ",", 
       RowBox[{"S", "[", 
        RowBox[{"1", ",", "3"}], "]"}]}], "]"}], ",", 
     RowBox[{"ControlledGate", "[", 
      RowBox[{
       RowBox[{"S", "[", "3", "]"}], ",", 
       RowBox[{"S", "[", 
        RowBox[{"2", ",", "3"}], "]"}]}], "]"}]}], "}"}]}], 
  "\[IndentingNewLine]", "]"}]], "Input",
 CellLabel->"In[748]:=",
 CellID->1588421662,ExpressionUUID->"e0b7942e-91c9-4eba-a53e-4fc19711424c"],

