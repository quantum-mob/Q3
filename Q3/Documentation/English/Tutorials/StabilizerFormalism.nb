 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->770398677,ExpressionUUID->"2fd58def-5306-47c8-bd2d-9dd3d166dc2b"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[600]:=",
 CellID->1563203618,ExpressionUUID->"3326258d-f5de-4b72-a0ef-6278bf432c08"],

Cell[TextData[{
 "Elements of the ",
 ButtonBox["full Pauli group",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/FullPauliGroup"],
 " are called (multi-qubit) ",
 StyleBox["Pauli operators",
  FontSlant->"Italic"],
 " (or Pauli strings)."
}], "TechNoteMathCaption",
 CellID->1947433679,ExpressionUUID->"29dee1e9-82e6-47ae-8c40-49a4fa314679"],

Cell[CellGroupData[{

