 CellID->833975757,ExpressionUUID->"02de7d77-d2e8-4e75-b0a6-d7c0e2579bd3"],

Cell[TextData[{
 "The number of elements quickly increases with the number of qubits, and it \
is more convenient to describe the full Pauli group in terms of generators. \
The Pauli group on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "32515696-2438-4544-a26f-a00087eaac26"],
 " qubits is generated by tensor products of the Pauli operators acting \
non-trivially on one and only one qubit."
}], "TechNoteText",
 CellID->438617403,ExpressionUUID->"30aa52ed-e16b-4b14-a46e-2697fab4339f"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1212956853,ExpressionUUID->"f9479211-bda1-4ddc-a55c-bc002de282ad"],

Cell["\<\
For example, the full Pauli group on two qubits are generated by single-qubit \
Pauli operators.\
\>", "TechNoteMathCaption",
 CellID->1678815717,ExpressionUUID->"ed3ef728-dce5-4ea4-8b67-ea681ffc0c38"],

