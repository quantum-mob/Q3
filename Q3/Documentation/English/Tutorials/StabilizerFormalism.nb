      TemplateBox[{",", "\",\"", "\"S\""}, "RowWithSeparators"]},
     "Subsuperscript"],
    $CellContext`S[3, 7]], ",", 
   RowBox[{"CZ", "[", 
    RowBox[{"{", 
     RowBox[{
      InterpretationBox[
       SubscriptBox["S", 
        TemplateBox[{",", "\",\"", "1"},
         "RowWithSeparators"]],
       $CellContext`S[1, QuantumMob`Q3`$]], ",", 
