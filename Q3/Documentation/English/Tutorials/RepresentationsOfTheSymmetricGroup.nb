Cell[CellGroupData[{

Cell["Young\[CloseCurlyQuote]s Seminormal Representation", "TechNoteSection",
 CellID->1984756008,ExpressionUUID->"11d9e465-e3ee-4ea5-84d6-5222624389c8"],

Cell[TextData[{
 "See ",
 ButtonBox["Sagan (2001, Exercise 2.11)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-1-4757-6804-6"], None}],
 "  or ",
 ButtonBox["G\[UDoubleDot]nther (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://community.wolfram.com/groups/-/m/t/1637345"], None}],
 "."
}], "TechNoteText",
 TextAlignment->Right,
 CellID->930737605,ExpressionUUID->"3bc2f4bb-f338-4505-96a3-8b6344f7e514"],

Cell[TextData[{
 "Every matrix element in Young's seminormal representation is ",
 StyleBox["rational",
  FontSlant->"Italic"],
 ". Young's seminormal representation is ",
 StyleBox["not orthogonal",
  FontSlant->"Italic"],
 " with respect to the standard Hermitian product, but it is orthogonal with \
respect to the generalized inner product associated with Young's seminormal \
metric."
}], "TechNoteText",
 CellID->2085576124,ExpressionUUID->"48679afd-480f-417f-869e-9c9fb350f4b3"],

Cell["Set the Specht basis", "TechNoteText",
 CellID->1844682274,ExpressionUUID->"34b45f16-7c14-42f7-b71c-4553e1a3099a"],

Cell[BoxData[
 FormBox[
  RowBox[{"\t", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         RowBox[{"\[Lambda]", ",", 
           SubscriptBox["Y", "i"]}]},
        "Ket"], ":", "i"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     SubscriptBox["d", "\[Lambda]"]}], "}"}]}], 
  TraditionalForm]], "TechNoteText",
 CellID->1480456495,ExpressionUUID->"57fe06b3-56d5-40b6-97d0-27019ccb9438"],

Cell[TextData[{
 "by fixing the ordering of standard Young tableaux ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Y", "i"], TraditionalForm]],ExpressionUUID->
  "6f3ab7ee-bb34-4ffc-86c3-0b6f191d6d1d"],
 " of shape ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],ExpressionUUID->
  "64fe0200-3443-4c1d-8e83-0414560be83d"],
 "."
}], "TechNoteText",
 CellID->1289600056,ExpressionUUID->"96b1333b-0f32-41a6-970c-82eba8c10017"],

Cell[TextData[{
 "Young\[CloseCurlyQuote]s seminormal representation of transposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "k"], ":=", 
    RowBox[{"(", 
     RowBox[{"k", ",", 
      RowBox[{"k", "+", "1"}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "5da329b6-1f17-4462-b8e3-5187e912aa68"],
 " is given by"
}], "TechNoteText",
 CellID->1792388480,ExpressionUUID->"65650317-0170-4448-a78a-fceaffaee177"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[CapitalGamma]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}], "\[Lambda]"], "(", 
     SubscriptBox["\[Tau]", "k"], ")"}], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        SubscriptBox["Y", "i"]},
       "Bra"], 
      SubscriptBox["\[Tau]", "k"], 
      TemplateBox[{
        SubscriptBox["Y", "j"]},
       "Ket"]}], "=", 
     TagBox[GridBox[{
        {"\[Piecewise]", GridBox[{
           {
            RowBox[{"1", "/", 
             RowBox[{
              SubscriptBox["\[Delta]", "k"], "(", 
              SubscriptBox["Y", "i"], ")"}]}], 
            RowBox[{"i", "=", "j"}]},
           {
            RowBox[{"1", "-", 
             RowBox[{"1", "/", 
              RowBox[{
               SubsuperscriptBox["\[Delta]", "k", "2"], "(", 
               SubscriptBox["Y", "i"], ")"}]}]}], 
            RowBox[{
             SubscriptBox["Y", "i"], "=", 
             RowBox[{
              SubscriptBox["\[Tau]", "k"], 
              SubscriptBox["Y", "j"], "  ", 
              RowBox[{"(", 
               RowBox[{"i", "<", "j"}], ")"}]}]}]},
           {"1", 
            RowBox[{
             SubscriptBox["Y", "i"], "=", 
             RowBox[{
              SubscriptBox["\[Tau]", "k"], 
              SubscriptBox["Y", "j"], "  ", 
              RowBox[{"(", 
               RowBox[{"i", ">", "j"}], ")"}]}]}]},
           {"0", "otherwise"}
          },
          AllowedDimensions->{2, Automatic},
          Editable->True,
          GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
          GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
          GridBoxSpacings->{"Columns" -> {
              Offset[0.27999999999999997`], {
               Offset[0.84]}, 
              Offset[0.27999999999999997`]}, "Rows" -> {
              Offset[0.2], {
               Offset[0.4]}, 
              Offset[0.2]}},
          Selectable->True]}
       },
       GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
       GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{1.}}},
       GridBoxSpacings->{"Columns" -> {
           Offset[0.27999999999999997`], {
            Offset[0.35]}, 
           Offset[0.27999999999999997`]}, "Rows" -> {
           Offset[0.2], {
            Offset[0.4]}, 
           Offset[0.2]}}],
      "Piecewise",
      DeleteWithContents->True,
      Editable->False,
      SelectWithContents->True,
      Selectable->False,
      StripWrapperBoxes->True]}]}], TraditionalForm]],ExpressionUUID->
  "89b2b865-a483-4b4e-9997-51173f182d04"],
 " ,"
}], "TechNoteText",
 CellID->1920066891,ExpressionUUID->"7071335a-0c90-4cfa-a47c-ec9520271f34"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Delta]", "k"], "(", "t", ")"}], TraditionalForm]],
  ExpressionUUID->"df021a0d-8845-43fe-97e7-c777dc111f87"],
 " is the ",
 ButtonBox["Young distance",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungDistance"],
 " from ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "ac7e718b-d872-4027-b095-9363a7d9c8fa"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "5855098e-e426-48c8-b136-86f4591380f6"],
 " in standard Young tableau ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "b72a98e3-bf17-4260-8d56-7ff85d8061e8"],
 ". "
}], "TechNoteText",
 CellID->327473568,ExpressionUUID->"83293a71-9ae2-4cc0-aee9-5186159dd2cf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Young\[CloseCurlyQuote]s Normal Representation", "TechNoteSection",
 CellID->636042487,ExpressionUUID->"4b8c7271-5759-48f0-9dbb-28d54fe291b1"],

Cell[TextData[{
 "See also ",
 ButtonBox["Krovi (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.22331/q-2019-02-14-122"], None}],
 " and ",
 ButtonBox["Kawano and Sekigawa (2016)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1016/j.jsc.2015.11.016"], None}],
 "."
}], "TechNoteText",
 TextAlignment->Right,
 CellID->1939967890,ExpressionUUID->"26767a1b-68d7-42d2-ac2d-2ac8ac2fdee0"],

Cell[TextData[{
 ButtonBox["Young's normal representation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungNormalRepresentation"],
 " is a multiplicity-free subgroup-adapted basis (i.e., a Young-Yamanouchi \
basis), adapted to the canonical subgroup tower ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[ScriptCapitalS]", "n"], "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", 
     RowBox[{"n", "-", "1"}]], "\[Superset]", "\[Ellipsis]", "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", "2"], "\[Superset]", 
    SubscriptBox["\[ScriptCapitalS]", "1"]}], TraditionalForm]],
  ExpressionUUID->"bf11f917-23ee-4d2c-9095-5f0ab2236ce7"],
 " for the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "f9f9d9a3-f93a-4145-9c17-2de2b4a43f14"],
 " of degree ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f2a0f88d-da7a-426f-aadd-df5a39ea5538"],
 "."
}], "TechNoteText",
 CellID->1379946733,ExpressionUUID->"843587ca-c9f9-4229-9430-16a9f03688a9"],

Cell[TextData[{
 "Unlike Young\[CloseCurlyQuote]s natural or seminormal representations, \
Young' normal representation is an ",
 StyleBox["orthogonal",
  FontSlant->"Italic"],
 " representation. A tradeoff is that the matrix elements are not rational \
any longer."
}], "TechNoteText",
 CellID->30815625,ExpressionUUID->"ea1242c6-6d6d-47d3-b917-a0d951eb7409"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "k"], ":=", 
    RowBox[{"(", 
     RowBox[{"k", ",", 
      RowBox[{"k", "+", "1"}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6b079d32-b300-4cc3-8860-87cafa31ff6d"],
 " denote the adjacent transposition of elements ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "dcc3bf7f-c57f-4e33-8b90-716c336ee59e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "fea6c16d-d99f-47ed-abd3-c59908dbfc96"],
 ". Recall that the symmetric group is generated by adjacent transpositions."
}], "TechNoteText",
 CellID->2061338262,ExpressionUUID->"98e6d0ab-21c7-4632-bb32-40dd9ae29362"],

