 ","
}], "TechNoteText",
 CellID->2080884647,ExpressionUUID->"b5a53333-1a52-4a8e-93dc-0235cf5c8613"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], ":=", 
    RowBox[{"1", "/", 
     SubscriptBox["\[Delta]", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "184434e0-b95c-4835-a4c1-b96a823c4ed2"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["b", "k"], ":=", 
    SqrtBox[
     RowBox[{"1", "-", 
      RowBox[{"1", "/", 
       SubsuperscriptBox["\[Delta]", "k", "2"]}]}]]}], TraditionalForm]],
  ExpressionUUID->"a22511c8-026b-4619-ac9e-98100b6a3252"],
 ", and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Delta]", "k"], ":=", 
    RowBox[{
     SubscriptBox["\[Delta]", "k"], "(", "Y", ")"}]}], TraditionalForm]],
  ExpressionUUID->"91d61887-8b91-45d9-94ee-1d3bde386706"],
 " is the ",
 ButtonBox["Young distance",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungDistance"],
 " (also known as axial distance or Manhattan distance) from ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "28340dae-718c-445f-b5a1-bf051df670de"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "b0d94e2b-146f-4540-831c-7fb704fbc364"],
 " in tableau ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "83db1ae4-5d3a-479a-8e36-7c59a2ad5891"],
 ". Note that the involution property of transpositions leads to"
}], "TechNoteText",
 CellID->677544958,ExpressionUUID->"f9cea98f-f26c-4913-ba80-87c4410b2709"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Tau]", "k"], 
     TemplateBox[{
       RowBox[{
         SubscriptBox["\[Tau]", "k"], "Y"}]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"Y"},
       "Ket"], 
      SubscriptBox["b", "k"]}], "-", 
     RowBox[{
      TemplateBox[{
