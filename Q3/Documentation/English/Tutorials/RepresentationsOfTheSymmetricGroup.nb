         Rational[2, 3]^Rational[1, 2], Rational[-1, 2] 3^Rational[-1, 2], 
         Rational[-1, 2]}}]]]]}], "}"}]], "Output",
 CellLabel->"Out[225]=",
 CellID->1662152653,ExpressionUUID->"755c0bd6-62ee-4d20-a060-1acdd7a753db"]
}, Open  ]],

