Cell[CellGroupData[{

Cell["Appendix: Specht vs Schur Bases", "TechNoteSection",
 CellID->1488800333,ExpressionUUID->"5c5457ff-5344-446f-bd6d-9feb8a2d382e"],

Cell["\<\
Both the Specht and Schur bases give orthogonal representations of the \
symmetric group. Here, we demonstrate that the group action specified at the \
beginning of this section is consistent with the representation given by the \
Schur basis.\
\>", "TechNoteText",
 CellID->710681819,ExpressionUUID->"feabdbef-d86f-43d1-bb85-fa4f53030d20"],

Cell[TextData[{
 "Consider the symmetric of degree ",
