    RowBox[{
     SubscriptBox["\[Tau]", "k"], 
     TemplateBox[{"Y"},
      "Ket"]}], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"Y"},
       "Ket"], 
