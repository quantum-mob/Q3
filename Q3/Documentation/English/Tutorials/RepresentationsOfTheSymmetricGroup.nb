Cell[TextData[{
 "Young's three common representations of the symmetric group are summarized. \
They are all associated with the ",
 ButtonBox["Specht modules",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtModules"],
 ". The Specht module ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"dcb5f934-d159-4569-9525-54e3c1921893"],
 "associated with partition \[Lambda] of integer ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "99d48016-1888-4e9d-92e0-f72ad046dcd9"],
 " is spanned by the basis"
}], "TechNoteText",
 CellID->1736412263,ExpressionUUID->"33aaa15b-ffc8-4ad9-8760-2dbec16379cc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", "Y"}]},
      "Ket"], "|", 
     RowBox[{
     "Y", " ", "is", " ", "a", " ", "standard", " ", "Young", " ", "tableau", 
      " ", "of", " ", "shape", " ", "\[Lambda]"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"da480e4b-06f1-4561-8a2a-1e539677b9dd"],
 " ."
}], "TechNoteText",
 CellID->549369163,ExpressionUUID->"dbda48ab-d786-4df1-b958-328b950a5cd1"],

Cell[TextData[{
 "We call this basis the ",
 StyleBox[ButtonBox["Specht basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SpechtBasis"],
  FontSlant->"Italic"],
 " of partition \[Lambda]. For example, consider ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "3"], TraditionalForm]],ExpressionUUID->
  "b71b14e9-5ca5-4e55-a0b5-bc6efd873546"],
 ". For partition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"{", 
     RowBox[{"2", ",", "1"}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "582ebfb0-b4c1-426e-9eec-1884675a7336"],
 ", the Specht basis consists of the following two vectors, "
}], "TechNoteText",
 CellID->1215324088,ExpressionUUID->"359392fc-bed8-4b54-b534-6ce742210004"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         TagBox[
          GridBox[{{
             ItemBox["1", Frame -> True, StripOnInput -> False], 
             ItemBox["3", Frame -> True, StripOnInput -> False]}, {
             ItemBox["2", Frame -> True, StripOnInput -> False], ""}}, 
           AutoDelete -> False, 
           GridBoxItemSize -> {
            "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"]}]},
      
      "Ket"], ",", 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         TagBox[
          GridBox[{{
             ItemBox["1", Frame -> True, StripOnInput -> False], 
             ItemBox["2", Frame -> True, StripOnInput -> False]}, {
             ItemBox["3", Frame -> True, StripOnInput -> False], ""}}, 
           AutoDelete -> False, 
           GridBoxItemSize -> {
            "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"]}]},
      
      "Ket"]}], "}"}], " ", "."}]}]], "TechNoteText",
 CellID->1234980399,ExpressionUUID->"661ba508-9ffb-456d-bce1-fb02e24f1a5b"],

Cell[TextData[{
 "Depending on the way the group acts on the Specht basis vectors in ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalS]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"baecdd91-368b-41ce-8db0-1a2a3e9e32b5"],
 ", \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Lambda]", ",", "Y"}]},
     "Ket"], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], "(", "g", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", "Y"}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "55a36ae8-99de-4897-8871-c137f29005a7"],
 ", \[LineSeparator]the representation ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"03eab324-c042-4976-a58f-fbe3d15f6694"],
 " gives Young\[CloseCurlyQuote]s ",
 StyleBox["natural",
  FontSlant->"Italic"],
 ", ",
 StyleBox["seminormal",
  FontSlant->"Italic"],
 ", or ",
 StyleBox["normal",
  FontSlant->"Italic"],
 " representation."
}], "TechNoteText",
 CellID->886117738,ExpressionUUID->"0aa65e98-afd4-4e86-aa8b-76485632eb47"],

