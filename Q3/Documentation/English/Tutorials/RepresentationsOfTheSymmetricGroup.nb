}], "TechNoteText",
 CellID->535909190,ExpressionUUID->"f0466013-e475-40b6-b856-b37c6a02c9ee"],

Cell[TextData[{
 "whereas if they are in the same column, they must be in adjacent rows (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], "=", 
    RowBox[{
     SubscriptBox["\[Delta]", "k"], "=", 
     RowBox[{"-", "1"}]}]}], TraditionalForm]],ExpressionUUID->
  "9dcf6208-985a-45b8-97d1-08fc39f72c71"],
 "), and the action is give by"
}], "TechNoteText",
 CellID->479340812,ExpressionUUID->"9f3f4e40-2878-44ec-8e7e-4f49c419936a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Tau]", "k"], 
     TemplateBox[{"Y"},
      "Ket"]}], ":=", 
    RowBox[{"-", 
     TemplateBox[{"Y"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "4ceba310-b362-41bc-874e-6337742547c9"],
 " ."
}], "TechNoteText",
 CellID->1069867387,ExpressionUUID->"fa5cec4a-f7ca-4269-a514-e94eddc7ef37"]
}, Open  ]],

