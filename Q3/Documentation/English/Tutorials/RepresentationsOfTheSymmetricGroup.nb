        RowBox[{"-", 
         FractionBox["1", "6"]}], 
        FractionBox[
         SqrtBox["3"], "2"]},
       {
        RowBox[{"-", 
         SqrtBox[
          FractionBox["2", "3"]]}], 
        RowBox[{"-", 
         FractionBox["1", 
          RowBox[{"2", " ", 
           SqrtBox["3"]}]]}], 
        RowBox[{"-", 
         FractionBox["1", "2"]}]}
      },
      GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
      GridBoxSpacings->{"Columns" -> {
