 CellID->2079185925,ExpressionUUID->"8fc438e6-9095-4dd9-8c88-c9f26aa1689d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"MatrixIn", "[", 
      RowBox[{"#", ",", "sub"}], "]"}], "&"}], "/@", "gnr"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "/@", "mat"}]}], "Input",
 CellLabel->"In[224]:=",
 CellID->714542409,ExpressionUUID->"1e317293-4eb3-44af-9e42-f0735c42e2b9"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"1", "0", "0"},
       {"0", "1", "0"},
       {"0", "0", 
        RowBox[{"-", "1"}]}
      },
      GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
      GridBoxSpacings->{"Columns" -> {
          Offset[0.27999999999999997`], {
           Offset[0.7]}, 
          Offset[0.27999999999999997`]}, "Rows" -> {
          Offset[0.2], {
           Offset[0.4]}, 
          Offset[0.2]}}], "\[NoBreak]", ")"}],
    Function[BoxForm`e$, 
     MatrixForm[
     SparseArray[
      Automatic, {3, 3}, 0, {
       1, {{0, 1, 2, 3}, {{1}, {2}, {3}}}, {1, 1, -1}}]]]], ",", 
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{"-", 
         FractionBox["1", "3"]}], 
        FractionBox[
         RowBox[{"2", " ", 
          SqrtBox["2"]}], "3"], "0"},
       {
        RowBox[{"-", 
