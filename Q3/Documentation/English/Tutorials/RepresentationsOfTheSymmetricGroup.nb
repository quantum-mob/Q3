Cell["\<\
Functions related to Young's representations of the symmetric group.\
\>", "TechNoteCaption",
 CellID->815377771,ExpressionUUID->"f1b97ac3-4eed-4854-a0c7-a91d636f566e"],

Cell["Make sure that the Q3 package is loaded:", "TechNoteMathCaption",
 CellID->961045690,ExpressionUUID->"9ae064fc-eaec-45b0-9e55-b01942e708ae"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[2]:=",
 CellID->1070402743,ExpressionUUID->"ebd370c9-97ab-4cae-b014-6847d7867795"],

Cell[CellGroupData[{

Cell["Young\[CloseCurlyQuote]s Natural Representation", "TechNoteSection",
 CellID->181730621,ExpressionUUID->"0bc05bb8-9cdc-4cb4-817c-a5242cb8d0ab"],

Cell[TextData[{
 "See ",
 ButtonBox["Sagan (2001, Section 2.7)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-1-4757-6804-6"], None}],
 "  or ",
 ButtonBox["G\[UDoubleDot]nther (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://community.wolfram.com/groups/-/m/t/1637345"], None}],
 "."
}], "TechNoteText",
 TextAlignment->Right,
 CellID->473781460,ExpressionUUID->"4960fb6e-543d-48a9-9406-ea4c8b5ebf7d"],

Cell[TextData[{
 "One advantage of Young's natural representation is that all matrix entries \
are ",
 StyleBox["integers",
  FontSlant->"Italic"],
 ". However, it is ",
 StyleBox["not  orthogonal",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->881314296,ExpressionUUID->"93fc50b4-aba0-4a54-b55a-9907d821c39e"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "k"], ":=", 
    RowBox[{"(", 
     RowBox[{"k", ",", 
      RowBox[{"k", "+", "1"}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "bfe07574-6c3c-43d3-89cb-df2a4f394ae0"],
 " denote the adjacent transposition of elements ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "2bf2f6a7-0044-4f58-96c6-73509c0885dc"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "adf65248-cf9b-4b10-a145-38dd473db7b4"],
 ". Recall that the symmetric group is generated by adjacent transpositions."
}], "TechNoteText",
 CellID->1414503638,ExpressionUUID->"946ab1dd-3919-418a-bab6-2511219578b7"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "fdd9c06e-bc1a-40f9-8f34-b15cba52afd9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "9b241071-0776-4160-808f-bf17a9fabad0"],
 " are in different rows and columns in standard Young tableau ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "7e1b52af-c736-466f-9832-77034842c9d5"],
 ", then  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "k"], "Y"}], TraditionalForm]],ExpressionUUID->
  "2d583d79-3789-43a5-ba52-f4df3a4533cb"],
 " is also a standard Young tableau, and the action of  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "k"], TraditionalForm]],ExpressionUUID->
  "1585848c-fa4f-449f-8aa7-3f2ddec7dd6e"],
 " on ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"Y"},
    "Ket"], TraditionalForm]],ExpressionUUID->
