  "d92b974e-95bf-4bac-b30b-3ffc95190e24"],
 "=",
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {6, -1}}, {{0, -2}, {6, -2}}, {{0, -3}, {6, -3}}, {{
     0, -4}, {6, -4}}, {{0, -5}, {6, -5}}}], {
     {GrayLevel[1], EdgeForm[GrayLevel[0]], 
      RectangleBox[{0.6, -5.4}, {1.4, -4.6}]}, InsetBox[
      StyleBox["\<\"C\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.06666666666666667],
       FontWeight->"Light",
       FontSlant->Italic], {1, -5}, ImageScaled[{0.5, 0.5}]]}, {
     LineBox[{{2, -1}, {2, -2}, {2, -3}, {2, -4}, {2, -5}}], 
     DiskBox[{2, -1}, 0.09], DiskBox[{2, -2}, 0.09], DiskBox[{2, -3}, 0.09], 
     DiskBox[{2, -4}, 0.09], {CircleBox[{2, -5}, 0.26666666666666666], 
      LineBox[{{{1.7333333333333334`, -5}, {2.2666666666666666`, -5}}, {{
         2, -5.266666666666667}, {2, -4.733333333333333}}}]}}, {
     {GrayLevel[1], EdgeForm[GrayLevel[0]], 
      RectangleBox[{2.6, -5.4}, {3.4, -4.6}]}, InsetBox[
      StyleBox["\<\"B\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.06666666666666667],
       FontWeight->"Light",
       FontSlant->Italic], {3, -5}, ImageScaled[{0.5, 0.5}]]}, {
     LineBox[{{4, -1}, {4, -2}, {4, -3}, {4, -4}, {4, -5}}], 
     DiskBox[{4, -1}, 0.09], DiskBox[{4, -2}, 0.09], DiskBox[{4, -3}, 0.09], 
     DiskBox[{4, -4}, 0.09], {CircleBox[{4, -5}, 0.26666666666666666], 
      LineBox[{{{3.7333333333333334`, -5}, {4.266666666666667, -5}}, {{
         4, -5.266666666666667}, {4, -4.733333333333333}}}]}}, {{
      {GrayLevel[1], EdgeForm[GrayLevel[0]], 
       RectangleBox[{4.6, -5.4}, {5.4, -4.6}]}, InsetBox[
       StyleBox["\<\"A\"\>",
        StripOnInput->False,
        FontSize->Scaled[0.06666666666666667],
        FontWeight->"Light",
        FontSlant->Italic], {5, -5}, ImageScaled[{0.5, 0.5}]]}, {
      LineBox[{{5, -1}, {5, -2}, {5, -3}, {5, -4}}], DiskBox[{5, -1}, 0.09], 
      DiskBox[{5, -2}, 0.09], DiskBox[{5, -3}, 0.09], 
      {GrayLevel[1], EdgeForm[GrayLevel[0]], 
       RectangleBox[{4.6, -4.4}, {5.4, -3.6}]}, InsetBox[
       StyleBox["\<\"\[Phi]\"\>",
        StripOnInput->False,
        FontSize->Scaled[0.06666666666666667],
        FontWeight->"Light",
        FontSlant->Italic], {5, -4}, ImageScaled[{0.5, 0.5}]]}}},
   AxesStyle->Large,
   FrameStyle->Large,
   ImagePadding->{{23.400000000000002`, 23.400000000000002`}, {1, 1}},
   ImageSize->262.8,
   PlotRange->NCache[{
      Rational[-11, 2], 
      Rational[-1, 2]}, {-5.5, -0.5}],
   PlotRangePadding->Scaled[0.025]]],ExpressionUUID->
  "56f9ffc3-2d0a-4263-8397-0d972aa41f04"]
}], "Picture",
 TextAlignment->-0.5,
 CellID->1551749101,ExpressionUUID->"397f7ffd-79ac-4744-9854-529355f2a46e"],

Cell[TextData[{
 StyleBox["Figure 4",
  FontWeight->"Bold"],
 ". An implementation of a 4-control unitary gate, where the special unitary \
operators ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "2d4b7383-ba1b-42f6-83e2-b29a12a9190d"],
 ", ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "7e1a2812-fa2b-47c7-9ae5-77c1eaa03ee1"],
 ", and ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "5cc6ae83-09c5-4926-82c8-e719a7a7bbac"],
 " satisfy ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]], "A", " ", "X", " ", "B", " ",
      "X", " ", "C"}]}], TraditionalForm]],ExpressionUUID->
  "4f90bf79-5e88-426b-aa8b-2f87b7a193d6"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", " ", "B", " ", "C"}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"edc50282-ae9f-41bb-9a02-9ce15e0c4038"],
 ". The circuit element with label \[OpenCurlyQuote]\[Phi]\[CloseCurlyQuote] \
denotes the relative phase gate by \[Phi]. If ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "278c0f74-d26a-4420-93fa-8986d81498db"],
 " itself is a special unitary operator (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"det", " ", "U"}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "56066d34-be24-41c9-8f64-a2eaa3224a5b"],
 "), then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "=", "0"}], TraditionalForm]],ExpressionUUID->
  "be35a8a3-c6a9-4697-8a1c-bb2848d6bd59"],
 ", and the cost is linear, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"44473b5b-e082-4ff7-be22-01d332bf4eee"],
 ", in the number ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "bd1d6b58-ff3f-4472-9c44-a17a50bcedfd"],
 " of the qubits."
}], "TechNoteCaption",
 CellID->1205731339,ExpressionUUID->"e5532a00-df94-4bfd-824b-7a063deff8e1"]
}, Open  ]],

