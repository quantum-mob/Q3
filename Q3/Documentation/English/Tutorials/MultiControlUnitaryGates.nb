Cell[TextData[{
 StyleBox["Figure 3",
  FontWeight->"Bold"],
 ". An implementation of a 4-control unitary gate, where ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "6cc8f5bd-c4ff-4497-bca5-7d8b943f79af"],
 " is the unitary operator satisfying ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", " ", 
    SuperscriptBox["V", "2"]}], TraditionalForm]],ExpressionUUID->
  "e5f7d6b6-2645-4748-b50a-c09c0053bffd"],
 "."
}], "TechNoteCaption",
 CellID->645696577,ExpressionUUID->"cb617b7e-920e-49e3-81ef-87267c2425f2"],

Cell[TextData[{
 "\tThe second method, illustrated in Figure 4, is a generalization of the \
idea for the implementation of a ",
 ButtonBox["controlled-unitary gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/TwoQubitGates#1847739219"],
 ". Recall that one can always find three special unitary operators ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "6d16839c-ffd3-49a0-9c45-4d4cbd503ecf"],
 ", ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "c675197c-7227-4ddf-b0ba-d5c4f3471cd0"],
 ", ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]],ExpressionUUID->
  "d3bb9349-3f7c-42be-882c-f022b7400205"],
 " and a global phase \[Phi] such that"
}], "TechNoteText",
 CellID->121635178,ExpressionUUID->"7b5d490e-4a4e-451b-b607-c81a449b368f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]], "A", " ", "X", " ", "B", " ",
      "X", " ", "C"}]}], TraditionalForm]],ExpressionUUID->
  "601752ba-731e-4a2f-a5fa-b49e0f6a10fe"],
 " ,"
}], "TechNoteText",
 CellID->490470210,ExpressionUUID->"2fb47c2a-19c6-43a2-a5e6-805e15599c6e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"A", " ", "B", " ", "C"}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"3527b042-cd43-4e1b-b0fa-3314b5fd48e2"],
 " ."
}], "TechNoteText",
 CellID->1434352982,ExpressionUUID->"e0a25752-fcda-4608-b91a-8d378e64ec64"],

Cell[TextData[{
 "A brief inspection asserts that the quantum circuit on the right-hand side \
of Figure 4 reproduces the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "d7f32e3f-dbf1-405c-bc54-4b6069116e3f"],
 "-control ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "99d48e34-a332-44b2-a765-5d845dfc8332"],
 " gate on the left-hand side."
}], "TechNoteText",
 CellID->1751656874,ExpressionUUID->"a548768d-adc1-40e8-90b8-71fa9f8b5360"],

Cell[TextData[{
 "\tIn this method, each of the two ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"n", "\[Minus]", "1"}], ")"}], TraditionalForm]],ExpressionUUID->
  "b026dac4-6dc9-40b9-a3f1-7e5e1cbdc9dc"],
 "-control NOT gates costs ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"9ba19431-abb3-4161-aefd-c9eb20176153"],
 " elementary gates. However, one still needs to recursively implement the (n \
\[Minus] 1)-control phase gate with phase angle \[Phi]. Therefore, the \
computational cost of this method is of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", 
    SuperscriptBox["n", "2"], ")"}], TraditionalForm]],ExpressionUUID->
  "1293c3c4-6204-4ae6-8816-a768603ed7ea"],
 " as well. One noteworthy fact is that the global phase \[Phi] of ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "b2e3a955-b55d-40f1-a1e6-1b3b3260cc8c"],
 " vanishes if ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "45faea71-06a4-4e78-8eb3-2bb3cd7ce0ef"],
 " is a special unitary operator (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"det", " ", "U"}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "d0ad925c-2d89-42ae-90be-71b41ab96fb5"],
 "). This implies that a multi-control unitary gate for a special unitary \
operator requires only ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalO]", "(", "n", ")"}], TraditionalForm]],
  ExpressionUUID->"503c01ca-133d-4535-88a8-02cd4fff670e"],
 " elementary gates; that is, the computational cost is linear."
}], "TechNoteText",
 CellID->1328942850,ExpressionUUID->"78049ace-4fe4-43ce-a300-abe879d13925"],

Cell[TextData[{
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {2, -1}}, {{0, -2}, {2, -2}}, {{0, -3}, {2, -3}}, {{
     0, -4}, {2, -4}}, {{0, -5}, {2, -5}}}], {
     LineBox[{{1, -1}, {1, -2}, {1, -3}, {1, -4}, {1, -5}}], 
     DiskBox[{1, -1}, 0.09], DiskBox[{1, -2}, 0.09], DiskBox[{1, -3}, 0.09], 
     DiskBox[{1, -4}, 0.09], {CircleBox[{1, -5}, 0.26666666666666666], 
      LineBox[{{{0.7333333333333334, -5}, {1.2666666666666666`, -5}}, {{
         1, -5.266666666666667}, {1, -4.733333333333333}}}]}}},
