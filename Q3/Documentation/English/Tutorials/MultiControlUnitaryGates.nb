Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ". An implementation of a three-control unitary gate based on the Gray-code \
method (Barenco et al., 1995)."
}], "TechNoteCaption",
 CellID->1686020851,ExpressionUUID->"d0bf18da-25d6-4cb9-a89c-542820681037"],

Cell[TextData[{
 "\tIn general, an ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b28d30c6-0fbe-4dd6-aa03-f0c1ad47b9d0"],
 "-control unitary gate can be implemented by combining ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "031a873c-9e49-49b7-a900-da5b58e71000"],
 " controlled-",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "285eadc0-ead6-444b-a315-23a0d0c25f73"],
 " gates, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["2", 
      RowBox[{"n", "-", "1"}]], "-", "1"}], ")"}], TraditionalForm]],
  ExpressionUUID->"7608de78-64e7-413c-bd38-c20249de8a50"],
 " controlled-",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["V", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "6136a30c-64b9-4e0c-8c67-123213760b06"],
 " gates, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox["2", "n"], "-", "2"}], ")"}], TraditionalForm]],
  ExpressionUUID->"6dbed6d9-de9e-488b-8a42-ddef63664d03"],
 " CNOT gates, where ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "883d49d0-33ab-4227-b963-17667cd12473"],
 " is a unitary operator satisfying ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["V", 
     SuperscriptBox["2", 
      RowBox[{"n", "-", "1"}]]], "=", "U"}], TraditionalForm]],ExpressionUUID->
  "258b8986-14c1-46c9-bd10-60936932f516"],
 ". For a relatively small ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b486d27b-e0f7-4fd3-9605-ad6e4032dc05"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[LessEqual]", "8"}], TraditionalForm]],ExpressionUUID->
  "8e83243e-f550-4c46-aa02-68af00714361"],
 "), the Gray-code method is known to be the most efficient method. However, \
it grows exponentially and eventually becomes impractical. Fortunately, there \
are alternative methods to overcome this exponential cost as discussed in the \
next section."
}], "TechNoteText",
 CellID->937732717,ExpressionUUID->"7645f138-64a1-4b81-bae2-684ac8307036"],

Cell[CellGroupData[{

Cell["Example", "Subsection",
 CellID->434566508,ExpressionUUID->"c803c259-b05c-4dd6-9cf3-e43463507094"],

Cell["Let us consider a 3-control unitary gate.", "TechNoteText",
 CellID->91289286,ExpressionUUID->"549aab9f-19ba-4d0b-b89e-dc10745c6713"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[476]:=",
 CellID->1410849737,ExpressionUUID->"9c9a5f93-7f36-4be9-8e73-86b9457773fb"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[477]:=",
 CellID->1972813118,ExpressionUUID->"a378611b-05cf-4058-9a21-ef5bb12cbe30"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$L", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"jj", "=", 
   RowBox[{"Range", "[", "$L", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cc", "=", 
   RowBox[{"S", "[", 
    RowBox[{"jj", ",", "None"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[478]:=",
 CellID->947038696,ExpressionUUID->"2c1b98e3-eaa0-4a90-bdc9-6cb204c08bc2"],

Cell["This is the gate to operate on the target qubit.", "TechNoteText",
 CellID->995705844,ExpressionUUID->"50bf7ace-768e-4708-8785-6bbe2337f828"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"T", "=", 
   RowBox[{"S", "[", 
    RowBox[{
     RowBox[{"$L", "+", "1"}], ",", "None"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"op", "=", 
  RowBox[{
   RowBox[{"Rotation", "[", 
    RowBox[{
     RowBox[{"Pi", "/", "3"}], ",", 
     RowBox[{"T", "[", "1", "]"}]}], "]"}], "//", "Elaborate"}]}]}], "Input",
 CellLabel->"In[481]:=",
 CellID->1878055755,ExpressionUUID->"14702382-d127-4dad-aecf-a1d53d3621a1"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   SqrtBox["3"], "2"], "-", 
  RowBox[{
   FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{"S", 
      TemplateBox[{",", "\",\"", "4"}, "RowWithSeparators"], 
      TemplateBox[{",", "\",\"", "\"X\""}, "RowWithSeparators"]},
     "Subsuperscript"],
    $CellContext`S[4, 1]]}]}]], "Output",
 CellLabel->"Out[482]=",
 CellID->505194797,ExpressionUUID->"774507ba-2d40-40b2-816a-44188445d42d"]
}, Open  ]],

Cell["\<\
This decomposes the multi-control unitary gate based on the Gray code -- \
showing only a part of it. Each component is either CNOT or a \
two-qubit-control unitary gate.\
\>", "TechNoteText",
 CellID->775208388,ExpressionUUID->"3c921a24-4ebb-45be-8f6e-d26f542166bb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"gc", "=", 
   RowBox[{"GrayControlledGate", "[", 
    RowBox[{"cc", ",", "op"}], "]"}]}], ";", " ", 
  RowBox[{"gc", "[", 
   RowBox[{"[", 
    RowBox[{";;", "3"}], "]"}], "]"}]}]], "Input",
 CellLabel->"In[483]:=",
 CellID->1697248997,ExpressionUUID->"2d9214ea-eb4f-4d4f-9c20-3d7a38d0df7c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"ControlledGate", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       InterpretationBox[
        SubscriptBox["S", 
         TemplateBox[{",", "\",\"", "1"},
          "RowWithSeparators"]],
        $CellContext`S[1, QuantumMob`Q3`$]], "\[Rule]", "1"}], "}"}], ",", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{
         SuperscriptBox["2", 
          RowBox[{"1", "/", "4"}]], " ", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"-", 
           FractionBox[
            RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "24"]}]]}], "+", 
        RowBox[{
         SuperscriptBox["2", 
          RowBox[{"1", "/", "4"}]], " ", 
         SuperscriptBox["\[ExponentialE]", 
          FractionBox[
           RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "24"]]}]}], 
       RowBox[{"2", " ", 
        SuperscriptBox["2", 
         RowBox[{"1", "/", "4"}]]}]], "+", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["2", 
            RowBox[{"1", "/", "4"}]], " ", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"-", 
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "24"]}]]}], "-", 
          RowBox[{
           SuperscriptBox["2", 
            RowBox[{"1", "/", "4"}]], " ", 
           SuperscriptBox["\[ExponentialE]", 
            FractionBox[
             RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "24"]]}]}], ")"}], " ", 
        
        InterpretationBox[
         TemplateBox[{"S", 
           TemplateBox[{",", "\",\"", "4"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"+\""}, "RowWithSeparators"]},
          "Subsuperscript"],
         $CellContext`S[4, 4]]}], 
       RowBox[{"2", " ", 
        SuperscriptBox["2", 
         RowBox[{"1", "/", "4"}]]}]], "+", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["2", 
            RowBox[{"1", "/", "4"}]], " ", 
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"-", 
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "24"]}]]}], "-", 
          RowBox[{
           SuperscriptBox["2", 
            RowBox[{"1", "/", "4"}]], " ", 
           SuperscriptBox["\[ExponentialE]", 
            FractionBox[
             RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "24"]]}]}], ")"}], " ", 
        
        InterpretationBox[
         TemplateBox[{"S", 
           TemplateBox[{",", "\",\"", "4"}, "RowWithSeparators"], 
           TemplateBox[{",", "\",\"", "\"-\""}, "RowWithSeparators"]},
          "Subsuperscript"],
         $CellContext`S[4, 5]]}], 
       RowBox[{"2", " ", 
        SuperscriptBox["2", 
         RowBox[{"1", "/", "4"}]]}]]}], ",", 
     RowBox[{"\<\"Label\"\>", "\[Rule]", "\<\"V\"\>"}]}], "]"}], ",", 
   RowBox[{"CNOT", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       InterpretationBox[
        SubscriptBox["S", 
         TemplateBox[{",", "\",\"", "1"},
          "RowWithSeparators"]],
        $CellContext`S[1, QuantumMob`Q3`$]], "\[Rule]", "1"}], "}"}], ",", 
     RowBox[{"{", 
      InterpretationBox[
       SubscriptBox["S", 
        TemplateBox[{",", "\",\"", "2"},
         "RowWithSeparators"]],
       $CellContext`S[2, QuantumMob`Q3`$]], "}"}]}], "]"}], ",", 
   RowBox[{"ControlledGate", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       InterpretationBox[
        SubscriptBox["S", 
         TemplateBox[{",", "\",\"", "2"},
          "RowWithSeparators"]],
