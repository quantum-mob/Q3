Cell["\<\
To make the physical meaning underlying the quantum Fourier transform \
clearer, in this document, we use a slightly different notation for the \
computational basis states, and denote them by\
\>", "TechNoteText",
 CellID->644227576,ExpressionUUID->"47fdd9c7-098e-4e15-a18a-6b1da93e42ca"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["X", "x"]},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["x", "1"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["x", "2"]},
      "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["x", "n"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "fa6c929b-dacb-4870-af95-a2ef9eb2d4a6"]
}], "TechNoteText",
 CellID->2067805305,ExpressionUUID->"62a0dfee-f7ca-43a4-a6fa-2984faf4c82b"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{
     SuperscriptBox["2", "n"], "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "5241457a-f82a-4d2c-8e3c-dcf710b4a5a9"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "k"], TraditionalForm]],ExpressionUUID->
  "ce260ddc-a078-4c08-804d-3a0e250b4e86"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", "n"}], 
   TraditionalForm]],ExpressionUUID->"558eb5d7-4fb5-45dd-896d-8409c7ac38c3"],
 " are the binary digits of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], 
       SubscriptBox["x", "2"], 
       SubscriptBox["\[CenterEllipsis]x", "n"]}], ")"}], "2"]}], 
   TraditionalForm]],ExpressionUUID->"b7cde151-cf1c-43ee-9429-2246425e616a"],
 "."
}], "TechNoteText",
 CellID->875901734,ExpressionUUID->"2ced5fe9-d3d6-40a4-be52-fdf735907824"],

Cell["\<\
\tThe quantum Fourier transform, QFT for short, is a unitary transformation \
defined by the association\
\>", "TechNoteText",
 CellID->280043153,ExpressionUUID->"8ff67030-83dc-4a11-80a6-c7467427d471"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "QFT"], 
     TemplateBox[{
       SubscriptBox["X", "y"]},
      "Ket"]}], ":=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"x", "=", "0"}], 
       RowBox[{
        SuperscriptBox["2", "n"], "-", "1"}]], 
      RowBox[{
       TemplateBox[{
         SubscriptBox["X", "x"]},
        "Ket"], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"\[ImaginaryI]", " ", "x", " ", 
         SubscriptBox["p", "y"]}]]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "63f6cfb6-6aba-4bf5-8191-b425b5654a61"]
}], "TechNoteText",
 CellID->1548601894,ExpressionUUID->"a0bc85ab-9564-4ed0-8118-3a7a12e787ba"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"y", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{
     SuperscriptBox["2", "n"], "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "b780ff16-0332-4a8d-aa7f-ef543ec7a157"],
 ", where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "y"], TraditionalForm]],ExpressionUUID->
  "da5dd07d-29f3-465c-89b2-9a5b2dd96e22"],
 " is the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["y", "th"], TraditionalForm]],ExpressionUUID->
  "88404137-18e5-4404-8013-38f0b5f85409"],
 " \[OpenCurlyDoubleQuote]wave number\[CloseCurlyDoubleQuote] defined by"
}], "TechNoteText",
 CellID->1997714465,ExpressionUUID->"e038af1c-2463-4793-83a7-c32f081d2cb7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "y"], ":=", 
    RowBox[{
     FractionBox[
      RowBox[{"2", "\[Pi]", " ", "y"}], 
      SuperscriptBox["2", "n"]], "=", 
     RowBox[{"2", 
      SubscriptBox[
       RowBox[{"\[Pi]", "(", 
        RowBox[{"0.", 
         SubscriptBox["y", "1"], 
         SubscriptBox["y", "2"], 
         SubscriptBox["\[CenterEllipsis]y", "n"]}], ")"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"c8cbf0b4-8795-459a-a76e-45b557949055"],
 "."
}], "TechNoteText",
 CellID->1827676057,ExpressionUUID->"4480c4e9-b612-420d-8237-3fbdc6ddbeb7"],

Cell[TextData[{
 "Like ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "k"], TraditionalForm]],ExpressionUUID->
  "42a34374-b2d2-4c6f-85da-804a515b0ba5"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "k"], TraditionalForm]],ExpressionUUID->
  "6b14bf18-a251-472a-a2ac-0ff8d763b11e"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", "n"}], 
   TraditionalForm]],ExpressionUUID->"e108cfc8-85cf-403f-84b4-c02e28c947ef"],
 " are the binary digits of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["y", "1"], 
       SubscriptBox["y", "2"], 
       SubscriptBox["\[CenterEllipsis]y", "n"]}], ")"}], "2"]}], 
   TraditionalForm]],ExpressionUUID->"e0a10f8a-b00c-48ed-983c-38d22a8e1e6d"],
 "."
}], "TechNoteText",
 CellID->145403311,ExpressionUUID->"ab225344-eea2-46f3-8196-9d7861890b9f"],

Cell[TextData[{
 "\tThe expression on the right-hand side of the above definition is of a \
familiar form of the ",
 StyleBox["discrete Fourier transform",
  FontSlant->"Italic"],
 " except that instead of numerical coefficients for the exponential factor \
",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "x", " ", 
     SubscriptBox["p", "y"]}]], TraditionalForm]],ExpressionUUID->
  "d2cae21e-4479-4105-8bda-b2008f4ba60e"],
 ", there appear state vectors. Therefore, one may think of the quantum \
Fourier transform as a ",
 StyleBox["vector-valued",
  FontSlant->"Italic"],
 " discrete Fourier transformation."
}], "TechNoteText",
 CellID->2104541338,ExpressionUUID->"b9926655-8e87-4bae-9983-ec33794fb86d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Physical Meaning", "TechNoteSection",
 CellID->1970601676,ExpressionUUID->"fcef6abb-28f4-45fa-bf3a-81cd1cb0ee5f"],

Cell["\<\
In many physical applications, there is a more important aspect of the \
quantum Fourier transform than its formal similarity to the discrete Fourier \
transform. It is useful and inspiring to regard the QFT as a basis change, a \
unitary transformation from the computational basis\
\>", "TechNoteText",
 CellID->1409564498,ExpressionUUID->"298233cf-96c7-4300-8433-2c5c8ea58d78"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["X", "x"]},
        "Ket"], ":", "x"}], "=", "0"}], ",", "1", ",", "2", ",", 
     "\[Ellipsis]", ",", 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"a5db1bd1-f827-487f-a979-a28bca0b821c"]
}], "TechNoteText",
 CellID->1658407829,ExpressionUUID->"e4de0b81-0ed8-4c99-9252-b55f2c3a2711"],

Cell["to the so-called \[OpenCurlyDoubleQuote]conjugate basis\
\[CloseCurlyDoubleQuote]", "TechNoteText",
 CellID->670127590,ExpressionUUID->"1cbe7efc-4554-4162-bfab-cd384c447931"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        SubscriptBox["P", "y"]},
       "Ket"], ":=", 
      RowBox[{
       RowBox[{
        SubscriptBox["U", "QFT"], 
        RowBox[{
         TemplateBox[{
           SubscriptBox["X", "y"]},
          "Ket"], ":", "y"}]}], "=", "0"}]}], ",", "1", ",", "2", ",", 
     "\[Ellipsis]", ",", 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"b6951da1-6711-45b0-87fa-db4ff4718c95"],
 "."
}], "TechNoteText",
 CellID->1430160262,ExpressionUUID->"5dd6ccdb-bafc-465a-9816-b7bfebcc6081"],

Cell[TextData[{
 "\tThe key observation is that in the \[OpenCurlyDoubleQuote]continuum\
\[CloseCurlyDoubleQuote] limit (",
 Cell[BoxData[
  FormBox[
   RowBox[{"L", " ", ":=", " ", 
    RowBox[{
     SuperscriptBox["2", "n"], "\[RightArrow]", " ", "\[Infinity]"}]}], 
   TraditionalForm]],ExpressionUUID->"e1150be8-d6ad-4953-ad1f-a18928ee6588"],
 "), the computational basis corresponds to the eigenbasis of the \
\[OpenCurlyDoubleQuote]position\[CloseCurlyDoubleQuote] and the conjugate \
basis to that of the \[OpenCurlyDoubleQuote]momentum\[CloseCurlyDoubleQuote]. \
Indeed, one can see that the two observables"
}], "TechNoteText",
 CellID->2066546210,ExpressionUUID->"056dc85c-e043-4d50-b706-d77008599eac"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", ":=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "x"], 
     TemplateBox[{
       SubscriptBox["X", "x"]},
      "Ket"], "x", 
     TemplateBox[{
       SubscriptBox["X", "x"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "f352dbef-f462-49b6-865e-9678e6faddd5"],
 "     and     ",
 Cell[BoxData[
  FormBox[
   RowBox[{"P", ":=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "y"], 
     TemplateBox[{
       SubscriptBox["P", "y"]},
      "Ket"], 
     SubscriptBox["p", "y"], 
     TemplateBox[{
       SubscriptBox["P", "y"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "9affaf84-fcc4-4dba-a90b-835920032cdc"]
}], "TechNoteText",
 CellID->1189128539,ExpressionUUID->"8a00b9a1-c2a7-4a4f-ba94-48614d686f5f"],

Cell[TextData[{
 "bearing eigenvalues ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "2ca9cbf5-7b65-4e63-a948-fef50fd5bd9e"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "y"], TraditionalForm]],ExpressionUUID->
  "2a4d6d36-2482-404d-82d4-131c137a721f"],
 ", respectively, satisfy the relation"
}], "TechNoteText",
 CellID->1200535991,ExpressionUUID->"c8c6ec61-ad06-4553-b6ce-ea432fbc0eec"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], " ", "a", " ", "P"}]], "X", " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"+", "\[ImaginaryI]"}], " ", "a", " ", "P"}]]}], "=", 
    RowBox[{"X", " ", "-", " ", 
     RowBox[{"a", " ", "I"}]}]}], TraditionalForm]],ExpressionUUID->
  "3a8b877b-51b9-4b1c-a9ab-5cdc63e78ff0"],
 "."
}], "TechNoteText",
 CellID->1799537172,ExpressionUUID->"d6eb1b18-f6fc-41a4-9ac4-97e1818d202b"],

Cell[TextData[{
 "This implies that ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "a", " ", "P"}]], TraditionalForm]],
  ExpressionUUID->"aee4c056-8440-4d26-9afc-3f88bbbe0a34"],
 "is a translation operator, and ",
 Cell[BoxData[
  FormBox["P", TraditionalForm]],ExpressionUUID->
  "8e573b9f-c920-4c7f-8e02-21b11a8fc0b0"],
 " is the generator of the translation, i.e., the momentum."
}], "TechNoteText",
 CellID->1809049103,ExpressionUUID->"92ab2fa6-d0ce-4b2b-96fd-51df305e44cb"],

Cell[TextData[{
 "\tThis notion can be made rigorous even in a finite-dimensional Hilbert \
space using the unitary operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{"exp", "(", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "p", " ", "X"}], ")"}], 
   TraditionalForm]],ExpressionUUID->"1418c909-442a-4496-aa9d-8caf35ae9cbd"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"exp", "(", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], " ", "a", " ", "P"}], ")"}], 
   TraditionalForm]],ExpressionUUID->"efd1c988-47ab-49dd-ae4c-a7b981d70463"],
 ", which generate the so-called ",
 StyleBox["Weyl-Heisenberg group",
  FontSlant->"Italic"],
 ";  see Weyl (1931, Section IV.14) for example."
}], "TechNoteText",
 CellID->614799895,ExpressionUUID->"5472471d-4d7d-402a-8b66-6490cf305cff"],

Cell["\<\
\tThe quantum Fourier transform appears frequently in many quantum algorithms \
(notably the quantum phase estimation algorithm), in an explicit or disguised \
form. The relation between the computational and conjugate basis defined \
above is useful to understand the principle behind the particular algorithms.\
\
\>", "TechNoteText",
 CellID->1398009548,ExpressionUUID->"3fd094e2-9246-4bb0-b9b1-a3bb0c45e86c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum Implementation", "TechNoteSection",
 CellID->727891409,ExpressionUUID->"4f8583f9-7589-45e4-a2ab-e4b9e7603381"],

Cell[TextData[{
 "The quantum Fourier transform algorithm is to efficiently implement the \
unitary operator ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "QFT"], TraditionalForm]],ExpressionUUID->
  "122dd840-6dc9-4c13-8d55-aefdd11a588c"],
 " in terms of the elementary gates. Getting back to the definition, the \
quantum Fourier transform maps the quantum states by"
}], "TechNoteText",
 CellID->2036400266,ExpressionUUID->"a227b60c-6ae4-4c0d-a880-d6becefe36b6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "QFT"], 
     TemplateBox[{
       SubscriptBox["X", "y"]},
      "Ket"]}], ":=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     TemplateBox[{
       SubscriptBox["X", "x"]},
      "Ket"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "x", " ", 
       SubscriptBox["p", "y"]}]]}]}], TraditionalForm]],ExpressionUUID->
  "94a66eb0-40a9-48d4-bd3b-1f033de5761e"]
}], "TechNoteText",
 CellID->1332388423,ExpressionUUID->"353faf45-0293-48c6-89dd-e43b32eeedd7"],

Cell["with wave number", "TechNoteText",
 CellID->1640238092,ExpressionUUID->"0d2ebc2c-9593-4c4e-880b-de623855eefc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "y"], ":=", 
    FractionBox[
     RowBox[{"2", "\[Pi]", " ", "y"}], 
     SuperscriptBox["2", "n"]]}], TraditionalForm]],ExpressionUUID->
  "f7ac6939-b19e-4613-8767-11ccd7036cf5"]
}], "TechNoteText",
 CellID->234035705,ExpressionUUID->"109b2a8b-a15e-4992-9096-f12bdbf25921"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"y", "=", "0"}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{
     SuperscriptBox["2", "n"], "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "11dee0a4-d048-45b2-bdf5-4fd43a600719"],
 "."
}], "TechNoteText",
 CellID->1395536278,ExpressionUUID->"8cd6177c-b485-4948-8e6f-e7210b1a23f8"],

Cell[TextData[{
 "\tSince the characteristic properties of the Fourier transform of any kind \
are attributed to an oscillatory phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", "x", " ", 
     SubscriptBox["p", "y"]}]], TraditionalForm]],ExpressionUUID->
  "516f834d-d123-4633-abf6-a664c0f722c3"],
 ", we start by elaborating it. The product ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", " ", 
    SubscriptBox["p", "y"]}], TraditionalForm]],ExpressionUUID->
  "a4054112-7957-4307-9680-86e2cb004b5e"],
 " in the exponent is given by"
}], "TechNoteText",
 CellID->2109315459,ExpressionUUID->"3867da1d-d797-410d-b7ef-801716102773"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", " ", 
     SubscriptBox["p", "y"]}], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"2", "\[Pi]", " ", "x", " ", "y"}], 
      SuperscriptBox["2", "n"]], "=", 
     RowBox[{
      RowBox[{"2", 
       SubscriptBox[
        RowBox[{"\[Pi]", "(", 
         RowBox[{"0.", 
          SubscriptBox["x", "1"], 
          SubscriptBox["x", "2"], 
          SubscriptBox["\[CenterEllipsis]x", "n"]}], ")"}], "2"], "y"}], "=", 
      
      RowBox[{"2", "\[Pi]", " ", "y", 
       RowBox[{
        UnderoverscriptBox["\[CapitalSigma]", 
         RowBox[{"k", "=", "1"}], "n"], 
        RowBox[{
         SubscriptBox["x", "k"], 
         SuperscriptBox["2", 
          RowBox[{"-", "k"}]]}]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "96d74826-ab38-4310-81d3-fe1d5a413d2d"],
 ","
}], "TechNoteText",
 CellID->604874737,ExpressionUUID->"12756bdc-5d42-4d8b-8975-eec0de6a0295"],

Cell["which recasts the phase factor into the form", "TechNoteText",
 CellID->2089603508,ExpressionUUID->"f9b33167-af69-42eb-a314-de4522bfffd2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"exp", "(", 
     RowBox[{"\[ImaginaryI]", " ", "x", " ", 
      SubscriptBox["p", "y"]}], ")"}], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{" ", 
       RowBox[{"k", "=", "1"}]}], 
      RowBox[{" ", "n"}]], 
     RowBox[{"exp", "(", 
      RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", "y", " ", 
       SubscriptBox["x", "k"], 
       SuperscriptBox["2", 
        RowBox[{"-", "k"}]]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "e9215dfc-2cd7-4ddf-a102-407c9730c3fb"],
 "."
}], "TechNoteText",
 CellID->1128739665,ExpressionUUID->"6f1d8e3a-7569-4941-aad7-125bf419eba3"],

Cell[TextData[{
 "We put it back in the defining expression of quantum Fourier transform in \
the above, and rewrite the sum over ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "e61b8ddb-7af7-4649-ba64-11b8178a0f72"],
 " with the sum over bit values ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "k"], "\[Element]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "1"}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "9474ecd4-4409-4ab3-9907-22547a46a127"],
 ", which lead to"
}], "TechNoteText",
 CellID->1156465011,ExpressionUUID->"0641ceff-196b-4544-b918-b4061bb0841f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "QFT"], 
     TemplateBox[{
       SubscriptBox["X", "y"]},
      "Ket"]}], "=", 
    RowBox[{
     UnderoverscriptBox[
      RowBox[{" ", 
       RowBox[{"\[CircleTimes]", " "}]}], 
      RowBox[{"k", "=", "1"}], "n"], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["x", "k"], "=", "0", ",", "1"}]], 
     TemplateBox[{
       SubscriptBox["x", "k"]},
      "Ket"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", 
       SubscriptBox["x", "k"], 
       RowBox[{"y", "/", 
        SuperscriptBox["2", "k"]}]}]]}]}], TraditionalForm]],ExpressionUUID->
  "0168c24a-e64f-4386-a64d-d94f4dadbc70"],
 "."
}], "TechNoteText",
 CellID->1980434527,ExpressionUUID->"ea6ee35a-d140-43e1-8343-1d4f83f5d914"],

Cell[TextData[{
 "For a fixed ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "f1eb9005-22d8-4e1b-90b4-5cefd2396aec"],
 ", the ratio ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "/", 
    SuperscriptBox["2", "k"]}], TraditionalForm]],ExpressionUUID->
  "4216efcc-3979-4d97-b7cd-8cc50082f7dc"],
 " is represented in binary digits as"
}], "TechNoteText",
 CellID->1314050436,ExpressionUUID->"68b88c47-d034-4021-b3e2-c129f39d1634"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"y", "/", 
     SuperscriptBox["2", "k"]}], "=", 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["y", "1"], 
       SubscriptBox["y", "2"], 
       RowBox[{
        SubscriptBox["\[CenterEllipsis]y", 
         RowBox[{"n", "-", "k"}]], ".", 
        SubscriptBox["y", 
         RowBox[{"n", "-", "k", "+", "1"}]]}], 
       SubscriptBox["\[CenterEllipsis]y", 
        RowBox[{"n", "-", "1"}]], 
       SubscriptBox["y", "n"]}], ")"}], "2"]}], TraditionalForm]],
  ExpressionUUID->"ae758186-a032-4fc0-94af-0c7d7269bc97"],
 "."
}], "TechNoteText",
 CellID->523852104,ExpressionUUID->"b7511cd8-2330-4b5b-96c7-25d6970a1a0b"],

Cell[TextData[{
 "The integer part does not affect the sum because ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", "m"}]], "=", "1"}], 
   TraditionalForm]],ExpressionUUID->"19b7a8ca-105e-4b39-8c81-a2815e282202"],
 " for any integer ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "9bc75819-2b60-4b0c-b338-786b9aa3ed32"],
 "; only the fractional part ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{"0.", 
      SubscriptBox["y", 
       RowBox[{"n", "-", "k", "+", "1"}]], 
      SubscriptBox["\[CenterEllipsis]y", "n"]}], ")"}], "2"], 
   TraditionalForm]],ExpressionUUID->"b89db1f6-e8a1-48ea-a2eb-ed7b4056068c"],
 " does. Depriving the phase factors ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[ImaginaryI]", " ", 
     SubscriptBox["x", "k"], 
     SubscriptBox["p", "y"]}]], TraditionalForm]],ExpressionUUID->
  "12448df1-2f7b-4b65-a604-1091fed09560"],
 " of the integer parts, we arrive at the expression for the result of the \
transformation"
}], "TechNoteText",
 CellID->1846842875,ExpressionUUID->"b7c6289d-bf7a-496a-a97b-77e89e1b1fc0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "QFT"], 
     TemplateBox[{
       SubscriptBox["X", "y"]},
      "Ket"]}], "=", 
    RowBox[{
     UnderoverscriptBox[
      RowBox[{" ", 
       RowBox[{"\[CircleTimes]", " "}]}], 
      RowBox[{"k", "=", "1"}], "n"], 
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{
       SubscriptBox["x", "k"], "=", "0", ",", "1"}]], 
     TemplateBox[{
       SubscriptBox["x", "k"]},
      "Ket"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", 
       SubscriptBox[
        RowBox[{
         SubscriptBox["x", "k"], "(", 
         RowBox[{"0.", 
          SubscriptBox["y", 
           RowBox[{"n", "-", "k", "+", "1"}]], 
          SubscriptBox["\[CenterEllipsis]y", 
           RowBox[{"n", "-", "1"}]], 
          SubscriptBox["y", "n"]}], ")"}], "2"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"e7882a04-5274-450a-9a68-90c03339c92b"],
 "."
}], "TechNoteText",
 CellID->159566387,ExpressionUUID->"7533b521-618f-4d65-afd0-8ac291f09474"],

Cell[TextData[{
 "Explicitly writing the sums over bit values ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "k"], TraditionalForm]],ExpressionUUID->
  "6fe497c4-9a4b-4934-8f7d-da585226a96b"],
 ", it reads as"
}], "TechNoteText",
 CellID->1772674853,ExpressionUUID->"51d89fcb-b079-49ec-9831-25581a852b10"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "QFT"], 
     TemplateBox[{
       SubscriptBox["X", "y"]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "+", 
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", "0.", 
           SubscriptBox["y", "n"]}]]}]}], 
       SqrtBox["2"]], ")"}], "\[CircleTimes]", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "+", 
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", "0.", 
           SubscriptBox["y", 
            RowBox[{"n", "-", "1"}]], 
           SubscriptBox["y", "n"]}]]}]}], 
       SqrtBox["2"]], ")"}], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "+", 
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", "0.", 
           SubscriptBox["y", "1"], 
           SubscriptBox["y", "2"], 
           SubscriptBox["\[CenterEllipsis]y", "n"]}]]}]}], 
       SqrtBox["2"]], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "db6c2fbf-fd9e-406c-a22b-487ae2863ed6"],
 "."
}], "TechNoteText",
 CellID->1305619540,ExpressionUUID->"5b441c5b-2cae-48f3-9c4a-cebbbb93716a"],

Cell[TextData[{
 "\tInterestingly, the state resulting from the quantum Fourier transform is \
clearly a product state. The first factor is stored in the first qubit of the \
quantum register, and consecutive factors are stored in the corresponding \
qubits in the same order. For later analysis, it is useful to reverse the \
order. This is equivalent to performing the ",
 StyleBox["quantum bit-reversal transform",
  FontSlant->"Italic"],
 " (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["QBR"]], "paclet:QuantumMob/Q3/ref/QBR", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4ff85dd3-c17e-4c33-9353-f2891b27743b"],
 ")"
}], "TechNoteText",
 CellID->559703734,ExpressionUUID->"e80351cf-193c-4dd2-93c4-27bdbc43adb5"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "QBR"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["y", "1"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["y", "2"]},
       "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["y", "n"]},
       "Ket"]}]}], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["y", "n"]},
      "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["y", "2"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["y", "1"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "edab946b-2190-4fa6-ae7e-e6ffd489fa00"],
 " ."
}], "TechNoteText",
 CellID->962283478,ExpressionUUID->"ec9be7d3-a341-40d8-bf4a-663f240d4397"],

Cell["\<\
Note that the quantum bit-reversal transform can be efficiently implemented \
by a sequence of SWAP gates as in Figure 1. Applying the quantum bit-reversal \
transform after the quantum Fourier transform, we arrive at the final \
expression that we analyze subsequently\
\>", "TechNoteText",
 CellID->399069189,ExpressionUUID->"c1b5935d-a72c-4c0c-8411-6051c2d129cd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "QBR"], 
     SubscriptBox["U", "QFT"], 
     TemplateBox[{
       SubscriptBox["X", "y"]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "+", 
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", "0.", 
           SubscriptBox["y", "1"], 
           SubscriptBox["y", "2"], 
           SubscriptBox["\[Ellipsis]y", "n"]}]]}]}], 
       SqrtBox["2"]], ")"}], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "+", 
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", "0.", 
           SubscriptBox["y", 
            RowBox[{"n", "-", "1"}]], 
           SubscriptBox["y", "n"]}]]}]}], 
       SqrtBox["2"]], ")"}], "\[CircleTimes]", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "+", 
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", "0.", 
           SubscriptBox["y", "n"]}]]}]}], 
       SqrtBox["2"]], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "9a3b5e3b-b64e-484d-a5ee-94505e009c99"],
 "."
}], "TechNoteText",
 CellID->564429942,ExpressionUUID->"3083bcb1-2b43-4bd7-bcf5-a1071cb678fe"],

