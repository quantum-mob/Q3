Cell["\<\
Another way to test the equivalence of the fully quantum and semiclassical \
implementation of the quantum Fourier transform is to randomly take an input \
state that ends up in a product state:\
\>", "TechNoteMathCaption",
 CellID->1323225536,ExpressionUUID->"9b4b25d0-e3b4-46c4-9450-7e8ab1074cd6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vecs", "=", 
   RowBox[{
    RowBox[{"FourierMatrix", "[", 
     RowBox[{
      RowBox[{"Power", "[", 
       RowBox[{"2", ",", "$n"}], "]"}], ",", 
      RowBox[{"FourierParameters", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"0", ",", 
         RowBox[{"-", "1"}]}], "}"}]}]}], "]"}], ".", 
    RowBox[{"Basis", "[", "SS", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"in", "=", 
  RowBox[{"RandomChoice", "[", "vecs", "]"}]}]}], "Input",
 CellLabel->"In[79]:=",
 CellID->1882411498,ExpressionUUID->"1df22eb0-3329-453a-8462-3b465d7d47b3"],

