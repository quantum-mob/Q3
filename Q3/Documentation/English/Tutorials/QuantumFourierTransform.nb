   "RowDefault"]],ExpressionUUID->"e24513c8-ca6c-4f02-a100-210fbef1c942"]
}], "Picture",
 CellID->1842836385,ExpressionUUID->"cd02456f-7f3d-4b2e-9d09-3c2a9f0d7e75"],

Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". An implementation of quantum bit-reversal transform (QBR)."
}], "TechNoteCaption",
 CellID->2022043910,ExpressionUUID->"97218a4c-b660-435c-83d5-a93146daccc0"],

Cell[TextData[{
 "\tSo far, we have done nothing but re-express the defining equation of the \
quantum Fourier transform. Now, we identify the elementary quantum logic \
gates that compose the transform. The product form in the above is remarkably \
simple to analyze. In particular, the state stored in the last qubit depends \
only on its own state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["y", "n"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "df69580d-8bfd-4285-8bd9-1c02d4372f45"],
 ", and the relative phase factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
     SubscriptBox[
      RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "(", 
       RowBox[{"0.", 
        SubscriptBox["y", "n"]}], ")"}], "2"]}]], TraditionalForm]],
  ExpressionUUID->"28852ad0-3391-4270-a4a4-e83df77be957"],
 " is equivalent to applying the Hadamard gate,"
}], "TechNoteText",
 CellID->938766395,ExpressionUUID->"fe7552b6-bb3b-4ac6-b054-0955008c4859"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
         SubscriptBox[
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "(", 
           RowBox[{"0.", 
            SubscriptBox["y", "n"]}], ")"}], "2"]}]]}]}], 
     SqrtBox["2"]], "=", 
    RowBox[{
     FractionBox[
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "+", 
       SuperscriptBox[
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], "(", 
         RowBox[{"-", "1"}], ")"}], 
        SubscriptBox["y", "n"]]}], 
      SqrtBox["2"]], "=", 
     RowBox[{"H", 
      TemplateBox[{
        SubscriptBox["y", "n"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "d0fe36a7-0d55-4d4e-b833-7b3c50ab0b7d"],
 " ."
}], "TechNoteText",
 CellID->149852799,ExpressionUUID->"5767dcc9-c2ec-4e85-b467-130068806ffe"],

Cell[TextData[{
 "The second last factor depends not only on the input state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["y", 
      RowBox[{"n", "-", "1"}]]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "25326aae-d4af-4991-900f-3e47ddb3d0f6"],
 " of the second last qubit but also on the last qubit. However, the phase \
factor ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
     SubscriptBox[
      RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "(", 
       RowBox[{"0.", 
        SubscriptBox["y", 
         RowBox[{"n", "-", "1"}]]}], ")"}], "2"]}]], TraditionalForm]],
  ExpressionUUID->"e2641309-c5db-44c8-bf51-20948554a02d"],
 "governed by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["y", 
      RowBox[{"n", "-", "1"}]]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "1d2c578a-796f-4fb7-99f6-3fc025ba7fc2"],
 " is again equivalent to the Hadamard gate. On the other hand, the \
additional phase factor ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
      SubscriptBox[
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "(", 
        RowBox[{"0.0", 
         SubscriptBox["y", "n"]}], ")"}], "2"]}]], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", 
        RowBox[{"\[Pi]", "/", 
         SuperscriptBox["2", "2"]}]}]], ")"}], 
     SubscriptBox["y", "n"]]}], TraditionalForm]],ExpressionUUID->
  "33c338f2-8521-4952-8cd6-63a5b2b70292"],
 "is equivalent to operating the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"controlled", "-", 
    SubscriptBox["Z", "2"]}], TraditionalForm]],ExpressionUUID->
  "9c58f861-cfc9-40f5-81a0-cceb47fc5906"],
 " gate, where"
}], "TechNoteText",
 CellID->1009795243,ExpressionUUID->"9b66f239-d0a5-4eb9-8c7c-96984a679691"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Z", "k"], ":=", 
    RowBox[{"(", GridBox[{
       {"1", "0"},
       {"0", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
          RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "/", 
           SuperscriptBox["2", "k"]}]}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "0d185b3b-de98-4514-94ef-bebf6a1e6d56"],
 " ,"
}], "TechNoteText",
 CellID->2134561191,ExpressionUUID->"838e8b49-7faf-45f6-9c3e-b4153cf1ac99"],

Cell[TextData[{
 "conditioned on the input state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["y", "n"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f6b8f960-149c-49e4-8e61-9f8cddd05ca4"],
 " of the last qubit. In short, the state stored in the second last qubit is \
given by"
}], "TechNoteText",
 CellID->857659199,ExpressionUUID->"2e4f69e8-7b35-4703-8213-ec59810cc876"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "+", 
       RowBox[{
        TemplateBox[{"1"},
         "Ket"], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", "\[Pi]", "\[VeryThinSpace]", 
          SubscriptBox[
           RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "(", 
            RowBox[{"0.", 
             SubscriptBox["y", 
              RowBox[{"n", "-", "1"}]], 
             SubscriptBox["y", "n"]}], ")"}], "2"]}]]}]}], 
      SqrtBox["2"]], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["y", "n"]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubsuperscriptBox["Z", "2", 
        SubscriptBox["y", "n"]], "H", 
       TemplateBox[{
         SubscriptBox["y", 
          RowBox[{"n", "-", "1"}]]},
        "Ket"]}], ")"}], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["y", "n"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "e519f5be-9b48-4ea9-ab31-942f73ae8c84"],
 " ."
}], "TechNoteText",
 CellID->523059180,ExpressionUUID->"fa2f3bdd-5919-4027-815c-8dd886315797"],

Cell[TextData[{
 "More generally, the state on the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "39eb83f8-01d3-4987-9934-29b913e49ad9"],
 " qubit"
}], "TechNoteText",
 CellID->692423820,ExpressionUUID->"f7ab9059-57f4-4b5a-8588-cc2abc3b682e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "+", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", "\[Pi]", " ", 
        SubscriptBox[
         RowBox[{"\[ImaginaryI]", "(", 
          RowBox[{"0.", 
           SubscriptBox["y", "k"], 
           SubscriptBox["y", 
            RowBox[{"k", "+", "1"}]], 
           SubscriptBox["\[CenterEllipsis]y", "n"]}], ")"}], "2"]}]]}]}], 
    SqrtBox["2"]], TraditionalForm]],ExpressionUUID->
  "ee8f5dca-36b4-4094-ac73-3c410d4677f0"]
}], "TechNoteText",
 CellID->2035810299,ExpressionUUID->"87b97e00-0a96-4907-ad8a-9ae73b007e2e"],

Cell["is characterized by the relative phase angle", "TechNoteText",
 CellID->409619855,ExpressionUUID->"8101f92c-2a25-4ff2-b896-8b7d0c64fd2b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"2", 
     SubscriptBox[
      RowBox[{"\[Pi]", "(", 
       RowBox[{"0.", 
        SubscriptBox["y", "k"], 
        SubscriptBox["y", 
         RowBox[{"k", "+", "1"}]], 
        SubscriptBox["\[Ellipsis]y", "n"]}], ")"}], "2"]}], "=", 
    RowBox[{
     RowBox[{"\[Pi]", "\[VeryThinSpace]", 
      SubscriptBox["y", "k"]}], "+", 
     RowBox[{
      FractionBox[
       RowBox[{"2", "\[Pi]"}], 
       SuperscriptBox["2", "k"]], 
      SubscriptBox[
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["y", 
          RowBox[{"k", "+", "1"}]], 
         SubscriptBox["\[Ellipsis]y", "n"]}], ")"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"f65079c3-5c98-4e8f-a3f4-676ca24647e9"],
 " ."
}], "TechNoteText",
 CellID->1377870653,ExpressionUUID->"446cc4c0-5187-48b3-a0a7-648ffd823b91"],

Cell[TextData[{
 "The first part ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "\[VeryThinSpace]", 
    SubscriptBox["y", "k"]}], TraditionalForm]],ExpressionUUID->
  "0db9f02b-8bdb-4401-a005-a87bce746d6b"],
 " depends on the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["y", "k"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "538c42f1-642b-4add-8a89-27bbc02d275c"],
 " of the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "60f263f9-3ebc-459f-8708-9725500b20ee"],
 "qubit itself, and is equivalent to the relative phase angle resulting from \
the Hadamard gate,"
}], "TechNoteText",
 CellID->192432173,ExpressionUUID->"5abc690f-0116-4dae-bfea-2af2312bf1f2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", 
     TemplateBox[{
       SubscriptBox["y", "k"]},
      "Ket"]}], "=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      SuperscriptBox[
       RowBox[{
        TemplateBox[{"1"},
         "Ket"], "(", 
        RowBox[{"-", "1"}], ")"}], 
       SubscriptBox["y", "k"]]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "1c3b89df-d921-47a6-867a-ea2431c49be4"],
 "."
}], "TechNoteText",
 CellID->474108015,ExpressionUUID->"a09fe4de-1f5f-46e3-90db-1c13160658eb"],

Cell[TextData[{
 "The second part ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"2", "\[Pi]"}], 
     SuperscriptBox["2", "k"]], 
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["y", 
        RowBox[{"k", "+", "1"}]], 
       SubscriptBox["\[Ellipsis]y", "n"]}], ")"}], "2"], " "}], 
   TraditionalForm]],ExpressionUUID->"8a68f3bb-f268-4e22-bf6f-52897fe926fb"],
 " is governed by the qubits ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "+", "1"}], TraditionalForm]],ExpressionUUID->
  "49c09269-30d8-475c-97e2-f7ae8ad62e49"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "+", "2"}], TraditionalForm]],ExpressionUUID->
  "9968a699-0a9a-4a96-93de-d1c41675726a"],
 ", \[Ellipsis], ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "664ccdb9-356d-453d-af1b-2b3da9411ba7"],
 " through the integer ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["y", 
        RowBox[{"k", "+", "1"}]], 
       SubscriptBox["\[Ellipsis]y", "n"]}], ")"}], "2"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["y", 
       RowBox[{"k", "+", "1"}]], 
      SuperscriptBox["2", "k"]}], "+", "\[Ellipsis]", "+", 
     RowBox[{
      SubscriptBox["y", 
       RowBox[{"n", "-", "1"}]], 
      SuperscriptBox["2", "1"]}], "+", 
     SubscriptBox["y", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "fcb2cc12-81a4-4bca-a9c0-804d8638cb22"],
 " associated with the bit string ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", 
     RowBox[{"k", "+", "1"}]], 
    SubscriptBox["\[Ellipsis]y", "n"]}], TraditionalForm]],ExpressionUUID->
  "e69612fc-4efa-43bd-aeb5-1b253a7ff477"],
 ". This corresponds to the ",
 ButtonBox["controlled power",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ControlledPower"],
 " of the phase gate ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["Z", "k"], TraditionalForm]],ExpressionUUID->
  "b88cca0d-be4a-458c-a9a2-ad3f6928552b"],
 ". Putting it all together, we can regard that the above state  stored on \
the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "th"], TraditionalForm]],ExpressionUUID->
  "3f7acdfe-633e-4265-8a10-2aac327e233b"],
 " qubit is a result of the transformation"
}], "TechNoteText",
 CellID->887676347,ExpressionUUID->"024190f3-e8b0-4af0-bf5e-398eacfdb325"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       SubscriptBox["y", "k"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["y", 
        RowBox[{"k", "+", "1"}]]},
      "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["y", "n"]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       UnderoverscriptBox["\[CapitalPi]", 
        RowBox[{" ", 
         RowBox[{"j", "=", "1"}]}], 
        RowBox[{" ", 
         RowBox[{"k", "-", "1"}]}]], 
       SubsuperscriptBox["Z", "k", 
        SubscriptBox[
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["y", 
            RowBox[{"k", "+", "1"}]], "\[Ellipsis]", "\[VeryThinSpace]", 
           SubscriptBox["y", "n"]}], ")"}], "2"]], "H", 
       TemplateBox[{
         SubscriptBox["y", "k"]},
        "Ket"]}], ")"}], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["y", 
        RowBox[{"k", "+", "1"}]]},
      "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["y", "n"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "426ca1de-c0a9-4255-b05d-b801e9fad40b"],
 " ."
}], "TechNoteText",
