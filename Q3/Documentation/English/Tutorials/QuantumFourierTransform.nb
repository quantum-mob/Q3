Cell["\<\
Convert the above quantum circuit to the form that is suitable for the \
semiclassical implementation of the quantum Fourier transform:\
\>", "TechNoteMathCaption",
 CellID->1803885280,ExpressionUUID->"ca3d1e42-dafa-4fd5-a45b-34dabb19ca6e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc4", "=", 
  RowBox[{
   RowBox[{"Drop", "[", 
    RowBox[{"qc3", ",", 
     RowBox[{"-", "2"}]}], "]"}], "/.", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"S", "[", 
      RowBox[{"k_", ",", "6"}], "]"}], ":>", 
     RowBox[{"Sequence", "[", 
      RowBox[{
       RowBox[{"S", "[", 
        RowBox[{"k", ",", "6"}], "]"}], ",", 
       RowBox[{"Measurement", "[", 
        RowBox[{"S", "[", 
         RowBox[{"k", ",", "3"}], "]"}], "]"}]}], "]"}]}], 
    "\[IndentingNewLine]", "}"}]}]}]], "Input",
 CellLabel->"In[74]:=",
