Cell[CellGroupData[{

Cell["Elementary Properties of Unitary Dynamics", "Subsection",
 CellTags->"Section12",
 CellID->140212108,ExpressionUUID->"b80ce911-7f0a-4266-8906-06b96100c437"],

Cell[TextData[{
 "An important point to bear in mind about unitary dynamics is that it does \
not depend on the history (for a time-independent Hamiltonian). This is \
reflected in the obvious property of the time-evolution operator,\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", 
     RowBox[{"t", "+", 
      SuperscriptBox["t", "\[Prime]"]}], ")"}], " ", "=", " ", 
    RowBox[{
     RowBox[{"U", "(", "t", ")"}], 
     RowBox[{"U", "(", 
      SuperscriptBox["t", "\[Prime]"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"88f8ba6e-f8b3-451b-a0ce-a15d34eb8ae8"],
 "\nfor any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", ",", " ", 
    SuperscriptBox["t", "\[Prime]"]}], TraditionalForm]],ExpressionUUID->
  "7e46f472-d5cb-4d46-b655-69a38e411c9a"],
 ". Physically, this implies that the evolution depends only on the duration \
of time, but not on when it starts or ends. In this respect, it is also \
natural for a time-evolution operator to have the property\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["U", "\[Dagger]"], "(", "t", ")"}], " ", "=", " ", 
    RowBox[{"U", "(", 
     RowBox[{"\[Minus]", "t"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e68046ae-4021-49f2-a1bf-1f9899062ca2"],
 " ."
}], "TechNoteText",
 CellID->755338397,ExpressionUUID->"2a810021-8cf7-431d-aa03-b324519ebd81"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Time Evolution of Mixed States", "Subsection",
 CellTags->"Section13",
 CellID->1196600962,ExpressionUUID->"75d31347-75e3-4354-8724-cc6d5f979ce7"],

Cell[TextData[{
 "So far, we have discussed the time evolution of a pure state. What if the \
system is in a mixed state ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", 
    RowBox[{"(", "0", ")"}]}], TraditionalForm]],ExpressionUUID->
  "c5c43e6c-99b6-4a0e-b662-0d755c0fe217"],
 " for a certain reason?"
}], "TechNoteText",
 CellID->88014179,ExpressionUUID->"d6078855-1929-4982-87f7-4b81d79ef92f"],

Cell["\<\
The mixed state can be expressed as a statistical mixture of pure states,\
\>", "TechNoteText",
 CellID->343381672,ExpressionUUID->"edda1713-ca33-47e2-9068-e0e99af0ecb0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", "0", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "\[Mu]"], 
     RowBox[{
      TemplateBox[{
        RowBox[{
          SubscriptBox["\[Psi]", "\[Mu]"], "(", "0", ")"}]},
       "Ket"], 
      SubscriptBox["p", "\[Mu]"], 
      TemplateBox[{
        RowBox[{
          SubscriptBox["\[Psi]", "\[Mu]"], "(", "0", ")"}]},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "67f65374-ce5e-479b-aa72-c5efe59c6b13"],
 "."
}], "TechNoteText",
 CellID->1785557317,ExpressionUUID->"499fbc6b-0421-4682-afab-c3d4050efe41"],

Cell[TextData[{
 "with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    SubscriptBox["p", "\[Mu]"], " ", "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"78b63c00-9f35-49e0-aaa8-af83a6b6e3b7"],
 ". If the system is closed, then each pure state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox["\[Psi]", "\[Mu]"], "(", "0", ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "01fd1292-a1b7-4d59-8b8d-a003e364aa62"],
 " evolves into ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"U", "(", "t", ")"}], 
    TemplateBox[{
      RowBox[{
        SubscriptBox["\[Psi]", "\[Mu]"], "(", "0", ")"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "eda8466a-5a3a-42f0-a0b9-65c7fe3fd08b"],
 ". Overall, the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", 
    RowBox[{"(", "t", ")"}]}], TraditionalForm]],ExpressionUUID->
  "e7ee7675-eb9a-42b9-b4c9-bf0a7b4c0dda"],
 " at a later time ",
 StyleBox["t",
  FontSlant->"Italic"],
 " is given by"
}], "TechNoteText",
 CellID->925343641,ExpressionUUID->"0bf55493-45ac-4d9e-b450-38126859aa73"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", "t", ")"}], "=", 
    RowBox[{
     RowBox[{"U", "(", "t", ")"}], 
     RowBox[{"\[Rho]", "(", "0", ")"}], 
     RowBox[{
      SuperscriptBox["U", "\[Dagger]"], "(", "t", ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"e3cf2c9c-e0bc-4c7a-8daf-d081dc5745fc"],
 " ."
}], "TechNoteText",
 CellID->174002713,ExpressionUUID->"06c1eeda-8981-4e58-b06b-147618eb4dad"],

Cell["\<\
In short, as long as the system remains closed, the dynamics are still \
unitary regardless of whether the system is initially prepared in a pure or a \
mixed state.\
\>", "TechNoteText",
 CellID->1738353824,ExpressionUUID->"d05c2729-68b8-4736-a462-11d8b064cc81"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->792400194,ExpressionUUID->"39708958-d69b-4f64-9e1d-d4beb788bfcf"],

