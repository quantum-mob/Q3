Cell["\<\
This visualizes the evolution of the state under the Hamiltonian on the Bloch \
sphere. Note that the magnitude of the Bloch vectors are preserved by the \
unitary dynamics.\
\>", "TechNoteMathCaption",
 CellID->1985073273,ExpressionUUID->"147a5aca-133d-4c1e-ac1c-974024a32522"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Rho]\[Rho]", "=", 
   RowBox[{
    RowBox[{"Bead", "/@", 
     RowBox[{"BlochVector", "/@", 
      RowBox[{"Table", "[", 
