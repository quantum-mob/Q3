Cell[CellGroupData[{

Cell["Example: Bell Measurement", "Subsection",
 CellTags->"Section15",
 CellID->2120244876,ExpressionUUID->"4156fbaf-ded5-455e-8f11-eb2e755defa3"],

Cell["\<\
Another interesting example is the Bell measurement. The Bell measurement is \
a measurement on two qubits in the basis of Bell states,\
\>", "TechNoteText",
 CellID->1759476261,ExpressionUUID->"c5f67d31-8a2e-48e2-a157-371ccd0407dd"],

