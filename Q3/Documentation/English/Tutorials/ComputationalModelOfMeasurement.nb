   RowBox[{
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[500]:=",
 CellID->480665445,ExpressionUUID->"2a864178-b607-4cce-9299-dbb887d958f0"],

