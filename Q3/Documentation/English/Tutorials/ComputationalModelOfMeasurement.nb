Cell["\<\
In quantum computers, measurement is assumed to be performed independently on \
individual qubits in the logical basis,\
\>", "TechNoteText",
 CellID->533411144,ExpressionUUID->"6e020795-5976-4028-882d-8dafbaaaa0f0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         TemplateBox[{"x"},
          "Ket"], " ", ":", " ", "x"}], "=", "0"}], ",", "1", ",", 
       RowBox[{".", " ", ".", " ", "."}], " ", ",", 
       RowBox[{
        SuperscriptBox["2", "n"], "\[Minus]", "1"}]}], "}"}], "."}]}], 
   TraditionalForm]],ExpressionUUID->"41c7f252-a729-4ce2-a9da-ee16e78cdf9f"]
}], "TechNoteText",
 CellID->1233770556,ExpressionUUID->"f3795115-3ed4-4819-a0ea-9489e62a4442"],

Cell[TextData[{
 "What if a measurement in another basis (say, the basis of eigenvectors of \
the Pauli X operator) is required? In addition, what if a ",
 StyleBox["collective",
  FontSlant->"Italic"],
 " measurement on a set of qubits (rather than individual qubits) is \
necessary? "
}], "TechNoteText",
 CellID->2027122907,ExpressionUUID->"f01322b5-0062-4588-8d72-318804f7e45b"],

Cell[TextData[{
 "See also Section 2.5 of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "332b8021-58a3-4894-8a8d-6fb2513972af"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"dbd5c7ed-7e94-4f87-875c-e1d158c14189"],

