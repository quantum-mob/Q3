Cell[TextData[{
 "More sophisticated measurements may also be necessary for fast quantum \
algorithms and quantum error corrections. A common example is the ",
 ButtonBox["quantum phase estimation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumPhaseEstimation"],
 ", which is one of the core parts of the quantum factorization algorithm."
}], "TechNoteText",
 CellID->1913990844,ExpressionUUID->"c0c63a0b-316a-42cd-8fc3-b111c193d31b"]
}, Open  ]],

