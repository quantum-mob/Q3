Cell[CellGroupData[{

Cell["Example: Measurement of Pauli X", "Subsection",
 CellID->279121963,ExpressionUUID->"f92f8ecc-3f4c-4d7c-97a7-1ae73035af9d"],

Cell[TextData[{
 "Next, suppose that we want to make a measurement, this time, in the basis \
of eigenvectors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[PlusMinus]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "458716e0-c611-4923-ac7f-333f6bf382da"],
 " of the Pauli X operator. In this case, it is the Hadamard gate that gives \
the desired basis change. In the new basis, the state vector |\[Psi]\:27e9 is \
given by"
}], "TechNoteText",
 CellID->620156009,ExpressionUUID->"c45ac15d-2644-4e53-b933-149f43516454"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"+"},
       "Ket"], 
      FractionBox[
       RowBox[{
        SubscriptBox["c", "0"], "+", 
        SubscriptBox["c", "1"]}], 
       SqrtBox["2"]]}], "+", 
     RowBox[{
      TemplateBox[{"-"},
       "Ket"], 
      FractionBox[
       RowBox[{
        SubscriptBox["c", "0"], "-", 
        SubscriptBox["c", "1"]}], 
       SqrtBox["2"]]}]}]}], TraditionalForm]],ExpressionUUID->
  "71caf1ba-df91-4200-a024-d1d9744056b4"],
 " ."
}], "TechNoteText",
 CellID->1223904372,ExpressionUUID->"20e86f16-6259-474c-84a1-9c6f18e9b7b7"],

Cell["\<\
In this case, the measurement statistics are thus in accordance with the \
probability distribution\
\>", "TechNoteText",
 CellID->1562409238,ExpressionUUID->"64961f58-3f8b-4f62-bed6-d885d047557b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "\[PlusMinus]"], "=", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{
        SubscriptBox["c", "0"], "+", 
        SubscriptBox["c", "1"]}], "\[RightBracketingBar]"}], "2"], "2"]}], 
   TraditionalForm]],ExpressionUUID->"729fec6a-368f-4496-abc1-bcbdd0b2ed42"],
 "."
}], "TechNoteText",
 CellID->2129511197,ExpressionUUID->"15785fab-813e-430b-b44c-79fa921b41fd"],

