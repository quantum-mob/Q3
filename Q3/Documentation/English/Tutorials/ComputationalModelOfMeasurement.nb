Cell[CellGroupData[{

Cell["Pauli Measurements", "TechNoteSection",
 CellTags->"Section16",
 CellID->541468603,ExpressionUUID->"afb2f75d-f463-486e-b897-84ad0d750af5"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[504]:=",
 CellID->718055094,ExpressionUUID->"e24be68a-3044-43aa-84a2-f1cbd33de3f7"],

Cell[TextData[{
 "In ",
 ButtonBox["quantum error-correction codes",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumErrorCorrectionCodes"],
 " and ",
 ButtonBox["stabilizer circuits",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/StabilizerFormalism#90183241"],
 ", one often encounters the so-called Pauli measurements, the measurements \
of tensor products of the single-qubit Pauli operators."
}], "TechNoteText",
 CellID->1574598282,ExpressionUUID->"a48ef513-7bd7-45dd-8348-3a47c9421fc5"],

Cell[TextData[{
 "To be specific, let us consider the measurement of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
   "Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]",
     "Z"}], TraditionalForm]],ExpressionUUID->
  "c7cfdb89-f41a-4e98-b420-9a1e2ffdc9a1"],
 " on ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "f01ed602-7cd9-41ae-9639-73ae66ed5d5a"],
 " qubits; the measurement of general Pauli operators can be achieved by \
incorporating the trick of basis change discussed above and introducing \
ancillary qubits."
}], "TechNoteText",
 CellID->832343593,ExpressionUUID->"5b7f71ff-b177-450e-8949-fcc33c020cd6"],

Cell[TextData[{
 "Before going further, it is important to note that the measurement of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
   "Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]",
     "Z"}], TraditionalForm]],ExpressionUUID->
  "47c80b9d-48c6-4484-a4ec-c606eec56161"],
 " is a ",
 StyleBox["collective",
  FontSlant->"Italic"],
 " measurement and must be distinguished from the ",
 StyleBox["sequential",
  FontSlant->"Italic"],
 " measurements of ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "ff730030-0170-487c-8ec7-731e24d12f0b"],
 " on individual qubits. For example, when an even number of qubits are \
prepared in quantum state"
}], "TechNoteText",
 CellID->490290993,ExpressionUUID->"c7d34f24-e218-473f-af77-4feac56120d8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{
        RowBox[{"00", "\[Ellipsis]0"}]},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{
        RowBox[{"11", "\[Ellipsis]1"}]},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "2b40bf29-aac0-42a4-8c6d-0bb5ebaa8269"],
 " ,"
}], "TechNoteText",
 CellID->425965812,ExpressionUUID->"98d3d0ac-bd3b-4d3c-af45-d6c3ff8ec4db"],

Cell[TextData[{
 "the measurement of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
   "Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]",
     "Z"}], TraditionalForm]],ExpressionUUID->
  "d397a402-03c0-42d6-a4de-14f7991b9634"],
 " always gives outcome 1 (out of two eigenvalues \[PlusMinus]1 of the \
observable), and the quantum state remains intact even after the measurement. \
On the other hand, the measurement of ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "b6a7d9cd-ef60-43c6-bdc2-367880bb5a5b"],
 ", say, on the first qubit produces outcome 0 or 1 (respectively \
corresponding to eigenvalues \[PlusMinus]1 of ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "a74b5fb6-d5b1-4a16-b135-967572aee4fa"],
 "), and the quantum state accordingly collapses to either ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"00", "\[Ellipsis]0"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "bc5cc88d-1e44-4c9f-bb1c-e380e9953bd9"],
 " or ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"11", "\[Ellipsis]1"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "12a67309-c9f4-4aab-8c1c-f10de813a36b"],
 "."
}], "TechNoteText",
 CellID->1644406833,ExpressionUUID->"889b7c8d-acc2-42a6-b2ec-22f052ec22cc"],

Cell[TextData[{
 "The measurement of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
   "Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]",
     "Z"}], TraditionalForm]],ExpressionUUID->
  "cf4159a8-edc2-4ab7-96db-ac303b9845e5"],
 " can be implemented within the quantum circuit model of quantum computation \
by using an ancillary qubit initialized in state |0\:27e9 and by coupling the \
qubits in the native register to the ancillary qubits as follows"
}], "TechNoteText",
 CellID->1578588988,ExpressionUUID->"4d403225-4617-4402-ae1c-9f48f58d0821"],

Cell["\t(\[Ellipsis] circuit diagram here \[Ellipsis])", "TechNoteText",
 CellID->601273444,ExpressionUUID->"cda9f568-2f5b-4e8f-8def-33395eda4a28"],

Cell[TextData[{
 "The CNOT gates transform the state of the ancillary qubit from the initial \
state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "7b22885d-e390-4204-8afc-8b741c50701e"],
 " to the final state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox["x", "1"], "\[CirclePlus]", 
       SubscriptBox["x", "2"], "\[CirclePlus]", "\[CenterEllipsis]", 
       "\[CirclePlus]", 
       SubscriptBox["x", "n"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "c5e6e09f-7e60-46c0-a95e-0f3353e59a1d"],
 " involving the logical values of the n qubits in the native register, and \
hence a simple measurement on the ancillary qubits in the computational basis \
leads to the desired result."
}], "TechNoteText",
 CellID->1865474371,ExpressionUUID->"b3e4a046-c151-4bf0-a2a4-7c35febdf233"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S", ",", "T"}], "]"}]}], "Input",
 CellLabel->"In[505]:=",
 CellID->1668267271,ExpressionUUID->"99503f36-0918-45b5-9c02-357c72abe86d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cc", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"CNOT", "[", 
      RowBox[{
       RowBox[{"S", "[", "k", "]"}], ",", "T"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "$n"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{"{", "T", "}"}], "]"}], ",", 
    RowBox[{"Sequence", "@@", "cc"}], ",", 
    RowBox[{"\"\<Invisible\>\"", "->", 
     RowBox[{"S", "[", 
      RowBox[{"$n", "+", 
       RowBox[{"1", "/", "2"}]}], "]"}]}]}], "]"}]}]}], "Input",
 CellLabel->"In[508]:=",
 CellID->422315842,ExpressionUUID->"60a123b2-134b-49e7-904d-f9c4fb9ffa70"],

