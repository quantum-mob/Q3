Cell[CellGroupData[{

Cell["Example: Measurement of Pauli Z", "Subsection",
 CellID->755170676,ExpressionUUID->"25194693-e365-4542-9f1b-0ec1f72e5180"],

Cell["Consider a qubit is in the state", "TechNoteText",
