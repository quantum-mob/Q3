Cell["\<\
By default, a measurement is assumed to be in the computational basis and the \
measurement statistics reflect the probability distribution\
\>", "TechNoteText",
 CellID->210418973,ExpressionUUID->"dbf7cb4c-f69c-4456-9716-007a3437f391"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], "=", 
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      SubscriptBox["c", "0"], "\[RightBracketingBar]"}], "2"]}], 
   TraditionalForm]],ExpressionUUID->"ffe8d384-d10a-4201-af88-148442295be8"],
 "  and  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "1"], "=", 
