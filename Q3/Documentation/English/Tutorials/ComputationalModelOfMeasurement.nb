 CellLabel->"In[489]:=",
 CellID->403330096,ExpressionUUID->"a06b273c-ebd2-4502-ac35-6045cd5917f5"],

Cell[CellGroupData[{

Cell["Measurement in an Arbitrary Basis", "TechNoteSection",
 CellID->58300685,ExpressionUUID->"06dde700-1444-4e15-9068-b7b3bcb18245"],

Cell[TextData[{
 "Suppose that a measurement in basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Alpha]", "x"]},
      "Ket"], " ", "=", " ", 
     RowBox[{"U", 
      TemplateBox[{"x"},
       "Ket"]}]}], " ", "}"}], TraditionalForm]],ExpressionUUID->
  "c957a1da-f9a6-476a-94b0-d1c91bff8178"],
 " is required. We require that the input state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Alpha]", "x"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "63444e35-dcd2-43f8-aab9-2982f28dcf78"],
 " should end up with the logical basis state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"x"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6015acf3-f4c3-4e11-8b11-cba068f90ec9"],
 " with unit probability so that the measurement yields outcome ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "316ba8f3-51a9-4054-87be-035b68673b5b"],
 ". This process is described by the measurement operators"
}], "TechNoteText",
 CellID->607069763,ExpressionUUID->"a6b1f9ef-d04f-4771-96fe-b2d6c6ea4a4e"],

Cell[TextData[{
 "\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "x"], " ", ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], 
      TemplateBox[{
        SubscriptBox["\[Alpha]", "x"]},
       "Bra"]}], "=", 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], 
      TemplateBox[{"x"},
       "Bra"], 
      SuperscriptBox["U", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"7f0017b7-19d8-4ea1-8387-0a4bab4f9db2"],
 " ."
}], "TechNoteText",
 CellID->326699844,ExpressionUUID->"d9da624c-0975-4692-9a9c-aab63a0c38df"],

Cell["Evidently, they satisfy the condition", "TechNoteText",
 CellID->1876076376,ExpressionUUID->"e60d99ae-4099-41f7-808e-e3f3006d8dab"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Sum]", "x"], 
     RowBox[{
      SubsuperscriptBox["M", "x", "\[Dagger]"], 
      SubscriptBox["M", "x"]}]}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"78f88153-536a-4dba-993a-4e53282772e1"]
}], "TechNoteText",
 CellID->1860746178,ExpressionUUID->"8755473a-f139-43d5-83fb-0e80bc4348d8"],

Cell[TextData[{
 " for measurement operators (see ",
 ButtonBox["Postulate 3",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MeasurementsOnQuantumStates#1477689096"],
 ")."
}], "TechNoteText",
 CellID->1904146032,ExpressionUUID->"9e308d14-e8d8-41d7-a423-18f3e59a467e"],

Cell[TextData[{
 "Here we note that the operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "x"], ":=", 
    RowBox[{
     TemplateBox[{"x"},
      "Ket"], 
     TemplateBox[{"x"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "a19cbdd7-11b1-410f-8ac0-6b0ae24943d0"],
 " describe nothing but the measurement in the logical basis. This implies \
that by simply applying the inverse unitary operation ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "1f4be211-c082-45bf-923f-8bcbf26c55fb"],
 " before the measurement, the measurement in the new basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["\[Alpha]", "x"]},
     "Ket"], " ", "}"}], TraditionalForm]],ExpressionUUID->
  "5e26e0ad-e0e0-4093-8f5c-10174d57ec77"],
 " can be achieved through measurement in the logical basis as illustrated in \
the following figure."
}], "TechNoteText",
 CellID->1181052230,ExpressionUUID->"820cc415-847f-40bd-b4df-457f0947d6c3"],

Cell[BoxData[
 GraphicsBox[{
   {Dashing[{Small, Small}], 
    LineBox[{{{4, -1}, {5, -1}}, {{4, -2}, {5, -2}}, {{4, -3}, {5, -3}}, {{
     4, -4}, {5, -4}}}]}, 
   LineBox[{{{0, -1}, {4, -1}}, {{0, -2}, {4, -2}}, {{0, -3}, {4, -3}}, {{
