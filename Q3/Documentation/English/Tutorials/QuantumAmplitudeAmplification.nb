 RowBox[{"in", "//", "Normal"}]}], "Input",
 CellLabel->"In[247]:=",
 CellID->1575398298,ExpressionUUID->"9846edab-93d5-40ce-8d9c-8ba5a0b9ff46"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "2"], ",", 
   FractionBox["1", "2"], ",", 
   FractionBox["1", "2"], ",", 
   FractionBox["1", "2"]}], "}"}]], "Output",
 CellLabel->"Out[249]=",
 CellID->1970545658,ExpressionUUID->"878cc524-2eda-4a37-902e-df87de2db2b0"]
}, Open  ]],

Cell["Get the output state through the algorithm:", "TechNoteMathCaption",
