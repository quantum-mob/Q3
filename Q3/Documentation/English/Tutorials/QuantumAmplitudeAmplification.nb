     RowBox[{"Join", "[", 
      RowBox[{"AA", ",", "SS"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"VV", "//", "ArrayShort"}]}], "Input",
 CellLabel->"In[260]:=",
