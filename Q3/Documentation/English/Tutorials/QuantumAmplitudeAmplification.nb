 CellLabel->"Out[267]=",
 CellID->1753558182,ExpressionUUID->"3e7d3b5a-98f2-4ed6-a5bb-bdd82604a49c"]
}, Open  ]],

Cell["\<\
If you apply the AA operator too many times, then the fidelity gets worse \
again:\
\>", "TechNoteMathCaption",
 CellID->1702758543,ExpressionUUID->"91fdda2a-6c76-4d42-9acc-5a98b1626e82"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mid", "=", 
   RowBox[{
    RowBox[{"MatrixPower", "[", 
     RowBox[{
      RowBox[{"N", "@", "AA"}], ",", "2"}], "]"}], ".", "out"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"fdl", "=", 
  RowBox[{
   RowBox[{"Fidelity", "[", 
    RowBox[{"good", ",", "mid"}], "]"}], "//", "N"}]}]}], "Input",
 CellLabel->"In[268]:=",
 CellID->65468293,ExpressionUUID->"e21e0720-462a-4374-8f20-e6b0fd833052"],

Cell[BoxData["0.15309310892394853`"], "Output",
 CellLabel->"Out[269]=",
 CellID->1234794999,ExpressionUUID->"ceeb0d30-eb95-4296-bd7a-fe4dc3b2334d"]
}, Open  ]],

Cell["Repeating the AA operation, the fidelity oscillates:", \
"TechNoteMathCaption",
 CellID->887215026,ExpressionUUID->"539d1efa-a362-4387-b811-b24ce550da82"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mid", "=", 
   RowBox[{
    RowBox[{"MatrixPower", "[", 
     RowBox[{
      RowBox[{"N", "@", "AA"}], ",", "5"}], "]"}], ".", "out"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"fdl", "=", 
  RowBox[{
   RowBox[{"Fidelity", "[", 
    RowBox[{"good", ",", "mid"}], "]"}], "//", "N"}]}]}], "Input",
 CellLabel->"In[270]:=",
 CellID->976522519,ExpressionUUID->"6d345aee-090d-4a4f-a413-f3a2ff429003"],

