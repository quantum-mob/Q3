Cell["\<\
Before constructing the amplitude amplification (AA) operator, construct the \
\"phase marker\" operators:\
\>", "TechNoteMathCaption",
 CellID->566017205,ExpressionUUID->"17541e61-66a0-4bb7-8466-1953c72442cb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Zin", "=", 
   RowBox[{
    RowBox[{"2", "*", 
     RowBox[{"Dyad", "[", 
      RowBox[{"in", ",", "in"}], "]"}]}], "-", 
    RowBox[{"One", "[", "$N", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Zgd", "=", 
   RowBox[{
    RowBox[{"2", "*", 
     RowBox[{"Dyad", "[", 
      RowBox[{"good", ",", "good"}], "]"}]}], "-", 
    RowBox[{"One", "[", "$N", "]"}]}]}], ";"}]}], "Input",
 CellLabel->"In[262]:=",
 CellID->675092936,ExpressionUUID->"51ffbb4e-4d59-4850-8cbf-8ecf70b90aac"],

Cell["Construct the AA operator:", "TechNoteMathCaption",
 CellID->1195732985,ExpressionUUID->"f87db700-bfec-472a-9e90-f22ee768d6ef"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"AA", "=", 
   RowBox[{"UU", ".", "Zin", ".", 
    RowBox[{"ConjugateTranspose", "[", "UU", "]"}], ".", "Zgd"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"AA", "//", "ArrayShort"}]}], "Input",
 CellLabel->"In[264]:=",
 CellID->1130868251,ExpressionUUID->"b7836606-da24-4765-b1a7-db9047a86774"],

