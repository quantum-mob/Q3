Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Geometric demonstration of the quantum amplitude amplification process ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "AA"], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "U"}], "\[VeryThinSpace]", 
      SubscriptBox["Z", "\[Psi]"], 
      SuperscriptBox["U", "\[Dagger]"], 
      SubscriptBox["Z", "\[Phi]"]}], "\[Congruent]", 
     RowBox[{
      RowBox[{"-", 
       SubscriptBox["Z", 
        RowBox[{"\[Psi]", "'"}]]}], 
      SubscriptBox["Z", "\[Phi]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "36f4cbdb-ea48-41ae-bf90-484a2a10745f"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "'"}]},
     "Ket"], ":=", 
    RowBox[{"U", 
     TemplateBox[{"\[Psi]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "36f4ccf5-50bc-40a5-9b88-f126455c4e8a"],
 ". Note that to construct the unitary operation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalOmega]", "AA"], TraditionalForm]],ExpressionUUID->
  "390cd154-9d60-48a7-9cba-8bf59e4fe53a"],
 " requires the knowledge of the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "eaa07334-686a-456a-ab8f-f09b7f32304e"],
 ", which is typically set to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SuperscriptBox["0", 
      RowBox[{"\[CircleTimes]", "n"}]]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "92b0b069-258d-47ef-9835-4e30fc5aa1f6"],
 "."
}], "TechNoteCaption",
 CellID->106944923,ExpressionUUID->"08f0b922-96fa-4b15-8ebb-4268d60a915e"],

Cell[CellGroupData[{

Cell["Demonstration", "Subsection",
 CellID->1502243926,ExpressionUUID->"b645c295-140a-4d70-8d19-d3f7e654ddc3"],

Cell["Consider a quantum register of a finite number of qubits:", \
"TechNoteMathCaption",
 CellID->1056618802,ExpressionUUID->"894aea24-1650-42a2-b05b-c7e26c0e308d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
