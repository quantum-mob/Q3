 RowBox[{"VV", "=", 
  RowBox[{"BlockEncoding", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Sqrt", "[", "$p", "]"}], "*", "UU"}], ",", "SS", ",", "AA"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"VV", "=", 
   RowBox[{"Matrix", "[", 
