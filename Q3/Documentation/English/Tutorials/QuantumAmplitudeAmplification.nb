Cell["The fidelity has been improved:", "TechNoteMathCaption",
 CellID->2008839700,ExpressionUUID->"b0e2d16b-262b-4650-aaba-5ab40e9caa5e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fdl", "=", 
  RowBox[{
   RowBox[{"Fidelity", "[", 
    RowBox[{"good", ",", "mid"}], "]"}], "//", "N"}]}]], "Input",
 CellLabel->"In[267]:=",
 CellID->178736448,ExpressionUUID->"a22f1552-35b6-4843-bd77-8259fbec0136"],

