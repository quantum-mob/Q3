Cell["The fidelity has been improved:", "TechNoteMathCaption",
 CellID->2008839700,ExpressionUUID->"33b6dbc9-fe97-4a29-b6b0-e6806879d7f2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fdl", "=", 
  RowBox[{
   RowBox[{"Fidelity", "[", 
    RowBox[{"good", ",", "mid"}], "]"}], "//", "N"}]}]], "Input",
 CellLabel->"In[267]:=",
 CellID->178736448,ExpressionUUID->"c78cda32-844a-4ce6-8a84-4704a04b67b8"],

