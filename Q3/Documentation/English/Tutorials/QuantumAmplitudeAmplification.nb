Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Geometric demonstration of the quantum amplitude amplification process ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "AA"], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "U"}], "\[VeryThinSpace]", 
      SubscriptBox["Z", "\[Psi]"], 
      SuperscriptBox["U", "\[Dagger]"], 
      SubscriptBox["Z", "\[Phi]"]}], "\[Congruent]", 
     RowBox[{
      RowBox[{"-", 
       SubscriptBox["Z", 
        RowBox[{"\[Psi]", "'"}]]}], 
      SubscriptBox["Z", "\[Phi]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "9761bc71-3052-4a6d-97b9-67892be68d30"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"\[Psi]", "'"}]},
     "Ket"], ":=", 
    RowBox[{"U", 
     TemplateBox[{"\[Psi]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "e2153b3f-330a-4972-bbbd-0bee197746cf"],
 ". Note that to construct the unitary operation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalOmega]", "AA"], TraditionalForm]],ExpressionUUID->
  "b347d1f2-87b0-40b9-a831-1add48cde965"],
 " requires the knowledge of the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2c686b51-2dd3-4edc-a764-bd278c370997"],
 ", which is typically set to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SuperscriptBox["0", 
      RowBox[{"\[CircleTimes]", "n"}]]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "aefd2961-dd17-4423-b7ec-18dbdd13bc6f"],
 "."
}], "TechNoteCaption",
 CellID->106944923,ExpressionUUID->"57e726a5-4a87-4f31-b314-d5c8b2d26b50"],

Cell[CellGroupData[{

Cell["Demonstration", "Subsection",
 CellID->1502243926,ExpressionUUID->"063f73b2-2b49-4f5f-aaae-a398fa54cf06"],

Cell["Consider a quantum register of a finite number of qubits:", \
"TechNoteMathCaption",
 CellID->1056618802,ExpressionUUID->"6fa7f266-ed01-4c69-a8eb-ca972a2b08b5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$N", "=", 
   RowBox[{"Power", "[", 
    RowBox[{"2", ",", "$n"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[237]:=",
 CellID->1030530536,ExpressionUUID->"50d33840-f46b-45db-add9-9980fbec91d3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"SS", "=", 
  RowBox[{"S", "[", 
   RowBox[{
    RowBox[{"Range", "@", "$n"}], ",", "$"}], "]"}]}]}], "Input",
 CellLabel->"In[239]:=",
 CellID->671105497,ExpressionUUID->"92f67f29-7484-451e-b75e-20630cc26560"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "1"},
      "RowWithSeparators"]],
    $CellContext`S[1, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "2"},
      "RowWithSeparators"]],
    $CellContext`S[2, QuantumMob`Q3`$]]}], "}"}]], "Output",
 CellLabel->"Out[240]=",
 CellID->526504709,ExpressionUUID->"9bdaa995-b1a3-4350-8190-a49c983f6a9d"]
}, Open  ]],

Cell["\<\
Consider an algorithm (or, equivalently, a unitary operator) in a numerical \
matrix form for convenience:\
\>", "TechNoteMathCaption",
 CellID->1332018523,ExpressionUUID->"e9112232-edd9-4dcd-aadb-e402291e78fc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"UU", "=", 
   RowBox[{
    RowBox[{"Rotation", "[", 
     RowBox[{
      RowBox[{"Pi", "/", "3"}], ",", 
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "3"}], "]"}]}], "]"}], "**", 
    RowBox[{"Rotation", "[", 
     RowBox[{
      RowBox[{"Pi", "/", "4"}], ",", 
      RowBox[{"S", "[", 
       RowBox[{"2", ",", "1"}], "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"UU", "=", 
   RowBox[{
    RowBox[{"Matrix", "[", 
     RowBox[{"UU", ",", "SS"}], "]"}], "//", "N"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"UU", "//", "IntegerChop"}], "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[241]:=",
 CellID->1473389149,ExpressionUUID->"988a7da6-ac4d-480e-babb-ca4fc9e8a0cd"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      RowBox[{"0.8001031451912655`", "\[VeryThinSpace]", "-", 
       RowBox[{"0.46193976625564337`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{
       RowBox[{"-", "0.1913417161825449`"}], "-", 
       RowBox[{"0.3314135740355918`", " ", "\[ImaginaryI]"}]}], "0", "0"},
     {
      RowBox[{
       RowBox[{"-", "0.1913417161825449`"}], "-", 
       RowBox[{"0.3314135740355918`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{"0.8001031451912655`", "\[VeryThinSpace]", "-", 
       RowBox[{"0.46193976625564337`", " ", "\[ImaginaryI]"}]}], "0", "0"},
     {"0", "0", 
      RowBox[{"0.8001031451912655`", "\[VeryThinSpace]", "+", 
       RowBox[{"0.46193976625564337`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{"0.1913417161825449`", "\[VeryThinSpace]", "-", 
       RowBox[{"0.3314135740355918`", " ", "\[ImaginaryI]"}]}]},
     {"0", "0", 
      RowBox[{"0.1913417161825449`", "\[VeryThinSpace]", "-", 
       RowBox[{"0.3314135740355918`", " ", "\[ImaginaryI]"}]}], 
      RowBox[{"0.8001031451912655`", "\[VeryThinSpace]", "+", 
       RowBox[{"0.46193976625564337`", " ", "\[ImaginaryI]"}]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {4, 4}, 0, {
     1, {{0, 2, 4, 6, 8}, {{1}, {2}, {2}, {1}, {3}, {4}, {4}, {3}}}, {Complex[
      0.8001031451912655, -0.46193976625564337`], 
      Complex[-0.1913417161825449, -0.3314135740355918], Complex[
      0.8001031451912655, -0.46193976625564337`], 
      Complex[-0.1913417161825449, -0.3314135740355918], Complex[
      0.8001031451912655, 0.46193976625564337`], Complex[
      0.1913417161825449, -0.3314135740355918], Complex[0.8001031451912655, 
      0.46193976625564337`], Complex[
      0.1913417161825449, -0.3314135740355918]}}]]]]], "Output",
 CellLabel->"Out[243]//MatrixForm=",
 CellID->215290027,ExpressionUUID->"f2735541-5d82-4bd2-b22b-471efb4f94ed"]
}, Open  ]],

Cell["Choose an initial state:", "TechNoteMathCaption",
 CellID->1689971758,ExpressionUUID->"4317d4fb-ca05-4156-aae1-ddb44a84cc06"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "6"}], "]"}], "**", 
    RowBox[{"Ket", "[", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{"Matrix", "[", 
    RowBox[{"in", ",", "SS"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"in", "//", "Normal"}]}], "Input",
 CellLabel->"In[247]:=",
 CellID->1575398298,ExpressionUUID->"41919d5b-47f9-468c-83d1-f1cb3b502159"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "2"], ",", 
   FractionBox["1", "2"], ",", 
   FractionBox["1", "2"], ",", 
   FractionBox["1", "2"]}], "}"}]], "Output",
 CellLabel->"Out[249]=",
 CellID->1970545658,ExpressionUUID->"df99134e-0873-4812-b0f2-25d608b12dce"]
}, Open  ]],

Cell["Get the output state through the algorithm:", "TechNoteMathCaption",
 CellID->468069972,ExpressionUUID->"2a27f6e9-8100-4d4a-8d30-11b864feb813"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"UU", ".", "in"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"out", "//", "Normal"}]}], "Input",
 CellLabel->"In[250]:=",
 CellID->1209953873,ExpressionUUID->"a63440c0-9e5c-485e-a3a9-c33191144089"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"0.3043807145043603`", "\[VeryThinSpace]", "-", 
    RowBox[{"0.3966766701456176`", " ", "\[ImaginaryI]"}]}], ",", 
   RowBox[{"0.3043807145043603`", "\[VeryThinSpace]", "-", 
    RowBox[{"0.3966766701456176`", " ", "\[ImaginaryI]"}]}], ",", 
   RowBox[{"0.4957224306869052`", "\[VeryThinSpace]", "+", 
    RowBox[{"0.06526309611002579`", " ", "\[ImaginaryI]"}]}], ",", 
   RowBox[{"0.4957224306869052`", "\[VeryThinSpace]", "+", 
    RowBox[{"0.06526309611002579`", " ", "\[ImaginaryI]"}]}]}], 
  "}"}]], "Output",
 CellLabel->"Out[251]=",
 CellID->1714818271,ExpressionUUID->"05cf3e63-4d41-42f5-a6e8-f010a8e760dd"]
}, Open  ]],

Cell["\<\
We want the output state to be close to a desired \"good\" state:\
\>", "TechNoteMathCaption",
 CellID->1720137957,ExpressionUUID->"63183883-c2a3-43ca-bf5f-6a271f39cc7c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"good", "=", 
  RowBox[{
   RowBox[{"GHZState", "[", "SS", "]"}], "//", "First"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"good", "=", 
   RowBox[{"Matrix", "[", "good", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"good", "//", "Normal"}]}], "Input",
 CellLabel->"In[252]:=",
 CellID->450278945,ExpressionUUID->"ef3a4725-bdf4-40d8-8203-d84b7bb34a5a"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      0, $CellContext`S[2, QuantumMob`Q3`$] -> 0|>]], "+", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      1, $CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]}], 
  SqrtBox["2"]]], "Output",
 CellLabel->"Out[252]=",
 CellID->1564409363,ExpressionUUID->"2d8330b6-ed0c-4366-b618-ec2e7c0deb8a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", 
    SqrtBox["2"]], ",", "0", ",", "0", ",", 
   FractionBox["1", 
    SqrtBox["2"]]}], "}"}]], "Output",
 CellLabel->"Out[254]=",
 CellID->1385873720,ExpressionUUID->"549a8ae0-6619-423b-a7db-82c2b1b69e9f"]
}, Open  ]],

