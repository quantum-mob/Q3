Cell[CellGroupData[{

Cell["Oblivious Amplitude Amplification (OAA)", "TechNoteSection",
 CellID->635509592,ExpressionUUID->"a87dd81e-4327-49ed-aa1a-1f68aa9af715"],

Cell["\<\
Oblivious amplitude amplification (OAA) is a generalization of the quantum \
amplitude amplification algorithm. Unlike the standard amplitude \
amplification, OAA does not require knowledge of the initial state or a full \
reflection about it. Instead, it amplifies the amplitude of a target state \
while handling scenarios where the initial state is unknown or \
\[OpenCurlyDoubleQuote]oblivious.\[CloseCurlyDoubleQuote]\
\>", "TechNoteText",
 CellID->162019086,ExpressionUUID->"8260b475-c2f7-4edf-9408-170c4c1dfb10"],

Cell[TextData[{
 "        Let ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "6cb1f4f6-4cbc-45a9-a31d-862acfa38de8"],
 " be a unitary operator on the quantum register of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "57e52b24-ed5c-4c80-a9d2-bf80272c2095"],
 " qubits. Introduce an ancillary quantum register of ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "f639b2d0-75c6-4582-bb5d-1542bd198e8f"],
 " qubits, and let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "00245ec1-fc58-463a-8747-9b34c3e1775d"],
 " be a unitary gate on the overall quantum register such that"
}], "TechNoteText",
 CellID->1166117144,ExpressionUUID->"99add544-e72b-41c0-93ff-208fdbe14d5e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", "(", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["0", "m"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"\[Psi]"},
       "Ket"]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Ket"], "\[CircleTimes]", 
       RowBox[{"(", 
        RowBox[{"U", 
         TemplateBox[{"\[Psi]"},
          "Ket"]}], ")"}]}], 
      SqrtBox["p"]}], "+", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
       "Ket"], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "89e8d74f-adf6-48a7-a581-188eb599a84c"],
 ", "
}], "TechNoteText",
 CellID->45514006,ExpressionUUID->"eda47f50-7d14-455d-8f2e-56e5a3e6b0dc"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f719d9ad-24c5-44c0-aa09-aa11711f0be0"],
 " is a normalized state that is not of our interest, such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPi]", 
     TemplateBox[{
       SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
      "Ket"]}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "74d925df-bdeb-4b2e-be84-81bfed1f01db"],
 ", where\t"
}], "TechNoteText",
 CellID->449720510,ExpressionUUID->"2caf1351-a343-4605-99e6-1c1d77cb1ea2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalPi]", ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Ket"], 
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Bra"]}], ")"}], "\[CircleTimes]", 
     SubscriptBox["I", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "0b8b33f6-e865-48e0-945d-562357523341"],
 " \[LineSeparator]and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "k"], TraditionalForm]],ExpressionUUID->
  "3d6b37b1-104c-466e-a819-289059265869"],
 " denotes the identity matrix on ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "cdd01b0d-9649-4c0d-b5da-f50d7306d7f9"],
 " qubits, i.e., the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", "k"], "\[Times]", 
    SuperscriptBox["2", "k"]}], TraditionalForm]],ExpressionUUID->
  "ee2ab057-a0ba-4acd-b9ae-c93374baa608"],
 " (not ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[Times]", "k"}], TraditionalForm]],ExpressionUUID->
  "ed7aefa6-525b-458b-b961-95f5153c782b"],
 ") identity matrix."
}], "TechNoteText",
 CellID->7974949,ExpressionUUID->"3db9d39c-77e1-462b-a73f-6f70d31d082d"],

Cell[TextData[{
 "In the matrix form, the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", 
     RowBox[{"m", "+", "n"}]], "\[Times]", 
    SuperscriptBox["2", 
     RowBox[{"m", "+", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "18a12571-d863-49d5-9389-99377779bb0b"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "44187470-8320-48b1-aff9-d68214a3ce0f"],
 " is a ",
 ButtonBox["block encoding",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding"],
 " of the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", "n"], "\[Times]", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "ee0f1d13-7fe4-4952-9e6d-53f25e21acab"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "be8b495f-21b8-4b66-b285-714378d03968"],
 ","
}], "TechNoteText",
 CellID->1154511227,ExpressionUUID->"8cb5ce97-5c0a-482a-b580-6269a373dd21"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{
         SqrtBox["p"], "U"}], "*"},
       {"*", "*"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6f9f892d-df9c-4ec0-8b5b-d2580b01062c"],
 " ."
}], "TechNoteText",
 CellID->1457657777,ExpressionUUID->"e36defc8-1cdf-4e8f-995e-56a1386e766a"],

Cell[TextData[{
 "Here, it is important that ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "46bc4027-ba83-47ce-abb7-251fd0034f5b"],
 " is unitary. The goal is to increase the success probability for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SuperscriptBox["0", "m"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "779126b8-1005-4848-8c39-1b30f7200057"],
 " on the ancillary register."
}], "TechNoteText",
 CellID->360813063,ExpressionUUID->"04f8c6c1-0548-4086-b0de-fbd868736626"],

Cell["        For later use, we define the product states", "TechNoteText",
 CellID->1710258253,ExpressionUUID->"db6c2b68-df37-4285-a8b6-b37331bb258c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SuperscriptBox["0", "m"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"\[Psi]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "959c7853-3628-4920-a6eb-beddb68bafec"],
 "  ,       ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPhi]"},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SuperscriptBox["0", "m"]},
      "Ket"], "\[CircleTimes]", 
     RowBox[{"(", 
      RowBox[{"U", 
       TemplateBox[{"\[Psi]"},
        "Ket"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "0d8baeed-58e7-455b-8bb6-addffcd21ec2"]
}], "TechNoteText",
 CellID->1161918896,ExpressionUUID->"f3859b02-b02a-4745-87e6-f7aa89662df8"],

Cell[TextData[{
 "so that the operation of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "56b799ba-1fae-45fc-8864-b72eb725580d"],
 " reads as"
}], "TechNoteText",
 CellID->1840366080,ExpressionUUID->"f780d0ea-457b-4639-85d1-f225ea9ba4d9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[CapitalPhi]"},
       "Ket"], 
      SqrtBox["p"]}], "+", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
       "Ket"], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "529cb3cd-47de-4c7b-8047-da85a3f9d040"],
 "."
}], "TechNoteText",
 CellID->960150010,ExpressionUUID->"c6c7727f-037b-4c91-8923-53fdd8bff820"],

Cell["\<\
        If you follow the standard amplitude amplification idea in the above, \
you need an oracle\
\>", "TechNoteText",
 CellID->1838814360,ExpressionUUID->"12358faa-3986-462b-a1d2-a52ac891f195"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["I", "m"], "\[CircleTimes]", "U"}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["I", 
       RowBox[{"m", "+", "n"}]], "-", 
      RowBox[{"2", 
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Ket"], 
       RowBox[{
        TemplateBox[{
          SuperscriptBox["0", "m"]},
         "Bra"], "\[CircleTimes]", 
        TemplateBox[{"\[Psi]"},
         "Ket"]}], 
       TemplateBox[{"\[Psi]"},
        "Bra"]}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["I", "m"], "\[CircleTimes]", 
      SuperscriptBox["U", "\[Dagger]"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"8d4d0c8e-acd0-4e60-9428-f19d0f084e7d"]
}], "TechNoteText",
 CellID->515784543,ExpressionUUID->"b2eb018c-ae17-4d30-b3cc-daba602b054b"],

Cell[TextData[{
 "and the reflection in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", 
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "48b24138-9b65-4a59-bbdf-8e6318d6e206"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", "(", 
     RowBox[{
      RowBox[{"2", 
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Ket"], 
       RowBox[{
        TemplateBox[{
          SuperscriptBox["0", "m"]},
         "Bra"], "\[CircleTimes]", 
        TemplateBox[{"\[Psi]"},
         "Ket"]}], 
       TemplateBox[{"\[Psi]"},
        "Bra"]}], "-", 
      SubscriptBox["I", 
       RowBox[{"m", "+", "n"}]]}], ")"}], 
    SuperscriptBox["V", "\[Dagger]"]}], TraditionalForm]],ExpressionUUID->
  "ccbdbb65-c8ea-4ab3-8976-edc76e9d58b7"],
 "."
}], "TechNoteText",
 CellID->1546814909,ExpressionUUID->"083f24c8-77f1-4b65-afbd-185378794ff3"],

Cell[TextData[{
 "Note that both require an access to the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "4b0e7d7a-9bc9-42c6-a9f7-5ef6fe6667da"],
 " or the reflection about it."
}], "TechNoteText",
 CellID->2028628628,ExpressionUUID->"2aa35ed6-418f-4a62-b0d9-fd2bde7d257b"],

Cell[TextData[{
 "        However, the OAA lemma (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Berry et al., 2014"]], 
    "https://doi.org/10.1145/2591796.2591854"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "79f67824-1287-42f4-91ef-307a81d596c4"],
 ") asserts that the goal can be achieved by just repeatedly applying"
}], "TechNoteText",
 CellID->1710971024,ExpressionUUID->"b5b8a7d7-0c4e-4e26-b30f-a7df76caf9e0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "OAA"], ":=", 
    RowBox[{
     RowBox[{"-", "V"}], "\[VeryThinSpace]", 
     SubscriptBox["Z", "\[CapitalPi]"], "\[VeryThinSpace]", 
     SuperscriptBox["V", "\[Dagger]"], 
     SubscriptBox["Z", "\[CapitalPi]"]}]}], TraditionalForm]],ExpressionUUID->
  "a9dd988e-3407-44c3-ae2e-43f9f04fcf50"],
 "    with    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Z", "\[CapitalPi]"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", 
        TemplateBox[{
          SuperscriptBox["0", "m"]},
         "Ket"], 
        TemplateBox[{
          SuperscriptBox["0", "m"]},
         "Bra"]}], "-", 
       SubscriptBox["I", "m"]}], ")"}], "\[CircleTimes]", 
     SubscriptBox["I", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "22122a07-fd35-4fd2-a6c9-25ceee4944e2"],
 "."
}], "TechNoteText",
 CellID->1483967038,ExpressionUUID->"445740f8-dcdb-411f-8a78-fcaffffadd87"],

Cell[TextData[{
 "Here, the crucial point is that it does not require a copy (or knowledge) \
of the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "849fe182-f46c-4399-929a-361801d684c8"],
 " at all."
}], "TechNoteText",
 CellID->158931408,ExpressionUUID->"6408f49a-f047-4f46-994f-c079ae6a265a"],

Cell[TextData[{
 "To understand the OAA lemma, the key observation is that over the transform \
",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "1eb01fac-ef26-465d-926b-e791d0cfe53c"],
 " (and hence the OAA process), the state remains in the two-dimensional \
subspace spanned by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPhi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a5a04af7-f9e1-4a5f-9f1a-ad57744d291a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", 
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "77fa1d8d-0e1f-4884-96a1-62c307ba70c7"],
 " (",
 ButtonBox["Berry et al., 2014",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1145/2591796.2591854"], None},
  ButtonNote->"https://doi.org/10.1145/2591796.2591854"],
 ") as shown in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/AmplitudeAmplification#1519958685"],
 ". This can be clearly seen by recalling the unitary gate ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "5c98fcd2-cbe2-4c49-a5d2-54e3eb02bf1f"]
}], "TechNoteText",
 CellID->1838001035,ExpressionUUID->"e6052312-a801-4de7-aecb-842ecc37bbf6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[CapitalPhi]"},
       "Ket"], 
      SqrtBox["p"]}], "+", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
       "Ket"], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "6ab1ff8a-cf9b-44c4-b63f-3b27e67aa69d"],
 ", "
}], "TechNoteText",
 CellID->1878616797,ExpressionUUID->"2d00e3aa-dfef-45cf-aa4f-f4b38f6dee65"],

Cell[TextData[{
 "and defining a new state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SuperscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "32dfac2a-fdaa-4b3e-8d0b-30a38520e6b9"],
 " through"
}], "TechNoteText",
 CellID->1607928985,ExpressionUUID->"f10d7b2e-0242-48e5-9d9b-d1439b6f0ced"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", 
     TemplateBox[{
       SuperscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[CapitalPhi]"},
       "Ket"], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}], "-", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
       "Ket"], 
      SqrtBox["p"]}]}]}], TraditionalForm]],ExpressionUUID->
  "362e3269-c5b4-455b-9235-c24f4aac57ce"],
 "."
}], "TechNoteText",
 CellID->528237047,ExpressionUUID->"2ee2ff6a-a15d-4f00-88ab-2f971c8b4ac0"],

Cell[TextData[{
 "One can see that not only ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]", 
      SuperscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
     "BraKet"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "a68e514d-0cbb-4d35-94d5-cf77fb247090"],
 " but also ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPi]", 
     TemplateBox[{
       SuperscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
      "Ket"]}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "f4cf73cb-b807-4ab9-87e0-500e4380452a"],
 "; hence, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["Z", "\[CapitalPi]"], 
     TemplateBox[{
       SubscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
      "Ket"]}], "=", 
    RowBox[{"-", 
     TemplateBox[{
       SubscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "a3f3ad5f-655a-4717-9e82-5163920c650b"],
 ". Then, one can show that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[CapitalOmega]", "OAA", "k"], "V", 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"V", 
       TemplateBox[{"\[CapitalPsi]"},
        "Ket"], 
       RowBox[{"cos", "(", 
        RowBox[{"2", "k", "\[VeryThinSpace]", "\[Theta]"}], ")"}]}], "+", 
      RowBox[{"V", 
       TemplateBox[{
         SubscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
        "Ket"], 
       RowBox[{"sin", "(", 
        RowBox[{"2", "k", "\[VeryThinSpace]", "\[Theta]"}], ")"}]}]}], "=", 
     RowBox[{
      RowBox[{
       TemplateBox[{"\[CapitalPhi]"},
        "Ket"], 
       RowBox[{"sin", "(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "k"}], "+", "1"}], ")"}], "\[Theta]"}], ")"}]}], "+", 
      
      RowBox[{
       TemplateBox[{
         SubscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
        "Ket"], 
       RowBox[{"cos", "(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "k"}], "+", "1"}], ")"}], "\[Theta]"}], ")"}]}]}]}]}],
    TraditionalForm]],ExpressionUUID->
  "d75a04c3-4094-4876-8a67-5f2b576aad40"],
 "\[LineSeparator]with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"sin", "(", "\[Theta]", ")"}], ":=", 
    SqrtBox["p"]}], TraditionalForm]],ExpressionUUID->
  "a91cf0e3-9066-4d1c-996c-57f878e56091"],
 "."
}], "TechNoteText",
 CellID->382652231,ExpressionUUID->"552c3ea7-4474-4cf7-ac28-955bfd94cfe4"],

