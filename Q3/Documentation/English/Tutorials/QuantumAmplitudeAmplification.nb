 CellLabel->"Out[267]=",
 CellID->1753558182,ExpressionUUID->"30e5c606-babd-4c6f-8183-371a77258233"]
}, Open  ]],

Cell["\<\
If you apply the AA operator too many times, then the fidelity gets worse \
again:\
\>", "TechNoteMathCaption",
 CellID->1702758543,ExpressionUUID->"45f8e75a-0156-428a-9254-52584604b691"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mid", "=", 
   RowBox[{
    RowBox[{"MatrixPower", "[", 
     RowBox[{
      RowBox[{"N", "@", "AA"}], ",", "2"}], "]"}], ".", "out"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"fdl", "=", 
  RowBox[{
   RowBox[{"Fidelity", "[", 
    RowBox[{"good", ",", "mid"}], "]"}], "//", "N"}]}]}], "Input",
 CellLabel->"In[268]:=",
 CellID->65468293,ExpressionUUID->"9c595e28-c21a-4ed9-b332-cb1979ca197e"],

Cell[BoxData["0.15309310892394853`"], "Output",
 CellLabel->"Out[269]=",
 CellID->1234794999,ExpressionUUID->"ae854b27-4768-46a0-a3e3-74000202fefd"]
}, Open  ]],

Cell["Repeating the AA operation, the fidelity oscillates:", \
"TechNoteMathCaption",
 CellID->887215026,ExpressionUUID->"2e5ee3ed-0919-4b8f-82c8-9a9c857fe9cf"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mid", "=", 
   RowBox[{
    RowBox[{"MatrixPower", "[", 
     RowBox[{
      RowBox[{"N", "@", "AA"}], ",", "5"}], "]"}], ".", "out"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"fdl", "=", 
  RowBox[{
   RowBox[{"Fidelity", "[", 
    RowBox[{"good", ",", "mid"}], "]"}], "//", "N"}]}]}], "Input",
 CellLabel->"In[270]:=",
 CellID->976522519,ExpressionUUID->"a2535a5a-2863-482a-9b4c-559e1020f5ae"],

