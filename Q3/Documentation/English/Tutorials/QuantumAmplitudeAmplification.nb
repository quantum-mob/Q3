   RowBox[{"0.3043807145043603`", "\[VeryThinSpace]", "-", 
    RowBox[{"0.3966766701456176`", " ", "\[ImaginaryI]"}]}], ",", 
   RowBox[{"0.3043807145043603`", "\[VeryThinSpace]", "-", 
