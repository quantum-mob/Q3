Cell["Choose an initial state:", "TechNoteMathCaption",
 CellID->1689971758,ExpressionUUID->"9b187ec5-7954-40fa-b20a-f94c55b6a00a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}], "**", 
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "6"}], "]"}], "**", 
    RowBox[{"Ket", "[", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{"Matrix", "[", 
