Cell[CellGroupData[{

Cell["Oblivious Amplitude Amplification (OAA)", "TechNoteSection",
 CellID->635509592,ExpressionUUID->"ec252a39-e7d5-403e-8820-3fb56356b0e3"],

Cell["\<\
Oblivious amplitude amplification (OAA) is a generalization of the quantum \
amplitude amplification algorithm. Unlike the standard amplitude \
amplification, OAA does not require knowledge of the initial state or a full \
reflection about it. Instead, it amplifies the amplitude of a target state \
while handling scenarios where the initial state is unknown or \
\[OpenCurlyDoubleQuote]oblivious.\[CloseCurlyDoubleQuote]\
\>", "TechNoteText",
 CellID->162019086,ExpressionUUID->"4e50fea3-446f-4cfd-b9d4-c642fe01ad71"],

Cell[TextData[{
 "        Let ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "bacbd4cc-ede0-46c2-bcb5-7df0d9b74ca3"],
 " be a unitary operator on the quantum register of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "ee7a4df4-92e9-42eb-837a-c5998c8b36bf"],
 " qubits. Introduce an ancillary quantum register of ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "6d26443a-3e76-4ba5-8da5-9bf6244df09b"],
 " qubits, and let ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "69feced0-0878-453e-91ca-68c686e3a3c3"],
 " be a unitary gate on the overall quantum register such that"
}], "TechNoteText",
 CellID->1166117144,ExpressionUUID->"d2a693f3-1a2d-4122-9f20-981130b769f3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", "(", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["0", "m"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"\[Psi]"},
       "Ket"]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Ket"], "\[CircleTimes]", 
       RowBox[{"(", 
        RowBox[{"U", 
         TemplateBox[{"\[Psi]"},
          "Ket"]}], ")"}]}], 
      SqrtBox["p"]}], "+", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
       "Ket"], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "a5fd457f-f5a5-4905-bca5-a0e472d8c4cf"],
 ", "
}], "TechNoteText",
 CellID->45514006,ExpressionUUID->"4bf12d89-4f1f-498a-8bfe-34970f2a8a10"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ab60a728-9cec-402d-8a75-af017dd61137"],
 " is a normalized state that is not of our interest, such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPi]", 
     TemplateBox[{
       SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
      "Ket"]}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "bd03b9c0-7ad6-4e84-89fe-918f52e75885"],
 ", where\t"
}], "TechNoteText",
 CellID->449720510,ExpressionUUID->"19b2cad3-86a9-4b7c-bfa1-09278e6b0e6e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalPi]", ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Ket"], 
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Bra"]}], ")"}], "\[CircleTimes]", 
     SubscriptBox["I", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "3c62fe0b-e051-4a62-b9bd-4f1a1db5717f"],
 " \[LineSeparator]and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["I", "k"], TraditionalForm]],ExpressionUUID->
  "68e2b6a2-605f-405f-b91d-b9aedf776f61"],
 " denotes the identity matrix on ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "910c3aa2-bc93-43de-9c4a-00bf5c4c6aba"],
 " qubits, i.e., the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", "k"], "\[Times]", 
    SuperscriptBox["2", "k"]}], TraditionalForm]],ExpressionUUID->
  "026a5b69-aa8e-43a6-8089-3e594914d636"],
 " (not ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[Times]", "k"}], TraditionalForm]],ExpressionUUID->
  "7117264f-eef2-4d54-a207-d981af36c175"],
 ") identity matrix."
}], "TechNoteText",
 CellID->7974949,ExpressionUUID->"1f3878b2-106a-4faa-9630-1ff5b51524ad"],

Cell[TextData[{
 "In the matrix form, the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", 
     RowBox[{"m", "+", "n"}]], "\[Times]", 
    SuperscriptBox["2", 
     RowBox[{"m", "+", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "cab5f4e5-d085-4376-a06b-3f4064234a1e"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "a599a52f-d034-4a9e-baaf-92d668a30d38"],
 " is a ",
 ButtonBox["block encoding",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding"],
 " of the ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["2", "n"], "\[Times]", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "f24bfe12-38f5-4612-b246-fd01958a2b1b"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "60b775ae-af14-45b7-b218-2dde4f23f8bd"],
 ","
}], "TechNoteText",
 CellID->1154511227,ExpressionUUID->"6a9b4059-9a42-442e-90b3-440cd18982e0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{
         SqrtBox["p"], "U"}], "*"},
       {"*", "*"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6dff37b7-30c3-4d26-836d-819c6c79571e"],
 " ."
}], "TechNoteText",
 CellID->1457657777,ExpressionUUID->"11ee4dac-2912-46c4-9eaf-ff9328c4f9aa"],

Cell[TextData[{
 "Here, it is important that ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "202d7b3d-9fd6-4090-9fe8-dccb4460f578"],
 " is unitary. The goal is to increase the success probability for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SuperscriptBox["0", "m"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "49ea4696-72e0-4b84-9ace-f28a91be3b61"],
 " on the ancillary register."
}], "TechNoteText",
 CellID->360813063,ExpressionUUID->"1c780039-752e-445a-bbbe-f68ea6fbc4f3"],

Cell["        For later use, we define the product states", "TechNoteText",
 CellID->1710258253,ExpressionUUID->"90950644-702d-45f8-9f4a-d51cbd5f5dc0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SuperscriptBox["0", "m"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"\[Psi]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "5eab6068-9c09-4ef0-9e6d-d57682aab314"],
 "  ,       ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPhi]"},
     "Ket"], ":=", 
    RowBox[{
     TemplateBox[{
       SuperscriptBox["0", "m"]},
      "Ket"], "\[CircleTimes]", 
     RowBox[{"(", 
      RowBox[{"U", 
       TemplateBox[{"\[Psi]"},
        "Ket"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "90389a91-f27e-4939-ba3e-6ea461ed9a61"]
}], "TechNoteText",
 CellID->1161918896,ExpressionUUID->"bcc3e911-7478-49c2-b891-ceedbfaa6304"],

Cell[TextData[{
 "so that the operation of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "bd040722-433b-4536-a8f8-d652675a284f"],
 " reads as"
}], "TechNoteText",
 CellID->1840366080,ExpressionUUID->"07776871-e149-4191-b8cc-bd45fe844268"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[CapitalPhi]"},
       "Ket"], 
      SqrtBox["p"]}], "+", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
       "Ket"], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "23309d2e-7b7c-4cc4-9a58-9583778c56d6"],
 "."
}], "TechNoteText",
 CellID->960150010,ExpressionUUID->"6e9ff7ce-bbf6-41ca-85f2-a98f52dd0582"],

Cell["\<\
        If you follow the standard amplitude amplification idea in the above, \
you need an oracle\
\>", "TechNoteText",
 CellID->1838814360,ExpressionUUID->"9a40c426-9692-48a2-91a8-7c4870b16fb2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["I", "m"], "\[CircleTimes]", "U"}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["I", 
       RowBox[{"m", "+", "n"}]], "-", 
      RowBox[{"2", 
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Ket"], 
       RowBox[{
        TemplateBox[{
          SuperscriptBox["0", "m"]},
         "Bra"], "\[CircleTimes]", 
        TemplateBox[{"\[Psi]"},
         "Ket"]}], 
       TemplateBox[{"\[Psi]"},
        "Bra"]}]}], ")"}], 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["I", "m"], "\[CircleTimes]", 
      SuperscriptBox["U", "\[Dagger]"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"36a96bb5-d797-4ef2-a40d-65564c9c9ce3"]
}], "TechNoteText",
 CellID->515784543,ExpressionUUID->"a880ee34-43d0-4c5d-bb37-7237c7072f7b"],

Cell[TextData[{
 "and the reflection in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", 
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "b756ea7b-9b10-4549-86a4-d2ca951c5573"],
 ",\n\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", "(", 
     RowBox[{
      RowBox[{"2", 
       TemplateBox[{
         SuperscriptBox["0", "m"]},
        "Ket"], 
       RowBox[{
        TemplateBox[{
          SuperscriptBox["0", "m"]},
         "Bra"], "\[CircleTimes]", 
        TemplateBox[{"\[Psi]"},
         "Ket"]}], 
       TemplateBox[{"\[Psi]"},
        "Bra"]}], "-", 
      SubscriptBox["I", 
       RowBox[{"m", "+", "n"}]]}], ")"}], 
    SuperscriptBox["V", "\[Dagger]"]}], TraditionalForm]],ExpressionUUID->
  "810c70bf-3db6-4f96-bf73-1da18cbacdb5"],
 "."
}], "TechNoteText",
 CellID->1546814909,ExpressionUUID->"52332475-4aa6-41d8-a28a-e6ce661fa986"],

Cell[TextData[{
 "Note that both require an access to the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a7152ba3-afae-488b-8e67-fdeeb472b80b"],
 " or the reflection about it."
}], "TechNoteText",
 CellID->2028628628,ExpressionUUID->"3a732b96-83b3-461e-8858-e4b5426c482f"],

Cell[TextData[{
 "        However, the OAA lemma (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Berry et al., 2014"]], 
    "https://doi.org/10.1145/2591796.2591854"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "68b62541-f0ff-42ab-b2a3-18c777a19d37"],
 ") asserts that the goal can be achieved by just repeatedly applying"
}], "TechNoteText",
 CellID->1710971024,ExpressionUUID->"c0709518-68a5-40cb-9874-72313e5aa9d9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "OAA"], ":=", 
    RowBox[{
     RowBox[{"-", "V"}], "\[VeryThinSpace]", 
     SubscriptBox["Z", "\[CapitalPi]"], "\[VeryThinSpace]", 
     SuperscriptBox["V", "\[Dagger]"], 
     SubscriptBox["Z", "\[CapitalPi]"]}]}], TraditionalForm]],ExpressionUUID->
  "e8be5427-1fdb-47ee-a371-dd00f36fabe9"],
 "    with    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Z", "\[CapitalPi]"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", 
        TemplateBox[{
          SuperscriptBox["0", "m"]},
         "Ket"], 
        TemplateBox[{
          SuperscriptBox["0", "m"]},
         "Bra"]}], "-", 
       SubscriptBox["I", "m"]}], ")"}], "\[CircleTimes]", 
     SubscriptBox["I", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "edb15519-675d-43fe-a3ce-4878eba4f766"],
 "."
}], "TechNoteText",
 CellID->1483967038,ExpressionUUID->"134983eb-6b72-4668-8180-030578bf3cb4"],

Cell[TextData[{
 "Here, the crucial point is that it does not require a copy (or knowledge) \
of the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a8b16091-eb02-4e5d-b9e2-1055fa10837b"],
 " at all."
}], "TechNoteText",
 CellID->158931408,ExpressionUUID->"e8cfc885-6c3c-40fe-81bf-f78716a63008"],

Cell[TextData[{
 "To understand the OAA lemma, the key observation is that over the transform \
",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "e1cf82c9-670b-475b-952f-b80392881f41"],
 " (and hence the OAA process), the state remains in the two-dimensional \
subspace spanned by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPhi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ee3d2154-c675-4dbb-aef9-b416204dedf6"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", 
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "a8681e29-4867-4b73-b634-ce8bfa85a8f9"],
 " (",
 ButtonBox["Berry et al., 2014",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1145/2591796.2591854"], None},
  ButtonNote->"https://doi.org/10.1145/2591796.2591854"],
 ") as shown in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/AmplitudeAmplification#1519958685"],
 ". This can be clearly seen by recalling the unitary gate ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "80066ff0-3d9e-4212-81f7-06a5e417f8b3"]
}], "TechNoteText",
 CellID->1838001035,ExpressionUUID->"772f192b-001e-4306-9c69-bb6eb87bc848"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[CapitalPhi]"},
       "Ket"], 
      SqrtBox["p"]}], "+", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
       "Ket"], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "2bf5dc1a-7a3a-472b-b8c1-ccf31d4c16a2"],
 ", "
}], "TechNoteText",
 CellID->1878616797,ExpressionUUID->"afec3c4f-0f38-4356-b567-c30ff20c966e"],

Cell[TextData[{
 "and defining a new state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SuperscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "c22d0f8e-cc50-4a23-966a-5c4826f29507"],
 " through"
}], "TechNoteText",
 CellID->1607928985,ExpressionUUID->"126f0a47-945b-4f53-979d-7db0c37235e4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"V", 
     TemplateBox[{
       SuperscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\[CapitalPhi]"},
       "Ket"], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}], "-", 
     RowBox[{
      TemplateBox[{
        SuperscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
       "Ket"], 
      SqrtBox["p"]}]}]}], TraditionalForm]],ExpressionUUID->
  "5f76e90e-24bf-48ca-87d3-93f4b9a2a119"],
 "."
}], "TechNoteText",
 CellID->528237047,ExpressionUUID->"a2383205-80f9-4236-ad39-ae289bc0962c"],

Cell[TextData[{
 "One can see that not only ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]", 
      SuperscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
     "BraKet"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "4c8d21a7-d74c-4386-b7d0-9efb3d591e6f"],
 " but also ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPi]", 
     TemplateBox[{
       SuperscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
      "Ket"]}], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "ba1bdc13-4b1d-442e-882b-cdc997f3cbc0"],
 "; hence, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["Z", "\[CapitalPi]"], 
     TemplateBox[{
       SubscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
      "Ket"]}], "=", 
    RowBox[{"-", 
     TemplateBox[{
       SubscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "4141e811-de24-4b93-9cef-31eea1096443"],
 ". Then, one can show that\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[CapitalOmega]", "OAA", "k"], "V", 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"V", 
       TemplateBox[{"\[CapitalPsi]"},
        "Ket"], 
       RowBox[{"cos", "(", 
        RowBox[{"2", "k", "\[VeryThinSpace]", "\[Theta]"}], ")"}]}], "+", 
      RowBox[{"V", 
       TemplateBox[{
         SubscriptBox["\[CapitalPsi]", "\[Perpendicular]"]},
        "Ket"], 
       RowBox[{"sin", "(", 
        RowBox[{"2", "k", "\[VeryThinSpace]", "\[Theta]"}], ")"}]}]}], "=", 
     RowBox[{
      RowBox[{
       TemplateBox[{"\[CapitalPhi]"},
        "Ket"], 
       RowBox[{"sin", "(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "k"}], "+", "1"}], ")"}], "\[Theta]"}], ")"}]}], "+", 
      
      RowBox[{
       TemplateBox[{
         SubscriptBox["\[CapitalPhi]", "\[Perpendicular]"]},
        "Ket"], 
       RowBox[{"cos", "(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "k"}], "+", "1"}], ")"}], "\[Theta]"}], ")"}]}]}]}]}],
    TraditionalForm]],ExpressionUUID->
  "48a61bf9-e9fa-4259-bf66-6bce0222552e"],
 "\[LineSeparator]with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"sin", "(", "\[Theta]", ")"}], ":=", 
    SqrtBox["p"]}], TraditionalForm]],ExpressionUUID->
  "2244e390-4780-4610-8af0-fbd2e2d0dd74"],
 "."
}], "TechNoteText",
 CellID->382652231,ExpressionUUID->"34ec0b87-af2d-485d-b597-a4c51475cada"],

