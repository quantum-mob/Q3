 CellLabel->"Out[397]=",
 CellID->608596782,ExpressionUUID->"b6585ce8-c74c-4cd4-b0ad-6b15ba1d24df"]
}, Open  ]],

Cell["Check the result.", "TechNoteMathCaption",
 CellID->2073812678,ExpressionUUID->"3d3e88d0-ee0e-42dd-b976-d0fde71bc2d1"],

