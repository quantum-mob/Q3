Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["U", "x"], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["U", 
        SuperscriptBox["2", 
         RowBox[{"n", "-", "1"}]]], ")"}], 
      SubscriptBox["x", "1"]], 
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["U", 
        SuperscriptBox["2", 
         RowBox[{"n", "-", "2"}]]], ")"}], 
      SubscriptBox["x", "1"]], 
     SuperscriptBox[
      RowBox[{"\[Ellipsis]", "(", 
       SuperscriptBox["U", 
        SuperscriptBox["2", "0"]], ")"}], 
      SubscriptBox["x", "n"]]}]}], TraditionalForm]],ExpressionUUID->
  "f44922eb-fa25-452d-a266-64bc9f6f2a40"],
 " ."
}], "TechNoteText",
 CellID->2034215257,ExpressionUUID->"97c0a2c3-d985-4971-aaf8-07a0a66f5e6e"],

