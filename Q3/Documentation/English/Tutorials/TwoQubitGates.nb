    RowBox[{
     RowBox[{
      RowBox[{"Ket", "[", "]"}], 
      RowBox[{"c", "[", "0", "]"}]}], "+", 
     RowBox[{
      RowBox[{"Ket", "[", 
       RowBox[{
        RowBox[{"S", "[", "1", "]"}], "->", "1"}], "]"}], 
      RowBox[{"c", "[", "1", "]"}]}]}], "//", "KetRegulate"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"op", "**", "in"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"in", "->", "out"}], "//", "KetFactor"}]}], "Input",
 CellLabel->"In[289]:=",
 CellID->291014636,ExpressionUUID->"42464e77-d8eb-4b11-b6f5-9f3bbcc3b2dd"],

