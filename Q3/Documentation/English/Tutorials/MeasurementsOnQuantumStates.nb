Cell[TextData[{
 "It is instructive to expand the interaction unitary operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "a62b8fdb-6c74-4b93-af85-f63b263cdf2a"],
 " int using the spectral decomposition of the observable ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "2488cc02-d288-4c93-97a9-5e210f7bd166"],
 " as"
}], "TechNoteText",
 CellID->798213346,ExpressionUUID->"b05c44f3-5a28-4202-89ac-7adea36d3969"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "int"], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "a"], 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", "g", " ", "a", " ", "P"}]], "\[CircleTimes]", 
       TemplateBox[{"a"},
        "Ket"]}], 
      TemplateBox[{"a"},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c4dc3076-c250-483b-8e2b-415230723d06"]
}], "TechNoteText",
 CellID->241363413,ExpressionUUID->"9eb04c1f-3c57-4476-b3cd-377c9abde6dd"],

Cell[TextData[{
 "The operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["T", "a"], ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], " ", "g", " ", "a", " ", "P"}], ")"}]}],
    TraditionalForm]],ExpressionUUID->
  "782ab343-f8d2-41fd-b36c-1fccef04e86c"],
 " represents the translation by an amount ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", " ", "a"}], TraditionalForm]],ExpressionUUID->
  "f453838e-873f-4590-96b6-0c9a138d81e4"],
 " depending on eigenvalue ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "d49c7b6e-f8d1-4b3d-b5ee-3c0497491189"],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "e8e3f556-7b85-4ca0-8261-401fb90b93ae"],
 ". To clarify the physical interpretation, we rewrite the interaction\n \
unitary operator into"
}], "TechNoteText",
 CellID->2145756755,ExpressionUUID->"0c512109-7f3b-4946-ae95-df2717f6978b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "int"], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "a"], 
     RowBox[{
      RowBox[{
       SubscriptBox["T", "a"], "\[CircleTimes]", 
       TemplateBox[{"a"},
        "Ket"]}], 
      TemplateBox[{"a"},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "e74a761e-3aec-4a21-b1d0-d45502e357d2"],
 "."
}], "TechNoteText",
 CellID->1040897214,ExpressionUUID->"a6a3f7b8-07cc-4b73-b4c3-f7f3786b0472"],

