Cell["\<\
After the interaction, the state vector of the total system becomes\
\>", "TechNoteText",
 CellID->1624318944,ExpressionUUID->"4371c3d7-bb55-475e-96b5-cc7fe208707e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "int"], 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Sum]", "a"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["T", "a"], 
         TemplateBox[{"\[Xi]"},
          "Ket"]}], ")"}], "\[CircleTimes]", 
       RowBox[{"(", 
        RowBox[{
         TemplateBox[{"a"},
          "Ket"], 
         SubscriptBox["\[Psi]", "a"]}], ")"}]}]}], "=", 
     RowBox[{"\[Integral]", 
      RowBox[{"d", " ", "x", " ", 
       RowBox[{
        TemplateBox[{"x"},
         "Ket"], "\[CircleTimes]", 
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["\[Sum]", "a"], 
          RowBox[{
           TemplateBox[{"a"},
            "Ket"], 
           RowBox[{"\[Xi]", "(", 
            RowBox[{"x", "-", 
             RowBox[{"g", " ", "a"}]}], ")"}], 
           SubscriptBox["\[Psi]", "a"]}]}], ")"}]}]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"c4552be0-17ca-47fe-86fe-c4451529cc42"],
 "."
}], "TechNoteText",
 CellID->1116371144,ExpressionUUID->"57012034-6aa6-48c0-99cf-0120b5d629ef"],

Cell[TextData[{
 "In general, the final state is an entangled state. The probability to \
register ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "e832f146-017c-45c8-b36b-8ba58619c811"],
 " out of the measurement on the measurement device is given by"
}], "TechNoteText",
 CellID->285193369,ExpressionUUID->"53094020-7daa-4a24-bfea-831322dfe1d8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "x", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "a"], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"\[Xi]", "(", 
         RowBox[{"x", "-", 
          RowBox[{"g", " ", "a"}]}], ")"}], "\[RightBracketingBar]"}], "2"], 
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["\[Psi]", "a"], "\[RightBracketingBar]"}], "2"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"c4c5ae36-bd05-4be4-87b5-6cead3102b08"],
 "."
}], "TechNoteText",
 CellID->61452679,ExpressionUUID->"3c2b23f2-1761-48c2-ab7f-4ae3e5723734"],

Cell[TextData[{
 "When the system starts from a definite eigenstate ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"a"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "d646b28c-f520-49e3-b7d3-8a248ad47529"],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "e633f6a6-6125-44ee-9f7f-c17489e43495"],
 ", the system and the measurement device remain separable after the \
system-measurement device interaction, with its probability distribution \
determined solely by the given eigenvalue ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "2bfee3ac-68dc-4800-be64-0dc663378702"]
}], "TechNoteText",
 CellID->2043025393,ExpressionUUID->"2bf49091-00c8-4bc6-80b4-cbb69d1a2e99"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"P", "(", "x", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "a"], 
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"\[Xi]", "(", 
        RowBox[{"x", "-", 
         RowBox[{"g", " ", "a"}]}], ")"}], "\[RightBracketingBar]"}], 
      "2"]}]}], TraditionalForm]],ExpressionUUID->
  "dce9a869-c021-4133-974d-b0b34744e224"],
 "."
}], "TechNoteText",
 CellID->1011748268,ExpressionUUID->"cea09ffd-7f85-47b4-b4a3-005c94cfaedc"],

Cell[TextData[{
 "Manifestly, the measurement accuracy is best in this case. \nAs illustrated \
in Figure 1 below, one can extract eigenvalue ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "c49966f3-547d-460a-bc9a-7eabc3e5b282"],
 " of the observable from the amount of translation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", " ", "a"}], TraditionalForm]],ExpressionUUID->
  "57192bd3-6cc6-4fb5-9661-52f6b82779ed"],
 " of the final wave function relative to the initial wave function assuming \
that coupling strength ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]],ExpressionUUID->
  "3a73c6f6-1d85-4d48-8e59-15eb8880f5a2"],
 " is known (it can be calibrated separately)."
}], "TechNoteText",
 CellID->677623330,ExpressionUUID->"f1eea986-a741-417d-ac15-be835bbac1d3"],

Cell[BoxData[
 RowBox[{"(", 
  RowBox[{
   RowBox[{"...", " ", "figure"}], " ", "..."}], ")"}]], "TechNoteText",
 TextAlignment->Center,
 CellID->709527269,ExpressionUUID->"5cfd4cfe-0375-4ee6-ba2d-f6bba3275d23"],

Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Change in the wave function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Xi]", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "bb27387b-2baa-46d0-907a-f4985ac34b44"],
 " of the measurement device from the initial state (blue) to the final state \
(orange) after it interacts with the system. This case illustrates a system \
in a definite eigenstate ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"a"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e9914908-1e8c-4b07-866b-7e4594242426"],
 " of the observable ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "1d6f0069-6fa3-4177-9885-7e2a89393b72"],
 " under measurement. The amount of translation is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", " ", "a"}], TraditionalForm]],ExpressionUUID->
  "fc523a49-2cf3-4f2e-b699-6eb39f9e4199"],
 ", the coupling constant times the eigenvalue associated with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"a"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "bd217c5d-0b9a-472c-98ed-93250c3d1326"],
 "."
}], "TechNoteCaption",
 CellID->48118292,ExpressionUUID->"a31bf32b-3cb7-47ad-83e6-5a64d78eef08"],

Cell[TextData[{
 "Figure 1 suggests that a sharper initial wave function of the measurement \
device results in a more precise extraction of the value of a. Roughly \
speaking, this is indeed one direction of the efforts to improve the \
precision of measurement (Caves, 1981). An obstacle directly apparent in the \
above figure to achieve precise measurement is the inherent statistical \
nature of quantum mechanics. Given that the probability distribution has \
finite width, any measurement in quantum mechanics should be repeated many \
times. The statistical error decreases as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "/", 
    SqrtBox["N"]}], TraditionalForm]],ExpressionUUID->
  "6efe46bd-0f29-4d2e-9e1c-82f39c2088ee"],
 " with the increasing number ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "48f4686d-ef21-489e-8dd2-288efd168eaf"],
 " of repeated measurements. This is called the ",
 StyleBox["standard quantum limit",
  FontSlant->"Italic"],
 ". Interestingly, if one prepares a set of measurement devices in a proper \
entangled state, one can improve the statistical error to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "/", "N"}], TraditionalForm]],ExpressionUUID->
  "ee91ce0c-8382-4845-9074-01fa7a2462cb"],
 " (Giovannetti et al., 2006). This enhanced accuracy due to quantum \
entanglement is called the ",
 StyleBox["Heisenberg limit",
  FontSlant->"Italic"],
 ", and it puts the ultimate limit on the measurement precision that quantum \
mechanics allows."
}], "TechNoteText",
 CellID->1270282372,ExpressionUUID->"b2e29875-95e0-4ac4-ab54-36457bfb632d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Generalized Measurements", "TechNoteSection",
 CellTags->"Section25",
 CellID->406380704,ExpressionUUID->"94af19f1-1619-4fe7-992a-394619040ca5"],

Cell[TextData[{
 "Concerning measurement, we introduced Postulate 3 in its usual form as \
discussed in most textbooks on quantum mechanics. However, in quantum \
information context and for various reasons to be discussed shortly, it is \
convenient to provided a generalized form of ",
 ButtonBox["Postulate 3",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MeasurementsOnQuantumStates#1477689096"],
 "."
}], "TechNoteText",
 CellID->1172578227,ExpressionUUID->"6da35f44-425f-479f-9240-fa09972317fd"],

Cell[TextData[{
 StyleBox["Postulate ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["3", "\[Prime]"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"14ce7c42-580b-46bf-8445-b8787f0cf753"],
 ". A generalized measurement is described by a set of measurement operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "m"], TraditionalForm]],ExpressionUUID->
  "ecf0fc73-cf4d-420f-9768-bbc8aebc8eee"],
 " corresponding to measurement outcomes ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "ea317b11-91ad-4742-8f76-b53a7a1718aa"],
 " that satisfy the completeness relation"
}], "TechNoteText",
 CellID->64832670,ExpressionUUID->"5a404f7a-6486-4f44-babe-5d9a44b34ad8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Sum]", "m"], 
     RowBox[{
      SubsuperscriptBox["M", "m", "\[Dagger]"], 
      SubscriptBox["M", "m"]}]}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"931a6c3c-49c8-4b82-bf4a-4a1774bab764"],
 ". "
}], "TechNoteText",
 CellID->868475661,ExpressionUUID->"9c623abf-3203-4c88-a9cd-f7b948501b92"],

Cell[TextData[{
 "Suppose that right before the measurement, the system is in the quantum \
state \[Rho]. Then the probability ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "m"], TraditionalForm]],ExpressionUUID->
  "c06ef78d-8484-4a8a-8ca4-06c45b1a0097"],
 " for outcome ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "382826be-7879-49c7-bb47-90b9c73d1445"],
 " is given by"
}], "TechNoteText",
 CellID->24085768,ExpressionUUID->"c58f285d-7f51-4a95-8b51-08246acc9744"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "m"], "=", 
    RowBox[{"Tr", " ", 
     SubscriptBox["M", "m"], "\[Rho]", " ", 
     SubsuperscriptBox["M", "m", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"bffed5a9-2ad4-4aa9-943f-c803b373a387"],
 ","
}], "TechNoteText",
 CellID->1082577140,ExpressionUUID->"bff2cd96-8850-4f34-b67a-c61d244a8132"],

Cell["and the state right after the measurement becomes", "TechNoteText",
 CellID->1392534596,ExpressionUUID->"82e1808f-35d2-40de-908b-736db3bbb5f4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SubscriptBox["P", "m"]], 
     SubscriptBox["M", "m"], "\[Rho]", " ", 
     SubsuperscriptBox["M", "m", "\[Dagger]"]}], "=", 
    FractionBox[
     RowBox[{
      SubscriptBox["M", "m"], "\[Rho]", " ", 
      SubsuperscriptBox["M", "m", "\[Dagger]"]}], 
     RowBox[{"Tr", " ", 
      SubscriptBox["M", "m"], "\[Rho]", " ", 
      SubsuperscriptBox["M", "m", "\[Dagger]"]}]]}], TraditionalForm]],
  ExpressionUUID->"bfe487bc-19cd-4466-8692-0011ca200bba"],
 "."
}], "TechNoteText",
 CellID->1052169966,ExpressionUUID->"318edb27-a274-4b33-a2f9-b31b0f1f48c6"],

Cell[TextData[{
 "\tThe ",
 ButtonBox["projective measurement",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MeasurementsOnQuantumStates#1477689096"],
 " discussed previously is a special case of the generalized measurement. \
Suppose that we measure an observable ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "0374c45f-bade-4919-a8c9-dabb83097b20"],
 ". In this case, the available measurement outcomes are eigenvalues ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "2dd842fc-8cec-43ef-90eb-a2cca14152cc"],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "389c27e5-b382-4bb7-9f03-0bde2d7f7914"],
 ". The measurement operator corresponding to outcome ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "4ac27367-de80-4fb1-a2dc-a59bb17d83f3"],
 " is the projection operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"a"},
     "Ket"], 
    TemplateBox[{"a"},
     "Bra"]}], TraditionalForm]],ExpressionUUID->
  "3bdac02d-40ee-40e5-b597-51c4377c2673"],
 " onto the eigenstate |a\[RightAngleBracket] belonging to eigenvalue ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],ExpressionUUID->
  "3545d50f-fd58-4c9b-af94-6b33accd17f9"],
 "."
}], "TechNoteText",
 CellID->1440269164,ExpressionUUID->"66f80021-30fe-4bb2-ace0-393dd6ed7413"],

Cell[TextData[{
 "In general, the physical meaning of the measurement operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "m"], TraditionalForm]],ExpressionUUID->
  "374ce539-5286-4099-96a7-986f1fdb256e"],
 " is not immediately clear until the specifics of the measurement in \
question are narrated. It is even more difficult to determine the setup of a \
physical device for the measurement described by the given set of operators \
",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "m"], TraditionalForm]],ExpressionUUID->
  "a6c51315-08ef-4eab-8aec-79859aefe409"],
 ". Nevertheless, one can show that generalized measurements are equivalent \
to ",
 ButtonBox["projective measurements",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/MeasurementsOnQuantumStates#1477689096"],
 " (extended to a larger system and supplemented with additional unitary \
operations). In many applications, however, generalized measurements are more \
convenient because they are less restrictive."
}], "TechNoteText",
 CellID->168170364,ExpressionUUID->"d2294828-8ca8-430e-948a-9ec4cdf654c5"],

Cell[TextData[{
 "For example, consider a fixed set of ",
 StyleBox["orthogonal",
  FontSlant->"Italic"],
 " quantum states ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Psi]", "1"]},
     "Ket"], ",", " ", 
    TemplateBox[{
      SubscriptBox["\[Psi]", "2"]},
     "Ket"], ",", " ", "\[Ellipsis]", ",", " ", 
    TemplateBox[{
      SubscriptBox["\[Psi]", "n"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "058c3da5-2ff8-4502-8d3e-ad60d3342a83"],
 " (not necessarily spanning the Hilbert space). Suppose that a state is \
drawn from the set. The task is to tell which of the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "65ca087e-79e0-41ed-8c3f-9fd7959de86a"],
 " states it is. We proceed by defining ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "edceb89b-735e-48ae-ae6e-895c9ad363d6"],
 " operators"
}], "TechNoteText",
 CellID->350828296,ExpressionUUID->"4a7546d3-5812-4371-b5ae-d0e6cb088e61"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "k"], ":=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "k"]},
      "Ket"], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "k"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "2b46d0ef-5f83-4f3f-bc7a-24e92878674d"]
}], "TechNoteText",
 CellID->1528559857,ExpressionUUID->"389bc698-e814-49db-8c90-92809f5de999"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", "n"}], 
   TraditionalForm]],ExpressionUUID->"c679c93e-b898-4c63-bfca-2215c64d2ca4"],
 " and an additional operator"
}], "TechNoteText",
 CellID->158647538,ExpressionUUID->"76487e60-c0b3-41a8-81a2-18549b633076"],

Cell[TextData[{
 " \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "0"], ":=", 
    RowBox[{"I", "-", 
     RowBox[{
      SubscriptBox["\[Sum]", "k"], 
      SubscriptBox["M", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "adbbe14b-f764-4f4e-93b1-dc455e8665c5"],
 "."
}], "TechNoteText",
 CellID->1361965239,ExpressionUUID->"43104717-e4a2-47fa-9799-1e2053027d78"],

Cell[" They satisfy the completeness relation", "TechNoteText",
 CellID->521578500,ExpressionUUID->"6527f896-fb35-4afa-ab65-f1c9678b07e4"],

Cell[TextData[{
 " \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Sum]", "k"], 
     RowBox[{
      SubsuperscriptBox["M", "k", "\[Dagger]"], 
      SubscriptBox["M", "k"]}]}], "=", "I"}], TraditionalForm]],
  ExpressionUUID->"927b8ba8-2867-4937-8089-661bfd7a4e45"]
}], "TechNoteText",
 CellID->141602446,ExpressionUUID->"76f22694-6695-4e6c-a77c-336a94d9b444"],

Cell[TextData[{
 " and describe a measurement. Now when a particular state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Psi]", "k"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "dbd4b84c-d914-4e9d-9603-ba93dbb79aab"],
 " is taken, the probability\n",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "\[Placeholder]"], TraditionalForm]],ExpressionUUID->
  "434f36ff-bd18-4ed1-a389-87cb43f71e3f"],
 " for measurement outcome ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "2d14fe0a-6937-4b40-b5c8-457532555694"],
 " is unity because"
}], "TechNoteText",
 CellID->500429046,ExpressionUUID->"9b63f3cf-15f6-4ccd-bd40-f4ee748c1241"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "k"], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Psi]", "k"]},
      "Bra"], 
     SubscriptBox["M", "k"], 
     TemplateBox[{
       SubscriptBox["\[Psi]", "k"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "d191db46-515a-48c1-b4aa-a55330cb768b"],
 "."
}], "TechNoteText",
 CellID->1165014470,ExpressionUUID->"7f44afca-5619-4d1b-9e60-eb6292ddea2e"],

Cell[CellGroupData[{

Cell["POVM", "Subsection",
 CellTags->"Section27",
 CellID->1789787591,ExpressionUUID->"ebb00cfe-80be-4341-800e-6617d91f745c"],

Cell[TextData[{
 "Postulates 3 and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["3", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "cb36cd19-fc73-40a8-90c1-ce42fa1cfa58"],
 " describe not only the probability for a particular measurement outcome but \
also the post-measurement state corresponding to the outcome after the \
measurement. However, many experiments probe the system only once, and the \
state after the measurement is irrelevant. Of primary concern are the \
probabilities. Often, it is even impossible to assign a post-measurement \
state to the system. For example, in an experiment to measure the position of \
photon, the photon is destroyed at the photo-screen, and it is meaningless to \
ask about the wave function of the photon after the measurement."
}], "TechNoteText",
 CellID->1156598408,ExpressionUUID->"6100361c-de32-4e80-be64-31c87b27ca3b"],

Cell[TextData[{
 "As long as one is focused on the probabilities, the description in \
Postulate ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["3", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "9c806930-7e0c-4876-a6c0-1d011864b98e"],
 " can be drastically simplified: Since the trace is invariant under cyclic \
permutation of the operators, the probability for the outcome ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "ed93a0dd-5d31-4db3-8de2-457c6baa803a"],
 " is given by"
}], "TechNoteText",
 CellID->2074954259,ExpressionUUID->"830a4bd9-cc13-49f4-b72d-b5346104425c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "m"], "=", 
    RowBox[{
     RowBox[{"Tr", " ", 
      SubscriptBox["M", "m"], "\[Rho]", " ", 
      SubsuperscriptBox["M", "m", "\[Dagger]"]}], "=", 
     RowBox[{"Tr", " ", 
      SubsuperscriptBox["M", "m", "\[Dagger]"], 
      SubscriptBox["M", "m"], "\[Rho]", " "}]}]}], TraditionalForm]],
  ExpressionUUID->"5a18f4c0-4f2f-428f-b84b-6289bbb91dc0"],
 "."
}], "TechNoteText",
 CellID->769287380,ExpressionUUID->"5de62e71-24e1-4b28-8e41-0f23c94ec3d6"],

Cell["\<\
Therefore, as far as the probabilities are concerned, all we need are the \
operators\
\>", "TechNoteText",
 CellID->1561440720,ExpressionUUID->"56d9c059-5af1-46cc-bb5b-0227958586a7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "m"], ":=", 
    RowBox[{
     SubsuperscriptBox["M", "m", "\[Dagger]"], 
     SubscriptBox["M", "m"]}]}], TraditionalForm]],ExpressionUUID->
  "ecba81f2-6af2-4eaa-b0ff-52a661ec1775"]
}], "TechNoteText",
 CellID->884014700,ExpressionUUID->"ffa5db96-fee1-4ab4-b7a9-c85a10b36d77"],

Cell[TextData[{
 "rather than the measurement operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "m"], TraditionalForm]],ExpressionUUID->
  "232ff703-657f-4f61-972a-b52ba07e59df"],
 ". Note that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "m"], TraditionalForm]],ExpressionUUID->
  "95e88b66-73b7-421a-83ac-453ec992ddc8"],
 " may contain far more details that cannot be extracted from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "m"], TraditionalForm]],ExpressionUUID->
  "0218588d-1998-4e5d-b436-deddbd46cae1"],
 ". Infinitely many distinct measurement operators can lead to the same ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "m"], TraditionalForm]],ExpressionUUID->
  "a1b0e500-c694-42d3-b394-1b0fe48b9ab4"],
 ". Nevertheless, it is possible to discard certain details in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "m"], TraditionalForm]],ExpressionUUID->
  "3256910f-dd53-4352-8fbf-3531fb00ad09"],
 " for more compact operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "m"], TraditionalForm]],ExpressionUUID->
  "6c4d46ba-bc31-4fc0-ba01-f555c7b20ca9"],
 " because we do not care about the post-measurement state. By construction, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "m"], TraditionalForm]],ExpressionUUID->
  "25a0c1d6-5ac6-4765-9c36-f6c2f1098d52"],
 " are positive semi-definite operators and satisfy"
}], "TechNoteText",
 CellID->1343192954,ExpressionUUID->"ca4240f4-780e-4d7e-a603-731fba2c79e4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Sum]", "m"], 
     SubscriptBox["E", "m"]}], "=", "I"}], TraditionalForm]],ExpressionUUID->
  "cc5817c0-0046-421d-b2b3-7f4773605976"],
 "."
}], "TechNoteText",
 CellID->695880614,ExpressionUUID->"9623a32d-d2af-4b68-b0e0-a6488e0efa0c"],

Cell[TextData[{
 "The set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["E", "m"], "}"}], TraditionalForm]],ExpressionUUID->
  "a7ee1f14-b8e7-4342-af26-f3146947dd99"],
 " of such operators is called a ",
 StyleBox["positive operator-valued measure",
  FontSlant->"Italic"],
 " or more often a ",
 StyleBox["POVM",
  FontSlant->"Italic"],
 ". The individual operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "m"], TraditionalForm]],ExpressionUUID->
  "0d40733f-44cb-458c-9a87-64e63231d688"],
 " are called ",
 StyleBox["POVM elements",
  FontSlant->"Italic"],
 ". For many experiments, the POVM formalism allows far more efficient \
description of the measurement."
}], "TechNoteText",
 CellID->469537936,ExpressionUUID->"7dedf968-ca1f-472e-a086-4bb763f11881"],

Cell["\<\
As a non-trivial example of the application of the POVM formalism, let us \
consider the problem of quantum state discrimination of non-orthogonal \
quantum states (Bergou et al., 2004; Chefles, 2004). To be specific, suppose \
that we are given either of the two states\
\>", "TechNoteText",
 CellID->1669171274,ExpressionUUID->"2729d224-b9b9-4690-8f44-5498b16fdee8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"v"},
     "Ket"], "=", 
    TemplateBox[{"0"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "3595ce6f-e99e-460c-af19-91b4d7d481b8"],
 " , \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"w"},
     "Ket"], "=", 
    FractionBox[
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], 
     SqrtBox["2"]]}], TraditionalForm]],ExpressionUUID->
  "d2caa5ec-2620-47aa-a311-d8c34a12e04e"],
 "."
}], "TechNoteText",
 CellID->1182721357,ExpressionUUID->"59d5f60f-9b76-4863-988c-1af55023f4c7"],

Cell[TextData[{
 "We have to figure out which one it is. These two states are not orthogonal, \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"v", "w"},
     "BraKet"], "!=", "0"}], TraditionalForm]],ExpressionUUID->
  "2e51fb30-bd63-4349-ac01-3c293ef519db"],
 ", and it is impossible to discriminate them with certainty. Instead, the \
task is to perform a measurement that tells which of the two, but never \
misidentifies a wrong state."
}], "TechNoteText",
 CellID->889210467,ExpressionUUID->"594e788f-485f-4cb4-9e09-2d54978ba158"],

Cell["Consider a POVM including the following three elements", "TechNoteText",
 CellID->621619396,ExpressionUUID->"f34a3ad0-72bf-421f-b173-39cc97cc47f9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "1"], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"1", "+", 
        TemplateBox[{"v", "w"},
         "BraKet"]}]]], 
     TemplateBox[{"1"},
      "Ket"], 
     TemplateBox[{"1"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "04918656-ed24-47b0-bada-0c13a9dd3e99"],
 ","
}], "TechNoteText",
 CellID->49245917,ExpressionUUID->"54274fe5-e164-4609-bce4-17991c557b8b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "2"], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"1", "+", 
        TemplateBox[{"v", "w"},
         "BraKet"]}]]], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "-", 
        TemplateBox[{"1"},
         "Ket"]}], 
       SqrtBox["2"]], ")"}], 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{"0"},
         "Bra"], "-", 
        TemplateBox[{"1"},
         "Bra"]}], 
       SqrtBox["2"]], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "8ed2d973-2500-4e01-82a8-f78c73f0f5db"],
 ","
}], "TechNoteText",
 CellID->894922924,ExpressionUUID->"d5ae90ed-d664-4bd0-bba6-cad3dd7e84d8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "3"], ":=", 
    RowBox[{"I", "-", 
     SubscriptBox["E", "1"], "-", 
     SubscriptBox["E", "2"]}]}], TraditionalForm]],ExpressionUUID->
  "889b8a6c-e1c2-4aeb-b443-be3ffe7923d0"],
 "."
}], "TechNoteText",
 CellID->2141603727,ExpressionUUID->"1dc960aa-0314-4403-b3dd-3c16863c87ee"],

Cell[TextData[{
 "It is straightforward to check that they form a POVM. Suppose that the \
state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"v"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "d7a64900-2add-40c7-beff-995eb51b39cc"],
 "  is given. As it is orthogonal to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f4653efc-a07c-462b-9aae-cc9172d3d7a6"],
 ", the measurement outcome ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "6fa0a316-edaa-4c48-a071-11cb39486135"],
 "\[LongDash]corresponding to the POVM element ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "1"], TraditionalForm]],ExpressionUUID->
  "afacad35-cb46-46fe-9700-47d5a846a14a"],
 "\[LongDash]never occurs. This means that once ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "2"}], TraditionalForm]],ExpressionUUID->
  "5e89459f-300b-4d84-8275-7e9f324b297b"],
 "\[LongDash]corresponding to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "2"], TraditionalForm]],ExpressionUUID->
  "0111b812-1ba3-4f0b-824f-084189940ace"],
 "\[LongDash]occurs, the state must be ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"w"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3a65b50c-fadd-4297-affb-d9b398150074"],
 ". For the same reason, the result ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "558e58cb-6bba-44b6-990e-8aadf38ac19e"],
 " implies that the state is definitely ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"v"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a2b35d8a-e739-4844-bde0-cef6bd9153e2"],
 ". Of course, it is possible to obtain the outcome m = 3, in which case the \
measurement reveals nothing. However, the important point is that there is no \
chance to make a mistake."
}], "TechNoteText",
 CellID->2107915969,ExpressionUUID->"be546209-1ce2-4a75-aa36-64815d32bd30"]
}, Open  ]]
}, Open  ]],

