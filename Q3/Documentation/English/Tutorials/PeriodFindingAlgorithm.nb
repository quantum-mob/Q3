Cell["\<\
\tLet us look into the algorithm more closely. We prepare the control \
register in state\
\>", "TechNoteText",
 CellID->1306542839,ExpressionUUID->"d4032622-778a-473f-ad85-aea9cc8f3822"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[RightTeeArrow]", 
     RowBox[{
      SuperscriptBox["H", 
       RowBox[{"\[CircleTimes]", "m"}]], 
      TemplateBox[{"0"},
       "Ket"]}]}], "=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       SuperscriptBox["2", 
        RowBox[{"m", "/", "2"}]]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "m"], "-", "1"}]], 
     TemplateBox[{"x"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "b07b4edc-798d-4b50-bfb0-056bdf015163"]
}], "TechNoteText",
 CellID->1045204498,ExpressionUUID->"539b9702-c2a8-42c5-a11e-ada231efedcc"],

Cell[TextData[{
 "by applying the ",
 ButtonBox["Hadamard gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/SingleQubitGates#347838345"],
 " on every qubit in the control register. The quantum oracle then makes the \
following transformation"
}], "TechNoteText",
 CellID->335765426,ExpressionUUID->"ff89100a-9215-4232-8964-177374ab6dcd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       SuperscriptBox["2", 
        RowBox[{"m", "/", "2"}]]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "m"], "-", "1"}]], 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"0"},
       "Ket"]}]}], "->", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       SuperscriptBox["2", 
        RowBox[{"m", "/", "2"}]]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "m"], "-", "1"}]], 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"f", "(", "x", ")"}]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "dde09adf-5cc7-46ef-b44a-3a9b15b752b4"],
 " ."
}], "TechNoteText",
 CellID->1769974113,ExpressionUUID->"cc1899fe-f352-4dcf-9568-4c1f82a89e44"],

Cell[TextData[{
 "We now replace states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"f", "(", "x", ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f5de0f05-d905-4cc1-99a9-b29dc68400e1"],
 " with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["F", "k"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "43aeeb76-4266-43b9-a20f-4898681f30df"],
 " using the inverse relation,"
}], "TechNoteText",
 CellID->1011438947,ExpressionUUID->"4a65aab0-0137-4de4-ac29-a90f8b7f6e52"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"f", "(", "x", ")"}]},
     "Ket"], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox["\[Lambda]"]], 
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"k", "=", "0"}], 
       RowBox[{"\[Lambda]", "-", "1"}]], 
      RowBox[{
       TemplateBox[{
         SubscriptBox["F", "k"]},
        "Ket"], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", "k", " ", 
         RowBox[{"x", "/", "\[Lambda]"}]}]]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"f24cf98e-1c46-4732-98b1-2bb9b59cc3e1"],
 ","
}], "TechNoteText",
 CellID->1921316224,ExpressionUUID->"93aaa3dd-e922-41f4-a962-fba2a69a969b"],

Cell["\<\
which leads to the following expression for the final state of the total \
system\
\>", "TechNoteText",
 CellID->1997660476,ExpressionUUID->"a4c222f3-2f7b-47f1-a4fb-5c4b424622c7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["1", 
     SqrtBox["\[Lambda]"]], 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], 
      RowBox[{"\[Lambda]", "-", "1"}]], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        FractionBox["1", 
         SqrtBox[
          SuperscriptBox["2", 
           RowBox[{"m", "/", "2"}]]]], 
        RowBox[{
         UnderoverscriptBox["\[CapitalSigma]", 
          RowBox[{"x", "=", "0"}], 
          RowBox[{
           SuperscriptBox["2", "m"], "-", "1"}]], 
         RowBox[{
          TemplateBox[{"x"},
           "Ket"], 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
            RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", "k", " ", 
            
            RowBox[{"x", "/", "\[Lambda]"}]}]]}]}]}], ")"}], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["F", "k"]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "3d32bd72-540f-4d11-9311-80121f18d6c9"],
 ","
}], "TechNoteText",
 CellID->920282934,ExpressionUUID->"f055eb9a-7a46-4d0a-a01a-66ed86995d6e"],

Cell[TextData[{
 "\tThe above final state reveals that the quantum oracle has induced \
relative phase shifts in the control register that are proportional to the \
logical value ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "c0421e46-271e-4698-a1ac-096a51405834"],
 ". As in the ",
 ButtonBox["quantum phase estimation procedure",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumPhaseEstimation"],
 ", one can extract the relative phase shifts by employing the ",
 ButtonBox["quantum Fourier transform",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumFourierTransform"],
 ". This corresponds to estimating the (normalized) \
\[OpenCurlyDoubleQuote]phase\[CloseCurlyDoubleQuote] ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "/", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "19544bf7-11e0-412c-b4a7-e2d71531def0"],
 ", from which one can find the period \[Lambda] (see below). In this sense, \
one can regard the period-finding problem to fall in the ",
 ButtonBox["quantum phase estimation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumPhaseEstimation"],
 " category."
}], "TechNoteText",
 CellID->1018046044,ExpressionUUID->"0939ac34-2fe6-461d-bbff-391eb648436b"],

Cell[TextData[{
 "\tOf course, one apparent difference is that the relative phase shifts are \
induced by the quantum oracle in this case. Furthermore, unlike the standard \
quantum phase estimation procedure, the phase ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "/", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "d3069fef-5e3c-4f31-96f3-a55da5e28a00"],
 " to be estimated is randomly selected from the values corresponding to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", "1", ",", "\[Ellipsis]", " ", ",", 
    RowBox[{"\[Lambda]", "\[Minus]", "1"}]}], TraditionalForm]],
  ExpressionUUID->"2d7c647b-9cb3-4639-8c5e-e25ddf998cd8"],
 ". Specifically, the probability ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "k"], TraditionalForm]],ExpressionUUID->
  "65880aaf-be48-4071-a0fc-0940ae043736"],
 " for ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "ca7e1dda-2605-4274-891d-569c68a31fa2"],
 " to take a particular value is given by"
}], "TechNoteText",
 CellID->1297645859,ExpressionUUID->"7f51cd3f-4ff4-4200-9f24-ef080bb4ae69"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "k"], "=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["F", "k"], 
       SubscriptBox["F", "k"]},
      "BraKet"], "/", "\[Lambda]"}]}], TraditionalForm]],ExpressionUUID->
  "5d235442-2d1b-45f7-ab65-e9b2b7c96f96"],
 " ."
}], "TechNoteText",
 CellID->1837516928,ExpressionUUID->"6f419a8f-21e3-4cfb-b3f3-600fa712e367"],

Cell[TextData[{
 "It is thus possible that the observed ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "9cc597aa-90e1-49f2-9ea1-411ffa21fb54"],
 " may have a common divider with \[Lambda] so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "/", "\[Lambda]"}], "=", 
    RowBox[{
     SuperscriptBox["k", "\[Prime]"], "/", 
     SuperscriptBox["\[Lambda]", "\[Prime]"]}]}], TraditionalForm]],
  ExpressionUUID->"61857c61-c59d-4fe9-8ccf-507901decb31"],
 " for another pair of integers ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["k", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "d619c327-8f89-43ee-8710-474adaccbdb9"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Lambda]", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "2457bbd0-9808-4a94-a812-d74ee1689a88"],
 ". For this reason, one cannot uniquely determine period \[Lambda] from the \
recorded value of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "/", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "f526468d-62a3-4bac-a31e-43389233c71b"],
 " alone. The denominator (and the integer multiples of it) is only a \
candidate for the true period \[Lambda]. However, it does not pose a serious \
obstacle given than it is easy to check if a candidate is the true period or \
not by evaluating the function for a few input values."
}], "TechNoteText",
 CellID->184681389,ExpressionUUID->"79989ef4-114a-4b1e-8f6b-a499c149bdbd"],

Cell[CellGroupData[{

Cell["Interim Demonstration", "Subsection",
 CellTags->"Section13",
 CellID->826235008,ExpressionUUID->"1cc7dcd8-7a20-48b8-acb7-81e0525a1cdd"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[4]:=",
 CellID->1369508966,ExpressionUUID->"c2c8e2d3-e5c7-4a8a-8fdd-4096eaedbf96"],

Cell["\<\
We demonstrate the basic ideas in the period-finding algorithm. More complete \
example follows below.\
\>", "TechNoteText",
 CellID->1865024231,ExpressionUUID->"efd6daf1-0e0d-4bbc-b336-822aa7931756"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$N", "=", 
   RowBox[{"Power", "[", 
    RowBox[{"2", ",", "$n"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[5]:=",
 CellID->993225010,ExpressionUUID->"9887cfdf-b2fe-4c56-9cf1-7cf3b54fe2e8"],

Cell[TextData[{
 "We take an example of the modular exponential function, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "=", 
    RowBox[{
     SuperscriptBox["a", "x"], " ", 
     RowBox[{"(", 
      RowBox[{"mod", " ", "L"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "6cc2e052-f072-45e0-a9c8-9242837f153a"],
 " for a fixed ",
 StyleBox["a",
  FontSlant->"Italic"],
 " and ",
