Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "m"], "\[RightArrow]", 
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"]}]}], TraditionalForm]],
  ExpressionUUID->"bb16cd20-0e94-4217-b5b2-e23ffac08a49"],
 " be a periodic function, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     RowBox[{"x", "+", "\[Lambda]"}], ")"}], "=", 
    RowBox[{"f", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "028752d4-c8c0-4ca4-9b14-eda3e3ee3e9e"],
 " for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "d2f9e120-bca9-4b7b-a1b6-4d96d2bac40b"],
 " and fixed \[Lambda]. The period-finding problem is to find the unknown \
(primary) period \[Lambda] with the least queries to the function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "9478db35-d7f1-455b-8e1e-bcaca8c58597"],
 ". For simplicity, we assume that \[Lambda] is a divider of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "m"], TraditionalForm]],ExpressionUUID->
  "f00c8f24-630b-41a3-b5b0-3732a9fc0559"],
 ". As long as an efficient implementation of the ",
 ButtonBox["quantum oracle",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle"],
 " corresponding to function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "f79becb1-41fe-42e9-a5c5-90c916aef67e"],
 ","
}], "TechNoteText",
 CellID->151766818,ExpressionUUID->"7a573680-bda1-4c7f-bbb0-5ec2ee992b3d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "f"], ":", 
    RowBox[{
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"y"},
       "Ket"]}], "\[RightTeeArrow]", 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"y", "\[CirclePlus]", 
          RowBox[{"f", "(", "x", ")"}]}]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "b93ee1cf-36e1-46c3-84c0-c40568b2f943"],
 ","
}], "TechNoteText",
 CellID->1681821137,ExpressionUUID->"02533519-b6d8-433a-b8cf-8c2bc4829a2f"],

Cell[TextData[{
 "is available, one can construct an efficient quantum algorithm to find \
period \[Lambda] of function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "a4f5b851-d8d4-430c-a783-edefad00676e"],
 "."
}], "TechNoteText",
 CellID->1188087745,ExpressionUUID->"470abf97-06ba-499a-9738-2c8f9a1dba79"],

