Cell[CellGroupData[{

Cell["Post-Processing: Continued Fraction Method", "TechNoteSection",
 CellTags->"Section14",
 CellID->667404647,ExpressionUUID->"3b34f715-9bb4-40e2-93e4-35a462b3f23c"],

Cell[TextData[{
 "A more serious hurdle is that the estimated phase \[Phi] is only \
approximate, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", " ", "\[TildeTilde]", " ", 
    RowBox[{"k", "/", "\[Lambda]"}]}], TraditionalForm]],ExpressionUUID->
  "43921a5b-506b-4a65-ad69-94b613305594"],
 ", to the precise value ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "/", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "5f89bcb1-f914-4493-9c13-c6c22a88ea2d"],
 " because the register is of finite size. This deviation makes it even \
harder to determine the period \[Lambda] from the estimated phase \[Phi]. \
Fortunately, a continued fraction representation provides an efficient method \
to find the period in such a situation."
}], "TechNoteText",
 CellID->762813848,ExpressionUUID->"bc0e187f-1f11-4d59-90a2-b887683e03a1"],

Cell[CellGroupData[{

Cell["Continued Fraction", "Subsection",
 CellID->200036020,ExpressionUUID->"2c25021f-f37d-4904-8f95-1578ae1479b2"],

Cell[TextData[{
 "A ",
 StyleBox[ButtonBox["continued fraction",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/ContinuedFraction"],
  FontSlant->"Italic"],
 " is an expression of the form"
}], "TechNoteText",
 CellID->134970746,ExpressionUUID->"9178bf26-3030-4c85-ba9a-46c43903c93d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "0"], "+", 
    FractionBox["1", 
     RowBox[{
      SubscriptBox["a", "1"], "+", 
      FractionBox["1", 
       RowBox[{
        SubscriptBox["a", "2"], "+", 
        FractionBox["1", 
         RowBox[{"\[DescendingEllipsis]", "+", 
          FractionBox["1", 
           SubscriptBox["a", "n"]]}]]}]]}]]}], TraditionalForm]],
  ExpressionUUID->"4ad86ac3-b2ca-4899-b9df-cd4b51433440"],
 " ,"
}], "TechNoteText",
 CellID->710596790,ExpressionUUID->"3176d738-99c4-4bf7-86a4-8f44df510840"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "0"], ",", 
    SubscriptBox["a", "1"], ",", 
    SubscriptBox["a", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["a", "n"]}], TraditionalForm]],ExpressionUUID->
  "7456f573-baa3-4dad-8cd1-2bbb73e0ce28"],
 " are positive integers (there are several other conventions for continued \
fractions, and here we only use the so-called ",
 StyleBox["simple",
  FontSlant->"Italic"],
 " or ",
 StyleBox["canonical continued fractions",
  FontSlant->"Italic"],
 "). It is often denoted by"
}], "TechNoteText",
 CellID->843688563,ExpressionUUID->"ec7576cb-3c28-46c1-b42b-afc08b2272b9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{
      SubscriptBox["a", "0"], ";", 
      SubscriptBox["a", "1"]}], ",", 
     SubscriptBox["a", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["a", "n"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "47a5160f-3251-480c-8184-7004da972222"],
 " ."
}], "TechNoteText",
 CellID->39157200,ExpressionUUID->"fede5e7f-8130-486d-9d9a-81f02b404fca"],

Cell[TextData[{
 "One can represent any real number with a unique continued fraction. (For a \
finite continued fraction, there is a trivial ambiguity such as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      RowBox[{
       SubscriptBox["a", "0"], ";", 
       SubscriptBox["a", "1"]}], ",", 
      SubscriptBox["a", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["a", "n"]}], "]"}], "=", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{
       SubscriptBox["a", "0"], ";", 
       SubscriptBox["a", "1"]}], ",", 
      SubscriptBox["a", "2"], ",", "\[Ellipsis]", ",", 
      RowBox[{
       SubscriptBox["a", "n"], "-", "1"}], ",", "1"}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"93e350d0-1bce-4c29-b84e-7aca93712555"],
 ". We regard such continued fractions to be equivalent.) For a given number, \
the procedure to find a continued fraction is simple. For example, consider \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"13", "/", "5"}], TraditionalForm]],ExpressionUUID->
  "2449b428-a4f0-4d26-a348-b80391d98c6b"],
 ". We first split it into its integer part which is 2 and fractional part ",
 Cell[BoxData[
  FormBox[
   RowBox[{"3", "/", "5"}], TraditionalForm]],ExpressionUUID->
  "a5729bb9-e80d-4219-af37-7c70456b1950"],
 ", so ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"13", "/", "5"}], "=", 
    RowBox[{"2", "+", 
     RowBox[{"3", "/", "5"}]}]}], TraditionalForm]],ExpressionUUID->
  "1ab3d432-21f6-469b-bc45-f1fac157bbdc"],
 ". Next, we take the reciprocal of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"3", "/", "5"}], TraditionalForm]],ExpressionUUID->
  "cea82077-1d36-4a12-a93b-3b760cd96935"],
 " and split it into its integer and fractional parts, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"5", "/", "3"}], "=", 
    RowBox[{"1", "+", 
     RowBox[{"2", "/", "3"}]}]}], TraditionalForm]],ExpressionUUID->
  "2581aa8c-7bb6-447f-a6ca-3376b2ad4e58"],
 ". By repeating the procedure, we find that"
}], "TechNoteText",
 CellID->985064418,ExpressionUUID->"bf008f70-827b-41a4-a293-109c657f9a45"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"13", "/", "5"}], "=", 
    RowBox[{
     RowBox[{"2", "+", 
      FractionBox["1", 
       RowBox[{"1", "+", 
        FractionBox["1", 
         RowBox[{"1", "+", 
          FractionBox["1", "2"]}]]}]]}], "=", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"2", ";", "1"}], ",", "1", ",", "2"}], "]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"a59c9606-f888-4c57-8cf5-472069c322b8"],
 "."
}], "TechNoteText",
 CellID->1026238603,ExpressionUUID->"d515e4b4-085d-41a5-8a14-571c3ab4b79d"],

Cell[TextData[{
 "The well-known ",
 StyleBox["Euclidean algorithm",
  FontSlant->"Italic"],
 ", dating back to Euclid\[CloseCurlyQuote]s book Elements, provides an \
efficient method to find a continued fraction representation of a number. A \
continued fraction may be terminated after a finite number of steps, and in \
such case is said to be finite. If a continued fraction continues the \
iteration without termination, then it is called an infinite continued \
fraction."
}], "TechNoteText",
 CellID->990454137,ExpressionUUID->"28cd5374-c9ed-4a4c-ba2b-3ceab28d86ed"],

Cell[TextData[{
 "\tAlthough not so common in daily life, continued fraction representations \
are, in many respects, more natural mathematically than the decimal \
representations or other similar representations with a fixed base. To see \
this, consider the following properties: The continued fraction for any \
rational number is finite, which stands in contrast with decimal \
representations. For example, 5/3 = [1; 1, 2] whereas 5/3 = 1.666 \
\[CenterDot] \[CenterDot] \[CenterDot] . On the other hand, continued \
fractions for irrational numbers are infinite. For example, the golden ratio \
is represented by the continued fraction, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       SqrtBox["5"]}], ")"}], "/", "2"}], "=", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"1", ";", "1"}], ",", "1", ",", "1", ",", "\[CenterEllipsis]"}],
      " ", "]"}]}], TraditionalForm]],ExpressionUUID->
  "280d5eae-0825-475f-9db9-a1cf555c5e59"],
 ". Furthermore, continued fractions for a number and its reciprocal are \
identical except for a shift by one place. In other words, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{
      SubscriptBox["a", "0"], ";", 
      SubscriptBox["a", "1"]}], ",", 
     SubscriptBox["a", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["a", "n"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "228332e9-2d60-4e61-918b-a980659ef53f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{
     RowBox[{"0", ";", 
      SubscriptBox["a", "0"]}], ",", 
     SubscriptBox["a", "1"], ",", 
     SubscriptBox["a", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["a", "n"]}], "]"}], TraditionalForm]],ExpressionUUID->
  "e78192ec-b151-4538-a3f7-6361c77540b6"],
 " are reciprocal of each other."
}], "TechNoteText",
 CellID->2030988862,ExpressionUUID->"7cba3d3a-1a6d-4bf6-99d6-e45d7724ac8d"],

Cell[TextData[{
 "\t",
 StyleBox[ButtonBox["Continued fraction convergents",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Convergents"],
  FontSlant->"Italic"],
 " are often used to approximate irrational numbers by rational ones. More \
specifically, given a (possibly irrational) number ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "9d660d0a-7528-4236-b4fd-bd4db93ac57e"],
 " and its continued fraction representation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "=", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{
       SubscriptBox["a", "0"], ";", 
       SubscriptBox["a", "1"]}], ",", 
      SubscriptBox["a", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["a", "m"], ",", 
      SubscriptBox["a", 
       RowBox[{"m", "+", "1"}]], ",", "\[Ellipsis]", ",", 
      SubscriptBox["a", "n"]}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "0b7e96c0-d07e-4019-9e35-ad63d1664036"],
 "  (with ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "62e61f47-7edf-4c62-904b-589c55466f5b"],
 " possibly being infinity), the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["m", "th"], TraditionalForm]],ExpressionUUID->
  "52f40e33-0d83-49c5-9a07-54e1fdfc4cc1"],
 " convergent of the continued fraction is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "/", "q"}], ":=", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{
       SubscriptBox["a", "0"], ";", 
       SubscriptBox["a", "1"]}], ",", 
      SubscriptBox["a", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["a", "m"]}], "]"}]}], TraditionalForm]],ExpressionUUID->
  "b63ca7bb-b2e3-47aa-9a1c-37d5a9769ec5"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", "m", "\[LessEqual]", "n"}], TraditionalForm]],
  ExpressionUUID->"978969d4-0f27-40a8-9a4d-7b99342e3a07"],
 ") and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "/", "q"}], TraditionalForm]],ExpressionUUID->
  "6ddca068-693c-4f15-98ea-6b4a33b3b691"],
 " approximates ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "0c23ca2c-4299-43ec-9169-a01478e2b59f"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "/", "q"}], "\[TildeTilde]", "x"}], TraditionalForm]],
  ExpressionUUID->"4820728d-eccb-40f5-8719-0f779ec3cfe6"],
 "). Those approximations alternate from above and below, and converge \
exponentially in the number ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "a6836450-0972-4511-a8bd-52940b392966"],
 " of terms. Furthermore, a convergent ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "/", "q"}], TraditionalForm]],ExpressionUUID->
  "2c323d01-befb-4ce3-8e50-ae83363ce7e7"],
 " of a simple continued fraction is better than any other rational \
approximation with denominator less than or equal to ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]],ExpressionUUID->
  "d22e11c0-280e-47eb-84c2-b9b599ab55dd"],
 "."
}], "TechNoteText",
 CellID->577234569,ExpressionUUID->"3859ba3e-4245-42de-81f5-5d54e2b7c1a2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Determination of the Period", "Subsection",
 CellID->622052596,ExpressionUUID->"81c05fb9-c2ac-4c11-80d9-e093b5ea653d"],

Cell[TextData[{
 "The method to determine the period \[Lambda] from the estimated phase, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Phi]", "\[TildeTilde]", 
    RowBox[{"k", "/", "\[Lambda]"}]}], TraditionalForm]],ExpressionUUID->
  "cfa827c1-1de2-4e26-8ac1-0d36bccd85db"],
 ", is based on a theorem from number theory. It states that if"
}], "TechNoteText",
 CellID->1397767684,ExpressionUUID->"cece2fab-f96b-4e59-b1ac-657b9215eba1"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftBracketingBar]", 
     RowBox[{
      FractionBox["k", "\[Lambda]"], "-", "\[Phi]"}], 
     "\[RightBracketingBar]"}], "\[LessEqual]", 
    FractionBox["1", 
     RowBox[{"2", 
      SuperscriptBox["\[Lambda]", "2"]}]]}], TraditionalForm]],ExpressionUUID->
  "761d3ca2-5fbd-4b6e-8370-2bf3602e28e9"]
}], "TechNoteText",
 CellID->957850455,ExpressionUUID->"07ed4f38-d84d-4837-b9a4-589532d2d6df"],

Cell[TextData[{
 "for any integers ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "101cf418-5577-4209-a334-123494714037"],
 " and \[Lambda], then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "/", "\[Lambda]"}], TraditionalForm]],ExpressionUUID->
  "7f3f359c-bddf-4b7a-a655-09c93e51a81d"],
 " is a ",
 ButtonBox["convergent",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/Convergent"],
 " of the continued fraction for \[Phi]. Note that \[Phi] is accurate to ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "22124bc5-f8b0-4feb-be67-16bdea150b5d"],
 " bits. The error is less than ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", 
    RowBox[{"-", "m"}]], TraditionalForm]],ExpressionUUID->
  "89a35fd2-efbc-4650-bf71-884a9323f90f"],
 " with probability higher than 0.81 (see ",
 ButtonBox["Quantum Phase Estimation",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumPhaseEstimation#1752851100"],
 "). Since ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "\[LessLess]", 
    SuperscriptBox["2", "m"]}], TraditionalForm]],ExpressionUUID->
  "eae03c23-8c46-4aaa-98d8-656eea0e8b0e"],
 ", the above condition is satisfied. Therefore, the continued fraction of \
the estimated phase \[Phi] gives coprimes ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["k", "\[Prime]"], "/", 
    SuperscriptBox["\[Lambda]", "\[Prime]"]}], TraditionalForm]],
  ExpressionUUID->"1239f224-ee79-47a6-8d18-d01d10e95c45"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["k", "\[Prime]"], "/", 
     SuperscriptBox["\[Lambda]", "\[Prime]"]}], "=", 
    RowBox[{"k", "/", "\[Lambda]"}]}], TraditionalForm]],ExpressionUUID->
  "d50d3d56-0514-4b90-8e58-36906b845b15"],
 ". ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Lambda]", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "d560406c-5fe2-4605-8bde-48f83460108c"],
 " and integer multiples of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Lambda]", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "eba687cb-1619-4a40-8f8e-68931888a0ca"],
 " are candidates for the period. We then evaluate (classically) the function \
to check if \[Lambda] (or any integer multiple of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Lambda]", "\[Prime]"], TraditionalForm]],ExpressionUUID->
  "4b397ca9-06f1-4cd1-9d02-e5c50bf349b4"],
 ") is the true period \[Lambda] of the function."
}], "TechNoteText",
 CellID->1055179273,ExpressionUUID->"b22fbf34-4e4c-42a5-81b7-7cf9fec6ea80"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Demonstration", "TechNoteSection",
 CellTags->"Section15",
 CellID->478084385,ExpressionUUID->"982b2dbc-7fd2-4b45-a365-9425aafad608"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[25]:=",
 CellID->1292762189,ExpressionUUID->"70e6f5ad-90db-458e-b2cd-41a1bbfe0f73"],

Cell["\<\
Now, we consider a full period-finding problem. We consider a four-qubit \
system.\
\>", "TechNoteText",
 CellID->1856381102,ExpressionUUID->"9cc00c85-6d81-4e1d-a0ae-8d2700512b5d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"$N", "=", 
   RowBox[{"Power", "[", 
    RowBox[{"2", ",", "$n"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[26]:=",
 CellID->1554757698,ExpressionUUID->"7f5fa709-f7cd-4933-8b37-9d4abeab7163"],

Cell["We define an arbitrary function with period 3.", "TechNoteText",
 CellID->231613590,ExpressionUUID->"f476d780-84ce-4524-871a-817215df1954"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "0", "]"}], "=", "1"}], ";", 
  RowBox[{
   RowBox[{"f", "[", "1", "]"}], "=", "5"}], ";", 
  RowBox[{
   RowBox[{"f", "[", "2", "]"}], "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "x_Integer", "]"}], ":=", 
  RowBox[{"f", "[", 
   RowBox[{"Mod", "[", 
    RowBox[{"x", ",", "3"}], "]"}], "]"}]}]}], "Input",
 CellLabel->"In[28]:=",
 CellID->1489238766,ExpressionUUID->"06c0f848-5c85-489a-a519-99f37b70bf18"],

Cell["\<\
This plot illustrates that the function is indeed periodic with period 3.\
\>", "TechNoteText",
 CellID->587524040,ExpressionUUID->"03078b7c-29d4-4070-988f-2faea5e9746b"],

