}, Open  ]],

Cell["\<\
From the above output state, we perform measurements (as many times as we \
like) to get random results.\
\>", "TechNoteText",
 CellID->1629395466,ExpressionUUID->"37bbac1a-6893-4fb0-bb57-cf4b5c96bdc2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"out", "=", 
   RowBox[{"msr", "@", 
    RowBox[{"N", "[", "new", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"phi", "=", 
  RowBox[{
   RowBox[{"FromDigits", "[", 
    RowBox[{
     RowBox[{"Readout", "[", "msr", "]"}], ",", "2"}], "]"}], "/", 
   "$N"}]}]}], "Input",
 CellLabel->"In[40]:=",
 CellID->585015184,ExpressionUUID->"94b2da37-badb-4400-ab24-649a93cc99f5"],

