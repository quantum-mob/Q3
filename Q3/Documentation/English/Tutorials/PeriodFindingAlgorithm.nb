Cell[CellGroupData[{

Cell["Quantum Fourier Transform for a Function", "TechNoteSection",
 CellTags->"Section11",
 CellID->162714494,ExpressionUUID->"f0393456-fefa-40a6-a2ab-bbdb719182bf"],

Cell[TextData[{
 "Before we discuss a quantum algorithm for the period-finding problem, let \
us first examine how the quantum Fourier transform naturally arises in the \
problem. Given the sequence of the function values ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "0", ")"}], ",", 
    RowBox[{"f", "(", "1", ")"}], ",", 
    RowBox[{".", " ", ".", " ", "."}], " ", ",", 
    RowBox[{"f", "(", 
     RowBox[{"\[Lambda]", "\[Minus]", "1"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"77ad09ae-65ff-4648-a984-53ce34278e31"],
 ", one can perform a ",
 StyleBox["discrete Fourier transform",
  FontSlant->"Italic"],
 " of the sequence to obtain"
}], "TechNoteText",
 CellID->995818027,ExpressionUUID->"8998db10-1456-4969-a74b-fe2b8cf54fc3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "k"], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox["\[Lambda]"]], 
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"x", "=", "0"}], 
       RowBox[{"\[Lambda]", "-", "1"}]], 
      RowBox[{
       RowBox[{"f", "(", "x", ")"}], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", "k", " ", 
         RowBox[{"x", "/", "\[Lambda]"}]}]]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"9ef0376e-6a76-4fb3-90d2-4f1fc92d6ae9"],
 "."
}], "TechNoteText",
 CellID->1373518718,ExpressionUUID->"ddece5fe-c380-4cc9-b0fb-2684de6f4923"],

Cell["\<\
Analogously, it is also possible to define new states (notice the opposite \
sign in the exponent)\
\>", "TechNoteText",
 CellID->1427371823,ExpressionUUID->"fab5257e-ec44-4a7c-a534-4cf9b07f4cfc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["F", "k"]},
     "Ket"], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox["\[Lambda]"]], 
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"x", "=", "0"}], 
       RowBox[{"\[Lambda]", "-", "1"}]], 
      RowBox[{
       TemplateBox[{
         RowBox[{"f", "(", "x", ")"}]},
        "Ket"], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"+", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", "k", " ", 
         RowBox[{"x", "/", "\[Lambda]"}]}]]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"0cad168a-2f61-4cd5-a87b-fd9951f4aa4b"],
 "."
}], "TechNoteText",
 CellID->298408524,ExpressionUUID->"fa4bfddc-2dd6-4e39-8f1e-a912136591c8"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "0"}], ",", "1", ",", "2", ",", 
    RowBox[{".", " ", ".", " ", "."}], " ", ",", 
    RowBox[{"\[Lambda]", "\[Minus]", "1"}]}], TraditionalForm]],
  ExpressionUUID->"7be14785-d48f-484c-b2bc-c7da3e3b6fac"],
 " using the discrete Fourier transform of the sequence of ",
 StyleBox["states",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"f", "(", "x", ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "be916018-ee12-4549-b1c6-7a13179eb4f1"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "=", "0"}], ",", "1", ",", "2", ",", 
    RowBox[{".", " ", ".", " ", "."}], " ", ",", 
    RowBox[{"\[Lambda]", "\[Minus]", "1"}]}], TraditionalForm]],
  ExpressionUUID->"ce38c7c5-230b-484c-99f0-87226b4ae1b9"],
 ".\t"
}], "TechNoteText",
 CellID->977747123,ExpressionUUID->"89eef73c-f85c-4352-a740-881ed9a6c215"],

Cell[TextData[{
 "\tSince the transformation involves states (rather than complex numbers), \
it is a sort of quantum Fourier transform. Indeed, compared with the \
\"usual\" quantum Fourier transform, the only difference is that it is \
defined over ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", ",", "1", ",", 
    RowBox[{"\[CenterDot]", "\[CenterDot]", "\[CenterDot]"}], " ", ",", 
    RowBox[{"\[Lambda]", "\[Minus]", "1"}]}], TraditionalForm]],
  ExpressionUUID->"1047893c-f9cb-4bb4-9227-8c88f2ccd934"],
 " rather than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", ",", "1", ",", "2", ",", 
    RowBox[{"\[CenterDot]", "\[CenterDot]", "\[CenterDot]"}], " ", ",", 
    RowBox[{
     SuperscriptBox["2", "m"], "\[Minus]", "1"}]}], TraditionalForm]],
  ExpressionUUID->"14b2c481-777e-4d33-921c-ae804c44b302"],
 " (usually ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", " ", "\[LessLess]", " ", 
    SuperscriptBox["2", "m"]}], TraditionalForm]],ExpressionUUID->
  "833c5f98-a6c9-4bae-a7a5-0d0b6a12276e"],
 "). Note that in general, the new states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["F", "k"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "d56f6d08-46e8-44df-97fb-6c3f02a82255"],
 " may not be linearly independent with each other because ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"f", "(", "x", ")"}]},
     "Ket"], "=", 
    TemplateBox[{
      RowBox[{"f", "(", "y", ")"}]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "4d571a79-fc51-458e-bc85-b0ef35550606"],
 " for some ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "49beb946-de6a-454b-a309-69fbd71cd64d"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "c20957bd-8ec4-49b0-a783-4cc59d327c99"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "\[LessEqual]", "x"}], ",", 
    RowBox[{"y", "<", "\[Lambda]"}]}], TraditionalForm]],ExpressionUUID->
  "7e33864c-b962-4277-9776-980398837710"],
 "."
}], "TechNoteText",
 CellID->451029417,ExpressionUUID->"d732313c-6816-4d2c-a231-2232e7ea5611"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum Implementation", "TechNoteSection",
 CellTags->"Section12",
 CellID->1981621256,ExpressionUUID->"4480bc17-50aa-4417-b12a-ca62c8e2a54a"],

Cell[TextData[{
 "In order to investigate the period of function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "f958b61f-37cb-4086-90cc-8fc94ec5d309"],
 ", the transformation in the above requires that the register is prepared in \
particular input states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"f", "(", "x", ")"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "abd2c004-c1ea-418f-812a-da4742ac9e28"],
 ". This can be achieved with the quantum oracle ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "f"], TraditionalForm]],ExpressionUUID->
  "5902add8-1d3e-4dd8-b70f-3dc15b1dd74b"],
 " specified at the beginning. The period-finding algorithm thus consists of \
two key components, the quantum Fourier transform and the quantum oracle. A \
quantum circuit for it is shown below."
}], "TechNoteText",
 CellID->1932051916,ExpressionUUID->"83eb2332-3a62-4181-8ed6-d3075dc96f8d"],

Cell[BoxData[
 GraphicsBox[{
