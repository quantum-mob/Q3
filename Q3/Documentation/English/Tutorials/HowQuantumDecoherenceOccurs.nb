Cell[TextData[{
 "For demonstration, consider the quantum circuit in ",
 ButtonBox["Figure 3 (right)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/HowQuantumDecoherenceOccurs#1247206449"],
 ", which is equivalent to the Mach-Zehnder interference experiment with a \
two-level system coupled to one of the two arms as in ",
 ButtonBox["Figure 2 (right)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/HowQuantumDecoherenceOccurs#1995122200"],
 "."
}], "TechNoteMathCaption",
 CellID->491247106,ExpressionUUID->"102358da-36cf-40c9-abcf-00e1ce3fd758"],

