         "RowWithSeparators"]},
       "Ket"],
      Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 0|>]],
     HoldForm], "\[CircleTimes]", 
    RowBox[{"(", 
     TagBox[
      RowBox[{
       RowBox[{
        FractionBox["1", "2"], " ", 
        InterpretationBox[
         TemplateBox[{
           TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
             SubscriptBox["0", 
              TemplateBox[{",", "\",\"", 
                InterpretationBox[
                 SubscriptBox["S", 
                  TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
                 $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]},
             "RowWithSeparators"]},
          "Ket"],
         Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 0|>]]}], "+", 
       RowBox[{
        FractionBox["1", "2"], " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
        InterpretationBox[
         TemplateBox[{
           TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
             SubscriptBox["1", 
              TemplateBox[{",", "\",\"", 
                InterpretationBox[
                 SubscriptBox["S", 
                  TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
                 $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]},
             "RowWithSeparators"]},
          "Ket"],
         Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]}]}],
      HoldForm], ")"}]}],
   QuantumMob`Q3`OSlash[
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 0|>], 
    Rational[1, 2] Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 0|>] + 
    Rational[1, 2] E^(Complex[0, 1] $CellContext`\[Phi]) 
     Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]], "+", 
  InterpretationBox[
   RowBox[{
    TagBox[
     InterpretationBox[
      TemplateBox[{
        TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
          SubscriptBox["1", 
           TemplateBox[{",", "\",\"", 
             InterpretationBox[
              SubscriptBox["S", 
               TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
              $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
         "RowWithSeparators"]},
       "Ket"],
      Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 1|>]],
     HoldForm], "\[CircleTimes]", 
    RowBox[{"(", 
     TagBox[
      RowBox[{
       RowBox[{
        FractionBox["1", "2"], " ", 
        InterpretationBox[
         TemplateBox[{
           TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
             SubscriptBox["0", 
              TemplateBox[{",", "\",\"", 
                InterpretationBox[
                 SubscriptBox["S", 
