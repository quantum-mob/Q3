Cell[TextData[{
 "For demonstration, consider the quantum circuit in ",
 ButtonBox["Figure 3 (left)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/HowQuantumDecoherenceOccurs#1247206449"],
 ", which is equivalent to the Mach-Zehnder interferometer in ",
 ButtonBox["Figure 2 (left)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/HowQuantumDecoherenceOccurs#1995122200"],
 "."
}], "TechNoteMathCaption",
 CellID->2035248940,ExpressionUUID->"85bde718-7125-4f06-9d45-dcf16131034e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{"S", "@", 
      RowBox[{"{", "1", "}"}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}], ",", 
    RowBox[{"Phase", "[", 
     RowBox[{"\[Phi]", ",", 
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "3"}], "]"}], ",", 
      RowBox[{"\"\<Label\>\"", "->", "\"\<\[Phi]\>\""}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[161]:=",
 CellID->688633989,ExpressionUUID->"8c499554-2cc8-4edd-852e-f54185c224e7"],

