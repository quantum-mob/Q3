     Rational[-5, 2], 
     Rational[-1, 2]}, {-2.5, -0.5}],
  PlotRangePadding->Scaled[
   0.025]]], \
"Output",ExpressionUUID->"ec0b7156-68bd-47c4-91d9-ddd9ebd8081f"]], "Picture",
 TextAlignment->Center,
 CellID->1911884494,ExpressionUUID->"6f34c106-a3b7-42e0-a847-2c9768ebf63d"],

Cell[TextData[{
 StyleBox["Figure 4",
  FontWeight->"Bold"],
 ". A quantum circuit simulating partial decoherence."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->273364983,ExpressionUUID->"191f872d-41e3-42c0-84eb-685caca006f2"],

Cell["\<\
Following the above lines of argument, one can obtain the final state of the \
combined system of the photon and the two-level system as\
\>", "TechNoteText",
 CellID->1059674885,ExpressionUUID->"f4e5639e-944d-44f9-b47b-9fe694b6d2bb"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "0"]},
         "Ket"], "+", 
        RowBox[{
         TemplateBox[{
           SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}]}], "2"], ")"}]}], "+", 
    RowBox[{
     TemplateBox[{"1"},
      "Ket"], "\[CircleTimes]", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "0"]},
         "Ket"], "-", 
        RowBox[{
         TemplateBox[{
           SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}]}], "2"], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"4b1b637c-ff71-4ef4-96c5-26db27b30d6c"],
 " ."
}], "TechNoteText",
 CellID->9289454,ExpressionUUID->"d2fb19bc-edf7-475f-907d-70b2837985bb"],

Cell[TextData[{
 "which is to be compared to the ",
 ButtonBox["previous final state",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/HowQuantumDecoherenceOccurs#659592202"],
 ". The photon detection probabilities are given by"
}], "TechNoteText",
 CellID->1910179782,ExpressionUUID->"ed596785-8ccd-4a8b-a22c-7f3a181061ce"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "4"], 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "0"]},
         "Bra"], "+", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}]], 
         TemplateBox[{
           SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
          "Bra"]}]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "0"]},
         "Ket"], "+", 
        RowBox[{
         TemplateBox[{
           SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}]}], ")"}]}], "=", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"Re", "(", 
         RowBox[{
          TemplateBox[{
            SubscriptBox["\[Epsilon]", "0"], 
            SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
           "BraKet"], 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}], ")"}]}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"c3f7a2e3-a2e7-452f-b0c5-42adbd409851"],
 " ,"
}], "TechNoteText",
 CellID->2023350969,ExpressionUUID->"e427ada7-96ef-4d70-80e4-832e34c86052"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "1"], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "4"], 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "0"]},
         "Bra"], "-", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Phi]"}]], 
         TemplateBox[{
           SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
          "Bra"]}]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{
          SubscriptBox["\[Epsilon]", "0"]},
         "Ket"], "-", 
        RowBox[{
         TemplateBox[{
           SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
          "Ket"], 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}]}], ")"}]}], "=", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Re", "(", 
         RowBox[{
          TemplateBox[{
            SubscriptBox["\[Epsilon]", "0"], 
            SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
           "BraKet"], 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}], ")"}]}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"7c80e8fd-1fb5-44e5-a4cb-c1d77b20eb4d"],
 " ."
}], "TechNoteText",
 CellID->1764343120,ExpressionUUID->"5070968f-3610-4670-bfca-2f622ba6ec84"],

Cell[TextData[{
 "Clearly, when ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "5190b1d2-f583-4c95-95c6-355e61d67466"],
 " is orthogonal to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "89947809-2e49-40ed-8489-8b7e11af3e7b"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Epsilon]", "0"], 
      SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
     "BraKet"], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "53c80905-a0ec-4b4a-a19e-8ee526a35b16"],
 ", the previous results are reproduced, and one can observe no interference. \
Furthermore, when there is no interaction between the photon and the \
two-level system, the two-level system should remain in the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "1d908c7b-4c33-49fe-9732-4f4b82054a3a"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
     "Ket"], "=", 
    TemplateBox[{
      SubscriptBox["\[Epsilon]", "0"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "12ab3b1f-da0c-42aa-9a2a-3440e58316e3"],
 ". In this case, the photon detection probabilities recover interference to \
the full extent. The above result  shows that in general, the interference is \
destroyed only partially depending on how easy ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubsuperscriptBox["\[Epsilon]", "1", "\[Prime]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b8e3c22f-d324-40bb-9ccb-a5b499bd9c71"],
 " can be, in principle, discriminated from ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "c3348621-5470-4bbb-9c16-8efd73f6a5ba"],
 ". Putting it another way, the better the environment \
\[OpenCurlyDoubleQuote]knows\[CloseCurlyDoubleQuote] about the quantum state, \
the more loss of phase coherence it suffers."
}], "TechNoteText",
 CellID->1699660816,ExpressionUUID->"9e18d2dc-51ff-401c-932e-c405836a2c6e"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->95838704,ExpressionUUID->"e2ff6a89-0525-494f-8fc1-1075c8069d39"],

Cell[BoxData[{
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]}], "Input",
 CellLabel->"In[173]:=",
 CellID->1081128520,ExpressionUUID->"55732856-3ba3-4525-833b-8668cc1bde2c"],

Cell[TextData[{
 "For demonstration, now consider a quantum circuit equivalent to the \
Mach-Zehnder interference experiment with a two-level system ",
 StyleBox["weakly",
  FontSlant->"Italic"],
 " coupled to one of the two arms. Here we assume the unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     SubscriptBox["U", "y"], "(", "\[Theta]", ")"}]}], TraditionalForm]],
  ExpressionUUID->"a42fb2d4-f49d-41f1-8d38-8cdcb5f5c321"],
 " with \[Theta]<\[Pi] acting conditionally on the two-level system."
}], "TechNoteMathCaption",
 CellID->943369494,ExpressionUUID->"55eb0532-c018-4fe7-b4ef-beb10bdfeea1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{"S", "@", 
      RowBox[{"{", 
       RowBox[{"1", ",", "2"}], "}"}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}], ",", 
    RowBox[{"Phase", "[", 
     RowBox[{"\[Phi]", ",", 
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "3"}], "]"}], ",", 
      RowBox[{"\"\<Label\>\"", "->", "\"\<\[Phi]\>\""}]}], "]"}], ",", 
    RowBox[{"ControlledGate", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"Rotation", "[", 
       RowBox[{"\[Theta]", ",", 
        RowBox[{"S", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "]"}], ",", 
      RowBox[{"\"\<Label\>\"", "->", "\"\<U\>\""}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "6"}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[175]:=",
 CellID->339319857,ExpressionUUID->"03472242-b9bd-4c4e-a9bc-ebc2bd5de19e"],

Cell[BoxData[
 InterpretationBox[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {5, -1}}, {{0, -2}, {5, -2}}}], {InsetBox[
      TemplateBox[{"0"},
       "Ket"], {-0.2, -1.}, NCache[
      ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1,
       0}], InsetBox[
      TemplateBox[{"0"},
       "Ket"], {-0.2, -2.}, NCache[
      ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1,
       0}]}, {
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -1.4}, {1.4, -0.6}]}, InsetBox[
      StyleBox["\<\"H\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.08000000000000002],
       FontWeight->"Light",
       FontSlant->Italic], {1., -1.}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}, {
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{1.6, -1.4}, {2.4, -0.6}]}, InsetBox[
      StyleBox["\<\"\[Phi]\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.08000000000000002],
       FontWeight->"Light",
