Cell[TextData[{
 StyleBox["Figure 3",
  FontWeight->"Bold"],
 ". Quantum circuits equivalent to the Mach-Zehnder interference experiments \
in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/HowQuantumDecoherenceOccurs#1995122200"],
 ". The Hadamard gate is the equivalent of the beam splitter in the \
Mach-Zehnder interferometer while the additional qubit corresponds to the \
two-level system coupled to the upper optical mode and the CNOT gate \
simulates the coupling. The unitary gate labeled by \[Phi] is the phase gate, \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], 
     TemplateBox[{"0"},
      "Bra"]}], "+", 
    RowBox[{
     TemplateBox[{"1"},
      "Ket"], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]], 
     TemplateBox[{"1"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "dd4fbf48-28ba-4ce6-b2f0-93bdc8b917d5"],
 "."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->1247206449,ExpressionUUID->"5364064c-4e3f-4571-9df7-6020f65a1ac3"],

