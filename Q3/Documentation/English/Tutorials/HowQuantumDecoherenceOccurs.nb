Cell[BoxData[
 RowBox[{
  InterpretationBox[
   RowBox[{
    TagBox[
     InterpretationBox[
      TemplateBox[{
        TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
          SubscriptBox["0", 
           TemplateBox[{",", "\",\"", 
