             "RowWithSeparators"]},
          "Ket"],
         Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 0|>]]}], "-", 
       RowBox[{
        FractionBox["1", "2"], " ", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]], " ", 
        InterpretationBox[
         TemplateBox[{
           TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
             SubscriptBox["1", 
              TemplateBox[{",", "\",\"", 
                InterpretationBox[
                 SubscriptBox["S", 
                  TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
                 $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]},
             "RowWithSeparators"]},
          "Ket"],
         Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]}]}],
      HoldForm], ")"}]}],
   QuantumMob`Q3`OSlash[
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 1|>], 
    Rational[1, 2] Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 0|>] + 
    Rational[-1, 2] E^(Complex[0, 1] $CellContext`\[Phi]) 
     Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 1|>]]]}]], "Output",
 CellLabel->"Out[170]=",
 CellID->1123285136,ExpressionUUID->"65ab27da-06e7-4bdb-922d-a03ad70e5ac7"]
}, Open  ]],

Cell["\<\
The above expression suggest the probabilities to get each outcome. Observe \
that no interference is observed.\
\>", "TechNoteMathCaption",
 CellID->1979420450,ExpressionUUID->"b40d34d5-364e-4044-8abb-3753de4c8863"],

