   PlotRangePadding->Scaled[0.025]],
  QuantumMob`Q3`QuantumCircuit[
   QuantumMob`Q3`PortIn[
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 0|>]], 
   $CellContext`S[1, 6], 
   QuantumMob`Q3`Phase[$CellContext`\[Phi], 
    $CellContext`S[1, 3], "Label" -> "\[Phi]"], 
   $CellContext`S[1, 6]]]], "Output",
 CellLabel->"Out[161]=",
 CellID->790876964,ExpressionUUID->"8d5ad6c9-d39a-4daf-a3d5-9d039017b11d"]
}, Open  ]],

Cell["Evaluate the output state.", "TechNoteMathCaption",
 CellID->374481881,ExpressionUUID->"16f59b14-cb4b-416d-b3ca-1a6337f8c007"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"out", "=", 
  RowBox[{"Elaborate", "[", "qc", "]"}]}]], "Input",
 CellLabel->"In[162]:=",
 CellID->1617625284,ExpressionUUID->"e780135d-48e8-42b7-a16b-7ef37798b6d5"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", "2"], " ", 
   RowBox[{"(", 
    RowBox[{"1", "+", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}], ")"}], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 0|>]]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}], ")"}], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 1|>]]}]}]], "Output",
 CellLabel->"Out[162]=",
 CellID->1492842665,ExpressionUUID->"48d9f47a-c6fd-485a-bfe7-dc03dd2e3614"]
}, Open  ]],

Cell["\<\
From the output above, analyze the measurement outcomes and corresponding \
post-measurement states.\
\>", "TechNoteMathCaption",
 CellID->1102338362,ExpressionUUID->"a42106c6-3923-4022-91fa-7a0ccfcc7d8d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Real", ",", "\[Phi]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"data", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"MeasurementOdds", "[", 
      RowBox[{"S", "[", 
       RowBox[{"1", ",", "3"}], "]"}], "]"}], "[", "out", "]"}], "//", 
    "Elaborate"}], "//", "FullSimplifyThrough"}]}]}], "Input",
 CellLabel->"In[163]:=",
 CellID->1579233507,ExpressionUUID->"7d7a7672-182a-49a4-9e89-b13c4d7bed81"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"0", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"Cos", "[", 
        FractionBox["\[Phi]", "2"], "]"}], "2"], ",", 
      RowBox[{
       FractionBox["1", "2"], " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}], ")"}], " ", 
       InterpretationBox[
        TemplateBox[{
          TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
            SubscriptBox["0", 
             TemplateBox[{",", "\",\"", 
               InterpretationBox[
                SubscriptBox["S", 
                 TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
                $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
           "RowWithSeparators"]},
         "Ket"],
        Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 0|>]]}]}], "}"}]}], ",", 
   RowBox[{"1", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"Sin", "[", 
        FractionBox["\[Phi]", "2"], "]"}], "2"], ",", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["1", "2"]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}], ")"}], " ", 
       InterpretationBox[
        TemplateBox[{
          TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
            SubscriptBox["1", 
             TemplateBox[{",", "\",\"", 
               InterpretationBox[
                SubscriptBox["S", 
                 TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
                $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
           "RowWithSeparators"]},
         "Ket"],
        Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 1|>]]}]}], "}"}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[164]=",
 CellID->1155222754,ExpressionUUID->"12ee0337-03d5-4b3a-bd9c-a6471d6ba482"]
}, Open  ]],

Cell["\<\
