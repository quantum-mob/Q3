    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"Text"}]],ExpressionUUID->
  "afb37d8a-5a67-4d76-b18b-160817d0cff0"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"0436293f-48bc-4d0c-b45a-77793f5b8aa1"],

