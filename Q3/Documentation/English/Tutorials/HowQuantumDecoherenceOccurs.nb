Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ". Mach-Zehnder interference experiments. ",
 StyleBox["(left)",
  FontWeight->"Bold"],
 " Ideal case without decoherence. The region labeled with \[Phi] causes a \
relative phase shift in the photon traveling along the upper arm. ",
 StyleBox["(right)",
  FontWeight->"Bold"],
 " The photon traveling along the upper arm interacts with a two-level system \
and causes it to make a transition from the ground state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "0"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "7507b43d-69c0-4f56-a134-3448be6b389d"],
 " to the excited state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Epsilon]", "1"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "bcd7695e-4281-43fe-af11-d0b1d5f4bd9a"],
 "."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->1995122200,ExpressionUUID->"a545988f-b19e-400a-9205-443cef61fafa"],

