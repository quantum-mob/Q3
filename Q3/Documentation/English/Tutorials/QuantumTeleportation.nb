Cell[CellGroupData[{

Cell["Synopsis", "TechNoteSection",
 CellID->255888865,ExpressionUUID->"bb584308-2bfc-4948-b72e-ddcf3c0d9701"],

Cell[TextData[{
 "Suppose that Bob wants to send one bit of quantum information, say, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     TemplateBox[{"\[Psi]"},
      "Ket"], "C"], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       TemplateBox[{"0"},
        "Ket"], "C"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      SubscriptBox[
       TemplateBox[{"1"},
        "Ket"], "C"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "e28d366c-4f1d-4736-9723-9ed4ce2b7319"],
 " stored in Charlie\[CloseCurlyQuote]s qubit, to Alice residing in a place \
far away from Bob (and Charlie). There is no quantum communication channel \
operating between Alice and Bob to directly send the quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f555c749-2b48-4c20-a820-1546d8b147b0"],
 " through. Fortunately, however, there is a classical commutation channel."
}], "TechNoteText",
 CellID->1461892761,ExpressionUUID->"95f2d4ec-e9b9-4d1d-a906-862b464e3d39"],

Cell[TextData[{
 "\tIt is important to note that the quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ae3bb96c-487a-4399-b9a3-e98aaba2051f"],
 " is unknown. The ",
 ButtonBox["no-cloning theorem",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/NoCloningTheorem"],
 " prevents a naive approach such as copying and transmitting the quantum \
state."
}], "TechNoteText",
 CellID->671228800,ExpressionUUID->"10e27e5a-6a58-4aaf-b9b3-c50c848835d0"]
}, Open  ]],

Cell[CellGroupData[{

