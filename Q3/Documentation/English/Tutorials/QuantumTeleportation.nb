    RowBox[{"\"\<Invisible\>\"", "\[Rule]", 
     RowBox[{"S", "[", "1.5", "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[41]:=",
 CellID->1612209499,ExpressionUUID->"7ff9ba00-adea-4cb1-8b41-6b9a1d3764c7"],

