    RowBox[{"Ket", "[", 
     RowBox[{"S", "@", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3", ",", "4", ",", "5"}], "}"}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"S", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"2", ",", "4"}], "}"}], ",", "6"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"CNOT", "[", 
       RowBox[{
        RowBox[{"S", "[", "2", "]"}], ",", 
        RowBox[{"S", "[", "3", "]"}]}], "]"}], ",", 
      RowBox[{"CNOT", "[", 
       RowBox[{
        RowBox[{"S", "[", "4", "]"}], ",", 
        RowBox[{"S", "[", "5", "]"}]}], "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", "\"\<Separator\>\"", ",", "\[IndentingNewLine]", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "3", "]"}], ",", 
      RowBox[{"S", "[", "4", "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellLabel->"In[49]:=",
