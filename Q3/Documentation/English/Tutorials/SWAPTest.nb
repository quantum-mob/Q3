Cell[CellGroupData[{

Cell["Notes", "TechNoteSection",
 CellID->365092346,ExpressionUUID->"8d24f564-773a-43c1-a521-5fb97d257d98"],

Cell[TextData[{
 "In the simple method introduced above, one can get the absolute value of \
the Hermitian product. It is also possible to get the sign (for real vectors) \
or real part (for complex vectors) as well. See Section 6.1.1 of ",
 ButtonBox["Schult and Petruccione (2018)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-3-319-96424-9"], None}],
 " and ",
 ButtonBox["Zhao, Fitzsimons and Fitzsimons (2019)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1103/physreva.99.052331"], None}],
 "."
}], "TechNoteText",
 CellID->1711937219,ExpressionUUID->"8e3abeb0-046e-4caa-b328-cfe652db8dbb"]
}, Open  ]],

