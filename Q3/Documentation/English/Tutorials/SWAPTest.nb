Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". A quantum circuit for the SWAP test. The first quantum register is a \
single qubit whereas the second and third quantum registers consist of an \
equal number of qubits."
}], "TechNoteCaption",
 CellID->2019350663,ExpressionUUID->"bd432a43-095c-4b30-b92f-4ca5cd71eec9"],

Cell["Figure 1 above shows a quantum circuit for the swap test.", \
"TechNoteText",
 CellID->693948956,ExpressionUUID->"7ed53223-1af9-4ddc-be08-70d231e57fde"],

Cell[TextData[{
 "The first Hadamard gate and the controlled-swap gate (also known as the ",
 StyleBox[ButtonBox["Fredkin gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Fredkin"],
  FontSlant->"Italic"],
 " for single-qubit target registers) converts the initial state to"
}], "TechNoteText",
 CellID->261620898,ExpressionUUID->"17b2bd97-b2b9-4215-930b-715ae5deef17"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"a", ",", "\[Beta]"}]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "+", 
       TemplateBox[{"1"},
        "Ket"]}], ")"}], "\[CircleTimes]", 
     TemplateBox[{
       RowBox[{"a", ",", "\[Beta]"}]},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"a", ",", "\[Beta]"}]},
       "Ket"]}], "+", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"\[Beta]", ",", "\[Alpha]"}]},
       "Ket"]}]}]}], TraditionalForm]],ExpressionUUID->
  "bf8d55a3-3968-4bd3-a48e-f09bcf7097bd"],
 " ."
}], "TechNoteText",
 CellID->522936198,ExpressionUUID->"74ec15f4-b959-4344-9248-e8e7af1c8174"],

Cell["Then, the second Hadamard gate on the control qubit leads to", \
"TechNoteText",
 CellID->166854471,ExpressionUUID->"a8a9192a-ddcb-4b1a-94c9-a01bae700249"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "+", 
        TemplateBox[{"1"},
         "Ket"]}], ")"}], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"a", ",", "\[Beta]"}]},
       "Ket"]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{"0"},
         "Ket"], "-", 
        TemplateBox[{"1"},
         "Ket"]}], ")"}], "\[CircleTimes]", 
      TemplateBox[{
        RowBox[{"\[Beta]", ",", "\[Alpha]"}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"\[Alpha]"},
       "Ket"]}]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "\[CircleTimes]", 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{
          RowBox[{"\[Alpha]", ",", "\[Beta]"}]},
         "Ket"], "+", 
        TemplateBox[{
          RowBox[{"\[Beta]", ",", "\[Alpha]"}]},
         "Ket"]}], ")"}]}], "+", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], "\[CircleTimes]", 
      RowBox[{"(", 
       RowBox[{
        TemplateBox[{
          RowBox[{"\[Alpha]", ",", "\[Beta]"}]},
         "Ket"], "-", 
        TemplateBox[{
          RowBox[{"\[Beta]", ",", "\[Alpha]"}]},
         "Ket"]}], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "851da306-172b-48df-a1e9-46d30b47bf4e"],
 " ."
}], "TechNoteText",
 CellID->1432553328,ExpressionUUID->"65f0d791-a302-4a86-8957-1b99e35ad39f"],

Cell["\<\
Therefore, upon the measurement on the control qubit, the probability for \
measurement outcomes 0 and 1 are given by \
\>", "TechNoteText",
 CellID->507538620,ExpressionUUID->"dff8e0fd-8a0c-44cb-bde8-bc4581ea86ab"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], "=", 
    RowBox[{
     FractionBox["1", "2"], "+", 
     RowBox[{
      FractionBox["1", "2"], 
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        TemplateBox[{"\[Alpha]", "\[Beta]"},
         "BraKet"], "\[RightBracketingBar]"}], "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"70990c09-5ed7-4f5c-a7fd-0488470682a4"]
}], "TechNoteText",
 CellID->1625395066,ExpressionUUID->"6aa84f24-c31e-4617-92b6-7d5fc5c514f8"],

Cell["and", "TechNoteText",
 CellID->799101365,ExpressionUUID->"a047f53c-356b-42b0-a477-2e094a4ab1bc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "1"], "=", 
    RowBox[{
