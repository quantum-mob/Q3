  RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Ket", "[", "AA", "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Through", "[", 
     RowBox[{"AA", "[", "6", "]"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"UniformlyControlledGate", "[", 
     RowBox[{"AA", ",", "UU", ",", 
      RowBox[{"\"\<Label\>\"", "->", "\"\<U\>\""}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Through", "[", 
     RowBox[{"AA", "[", "6", "]"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"\"\<Invisible\>\"", "->", 
     RowBox[{"A", "[", 
      RowBox[{"$m", "+", 
       RowBox[{"1", "/", "2"}]}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
