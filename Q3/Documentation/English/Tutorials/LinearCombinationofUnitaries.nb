  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 " package is loaded to use the demonstrations in this documentation:"
}], "TechNoteMathCaption",
 CellID->1428640008,ExpressionUUID->"0680728c-c03e-4a5e-9563-9fd773022b82"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->853967906,ExpressionUUID->"b28335fb-a496-4722-81df-21ad62ff8332"]
}, Open  ]],

Cell[CellGroupData[{

Cell["General Implementation", "TechNoteSection",
 CellID->221637712,ExpressionUUID->"35b94658-20b3-4271-ae26-354fc1ff61a8"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "1"], ",", 
    SubscriptBox["U", "2"], ",", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"93b40b5a-3619-4fb3-beb3-3a01817d9b0a"],
 " be unitary operators and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], ",", 
      SubscriptBox["\[Alpha]", "2"], ",", "\[Ellipsis]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"6c2ddaa4-8db1-4323-b5c5-5f4cc848d39f"],
 " be a vector of complex numbers.  We want to implement a linear combination \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ":=", 
    RowBox[{
     SubscriptBox["\[Sum]", "k"], 
     RowBox[{
      SubscriptBox["\[Alpha]", "k"], 
      SubscriptBox["U", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "9d358c27-f3f8-4b0d-856f-2cb6742da573"],
 " of those unitary operators. Since ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "8c8c0fc7-ab3b-4bdd-9949-b0e1e57fb582"],
 " is not unitary in general, ancillary qubits are necessary."
}], "TechNoteText",
 CellID->2083809428,ExpressionUUID->"1d27eb51-96de-48a3-a918-d336035d4fa1"],

Cell[TextData[{
 "One way to implement ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "1e11f29d-2658-4faf-be85-503c9aa54395"],
 " is through the quantum circuit shown in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/LinearCombinationOfUnitaries#1051781767"],
 ", where ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "d60c9ec4-9f19-446a-bdb0-d54085907230"],
 " is a unitary operator with the first column stores the coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "k"], TraditionalForm]],ExpressionUUID->
  "105a9012-66d4-454f-a568-3dfeef1f4fca"],
 " as follows:"
}], "TechNoteText",
 CellID->786839548,ExpressionUUID->"2bd36580-8e67-4ed5-8d29-d41e9b1200c8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "\[DotEqual]", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{"\[Alpha]", 
         SubscriptBox["\[LeftDoubleBracketingBar]", "1"]}]}]]], 
     RowBox[{"(", GridBox[{
        {
         SqrtBox[
          SubscriptBox["\[Alpha]", "1"]], "*", "\[Ellipsis]", "*"},
        {
         SqrtBox[
          SubscriptBox["\[Alpha]", "2"]], "*", "\[Ellipsis]", "*"},
        {"\[VerticalEllipsis]", "\[VerticalEllipsis]", 
         "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
        {"\[VerticalEllipsis]", "*", "\[Ellipsis]", "*"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c4baa2f8-a140-457d-b5cb-3c04832b7e5b"],
 " ."
}], "TechNoteText",
 CellID->1421741120,ExpressionUUID->"abb8c5b1-eaf1-493f-977b-61890d4c7adf"],

Cell[TextData[{
 "More specifically, for given coefficients ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], ",", 
      SubscriptBox["\[Alpha]", "2"], ",", "\[Ellipsis]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"a223c894-f772-4923-9dc5-c238234eaf86"],
 ", the unitary operator ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "1930e096-c93b-4d6f-aac5-3de0017c4b32"],
 " may be implemented by the ",
 ButtonBox["amplitude encoding gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/AmplitudeEncoding"],
 ". The desired operation ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "bac314f4-b702-4f91-9dae-59094d045c93"],
 " is achieved when the ancillary register is measured with all qubits in the \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2df0d584-a0db-4cdf-bcd1-d1ddc57fde13"],
 " state; if not, the procedure fails and must be attempted again. The \
success probability is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Bra"], 
    SuperscriptBox["T", "\[Dagger]"], "T", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], "/", 
     SubsuperscriptBox[
      RowBox[{
      "\[LeftDoubleBracketingBar]", "\[Alpha]", 
       "\[RightDoubleBracketingBar]"}], "1", "2"]}]}], TraditionalForm]],
  ExpressionUUID->"40553235-029a-4350-9cfc-c84df0c12ea6"],
 ". Therefore, the maximum success probability is limited by the squared norm \
of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "4c870c7f-85b4-44ef-b696-f2d14ea55419"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     RowBox[{
     "\[LeftDoubleBracketingBar]", "T", "\[RightDoubleBracketingBar]"}], "2", 
     "2"], "/", 
    SubsuperscriptBox[
     RowBox[{
     "\[LeftDoubleBracketingBar]", "\[Alpha]", 
      "\[RightDoubleBracketingBar]"}], "1", "2"]}], TraditionalForm]],
  ExpressionUUID->"f440931a-b1d1-4900-a5c1-3dafd9b319d3"],
 "."
}], "TechNoteText",
 CellID->1718500619,ExpressionUUID->"2f139c87-501d-4448-be6a-a74c6b2ce272"],

Cell[TextData[{
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], 
     LineBox[{{{5, -1}, {6, -1}}, {{5, -2}, {6, -2}}}]}, 
    LineBox[{{{0, -1}, {5, -1}}, {{0, -2}, {5, -2}}, {{0, -4}, {6, -4}}}], {
     InsetBox[
      TemplateBox[{"0"},
       "Ket"], {-0.2, -1.}, NCache[
      ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1,
       0}], InsetBox[
      TemplateBox[{"0"},
       "Ket"], {-0.2, -2.}, NCache[
      ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1,
       0}]}, {
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -2.4}, {1.4, -0.6}]}, InsetBox[
      StyleBox["\<\"V\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.06666666666666667],
       FontWeight->"Light",
       FontSlant->Italic], {1., -1.5}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}, {LineBox[{{2, -1}, {2, -2}, {2, -4}}], 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      DiskBox[{2, -1}, 0.09, 
       NCache[{Rational[1, 4] Pi, Rational[5, 4] Pi}, {0.7853981633974483, 
        3.9269908169872414`}]], 
      {LightDarkSwitched[
        GrayLevel[0]], 
       DiskBox[{2, -1}, 0.09, 
        NCache[{Rational[-3, 4] Pi, Rational[1, 4] Pi}, {-2.356194490192345, 
