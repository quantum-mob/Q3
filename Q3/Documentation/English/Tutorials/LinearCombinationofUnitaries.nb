Cell[TextData[{
 "Consider a set of unitary gates ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["U", "0"], ",", 
     SubscriptBox["U", "1"], ",", 
     SubscriptBox["U", "2"], ",", 
     SubscriptBox["U", "3"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "b086d667-518d-4978-9541-93a4d2f0c21d"],
 " on the system register of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "k"], ":=", 
    RowBox[{"exp", "[", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      RowBox[{
       SubscriptBox["\[Phi]", "k"], "(", 
       RowBox[{
        RowBox[{
         SubsuperscriptBox["T", "1", "X"], 
         SubsuperscriptBox["T", "2", "X"]}], "+", 
        RowBox[{
         SubsuperscriptBox["T", "1", "Y"], 
         SubsuperscriptBox["T", "2", "Y"]}], "+", 
        RowBox[{
         SubsuperscriptBox["T", "1", "Z"], 
         SubsuperscriptBox["T", "2", "Z"]}]}], ")"}]}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"f73e2fbf-bd1b-4418-912a-a5693220bce0"],
 " ."
}], "TechNoteMathCaption",
 CellID->216503724,ExpressionUUID->"02662317-de4c-470b-b1d5-370d186d9bae"],

