 CellID->853967906,ExpressionUUID->"4d3d3231-a3c0-46af-bcfc-240e551071b1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["General Implementation", "TechNoteSection",
 CellID->221637712,ExpressionUUID->"6a92814a-0ed4-4b6c-8562-54bfd83463bb"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "1"], ",", 
    SubscriptBox["U", "2"], ",", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"649954b2-62d0-43b0-bc84-9d2276298acd"],
 " be unitary operators and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], ",", 
      SubscriptBox["\[Alpha]", "2"], ",", "\[Ellipsis]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"2ce782ba-6168-4ae8-b68b-290f30d23e74"],
 " be a vector of complex numbers.  We want to implement a linear combination \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", ":=", 
    RowBox[{
     SubscriptBox["\[Sum]", "k"], 
     RowBox[{
      SubscriptBox["\[Alpha]", "k"], 
      SubscriptBox["U", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "1d4f0b7e-4cf5-4fcc-aeb6-4962132c5a50"],
 " of those unitary operators. Since ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "810ff087-5d25-4cab-8067-657d668df859"],
 " is not unitary in general, ancillary qubits are necessary."
}], "TechNoteText",
 CellID->2083809428,ExpressionUUID->"80812fd0-60b4-4f8d-a34d-1fc3f3882020"],

Cell[TextData[{
 "One way to implement ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "ba47745f-73f4-4cd6-b19f-dfc2e7c7f28a"],
 " is through the quantum circuit shown in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/LinearCombinationOfUnitaries#1051781767"],
 ", where ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "4a42e448-19e8-4bb1-aa31-abfd20748a19"],
 " is a unitary operator with the first column stores the coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "k"], TraditionalForm]],ExpressionUUID->
  "0903a048-fe9f-41f0-9eff-bfed2c9975fe"],
 " as follows:"
}], "TechNoteText",
 CellID->786839548,ExpressionUUID->"0a0417c8-499a-4fa7-8af8-4685c7da68f0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"V", "\[DotEqual]", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"\[LeftDoubleBracketingBar]", 
        RowBox[{"\[Alpha]", 
         SubscriptBox["\[LeftDoubleBracketingBar]", "1"]}]}]]], 
     RowBox[{"(", GridBox[{
        {
         SqrtBox[
          SubscriptBox["\[Alpha]", "1"]], "*", "\[Ellipsis]", "*"},
        {
         SqrtBox[
          SubscriptBox["\[Alpha]", "2"]], "*", "\[Ellipsis]", "*"},
        {"\[VerticalEllipsis]", "\[VerticalEllipsis]", 
         "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
        {"\[VerticalEllipsis]", "*", "\[Ellipsis]", "*"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "ca20980d-efa8-419f-a169-527c1f114f67"],
 " ."
}], "TechNoteText",
 CellID->1421741120,ExpressionUUID->"a20b4cb7-9a26-4b7f-8eeb-3069380cf3b0"],

Cell[TextData[{
 "More specifically, for given coefficients ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], ",", 
      SubscriptBox["\[Alpha]", "2"], ",", "\[Ellipsis]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"3d1af713-78f4-4750-a3c1-58e9ec4e12b5"],
 ", the unitary operator ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "4b9e5904-c93e-4d78-8578-d4998246a422"],
 " may be implemented by the ",
 ButtonBox["amplitude encoding gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/AmplitudeEncoding"],
 ". The desired operation ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "c797deef-4917-4a2f-94cf-d5abb6ec5e4b"],
 " is achieved when the ancillary register is measured with all qubits in the \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8945255b-05a5-48c5-bd45-08b9ed1952d5"],
 " state; if not, the procedure fails and must be attempted again. The \
success probability is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Bra"], 
    SuperscriptBox["T", "\[Dagger]"], "T", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], "/", 
     SubsuperscriptBox[
      RowBox[{
      "\[LeftDoubleBracketingBar]", "\[Alpha]", 
       "\[RightDoubleBracketingBar]"}], "1", "2"]}]}], TraditionalForm]],
  ExpressionUUID->"258790e8-7b7e-41fb-8a1e-33919a361790"],
 ". Therefore, the maximum success probability is limited by the squared norm \
of ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "08fa5dd5-3aff-4f74-a557-40d7ef4e4861"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     RowBox[{
     "\[LeftDoubleBracketingBar]", "T", "\[RightDoubleBracketingBar]"}], "2", 
     "2"], "/", 
    SubsuperscriptBox[
     RowBox[{
     "\[LeftDoubleBracketingBar]", "\[Alpha]", 
      "\[RightDoubleBracketingBar]"}], "1", "2"]}], TraditionalForm]],
  ExpressionUUID->"aed0d93c-8b72-4e59-a9f8-61e936a25233"],
 "."
}], "TechNoteText",
 CellID->1718500619,ExpressionUUID->"72bf9746-a626-4cec-82d6-bae5577d2553"],

Cell[TextData[{
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], 
     LineBox[{{{5, -1}, {6, -1}}, {{5, -2}, {6, -2}}}]}, 
    LineBox[{{{0, -1}, {5, -1}}, {{0, -2}, {5, -2}}, {{0, -4}, {6, -4}}}], {
     InsetBox[
      TemplateBox[{"0"},
       "Ket"], {-0.2, -1.}, NCache[
      ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1,
       0}], InsetBox[
      TemplateBox[{"0"},
       "Ket"], {-0.2, -2.}, NCache[
      ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1,
       0}]}, {
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -2.4}, {1.4, -0.6}]}, InsetBox[
      StyleBox["\<\"V\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.06666666666666667],
       FontWeight->"Light",
       FontSlant->Italic], {1., -1.5}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}, {LineBox[{{2, -1}, {2, -2}, {2, -4}}], 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      DiskBox[{2, -1}, 0.09, 
       NCache[{Rational[1, 4] Pi, Rational[5, 4] Pi}, {0.7853981633974483, 
        3.9269908169872414`}]], 
      {LightDarkSwitched[
        GrayLevel[0]], 
