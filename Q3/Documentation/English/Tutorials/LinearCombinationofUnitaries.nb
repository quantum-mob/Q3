Cell[TextData[{
 "Consider a set of unitary gates ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["U", "0"], ",", 
     SubscriptBox["U", "1"], ",", 
     SubscriptBox["U", "2"], ",", 
     SubscriptBox["U", "3"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "f880149f-a043-4dd8-ba03-4e9d75811b7b"],
 " on the system register of the form\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "k"], ":=", 
    RowBox[{"exp", "[", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      RowBox[{
       SubscriptBox["\[Phi]", "k"], "(", 
       RowBox[{
        RowBox[{
         SubsuperscriptBox["T", "1", "X"], 
         SubsuperscriptBox["T", "2", "X"]}], "+", 
        RowBox[{
         SubsuperscriptBox["T", "1", "Y"], 
         SubsuperscriptBox["T", "2", "Y"]}], "+", 
        RowBox[{
         SubsuperscriptBox["T", "1", "Z"], 
         SubsuperscriptBox["T", "2", "Z"]}]}], ")"}]}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"964f4d39-26d4-4e8c-8c21-b36bb9313545"],
 " ."
}], "TechNoteMathCaption",
 CellID->216503724,ExpressionUUID->"3783e914-4e1f-49f9-a88c-52b532be3929"],

