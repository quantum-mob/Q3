Cell["\<\
For the particular initial state, the success probability is given as follows:\
\>", "TechNoteMathCaption",
 CellID->1872304997,ExpressionUUID->"effcf3ef-3480-4103-9ee5-b2ceb84b3166"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vv", "=", 
   RowBox[{"Matrix", "[", "in", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"prb", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", "vv", "]"}], ".", 
      RowBox[{"ConjugateTranspose", "[", "mat", "]"}], ".", "mat", ".", 
      "vv"}], "/", "16"}], "//", "N"}], "//", "Chop"}]}]}], "Input",
 CellLabel->"In[25]:=",
 CellID->255380146,ExpressionUUID->"2428472e-e674-401b-a277-1b83f1a4da1f"],

