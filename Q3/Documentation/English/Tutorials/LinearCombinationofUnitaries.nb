 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"k", "=", "0"}], ",", "\[Ellipsis]", ",", 
     RowBox[{
      SuperscriptBox["2", "m"], "-", "1"}]}], ")"}], TraditionalForm]],
  ExpressionUUID->"a64d8828-0189-4df0-9f80-70ee1c539d40"],
 " on the system register:"
}], "TechNoteMathCaption",
