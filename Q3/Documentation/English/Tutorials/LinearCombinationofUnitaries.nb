Cell["\<\
For the particular initial state, the success probability is given as follows:\
\>", "TechNoteMathCaption",
 CellID->1872304997,ExpressionUUID->"ac0dbe04-f0fb-4000-9853-4883ae77d493"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"vv", "=", 
   RowBox[{"Matrix", "[", "in", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"prb", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Conjugate", "[", "vv", "]"}], ".", 
      RowBox[{"ConjugateTranspose", "[", "mat", "]"}], ".", "mat", ".", 
      "vv"}], "/", "16"}], "//", "N"}], "//", "Chop"}]}]}], "Input",
 CellLabel->"In[25]:=",
 CellID->255380146,ExpressionUUID->"7ce8b1e4-8651-4f5f-8f91-7c5c8bb28871"],

