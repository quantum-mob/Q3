           RowBox[{
            RowBox[{"First", "[", "#2", "]"}], "-", "1"}]}], "]"}]}]}], "]"}],
       "&"}], ",", "\[IndentingNewLine]", "aa"}], "\[IndentingNewLine]", 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
