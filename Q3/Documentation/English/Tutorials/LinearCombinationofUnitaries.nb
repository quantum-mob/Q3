    RowBox[{"UniformlyControlledGate", "[", 
     RowBox[{"AA", ",", "UU", ",", 
      RowBox[{"\"\<Label\>\"", "->", "\"\<U\>\""}]}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"Through", "[", 
     RowBox[{"AA", "[", "6", "]"}], "]"}], ",", "\[IndentingNewLine]", 
