Cell[TextData[{
 "To understate the above success probability, calculate the squared norm of \
operator ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "1c11b25b-4569-4e0e-a28a-2d60068b427f"],
 ", which gives the maximum success probability:"
}], "TechNoteMathCaption",
 CellID->188723714,ExpressionUUID->"e9cb7a62-f329-4ec5-bf76-eb1d800c8a88"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{"Total", "[", 
    RowBox[{"Matrix", "@", "ex"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"max", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Norm", "[", 
       RowBox[{"mat", ",", "2"}], "]"}], "^", "2"}], "/", "16"}], "//", "N"}],
    "//", "Chop"}]}]}], "Input",
 CellLabel->"In[23]:=",
 CellID->1600337733,ExpressionUUID->"3c7a053a-80a6-456b-8af2-135aea75a55c"],

