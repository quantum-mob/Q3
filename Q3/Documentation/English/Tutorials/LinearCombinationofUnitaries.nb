Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"U", "[", "k_", "]"}], ":=", 
  RowBox[{"Rotation", "[", 
   RowBox[{
    RowBox[{"Pi", "*", 
     RowBox[{"k", "/", "6"}]}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "2"}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"UU", "=", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"U", "[", "k", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{
       RowBox[{"Range", "@", 
        RowBox[{"Power", "[", 
         RowBox[{"2", ",", "$m"}], "]"}]}], "-", "1"}]}], "}"}]}], 
   "]"}]}]}], "Input",
 CellLabel->"In[7]:=",
 CellID->1361450766,ExpressionUUID->"c505b68a-1206-47e0-a877-58ffa6e7d90f"],

