Cell[TextData[{
 "To understate the above success probability, calculate the squared norm of \
operator ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "a7d2b936-7a16-4413-9131-48a3b2ad439e"],
 ", which gives the maximum success probability:"
}], "TechNoteMathCaption",
 CellID->188723714,ExpressionUUID->"fa08664b-44d9-477b-a3a1-9639b06d09bc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mat", "=", 
   RowBox[{"Total", "[", 
    RowBox[{"Matrix", "@", "ex"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"max", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Norm", "[", 
       RowBox[{"mat", ",", "2"}], "]"}], "^", "2"}], "/", "16"}], "//", "N"}],
    "//", "Chop"}]}]}], "Input",
 CellLabel->"In[23]:=",
 CellID->1600337733,ExpressionUUID->"573a19d0-6f4b-4334-9a56-6f95e4ce904c"],

