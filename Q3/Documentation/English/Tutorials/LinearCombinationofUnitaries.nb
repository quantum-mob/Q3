 CellID->1025109959,ExpressionUUID->"fbdfb219-c0fc-4019-ac07-1c6a1ff3791f"],

Cell["\<\
Q3 functions that are useful to construct a linear combination of unitary \
operators.\
\>", "TechNoteCaption",
 CellID->1909264679,ExpressionUUID->"18432cf4-d0da-4465-97f2-810355db488b"],

Cell[TextData[{
 "Make sure that the ",
