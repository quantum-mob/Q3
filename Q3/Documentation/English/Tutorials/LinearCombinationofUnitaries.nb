      RowBox[{"2", "/", "6"}], ",", 
      RowBox[{"4", "/", "6"}], ",", 
      RowBox[{"5", "/", "6"}]}], "}"}], "*", "Pi"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ex", "=", 
