Cell[TextData[{
 "In general, ",
 Cell[BoxData[
  FormBox["T", TraditionalForm]],ExpressionUUID->
  "51f8e57a-4caa-43c7-852d-6c02ce00d210"],
 " is not unitary, and cannot be directly implemented on a quantum computer. \
However, one can realize it probabilistically with a quantum circuit of the \
form and post-selection with respect to the ancilla register for state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"00", "\[Ellipsis]0"}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "fbcc0296-3a7d-47de-9d6b-65a41cf491e1"],
 ":"
}], "TechNoteMathCaption",
 CellID->47470155,ExpressionUUID->"c9d5966b-f02f-40b2-82e7-b560d87edec5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", "\[IndentingNewLine]", 
