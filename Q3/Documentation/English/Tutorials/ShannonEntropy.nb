Cell[BoxData[{
 RowBox[{
  RowBox[{"max", "=", 
   RowBox[{"Max", "[", "data", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"data", ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"Line", "@", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
