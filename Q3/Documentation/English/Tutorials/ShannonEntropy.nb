   FractionBox["1", "17"], ",", 
   FractionBox["3", "17"], ",", 
   FractionBox["1", "17"], ",", 
   FractionBox["5", "17"], ",", 
   FractionBox["3", "17"], ",", 
   FractionBox["4", "17"]}], "}"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->1297315053,ExpressionUUID->"692eaab7-d527-4ff5-b8bd-bda22a106995"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qq", "=", 
  RowBox[{"Normalize", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "3", ",", "2", ",", "4", ",", "1", ",", "1"}], "}"}], ",",
     "Total"}], "]"}]}]], "Input",
 CellLabel->"In[2]:=",
 CellID->828444533,ExpressionUUID->"aa9a480a-2ab3-44f1-9a00-21caa1a978af"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "12"], ",", 
   FractionBox["1", "4"], ",", 
   FractionBox["1", "6"], ",", 
   FractionBox["1", "3"], ",", 
   FractionBox["1", "12"], ",", 
   FractionBox["1", "12"]}], "}"}]], "Output",
 CellLabel->"Out[2]=",
 CellID->572627780,ExpressionUUID->"5428a4b6-9d32-4c1f-8622-5253ba6be064"]
}, Open  ]],

Cell["\<\
Calculate the (classical) relative entropy between the two probability \
distributions\
\>", "TechNoteMathCaption",
 CellID->1316109597,ExpressionUUID->"0ecda109-9a23-4b4e-91f3-5b9da9fbde07"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rel", "=", 
  RowBox[{"ShannonEntropy", "[", 
   RowBox[{"pp", ",", "qq"}], "]"}]}]], "Input",
 CellLabel->"In[3]:=",
 CellID->1560551474,ExpressionUUID->"14624948-0c6d-4c73-9dcc-57c974c9201e"],

Cell[BoxData[
 RowBox[{
  FractionBox["6", "17"], "+", 
  FractionBox[
   RowBox[{"5", " ", 
    RowBox[{"Log", "[", "3", "]"}]}], 
   RowBox[{"17", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]], "-", 
  FractionBox[
   RowBox[{"5", " ", 
    RowBox[{"Log", "[", 
     FractionBox["17", "5"], "]"}]}], 
   RowBox[{"17", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]], "-", 
  FractionBox[
   RowBox[{"4", " ", 
    RowBox[{"Log", "[", 
     FractionBox["17", "4"], "]"}]}], 
   RowBox[{"17", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]], "-", 
  FractionBox[
   RowBox[{"6", " ", 
    RowBox[{"Log", "[", 
     FractionBox["17", "3"], "]"}]}], 
   RowBox[{"17", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]], "+", 
  FractionBox[
   RowBox[{"Log", "[", "6", "]"}], 
   RowBox[{"17", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]], "+", 
  FractionBox[
   RowBox[{"8", " ", 
    RowBox[{"Log", "[", "12", "]"}]}], 
   RowBox[{"17", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]], "-", 
  FractionBox[
   RowBox[{"2", " ", 
    RowBox[{"Log", "[", "17", "]"}]}], 
   RowBox[{"17", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]]}]], "Output",
 CellLabel->"Out[3]=",
 CellID->1280876253,ExpressionUUID->"95af7d26-9c33-45bb-93c6-7894fb162e93"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rel", "//", "N"}]], "Input",
 CellLabel->"In[4]:=",
 CellID->1770487411,ExpressionUUID->"2442936d-9af1-4c53-bb37-a04e2fdb6e26"],

Cell[BoxData["0.2836483639767158`"], "Output",
