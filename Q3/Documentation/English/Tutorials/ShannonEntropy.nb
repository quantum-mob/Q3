   RowBox[{"AspectRatio", "->", "1"}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<H(X:Y)\>\"", ",", "\"\<H(Y)\>\""}], "}"}]}]}], 
  "]"}]}], "Input",
 CellLabel->"In[156]:=",
 CellID->1945668745,ExpressionUUID->"3014627e-de77-42e2-8ddb-a780cc0d9657"],

