Cell["\<\
Why is the relative entropy a good measure of closeness of two probability \
distributions? Or, is it at all? For example, consider the two probability \
distributions\
\>", "TechNoteText",
 CellID->1803954758,ExpressionUUID->"137bd563-b58a-49bb-aa3f-5e76312fb7e9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"p", "(", "x", ")"}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      FractionBox["2", "3"], ",", 
      FractionBox[
       RowBox[{"1", "-", "\[Epsilon]"}], "3"], ",", 
      FractionBox["\[Epsilon]", "3"]}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"70f84338-319f-4e09-8f88-5091d898e36c"],
 ",\t    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"q", "(", "x", ")"}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      FractionBox["2", "3"], ",", 
      FractionBox["1", "3"], ",", 
      FractionBox["0", "3"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "b9916674-726b-43d5-a2e9-a1b997a4a5a1"],
 " "
}], "TechNoteText",
 CellID->893489360,ExpressionUUID->"1792e426-f87f-4b71-9b50-6c26a7a5ccf5"],

Cell[TextData[{
 "with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", "\[Epsilon]", "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"fea084d2-75e1-44ff-97c0-e97eeb40a81f"],
 ". The two distributions look reasonably similar to each other. Yet, we have \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p", 
         RowBox[{"(", "x", ")"}]}], "}"}], "\[DoubleVerticalBar]", 
       RowBox[{"{", 
        RowBox[{"q", 
         RowBox[{"(", "x", ")"}]}], "}"}]}], ")"}]}], " ", "=", " ", 
    "\[Infinity]"}], TraditionalForm]],ExpressionUUID->
  "09da8769-56a8-47d4-9f08-828496d09582"],
 " for any arbitrarily small yet finite ",
 Cell[BoxData[
  FormBox["\[Epsilon]", TraditionalForm]],ExpressionUUID->
  "4661a8e8-4683-4046-80af-1582d9499448"],
 ". For comparison, consider another probability distribution"
}], "TechNoteText",
 CellID->1670013696,ExpressionUUID->"a936a3ee-4855-443e-af5a-2871ff7c298e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", "(", "x", ")"}], "}"}], "=", 
    RowBox[{"{", 
     RowBox[{
      FractionBox["1", "6"], ",", 
      FractionBox["5", "6"], ",", "0"}], "}"}]}], TraditionalForm]],
  ExpressionUUID->"08d9adb1-a6c1-45fa-81a5-c67e317bf84b"],
 "."
}], "TechNoteText",
 CellID->308922382,ExpressionUUID->"3531f003-24a3-4d28-947d-bb15de57134a"],

Cell[TextData[{
 "It looks considerably different from both ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "5422e49d-7d84-496c-9e15-80f218add900"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"q", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "56be08b2-b16c-45c9-9803-1df0d91ba021"],
 ". However, we have"
}], "TechNoteText",
 CellID->1590499475,ExpressionUUID->"a92f4442-8d61-49ba-b779-2eb3e5ea6d72"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r", 
         RowBox[{"(", "x", ")"}]}], "}"}], " ", "\[DoubleVerticalBar]", " ", 
       RowBox[{"{", 
        RowBox[{"q", 
         RowBox[{"(", "x", ")"}]}], "}"}]}], ")"}]}], " ", "\[TildeTilde]", 
    " ", "1.4183"}], TraditionalForm]],ExpressionUUID->
  "09f26be7-c6bc-4627-b168-ec148af8b34b"],
 "."
}], "TechNoteText",
 CellID->1795722116,ExpressionUUID->"26cb14ec-558b-442a-adab-6b69233ff17d"],

Cell[TextData[{
 "Why should we regard that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "eea540dc-a7f4-4656-ad93-bedd39ed7040"],
 " is more different from {q(x)} than ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"r", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "11795161-f0af-4662-b49c-2c9843553a1e"],
 " is?"
}], "TechNoteText",
 CellID->2113912321,ExpressionUUID->"19460283-2813-4926-acfc-8c90d130038e"],

Cell[TextData[{
 "Another weird property of the relative entropy, as a distance measure, is \
that it is asymmetric about ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "81dd676b-9ed0-4eda-8cb3-852fdbdd3c16"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"q", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "48f2b01a-2029-4a73-bd99-9a560faba061"],
 ". For the above example, we already observed"
}], "TechNoteText",
 CellID->554923079,ExpressionUUID->"653b7aea-1538-486a-aa07-f1d9b5dfbd56"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p", 
         RowBox[{"(", "x", ")"}]}], "}"}], " ", "\[DoubleVerticalBar]", " ", 
       RowBox[{"{", 
        RowBox[{"q", 
         RowBox[{"(", "x", ")"}]}], "}"}]}], ")"}]}], " ", "=", " ", 
    "\[Infinity]"}], TraditionalForm]],ExpressionUUID->
  "d8a27cf7-36ac-4744-8de0-fc8f27c696fc"],
 ", "
}], "TechNoteText",
 CellID->70709832,ExpressionUUID->"3e395966-3452-40f6-aeb4-e316b1b7e459"],

Cell["whereas we find", "TechNoteText",
 CellID->861689633,ExpressionUUID->"82a413ce-0856-421c-874b-d6f9cfff901b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"q", 
        RowBox[{"(", "x", ")"}]}], "}"}], " ", "\[DoubleVerticalBar]", " ", 
      RowBox[{"{", 
       RowBox[{"p", 
        RowBox[{"(", "x", ")"}]}], "}"}]}], ")"}], " ", "\[TildeTilde]", " ", 
    
    FractionBox["\[Epsilon]", 
     RowBox[{"3", "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "2"}]], "\[TildeTilde]",
     "0"}], TraditionalForm]],ExpressionUUID->
  "ae676be1-82ce-4d4b-963a-9fcbb776d467"],
 "."
}], "TechNoteText",
 CellID->1935430110,ExpressionUUID->"8db7501c-6719-4ce3-a176-8c0feb335dfc"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->839057661,ExpressionUUID->"21d23311-a85b-4bb9-acb5-a9ce35ac76fa"],

Cell["\<\
Consider an evil dice with strongly biased probability distribution.\
\>", "TechNoteMathCaption",
 CellID->19784877,ExpressionUUID->"e1f82bff-8183-435e-9f1d-001d0ef3602a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pp", "=", 
  RowBox[{"Normalize", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2", ",", "2", ",", "4", ",", "3", ",", "0"}], "}"}], ",",
     "Total"}], "]"}]}]], "Input",
 CellLabel->"In[11]:=",
 CellID->169260443,ExpressionUUID->"6db63643-5153-428c-a83b-a5b7fea6e6b5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "12"], ",", 
   FractionBox["1", "6"], ",", 
   FractionBox["1", "6"], ",", 
   FractionBox["1", "3"], ",", 
   FractionBox["1", "4"], ",", "0"}], "}"}]], "Output",
 CellLabel->"Out[11]=",
 CellID->843456974,ExpressionUUID->"84fc3dc7-5853-42d2-979b-5e64c64eae50"]
}, Open  ]],

Cell["Here is another probability distribution.", "TechNoteMathCaption",
 CellID->236364139,ExpressionUUID->"781efe3f-5fa9-4297-8dc9-127995c0e8d3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Epsilon]", "=", 
   RowBox[{"1", "/", "100"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Delta]", "=", 
   RowBox[{"Append", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"-", "\[Epsilon]"}], ",", "5"}], "]"}], ",", 
     RowBox[{"5", "\[Epsilon]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"qq", "=", 
  RowBox[{"pp", "+", "\[Delta]"}]}]}], "Input",
 CellLabel->"In[12]:=",
 CellID->663972346,ExpressionUUID->"f997f71b-d0ac-4bbe-861d-57f93e0f487f"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["11", "150"], ",", 
   FractionBox["47", "300"], ",", 
   FractionBox["47", "300"], ",", 
   FractionBox["97", "300"], ",", 
   FractionBox["6", "25"], ",", 
   FractionBox["1", "20"]}], "}"}]], "Output",
 CellLabel->"Out[14]=",
 CellID->1722948413,ExpressionUUID->"62b9752e-5345-45dd-9f40-52d42c4dcd0e"]
}, Open  ]],

Cell["\<\
The two probability distributions look similar. Indeed, the classical \
fidelity between them is reasonably high.\
\>", "TechNoteMathCaption",
 CellID->1703016356,ExpressionUUID->"19dfa995-e875-4cc2-a426-dae105a14746"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ClassicalFidelity", "[", 
   RowBox[{"pp", ",", "qq"}], "]"}], "//", "N"}]], "Input",
 CellLabel->"In[15]:=",
 CellID->1399903238,ExpressionUUID->"23f6b83c-db65-4150-8922-eac8512b3beb"],

Cell[BoxData["0.9745964874963337`"], "Output",
 CellLabel->"Out[15]=",
 CellID->1703719855,ExpressionUUID->"e145b77a-e9db-4bb0-8fa0-0c0b8c66af80"]
}, Open  ]],

Cell[TextData[{
 "Nevertheless, the relative entropy of ",
 StyleBox["qq", "Input"],
 " to ",
 StyleBox["pp", "Input"],
 " diverges."
}], "TechNoteMathCaption",
 CellID->119920984,ExpressionUUID->"de5c2a2b-e74a-497c-b1e2-9f1c4e78de4b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ShannonEntropy", "[", 
  RowBox[{"qq", ",", "pp"}], "]"}]], "Input",
 CellLabel->"In[16]:=",
 CellID->341332645,ExpressionUUID->"356f51f8-684e-492a-b0bb-0ff0cb729bc1"],

Cell[BoxData["\[Infinity]"], "Output",
 CellLabel->"Out[16]=",
 CellID->115908387,ExpressionUUID->"e40a2fd1-958e-478b-8764-05ca68321e45"]
}, Open  ]],

Cell[TextData[{
 "Note that relative entropy is asymmetrical about the two input arguments, \
and the relative entropy of ",
 StyleBox["pp", "Input"],
 " to ",
 StyleBox["qq", "Input",
  IgnoreSpellCheck->True],
 " is finite."
}], "TechNoteMathCaption",
 CellID->608754540,ExpressionUUID->"56178ce8-e0cb-4529-8287-d0efa5a41e20"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ShannonEntropy", "[", 
   RowBox[{"pp", ",", "qq"}], "]"}], "//", "N"}]], "Input",
 CellLabel->"In[17]:=",
 CellID->222898868,ExpressionUUID->"6f4ec671-dea4-4f68-8b35-54a51d3a51a3"],

Cell[BoxData["0.0744956984197393`"], "Output",
 CellLabel->"Out[17]=",
 CellID->1493401151,ExpressionUUID->"b344c15b-3914-438e-b4f3-1ceb5ba67846"]
}, Open  ]],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1664482225,ExpressionUUID->"ef6ae417-0c77-496c-8ae1-979db275a873"],

Cell[TextData[{
 "Because of the above drawbacks, the relative entropy is not particularly \
useful or interesting in its own right. There is a separate reason why it is \
used so broadly in investigating entropic quantities and relations. At the \
core of the reason is ",
 StyleBox["Gibbs\[CloseCurlyQuote] inequality",
  FontSlant->"Italic"]
}], "TechNoteText",
 CellID->1830769753,ExpressionUUID->"55c988e3-e291-41be-ba51-7a19558040ae"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p", 
         RowBox[{"(", "x", ")"}]}], "}"}], " ", "\[DoubleVerticalBar]", " ", 
       RowBox[{"{", 
        RowBox[{"q", 
         RowBox[{"(", "x", ")"}]}], "}"}]}], ")"}]}], " ", "\[GreaterEqual]", 
    " ", "0"}], TraditionalForm]],ExpressionUUID->
  "b570e372-f326-4e29-8a61-58c1d5a052a4"]
}], "TechNoteText",
 CellID->601544455,ExpressionUUID->"6641da31-115c-44d8-a862-a4cbcc732bd3"],

Cell[TextData[{
 "with equality attained if and only if the two probability distributions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "b9b5356b-3e0b-423e-a0e8-12fa16843296"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"q", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "44d85637-65dd-4fa3-83d7-b61f67c17377"],
 " are identical. A widely popular technique is to express entropic \
quantities in terms of the relative entropy or regard them as special cases \
of the relative entropy, and then use the Gibbs\[CloseCurlyQuote] inequality \
as necessary."
}], "TechNoteText",
 CellID->1952128756,ExpressionUUID->"090f3ca0-744c-4acd-b123-e7eebd7fcbef"],

Cell[TextData[{
 "As an example, let us prove that the maximum entropy is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"log", "\[VeryThinSpace]", "d"}], TraditionalForm]],ExpressionUUID->
  "a36c22ae-d741-4692-8fda-e4b92becfc72"],
 " for a random variable ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "5ff7460b-c446-467b-905f-c5275f02e03a"],
 " taking ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "81afaba7-55a5-425c-93df-250ed97ece18"],
 " distinct values, using Gibbs\[CloseCurlyQuote] inequality. Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "f52b9a8d-6a5a-4dfd-9624-5f92774c492c"],
 " be the probability distribution associated with ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "3ca52d04-d37f-4640-8b31-f039dc7dfcfd"],
 ". In addition, we consider a uniform distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"q", "(", "x", ")"}], "=", 
    RowBox[{"1", "/", "d"}]}], TraditionalForm]],ExpressionUUID->
  "5a32b7be-bf43-4cc2-8697-3260de2d8c90"],
 ". According to Gibbs\[CloseCurlyQuote] inequality, we have"
}], "TechNoteText",
 CellID->172843226,ExpressionUUID->"6995faf8-288a-463f-9022-ac679d7a0cd8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"p", 
         RowBox[{"(", "x", ")"}]}], "}"}], " ", "\[DoubleVerticalBar]", " ", 
       RowBox[{"{", 
        RowBox[{"q", 
         RowBox[{"(", "x", ")"}]}], "}"}]}], ")"}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"\[Minus]", "H"}], 
       RowBox[{"(", 
        RowBox[{"{", 
         RowBox[{"p", 
          RowBox[{"(", "x", ")"}]}], "}"}], ")"}]}], " ", "+", " ", 
      RowBox[{"log", " ", "d"}]}], " ", "\[GreaterEqual]", " ", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"b1d0cbca-165e-46d6-a213-89bd8b9df976"],
 " ."
}], "TechNoteText",
 CellID->1578208638,ExpressionUUID->"c3113183-b79b-4c38-8c97-7cc09c749a07"],

Cell[TextData[{
 "The equality is attained if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "6a24d4b8-7004-41d0-b086-c521747bb270"],
 " is uniform just like ",
 Cell[BoxData[
  FormBox[
   RowBox[{"q", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "57f086c9-fa21-41f5-8217-4f71ee103917"],
 "; that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "x", ")"}], "=", 
    RowBox[{"1", "/", "d"}]}], TraditionalForm]],ExpressionUUID->
  "36aa531b-0fd7-45b9-b68c-c970a9e1d27c"],
 "."
}], "TechNoteText",
 CellID->1382054769,ExpressionUUID->"fc3cdc4d-b48a-4860-8891-31267576e993"],

Cell[TextData[{
 "Let us close this subsection with a proof of Gibbs\[CloseCurlyQuote] \
inequality. It is instructive because some of its elements are frequently \
used to study other entropic quantities and relations. We first recall the \
properties of a convex function. A function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "dbb3b857-0095-444e-a283-d37996ab95f5"],
 " is said to be convex if it satisfies"
}], "TechNoteText",
 CellID->1011376631,ExpressionUUID->"0880d6e6-6ff8-4a82-891f-d81f5b815353"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "\[Minus]", "t"}], ")"}], "x"}], " ", "+", " ", 
      RowBox[{"t", "\[VeryThinSpace]", "y"}]}], ")"}], "\[LessEqual]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "\[Minus]", "t"}], ")"}], 
      RowBox[{"f", "(", "x", ")"}]}], "+", 
     RowBox[{"t", "\[VeryThinSpace]", 
      RowBox[{"f", "(", "y", ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "9fb2da73-56ea-4b00-b41f-b69e171b6c91"]
}], "TechNoteText",
 CellID->873971212,ExpressionUUID->"4503b06f-f521-457c-90ba-6a6be327e265"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", "t", "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"471cdb87-b1a2-497a-bf47-7ad6a6acbbbe"],
 " and all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "a0e09afb-4769-4f52-8228-0303cb784fef"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "6c32cc72-bc5a-4247-8966-b4f6c2dcac12"],
 " in the domain of the function. It is often expressed in a slightly more \
general but equivalent form"
}], "TechNoteText",
 CellID->46014604,ExpressionUUID->"ab12f5a9-36d0-4b43-a4f1-32e699eee631"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", 
     RowBox[{
      SubscriptBox["\[CapitalSigma]", "j"], " ", 
      RowBox[{"p", "(", "j", ")"}], 
      SubscriptBox["x", "j"]}], ")"}], " ", "\[LessEqual]", " ", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     RowBox[{"p", "(", "j", ")"}], 
     RowBox[{"f", "(", 
      SubscriptBox["x", "j"], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "e4886cdc-2840-4995-a4f9-596e2fe0e7d1"]
}], "TechNoteText",
 CellID->273336508,ExpressionUUID->"8ca2ddbf-9f9a-408f-b84c-2ad4e9d579eb"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "j"], TraditionalForm]],ExpressionUUID->
  "33c1aa19-7aa8-4dad-bbd8-c0c34b90fc0c"],
 " and all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", "j", ")"}]}], TraditionalForm]],ExpressionUUID->
  "98128910-9540-48c3-861f-8799dddfe259"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    RowBox[{"p", 
     RowBox[{"(", "j", ")"}]}], "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"94b07758-cd81-4d04-b3ef-416c0b51c98f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "j"], 
     RowBox[{"p", "(", "j", ")"}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"9c21ed2c-fad0-43c5-bffb-b11470f5edd9"],
 ".If ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", "(", "x", ")"}], TraditionalForm]],ExpressionUUID->
  "11fca61e-5d1f-439c-b436-719ae6659b47"],
 " is differentiable, then one can express the convexity condition in the form"
}], "TechNoteText",
 CellID->499169023,ExpressionUUID->"b8fe4c21-4b7c-481c-9932-6901e7b1fd64"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", "(", "x", ")"}], "\[GreaterEqual]", 
    RowBox[{
     RowBox[{"f", "(", "y", ")"}], "+", 
     RowBox[{
      RowBox[{"f", "'"}], 
      RowBox[{"(", "y", ")"}], 
      RowBox[{"(", 
       RowBox[{"x", "\[Minus]", "y"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"912ddeeb-0a0b-416b-b871-4241087f29a8"]
}], "TechNoteText",
 CellID->1462644379,ExpressionUUID->"cf7ebc23-f9c8-46fa-9978-84120011cb39"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "454d2161-4306-47e7-abe9-0e74767cb9ba"],
 " and ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "14f6d078-be02-407f-beac-7c24df9ae4fe"],
 ". Geometrically, this means that the graph of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "b849babc-4a26-475f-a7cb-ae65de6a0346"],
 " lies above all its tangents. Now, note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"f", " ", 
     RowBox[{"(", "x", ")"}]}], "=", 
    RowBox[{
     RowBox[{"\[Minus]", " ", "log"}], "\[VeryThinSpace]", "x"}]}], 
   TraditionalForm]],ExpressionUUID->"39c917f6-5be5-4db9-9630-c7f1ae138c5e"],
 " is a convex function. Then, we apply the above condition to this negative \
logarithm function by putting ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "a2d62871-93de-4339-b4f3-bbad30f97dfa"],
 " to get"
}], "TechNoteText",
 CellID->418770644,ExpressionUUID->"33fc5509-5bb2-4f3f-a719-d62e4b6bd4f4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"-", "log"}], "\[VeryThinSpace]", "x"}], "\[GreaterEqual]", 
    FractionBox[
     RowBox[{"1", "-", "x"}], 
     RowBox[{
      SubscriptBox["log", "\[ExponentialE]"], "2"}]]}], TraditionalForm]],
  ExpressionUUID->"66faf52c-0100-4323-9a0e-de0ae42436f7"],
 " ."
}], "TechNoteText",
 CellID->974302489,ExpressionUUID->"3a7549f5-bc10-4a4a-ab00-cf3587ea5840"],

Cell["Finally, we examine the relative entropy and obtain", "TechNoteText",
 CellID->539124248,ExpressionUUID->"4440c923-47ac-453b-a7a8-95353128c862"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"p", 
        RowBox[{"(", "x", ")"}]}], "}"}], "\[DoubleVerticalBar]", 
      RowBox[{"{", 
       RowBox[{"q", "(", "x", ")"}], "}"}]}], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Minus]", 
       UnderscriptBox["\[CapitalSigma]", "x"]}], 
      RowBox[{"p", "(", "x", ")"}], "log", 
      FractionBox[
       RowBox[{"p", 
        RowBox[{"(", "x", ")"}]}], 
       RowBox[{"q", "(", "x", ")"}]]}], "\[GreaterEqual]", 
     RowBox[{
      FractionBox["1", 
       RowBox[{
        SubscriptBox["log", "\[ExponentialE]"], "2"}]], 
      UnderscriptBox["\[CapitalSigma]", "x"], 
      RowBox[{"p", "(", "x", ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        FractionBox[
         RowBox[{"q", "(", "x", ")"}], 
         RowBox[{"p", "(", "x", ")"}]]}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"0334bf9b-ceed-4ca6-ba27-b328ee0ab7d4"],
 " ."
}], "TechNoteText",
 CellID->827729443,ExpressionUUID->"8ce98d52-0ed5-4850-8d87-1f32163d7e26"],

Cell["Then, it is clear that", "TechNoteText",
 CellID->249683235,ExpressionUUID->"8932e9c1-96df-42e3-815a-09f1187a9f4f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"H", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"p", 
          RowBox[{"(", "x", ")"}]}], "}"}], " ", "\[DoubleVerticalBar]", " ", 
        
        RowBox[{"{", 
         RowBox[{"q", "(", "x", ")"}], "}"}]}], ")"}]}], "\[GreaterEqual]", 
     RowBox[{
      FractionBox["1", 
       RowBox[{
        SubscriptBox["log", "\[ExponentialE]"], "2"}]], 
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", "x"], "(", 
       RowBox[{
        RowBox[{"p", "(", "x", ")"}], "-", 
        RowBox[{"q", "(", "x", ")"}]}], ")"}]}]}], "=", 
    RowBox[{
     FractionBox[
      RowBox[{"1", "-", "1"}], 
      RowBox[{
       SubscriptBox["log", "\[ExponentialE]"], "2"}]], "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"8e8d2ac3-7955-46ed-92b7-1d4d75d61e24"],
 " ."
}], "TechNoteText",
 CellID->243084407,ExpressionUUID->"619613e7-f15d-44a9-a598-3ffde5dd1d8c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Mutual Information", "TechNoteSection",
 CellID->1881325977,ExpressionUUID->"f95f08dc-3cb9-4984-955a-0a08d2f9695b"],

Cell[TextData[{
 "So far, we have considered a single random variable. Let us now consider \
two random variables ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "fdcc565c-f973-4521-935b-e557ede25cb2"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "5e97ef6b-8d0c-466c-b9a5-857ed2abf39d"],
 " . Suppose that they randomly take values from the sets ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", "x", "}"}], TraditionalForm]],ExpressionUUID->
  "800fcd26-e8e5-4927-b31b-248b5da8b2c8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", "y", "}"}], TraditionalForm]],ExpressionUUID->
  "6f62ad91-37d3-475d-b0f5-87cf502f7048"],
 ", respectively, governed by the ",
 StyleBox["joint probability distribution",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", 
     RowBox[{"x", ",", "y"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "bec6090a-443b-4739-8123-0ed05cb707c6"],
 ". As long as one is concerned with the total uncertainty in ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "c2d639ba-acdc-451a-983c-16bc11b1b264"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "d6422b44-efba-4779-bf02-f0f0ca23ccd7"],
 " or the total information gain after one learns the both values of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "e641544f-15f0-471d-89ee-41e2d1f2ec57"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "e30a2ee3-d3e2-4b9f-b280-5b0d77ae5c3d"],
 ", there is nothing new. The quantity in question is nothing but the Shannon \
entropy associated with the joint probability distribution"
}], "TechNoteText",
 CellID->2043960658,ExpressionUUID->"74a25d36-1b9f-4356-aa43-6622c881e054"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"H", "(", 
      RowBox[{"X", ",", "Y"}], " ", ")"}], "\[Congruent]", 
     RowBox[{"H", "(", 
      RowBox[{"{", 
       RowBox[{"p", "(", 
        RowBox[{"x", ",", " ", "y"}], ")"}], "}"}], ")"}]}], "=", 
    RowBox[{
     RowBox[{"\[Minus]", 
      UnderscriptBox["\[CapitalSigma]", 
       RowBox[{"x", ",", "y"}]]}], 
     RowBox[{"p", "(", 
      RowBox[{"x", ",", "y"}], ")"}], "log", "\[VeryThinSpace]", 
     RowBox[{"p", "(", 
      RowBox[{"x", ",", "y"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "e2b5dcb3-daed-4ef9-b273-a5d3ae7f679f"],
 "."
}], "TechNoteText",
 CellID->1698361594,ExpressionUUID->"3ffea72c-ddcf-4e13-a4b0-193758acbbb6"],

Cell["\<\
To distinguish it from other entropies to be introduced below, we call it \
joint Shannon entropy or simply joint entropy.\
\>", "TechNoteText",
 CellID->10674434,ExpressionUUID->"d647b614-118f-4ad2-85aa-675d6067f718"],

Cell[TextData[{
 "With multiple random variables, a more interesting question is, how much do \
we get to know about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "0ee2c83e-7024-4f58-982b-1d0d00d30327"],
 " (or how much our uncertainty in ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "90d8216a-2234-4a2b-adec-ac7f358efaab"],
 " still remains) when we have learned the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "e8823d75-c604-4fb6-86dc-b7f2b03e5355"],
 "? By learning the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "b57e708b-0d05-4a0f-8b71-f4e1ea190d72"],
 ", the amount of information we acquire about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "5b6cfba1-9715-4679-8b37-5555a9f8d6a8"],
 " is the Shannon entropy, \t"
}], "TechNoteText",
 CellID->1164069537,ExpressionUUID->"27f4167f-0926-4ae6-85c3-81eedc2574fb"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", 
     RowBox[{"(", "Y", " ", ")"}]}], " ", "=", " ", 
    RowBox[{"H", 
     RowBox[{"(", 
      RowBox[{"{", 
       RowBox[{"p", 
        RowBox[{"(", "y", ")"}]}], "}"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"d7011ea7-a095-48a0-a1c3-a55501de541a"]
}], "TechNoteText",
 CellID->940684189,ExpressionUUID->"65a5b1fc-5f7b-48d5-a6db-ca2e4a8a9b4e"],

Cell[TextData[{
 "associated with the probability distribution of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "dc01b2c8-a36c-41b4-914f-5e60e0386faf"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "y", ")"}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "x"], " ", 
     RowBox[{"p", "(", 
      RowBox[{"x", ",", "y"}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "90aa5bbf-d423-452a-876e-b9031b6ce58d"],
 ". In other words, the total uncertainty ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "(", 
    RowBox[{"X", ",", "Y"}], " ", ")"}], TraditionalForm]],ExpressionUUID->
  "1c9adbaa-0e63-49ef-a967-3b51de7a8cdb"],
 " about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "ace60a36-209b-44a5-bb13-500aaf3aa43c"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "bf0fc7f5-871e-4727-a6af-a6613b3814cd"],
 " has decreased by this same amount of uncertainty ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", "Y", " ", ")"}]}], TraditionalForm]],ExpressionUUID->
  "392bbdae-0282-4347-a6e8-4486fdd6626e"],
 ". The Shannon entropy of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "6b822dfe-b6bb-4f40-b910-61f157b575db"],
 " conditional on knowing ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "b5432646-eb7b-4b22-a3bd-d2789f8d228d"],
 " or simply ",
 StyleBox["conditional entropy",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "22f4ccab-cec4-45a1-bf69-102208eb9ffd"],
 " on ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "22ef57c4-1d30-45af-bab3-04c36f00a956"],
 ","
}], "TechNoteText",
 CellID->304555309,ExpressionUUID->"618dc718-58c5-4ac4-a034-c478596f18d0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", "|", "Y"}], " ", ")"}], ":=", 
    RowBox[{
     RowBox[{"H", "(", 
      RowBox[{"X", ",", "Y"}], " ", ")"}], "\[Minus]", 
     RowBox[{"H", "(", "Y", " ", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "1fcc0909-4c0e-4f41-8bdc-60465dacc689"],
 ","
}], "TechNoteText",
 CellID->1207547562,ExpressionUUID->"2d6831ad-4932-4dd8-ad4b-aada42012e2a"],

Cell[TextData[{
 "is the amount of uncertainty still remaining about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "3cbddfae-0685-4d23-bfa6-1c2e63c4fc44"],
 " given that we know the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "fa753c3f-9a1c-4185-9abd-cb97072e4750"],
 ". One can further justify the above definition as a measure of conditional \
uncertainty. Initially, that is, before we learn the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "d57e886c-b916-4e66-994d-f1e45a8b7716"],
 ", the probability distribution of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "9b4771b5-a967-4f53-90b0-d8d63aad0cad"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "x", ")"}], " ", "=", " ", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "x"], " ", 
     RowBox[{"p", "(", 
      RowBox[{"x", ",", " ", "y"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"7b9572c3-815e-445a-8592-abdc07ec27be"],
 ". After we learn the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "c22fda9d-9898-4920-a53a-47f007d7a2e5"],
 " , the random variable ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "b3701b57-33ba-4eac-aab2-63775da6296d"],
 " is now governed by the conditional probability distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", 
     RowBox[{"x", "|", "y"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "aa1e0ac4-f59a-4ee4-9fcf-ba25e4c8e7b8"],
 ". Therefore, one can estimate the average amount of uncertainty about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "a3073949-cc5f-4323-a4f0-7c6a72124ede"],
 " still remaining after we know ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "c9f08908-6d98-4c83-b4b5-fcdc57b61bce"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", 
     RowBox[{"X", "|", "Y"}], " ", ")"}]}], TraditionalForm]],ExpressionUUID->
  "64ee1ab3-10af-43eb-bbd5-80320fa05947"],
 ", by the Shannon entropy associated with the conditional probability \
distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", 
     RowBox[{"x", "|", "y"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "ac0c802b-69f4-4fe0-8cd0-300f709c64ca"],
 ","
}], "TechNoteText",
 CellID->1531410384,ExpressionUUID->"dd4d174d-1918-489f-890f-55e46c07f54f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", "|", "Y"}], " ", ")"}], "=", 
    SubscriptBox[
     RowBox[{"\[LeftAngleBracket]", 
      RowBox[{"H", "(", 
       RowBox[{"{", 
        RowBox[{"p", "(", 
         RowBox[{"x", "|", "y"}], ")"}], "}"}], ")"}], 
      "\[RightAngleBracket]"}], "Y"]}], TraditionalForm]],ExpressionUUID->
  "72f852e1-b64b-4bf0-bd4d-3c8b21d0d78c"],
 " , "
}], "TechNoteText",
 CellID->822814593,ExpressionUUID->"0757a0f4-214b-4e10-836a-1c64c26738ea"],

Cell[TextData[{
 "where the average is over all possible values of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "a3fa3eee-6f35-49ad-a6db-7ab0eb7f65cb"],
 " with respect to the probability\ndistribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", "y", ")"}]}], TraditionalForm]],ExpressionUUID->
  "6fbeb83c-ea8a-42af-beb7-012ecaf6aaad"],
 ". By Bayes\[CloseCurlyQuote] rule, the conditional probability is given by"
}], "TechNoteText",
 CellID->1397661518,ExpressionUUID->"ec3c82b0-83fc-4443-9489-c3e79471db0d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", 
     RowBox[{"x", "|", "y"}], ")"}], " ", "=", 
    RowBox[{
     FractionBox[
      RowBox[{
       RowBox[{"p", "(", 
        RowBox[{"y", "|", "x"}], ")"}], 
       RowBox[{"p", "(", "x", ")"}]}], 
      RowBox[{"p", "(", "y", ")"}]], "=", 
     FractionBox[
      RowBox[{"p", "(", 
       RowBox[{"x", ",", "y"}], ")"}], 
      RowBox[{"p", "(", "y", ")"}]]}]}], TraditionalForm]],ExpressionUUID->
  "2c5e56dd-2dbf-4c7c-a523-81dd4416de09"],
 " ."
}], "TechNoteText",
 CellID->1321002140,ExpressionUUID->"637a93dd-1b01-4fbb-a70b-029163efc964"],

Cell["Then, we have", "TechNoteText",
 CellID->1397024294,ExpressionUUID->"eee71525-d982-4114-951d-9ce04ee99a71"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", "|", "Y"}], " ", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"\[Minus]", 
       UnderscriptBox["\[CapitalSigma]", "y"]}], 
      RowBox[{"p", "(", "y", ")"}], 
      UnderscriptBox["\[CapitalSigma]", "x"], 
      FractionBox[
       RowBox[{"p", "(", 
        RowBox[{"x", ",", "y"}], ")"}], 
       RowBox[{"p", "(", "y", ")"}]], "log", 
      FractionBox[
       RowBox[{"p", 
        RowBox[{"(", 
         RowBox[{"x", ",", "y"}], ")"}]}], 
       RowBox[{"p", "(", "y", ")"}]]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         UnderscriptBox["\[CapitalSigma]", 
          RowBox[{"x", ",", "y"}]]}], 
        RowBox[{"p", "(", 
         RowBox[{"x", ",", "y"}], ")"}], "log", "\[VeryThinSpace]", 
        RowBox[{"p", "(", 
         RowBox[{"x", ",", "y"}], ")"}]}], "+", 
       RowBox[{
        UnderscriptBox["\[CapitalSigma]", "y"], 
        RowBox[{"p", "(", "y", ")"}], "log", "\[VeryThinSpace]", 
        RowBox[{"p", "(", "y", ")"}]}]}], "=", 
      RowBox[{
       RowBox[{"H", "(", 
        RowBox[{"X", ",", "Y"}], ")"}], "-", 
       RowBox[{"H", "(", "Y", ")"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "81344c63-1e02-4aeb-81f2-9ba9b634f5b5"],
 ","
}], "TechNoteText",
 CellID->1348596607,ExpressionUUID->"8b8e2173-f5eb-4ed9-a241-81b4ed07a20d"],

Cell["reproducing the previous defining expression.", "TechNoteText",
 CellID->1320763411,ExpressionUUID->"ec2696dd-4cdf-4d28-943f-370bf4c638a6"],

Cell[TextData[{
 "If ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "a673bb75-9af3-45d9-8324-54a8c155bf2e"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "da4eb546-f531-418b-b86b-6e111cd73584"],
 " are statistically independent, then learning the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "b9353d7b-fc51-4a55-8e14-e65cfddd1af5"],
 " does not help know about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "324fc199-66dd-406b-bb2c-3ad1b48c2170"],
 " at all. In this case, one thus expects that the remaining uncertainty ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", 
     RowBox[{"X", "|", "Y"}], " ", ")"}]}], TraditionalForm]],ExpressionUUID->
  "566b1311-ee6e-4098-8923-465aeafbf59f"],
 " after knowing ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "7f97824a-7c97-4c5c-beae-2264acf554d0"],
 " is the same as the Shannon entropy ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", 
     RowBox[{"{", 
      RowBox[{"p", 
       RowBox[{"(", "x", ")"}]}], "}"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"cf200ee9-39c0-43ba-a1aa-4f6622033278"],
 " associated with the initial probability distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "b2768608-78d3-4001-83c4-0e414de552fb"],
 " of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "6c0f9925-233f-4ff3-8d72-622c03778abd"],
 ". This is indeed the case since with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", 
     RowBox[{"x", ",", "y"}], ")"}], "=", 
    RowBox[{
     RowBox[{"p", "(", "x", ")"}], 
     RowBox[{"p", "(", "y", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "f15cd258-9b14-44e0-9380-9e1545ecda5d"],
 ", we have ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", ",", "Y"}], " ", ")"}], "=", 
    RowBox[{
     RowBox[{"H", "(", "X", ")"}], "+", 
     RowBox[{"H", "(", "Y", " ", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "5b2ad614-fd1f-418a-949b-a08d91988fe7"],
 " and hence ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", "|", "Y"}], " ", ")"}], "=", 
    RowBox[{"H", "(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "e51fece3-31d9-4a14-842f-b609e7adadef"],
 ". On the other hand, if the two variables are correlated with each other, \
then learning the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "8ea699ef-2d89-4b6d-a5f7-87684ef0225f"],
 " reduces the uncertainty about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "52dc1f73-3ff2-4bc7-a087-a04d9c741428"],
 ", on average, below the initial level. For example, consider ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "304709ee-b47c-4709-8281-3565b6186c41"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "86c667ab-b7cf-4b27-8037-fee222fde9d1"],
 " taking values from a common value set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", " ", "\[Ellipsis]", ",", "6"}], "}"}], 
   TraditionalForm]],ExpressionUUID->"38b18b9a-ac8d-4b5a-8f4e-58ad44afdc64"],
 ". Suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", 
     RowBox[{"x", ",", "y"}], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Delta]", 
      RowBox[{"x", ",", "y"}]], "/", "6"}]}], TraditionalForm]],
  ExpressionUUID->"ed7ab963-519a-4695-a143-14bd621e0c4d"],
 ". Once the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "a607af56-323e-4a9d-8dae-e1621f0caaaf"],
 " is known, we know the value of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "681b1a80-75ed-4e06-9bd3-d4e2a9bd4d82"],
 " with certainty and there remains no uncertainty about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "0483ad56-b726-4bf3-a1f3-acb75ee652da"],
 "."
}], "TechNoteText",
 CellID->1679673285,ExpressionUUID->"8a79c273-ac15-4e6e-b68f-8a93aa6c2d0c"],

Cell[TextData[{
 "Therefore, the difference between the initial amount of uncertainty about \
",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "4a41984d-c5ce-4f36-a6cb-dafa8bb7309e"],
 " and the amount of uncertainty about ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "1e625c69-5c36-400d-82f1-446e0ee7cd59"],
 " remaining after learning the value of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "e4e9899e-77a2-47e8-ba53-4add5b2f30eb"],
 " measures the correlation between the two variables. We call it the ",
 StyleBox["mutual information",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "3f8bb69c-c979-4534-805d-ba6690a4f975"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "fd675632-ec5c-4c5d-9f9b-b4fc44efed9e"],
 " , and denote it by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", 
     RowBox[{"X", ":", "Y"}], " ", ")"}]}], TraditionalForm]],ExpressionUUID->
  "2d380937-b1e1-4684-b06b-8a16ee37a614"],
 ". In other words, the mutual information"
}], "TechNoteText",
 CellID->1596361180,ExpressionUUID->"d715cc30-4ebd-45bd-98b9-a1fca29b71ed"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", ":", "Y"}], " ", ")"}], ":=", 
    RowBox[{
     RowBox[{"H", "(", "X", ")"}], "\[Minus]", 
     RowBox[{"H", "(", 
      RowBox[{"X", "|", "Y"}], " ", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"cfcac84f-5b3e-4a29-a363-618b4da467b3"],
 " ,"
}], "TechNoteText",
 CellID->1529150289,ExpressionUUID->"667beab1-5749-4d80-bdfb-db9b59db300a"],

Cell[TextData[{
 "quantifies the common information shared by ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "fdb05b9d-f2db-4a1a-a053-8d9d5b653951"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "60c5372a-9c02-42e8-8d78-d6347b550dd4"],
 ". From the definition of conditional entropy, we have identities"
}], "TechNoteText",
 CellID->1492103574,ExpressionUUID->"64d4c64a-e02a-4dc1-9d05-af44c07381c3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", ":", "Y"}], " ", ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"H", "(", "X", ")"}], "+", 
      RowBox[{"H", "(", "Y", " ", ")"}], "\[Minus]", 
      RowBox[{"H", "(", 
       RowBox[{"X", ",", "Y"}], " ", ")"}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"H", "(", "X", ")"}], "\[Minus]", 
       RowBox[{"H", "(", 
        RowBox[{"X", "|", "Y"}], " ", ")"}]}], "=", " ", 
      RowBox[{
       RowBox[{"H", "(", "Y", " ", ")"}], "\[Minus]", 
       RowBox[{"H", "(", 
        RowBox[{"Y", " ", "|", "X"}], ")"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"dc09371d-9bd8-42c1-8a3a-454693bb9dc1"],
 " ."
}], "TechNoteText",
 CellID->1618222199,ExpressionUUID->"12487144-ade7-4346-a409-aaa7497182ef"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1727592985,ExpressionUUID->"1089fff9-30fe-4553-a55f-6a9ecefe7549"],

Cell[TextData[{
 "Consider a classical joint probability distribution  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", 
     RowBox[{"i", " ", "j"}]], ":=", 
    RowBox[{"p", "(", 
     RowBox[{
      SubscriptBox["x", "i"], ",", 
      SubscriptBox["y", "j"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "e4682222-0b73-45ab-9fe4-319b01cd5b76"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", "2", ",", "\[Ellipsis]"}], 
   TraditionalForm]],ExpressionUUID->"b027b3b5-ef58-4dbf-85f5-3c1da856600a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]"}], 
   TraditionalForm]],ExpressionUUID->"d66ec257-c9c4-4f2e-95d4-3ee43832f83d"],
 " associated with two random variables ",
 StyleBox["X",
  FontSlant->"Italic"],
 " and ",
 StyleBox["Y",
  FontSlant->"Italic"],
 "."
}], "TechNoteMathCaption",
 CellID->1425607416,ExpressionUUID->"89ce2697-a6fc-481d-9d91-8f0c62dd9ff7"],

Cell[CellGroupData[{

