Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". The Shannon entropy ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "(", 
    RowBox[{"{", 
     RowBox[{"p", ",", 
      RowBox[{"1", "\[Minus]", "p"}]}], "}"}], ")"}], TraditionalForm]],
  ExpressionUUID->"4c304ac8-38de-44dc-ac05-7e0f788d9956"],
 " associated with a binary probability distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"p", "(", "0", ")"}], "=", "p"}], ",", 
     RowBox[{
      RowBox[{"p", "(", "1", ")"}], "=", 
      RowBox[{"1", "\[Minus]", "p"}]}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"aa243311-36ae-498c-9898-bd799bc09c29"],
 " of a random variable with values in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"0", ",", "1"}], "}"}], TraditionalForm]],ExpressionUUID->
  "cdb8955e-aba0-4f57-968b-c6c79773657a"],
 "."
}], "TechNoteCaption",
 CellID->1166102292,ExpressionUUID->"b556be5f-bfa0-4a93-b3d6-5f0682cf7969"],

Cell[TextData[{
 "So far, entropy has been regarded as a measure of uncertainty. It may sound \
contradictory at first glance, but a valuable alternative interpretation is \
that entropy quantifies the information content in the state of a physical \
system. Suppose that we have learned value ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "80a8b5f7-12c4-4def-b977-967e97cfd534"],
 " of a random variable ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "ea527d98-04a3-46c1-a9ce-614aa95cfe33"],
 ". Compared to the case we did not learn the value, our knowledge of the \
random variable has increased. We then ask the question, \
\[OpenCurlyDoubleQuote]How much of information, on average, have we acquired \
by learning the value of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "e5d51a14-f767-421b-bd17-fa83a1e82a5f"],
 "?\[CloseCurlyDoubleQuote] Since the Shannon entropy is the amount of \
uncertainty before we learn the value and it is the amount of uncertainty \
that is cleared by learning the value, the information gain is also given by \
the Shannon entropy. The two interpretations thus provide two alternative \
views of entropy: One can regard the entropy as a measure of the uncertainty \
before we learn the value of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "d409edcf-ee00-4a7a-be80-c978b73f3e55"],
 ". But one can also regard it as a measure of the information gained after \
we learn the value of ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "5ac4ee50-2b3a-49e7-8bcc-5788c852419f"],
 "."
}], "TechNoteText",
 CellID->2006559630,ExpressionUUID->"c0663cab-27e8-4d20-a61c-5e53fdcc0e79"],

Cell["\<\
A basic yet significant property of the Shannon entropy is the inequality\
\>", "TechNoteText",
 CellID->772479020,ExpressionUUID->"8b89eee0-4b85-4594-95a2-c698bd6e0874"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    RowBox[{"H", "(", "X", ")"}], "\[LessEqual]", 
    RowBox[{"log", " ", "d"}]}], TraditionalForm]],ExpressionUUID->
  "f35103d2-d18b-4d69-bae9-e7214cf3932d"],
 " ,"
}], "TechNoteText",
 CellID->1448951521,ExpressionUUID->"a4dc8608-dcd6-444a-a70c-a04783082052"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "954f9797-7d67-4f79-a00c-02cd70cb4a2a"],
 " is the number of values that ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "392012f9-5015-4b02-b96b-ebcf999757ec"],
 " can take. The entropy becomes maximum, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", "X", ")"}], "=", 
    RowBox[{"log", " ", "d"}]}], TraditionalForm]],ExpressionUUID->
  "f0de96b1-bca1-4887-99ee-4df2dc6c8780"],
 ", if and only if the probability is uniformly distributed. We defer proving \
the property until we introduce ",
 StyleBox["relative entropy",
  FontSlant->"Italic"],
 " since the proof is simplest by using this quantity."
}], "TechNoteText",
 CellID->79177064,ExpressionUUID->"cfd1d5c1-9b7f-4cdb-aef6-ec25378cc8ce"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Relative Entropy", "TechNoteSection",
 CellID->240193879,ExpressionUUID->"41f8eb93-350b-4219-b8ca-88ad8654910a"],

Cell[TextData[{
 "The relative entropy (also known as Kullback-Leibler divergence) is a \
measure of the closeness of two probability distributions. In character, it \
is quite different from the previously introduced measures, the ",
 ButtonBox["Euclidean distance",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/DistanceMeasuresBetweenQuantumStates#\
1750923645"],
 ", the ",
 ButtonBox["Kolmogorov distance",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/DistanceMeasuresBetweenQuantumStates#\
679291181"],
 ", or the ",
 ButtonBox["classical fidelity",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/DistanceMeasuresBetweenQuantumStates#\
314819524"],
 ". It behaves, in many respects, more like the entropy as the name \
suggests."
}], "TechNoteText",
 CellID->2042874984,ExpressionUUID->"ea9f4e8a-4bab-4954-997c-0796f822d1df"],

Cell[TextData[{
 "Suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "95f56880-0a4a-4e62-aa56-443ecc6662bb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"q", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "9830c190-e484-4c34-b013-92aeec85cfb7"],
 " are two probability distributions of the same random variable ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "2eb215c0-7a00-439d-b07f-f6c968aefd0b"],
 " with values in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", "x", "}"}], TraditionalForm]],ExpressionUUID->
  "a639b28a-e369-4d92-9e07-902385742857"],
 ". The ",
 StyleBox["relative Shannon entropy",
  FontSlant->"Italic"],
 " or simply ",
 StyleBox["relative entropy",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "ff5d8df3-e94b-4741-a8f9-c227b2f68564"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"q", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "7fe83fc9-38f4-4d9a-a857-4fcb286bf5ab"],
 " (or the Kullback-Leibler divergence of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "c66cd76e-4475-41d0-a0b6-97759b7fae31"],
 " from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"q", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "2002b411-c924-4da8-8e3d-87d8eddb1b44"],
 ") is defined by"
}], "TechNoteText",
 CellID->631307852,ExpressionUUID->"f96b4330-401d-439f-98c0-18eb54ed17c3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"p", "(", "x", ")"}], "}"}], "\[DoubleVerticalBar]", 
      RowBox[{"{", 
       RowBox[{"q", "(", "x", ")"}], "}"}]}], ")"}], ":=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "x"], 
      RowBox[{"p", "(", "x", ")"}], " ", "log", " ", 
      FractionBox[
       RowBox[{"p", "(", "x", ")"}], 
       RowBox[{"q", "(", "x", ")"}]]}], "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"H", "(", 
        RowBox[{"{", 
         RowBox[{"p", "(", "x", ")"}], "}"}], ")"}]}], "-", 
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", "x"], 
       RowBox[{"p", "(", "x", ")"}], "log", "\[VeryThinSpace]", 
       RowBox[{"q", "(", "x", ")"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "482d5e18-f9d3-43e6-a75e-3f8f696a13cf"],
 "."
}], "TechNoteText",
 CellID->1821852384,ExpressionUUID->"0196fc3d-4448-41ef-ae5c-d69ef4a38282"],

Cell[TextData[{
 "As before, it is assumed that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"0", "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "0"}], "=", 
    "0"}], TraditionalForm]],ExpressionUUID->
  "51e5f46e-1e1b-45d7-849f-111a02a6919b"],
 ". In addition, we define ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}], " ", "log", " ", "0"}], " ", "=", " ", 
    RowBox[{"\[Minus]", "\[Infinity]"}]}], TraditionalForm]],ExpressionUUID->
  "6a33cf70-2ed7-4499-b99f-4391e51fbd48"],
 " if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], " ", ">", " ", "0"}], TraditionalForm]],
  ExpressionUUID->"a6abaee2-e41f-4bb4-8caa-2620f622fb06"],
 " for any ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "e8437037-b151-40b8-b7b5-d054b9b2dbb1"],
 ". In information theory, the second term, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", 
     SubscriptBox["\[Sum]", "x"]}], 
    RowBox[{"p", "(", "x", ")"}], "log", "\[VeryThinSpace]", 
    RowBox[{"q", "(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "45bf16fa-50ec-44a6-87b8-2e0306c6bd0c"],
 ", is often called the cross-entropy of two probability distributions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"p", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "37f7f85b-0d5b-404e-8feb-faa958701991"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"q", 
     RowBox[{"(", "x", ")"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "16526994-feee-4ea5-855b-58a61e18df0f"],
 ", and itself is used to measure the difference of two probability \
distributions."
}], "TechNoteText",
 CellID->1051178962,ExpressionUUID->"b29f0e41-3e7b-49b7-a3b9-41b8f83cc253"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
