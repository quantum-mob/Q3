 RowBox[{
  RowBox[{"pp", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"6", ",", "6"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pp", "/=", 
   RowBox[{"Total", "[", 
    RowBox[{"Flatten", "@", "pp"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"pp", "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[18]:=",
 CellID->1992478139,ExpressionUUID->"1ca187a9-291b-4d3b-b927-ae7767ba3b2c"],

