Cell["\<\
Entropy is a measure of uncertainty. Entropy is an essential concept \
ubiquitously used in every science that has statistical elements. Examples \
include classical and quantum statistical mechanics, classical and quantum \
information theory, data analysis, machine learning, and many more.\
\>", "TechNoteText",
 CellID->356897954,ExpressionUUID->"af3b00cd-52d9-4602-aa5a-5f1d0e46dccd"],

Cell[TextData[{
 "See also Section 7.1 of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "359a88f8-6335-4c8d-a116-ccbd3af7a689"],
 "."
}], "TechNoteText",
 CellID->1804678267,ExpressionUUID->"5e29719d-6652-4d5c-bb0f-a1b39a4027e4"],

