         RowBox[{"1", ",", "1"}], "}"}], "*", "max"}]}], "}"}]}]}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
