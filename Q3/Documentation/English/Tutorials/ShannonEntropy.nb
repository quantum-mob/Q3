Cell["Now, consider two anti-correlated random variables.", \
"TechNoteMathCaption",
 CellID->1633832126,ExpressionUUID->"31e17666-3298-4bf8-8fb2-774ba212c566"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"pp", "=", 
   RowBox[{"Normalize", "[", 
    RowBox[{
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", "6"}], "]"}], ",", "Total"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pp", "=", 
   RowBox[{"Chop", "@", 
    RowBox[{"Reverse", "@", 
     RowBox[{"DiagonalMatrix", "@", "pp"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", "pp", "]"}]}], "Input",
 CellLabel->"In[27]:=",
 CellID->166523700,ExpressionUUID->"cce90f2a-a917-4d26-b7b1-46a44118519a"],

