Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->125735545,ExpressionUUID->"50e249de-3073-45bd-80f2-02557fb10500"],

Cell[TextData[{
 "From the above arguments leading to the definition of mutual information, \
it is physically clear that the conditional entropy ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", 
     RowBox[{"X", "|", "Y"}], " ", ")"}]}], TraditionalForm]],ExpressionUUID->
  "9fef7f11-0d0c-47c3-9542-eed908cf528c"],
 " cannot exceed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "1985e490-4508-4ff6-924b-535e95590ce2"],
 " (see Problem 7.1 in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "8fbd2980-c1b1-496a-bca5-ce49f3ac77e7"],
 " for a mathematical proof). This implies the ",
 StyleBox["subadditivity",
  FontSlant->"Italic"]
}], "TechNoteText",
 CellID->113396167,ExpressionUUID->"c322471b-9c01-4a42-b090-0b09fa3ab79c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", ",", " ", "Y"}], " ", ")"}], "\[LessEqual]", 
    RowBox[{
     RowBox[{"H", "(", "X", ")"}], "+", 
     RowBox[{"H", "(", "Y", " ", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "76bf3c8f-fab1-4f69-8bb7-4b5ef084f132"]
}], "TechNoteText",
 CellID->1031383880,ExpressionUUID->"b78858b4-7830-43a5-879b-d2e5cd38a120"],

Cell[TextData[{
 "with equality if and only if ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "ccf524a6-b543-4996-91cc-1ca898ca6b4a"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "2d67b34c-ab36-4a03-9c1b-96e0f6856300"],
 " are statistically independent. For the same reason, the mutual information \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", 
     RowBox[{"X", ":", "Y"}], " ", ")"}]}], TraditionalForm]],ExpressionUUID->
  "5ca4ae39-5386-4fd5-9a14-21b8552b6ff4"],
 " cannot exceed ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "e9da8db4-ba3b-4738-b5b6-48d9ac29a0e9"],
 " nor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", 
    RowBox[{"(", "Y", " ", ")"}]}], TraditionalForm]],ExpressionUUID->
  "fc7d780d-e79a-4f98-9db8-f456cc4a0b80"],
 " (Problem 7.1 in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "f07604ac-1b9e-44b7-b5e3-7b56680fe21d"],
 " for a mathematical proof),"
}], "TechNoteText",
 CellID->2128356223,ExpressionUUID->"97e94506-8d5a-4bf2-9949-800fd3311fba"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", ":", "Y"}], " ", ")"}], "\[LessEqual]", 
    RowBox[{"H", "(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "9fe36c7b-1152-4fec-ba96-d259f0beaae8"],
 ","
}], "TechNoteText",
 CellID->647931882,ExpressionUUID->"dbf5ae29-d9ba-475c-9e86-ed9631e8f503"],

Cell["which is equivalent to", "TechNoteText",
 CellID->2049050484,ExpressionUUID->"96c92ff0-1cf2-4a77-babe-fff763b6f992"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", "|", "Y"}], " ", ")"}], "\[GreaterEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"b33cf111-f537-4cdc-ba60-678e46fcc121"],
 "."
}], "TechNoteText",
 CellID->1343721296,ExpressionUUID->"3871f9fd-6d14-4a32-969a-c87706e23779"],

Cell[TextData[{
 "Equality in each of the above two equations is attained if and only if X is \
a function of ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "55d65962-37d8-4b9b-a1f1-ea86d3b2f840"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", " ", "=", " ", 
    RowBox[{"f", 
     RowBox[{"(", "Y", " ", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "63c19c33-e1c0-4c57-8d2d-8602f26db57e"],
 ", that is, if ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "a6f3bce3-8daa-41bd-8bcd-01897fdcea43"],
 " and ",
 Cell[BoxData[
  FormBox["Y", TraditionalForm]],ExpressionUUID->
  "916cfbb7-d63b-426c-abd0-ef25f3fa3863"],
 " are perfectly correlated. The inequality ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", 
     RowBox[{"X", ":", "Y"}], " ", ")"}], "\[LessEqual]", 
    RowBox[{"H", "(", "X", ")"}]}], TraditionalForm]],ExpressionUUID->
  "4142dd55-d213-44c1-a0ff-25ddb373dfc9"],
 " is often called the ",
 StyleBox["data processing inequality",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->985790020,ExpressionUUID->"8da4af50-6443-4b04-8fe5-0db71b009ee1"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->336529535,ExpressionUUID->"580fdc29-6c4d-474e-8c36-9dd6a132e476"],

Cell["\<\
Let us now demonstrate that classical mutual information cannot exceeds the \
Shannon entropies of two individual probability distributions.\
\>", "TechNoteMathCaption",
 CellID->296217951,ExpressionUUID->"4a690c55-9684-4cce-9df7-606d935cb14b"],

Cell[TextData[{
 "Define a function randomly generate a joint probability distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]],ExpressionUUID->
  "12bb9adf-21f1-412d-9250-c0aad22cfd47"],
 " and then returns a pair {",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "(", 
    RowBox[{"X", ":", "Y"}], ")"}], TraditionalForm]],ExpressionUUID->
  "662cb761-607d-4a16-847f-c780c7ad649a"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "(", "Y", ")"}], TraditionalForm]],ExpressionUUID->
  "dad7bed3-009b-49f3-b991-159f25342d5d"],
 "} of the mutual information and Shannon entropy ."
}], "TechNoteMathCaption",
 CellID->1879305581,ExpressionUUID->"9444bfa1-77cb-432b-838e-347fb8507dec"],

Cell[BoxData[
 RowBox[{
  RowBox[{"try", "[", "]"}], ":=", 
  RowBox[{"Block", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"pp", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"6", ",", "6"}], "}"}]}], "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pp", "/=", 
      RowBox[{"Total", "[", 
       RowBox[{"Flatten", "@", "pp"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"MutualInformation", "[", "pp", "]"}], ",", 
       RowBox[{"ShannonEntropy", "@", 
        RowBox[{"Total", "@", "pp"}]}]}], "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellLabel->"In[154]:=",
 CellID->1645021452,ExpressionUUID->"e5ff5a1c-10d9-4cd9-8d0a-ee68480f25b1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", 
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"try", "[", "]"}], ",", "20000"}], "]"}]}], ";"}], 
  "]"}]], "Input",
 CellLabel->"In[155]:=",
 CellID->1890951150,ExpressionUUID->"885d35fd-0094-4f78-93dd-0c11d8cb097e"],

