        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {4, 4}, 0, {
     1, {{0, 0, 2, 4, 5}, {{2}, {3}, {3}, {2}, {4}}}, {
      1, $CellContext`t, 1, $CellContext`t, 2}}]]]]], "Output",
 CellLabel->"Out[9]//MatrixForm=",
