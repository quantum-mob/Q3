Cell["\<\
Calculate the matrix representation in the computational basis:\
\>", "TechNoteMathCaption",
 CellID->362238423,ExpressionUUID->"e5173222-e648-423a-b87a-b042ad59c5da"],

Cell[CellGroupData[{

Cell[BoxData[{
