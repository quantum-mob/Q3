Cell[TextData[{
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["PermtuationMatrix"]], 
    "paclet:QuantumMob/Q3/ref/PermtuationMatrix", "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5cd68457-324a-4390-bf03-cf72ade1932d"],
 " is a realization of the ",
 StyleBox["permutation representation",
  FontSlant->"Italic"],
 " of the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "ef326ec4-f395-4d80-815a-6a58b13f366b"],
 " associated with set ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", " ", 
    StyleBox["n", "TI"]}], "}"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d574caa9-1832-49b0-8537-ecf2b07675ba"],
 ". In this document, the relation between the built-in PermutationMatrix and \
permutation representation is explained in detail."
}], "TechNoteText",
 CellID->112351974,ExpressionUUID->"f9eb1284-4255-437e-8c5b-8e39abd60b37"],

