Cell["\<\
Functions related to the permutation representation of the symmetric group.\
\>", "TechNoteCaption",
 CellID->329592616,ExpressionUUID->"7501f72f-c80a-46c3-b71d-dbeeadcd1804"],

Cell[CellGroupData[{

Cell["Permutation as a Function vs as a Group Action", "TechNoteSection",
 CellID->397699689,ExpressionUUID->"dfeddadb-6963-48fc-92b4-b7afe9235876"],

Cell[TextData[{
 "A permutation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", ":", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", "n"}], "}"}], "\[RightArrow]", 
     RowBox[{"{", 
      RowBox[{"1", ",", "2", ",", "\[Ellipsis]", ",", "n"}], "}"}]}]}], 
   TraditionalForm]],ExpressionUUID->"a04bd1c8-3737-4b8f-bbf5-320fe0d2e84f"],
 " is an one-to-one correspondence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[RightTeeArrow]", 
    RowBox[{"\[Sigma]", "(", "k", ")"}]}], TraditionalForm]],ExpressionUUID->
  "ef2da3c6-eaf6-41a4-adb8-8a0ec017cf62"],
 ". When it is regarded as a group element, its action on a set defined by\
\[LineSeparator]\t",
 Cell[BoxData[
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     SubscriptBox[
      StyleBox["y", "TI"], 
      StyleBox["1", "TR"]], ",", 
     SubscriptBox[
      StyleBox["y", "TI"], 
      StyleBox["2", "TR"]], ",", 
     StyleBox["\[Ellipsis]", "TR"], ",", 
     SubscriptBox[
      StyleBox["y", "TI"], 
      StyleBox["n", "TI"]]}], "}"}], ":=", 
   RowBox[{
    RowBox[{
     StyleBox["\[Sigma]", "TR"], 
     RowBox[{"{", 
      RowBox[{
       SubscriptBox[
        StyleBox["x", "TI"], 
        StyleBox["1", "TR"]], ",", 
       SubscriptBox[
        StyleBox["x", "TI"], 
        StyleBox["2", "TR"]], ",", 
       StyleBox["\[Ellipsis]", "TR"], ",", 
       SubscriptBox[
        StyleBox["x", "TI"], 
        StyleBox["n", "TI"]]}], "}"}]}], "=", 
    RowBox[{
     TemplateBox[{
       Cell[
        TextData["Permute"]], "paclet:ref/Permute"},
      "RefLink",
      BaseStyle->{"InlineFormula"}], "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        SubscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["1", "TR"]], ",", 
        SubscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["2", "TR"]], ",", 
        StyleBox["\[Ellipsis]", "TR"], ",", 
        SubscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["n", "TI"]]}], "}"}], ",", 
      StyleBox["\[Sigma]", "TR"]}], "]"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f582c4cd-2d01-4065-8367-384fcf0b8e84"],
 " \[LineSeparator]returns ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["y", "1"], ",", 
     SubscriptBox["y", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["y", "n"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "82779b34-1323-4412-b3b2-2d10d801de37"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["y", "k"], "=", 
    SubscriptBox["x", 
     RowBox[{
      SuperscriptBox["\[Sigma]", 
       RowBox[{"-", "1"}]], "(", "k", ")"}]]}], TraditionalForm]],
  ExpressionUUID->"250bae14-ef92-4618-bba5-2b2f2bf9c581"],
 " ; that is, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "k"], TraditionalForm]],ExpressionUUID->
  "a4c1f81c-01b6-49d6-8a3b-b975f03742c9"],
 " is moved to position ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", "(", "k", ")"}], TraditionalForm]],ExpressionUUID->
  "2074855e-a797-41a9-9673-51b2deb1dea6"],
 " of the output list ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "8e791612-5a94-45c0-8678-a78ae94cc115"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "k"], "\[RightTeeArrow]", 
    SubscriptBox["y", 
     RowBox[{"\[Sigma]", "(", "k", ")"}]]}], TraditionalForm]],ExpressionUUID->
  "957cee5a-0038-4e63-9b67-f85cef1dd829"],
 "."
}], "TechNoteText",
 InitializationCell->True,
 CellID->1169563559,ExpressionUUID->"0d7ef47e-bb9c-4a47-8391-81d535b0cdd3"],

Cell[TextData[{
 "Specifically, a cyclic permutation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["i", "1"], ",", 
      SubscriptBox["i", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["i", "k"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "86cd2e58-a40a-46c2-9bd3-5cde23ae3f3b"],
 " is defined by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["i", "k"], "\[RightTeeArrow]", 
    SubscriptBox["i", 
     RowBox[{"k", "+", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "2d75f8da-d207-4a7f-93aa-001834910811"],
 ". Then,\n\t",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Permute"]], "paclet:ref/Permute"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["x", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["x", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["x", "TI"], 
       StyleBox["n", "TI"]]}], "}"}], ",", 
    StyleBox["\[Sigma]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e72ff5f5-56a2-4fb7-9092-77193079eaaa"],
 "\[LineSeparator]moves ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", 
    SubscriptBox["i", "k"]], TraditionalForm]],ExpressionUUID->
  "62d14c3e-2020-4c22-8489-97c280dc78d3"],
 " to position ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["i", 
    RowBox[{"k", "+", "1"}]], TraditionalForm]],ExpressionUUID->
  "da417362-a237-4d6c-bff4-bce039f009b8"],
 " of the output list y."
}], "TechNoteText",
 CellID->936915122,ExpressionUUID->"5bc61341-cecf-435d-bea4-7de38ce52a14"],

Cell[TextData[{
 "On the other hand, a permutation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["p", "1"], ",", 
      SubscriptBox["p", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["p", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "5ed37c0e-ae22-46a3-9c91-725b5f404b32"],
 " specified in the ",
 StyleBox["permutation list",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["p", "1"], ",", 
     SubscriptBox["p", "2"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["p", "n"]}], "}"}], TraditionalForm]],ExpressionUUID->
  "a0d5fe49-ef07-47f5-b3d3-2f7db25d114f"],
 " is a correspondence ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[RightTeeArrow]", 
    SubscriptBox["p", "k"]}], TraditionalForm]],ExpressionUUID->
  "658a2d71-30b2-490a-8303-701388f5eb6d"],
 ". Therefore,\n\t",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Permute"]], "paclet:ref/Permute"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox[
       StyleBox["x", "TI"], 
       StyleBox["1", "TR"]], ",", 
      SubscriptBox[
       StyleBox["x", "TI"], 
       StyleBox["2", "TR"]], ",", 
      StyleBox["\[Ellipsis]", "TR"], ",", 
      SubscriptBox[
       StyleBox["x", "TI"], 
       StyleBox["n", "TI"]]}], "}"}], ",", 
    StyleBox["\[Sigma]", "TR"]}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5ac81ed7-e8c7-4e20-b0c5-84963ebd3eac"],
 "\[LineSeparator]moves ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "k"], TraditionalForm]],ExpressionUUID->
  "384cba76-f5fc-4cfe-b088-c999ddeb0490"],
 " to position ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "k"], TraditionalForm]],ExpressionUUID->
  "e88101ad-f27c-4ef8-95d2-8431aa7e546c"],
 " of the output list y."
}], "TechNoteText",
 CellID->1382355650,ExpressionUUID->"b19a27e4-36e4-4ed8-9562-1c06c27276bb"],

Cell[CellGroupData[{

Cell["Demonstration", "Subsection",
 CellID->1773316304,ExpressionUUID->"6b8945b1-663f-4e33-949c-f6aa0f6d805c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "4"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"cyc", "=", 
  RowBox[{"Cycles", "@", 
   RowBox[{"{", 
    RowBox[{"Range", "@", "$n"}], "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"prm", "=", 
  RowBox[{"PermutationList", "[", 
