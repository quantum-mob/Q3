Cell[CellGroupData[{

Cell["Permutation Representation", "TechNoteSection",
 CellID->374624317,ExpressionUUID->"7315fc7c-0e24-462d-8568-8a4c3a9d9841"],

Cell["\<\
The permutation representation of a group is a homomorphism from the group to \
a group of permutations.\
\>", "TechNoteText",
 CellID->869301310,ExpressionUUID->"8029f021-4e67-4476-849a-1007a51275bc"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "a7e01192-103a-4cd2-83c9-8860b6dd80ba"],
 " be a group. Suppose that ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "e6a34e78-a60a-4193-a2c0-059f096a2f81"],
 " acts on a set ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalS]", "=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["s", "1"], ",", 
      RowBox[{
       SubscriptBox["s", "2"], "\[Ellipsis]"}], ",", 
      SubscriptBox["s", "n"]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "94fc055c-127a-4662-92cf-41cbb90e05d8"],
 ". The permutation representation of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalG]", TraditionalForm]],ExpressionUUID->
  "61be9a0f-c96b-4a80-8f74-e1feecd020f7"],
 " associated with ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalS]", TraditionalForm]],ExpressionUUID->
  "f9c571b0-5e2e-4f44-9b11-92695ca5c92a"],
 " is spanned by the standard basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      TemplateBox[{
        SubscriptBox["s", "1"]},
       "Ket"], ",", 
      TemplateBox[{
        SubscriptBox["s", "2"]},
       "Ket"], ",", "\[Ellipsis]", ",", 
      TemplateBox[{
        SubscriptBox["s", "n"]},
       "Ket"]}], "}"}], ","}], TraditionalForm]],ExpressionUUID->
  "b8ca1256-b92f-4a76-94d4-96fc079540f5"],
 " and the action of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", "\[Element]", "\[ScriptCapitalG]"}], TraditionalForm]],
  ExpressionUUID->"e95396e9-c0ed-4c38-88ae-b034374a048b"],
 " is defined by"
}], "TechNoteText",
 CellID->1440271939,ExpressionUUID->"3a245164-8965-453f-b8c3-cea5bba8f5a2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["G", "^"], 
     TemplateBox[{
       SubscriptBox["s", "j"]},
      "Ket"]}], ":=", 
    RowBox[{
     TemplateBox[{
       RowBox[{"G", "\[VeryThinSpace]", 
         SubscriptBox["s", "j"]}]},
      "Ket"], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "i"], 
      TemplateBox[{
        SubscriptBox["s", "i"]},
       "Ket"], 
      RowBox[{
       SubscriptBox["\[CapitalGamma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", "G", ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"940fefd6-2753-4b0d-a2b9-adac64530294"]
}], "TechNoteText",
 CellID->1385580040,ExpressionUUID->"3271b264-66b5-49bb-8758-663d50bb5810"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["s", "j"], "\[Element]", "\[ScriptCapitalS]"}], 
   TraditionalForm]],ExpressionUUID->"7439b1eb-29ef-4a99-9d0d-00a8118d0c94"],
 "."
}], "TechNoteText",
 CellID->1183708076,ExpressionUUID->"2acf009b-ca8d-490f-ab32-e23750e0921a"],

Cell[TextData[{
 "For a permutation ",
 Cell[BoxData[
  StyleBox["g", "TI"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "29bbd4ab-ade0-4f8e-b744-292b16cdcf8d"],
 " in the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "d91b82aa-5204-4a25-b9cd-78b0a557137d"],
 ", suppose that"
}], "TechNoteText",
 CellID->848615397,ExpressionUUID->"00b05539-6c76-4e62-bb08-2217c7d4f2f2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "i"], 
     TemplateBox[{
       SubscriptBox["s", "i"]},
      "Ket"], 
     SubscriptBox["d", "i"]}], "=", 
    RowBox[{
     RowBox[{"\[CapitalGamma]", "(", "g", ")"}], 
     UnderscriptBox["\[CapitalSigma]", "j"], 
     TemplateBox[{
       SubscriptBox["s", "j"]},
      "Ket"], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "91c33be3-c8df-4fed-826e-24175c461404"],
 "."
}], "TechNoteText",
 CellID->1928828323,ExpressionUUID->"ba2cd433-da3c-46ac-94b5-b895cd0b2b05"],

Cell["Then, the coefficients transform as", "TechNoteText",
 CellID->27978651,ExpressionUUID->"35e30440-c7eb-46cd-a135-18968da75006"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "j"], "=", 
    RowBox[{
     SubscriptBox["c", 
      RowBox[{
       SuperscriptBox["g", 
        RowBox[{"-", "1"}]], "(", "j", ")"}]], "=", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "i"], 
      RowBox[{
       SubscriptBox["\[CapitalGamma]", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", "g", ")"}], 
      SubscriptBox["c", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "e2077d14-84ed-4767-97cf-2f64993cbb96"],
 "."
}], "TechNoteText",
 CellID->884703309,ExpressionUUID->"a4825b25-4d6b-4d82-b11c-76fa5959dc7f"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["PermutationMatrix"]], "paclet:ref/PermutationMatrix"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "[", 
   StyleBox["g", "TI"], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "301586cc-6112-498d-8528-1877ffeee3f0"],
 " refers to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], "(", "g", ")"}], 
   TraditionalForm]],ExpressionUUID->"e3dedaee-ecb3-46c2-95d2-df672499c338"],
 "."
}], "TechNoteText",
 CellID->920071788,ExpressionUUID->"54f46c65-685a-45f5-a7fe-a34774f0ed68"]
}, Open  ]],

