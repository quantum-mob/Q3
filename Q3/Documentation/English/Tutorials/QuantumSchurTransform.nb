Cell["\<\
\tIn terms of the Gelfand-Zetlin basis for each irreducible representation, \
the above decomposition implies that\
\>", "TechNoteText",
 CellID->1234928612,ExpressionUUID->"917cd4f6-d6df-4973-87d8-6959cb9c7893"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Mu]", "    "}]}, {
              RowBox[{"(", 
                SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], 
        TraditionalForm]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"j"},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "\[Lambda]"], 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"(", 
        SubscriptBox["w", "\[Lambda]"], ")"}]], 
      RowBox[{
       TemplateBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]},
        "Ket"], 
       TemplateBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "    "}]}, {
               RowBox[{"(", 
                 SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
         RowBox[{
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 RowBox[{"\[Mu]", "    "}]}, {
                 RowBox[{"(", 
                   SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], ",", 
           "j"}]},
        "BraKet"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "23410349-6db4-4dbe-80e8-cb561b225a75"],
 ","
}], "DisplayMath",
 CellID->727733168,ExpressionUUID->"66bd3319-3604-4b42-8de1-82b96480f7bf"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       SubscriptBox[
        RowBox[{"(", 
          SubscriptBox["w", "\[Lambda]"], ")"}], 
        RowBox[{"d", "-", "1"}]]}], 
     RowBox[{"\[Mu]", ",", 
       RowBox[{
         SubscriptBox[
          RowBox[{"(", 
            SubscriptBox["v", "\[Mu]"], ")"}], 
          RowBox[{"d", "-", "1"}]], ";", "j"}]}]},
    "BraKet"], TraditionalForm]],ExpressionUUID->
  "92e99a4e-371d-4e78-9cdf-484c98ae34e7"],
 " are the ",
 StyleBox[ButtonBox["Clebsch-Gordan coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ClebschGordanX"],
  FontSlant->"Italic"],
 ". The basis change is called the ",
 StyleBox["Clebsch-Gordan transform",
  FontSlant->"Italic"],
 ". Here, we have not explicitly specified summation ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sum]", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "8045a2e8-127b-4b78-997d-38ca3132a951"],
 " over \[Lambda] at the moment, but it is subjected to the strong selection \
rule (see below) imposed by the Clebsch-Gordan coefficients and significantly \
restricted."
}], "TechNoteText",
 CellID->1387206624,ExpressionUUID->"fc5dd006-f0e5-41b4-8fcd-511c09676a3f"],

Cell[TextData[{
 "\tTo implement the Clebsch-Gordan transform for ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a7ab470e-7f80-4090-b509-eb6cbb847859"],
 " recursively from that for ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   RowBox[{
    StyleBox["d",
     FontSlant->"Italic"], "-", "1"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b2ba7925-5af0-4f63-8364-f193ab8cb60f"],
 ", it is convenient to introduce a linear map ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox[
      OverscriptBox["T", "^"], "j", 
      RowBox[{"\[Lambda]", ",", "\[Mu]"}]], ":", 
     SuperscriptBox["\[ScriptCapitalW]", "\[Mu]"]}], "\[Rule]", 
    SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}], TraditionalForm]],
  ExpressionUUID->"e0223c18-2f2d-4b11-aa49-ea2933b795b8"],
 " by "
}], "TechNoteText",
 CellID->239788239,ExpressionUUID->"2291337d-4002-44e6-b42b-08563a4cc65f"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox[
      OverscriptBox["T", "^"], "j", 
      RowBox[{"\[Lambda]", ",", "\[Mu]"}]], 
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Mu]", "  "}]}, {
              RowBox[{"(", 
                SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], 
        TraditionalForm]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       OverscriptBox["P", "^"], "\[Lambda]"], 
      RowBox[{"{", 
       RowBox[{
        TemplateBox[{
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Mu]", "  "}]}, {
                RowBox[{"(", 
                  SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"]},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{"j"},
         "Ket"]}], "}"}]}], "=", 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"(", 
        SubscriptBox["w", "\[Lambda]"], ")"}]], 
      RowBox[{
       TemplateBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "   "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]},
        "Ket"], 
       TemplateBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "   "}]}, {
               RowBox[{"(", 
                 SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
         RowBox[{
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 RowBox[{"\[Mu]", "  "}]}, {
                 RowBox[{"(", 
                   SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], ",", 
           "j"}]},
        "BraKet"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "5b1dbb0d-b743-4632-bc92-03c36ccd8796"],
 ","
}], "DisplayMath",
 CellID->1395773655,ExpressionUUID->"e191e21c-4a05-4707-8411-e63982a43c74"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["P", "^"], "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "84700b8c-3e56-4d6a-a841-20856ef47f15"],
 " is the projection into ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
