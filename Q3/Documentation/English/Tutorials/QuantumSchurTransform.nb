Cell[TextData[{
 "\tAt this stage, the vectors in the Gelfand-Zetlin basis do not take any \
particular form of expression. All we require is that under the action of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "\[Element]", 
    SubscriptBox["\[ScriptCapitalU]", "d"]}], TraditionalForm]],
  ExpressionUUID->"03c1d9cd-a19f-4787-a665-a8c78ae6fc0f"],
 ", the basis vectors transform as"
}], "TechNoteText",
 CellID->1427798485,ExpressionUUID->"2351c3fc-25fc-41ef-a2c7-02cc48434782"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["\[CapitalOmega]", "^"], "(", "U", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         SubscriptBox[
          RowBox[{"(", 
            SubscriptBox["w", "\[Lambda]"], ")"}], 
          RowBox[{"d", "-", "1"}]]}]},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "v"], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Lambda]", ",", 
          SubscriptBox[
           RowBox[{"(", 
             SubscriptBox["v", "\[Lambda]"], ")"}], 
           RowBox[{"d", "-", "1"}]]}]},
       "Ket"], 
      RowBox[{
       SubsuperscriptBox["\[CapitalOmega]", 
        StyleBox["vw",
         FontSlant->"Italic"], "\[Lambda]"], "(", "U", ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"cdd87053-8808-46cd-ad25-dbdb97aceb6b"],
 ","
}], "DisplayMath",
 CellID->24250654,ExpressionUUID->"f45d516f-da30-4031-b762-edb5a3eef1ce"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalOmega]", 
     StyleBox["vw",
      FontSlant->"Italic"], "\[Lambda]"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"5ffa6ace-40e7-4a9d-a8dc-8faae12f4649"],
 " is the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"v", " ", "w"}], ")"}], "th"], TraditionalForm]],ExpressionUUID->
  "d047e260-704f-4b47-be9d-9a8ac5b3ae67"],
 " matrix element of the irreducible representation \[Lambda] and the \
summation is over all Gelfand subpatterns ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["v", "\[Lambda]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "04d93aac-3024-48ab-91fa-a73786cd8823"],
 " consistent with Weyl tableaux of shape \[Lambda]."
}], "TechNoteText",
 CellID->1355199027,ExpressionUUID->"41a274de-f568-4fed-b8ab-7454c12f7504"],

Cell[TextData[{
 "\tPartition ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", "1", ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "40532d48-d52b-43cf-b42c-5f7b7129a45a"],
 " is a special case, the corresponding irreducible space ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", 
    RowBox[{"(", "1", ")"}]], TraditionalForm]],ExpressionUUID->
  "0f7aad7d-4c18-4ebc-a09d-70f211009a9c"],
 " coincides with ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalV]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "35e5638e-ad5e-4a85-9018-e5fe8417ab18"],
 ", and hence we identify the Gelfand-Zetlin basis of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", 
    RowBox[{"(", "1", ")"}]], TraditionalForm]],ExpressionUUID->
  "255eca67-8e07-4880-b44c-f8dba43933c7"],
 " with the computational basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"j"},
        "Ket"], ":", "j"}], "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
     "d"}], "}"}], TraditionalForm]],ExpressionUUID->
  "0e680711-f3ef-4424-86e5-8c07d761ad76"],
 ". Here is an example for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "=", "4"}], TraditionalForm]],ExpressionUUID->
  "b0680dce-3888-403e-8cd9-add6a3acd760"],
 ":"
}], "TechNoteText",
 CellID->1598487441,ExpressionUUID->"d20f9326-0227-468d-8f45-894691eaedba"],

