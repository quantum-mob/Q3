Cell["By repeating the Clebsch-Gordan transform,", "TechNoteText",
 CellID->959066670,ExpressionUUID->"eefb30fe-78e4-4108-9bab-6024fd8a6379"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               SubscriptBox["\[Lambda]", "k"]}, {"\[VerticalEllipsis]"}, {
               SubscriptBox["\[Lambda]", "2"]}, {
               RowBox[{
                 SubscriptBox["\[Lambda]", "1"], " "}]}}], ")"}], "k"], ",", 
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               SubscriptBox["\[Lambda]", "k"]}, {
               RowBox[{"(", 
                 SubscriptBox[
                  SubscriptBox["w", "\[Lambda]"], "k"], ")"}]}}], ")"}], 
          "d"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"j"},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", 
      SubscriptBox["\[Lambda]", 
       RowBox[{"k", "+", "1"}]]], 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"(", 
        SubscriptBox["w", 
         SubscriptBox["\[Lambda]", 
          RowBox[{"k", "+", "1"}]]], ")"}]], 
      RowBox[{
       TemplateBox[{
         RowBox[{
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 SubscriptBox["\[Lambda]", 
                  RowBox[{"k", "+", "1"}]]}, {
                 SubscriptBox["\[Lambda]", "k"]}, {"\[VerticalEllipsis]"}, {
                 SubscriptBox["\[Lambda]", "2"]}, {
                 RowBox[{
                   SubscriptBox["\[Lambda]", "1"], " "}]}}], ")"}], "k"], ",", 
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 SubscriptBox["\[Lambda]", 
                  RowBox[{"k", "+", "1"}]]}, {
                 RowBox[{"(", 
                   SubscriptBox["w", 
                    SubscriptBox["\[Lambda]", 
                    RowBox[{"k", "+", "1"}]]], ")"}]}}], ")"}], "d"]}]},
        "Ket"], 
       TemplateBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               SubscriptBox["\[Lambda]", 
                RowBox[{"k", "+", "1"}]]}, {
               RowBox[{"(", 
                 SubscriptBox["w", 
                  SubscriptBox["\[Lambda]", 
                   RowBox[{"k", "+", "1"}]]], ")"}]}}], ")"}], "d"], 
         RowBox[{
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 SubscriptBox["\[Lambda]", "k"]}, {
                 RowBox[{"(", 
                   SubscriptBox[
                    SubscriptBox["w", "\[Lambda]"], "k"], ")"}]}}], ")"}], 
            "d"], ",", "j"}]},
        "BraKet"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "22f3882f-46b3-4c84-94b6-f46bf0e6c494"],
 ","
}], "DisplayMath",
 CellID->700195033,ExpressionUUID->"d3da9bc6-0382-459b-a041-3e7a362f32b6"],

Cell["\<\
multiple times, one can eventually get the basis vectors of the form\
\>", "TechNoteText",
 CellID->1261281028,ExpressionUUID->"7c90d45c-49ae-4eb4-b95f-48030e0531a6"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{
             SubscriptBox["\[Lambda]", "n"]}, {"\[VerticalEllipsis]"}, {
             SubscriptBox["\[Lambda]", "2"]}, {
             RowBox[{
               SubscriptBox["\[Lambda]", "1"], " "}]}}], ")"}], "n"], ",", 
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{
             SubscriptBox["\[Lambda]", "n"]}, {
             RowBox[{"(", 
               SubscriptBox[
                SubscriptBox["w", "\[Lambda]"], "n"], ")"}]}}], ")"}], "d"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "80c34eba-b265-4613-ae06-b7569063efac"],
 " ."
}], "DisplayMath",
 CellID->1446027167,ExpressionUUID->"c76cdc55-92a5-40ee-8a15-106bd2766a0f"],

Cell["\tNow the crucial observation is that stack", "TechNoteText",
 CellID->1512418608,ExpressionUUID->"0ffc89b0-9b8e-4c14-9dde-2f20dbde972a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["\[Lambda]", "n"]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["\[Lambda]", "2"]},
       {
        RowBox[{
         SubscriptBox["\[Lambda]", "1"], " "}]}
      }], ")"}], "n"], TraditionalForm]],ExpressionUUID->
  "5f08a3ef-b5aa-4ec3-8ad5-010e71c0122c"],
 "of shapes ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], ",", 
    SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["\[Lambda]", "n"]}], TraditionalForm]],ExpressionUUID->
  "a4fa18e9-b3fc-4ea1-81bf-df876553c9b2"]
}], "TechNoteText",
 CellID->1289711855,ExpressionUUID->"03e033f6-fde3-4b20-8b56-4843f5f8e793"],

Cell[TextData[{
 "stored at each Clebsch-Gordan transform is nothing but a Gelfand-Young \
pattern uniquely referring to one of the Young-Yamanouchi basis vectors of \
the irreducible representation ",
 Cell[BoxData[
  SuperscriptBox["\[ScriptCapitalY]", 
   SubscriptBox["\[Lambda]", 
    StyleBox["n",
     FontSlant->"Italic"]]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dabc75df-d3a8-4ba5-88f1-5f51ee6cf390"],
 " of symmetric group ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalS]", 
   StyleBox["n",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bc5ecc24-1ff8-4017-85f7-dd120d3ed883"],
 " (this is where the RSK map plays a part). Therefore, the above basis \
vectors are the elements of the required Schur basis."
}], "TechNoteText",
 CellID->2071960339,ExpressionUUID->"7016f3d2-aa70-4e8a-8e66-764c37116e34"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Canonical Tower of Subgroups", "TechNoteSection",
 CellID->1038153181,ExpressionUUID->"02bd2179-f1a7-4bee-a26c-1d289548691f"],

Cell[TextData[{
 "Here, demonstrated are the ",
 StyleBox["branching rules",
  FontSlant->"Italic"],
 " of the Schur basis for the canonical towers of subgroups of the symmetric \
and unitary groups."
}], "TechNoteText",
 CellID->1408836892,ExpressionUUID->"4e13b954-f0f6-4c34-8c48-c45458469e02"],

Cell[CellGroupData[{

Cell["Canonical Tower of Subgroups of the Symmetric Group", "Subsection",
 CellID->1060186955,ExpressionUUID->"8036a059-685b-4021-8b48-f0935d470b96"],

Cell["The branching rule for the symmetric group is given by", "TechNoteText",
 CellID->1618252931,ExpressionUUID->"0ba5e200-6ffa-45ee-a2c4-594117ef4f25"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[ScriptCapitalY]", "n", "\[Lambda]"], 
     SubscriptBox["\[DownArrow]", 
      SubscriptBox["\[ScriptCapitalS]", 
       RowBox[{"n", "-", "1"}]]]}], "\[TildeEqual]", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "\[Element]", 
       RowBox[{"\[Lambda]", "-", "1"}]}]], 
     SubsuperscriptBox["\[ScriptCapitalY]", 
      RowBox[{"n", "-", "1"}], "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "224a0939-dd68-4b4d-9fd1-dd3ce883710c"],
 ","
}], "TechNoteText",
 CellID->96622062,ExpressionUUID->"c2bd3a0a-38e9-4d40-8e99-6f454519c7a6"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "-", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b2f2b04a-fb2f-4fad-bcd1-c5309c6cb5b8"],
 " denotes the set of Young diagrams resulting from removing a box from \
\[Lambda]. This is demonstrated here."
}], "TechNoteText",
 CellID->847279343,ExpressionUUID->"84c9efe4-061e-497e-a3d3-3414ff0c88e7"],

