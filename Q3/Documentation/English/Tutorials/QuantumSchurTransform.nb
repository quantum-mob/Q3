Cell[TextData[{
 "On the other hand, attaching a box to the Young diagram of shape ",
 Cell[BoxData[
  RowBox[{"\[Mu]", "=", 
   RowBox[{"(", 
    RowBox[{"1", ",", "1"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cc3f1b0c-42a4-4999-b544-db669e857805"],
 " may lead to the only Young diagram of shape ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "046688fd-1f46-4811-bbd4-2ef7a1088c5b"],
 " since attaching the box to the second row does not yield a valid Young \
diagram."
}], "TechNoteText",
 CellID->1119859386,ExpressionUUID->"6784137c-8064-45fb-9fcd-08858985a70a"],

Cell[CellGroupData[{

