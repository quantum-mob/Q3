Cell["Young diagrams and related tableaux.", "TechNoteCaption",
 CellID->1344678826,ExpressionUUID->"bdc1d2ab-ad7e-435c-adfd-873e1b6dc986"],

Cell[CellGroupData[{

Cell["Young Diagrams", "Subsection",
 CellID->849871904,ExpressionUUID->"e1378591-e232-4ca7-99d9-e8fc9e628971"],

Cell[TextData[{
 "A ",
 StyleBox[ButtonBox["Young diagram",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungDiagram"],
  FontSlant->"Italic"],
 " is a finite collection of boxes (or cells) arranged in left-justified \
rows, with the row lengths in non-increasing order. Listing the number of \
boxes in each row gives a ",
 StyleBox["partition",
  FontSlant->"Italic"],
 " \[Lambda] of a non-negative integer ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", the total number of boxes of the diagram. That is, for a Young diagram of \
",
 StyleBox["d",
  FontSlant->"Italic"],
 " rows, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"b8002617-211e-4f9c-833e-0a42f2491f52"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "2"], "\[GreaterEqual]", "\[Ellipsis]", "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "d"], ">", "0"}], TraditionalForm]],
  ExpressionUUID->"a4395524-caf7-4e19-95ef-5e874aa448f7"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"770d1456-12c5-4122-8a00-f41edf6c0a83"],
 ". Then, the Young diagram is said to be of shape \[Lambda] and degree ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "051b9604-4595-494c-b405-fd4992ef8674"],
 ", and it carries the same information as the corresponding partition."
}], "TechNoteText",
 CellID->392025427,ExpressionUUID->"5abccc5a-0678-48bb-bca2-dfd2719afeba"],

Cell[TextData[{
 "\tFor example, consider partitions of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["n",
    FontSlant->"Italic"], "=", "3"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "503c1ba8-f4cb-4ec2-ae4f-fe6833ef1a19"],
 ":"
}], "TechNoteText",
 CellID->489159754,ExpressionUUID->"438d21fa-74e4-4237-b89c-8bbcdab30e21"],

