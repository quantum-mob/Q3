Cell[TextData[{
 "The restriction of the above irreducible representation of S(",
 StyleBox["n",
  FontSlant->"Italic"],
 ") to subgroup S(",
 StyleBox["n",
  FontSlant->"Italic"],
 "-1) is reducible and is decomposed into different irreducible \
representations of S(",
 StyleBox["n",
  FontSlant->"Italic"],
 "-1) as illustrated below in a few select sectors:"
}], "TechNoteMathCaption",
 CellID->883586886,ExpressionUUID->"c34aecf8-3088-42d0-b187-6995b61d3889"],

