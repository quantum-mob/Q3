        AutoDelete -> False, 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
      QuantumMob`Q3`YoungTableau[{{1, 3}, {2}}]]},
    "Ket"], ",", 
   TemplateBox[{
     InterpretationBox[
      TagBox[
       GridBox[{{
          ItemBox["1", Frame -> True, StripOnInput -> False]}, {
          ItemBox["2", Frame -> True, StripOnInput -> False]}, {
          ItemBox["3", Frame -> True, StripOnInput -> False]}}, AutoDelete -> 
        False, GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
      QuantumMob`Q3`YoungTableau[{{1}, {2}, {3}}]]},
    "Ket"]}], "}"}]], "Output",
 CellLabel->"Out[66]=",
 CellID->1390811767,ExpressionUUID->"4414b54d-fd6f-4a57-860f-59e96cbfe043"]
}, Open  ]],

Cell[TextData[{
 "\tAt the moment, the vectors in the Young-Yamanouchi basis do not take any \
particular form of expression. All we require is that under the action of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Element]", 
    SubscriptBox["\[ScriptCapitalS]", "n"]}], TraditionalForm]],
  ExpressionUUID->"aaa4e846-ead6-4494-a51c-3c2a63397e7b"],
 ", the basis vectors transform as"
}], "TechNoteText",
 CellID->1155245835,ExpressionUUID->"2140623b-12b0-434c-9ecf-382024c92525"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      OverscriptBox["\[CapitalPi]", "^"], "(", "S", ")"}], 
     TemplateBox[{
       RowBox[{"\[Lambda]", ",", 
         SubscriptBox[
          RowBox[{"(", 
            SubscriptBox["y", "\[Lambda]"], ")"}], 
          RowBox[{"n", "-", "1"}]]}]},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "x"], 
     RowBox[{
      TemplateBox[{
        RowBox[{"\[Lambda]", ",", 
          SubscriptBox[
           RowBox[{"(", 
             SubscriptBox["x", "\[Lambda]"], ")"}], 
           RowBox[{"n", "-", "1"}]]}]},
       "Ket"], 
      RowBox[{
       SubsuperscriptBox["\[CapitalPi]", 
        RowBox[{"x", " ", "y"}], "\[Lambda]"], "(", "S", ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"5288f371-c59b-46a6-9711-2506bfbf2bbf"],
 ","
}], "DisplayMath",
 CellID->1800144916,ExpressionUUID->"56f7eab2-f097-4495-ab08-c6416d0b52f4"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalPi]", 
     StyleBox[
      RowBox[{"x", " ", "y"}],
      FontSlant->"Italic"], "\[Lambda]"], "(", "S", ")"}], TraditionalForm]],
  ExpressionUUID->"3f477f52-f20a-41fa-9396-063e9b3b01c7"],
 " is the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{"x", " ", "y"}], ")"}], "th"], TraditionalForm]],ExpressionUUID->
  "353fea08-dfee-4735-84d7-72f0195e513d"],
 " matrix element of the irreducible representation \[Lambda] and the \
summation is over all Gelfand subpatterns ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["x", "\[Lambda]"], ")"}], 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "962cf837-fc46-4a8d-8edf-aedd155bb028"],
 " consistent with standard Young tableaux of shape \[Lambda]."
}], "TechNoteText",
 CellID->1389722945,ExpressionUUID->"6be0511a-b231-4445-b9e3-83096f8b4ae2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Irreducible Representations of the Unitary Group", "Subsection",
 CellID->992313767,ExpressionUUID->"158bd90a-153e-40c1-af07-a89727812fc0"],

Cell[TextData[{
 "Unlike symmetric group ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalS]", 
   StyleBox["n",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4f43949d-abe2-4ccb-82a0-6de12f502748"],
 ", unitary group ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "30581fa7-91dc-486e-9cbe-e4764c72d85d"],
 " is an infinite group and has an unlimited number of irreducible \
representations. Nevertheless, for a fixed integer ",
 StyleBox["n",
  FontSlant->"Italic"],
 ", any partition \[Lambda] of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " into at most ",
 StyleBox["d",
  FontSlant->"Italic"],
 " integers labels uniquely (up to equivalence) an irreducible representation \
of ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "731398d7-3d6a-4781-adcb-dc621d2acbc1"],
 ". More specifically, let ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"9764810a-5191-42c0-90a0-e70a82f2648a"],
 " be an integer partition of a fixed integer ",
 StyleBox["n",
  FontSlant->"Italic"],
 " such that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "2"], "\[GreaterEqual]", "\[Ellipsis]", "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "d"], "\[GreaterEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"4b6e7478-7703-48b9-9fb4-c1a9bb7244c2"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", "2"], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"05a8a0ee-d542-47aa-93f9-4af1d63deb33"],
 ". Then, one can find one and only one irreducible representation of ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "629b89bd-1299-41db-88ac-244e7593b456"],
 "."
}], "TechNoteText",
 CellID->657827309,ExpressionUUID->"6e2a3583-f539-4d22-9c01-92d06f3f9b6c"],

Cell[TextData[{
 "\tHere, note that different partitions of different integers may lead to \
equivalent irreducible representations. For example, both ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"(", 
     RowBox[{"2", ",", "1"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "2bd86dde-9f2e-4fed-9cf4-59df06d3d461"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "=", 
    RowBox[{"(", "1", ")"}]}], TraditionalForm]],ExpressionUUID->
  "8ef86920-62f7-4892-886e-17a07873d090"],
 " give the irreducible representation of SU(2) associated with angular \
momentum ",
 Cell[BoxData[
  FormBox[
   RowBox[{"J", "=", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "ffe1afd8-a89b-410b-82a6-d113a8a15e7a"],
 " (see ",
 ButtonBox["Note 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumSchurTransform#892325562"],
 "). Within the formulation of branching rules (e.g., for a subgroup adapted \
basis), it is convenient to regard such representations as inequivalent."
}], "TechNoteText",
 CellID->734204582,ExpressionUUID->"17bd975e-3f43-434a-80d9-8878022076e6"],

Cell[TextData[{
 "\tFor a partition \[Lambda] into at most ",
 StyleBox["d",
  FontSlant->"Italic"],
 " integers, let ",
 Cell[BoxData[
  SubsuperscriptBox["\[ScriptCapitalW]", 
   StyleBox["d",
    FontSlant->"Italic"], "\[Lambda]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2bc2bbac-b66f-4144-a116-c0389c4f2d5b"],
 " be the representation space of irreducible representation \[Lambda] of ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8ae96eec-6d8e-4750-8351-10cf78c55f6a"],
 ". Below, we mostly drop the subscript ",
 StyleBox["d",
  FontSlant->"Italic"],
 ", which is usually clear from the context, and denote the representation \
space just by ",
 Cell[BoxData[
  SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4c5497cd-8de7-4c48-b33c-313bf54be814"],
 ". The dimension of ",
 Cell[BoxData[
  SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a800c998-cb8c-4d3c-bc63-f5fed4226067"],
 " equals the number of ",
 StyleBox["Weyl tableaux",
  FontSlant->"Italic"],
 " of shape \[Lambda]. It is thus natural to label the basis elements with \
Weyl tableaux ",
 Cell[BoxData[
  SubscriptBox[
   StyleBox["W",
    FontSlant->"Italic"], "\[Lambda]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6c580c3d-8b5b-44a0-99bc-009493600542"],
 " of shape \[Lambda],"
}], "TechNoteText",
 CellID->857767607,ExpressionUUID->"6489d5d2-8611-48c6-90a5-122514d96392"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"{", 
   TemplateBox[{
     SubscriptBox[
      StyleBox["W", FontSlant -> "Italic"], "\[Lambda]"]},
    "Ket"], "}"}]],ExpressionUUID->"9e9508a8-9cdf-4e28-8655-5d4a30569968"],
 " ."
}], "DisplayMath",
 CellID->442448538,ExpressionUUID->"fb8e9906-feea-41a2-9c1d-6074af99264d"],

Cell[TextData[{
 "This basis is called the ",
 StyleBox["Gelfand-Zetlin (or Gelfand-Tsetlin) basis",
  FontSlant->"Italic"],
 ". Physically, a Weyl tableau represents the occupation of quantum states \
corresponding to the letters in the entries of the tableau (see below)."
}], "TechNoteText",
 CellID->1644192252,ExpressionUUID->"a209dfdd-7d3e-43ac-bb89-e01087b41887"],

Cell[TextData[{
 "\tAgain, we prefer Gelfand patterns to Young tableaux and replace Weyl \
tableau ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "8107ac31-ab7f-49c4-960a-49c92725a5b9"],
 " with the corresponding ",
 StyleBox[ButtonBox["Gelfand-Weyl pattern",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumSchurTransform#1685151388"],
  FontSlant->"Italic"],
 " so that"
}], "TechNoteText",
 CellID->119609768,ExpressionUUID->"dff1a3f2-037a-422a-a418-6e41b8055773"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    TemplateBox[{
      FormBox[
       RowBox[{"(", 
         GridBox[{{
            RowBox[{"\[Lambda]", "       "}]}, {
            SubscriptBox[
             RowBox[{"(", 
               SubscriptBox["w", "\[Lambda]"], ")"}], 
             RowBox[{"d", "-", "1"}]]}}], ")"}], TraditionalForm]},
     "Ket"], "=", 
    RowBox[{
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Lambda]", "  "}]}, {
              RowBox[{"(", 
                SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
        TraditionalForm]},
      "Ket"], "=", 
     TemplateBox[{
       FormBox[
        SubscriptBox["w", "\[Lambda]"], TraditionalForm]},
      "Ket"]}]}], "}"}]],ExpressionUUID->
  "6ab2c1db-3478-402a-96b8-53dbe676771c"],
 "."
}], "DisplayMath",
 CellID->236677184,ExpressionUUID->"70c6576f-e25b-423e-98b6-887d35e78f6f"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["w", "\[Lambda]"], ")"}], 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "ce958f83-d918-497e-844f-64ad496f6241"],
 " denotes the Gelfand subpattern consistent with Weyl tableau ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["w", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "4e94706e-9a9e-4373-9819-8e831896c7b9"],
 ". As for the Young-Yamanouchi basis, shape \[Lambda] appears as a part (the \
top row) of the full Gelfand pattern. Since shape \[Lambda] refers to an \
irreducible representation and subpattern ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["w", "\[Lambda]"], ")"}], 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "46c00ebd-3ada-40f3-88a3-e1efa073425b"],
 " to basis elements in the irreducible representation, to make more explicit \
their roles, we sometimes split them to write as"
}], "TechNoteText",
 CellID->693717244,ExpressionUUID->"65315653-6a15-4456-b3ed-74368e79d776"],

Cell[TextData[Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       SubscriptBox[
        RowBox[{"(", 
          SubscriptBox[
           StyleBox["w", FontSlant -> "Italic"], "\[Lambda]"], ")"}], 
        RowBox[{
          StyleBox["d", FontSlant -> "Italic"], "-", "1"}]]}]},
    "Ket"], ":=", 
   RowBox[{
    TemplateBox[{
      FormBox[
       RowBox[{"(", 
         GridBox[{{
            RowBox[{"\[Lambda]", "       "}]}, {
            SubscriptBox[
             RowBox[{"(", 
               SubscriptBox["w", "\[Lambda]"], ")"}], 
             RowBox[{"d", "-", "1"}]]}}], ")"}], TraditionalForm]},
     "Ket"], "=", 
    RowBox[{
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Lambda]", "  "}]}, {
              RowBox[{"(", 
                SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
        TraditionalForm]},
      "Ket"], "=", 
     TemplateBox[{
       FormBox[
        SubscriptBox["w", "\[Lambda]"], TraditionalForm]},
      "Ket"]}]}]}], 
  "}"}]],ExpressionUUID->"0dfcd34c-098a-45d1-a364-1bb50199fdc5"]], \
"DisplayMath",
 CellID->617000345,ExpressionUUID->"e4819e56-5ba8-4663-989d-7b0ec0d12408"],

Cell["when there is no risk of confusion.", "TechNoteText",
 CellID->1873750699,ExpressionUUID->"ad481a56-aefb-41f7-a12b-bf3ec779c296"],

