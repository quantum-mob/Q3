     FontSlant->"Italic"], "-", "1"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b4a7708b-a8d1-4d85-83e3-68cc0ecba094"],
 ". For ",
 Cell[BoxData[
  FormBox[
   RowBox[{"j", "=", "d"}], TraditionalForm]],ExpressionUUID->
  "0dc5481c-74a8-48f3-99a0-d9425099e2e3"],
 ", define"
}], "TechNoteText",
 CellID->1010856397,ExpressionUUID->"a4156223-6d8a-4e38-a4e9-9d5f44737642"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     OverscriptBox["T", "^"], "d", 
     RowBox[{"\[Lambda]", ",", 
      RowBox[{"\[Mu]", ";", 
       RowBox[{"\[Lambda]", "'"}]}], ",", 
      RowBox[{"\[Mu]", "'"}]}]], "=", 
    RowBox[{
     SubscriptBox["\[Delta]", 
      RowBox[{
       SuperscriptBox["\[Lambda]", "\[Prime]"], 
       SuperscriptBox["\[Mu]", "\[Prime]"]}]], 
     SuperscriptBox["T", 
      RowBox[{"\[Lambda]", ",", 
       RowBox[{"\[Mu]", ";", 
        RowBox[{"\[Mu]", "'"}]}], ",", 
       RowBox[{"\[Mu]", "'"}]}]], 
     SubscriptBox[
      OverscriptBox["I", "^"], 
      SuperscriptBox["\[Mu]", "\[Prime]"]]}]}], TraditionalForm]],
  ExpressionUUID->"2f086b78-64b7-4338-a562-0e9d528afc09"],
 ","
}], "TechNoteText",
 CellID->1355003504,ExpressionUUID->"6ed034c4-c8ba-4d91-8a8e-fba70ddb2a11"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["T", 
    RowBox[{"\[Lambda]", ",", 
     RowBox[{"\[Mu]", ";", 
      RowBox[{"\[Mu]", "'"}]}], ",", 
     RowBox[{"\[Mu]", "'"}]}]], TraditionalForm]],ExpressionUUID->
  "318caf08-f5ef-4d93-98ab-6d11c37c789a"],
 "is some constant to be fixed later. Using the fact that ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    OverscriptBox["T", "^"], "j", 
    RowBox[{"\[Lambda]", ",", "\[Mu]"}]], TraditionalForm]],ExpressionUUID->
  "abe29fe3-6aef-44e4-a6c5-786905dd397e"],
 " is an irreducible tensor operator transforming like ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "8f0bbb84-1efb-4fc5-9aca-e1e95536f527"],
 ", one can show that it is decomposed as"
}], "TechNoteText",
 CellID->1627298940,ExpressionUUID->"40735036-8e12-4b2e-bf68-a8ff60287cfb"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox[
      OverscriptBox["T", "^"], "j", 
      RowBox[{"\[Lambda]", ",", "\[Mu]"}]], 
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Mu]", "  "}]}, {
              RowBox[{"\[Mu]", "'"}]}, {
              RowBox[{"(", 
                SubscriptBox["v", 
                 RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], "d"], 
        TraditionalForm]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"\[Lambda]", "'"}]], 
      RowBox[{
       SubsuperscriptBox[
        OverscriptBox["T", "^"], "j", 
        RowBox[{"\[Lambda]", ",", 
         RowBox[{"\[Mu]", ";", 
          RowBox[{"\[Lambda]", "'"}]}], ",", 
         RowBox[{"\[Mu]", "'"}]}]], 
       TemplateBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{
                  RowBox[{"\[Mu]", "'"}], "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["v", 
                   RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], 
           RowBox[{"d", "-", "1"}]], TraditionalForm]},
        "Ket"]}]}], "=", 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"\[Lambda]", "'"}]], 
      RowBox[{
       SubscriptBox["\[Sum]", 
        RowBox[{"(", 
         SubscriptBox["w", 
          RowBox[{"\[Lambda]", "'"}]], ")"}]], 
       RowBox[{
        TemplateBox[{
          FormBox[
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 RowBox[{"\[Lambda]", "  "}]}, {
                 RowBox[{"\[Lambda]", "'"}]}, {
                 RowBox[{"(", 
                   SubscriptBox["w", 
                    RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], "d"], 
           TraditionalForm]},
         "Ket"], 
        TemplateBox[{
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{
                  RowBox[{"\[Lambda]", "'"}], "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", 
                   RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], 
           RowBox[{"d", "-", "1"}]]},
         "Bra"], 
        SubsuperscriptBox[
         OverscriptBox["T", "^"], "j", 
         RowBox[{"\[Lambda]", ",", 
          RowBox[{"\[Mu]", ";", 
           RowBox[{"\[Lambda]", "'"}]}], ",", 
          RowBox[{"\[Mu]", "'"}]}]], 
        TemplateBox[{
          FormBox[
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 RowBox[{
                   RowBox[{"\[Mu]", "'"}], "    "}]}, {
                 RowBox[{"(", 
                   SubscriptBox["v", 
                    RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], 
            RowBox[{"d", "-", "1"}]], TraditionalForm]},
         "Ket"]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "8fe11d9a-1c50-406c-98d3-59856ec38a2a"],
 ","
}], "DisplayMath",
 CellID->1067393303,ExpressionUUID->"ca16598e-c5f3-4afc-bfd0-4a1372d47434"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
