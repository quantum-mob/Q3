 CellID->225082645,ExpressionUUID->"1d6c284f-5689-496a-ab01-5edfb4a86d11"],

Cell["Schur and dual Schur bases.", "TechNoteCaption",
 CellID->1245312148,ExpressionUUID->"1aa93072-d420-4748-83e1-1e9e8963a3bd"],

Cell[TextData[{
 "Consider a composite system of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " identical nodes (subsystems). Each node is associated with a ",
 StyleBox["d",
  FontSlant->"Italic"],
 "-dimensional Hilbert space ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", "d"], TraditionalForm]],ExpressionUUID->
  "6a562e14-b36c-4d90-85e2-8eb1c7fa6cc4"],
 ", and the computational (logical) basis is denoted by ",
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    TemplateBox[{"1"},
     "Ket"], ",", 
    TemplateBox[{"2"},
     "Ket"], ",", "\[Ellipsis]", ",", 
    TemplateBox[{
      StyleBox["d", FontSlant -> "Italic"]},
     "Ket"]}], "}"}]],ExpressionUUID->
  "38d7b56b-d0a5-4bc7-891e-98680a550c4e"],
 ". The tensor-product space ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[ScriptCapitalV]", "d"], "\[CircleTimes]", 
     SubscriptBox["\[ScriptCapitalV]", "d"], "\[CircleTimes]", "\[Ellipsis]", 
     "\[CircleTimes]", 
     SubscriptBox["\[ScriptCapitalV]", "d"]}], "=", 
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "eaa80a2c-9bac-4567-a2d5-6960ded17abd"],
 " is associated with the entire composite system."
}], "TechNoteText",
 CellID->1286515510,ExpressionUUID->"9275f7db-b660-46d4-b450-76ba38414f76"],

Cell[CellGroupData[{

Cell["\<\
Actions of the Symmetric and Unitary Groups on the Composite System\
\>", "Subsection",
 CellID->765616031,ExpressionUUID->"6db8f14f-2762-4940-9f54-1b6ee11d6772"],

Cell["\<\
We are often interested in characterizing the symmetries in the system. In \
this case, the relevant symmetries are associated with the symmetric and/or \
unitary group.\
\>", "TechNoteText",
 CellID->1568061860,ExpressionUUID->"df0e7f8a-fc83-45c2-8fc8-0e3ad1528ad4"],

Cell[TextData[{
 "\tOn the tensor-product space, ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "1a9863e3-d4d7-4137-ae60-6e100d5a3b92"],
 ", the action of symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "d0ee0f3f-5c20-4e2c-9627-0ec7b03ab6fa"],
 " is defined by"
}], "TechNoteText",
 CellID->1823059039,ExpressionUUID->"f06d125e-0d10-4aee-a04d-69fd31fb39ee"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    OverscriptBox["\[CapitalPi]", "^"], " ", 
    RowBox[{"(", "S", ")"}], 
    RowBox[{
     TemplateBox[{
       SubscriptBox["j", "1"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["j", "2"]},
      "Ket"], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["j", "n"]},
      "Ket"]}]}], "=", 
   RowBox[{
    TemplateBox[{
      SubscriptBox["j", 
       RowBox[{
         SuperscriptBox["S", 
          RowBox[{"-", "1"}]], "(", "1", ")"}]]},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{
      SubscriptBox["j", 
       RowBox[{
         SuperscriptBox["S", 
          RowBox[{"-", "1"}]], "(", "2", ")"}]]},
     "Ket"], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
    TemplateBox[{
      SubscriptBox["j", 
       RowBox[{
         SuperscriptBox["S", 
          RowBox[{"-", "1"}]], "(", "n", ")"}]]},
     "Ket"]}]}], 
  TraditionalForm]],ExpressionUUID->"6066706b-5a11-48b6-9a8d-f4fefa004ece"]], \
"DisplayMath",
 CellID->1513215855,ExpressionUUID->"0892d0b8-2d14-4bb6-a664-1a8d4db3047f"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Element]", 
    SubscriptBox["\[ScriptCapitalS]", "n"]}], TraditionalForm]],
  ExpressionUUID->"321de6d2-28a3-4302-b237-47ecfee8ed4d"],
 "."
}], "TechNoteText",
 CellID->1317677936,ExpressionUUID->"33b55340-9914-4003-83a6-71fafd28be75"],

Cell[TextData[{
 "\tOn the other hand, the action of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalU]", "d"], TraditionalForm]],ExpressionUUID->
  "f32d7540-de5c-4d7d-ad4c-d2fe8b73f531"],
 " on ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "41933ad6-670f-4f70-a299-5609fa5d97f3"],
 " is defined by"
}], "TechNoteText",
 CellID->118522863,ExpressionUUID->"66a5ffc3-7a9c-4c32-9daf-a1e2da4ddc26"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[CapitalOmega]", "^"], " ", 
     RowBox[{"(", "U", ")"}], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["j", "1"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["j", "2"]},
       "Ket"], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["j", "n"]},
       "Ket"]}]}], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       OverscriptBox["U", "^"], 
       TemplateBox[{
         SubscriptBox["j", "1"]},
        "Ket"]}], ")"}], "\[CircleTimes]", 
     RowBox[{"(", 
      RowBox[{
       OverscriptBox["U", "^"], 
       TemplateBox[{
         SubscriptBox["j", "2"]},
        "Ket"]}], ")"}], "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
     RowBox[{"(", 
      RowBox[{
       OverscriptBox["U", "^"], 
       TemplateBox[{
         SubscriptBox["j", "n"]},
        "Ket"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "1340b23b-6174-428e-a9b2-62d506d68a58"],
 ","
}], "DisplayMath",
 CellID->1321586049,ExpressionUUID->"fb92d22c-b27b-4fea-bd06-07b64f4474c5"],

Cell[TextData[{
 "The action ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["\[CapitalOmega]", "^"], " ", 
    RowBox[{"(", "U", ")"}]}], TraditionalForm]],ExpressionUUID->
  "d770d3e7-fda6-4f3c-9aeb-83711032eec4"],
 " characterizes the global unitary symmetry transformation, that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[CapitalOmega]", "^"], "(", "U", ")"}], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      OverscriptBox["U", "^"], ")"}], 
     RowBox[{"\[CircleTimes]", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "7310973b-d940-413d-b789-bf86d109ac01"],
 ". Recall that the actions of unitary group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalU]", "d"], TraditionalForm]],ExpressionUUID->
  "14f4286f-72f7-41f2-8320-47ee0b23868d"],
 " on ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalV]", "d"], TraditionalForm]],ExpressionUUID->
  "6bb90938-44de-4deb-b4e5-2994dee59047"],
 " is inherently given by"
}], "TechNoteText",
 CellID->910191976,ExpressionUUID->"59e04b82-8633-4879-9a4b-d8908076cc52"],

Cell[TextData[Cell[BoxData[
 RowBox[{
  RowBox[{
   OverscriptBox[
    StyleBox["U",
     FontSlant->"Italic"], "^"], 
   TemplateBox[{
     StyleBox["j", FontSlant -> "Italic"]},
    "Ket"]}], "=", 
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{
     StyleBox["i",
      FontSlant->"Italic"], "=", "1"}], 
    StyleBox["d",
     FontSlant->"Italic"]], 
   RowBox[{
    TemplateBox[{
      StyleBox["i", FontSlant -> "Italic"]},
     "Ket"], 
    SubscriptBox[
     StyleBox["U",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->
       "Italic"]]}]}]}]],ExpressionUUID->"7902e747-8e40-4636-9b5d-\
2ce36f055978"]], "DisplayMath",
 CellID->545541245,ExpressionUUID->"4a46735c-1041-43a6-8a55-9e06641d8c52"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "\[Element]", 
    SubscriptBox["\[ScriptCapitalU]", "d"]}], TraditionalForm]],
  ExpressionUUID->"cdf525ed-6a2e-4aea-a0b4-4a858ea9e4b3"],
 "."
}], "TechNoteText",
 CellID->1472805211,ExpressionUUID->"e8b74ab8-81ca-4d08-8d15-c3d975aa82d4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Schur-Weyl Duality", "Subsection",
 CellID->1574111099,ExpressionUUID->"f13c03ec-4e9b-4614-887d-578230e01764"],

Cell[TextData[{
 "The tensor-product space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "eba999c2-3542-4840-bfcb-4b7665c160cd"],
 " associated with the composite system is not irreducible under the above \
actions of the symmetric and unitary groups. The ",
 StyleBox["Schur-Weyl duality",
  FontSlant->"Italic"],
 " theorem states that"
}], "TechNoteText",
 CellID->1012163206,ExpressionUUID->"09c90497-634f-4139-b8c5-45d335bd16c2"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[ScriptCapitalV]", "d", 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], "\[CircleTimes]", 
      SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"2aa5c11b-43e5-40c9-9273-cd6f8da364e3"],
 " ."
}], "DisplayMath",
 CellID->1522503933,ExpressionUUID->"bcbdf799-a264-4222-b325-0d3acf5f2872"],

Cell[TextData[{
 "Here, the summation is over all partitions ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", "d"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"03e89726-d93c-480b-978c-320fa021a4b7"],
 " of integer ",
 StyleBox["n",
  FontSlant->"Italic"],
 " into at most ",
 StyleBox["d",
  FontSlant->"Italic"],
 " integers (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "2"], "\[GreaterEqual]", "\[Ellipsis]", "\[GreaterEqual]", 
    SubscriptBox["\[Lambda]", "d"], "\[GreaterEqual]", "0"}], 
   TraditionalForm]],ExpressionUUID->"fa6da6ac-ece8-4f60-ba72-808c11608604"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "1"], "+", 
     SubscriptBox["\[Lambda]", 
      RowBox[{"2", " "}]], "+", "\[Ellipsis]", "+", 
     SubscriptBox["\[Lambda]", "d"]}], "=", "n"}], TraditionalForm]],
  ExpressionUUID->"f3023b1f-d35f-4bf1-a493-4e4e8a1dd1f8"],
 "), and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"0b85709a-2eac-4d6c-b371-6490d8388546"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"cee560a8-176e-47a7-a4e8-9a3efab240a7"],
 " are the irreducible representation spaces of ",
 ButtonBox["symmetric group",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SymmetricGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "3fe784c9-3be8-4117-8c38-8659e5e453a8"],
 " and unitary group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalU]", "d"], TraditionalForm]],ExpressionUUID->
  "c7d30026-60ca-47d0-92a4-fd8593b43493"],
 ", respectively, labelled uniquely (up to equivalence) by partition (shape \
of Young diagrams) \[Lambda]. "
}], "TechNoteText",
 CellID->1364818379,ExpressionUUID->"2f5ba5f2-36f1-4c58-a82e-018356792504"],

Cell[TextData[{
 "\tRecall that the ",
 StyleBox["Young-",
  FontSlant->"Italic"],
 StyleBox["Yamanouchi",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox[" basis",
  FontSlant->"Italic"],
 " vectors of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"61451a83-f05e-4daf-aebe-f486afab01a6"],
 " can be labelled with standard Young tableaux of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " letters with shape \[Lambda], or equivalent Gelfand patterns in the form"
}], "TechNoteText",
 CellID->1246192328,ExpressionUUID->"34f32478-f6fe-460c-b821-231029607f42"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       SubscriptBox[
        RowBox[{"(", 
          SubscriptBox[
           StyleBox["y", FontSlant -> "Italic"], "\[Lambda]"], ")"}], 
        RowBox[{
          StyleBox["n", FontSlant -> "Italic"], "-", "1"}]]}]},
    "Ket"], "=", 
   TemplateBox[{
     FormBox[
      RowBox[{"(", 
        GridBox[{{
           RowBox[{
             SubscriptBox[
              RowBox[{"[", "\[Lambda]", "]"}], "n"], "    "}]}, {
           SubscriptBox[
            RowBox[{"(", 
              SubscriptBox["y", "\[Lambda]"], ")"}], 
            RowBox[{"n", "-", "1"}]]}}], ")"}], TraditionalForm]},
    "Ket"]}]],ExpressionUUID->"6bf1ecd5-d851-4b99-a107-8c1ad1f0460a"],
 "."
}], "DisplayMath",
 CellID->1096805733,ExpressionUUID->"17df9c55-6016-464a-baf0-d715f163a4f8"],

Cell[TextData[{
 "\tSimilarly, the ",
 StyleBox["Gelfand-",
  FontSlant->"Italic"],
 StyleBox["Zetlin",
  IgnoreSpellCheck->True,
  FontSlant->"Italic"],
 StyleBox[" basis",
  FontSlant->"Italic"],
 " vectors of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], TraditionalForm]],
  ExpressionUUID->"62b1d7eb-547a-4002-9ab2-7dce09412d4c"],
 " are labelled with Weyl tableaux of ",
 StyleBox["d",
  FontSlant->"Italic"],
 " letters with shape \[Lambda], or equivalent Gelfand patterns"
}], "TechNoteText",
 CellID->784307233,ExpressionUUID->"cd86df33-a392-4cf7-8a26-1f7baa2892d7"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       SubscriptBox[
        RowBox[{"(", 
          SubscriptBox[
           StyleBox["w", FontSlant -> "Italic"], "\[Lambda]"], ")"}], 
        RowBox[{
          StyleBox["d", FontSlant -> "Italic"], "-", "1"}]]}]},
    "Ket"], "=", 
   TemplateBox[{
     FormBox[
      RowBox[{"(", 
        GridBox[{{
           RowBox[{
             SubscriptBox[
              RowBox[{"[", "\[Lambda]", "]"}], "d"], "    "}]}, {
           SubscriptBox[
            RowBox[{"(", 
              SubscriptBox["w", "\[Lambda]"], ")"}], 
            RowBox[{"d", "-", "1"}]]}}], ")"}], TraditionalForm]},
    "Ket"]}]],ExpressionUUID->"14706208-2cf8-471b-8936-544ca95ca9d4"],
 "."
}], "DisplayMath",
 CellID->1138096490,ExpressionUUID->"5ef800b4-7df5-4838-b8d9-823920a0adea"],

Cell[TextData[{
 "Here, recall also that by convention, we regard ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox[
      RowBox[{"[", "\[Lambda]", "]"}], "d"], "\[Congruent]", 
     SubscriptBox[
      RowBox[{"[", "\[Lambda]", "]"}], "n"], "\[Congruent]", "\[Lambda]"}], "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Lambda]", "1"], ",", 
      SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["\[Lambda]", 
       StyleBox["d",
        FontSlant->"Italic"]], ",", "0", ",", "\[Ellipsis]", ",", "0"}], 
     ")"}]}], TraditionalForm]],ExpressionUUID->
  "c6482fee-5f7a-4a57-a726-815216e19900"],
 " with trailing zeros in partition specifications ignored."
}], "TechNoteText",
 CellID->126971447,ExpressionUUID->"42138200-25b9-492c-a76b-351b23470b18"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Schur Basis", "Subsection",
 CellID->409286437,ExpressionUUID->"19823de2-5725-42cd-a844-f7bcf1496219"],

Cell[TextData[{
 "According to the above Schur-Weyl duality, one can choose a basis of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "1545b843-adeb-4f33-a1de-f80d341c5a2e"],
 " whose elements are labelled by pairs of two Gelfand patterns of order ",
 StyleBox["n",
  FontSlant->"Italic"],
 " and ",
 StyleBox["d",
  FontSlant->"Italic"],
 ", respectively, as"
}], "TechNoteText",
 CellID->2012954289,ExpressionUUID->"dda756e6-00af-45d7-bc05-91e31d13caa6"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    TemplateBox[{
      RowBox[{
        FormBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{
                SubscriptBox[
                 RowBox[{"[", "\[Lambda]", "]"}], "n"], "     "}]}, {
              SubscriptBox[
               RowBox[{"(", 
                 SubscriptBox["y", "\[Lambda]"], ")"}], 
               RowBox[{"n", "-", "1"}]]}}], ")"}], TraditionalForm], ",", 
        FormBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{
                SubscriptBox[
                 RowBox[{"[", "\[Lambda]", "]"}], "d"], "     "}]}, {
              SubscriptBox[
               RowBox[{"(", 
                 SubscriptBox["w", "\[Lambda]"], ")"}], 
               RowBox[{"d", "-", "1"}]]}}], ")"}], TraditionalForm]}]},
     "Ket"], "=", 
    TemplateBox[{
      RowBox[{
        FormBox[
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "   "}]}, {
               RowBox[{"(", 
                 SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
         TraditionalForm], ",", 
        FormBox[
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "    "}]}, {
               RowBox[{"(", 
                 SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
         TraditionalForm]}]},
     "Ket"]}], "}"}]],ExpressionUUID->
  "0a2b56bf-e353-42b6-9c2f-6383ff402458"],
 "."
}], "DisplayMath",
 CellID->1877572792,ExpressionUUID->"8e4c9f97-80d7-478a-ac37-29df634223a0"],

Cell[TextData[{
 "Clearly, this is equivalent (but not exactly identical) to a tensor product \
of the Young-Yamanouchi and Gelfand-Zetlin bases explained in the above. By \
varying \[Lambda] over all partitions of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " into at most ",
 StyleBox["d",
  FontSlant->"Italic"],
 " integers and varying Gelfand subpatterns ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["y", "\[Lambda]"], ")"}], 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "4dabb8d3-3922-49fd-a5ea-e4eb85f40ab3"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["w", "\[Lambda]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "90155ef1-f500-4ca0-a671-b6850341a281"],
 " consistent with \[Lambda], one can list all basis elements sufficient to \
span the space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "3e6d3b48-4a74-4813-a57a-a7b176143498"],
 ". This basis is called the ",
 StyleBox[ButtonBox["Schur basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchurBasis"],
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1662578750,ExpressionUUID->"81abcebc-eea4-450f-95ed-8b980425b731"],

Cell["\<\
\tUsing the same short-hand specifications as in the Young-Yamanouchi and \
Gelfand-Zetlin bases, the Schur basis elements may be denoted by\
\>", "TechNoteText",
 CellID->1421550164,ExpressionUUID->"fa071a03-3a7f-4997-9112-d8274f1ad231"],

Cell[TextData[Cell[BoxData[
 RowBox[{
  TemplateBox[{
    RowBox[{"\[Lambda]", ",", 
      SubscriptBox[
       RowBox[{"(", 
         SubscriptBox[
          StyleBox["y", FontSlant -> "Italic"], "\[Lambda]"], ")"}], 
       RowBox[{
         StyleBox["n", FontSlant -> "Italic"], "-", "1"}]], ",", 
      SubscriptBox[
       RowBox[{"(", 
         SubscriptBox[
          StyleBox["w", FontSlant -> "Italic"], "\[Lambda]"], ")"}], 
       RowBox[{
         StyleBox["d", FontSlant -> "Italic"], "-", "1"}]]}]},
   "Ket"], ":=", 
  RowBox[{
   TemplateBox[{
     RowBox[{
       FormBox[
        RowBox[{"(", 
          GridBox[{{
             RowBox[{
               SubscriptBox[
                RowBox[{"[", "\[Lambda]", "]"}], "n"], "     "}]}, {
             SubscriptBox[
              RowBox[{"(", 
                SubscriptBox["y", "\[Lambda]"], ")"}], 
              RowBox[{"n", "-", "1"}]]}}], ")"}], TraditionalForm], ",", 
       FormBox[
        RowBox[{"(", 
          GridBox[{{
             RowBox[{
               SubscriptBox[
                RowBox[{"[", "\[Lambda]", "]"}], "d"], "     "}]}, {
             SubscriptBox[
              RowBox[{"(", 
                SubscriptBox["w", "\[Lambda]"], ")"}], 
              RowBox[{"d", "-", "1"}]]}}], ")"}], TraditionalForm]}]},
    "Ket"], "=", 
   TemplateBox[{
     RowBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Lambda]", "   "}]}, {
              RowBox[{"(", 
                SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
        TraditionalForm], ",", 
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Lambda]", "    "}]}, {
              RowBox[{"(", 
                SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
        TraditionalForm]}]},
    "Ket"]}]}]],ExpressionUUID->"bf4fd954-3022-46f5-b461-7d154388966a"]], \
"DisplayMath",
 CellID->215430891,ExpressionUUID->"132e442d-5a92-42ce-8f72-767f9d6b3ba1"],

Cell["\<\
One expects that the actions of the symmetric and unitary groups on these \
basis vectors are given by\
\>", "TechNoteText",
 CellID->846171941,ExpressionUUID->"a15eef8e-e894-4e1b-8cbe-c818676816a4"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     OverscriptBox["\[CapitalPi]", "^"], "(", "S", ")"}], 
    TemplateBox[{
      RowBox[{
        FormBox[
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "   "}]}, {
               RowBox[{"(", 
                 SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
         TraditionalForm], ",", 
        FormBox[
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "    "}]}, {
               RowBox[{"(", 
                 SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
         TraditionalForm]}]},
     "Ket"]}], "=", 
   RowBox[{
    SubscriptBox["\[Sum]", "x"], 
    RowBox[{
     TemplateBox[{
       RowBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "   "}]}, {
                RowBox[{"(", 
                  SubscriptBox["x", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
          TraditionalForm], ",", 
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalPi]", 
       StyleBox["xy",
        FontSlant->"Italic"], "\[Lambda]"], "(", "S", ")"}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"805079f2-e901-4928-a7c0-909fbf78a405"]], \
"DisplayMath",
 CellID->630656214,ExpressionUUID->"c1505715-68f3-452d-9d2e-8e046d8ddc0e"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Element]", 
    SubscriptBox["\[ScriptCapitalS]", "n"]}], TraditionalForm]],
  ExpressionUUID->"957de171-9474-4d3a-80b6-aca76290c2a3"],
 " and"
}], "TechNoteText",
 CellID->657711319,ExpressionUUID->"b2b4d1a2-207a-4e0c-95a0-0834711256c7"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     OverscriptBox["\[CapitalOmega]", "^"], "(", "U", ")"}], 
    TemplateBox[{
      RowBox[{
        FormBox[
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "   "}]}, {
               RowBox[{"(", 
                 SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
         TraditionalForm], ",", 
        FormBox[
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "    "}]}, {
               RowBox[{"(", 
                 SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
         TraditionalForm]}]},
     "Ket"]}], "=", 
   RowBox[{
    SubscriptBox["\[Sum]", "v"], 
    RowBox[{
     TemplateBox[{
       RowBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "   "}]}, {
                RowBox[{"(", 
                  SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
          TraditionalForm], ",", 
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["v", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]}]},
      "Ket"], 
     RowBox[{
      SubsuperscriptBox["\[CapitalOmega]", 
       StyleBox["vw",
        FontSlant->"Italic"], "\[Lambda]"], "(", "U", ")"}]}]}]}], 
  TraditionalForm]],ExpressionUUID->"b728292f-947e-43d0-bc9f-cdce4de886b8"]], \
"DisplayMath",
 CellID->2072996005,ExpressionUUID->"0fe8643d-168d-44bf-90cb-3891dbd43d0c"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "\[Element]", 
    SubscriptBox["\[ScriptCapitalU]", "d"]}], TraditionalForm]],
  ExpressionUUID->"5d528c59-380a-4db1-8db8-0f155da7bd19"],
 ", where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalPi]", 
     StyleBox["xy",
      FontSlant->"Italic"], "\[Lambda]"], "(", "S", ")"}], TraditionalForm]],
  ExpressionUUID->"61d88de0-e4dd-45ca-8258-5b0f75c1bf43"],
 " is the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[VeryThinSpace]", 
    SuperscriptBox["y", "th"]}], TraditionalForm]],ExpressionUUID->
  "c3c7136d-921a-4c9c-a745-c7bbb4a57978"],
 " matrix element of the irreducible representation \[Lambda] of ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]],ExpressionUUID->
  "58e13869-ea71-4146-a556-90101d21c7ef"],
 ", and similarly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalOmega]", 
     StyleBox["vw",
      FontSlant->"Italic"], "\[Lambda]"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"19a8c100-98fc-406b-855d-69c531bd5190"],
 " is the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"v", "\[VeryThinSpace]", 
    SuperscriptBox["w", "th"]}], TraditionalForm]],ExpressionUUID->
  "e79c3913-1f37-4776-bbcd-859c01604d3c"],
 " matrix element of the irreducible representation \[Lambda] of the group \
element ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "af0ae917-6f49-4af8-b75b-a8b834281872"],
 ". Note that matrix elements ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalPi]", 
     StyleBox["xy",
      FontSlant->"Italic"], "\[Lambda]"], "(", "S", ")"}], TraditionalForm]],
  ExpressionUUID->"fbf28e7f-8a32-4518-87d3-fdb1e9687344"],
 " are independent of Gelfand-Weyl subpattern ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["w", "\[Lambda]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "70fa1598-bacb-4948-9637-8888ad954203"],
 " (hence the corresponding Weyl tableaux) and similarly that matrix elements \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[CapitalOmega]", 
     StyleBox["vw",
      FontSlant->"Italic"], "\[Lambda]"], "(", "U", ")"}], TraditionalForm]],
  ExpressionUUID->"9d07c2db-3e33-44fd-8e41-498b32c3cbd5"],
 " are independent of Gelfand-Young subpattern ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["y", "\[Lambda]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "7a31eb05-5d51-4d1b-ae07-2004466b65b8"],
 " (hence the corresponding standard Young tableaux)."
}], "TechNoteText",
 CellID->145034866,ExpressionUUID->"4bc0d8e0-5caa-4f01-9d45-5e37e362d5c9"],

Cell[TextData[{
 "\tFurthermore, with shape \[Lambda] and Gelfand-Young subpattern ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["y", "\[Lambda]"], ")"}], 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "38225225-dc87-4880-94b6-8fa34fdf1aa9"],
 "fixed and varying ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["w", "\[Lambda]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "dd1a75a9-ccb6-47a7-a3ec-375533bcc512"],
 "over all possible Gelfand-Weyl subpatterns consistent with \[Lambda], one \
can get the Gelfand-Zetlin basis of an irreducible subspace of  ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "154a69f6-e5b2-4dd1-8ae3-1a5f76d15f7b"],
 " invariant under the actions of unitary group ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c362cb1f-5352-4810-911c-60333522d0ea"],
 ". Similarly, with shape \[Lambda] and Gelfand-Weyl subpattern ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["w", "\[Lambda]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "94782184-3edf-4113-b41e-14724b99111c"],
 " fixed and varying ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["y", "\[Lambda]"], ")"}], 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "0800e704-3ad0-4ea4-94eb-5ec29802bbd2"],
 "over all possible Gelfand-Young subpatterns consistent with \[Lambda], one \
obtains the Young-Yamanouchi basis of an irreducible subspace of  ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "dc8ec33a-49c4-4223-911a-2b550591a086"],
 " invariant under the actions of ",
 ButtonBox["symmetric group",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SymmetricGroup"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "565735c8-1069-4e39-9118-03e0b13b7955"],
 "."
}], "TechNoteText",
 CellID->131909032,ExpressionUUID->"323c6939-a5f7-4ae8-8262-2c3fbeb75018"],

Cell[TextData[{
 "\tThese imply that for every element ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Element]", 
    SubscriptBox["\[ScriptCapitalS]", "n"]}], TraditionalForm]],
  ExpressionUUID->"41525118-1ba5-48f6-aa79-5f74a7addf05"],
 "and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "\[Element]", 
    SubscriptBox["\[ScriptCapitalU]", "d"]}], TraditionalForm]],
  ExpressionUUID->"cae4c1b1-5f01-405d-92d5-119d8682ad54"],
 ","
}], "TechNoteText",
 CellID->1157901048,ExpressionUUID->"a7ebdd40-bcea-42a0-90cb-34750d379d1f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[CapitalPi]", "^"], "(", "S", ")"}], "\[DotEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Lambda]"], " ", 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["\[CapitalPi]", 
        RowBox[{
         SubscriptBox["N", "Y"], "\[Times]", 
         SubscriptBox["N", "Y"]}], "\[Lambda]"], "(", "S", ")"}], "\[CircleTimes]", 
      SubsuperscriptBox["I", 
       SubscriptBox["N", "W"], "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"6594d590-f9d0-4caa-8c08-262c43fdd428"],
 ",\[LineSeparator]and\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["\[CapitalOmega]", "^"], "(", "U", ")"}], "\[DotEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Lambda]"], " ", 
     RowBox[{
      SubsuperscriptBox["I", 
       SubscriptBox["N", "Y"], "\[Lambda]"], "\[CircleTimes]", 
      RowBox[{
       SubsuperscriptBox["\[CapitalOmega]", 
        RowBox[{
         SubscriptBox["N", "W"], "\[Times]", 
         SubscriptBox["N", "W"]}], "\[Lambda]"], "(", "U", ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"1b93b199-0fe1-46f6-91c1-7904cb3fa70b"],
 " ,\[LineSeparator]where ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["N", "Y", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "ecb0dbe5-eb56-4b9e-8407-67deb328dc1d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["N", "W", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "a84fbb2e-0c34-4677-8c42-90815159c1b7"],
 " are the number of standard Young tableaux and Weyl tableaux, respectively, \
for shape \[Lambda] (in the above equations, superscript \[Lambda] has been \
omitted as it is clear from context).\t Moreover, If an operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "8f8a9919-0bb1-4b2a-bbf4-fc71c0743c66"],
 " is invariant under the symmetric group, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      OverscriptBox["H", "^"], ",", 
      RowBox[{
       OverscriptBox["\[CapitalPi]", "^"], "(", "S", ")"}]}], "]"}], "=", 
    "0"}], TraditionalForm]],ExpressionUUID->
  "d48e144d-b2ca-45ae-b1d0-a9617cbae76b"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "\[Element]", 
    SubscriptBox["\[ScriptCapitalS]", "n"]}], TraditionalForm]],
  ExpressionUUID->"6079cd41-8194-47bf-acbb-a33dd4365ac3"],
 ", then the matrix representation of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "293b9edc-1a00-4302-a43d-e08d2c43e9df"],
 " is given by"
}], "TechNoteText",
 CellID->2067454344,ExpressionUUID->"99719998-9b14-43e1-abcd-aeaabe865b9e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "\[DotEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Lambda]"], " ", 
     RowBox[{
      SubsuperscriptBox["I", 
       SubscriptBox["N", "Y"], "\[Lambda]"], "\[CircleTimes]", 
      SubsuperscriptBox["H", 
       RowBox[{
        SubscriptBox["N", "W"], "\[Times]", 
        SubscriptBox["N", "W"]}], "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"66f17b9d-3323-4675-b55b-37ab92e8729e"],
 " ."
}], "TechNoteText",
 CellID->162236752,ExpressionUUID->"f4f70e62-db80-4589-9d9b-57c4fd31ac80"],

Cell[TextData[{
 "Similarly, If an operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "f1426b77-c865-4683-86a3-fd9dd3752133"],
 " is invariant under the unitary group, i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      OverscriptBox["H", "^"], ",", 
      RowBox[{
       OverscriptBox["\[CapitalOmega]", "^"], "(", "U", ")"}]}], "]"}], "=", 
    "0"}], TraditionalForm]],ExpressionUUID->
  "4d9cad03-c75b-4677-bebd-3874b8f0afe8"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "\[Element]", 
    SubscriptBox["\[ScriptCapitalU]", "d"]}], TraditionalForm]],
  ExpressionUUID->"c0b0792e-d833-41fa-b729-5bb7b69b4dad"],
 ", then the matrix representation of ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "0944deea-f2b4-427c-b8d8-d8950da02b59"],
 " is given by"
}], "TechNoteText",
 CellID->825692376,ExpressionUUID->"77acc476-1fe5-4e4f-bb22-16c92a1bb8a2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "\[DotEqual]", 
    RowBox[{
     UnderscriptBox["\[CirclePlus]", "\[Lambda]"], " ", 
     RowBox[{
      SubsuperscriptBox["H", 
       RowBox[{
        SubscriptBox["N", "W"], "\[Times]", 
        SubscriptBox["N", "W"]}], "\[Lambda]"], "\[CircleTimes]", 
      SubsuperscriptBox["I", 
       SubscriptBox["N", "Y"], "\[Lambda]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"a86f4938-5ad6-49e2-956e-0489b2b7e21f"],
 " ."
}], "TechNoteText",
 CellID->1990463067,ExpressionUUID->"e5721b51-8e7b-42ea-ac9b-8d6dc78c8c02"],

Cell[TextData[{
