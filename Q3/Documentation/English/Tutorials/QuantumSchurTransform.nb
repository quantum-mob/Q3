    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "8dd217d4-699a-4635-b110-e80df1565aa2"],
 " compatible with shape \[Lambda], i.e.,"
}], "TechNoteText",
 CellID->681885491,ExpressionUUID->"7b4ed148-08a9-4347-afc7-1b457f78cb07"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       RowBox[{"\[Lambda]", "          "}]},
      {
       SubscriptBox[
        RowBox[{"(", 
         SubscriptBox["w", "\[Lambda]"], ")"}], 
        RowBox[{"d", "-", "1"}]]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "c6f069a0-f71d-4375-a6b7-945ea70373a7"],
 " "
