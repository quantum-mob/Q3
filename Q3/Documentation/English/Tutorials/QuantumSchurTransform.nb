Cell[TextData[{
 "\tThe crucial point here is that Wigner operator ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    OverscriptBox["T", "^"], "j", 
    RowBox[{"\[Lambda]", ",", "\[Mu]"}]], TraditionalForm]],ExpressionUUID->
  "e442c53f-f53c-4943-8408-e9694053468d"],
 " is an irreducible tensor operator transforming as the computational basis. \
That is,"
}], "TechNoteText",
 CellID->1084189614,ExpressionUUID->"9e2ac34f-ebbd-4559-b291-1445d9f49db7"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox[
       OverscriptBox["\[CapitalOmega]", "^"], "\[Lambda]"], "(", "U", ")"}], 
     SubsuperscriptBox[
      OverscriptBox["T", "^"], "j", 
      RowBox[{"\[Lambda]", ",", "\[Mu]"}]], 
     RowBox[{
      SubsuperscriptBox[
       OverscriptBox["\[CapitalOmega]", "^"], "\[Mu]", "\[Dagger]"], "(", "U",
       ")"}]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "i"], 
     RowBox[{
      SubsuperscriptBox[
       OverscriptBox["T", "^"], "i", 
       RowBox[{"\[Lambda]", ",", "\[Mu]"}]], 
      SubscriptBox["U", 
       StyleBox["ij",
        FontSlant->"Italic"]]}]}]}], TraditionalForm]],ExpressionUUID->
  "e0fa59eb-ba64-4707-9642-6fc4054043b5"],
 " ."
}], "DisplayMath",
 CellID->1362930851,ExpressionUUID->"4a63ff31-e371-434c-a59a-af7bafda4f7e"],

Cell[TextData[{
 "This would allow one to apply the ",
 StyleBox["Wigner-Eckart theorem",
  FontSlant->"Italic"],
 " to evaluate the matrix elements. In this particular case, the \
Wigner-Eckart theorem states that"
}], "TechNoteText",
 CellID->1143799776,ExpressionUUID->"4779e3eb-3a3e-4974-a193-b2427423b8f9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{
             RowBox[{"\[Lambda]", "   "}]}, {
             RowBox[{"(", 
               SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"]},
      "Bra"], 
     SubsuperscriptBox[
      OverscriptBox["T", "^"], "j", 
      RowBox[{"\[Lambda]", ",", "\[Mu]"}]], 
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Mu]", "  "}]}, {
              RowBox[{"(", 
                SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], 
        TraditionalForm]},
      "Ket"]}], "=", 
    RowBox[{
     SuperscriptBox["T", 
      RowBox[{"\[Lambda]", ",", "\[Mu]"}]], 
     TemplateBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{
             RowBox[{"\[Lambda]", "   "}]}, {
             RowBox[{"(", 
               SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
       RowBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Mu]", "  "}]}, {
               RowBox[{"(", 
                 SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], ",", 
         "j"}]},
      "BraKet"]}]}], TraditionalForm]],ExpressionUUID->
  "265c0cb3-772f-47e1-acd5-421165a95303"],
 ","
}], "TechNoteText",
 CellID->196819860,ExpressionUUID->"858c8b5c-8315-4ee6-b879-bb3f8d4f23ea"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["T", 
    RowBox[{"\[Lambda]", ",", "\[Mu]"}]], TraditionalForm]],ExpressionUUID->
  "d053bbb6-2648-4287-abfa-04a9ea8b9e2d"],
 " is a constant independent of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["w", "\[Lambda]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "fa81f547-1d23-4bf3-a9f5-e653fac6419c"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["v", "\[Mu]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "12329972-0a15-465e-b693-a9e64ea0bf29"],
 ", and ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "2d782c57-be19-42d5-b1aa-16cbbcb5fe98"],
 ". However, we do not apply the Wigner-Eckart theorem directly to ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    OverscriptBox["T", "^"], "j", 
    RowBox[{"\[Lambda]", ",", "\[Mu]"}]], TraditionalForm]],ExpressionUUID->
  "4dd75e46-3147-4547-98da-6caa6b95c75e"],
 "."
}], "TechNoteText",
 CellID->257587647,ExpressionUUID->"f316e9bb-44ed-429d-bbfe-6d17c37c6f6b"],

Cell[TextData[{
 "\tInstead, using the fact that ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    OverscriptBox["T", "^"], "j", 
    RowBox[{"\[Lambda]", ",", "\[Mu]"}]], TraditionalForm]],ExpressionUUID->
  "fc165d9e-ec7e-4232-a5f5-a33d37d4a67a"],
 " is an irreducible tensor operator transforming as the computational basis, \
we decompose Wigner operator ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    OverscriptBox["T", "^"], "j", 
    RowBox[{"\[Lambda]", ",", "\[Mu]"}]], TraditionalForm]],ExpressionUUID->
  "cf2f5dc3-cb0f-4fa9-a7b2-2682107fb768"],
 " on ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "86e67594-091c-4afa-97d3-5acc10c3561d"],
 " into another Wigner operators ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    OverscriptBox["T", "^"], "j", 
    RowBox[{"\[Lambda]", ",", 
     RowBox[{"\[Mu]", ";", 
      RowBox[{"\[Lambda]", "'"}]}], ",", 
     RowBox[{"\[Mu]", "'"}]}]], TraditionalForm]],ExpressionUUID->
  "aa12b2d8-f2c8-49df-b819-cbd6a8fd5a2d"],
 " on ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   RowBox[{
    StyleBox["d",
     FontSlant->"Italic"], "-", "1"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d3d0db67-154a-49a8-a5bd-7e4ad9b17533"],
 ". More specifically, let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox[
     OverscriptBox["T", "^"], "j", 
     RowBox[{"\[Lambda]", ",", 
      RowBox[{"\[Mu]", ";", 
       RowBox[{"\[Lambda]", "'"}]}], ",", 
      RowBox[{"\[Mu]", "'"}]}]], ":", 
    RowBox[{
     SuperscriptBox["\[ScriptCapitalW]", 
      RowBox[{"\[Mu]", "'"}]], "\[RightTeeArrow]", 
     SuperscriptBox["\[ScriptCapitalW]", 
      RowBox[{"\[Lambda]", "'"}]]}]}], TraditionalForm]],ExpressionUUID->
  "c21f82b7-e8cb-4720-b8f4-3288ad92f036"],
 ", where it is implied that shapes ",
 Cell[BoxData[
  SuperscriptBox["\[Lambda]", "\[Prime]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0173b5a7-de25-487d-ae17-2e9a91b92a57"],
 " and ",
 Cell[BoxData[
  SuperscriptBox["\[Mu]", "\[Prime]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f99b88c1-6927-4ae3-88e8-0358e52bda6e"],
 " are compatible with \[Lambda] and \[Mu], respectively. Define"
}], "TechNoteText",
 CellID->38412572,ExpressionUUID->"842a567b-ec02-45e2-8f51-d8fbdbc8be77"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox[
      OverscriptBox["T", "^"], "j", 
      RowBox[{"\[Lambda]", ",", 
       RowBox[{"\[Mu]", ";", 
        RowBox[{"\[Lambda]", "'"}]}], ",", 
       RowBox[{"\[Mu]", "'"}]}]], 
     TemplateBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{
             RowBox[{"\[Mu]", "  "}]}, {
             RowBox[{"\[Mu]", "'"}]}, {
             RowBox[{"(", 
               SubscriptBox["v", 
                RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], "d"]},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox[
       OverscriptBox["P", "^"], 
       RowBox[{"\[Lambda]", "'"}]], 
      RowBox[{"{", 
       RowBox[{
        TemplateBox[{
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Mu]", "  "}]}, {
                RowBox[{"\[Mu]", "'"}]}, {
                RowBox[{"(", 
                  SubscriptBox["v", 
                   RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], "d"]},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{"j"},
         "Ket"]}], "}"}]}], "=", 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"(", 
        SubscriptBox["w", 
         RowBox[{"\[Lambda]", "'"}]], ")"}]], 
      RowBox[{
       TemplateBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{"\[Lambda]", "  "}]}, {
               RowBox[{"\[Lambda]", "'"}]}, {
               RowBox[{"(", 
                 SubscriptBox["w", 
                  RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], "d"]},
        "Ket"], 
       TemplateBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{
                 RowBox[{"\[Lambda]", "'"}], "   "}]}, {
               RowBox[{"(", 
                 SubscriptBox["w", 
                  RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], 
          RowBox[{"d", "-", "1"}]], 
         RowBox[{
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 RowBox[{
                   RowBox[{"\[Mu]", "'"}], "  "}]}, {
                 RowBox[{"(", 
                   SubscriptBox["v", 
                    RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], 
            RowBox[{"d", "-", "1"}]], ",", "j"}]},
        "BraKet"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "8a57526c-211a-4c22-b1a4-71b68f821989"]
}], "TechNoteText",
 CellID->1809040035,ExpressionUUID->"4c6e7fa8-eb09-44c7-820b-2db2cd9d035d"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
