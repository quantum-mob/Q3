Cell[CellGroupData[{

Cell["Quantum Schur Transform", "TechNoteSection",
 CellID->1930427601,ExpressionUUID->"fcb18bb4-4344-4955-8696-7460c70302b9"],

Cell[TextData[{
 "The ",
 StyleBox["quantum Schur transform",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["U", "^"], "Sch"], TraditionalForm]],ExpressionUUID->
  "e7f37b45-b2df-47c3-934e-f4e7b50b80fd"],
 " on the tensor-product space ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[ScriptCapitalV]", "d", 
    RowBox[{"\[CircleTimes]", "n"}]], TraditionalForm]],ExpressionUUID->
  "b4a2c0c0-c25e-4c44-a936-18cd0347d47c"],
 " maps the standard tensor-product basis to the Schur basis,"
}], "TechNoteText",
 CellID->1287789268,ExpressionUUID->"8b304ccd-a608-45f5-b3a7-a77608517448"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox["j", "1"], ",", 
        SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["j", "n"]}]},
     "Ket"], "=", 
    RowBox[{
     SubscriptBox[
      OverscriptBox["U", "^"], "Sch"], 
     TemplateBox[{
       RowBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "   "}]}, {
                RowBox[{"(", 
                  SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
          TraditionalForm], ",", 
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "c8eb31eb-2f17-4d8e-9651-48eadbeb0e48"],
 "."
}], "DisplayMath",
 CellID->640601304,ExpressionUUID->"58170f5e-0e04-42e8-bc9b-2c5ac871746f"],

Cell["\<\
Of course, the quantum Schur transform is implied in the relation between the \
two bases,\
\>", "TechNoteText",
 CellID->233884618,ExpressionUUID->"2f6376ff-b0cb-47a2-a952-95c2362e66e7"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox["j", "1"], ",", 
        SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
        SubscriptBox["j", "n"]}]},
     "Ket"], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "\[Lambda]"], 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"(", 
        SubscriptBox["y", "\[Lambda]"], ")"}]], 
      RowBox[{
       SubscriptBox["\[Sum]", 
        RowBox[{"(", 
         SubscriptBox["w", "\[Lambda]"], ")"}]], 
       RowBox[{
        TemplateBox[{
          RowBox[{
            FormBox[
             SubscriptBox[
              RowBox[{"(", 
                GridBox[{{
                   RowBox[{"\[Lambda]", "   "}]}, {
                   RowBox[{"(", 
                    SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
             TraditionalForm], ",", 
            FormBox[
             SubscriptBox[
              RowBox[{"(", 
                GridBox[{{
                   RowBox[{"\[Lambda]", "    "}]}, {
                   RowBox[{"(", 
                    SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
             TraditionalForm]}]},
         "Ket"], 
        TemplateBox[{
          RowBox[{
            FormBox[
             SubscriptBox[
              RowBox[{"(", 
                GridBox[{{
                   RowBox[{"\[Lambda]", "   "}]}, {
                   RowBox[{"(", 
                    SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
             TraditionalForm], ",", 
            FormBox[
             SubscriptBox[
              RowBox[{"(", 
                GridBox[{{
                   RowBox[{"\[Lambda]", "    "}]}, {
                   RowBox[{"(", 
                    SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
             TraditionalForm]}], 
          RowBox[{
            SubscriptBox["j", "1"], ",", 
            SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
            SubscriptBox["j", "n"]}]},
         "BraKet"]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "85a7e7c8-c816-408e-9b57-520977bea244"],
 ","
}], "DisplayMath",
 CellID->1993039808,ExpressionUUID->"f2c2dc43-2149-480f-bdec-e09a2247c4b9"],

Cell["\<\
and evaluating the quantum Schur transform is reduced to calculating the \
expansion coefficients\
\>", "TechNoteText",
 CellID->1012275302,ExpressionUUID->"ed80ac9f-23a2-4619-ada6-20859b285bc0"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
