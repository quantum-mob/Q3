Cell[TextData[{
 "\tConventionally, two shapes \[Lambda] and \[Lambda]' are regarded equal \
when they are different only by trailing zeros. For example, ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5dcf4d0e-a72e-4eec-ada2-870a9399cb6a"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"\[Lambda]", "'"}], "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1", ",", "0", ",", "0"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "31fda81c-1d4e-489b-b7f0-1996763d079f"],
 " are said to be equal."
}], "TechNoteText",
 CellID->204731514,ExpressionUUID->"35fb7ecd-aef6-4c71-98ee-1ced3b1f78b5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Young Tableaux", "Subsection",
 CellID->280164077,ExpressionUUID->"003bbe2a-df52-4ff7-a852-0692861fcdd2"],

Cell[TextData[{
 "A ",
 StyleBox[ButtonBox["Young tableau",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungTableaux"],
  FontSlant->"Italic"],
 " of shape \[Lambda] is an array of numbers filling the boxes of the Young \
diagram of shape \[Lambda] (or replacing the dots of the Ferrers diagram). \
For example, here is a Young tableau of shape ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "dce697e0-a6af-4bba-a489-1c8547410c3f"],
 ":"
}], "TechNoteText",
 CellID->833426319,ExpressionUUID->"c3f5a1f5-a694-46af-a92a-9de4a466703f"],

