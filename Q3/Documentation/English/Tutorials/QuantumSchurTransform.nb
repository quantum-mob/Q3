Cell[TextData[{
 "\tConversely, to convert a Gelfand pattern ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", "m", ")"}], "d"], TraditionalForm]],ExpressionUUID->
  "1a393dab-7829-4929-9dc1-3a5c458f2c62"],
 " to the corresponding Weyl tableau ",
 StyleBox["W",
  FontSlant->"Italic"],
 ", we follow the above procedure in the reversed way. Here, it is convenient \
to note that the number of boxes with number ",
 StyleBox["i",
  FontSlant->"Italic"],
 " in the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["j", "th"], TraditionalForm]],ExpressionUUID->
  "adbd83c8-85ce-4c90-971e-2505fbdf0156"],
 " row (from the top) of ",
 StyleBox["W",
  FontSlant->"Italic"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", 
     RowBox[{"i", ",", "j"}]], "-", 
    SubscriptBox["m", 
     RowBox[{
      RowBox[{"i", "-", "1"}], ",", "j"}]]}], TraditionalForm]],
  ExpressionUUID->"c7e1d662-71a7-4f67-900b-3480262849c8"],
 " (assuming ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", 
     RowBox[{"i", ",", "j"}]], "=", "0"}], TraditionalForm]],ExpressionUUID->
  "b6269694-1fef-46e2-acac-53510e3ee0b2"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "<", "j"}], TraditionalForm]],ExpressionUUID->
  "22e09592-76c7-4f2b-91f4-25b1f790cb6c"],
 "). For example, consider the following Gelfand pattern,"
}], "TechNoteText",
 CellID->1856039132,ExpressionUUID->"264279d2-b1c2-4946-991b-addd81b650eb"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   TagBox[
    RowBox[{"(", 
     TagBox[GridBox[{
        {"2", "1", "0"},
        {"2", "1", ""},
        {"2", "", ""}
       },
       AutoDelete->False,
       GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
       
       GridBoxSpacings->{"Columns" -> {{0.5}}, "Rows" -> {{0}}}],
      "Grid"], ")"}],
    DisplayForm], "."}]}]], "TechNoteText",
