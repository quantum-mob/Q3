Cell["A standard Young tableau is a special case of Weyl tableaux.", \
"TechNoteText",
 CellID->1852114950,ExpressionUUID->"41b56cc3-d54e-4a54-a042-1536bbacaa93"],

Cell["\<\
\tAs we will see later, a Weyl tableau physically represents the occupation \
of quantum states corresponding to the entries of the tableau.\
\>", "TechNoteText",
 CellID->4584806,ExpressionUUID->"2b943511-9a70-45f4-9e88-f69954198aa7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gelfand Patterns", "Subsection",
 CellID->1685151388,ExpressionUUID->"7ad1e81e-5229-4b88-a68f-1f0054a99ed2"],

Cell["\<\
Standard Young tableaux and Weyl tableaux can be conveniently represented in \
a unified manner in terms of Gelfand patterns. Gelfand patterns also offer \
more programmable conveniences. Therefore, Q3 prefers Gelfand patterns to \
standard Young tableaux or Weyl tableaux when it deals with the Schur basis \
and transform.\
\>", "TechNoteText",
 CellID->2060545956,ExpressionUUID->"4642bfe3-77ff-4217-a397-ca4da421c8d6"],

Cell[TextData[{
 "\tA ",
 StyleBox[ButtonBox["Gelfand pattern",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/GelfandPattern"],
  FontSlant->"Italic"],
 " (also known as Gelfand-Zetlin or Gelfand-Tsetlin pattern) of dimension ",
 StyleBox["d",
  FontSlant->"Italic"],
 " is an upper-left triangular arrangement of non-negative integers (or \
equivalent letters) of ",
 StyleBox["d",
  FontSlant->"Italic"],
 " rows:"
}], "TechNoteText",
 CellID->1671460309,ExpressionUUID->"52c46fa3-da0b-447a-9995-2d860e6274ee"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{"(", GridBox[{
     {
      SubscriptBox["m", 
       RowBox[{"d", "\[InvisibleSpace]", "1"}]], 
      SubscriptBox["m", 
       RowBox[{"d", "\[InvisibleSpace]", "2"}]], "\[Ellipsis]", 
      SubscriptBox["m", 
       RowBox[{"d", "\[VeryThinSpace]", "d"}]]},
     {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[AscendingEllipsis]", 
      " "},
     {
      SubscriptBox["m", 
       RowBox[{"2", "\[InvisibleSpace]", "1"}]], 
      SubscriptBox["m", 
       RowBox[{"2", "\[InvisibleSpace]", "2"}]], " ", " "},
     {
      SubscriptBox["m", 
       RowBox[{"1", "\[InvisibleSpace]", "1"}]], " ", " ", " "}
    }], ")"}], 
  TraditionalForm]],ExpressionUUID->"adeaf2dc-9871-456a-9eca-73230a27f21f"]], \
"DisplayMath",
 CellID->164780836,ExpressionUUID->"9ca94130-8960-432d-867a-0608e81c7799"],

Cell["The entries satisfy the so-called \"betweenness\" condition:", \
"TechNoteText",
 CellID->78492163,ExpressionUUID->"d2c243c4-b7a4-4df3-93ee-956dec1c6e0c"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     StyleBox["ij",
      FontSlant->"Italic"]], "\[GreaterEqual]", 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     RowBox[{
      RowBox[{"i", "-", "1"}], ",", 
      StyleBox["j",
       FontSlant->"Italic"]}]], "\[GreaterEqual]", 
    SubscriptBox[
     StyleBox["m",
      FontSlant->"Italic"], 
     RowBox[{
      StyleBox["i",
       FontSlant->"Italic"], ",", 
      RowBox[{
       StyleBox["j",
        FontSlant->"Italic"], "+", "1"}]}]]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1417bc06-1a89-46c5-9190-35c659a9f6b3"],
 "."
}], "DisplayMath",
 CellID->725612651,ExpressionUUID->"1996dad8-8c42-4a27-a674-b420676d8db1"],

Cell[TextData[{
 "\tIn a Gelfand pattern, each row ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "m", "]"}], "k"], "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["m", "k1"], ",", 
      SubscriptBox["m", "k2"], ",", "\[Ellipsis]", ",", 
      SubscriptBox["m", 
       StyleBox["kk",
        FontSlant->"Italic"]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "5bd0a0ad-f3a6-4bb8-b303-c3e0b7b2c5fe"],
 " represents a partition of integer ",
 Cell[BoxData[
  StyleBox[
   SubscriptBox["n", "k"],
   FontSlant->"Italic"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ef76f78b-fc94-4ef9-a504-6c5e64f578f0"],
 " satisfying ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["n", "k"], "\[LessEqual]", 
    SubscriptBox["n", 
     RowBox[{"k", "+", "1"}]]}], TraditionalForm]],ExpressionUUID->
  "75a2d973-e7c4-4236-80b3-5518c89a3d8d"],
 "for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"k", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", "n"}], 
   TraditionalForm]],ExpressionUUID->"d0f1da48-bc7c-4a72-851e-ec52e156b986"],
 ". Therefore, a Gelfand pattern may be regarded as a sequence of partitions \
of non-increasing integers from top to bottom. This endows Gelfand pattern \
with a recursive structure. Accordingly, in many cases, it is useful to refer \
to a Gelfand pattern by the top row and the rest subpattern. For example, if \
the above entire Gelfand pattern is referred to by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", "m", ")"}], "d"], TraditionalForm]],ExpressionUUID->
  "9356cab2-42b5-4ac1-a604-765bb63ca3fa"],
 ","
}], "TechNoteText",
 CellID->855192669,ExpressionUUID->"9cd46142-0178-4e06-854e-30752aceb9fc"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", "m", ")"}], "d"], "=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["m", 
         RowBox[{"d", "\[InvisibleSpace]", "1"}]], 
        SubscriptBox["m", 
         RowBox[{"d", "\[InvisibleSpace]", "2"}]], "\[Ellipsis]", 
        SubscriptBox["m", 
         RowBox[{"d", "\[VeryThinSpace]", "d"}]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[AscendingEllipsis]", 
        " "},
       {
        SubscriptBox["m", 
         RowBox[{"2", "\[InvisibleSpace]", "1"}]], 
        SubscriptBox["m", 
         RowBox[{"2", "\[InvisibleSpace]", "2"}]], " ", " "},
       {
        SubscriptBox["m", 
         RowBox[{"1", "\[InvisibleSpace]", "1"}]], " ", " ", " "}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "7376ed8f-c886-47b8-afdc-8e3c71a8c47c"],
 ","
}], "DisplayMath",
 CellID->1579905879,ExpressionUUID->"4445a06b-e069-46ed-9597-75d7feddd2c5"],

Cell["then one can also write it as", "TechNoteText",
 CellID->195919333,ExpressionUUID->"68d20c2d-26f3-4601-b42a-00471507e0f9"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", "m", ")"}], "d"], "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{
         SubscriptBox[
          RowBox[{"[", "m", "]"}], "d"], "    "}]},
       {
        SubscriptBox[
         RowBox[{"(", "m", ")"}], 
         RowBox[{"d", "-", "1"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "7a081bb6-9769-4ee5-b97e-0c6cd37ee657"],
 ","
}], "DisplayMath",
 CellID->378820018,ExpressionUUID->"bbf28f7f-a6e3-4c5b-ad00-f473e1282557"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"[", "m", "]"}], "d"], "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["m", 
       StyleBox["d1",
        FontSlant->"Italic"]], ",", 
      SubscriptBox["m", 
       StyleBox["d2",
        FontSlant->"Italic"]], ",", "\[Ellipsis]", ",", 
      SubscriptBox["m", 
       StyleBox["dd",
        FontSlant->"Italic"]]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "bcfc49d5-56ab-4152-9860-e64874a7b9f6"],
 " refers to the top row and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", "m", ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "a6012420-d62e-447b-bfd9-54f4b154ce30"],
 "refers to the remaining subpattern of order ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "e82a125f-ef8b-4075-9c8d-a10413699f7c"],
 ", that is,"
}], "TechNoteText",
 CellID->1586125987,ExpressionUUID->"0359c8ee-4dcd-4253-b1bd-8fea21d3247b"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", "m", ")"}], 
     RowBox[{"d", "-", "1"}]], "=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["m", 
         RowBox[{
          RowBox[{"d", "-", "1"}], ",", "1"}]], 
        SubscriptBox["m", 
         RowBox[{
          RowBox[{"d", "-", "1"}], ",", "2"}]], "\[Ellipsis]", 
        SubscriptBox["m", 
         StyleBox[
          RowBox[{
           RowBox[{"d", "-", "1"}], ",", 
           RowBox[{"d", "-", "1"}]}],
          FontSlant->"Italic"]]},
       {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[AscendingEllipsis]", 
        " "},
       {
        SubscriptBox["m", "21"], 
        SubscriptBox["m", "22"], " ", " "},
       {
        SubscriptBox["m", "11"], " ", " ", " "}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "4d11e37f-6002-432a-be44-2d763ea8e07a"],
 " ."
}], "DisplayMath",
 CellID->1021805171,ExpressionUUID->"159ac18f-c840-470e-9b00-e4050f618270"],

Cell[TextData[{
 "When there is no risk of confusion, explicit specifications of dimension in \
subpatterns may be omitted. For example, let \[Lambda] be an integer \
partition and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["m", "\[Lambda]"], ")"}], 
    RowBox[{"d", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "95c085e8-9314-4a21-8427-1c3617db937e"],
 "be a subpattern of dimension ",
 Cell[BoxData[
  FormBox[
   RowBox[{"d", "-", "1"}], TraditionalForm]],ExpressionUUID->
  "7da8551d-4e42-4cb6-99bc-4e95ad684eb9"],
 " consistent with shape \[Lambda] to form a full Gelfand pattern. Then,"
}], "TechNoteText",
 CellID->2028142937,ExpressionUUID->"b87c57b9-c5d2-4f99-8dcd-f5be79a57cc3"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", GridBox[{
        {"\[Lambda]"},
        {
         RowBox[{"(", 
          SubscriptBox["m", "\[Lambda]"], ")"}]}
       }], ")"}], "d"], "=", 
    RowBox[{"(", GridBox[{
       {
        RowBox[{"\[Lambda]", "     "}]},
       {
        SubscriptBox[
         RowBox[{"(", 
          SubscriptBox["m", "\[Lambda]"], ")"}], 
         RowBox[{"d", "-", "1"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "97e9438a-7ace-4c37-b6ed-83181eec0ff9"],
 "."
}], "DisplayMath",
 CellID->980236580,ExpressionUUID->"d1ce24bb-65d6-4846-acd9-b676e05586e3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Correspondence between Gelfand Patterns and Weyl Tableaux", "Subsection",
 CellID->704430476,ExpressionUUID->"7ae147a4-f3a0-4f23-87da-b7309ca68df4"],

Cell[TextData[{
 "There is a ",
 StyleBox["one-to-one correspondence ",
  FontSlant->"Italic"],
 "between Gelfand patterns of dimension ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "39655d75-b9fa-49e7-a19e-86ac5304faef"],
 " and Weyl tableaux with entries of ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "0258ec98-be41-4d01-976e-f3d8762c3063"],
 " letters."
}], "TechNoteText",
 CellID->934671975,ExpressionUUID->"38a8305a-026e-4da1-85cc-171b19864a6c"],

Cell[TextData[{
 "\tTo convert a Weyl tableau to the corresponding Gelfand pattern, generate \
new Weyl tableaux, at each step, by removing boxes with the consecutive \
number starting from the dimension ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "991b67b6-91c8-443b-aa13-a981c66c414e"],
 ", and put their shapes into the rows of the Gelfand pattern. For example, \
consider the following Weyl tableau of dimension 3,"
}], "TechNoteText",
 CellID->804269743,ExpressionUUID->"73cabc88-2ea2-4bd5-966c-ed8932408b60"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   TagBox[GridBox[{
      {
       ItemBox["1",
        Frame->True,
        StripOnInput->False], 
       ItemBox["1",
        Frame->True,
        StripOnInput->False]},
      {
       ItemBox["2",
        Frame->True,
        StripOnInput->False], ""}
     },
     AutoDelete->False,
     GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
    "Grid"], " ", "."}]}]], "TechNoteText",
 CellID->1329302412,ExpressionUUID->"ec1113d5-0aaf-467d-8ba4-f38dc6ca8e5a"],

Cell["\<\
First, remove all boxes with entry 3, the dimension of the Weyl tableau. In \
this case, there is no such box and the generated Weyl tableau is the same as \
the original one,\
\>", "TechNoteText",
 CellID->1720719113,ExpressionUUID->"a0d71c80-c3ab-4460-b582-68c74f38d1e2"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   TagBox[GridBox[{
      {
       ItemBox["1",
        Frame->True,
        StripOnInput->False], 
       ItemBox["1",
        Frame->True,
        StripOnInput->False]},
      {
       ItemBox["2",
        Frame->True,
        StripOnInput->False], ""}
     },
     AutoDelete->False,
     GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
    "Grid"], " ", "."}]}]], "TechNoteText",
 CellID->1579806055,ExpressionUUID->"95ff4cca-6ff2-4f38-b323-e44a5689c210"],

Cell["\<\
Next, remove boxes with entry 2. The resulting Weyl tableau is given as \
follows,\
\>", "TechNoteText",
 CellID->1371560563,ExpressionUUID->"229a2b81-53a0-4eb4-9425-f695dbc36b30"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   TagBox[GridBox[{
      {
       ItemBox["1",
        Frame->True,
        StripOnInput->False], 
       ItemBox["1",
        Frame->True,
        StripOnInput->False]}
     },
     AutoDelete->False,
     GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
    "Grid"], " ", "."}]}]], "TechNoteText",
 CellID->1647959610,ExpressionUUID->"ec01598e-01c8-4f55-aa66-e65a9a2fd7d0"],

Cell["\<\
Finally, removing boxes with entry 1 leads to the empty tableau. Overall, we \
have obtained a sequence of Weyl tableaux,\
\>", "TechNoteText",
 CellID->1829353104,ExpressionUUID->"ca2483d5-a51c-4929-8373-a50298f53644"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   TagBox[GridBox[{
      {
       ItemBox["1",
        Frame->True,
        StripOnInput->False], 
       ItemBox["1",
        Frame->True,
        StripOnInput->False]},
      {
       ItemBox["2",
        Frame->True,
        StripOnInput->False], ""}
     },
     AutoDelete->False,
     GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
    "Grid"], "\[Rule]", 
   RowBox[{
    TagBox[GridBox[{
       {
        ItemBox["1",
         Frame->True,
         StripOnInput->False], 
        ItemBox["1",
         Frame->True,
         StripOnInput->False]},
       {
        ItemBox["2",
         Frame->True,
         StripOnInput->False], ""}
      },
      AutoDelete->False,
      GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
     
     "Grid"], "\[Rule]", 
    RowBox[{
     TagBox[GridBox[{
        {
         ItemBox["1",
          Frame->True,
          StripOnInput->False], 
         ItemBox["1",
          Frame->True,
          StripOnInput->False]}
       },
       AutoDelete->False,
       GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
      "Grid"], " ", "."}]}]}]}]], "TechNoteText",
 CellID->1236004617,ExpressionUUID->"20c4a056-82f1-4ee4-9bb8-f975a8b98bd0"],

Cell["\<\
These Weyl tableaux in the sequence have shapes (2,1,0), (2,1), (2), \
respectively, and collecting them in rows from top to bottom gives the \
desired Gelfand pattern,\
\>", "TechNoteText",
 CellID->1458748950,ExpressionUUID->"d0df13e1-3774-43c3-ba1a-03a9e5491f69"],

Cell[BoxData[
 RowBox[{"\t", 
  RowBox[{
   TagBox[
    RowBox[{"(", 
     TagBox[GridBox[{
        {"2", "1", "0"},
        {"2", "1", ""},
        {"2", "", ""}
       },
       AutoDelete->False,
       GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
       
       GridBoxSpacings->{"Columns" -> {{0.5}}, "Rows" -> {{0}}}],
      "Grid"], ")"}],
    DisplayForm], "."}]}]], "TechNoteText",
 CellID->424801075,ExpressionUUID->"2c1e5219-2fef-4bd8-823d-66fa5348fa5c"],

Cell["Here are more examples:", "TechNoteText",
 CellID->1881903222,ExpressionUUID->"e26f7fd0-dfd6-49ef-98e0-79a5c98f9cca"],

Cell[CellGroupData[{

