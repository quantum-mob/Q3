Cell[TextData[{
 "As already noted, the last two Young diagrams are of the same shape ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{"2", ",", "0"}], ")"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "945e1a90-3f19-40c0-b84c-d01ff11273ed"],
 " but now distinguished by different fillings of integers."
}], "TechNoteText",
 CellID->507198464,ExpressionUUID->"b0d30080-058e-45d0-b791-d67c407d6b37"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Constructing Schur Basis with Clebsch-Gordan Transform", "Subsection",
 CellID->1302073747,ExpressionUUID->"15f70114-8dff-495c-9f97-83005a6bada2"],

Cell[TextData[{
 "Finally, we discuss the ",
 StyleBox[ButtonBox["Bacon-Chuang-Harrow algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchurBasis"],
  FontSlant->"Italic"],
 " to construct the ",
 ButtonBox["Schur basis",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchurBasis"],
 " recursively by adding nodes one by one and each time using the \
Clebsch-Gordan transform."
}], "TechNoteText",
 CellID->1263710315,ExpressionUUID->"df746e3d-00f0-4326-97e4-ddf772d57528"],

Cell["\tStart with", "TechNoteText",
 CellID->767949700,ExpressionUUID->"7c48a66f-2721-48f2-a8c1-db69a511bc0f"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"i"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"j"},
      "Ket"]}], "\[Congruent]", 
    RowBox[{
     TemplateBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{"\[Mu]"}, {
             RowBox[{"(", 
               SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"j"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "7b79e48a-66ee-4914-91e6-21e98d369cd1"],
 ","
}], "DisplayMath",
 CellID->782453139,ExpressionUUID->"6c11e684-bfc6-46f3-9ca6-473b2cb4ee47"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{"1", ",", "0", ",", "0", ",", "\[Ellipsis]", ",", "0"}], ")"}]}],
    TraditionalForm]],ExpressionUUID->
  "2e4b538e-dbf4-4e47-a4c0-dacf77b56ef3"],
 ". Note that Gelfand-Weyl pattern ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", GridBox[{
       {"\[Mu]"},
       {
        RowBox[{"(", 
         SubscriptBox["v", "\[Mu]"], ")"}]}
      }], ")"}], "d"], TraditionalForm]],ExpressionUUID->
  "2e3895ef-f9db-4773-b7a5-a584868cbf7a"],
 " is sufficient to uniquely refer to basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"i"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "d45b418a-3901-4521-8028-8cc11d82b115"],
 ". Recall the example for ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d",
    FontSlant->"Italic"], "=", "3"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "81c36c5d-2863-4521-9f4d-561b66550b1c"],
 " seen above,"
}], "TechNoteText",
 CellID->2040407671,ExpressionUUID->"8595c944-5703-42d3-91d5-f996ef6d74c7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"gg", "=", 
   RowBox[{"GelfandPatterns", "[", 
    RowBox[{
     RowBox[{"{", "1", "}"}], ",", 
     RowBox[{"$d", "=", "3"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Thread", "[", 
  RowBox[{
   RowBox[{"Ket", "@@@", 
    RowBox[{"First", "/@", 
     RowBox[{"YoungTableau", "/@", "gg"}]}]}], "<->", "gg"}], "]"}]}], "Input",\

 CellLabel->"In[101]:=",
 CellID->2133134294,ExpressionUUID->"e16f24ce-eeed-4051-89a9-02291d864799"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    TemplateBox[{"1"},
     "Ket"], "\[TwoWayRule]", 
    InterpretationBox[
     TagBox[
      RowBox[{"(", 
       TagBox[GridBox[{
          {"1", "0", "0"},
          {"1", "0", ""},
          {"1", "", ""}
         },
         AutoDelete->False,
         GridBoxItemSize->{
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
         GridBoxSpacings->{"Columns" -> {{0.5}}, "Rows" -> {{0}}}],
        "Grid"], ")"}],
      DisplayForm],
     QuantumMob`Q3`GelfandPattern[{{1, 0, 0}, {1, 0}, {1}}]]}], ",", 
   RowBox[{
    TemplateBox[{"2"},
     "Ket"], "\[TwoWayRule]", 
    InterpretationBox[
     TagBox[
      RowBox[{"(", 
       TagBox[GridBox[{
          {"1", "0", "0"},
          {"1", "0", ""},
          {"0", "", ""}
         },
         AutoDelete->False,
         GridBoxItemSize->{
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
         GridBoxSpacings->{"Columns" -> {{0.5}}, "Rows" -> {{0}}}],
        "Grid"], ")"}],
      DisplayForm],
     QuantumMob`Q3`GelfandPattern[{{1, 0, 0}, {1, 0}, {0}}]]}], ",", 
   RowBox[{
    TemplateBox[{"3"},
     "Ket"], "\[TwoWayRule]", 
    InterpretationBox[
     TagBox[
      RowBox[{"(", 
       TagBox[GridBox[{
          {"1", "0", "0"},
          {"0", "0", ""},
          {"0", "", ""}
         },
         AutoDelete->False,
         GridBoxItemSize->{
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}},
         GridBoxSpacings->{"Columns" -> {{0.5}}, "Rows" -> {{0}}}],
        "Grid"], ")"}],
      DisplayForm],
     QuantumMob`Q3`GelfandPattern[{{1, 0, 0}, {0, 0}, {0}}]]}]}], 
  "}"}]], "Output",
 CellLabel->"Out[102]=",
 CellID->69728820,ExpressionUUID->"799e7468-1f1b-485f-a5f8-ed2ca16a94b0"]
}, Open  ]],

Cell[TextData[{
 "However, for a reason to get clear soon, we add a redundant parameter, ",
 Cell[BoxData[
  RowBox[{"\[Mu]", "=", 
   RowBox[{
    RowBox[{"(", "1", ")"}], "\[Congruent]", 
    RowBox[{"(", 
     RowBox[{"1", ",", "0", ",", "\[Ellipsis]", ",", "0"}], ")"}]}]}]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6285ca23-df6d-425e-8eee-0912f9b0b3bc"],
 " so that"
}], "TechNoteText",
 CellID->6819342,ExpressionUUID->"c1a1e4e1-d715-4fa1-8024-bf2c2e143103"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"i"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"j"},
      "Ket"]}], "\[Congruent]", 
    RowBox[{
     TemplateBox[{
       RowBox[{
         RowBox[{"(", "1", ")"}], ",", 
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{"\[Mu]"}, {
               RowBox[{"(", 
                 SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"]}]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"j"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "727a47ee-b5ef-4dac-8c68-59bc251f672e"],
 "."
}], "DisplayMath",
 CellID->2065727940,ExpressionUUID->"447ad66d-c9ba-4a69-9381-86114d51abd3"],

Cell["\tNow, the Clebsch-Gordan transform gives decomposition", "TechNoteText",
 CellID->864206507,ExpressionUUID->"a4efa9a6-e4d6-4df4-b7fa-e60cee22f038"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      TemplateBox[{"i"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"j"},
       "Ket"]}], "\[Congruent]", 
     RowBox[{
      TemplateBox[{
        RowBox[{
          RowBox[{"(", "1", ")"}], ",", 
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{"\[Mu]"}, {
                RowBox[{"(", 
                  SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"]}]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"j"},
       "Ket"]}]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "\[Lambda]"], 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"(", 
        SubscriptBox["w", "\[Lambda]"], ")"}]], 
      RowBox[{
       TemplateBox[{
         RowBox[{
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{"\[Lambda]"}, {"1"}}], ")"}], "2"], ",", 
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{"\[Lambda]"}, {
                 RowBox[{"(", 
                   SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"]}]},
        "Ket"], 
       TemplateBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{"\[Lambda]"}, {
               RowBox[{"(", 
                 SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
         RowBox[{
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{"\[Mu]"}, {
                 RowBox[{"(", 
                   SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], ",", 
           "j"}]},
        "BraKet"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "4b299c09-63de-4777-baa0-1e25b731d8d8"],
 "."
}], "DisplayMath",
 CellID->670361110,ExpressionUUID->"4220e90f-c9d5-4b89-a5b3-bad5c547a079"],

Cell[TextData[{
 "Here, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{"\[Lambda]"}, {"1"}}], ")"}], "2"], ",", 
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{"\[Lambda]"}, {
             RowBox[{"(", 
               SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "fd3508d3-c307-41f9-b501-4a52bcff4bcb"],
 " is a Gelfand-Zetlin basis vector with additional parameter ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", GridBox[{
       {"\[Lambda]"},
       {"1"}
      }], ")"}], "2"], TraditionalForm]],ExpressionUUID->
  "d8153894-5151-4dbf-8acd-144e2487de2b"],
 " registered here just to store the history. Also recall that at this stage, \
the only \[Lambda] allowed by the selection rule of Clebsch-Gordan \
coefficient ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox[
      RowBox[{"(", 
        GridBox[{{"\[Lambda]"}, {
           RowBox[{"(", 
             SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
     RowBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{"\[Mu]"}, {
             RowBox[{"(", 
               SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], ",", "j"}]},
    
    "BraKet"], TraditionalForm]],ExpressionUUID->
  "e5ec5f7d-5367-4076-8146-72a4c1c35ccb"],
 " are ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"2", ",", "0"}], ")"}], "\[Congruent]", 
    RowBox[{"(", 
     RowBox[{"2", ",", "0", ",", "0", ",", "\[Ellipsis]", ",", "0"}], 
     ")"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "71df01f8-4912-4bf3-ac4b-2e37841c93d8"],
 " and ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", ",", "1"}], ")"}], "\[Congruent]", 
    RowBox[{"(", 
     RowBox[{"1", ",", "1", ",", "0", ",", "\[Ellipsis]", ",", "0"}], 
     ")"}]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "060e0d22-d206-43c6-8469-9b657916e508"],
 "."
}], "TechNoteText",
 CellID->299964845,ExpressionUUID->"f4da2e9c-a472-42d8-a20d-9b7933b86236"],

Cell["\<\
\tWe have just finished one iterative step for the quantum Schur transform. \
We repeat the same procedure with the tensor-product state \
\>", "TechNoteText",
 CellID->12599637,ExpressionUUID->"e413a2c1-0f12-4537-9b39-bba99d00269f"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{"\[Lambda]"}, {"1"}}], ")"}], "2"], ",", 
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{"\[Lambda]"}, {
              RowBox[{"(", 
                SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"]}]},
     "Ket"], "\[CircleTimes]", 
    TemplateBox[{"j"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "19476c32-8fb7-497c-a92a-053472b604ff"],
 "."
}], "DisplayMath",
 CellID->904832840,ExpressionUUID->"33ed1770-0b47-498f-9898-d4bb1cdb7cc6"],

Cell[TextData[{
 "Suppose that we have finished ",
 Cell[BoxData[
  RowBox[{
   StyleBox["k",
    FontSlant->"Italic"], "-", "1"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "12e87945-a0d0-4940-8174-ffac87a5b1f6"],
 " such procedures so that we have obtained basis vectors"
}], "TechNoteText",
 CellID->960036546,ExpressionUUID->"ad13c97b-0edb-4b49-8fbe-fec4bb79c788"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{
             SubscriptBox["\[Lambda]", "k"]}, {"\[VerticalEllipsis]"}, {
             SubscriptBox["\[Lambda]", "2"]}, {
             RowBox[{
               SubscriptBox["\[Lambda]", "1"], " "}]}}], ")"}], "k"], ",", 
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{
             SubscriptBox["\[Lambda]", "k"]}, {
             RowBox[{"(", 
               SubscriptBox[
                SubscriptBox["w", "\[Lambda]"], "k"], ")"}]}}], ")"}], "d"]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "ed709831-9dad-46c0-a3da-f5f43671c12e"],
 " ,  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "1"], "=", 
    RowBox[{"(", "1", ")"}]}], TraditionalForm]],ExpressionUUID->
  "a5e4d644-aaec-4018-9c4b-c7a826d2de22"],
 ",  ",
 Cell[BoxData[
