   RowBox[{"d", "=", "3"}], TraditionalForm]],ExpressionUUID->
  "5c9bb353-c695-4dbd-8d08-d59f79dada57"],
 ", as a example, there are eight Weyl tableaux of shape ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"(", 
     RowBox[{"2", ",", "1"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "0eeb1f70-0bdf-4490-bc9c-c3f3c98ad338"],
