Cell[TextData[{
 "is a valid Gelfand pattern. This operator is called a ",
 StyleBox["Wigner operator",
  FontSlant->"Italic"],
 " and, physically, attaches a node to the preexisting Gelfand-Zetlin state \
to get another Gelfand-Zetlin state. In terms of the Wigner operator, the \
Clebsch-Gordan transform reads as"
}], "TechNoteText",
 CellID->1964145633,ExpressionUUID->"645000fb-511a-4712-97fa-b6969f7bfb1f"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Mu]", "  "}]}, {
              RowBox[{"(", 
                SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], 
        TraditionalForm]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"j"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Sum]", "\[Lambda]"], 
      RowBox[{
       SubsuperscriptBox[
        OverscriptBox["T", "^"], "j", 
        RowBox[{"\[Lambda]", ",", "\[Mu]"}]], 
       TemplateBox[{
         FormBox[
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Mu]", "  "}]}, {
                RowBox[{"(", 
                  SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], 
          TraditionalForm]},
        "Ket"]}]}], "=", 
     RowBox[{
      SubscriptBox["\[Sum]", "\[Lambda]"], 
      RowBox[{
       SubscriptBox["\[Sum]", 
        RowBox[{"(", 
         SubscriptBox["w", "\[Lambda]"], ")"}]], 
       RowBox[{
        TemplateBox[{
          FormBox[
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 RowBox[{"\[Lambda]", "   "}]}, {
                 RowBox[{"(", 
                   SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"], 
           TraditionalForm]},
         "Ket"], 
        TemplateBox[{
          SubscriptBox[
           RowBox[{"(", 
             GridBox[{{
                RowBox[{"\[Lambda]", "    "}]}, {
                RowBox[{"(", 
                  SubscriptBox["w", "\[Lambda]"], ")"}]}}], ")"}], "d"]},
         "Bra"], 
        SubsuperscriptBox[
         OverscriptBox["T", "^"], "j", 
         RowBox[{"\[Lambda]", ",", "\[Mu]"}]], 
        TemplateBox[{
          FormBox[
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 RowBox[{"\[Mu]", "  "}]}, {
                 RowBox[{"(", 
                   SubscriptBox["v", "\[Mu]"], ")"}]}}], ")"}], "d"], 
           TraditionalForm]},
         "Ket"]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "74c34a96-7111-4607-b6ac-ec2aa8cf2afe"],
 "."
}], "DisplayMath",
 CellID->2049232317,ExpressionUUID->"449b4a3e-db4b-428b-8499-a3ff80e6dcfe"],

Cell["\<\
This has reduced the Clebsch-Gordan transform to calculating the matrix \
elements \
\>", "TechNoteText",
