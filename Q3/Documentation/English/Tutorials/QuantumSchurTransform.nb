Cell[CellGroupData[{

Cell["Weyl Tableaux", "Subsection",
 CellID->988653157,ExpressionUUID->"daa45c38-dd0b-4c97-81c6-b53fecd73250"],

Cell[TextData[{
 "A Young tableau is called a ",
 StyleBox["semi-standard Young tableau",
  FontSlant->"Italic"],
 " or ",
 StyleBox[ButtonBox["Weyl tableau",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/WeylTableaux"],
  FontSlant->"Italic"],
 " if the entries weakly increase (i.e., non-decrease) along each row and \
strictly increase along each column. For example, these are all Weyl tableaux \
of shape ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e42f817d-2ca3-4bb0-91e6-9be318bac6aa"],
 ":"
}], "TechNoteText",
 CellID->2011127896,ExpressionUUID->"13728471-8485-4b0f-a749-46e8f497f4f4"],

