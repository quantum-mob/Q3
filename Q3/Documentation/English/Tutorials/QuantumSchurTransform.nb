 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[167]:=",
 CellID->1064806223,ExpressionUUID->"20148838-f1a4-4d27-bcc2-df95adabdd35"],

Cell["\<\
For example, partition (1) of 1 obviously gives the spin=1/2 representation \
of U(2):\
\>", "TechNoteMathCaption",
 CellID->113268700,ExpressionUUID->"7b718410-1e55-4b42-8701-cc8e89b04c11"],

