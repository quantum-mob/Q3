Cell["Now, consider the generators of subgroup U(2) of U(3):", \
"TechNoteMathCaption",
 CellID->2047993866,ExpressionUUID->"4c43872e-c23b-4b58-ad3d-547896766097"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Kx", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"A", "[", 
        RowBox[{"kk", ",", 
         RowBox[{"0", "->", "1"}]}], "]"}], "+", 
       RowBox[{"A", "[", 
        RowBox[{"kk", ",", 
         RowBox[{"1", "->", "0"}]}], "]"}]}], ")"}], "/", "2"}], "//", 
    "Total"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Ky", "=", 
   RowBox[{
    RowBox[{"I", "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"kk", ",", 
          RowBox[{"0", "->", "1"}]}], "]"}], "-", 
        RowBox[{"A", "[", 
         RowBox[{"kk", ",", 
          RowBox[{"1", "->", "0"}]}], "]"}]}], ")"}], "/", "2"}]}], "//", 
    "Total"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Kz", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"A", "[", 
        RowBox[{"kk", ",", 
         RowBox[{"0", "->", "0"}]}], "]"}], "-", 
       RowBox[{"A", "[", 
        RowBox[{"kk", ",", 
         RowBox[{"1", "->", "1"}]}], "]"}]}], ")"}], "/", "2"}], "//", 
    "Total"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"KK", "=", 
   RowBox[{
    RowBox[{"Kx", "**", "Kx"}], "+", 
    RowBox[{"Ky", "**", "Ky"}], "+", 
    RowBox[{"Kz", "**", "Kz"}]}]}], ";"}]}], "Input",
 CellLabel->"In[148]:=",
 CellID->1910111328,ExpressionUUID->"d58278e6-7038-4a65-8c17-d7a825bbada1"],

