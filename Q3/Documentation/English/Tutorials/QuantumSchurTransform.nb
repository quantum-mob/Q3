Cell[TextData[{
 "\tFrom the above examples, notice that the same Young diagram of shape ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1148e34d-3a05-4d7c-b491-fc6eb8fb5fb2"],
 " may result from both tensor products ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"2", ",", "0"}], ")"}], "\[CircleTimes]", 
   RowBox[{"(", "1", ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c7f1e9f6-e418-440e-9060-a4040455ef6e"],
 " and ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", ",", "1"}], ")"}], "\[CircleTimes]", 
   RowBox[{"(", "1", ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1ad8d736-00c6-421a-8834-7df5eb75bb18"],
 ". In order to label different irreducible representations arising from \
different tensor products, one thus need to keep track of the history of each \
of the resulting Young diagrams. This can be achieved most conveniently in \
terms of standard Young tableaux, or technically, in terms of the \
corresponding ",
 ButtonBox["Gelfand-Young patterns",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/YoungPileUp"],
 ". "
}], "TechNoteText",
 CellID->912015927,ExpressionUUID->"686332ff-1744-460f-b4fa-cebf3f72d420"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"in", "=", 
  RowBox[{"YoungTableau", "@", 
   RowBox[{"{", 
    RowBox[{"{", "1", "}"}], "}"}]}]}]], "Input",
 CellLabel->"In[98]:=",
 CellID->770163747,ExpressionUUID->"d899b3e4-0395-4bdf-84b4-3355ac5e896e"],

