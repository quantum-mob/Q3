     "Ket"], "\[LeftRightArrow]", "2"}], TraditionalForm]],ExpressionUUID->
  "17d25988-f1fc-4d04-b7ea-a17e4ddca680"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"2"},
     "Ket"], "\[LeftRightArrow]", "3"}], TraditionalForm]],ExpressionUUID->
  "4f139a1e-b8e4-4d8a-8d0b-621cf989c136"],
 ")."
}], "TechNoteText",
 CellID->1856596181,ExpressionUUID->"15b56cc1-9e9f-42ba-a369-8eb98f136204"],

