Cell[TextData[{
 "\tIf a Gelfand pattern corresponds to a stand Young tableau, then we call \
it a ",
 StyleBox["Gelfand-Young pattern",
  FontSlant->"Italic"],
 ". Otherwise, it is called a ",
 StyleBox["Gelfand-Weyl pattern",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->33598967,ExpressionUUID->"28ddac5a-ca84-4d4e-8933-9da2cc962597"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Irreducible Representations of Symmetric and Unitary Groups", \
"TechNoteSection",
 CellID->936189082,ExpressionUUID->"cae1e8f1-70e5-42f0-afb5-4c26f303dee0"],

Cell["\<\
Irreducible representations of the symmetric and unitary groups have many \
parallels, with Weyl tableaux for the unitary group playing the role of \
standard Young tableaux for the symmetric group. A difference is the allowed \
Young diagrams (shapes).\
\>", "TechNoteText",
 CellID->568094772,ExpressionUUID->"ca7bd6cb-b64f-4a7f-92ef-fd6aaf22aaa3"],

Cell[CellGroupData[{

Cell["Irreducible Representations of the Symmetric Group", "Subsection",
 CellID->335665526,ExpressionUUID->"35d561d6-1b99-47d7-9d90-6ffdd6603f4b"],

Cell[TextData[{
 "It has long been known that the number of inequivalent irreducible \
representations of ",
 ButtonBox["symmetric group",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/SymmetricGroup"],
 " ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalS]", 
   StyleBox["n",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ac25e5d4-b776-4a6d-af0b-8894ca853b65"],
 " is equal to the number of partitions of ",
 StyleBox["n",
  FontSlant->"Italic"],
 ". It is thus natural to label (or refer to) the irreducible representations \
of ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalS]", 
   StyleBox["n",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f182fb73-43f8-49bc-bc7d-abcf29842a29"],
 " with partitions \[Lambda] of ",
 StyleBox["n",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1046008454,ExpressionUUID->"ce3e748c-1be4-4191-927c-d0493db70132"],

Cell[TextData[{
 "\tFor a partition \[Lambda], let ",
 Cell[BoxData[
  SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bc86ae3a-386f-4485-8d33-3259939a04b4"],
 " be the representation space of irreducible representation \[Lambda] of ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalS]", 
   StyleBox["n",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "afda9c06-af65-433e-a9a5-537d799df4de"],
 ". The dimension of ",
 Cell[BoxData[
  SuperscriptBox["\[ScriptCapitalY]", "\[Lambda]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "789a4d2a-7704-4f57-8020-4cf5812e3665"],
 " equals the number of ",
 StyleBox["standard Young tableaux",
  FontSlant->"Italic"],
 " of shape \[Lambda]. It is thus natural to label the basis elements with \
standard Young tableaux ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "5160551d-ba45-4cb7-ba05-d2082c2f3b69"],
 " of shape \[Lambda],"
}], "TechNoteText",
 CellID->761931895,ExpressionUUID->"fffc313b-9858-4cdb-afcc-cac7636256c8"],

Cell[TextData[Cell[BoxData[
 RowBox[{"{", 
  TemplateBox[{
    FormBox[
     SubscriptBox["y", "\[Lambda]"], TraditionalForm]},
   "Ket"], 
  "}"}]],ExpressionUUID->"2b92ac90-26b6-4906-9661-b4f674922eb3"]], \
"DisplayMath",
 CellID->511122358,ExpressionUUID->"2eea3aa0-21d2-4c0a-8a2c-a647dcc292c5"],

Cell[TextData[{
 "This basis is called the ",
 StyleBox["Young-Yamanouchi basis",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->765050331,ExpressionUUID->"d84cb982-c95f-4625-975a-e3d26de75175"],

Cell[TextData[{
 "\tWe prefer Gelfand patterns to Young tableaux and replace standard Young \
tableau ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "5c8f4e93-624c-4264-b9ea-8f1eee1ffb3c"],
 " with the corresponding ",
 StyleBox[ButtonBox["Gelfand-Young pattern",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumSchurTransform#1685151388"],
  FontSlant->"Italic"],
 " so that"
}], "TechNoteText",
 CellID->185864679,ExpressionUUID->"3dca2335-8ca2-4905-9937-f93a10c895d8"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"{", 
   RowBox[{
    TemplateBox[{
      FormBox[
       RowBox[{"(", 
         GridBox[{{
            RowBox[{
              SubscriptBox[
               RowBox[{"[", "\[Lambda]", "]"}], "n"], "    "}]}, {
            SubscriptBox[
             RowBox[{"(", 
               SubscriptBox["y", "\[Lambda]"], ")"}], 
             RowBox[{"n", "-", "1"}]]}}], ")"}], TraditionalForm]},
     "Ket"], "=", 
    RowBox[{
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Lambda]", "   "}]}, {
              RowBox[{"(", 
                SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
        TraditionalForm]},
      "Ket"], "=", 
     TemplateBox[{
       FormBox[
        SubscriptBox["y", "\[Lambda]"], TraditionalForm]},
      "Ket"]}]}], "}"}]],ExpressionUUID->
  "87134e32-8a01-477d-a864-77063624c28b"],
 ","
}], "DisplayMath",
 CellID->1814477802,ExpressionUUID->"584c34ad-781e-4abc-bc6f-2e29cbf5696b"],

Cell[TextData[{
 "where the top row ",
 Cell[BoxData[Cell[TextData[Cell[BoxData[
   FormBox[
    SubscriptBox[
     RowBox[{"[", "\[Lambda]", "]"}], "n"], TraditionalForm]],ExpressionUUID->
   "4fba8b28-ec5f-4b3e-bd1d-4594e7accb2c"]],ExpressionUUID->
   "83f971c4-08f8-4e28-8c73-c9afd44c642b"]],ExpressionUUID->
  "27ab4c28-322a-44f4-ac24-b1ba594ab2cf"],
 " represents the same shape as \[Lambda] but possibly padded with trailing \
zeros to have length ",
 StyleBox["n,",
  FontSlant->"Italic"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["y", "\[Lambda]"], ")"}], 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "0481e2cc-0877-480c-a0f8-ff0eba166414"],
 " denotes the Gelfand subpattern consistent with standard Young tableau ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["y", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "46f32650-d7ad-46b7-9616-29fb92ea0fb7"],
 ". In the above specification of basis elements, shape \[Lambda] appears as \
a part (the top row) of the full Gelfand pattern. Since shape \[Lambda] \
refers to an irreducible representation and subpattern ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    RowBox[{"(", 
     SubscriptBox["y", "\[Lambda]"], ")"}], 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "d344132c-31a1-4f7c-853d-dd22e0557736"],
 " to basis elements in the irreducible representation, to make more explicit \
their roles, we sometimes split them to write as"
}], "TechNoteText",
 CellID->637519848,ExpressionUUID->"86f98fbf-1412-40df-a472-64e9c5686302"],

Cell[TextData[Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TemplateBox[{
     RowBox[{"\[Lambda]", ",", 
       SubscriptBox[
        RowBox[{"(", 
          SubscriptBox[
           StyleBox["y", FontSlant -> "Italic"], "\[Lambda]"], ")"}], 
        RowBox[{
          StyleBox["n", FontSlant -> "Italic"], "-", "1"}]]}]},
    "Ket"], ":=", 
   RowBox[{
    TemplateBox[{
      FormBox[
       RowBox[{"(", 
         GridBox[{{
            RowBox[{
              SubscriptBox[
               RowBox[{"[", "\[Lambda]", "]"}], "n"], "    "}]}, {
            SubscriptBox[
             RowBox[{"(", 
               SubscriptBox["y", "\[Lambda]"], ")"}], 
             RowBox[{"n", "-", "1"}]]}}], ")"}], TraditionalForm]},
     "Ket"], "=", 
    RowBox[{
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Lambda]", "   "}]}, {
              RowBox[{"(", 
                SubscriptBox["y", "\[Lambda]"], ")"}]}}], ")"}], "n"], 
        TraditionalForm]},
      "Ket"], "=", 
     TemplateBox[{
       FormBox[
        SubscriptBox["y", "\[Lambda]"], TraditionalForm]},
      "Ket"]}]}]}], 
  "}"}]],ExpressionUUID->"40759e9e-6477-472a-ba73-2a1ff01a5711"]], \
"DisplayMath",
 CellID->1665016374,ExpressionUUID->"c195163f-f9dd-408e-b9ef-8a399f39cf57"],

Cell["when there is no risk of confusion.", "TechNoteText",
 CellID->372615568,ExpressionUUID->"e22fdba1-9a17-4e69-8856-f4e5676ad2ac"],

Cell[TextData[{
 "\tFor example, there are three partitions of 3 and hence three irreducible \
representations of ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalS]", "3"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5577e2dd-6a5b-4337-b077-6af5f70793ce"],
 "."
}], "TechNoteText",
 CellID->1357844502,ExpressionUUID->"0bc86db9-6257-4476-83b5-eae84ea8e92e"],

