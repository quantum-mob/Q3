Cell[TextData[{
 "In this example, one can see that Weyl tableaux physically represent the \
occupation of computational basis states corresponding to the letters filling \
the Weyl tableaux (in this example, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], "\[LeftRightArrow]", "1"}], TraditionalForm]],ExpressionUUID->
  "cca5abd5-6e63-4315-8bd0-a03fc6806fd3"],
