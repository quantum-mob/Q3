        TraditionalForm]}], 
     RowBox[{
       SubscriptBox["j", "1"], ",", 
       SubscriptBox["j", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["j", "n"]}]},
    "BraKet"], TraditionalForm]],ExpressionUUID->
  "f10e669a-606a-43f9-a7b2-5f975529ae68"],
 "."
}], "DisplayMath",
 CellID->1250321802,ExpressionUUID->"d509eaf0-9ff4-4139-b971-be5e9cff1a50"],

Cell["\<\
The Bacon-Chuang-Harrow algorithm constructs the Schur basis by iteratively \
adding nodes one by one and each time using the Clebsch-Gordan transform \
rather than directly calculating the above expansion coefficients.\
\>", "TechNoteText",
 CellID->1992013882,ExpressionUUID->"4c5cb612-ddab-47a1-a828-83ec54c124e5"],

Cell[CellGroupData[{

Cell["Clebsch-Gordan Transform", "Subsection",
 CellID->240153234,ExpressionUUID->"26b1733e-79b8-450f-a96c-0c99aaaeda85"],

Cell[TextData[{
 "A tensor product of two irreducible representations of a group is also a \
representation of the same group but is not irreducible any longer. In the \
case of unitary group ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "09948c7a-044c-437d-8d24-1e5040e78cc4"],
 ", it implies that"
}], "TechNoteText",
 CellID->741833493,ExpressionUUID->"98983ec0-7128-4787-9291-97ec36c9b1ab"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalW]", "\[Mu]"], "\[CircleTimes]", 
     SuperscriptBox["\[ScriptCapitalW]", "\[Nu]"]}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
     RowBox[{
      SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"], 
      SubsuperscriptBox["c", "\[Lambda]", "\[Mu]\[Nu]"]}]}]}], 
   TraditionalForm]],ExpressionUUID->"c7db1044-9f58-4e1a-ac5e-9de9d731cda7"],
 "."
}], "DisplayMath",
 CellID->1138985092,ExpressionUUID->"92cffd78-9012-4140-b456-60cd5ddb333c"],

Cell[TextData[{
 "where coefficient ",
 Cell[BoxData[
  SubsuperscriptBox[
   StyleBox["c",
    FontSlant->"Italic"], "\[Lambda]", "\[Mu]\[Nu]"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2b620be4-b9f2-4931-b298-176aaf93b8df"],
 " is the Littlewood-Richardson multiplicity factor."
}], "TechNoteText",
 CellID->609711758,ExpressionUUID->"281e644c-5c0a-4f54-bb4f-dd3f08ee9e93"],

Cell[TextData[{
 "\tFor the Bacon-Chuang-Harrow algorithm, of primary concern is the case \
where ",
 Cell[BoxData[
  RowBox[{"\[Nu]", "=", 
   RowBox[{"(", "1", ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6c046fa2-55a4-49ec-896c-2aa6179a950a"],
 " since in this case, the multiplicity factor is unity,"
}], "TechNoteText",
 CellID->1182152676,ExpressionUUID->"a2199158-62bb-4e5a-b7d1-3f6108eabd46"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalW]", "\[Mu]"], "\[CircleTimes]", 
     SuperscriptBox["\[ScriptCapitalW]", 
      RowBox[{"(", "1", ")"}]]}], "=", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
     SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}], TraditionalForm]],
  ExpressionUUID->"12911314-6040-45ad-aa47-2cf006a6d135"],
 "."
}], "DisplayMath",
 CellID->394643618,ExpressionUUID->"2fd4dc20-d40c-44e9-be2c-134e9460ff21"],

Cell[TextData[{
 "Note that for ",
 Cell[BoxData[
  SuperscriptBox["\[ScriptCapitalW]", 
   RowBox[{"(", "1", ")"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "88578c65-77df-4eec-870f-90a00865e4b8"],
 ", the Gelfand-Zetlin basis is identical to the computational basis"
}], "TechNoteText",
 CellID->1245521133,ExpressionUUID->"563abbab-d376-4dd6-b7b4-91c42f4e4bc2"],

Cell[TextData[{
 "\t ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      TemplateBox[{"j"},
       "Ket"], ":", "1"}], ",", "2", ",", "\[Ellipsis]", ",", "d"}], "}"}], 
   TraditionalForm]],ExpressionUUID->"6ce3b9f2-eb50-40fc-a4e0-eea18bd8d4cb"],
 "."
}], "TechNoteText",
 CellID->1518477897,ExpressionUUID->"02d4fef4-2475-4e9c-9c17-54ff4321c59c"],

Cell[TextData[{
 "As an example, consider the case of ",
 Cell[BoxData[
  RowBox[{
   StyleBox["d",
    FontSlant->"Italic"], "=", "3"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
