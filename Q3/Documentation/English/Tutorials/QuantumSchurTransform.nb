Cell[CellGroupData[{

Cell["Note 1", "Subsection",
 CellID->892325562,ExpressionUUID->"070ff3ff-cab5-409e-8c4d-b0c1e04898fc"],

Cell["\<\
Here, it is illustrated that partitions of different integers may lead to \
equivalent irreducible representations of the unitary group. Sometimes (for \
example, within the formulation of branching rules), two representations \
associated with distinct Young diagrams are regarded inequivalent.\
\>", "TechNoteText",
 CellID->1274643347,ExpressionUUID->"b1a02a8a-b605-498b-8912-cafa2f0baeb1"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[166]:=",
 CellID->1212062878,ExpressionUUID->"ace34273-875c-4e29-b001-95f5c28bef44"],

