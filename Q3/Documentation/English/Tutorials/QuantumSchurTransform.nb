   RowBox[{"d", "-", "2"}], TraditionalForm]],ExpressionUUID->
  "18b57a76-7139-4f46-b51c-0fa8f5879d8c"],
 " compatible with the given shape \[Lambda]'. Applying the Wigner-Eckart \
theorem,"
}], "TechNoteText",
 CellID->251111273,ExpressionUUID->"123fd665-4026-4919-acfd-02bedec7eb82"],

Cell[TextData[Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    TemplateBox[{
      SubscriptBox[
       RowBox[{"(", 
         GridBox[{{
            RowBox[{
              RowBox[{"\[Lambda]", "'"}], "    "}]}, {
            RowBox[{"(", 
              SubscriptBox["w", 
               RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], 
       RowBox[{"d", "-", "1"}]]},
     "Bra"], 
    SubsuperscriptBox[
     OverscriptBox["T", "^"], "j", 
     RowBox[{"\[Lambda]", ",", 
      RowBox[{"\[Mu]", ";", 
       RowBox[{"\[Lambda]", "'"}]}], ",", 
