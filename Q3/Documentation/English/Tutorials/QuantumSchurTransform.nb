Cell[CellGroupData[{

Cell["Canonical Tower of Subgroups of the Unitary Group", "Subsection",
 CellID->1045056921,ExpressionUUID->"3dbba52a-87c4-4bb7-8709-169333aef7fd"],

Cell["The branching rule for the unitary group is give by", "TechNoteText",
 CellID->291066379,ExpressionUUID->"a7238401-9219-4927-9349-53e2a4f50f5d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[ScriptCapitalW]", "d", "\[Lambda]"], 
     SubscriptBox["\[DownArrow]", 
      SubscriptBox["\[ScriptCapitalU]", 
       RowBox[{"d", "-", "1"}]]]}], "\[TildeEqual]", 
    RowBox[{
     SubscriptBox["\[CirclePlus]", 
      RowBox[{"\[Mu]", "\[PrecedesSlantEqual]", "\[Lambda]"}]], 
     SubsuperscriptBox["\[ScriptCapitalW]", 
      RowBox[{"d", "-", "1"}], "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "62a29d96-1dab-4238-b72f-767d3749fab3"]
}], "TechNoteText",
 CellID->2132367634,ExpressionUUID->"c5e5017f-1164-41a8-8549-85e5849ba9bb"],

Cell["This is demonstrated here.", "TechNoteText",
 CellID->1720428434,ExpressionUUID->"0748274c-a8a3-48d0-bd77-82541e77778b"],

