 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"j", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"d", "-", "1"}]}], TraditionalForm]],ExpressionUUID->
  "e553cec9-51e4-437b-8bf0-95158c9d6eb9"],
 " form an irreducible tensor operator transforming like ",
 Cell[BoxData[
