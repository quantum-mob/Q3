  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1390955787,ExpressionUUID->"95715527-683f-4ab4-af2f-383af75a5874"],

Cell[TextData[{
 "\tIn summary, the Clebsch-Gordan transform on ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c48b032b-df53-4429-a1fe-306eb3e39516"],
 " can be calculated recursively from the Clebsch-Gordan transform on ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   RowBox[{
    StyleBox["d",
     FontSlant->"Italic"], "-", "1"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aaf55081-d289-408f-90df-358af1a61338"],
 " as follows:"
}], "TechNoteText",
 CellID->1366985369,ExpressionUUID->"72414435-36d0-4339-990d-ae58cb9c3cb0"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       FormBox[
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Mu]", "  "}]}, {
              RowBox[{"\[Mu]", "'"}]}, {
              RowBox[{"(", 
                SubscriptBox["v", 
                 RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], "d"], 
        TraditionalForm]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"j"},
      "Ket"]}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "\[Lambda]"], 
     RowBox[{
      SubscriptBox["\[Sum]", 
       RowBox[{"\[Lambda]", "'"}]], 
      RowBox[{
       SuperscriptBox["T", 
        RowBox[{"\[Lambda]", ",", 
         RowBox[{"\[Mu]", ";", 
          RowBox[{"\[Lambda]", "'"}]}], ",", 
         RowBox[{"\[Mu]", "'"}]}]], 
       RowBox[{
        SubscriptBox["\[Sum]", 
         RowBox[{"(", 
          SubscriptBox["w", 
           RowBox[{"\[Lambda]", "'"}]], ")"}]], 
        RowBox[{
         TemplateBox[{
           FormBox[
            SubscriptBox[
             RowBox[{"(", 
               GridBox[{{
                  RowBox[{"\[Lambda]", "  "}]}, {
                  RowBox[{"\[Lambda]", "'"}]}, {
                  RowBox[{"(", 
                    SubscriptBox["w", 
                    RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], "d"], 
            TraditionalForm]},
          "Ket"], 
         TemplateBox[{
           SubscriptBox[
            RowBox[{"(", 
              GridBox[{{
                 RowBox[{
                   RowBox[{"\[Lambda]", "'"}], "    "}]}, {
                 RowBox[{"(", 
                   SubscriptBox["w", 
                    RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], 
            RowBox[{"d", "-", "1"}]], 
           RowBox[{
             SubscriptBox[
              RowBox[{"(", 
                GridBox[{{
                   RowBox[{
                    RowBox[{"\[Mu]", "'"}], "    "}]}, {
                   RowBox[{"(", 
                    SubscriptBox["v", 
                    RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], 
              RowBox[{"d", "-", "1"}]], ",", "j"}]},
          "BraKet"]}]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "44c3d115-507d-4226-8a3e-62974f5a41ee"],
 "."
}], "DisplayMath",
 CellID->1174924088,ExpressionUUID->"a7864e57-beb8-4cea-a8b6-90a95e8a148a"],

Cell[TextData[{
 "Both summations ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sum]", "\[Lambda]"], TraditionalForm]],ExpressionUUID->
  "d18250e7-0909-4b51-bad2-cbf279ae1087"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sum]", 
    RowBox[{"\[Lambda]", "'"}]], TraditionalForm]],ExpressionUUID->
  "f34f9203-83f1-477d-8ca7-f49fdbc7db9f"],
 " over \[Lambda] and \[Lambda]' are strongly restricted due to the selection \
rule (see below) imposed by the Clebsch-Gordan coefficients on ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0a57d291-d71e-46d8-94a1-e6d405f9e940"],
 " and ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   RowBox[{
    StyleBox["d",
     FontSlant->"Italic"], "-", "1"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "22842471-e401-4112-8290-5e2718e92870"],
 ", respectively. Equivalently, the ",
 ButtonBox["Clebsch-Gordan coefficients",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ClebschGordanX"],
 " on ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   StyleBox["d",
    FontSlant->"Italic"]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f03064b6-e10d-4914-a7ae-061c1f00bc3c"],
 " are related to those on ",
 Cell[BoxData[
  SubscriptBox["\[ScriptCapitalU]", 
   RowBox[{
    StyleBox["d",
     FontSlant->"Italic"], "-", "1"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "93245667-37db-4aa5-956e-fe6ecdefab0e"],
 " as follows:"
}], "TechNoteText",
 CellID->306074656,ExpressionUUID->"130e96e4-cdf1-4f59-a9fc-f6d8921477a6"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox[
       RowBox[{"(", 
         GridBox[{{
            RowBox[{"\[Lambda]", "  "}]}, {
            RowBox[{"\[Lambda]", "'"}]}, {
            RowBox[{"(", 
              SubscriptBox["w", 
               RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], "d"], 
      RowBox[{
        SubscriptBox[
         RowBox[{"(", 
           GridBox[{{
              RowBox[{"\[Mu]", "  "}]}, {
              RowBox[{"\[Mu]", "'"}]}, {
              RowBox[{"(", 
                SubscriptBox["v", 
                 RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], "d"], ",", "j"}]},
     "BraKet"], "=", 
    RowBox[{
     SuperscriptBox["T", 
      RowBox[{"\[Lambda]", ",", 
       RowBox[{"\[Mu]", ";", 
        RowBox[{"\[Lambda]", "'"}]}], ",", 
       RowBox[{"\[Mu]", "'"}]}]], 
     TemplateBox[{
       SubscriptBox[
        RowBox[{"(", 
          GridBox[{{
             RowBox[{
               RowBox[{"\[Lambda]", "'"}], "    "}]}, {
             RowBox[{"(", 
               SubscriptBox["w", 
                RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], 
        RowBox[{"d", "-", "1"}]], 
       RowBox[{
         SubscriptBox[
          RowBox[{"(", 
            GridBox[{{
               RowBox[{
                 RowBox[{"\[Mu]", "'"}], "    "}]}, {
               RowBox[{"(", 
                 SubscriptBox["v", 
                  RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], 
          RowBox[{"d", "-", "1"}]], ",", "j"}]},
      "BraKet"]}]}], TraditionalForm]],ExpressionUUID->
  "3c66c54d-e395-4914-9132-94299cbcf0ee"],
 "."
}], "DisplayMath",
 CellID->1330509738,ExpressionUUID->"d1fb11ae-45db-488b-a4a9-4ae0e8bd8353"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Selection Rules", "Subsection",
 CellID->594399900,ExpressionUUID->"684d635e-32ea-4e0c-b8be-c4269232249f"],

Cell["The Clebsch-Gordan coefficient", "TechNoteText",
 CellID->1914133451,ExpressionUUID->"0b5b57b8-4498-452a-8206-e596f02d2e5c"],

Cell[TextData[Cell[BoxData[
 FormBox[
  TemplateBox[{
    SubscriptBox[
     RowBox[{"(", 
       GridBox[{{
          RowBox[{"\[Lambda]", "  "}]}, {
          RowBox[{"\[Lambda]", "'"}]}, {
          RowBox[{"(", 
            SubscriptBox["w", 
             RowBox[{"\[Lambda]", "'"}]], ")"}]}}], ")"}], "d"], 
    RowBox[{
      SubscriptBox[
       RowBox[{"(", 
         GridBox[{{
            RowBox[{"\[Mu]", "  "}]}, {
            RowBox[{"\[Mu]", "'"}]}, {
            RowBox[{"(", 
              SubscriptBox["v", 
               RowBox[{"\[Mu]", "'"}]], ")"}]}}], ")"}], "d"], ",", "j"}]},
   "BraKet"], 
  TraditionalForm]],ExpressionUUID->"63a6e242-3a6e-465c-899b-d0114245f7a4"]], \
"DisplayMath",
 CellID->1342140963,ExpressionUUID->"e67ce646-64ae-4d4f-ac58-6a69c57c784c"],

Cell[TextData[{
 "vanishes unless pairs ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{"\[Lambda]", ",", "\[Mu]"}], ")"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0fcd12bb-c948-42f4-8902-5406a7765b78"],
 " and ",
 Cell[BoxData[
  RowBox[{"(", 
   RowBox[{
    RowBox[{"\[Lambda]", "'"}], ",", 
    RowBox[{"\[Mu]", "'"}]}], ")"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "65130974-ac2c-4606-ad1d-ea2c5d3a03aa"],
 " satisfy the following selection rules."
}], "TechNoteText",
 CellID->746800379,ExpressionUUID->"7f4ab5df-2d5b-4844-af17-055af34fbf68"],

Cell[TextData[{
 "\tThe Young diagram of shape \[Lambda] must be attainable by attaching a \
single box to the Young diagram of shape \[Mu]. Similarly, the Young diagram \
of shape ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "'"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6e2778a1-6c41-42f1-839a-24ccc93f255d"],
 " must be attainable from the Young diagram of shape ",
 Cell[BoxData[
  RowBox[{"\[Mu]", "'"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1d4e43e5-cd40-463d-aed6-2d42e9ca8d59"],
 " by attaching a single box."
}], "TechNoteText",
 CellID->529589213,ExpressionUUID->"4c321387-d8d8-4302-b4f8-1e92d7fffdcc"],

Cell[TextData[{
 "\tThese rules follow from the Schur-Weyl duality, which in this case \
concerns the decomposition of the tensor-product representation of the form, ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ScriptCapitalW]", "\[Mu]"], "\[CircleTimes]", 
     SubscriptBox["\[ScriptCapitalV]", 
      StyleBox["d",
       FontSlant->"Italic"]]}], "\[Congruent]", 
    RowBox[{
     SuperscriptBox["\[ScriptCapitalW]", "\[Mu]"], "\[CircleTimes]", 
     SuperscriptBox["\[ScriptCapitalW]", 
      RowBox[{"(", "1", ")"}]]}]}], "=", 
   RowBox[{
    SubscriptBox["\[CirclePlus]", "\[Lambda]"], 
    SuperscriptBox["\[ScriptCapitalW]", "\[Lambda]"]}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e3a3d67e-dc11-49c0-8b4e-485b50e8db13"],
 ". Notice that as we recall from the above, the multiplicity factors are all \
unity."
}], "TechNoteText",
 CellID->1820165800,ExpressionUUID->"c6ba5722-2172-47d3-94dc-7a20cba9f8f6"],

Cell[TextData[{
 "\tFor example, attaching a box to the Young diagram of shape ",
 Cell[BoxData[
  RowBox[{"\[Mu]", "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "0"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "74cb68e9-a6b7-432e-9324-32c52acb4f29"],
 " may lead to a Young diagram of either shape ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", 
    RowBox[{"3", ",", "0"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2daff1c7-dcc1-45d5-b99a-7ba32a42eda6"],
 " or shape ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "19ba79e7-7603-4a3c-93b8-6b3fa0a2b765"],
 "."
}], "TechNoteText",
 CellID->1146608282,ExpressionUUID->"9602d688-4471-4d42-ba45-cddc54c88023"],

