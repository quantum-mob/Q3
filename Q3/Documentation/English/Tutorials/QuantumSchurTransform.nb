Cell[TextData[{
 "There are two standard Young tableaux of shape ",
 Cell[BoxData[
  RowBox[{"\[Lambda]", "=", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1"}], ")"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2f31c4f5-bdd5-46b0-a49a-2633791f35b2"],
 ", and thus the dimension of ",
 Cell[BoxData[
  SuperscriptBox["\[ScriptCapitalY]", 
   RowBox[{"(", 
    RowBox[{"2", ",", "1"}], ")"}]]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "259f2cf2-8b82-4353-82a0-8ba4af75fe31"],
 " is 2."
}], "TechNoteText",
 CellID->520786213,ExpressionUUID->"fb92ae13-8911-4870-8403-591e21708dcf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"yy", "=", 
  RowBox[{"YoungTableaux", "[", 
   RowBox[{"{", 
    RowBox[{"2", ",", "1"}], "}"}], "]"}]}]], "Input",
 CellLabel->"In[65]:=",
 CellID->1794727756,ExpressionUUID->"a5a28e12-8ba5-4ed2-b724-dd2125013308"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    TagBox[GridBox[{
       {
        ItemBox["1",
         Frame->True,
