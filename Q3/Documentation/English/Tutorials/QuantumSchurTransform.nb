     "Grid"],
    QuantumMob`Q3`YoungTableau[{{1, 3}, {2}}]]}], "}"}]], "Output",
 CellLabel->"Out[65]=",
 CellID->1398703178,ExpressionUUID->"a971910e-719a-404e-9ed1-b629357b3522"]
}, Open  ]],

Cell["\<\
Finding all standard Young tableaux of other shapes, one can list all the \
basis elements.\
\>", "TechNoteText",
 CellID->1697799623,ExpressionUUID->"91c6aad4-0bbd-4ccd-a003-045cbf22928f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Ket", "/@", 
  RowBox[{"List", "/@", 
   RowBox[{"YoungTableaux", "[", "$n", "]"}]}]}]], "Input",
 CellLabel->"In[66]:=",
 CellID->260503818,ExpressionUUID->"b903353a-d4b7-4fc9-a610-1744e06e1973"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TemplateBox[{
     InterpretationBox[
      TagBox[
       GridBox[{{
          ItemBox["1", Frame -> True, StripOnInput -> False], 
          ItemBox["2", Frame -> True, StripOnInput -> False], 
          ItemBox["3", Frame -> True, StripOnInput -> False]}}, AutoDelete -> 
        False, GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
      QuantumMob`Q3`YoungTableau[{{1, 2, 3}}]]},
    "Ket"], ",", 
   TemplateBox[{
     InterpretationBox[
      TagBox[
       GridBox[{{
          ItemBox["1", Frame -> True, StripOnInput -> False], 
          ItemBox["2", Frame -> True, StripOnInput -> False]}, {
          ItemBox["3", Frame -> True, StripOnInput -> False], ""}}, 
        AutoDelete -> False, 
        GridBoxItemSize -> {
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], "Grid"], 
      QuantumMob`Q3`YoungTableau[{{1, 2}, {3}}]]},
    "Ket"], ",", 
   TemplateBox[{
     InterpretationBox[
      TagBox[
       GridBox[{{
          ItemBox["1", Frame -> True, StripOnInput -> False], 
