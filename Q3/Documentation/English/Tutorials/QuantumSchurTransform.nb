     RowBox[{"2", ",", "1"}], ")"}]], TraditionalForm]],ExpressionUUID->
  "b340155a-9a7e-4c90-8ca6-2a7fa8aa6faa"],
 " is 8."
}], "TechNoteText",
 CellID->1828435740,ExpressionUUID->"4bbe3139-9c33-442c-9ee9-c8a7976cdf99"],

