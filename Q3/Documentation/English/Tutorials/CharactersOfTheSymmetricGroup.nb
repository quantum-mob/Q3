Cell[TextData[{
 "We have coded this test in the function ",
 StyleBox["CoxeterTest", "Input"],
 ", and of course any representation must satisfy this test (I yet have to \
adapt the description text accordingly). We might try e.g. ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "i"], "=", 
    RowBox[{"(", GridBox[{
       {"0", "1"},
       {"1", "0"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "19bf7b27-6550-40d6-9edf-c711fd3f342c"],
 ", all ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "447b9a13-48d3-42b8-a99e-e36a1ec17d85"],
 ":"
}], "TechNoteMathCaption",
 CellID->1635563167,ExpressionUUID->"159e5225-0396-4c7e-8c76-42f85c7a7c34"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CoxeterTest", "[", 
  RowBox[{"ConstantArray", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", "0"}], "}"}]}], "}"}], ",", "$n"}], "]"}], 
  "]"}]], "Input",
 CellLabel->"In[696]:=",
 CellID->1119466169,ExpressionUUID->"49b7af08-a674-4c6d-8a45-7371e672c3fe"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[696]=",
 CellID->1440058714,ExpressionUUID->"3e04d3ba-932d-44ad-95ff-f632eeb2881f"]
}, Open  ]],

Cell[TextData[{
 "So these matrices do indeed define a representation. Of course you notice \
right away that it is reducible, because the two lines with slope ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["45", "o"], TraditionalForm]],ExpressionUUID->
  "0a3aa2f7-8ce4-461f-b6ac-2feb9673aa45"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["135", "o"], TraditionalForm]],ExpressionUUID->
  "341016ed-c3f0-46e3-b4cb-63bfa50998b4"],
 " are invariant one dimensional subspaces."
}], "TechNoteMathCaption",
 CellID->1656491440,ExpressionUUID->"5dde7406-7b18-4cd1-8c00-0980f85764ad"],

Cell[TextData[{
 "If you have a representation defined this way, then the image of any \
permutation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "\[Element]", 
    SubscriptBox["S", "n"]}], TraditionalForm]],ExpressionUUID->
  "7a1f251d-ca10-4d5e-943e-b9e8b66fa51c"],
 " can be constructed as follows:"
}], "TechNoteMathCaption",
 CellID->673632372,ExpressionUUID->"7dd15359-23a1-43e4-a40f-4b70173ce05c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"trs", "=", 
  RowBox[{"PermutationTranspositions", "@", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "6", ",", "3", ",", "4", ",", "5"}], 
    "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"trs", "//", "PermutationForm"}]}], "Input",
 CellLabel->"In[697]:=",
 CellID->1461395787,ExpressionUUID->"563b7093-c058-4ab0-8997-3a936b6088fb"],

Cell[BoxData[
 RowBox[{"Transpositions", "[", 
  RowBox[{"{", 
   RowBox[{"3", ",", "4", ",", "5"}], "}"}], "]"}]], "Output",
 CellLabel->"Out[697]=",
 CellID->926104508,ExpressionUUID->"35e43433-4bf7-4755-97bd-df0c83019637"],

Cell[BoxData[
 TemplateBox[{
   SubscriptBox["\"\[Tau]\"", 
    TemplateBox[{"3", "4"}, "RowDefault"]], 
   SubscriptBox["\"\[Tau]\"", 
    TemplateBox[{"4", "5"}, "RowDefault"]], 
   SubscriptBox["\"\[Tau]\"", 
    TemplateBox[{"5", "6"}, "RowDefault"]]},
  "RowDefault"]], "Output",
 CellLabel->"Out[698]=",
 CellID->76992500,ExpressionUUID->"c0a73f90-1576-4e1d-a593-73cc18508b16"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Young\[CloseCurlyQuote]s Natural Representation", "TechNoteSection",
 CellID->123225772,ExpressionUUID->"46cdbc75-ee44-45f8-8643-98509481ef1c"],

Cell[TextData[{
 "Let\[CloseCurlyQuote]s take a look at the representation matrices. The nice \
thing about the natural representation is that its entries are integers. \
There are as many different irreducible representations of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "729efa94-5ace-4cea-8fc2-9bf7a1491455"],
 " as there are partitions of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "c0802b3e-cdca-4deb-8757-756201093df1"],
 "."
}], "TechNoteText",
 CellID->881314296,ExpressionUUID->"612913c7-5844-415d-95ec-2bbef423653f"],

Cell[BoxData[
 RowBox[{"Get", "[", "\"\<QuantumMob`Q3`YoungPlus`\>\"", "]"}]], "Input",
 CellLabel->"In[699]:=",
 CellID->2118046591,ExpressionUUID->"bbd87b44-9876-419a-b40e-ee23cc7ddc39"],

Cell[CellGroupData[{

Cell[BoxData[
