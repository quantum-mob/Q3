Cell[CellGroupData[{

Cell["Compound Characters", "TechNoteSection",
 CellID->519778699,ExpressionUUID->"e54a9163-99ed-4dc3-ba00-6cd5fc06a0ed"],

Cell[TextData[{
 "Compound characters of the symmetric group  are reducible characters \
constructed by inducing irreducible characters from its subgroups (like ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", 
    RowBox[{"n", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "b0a2d794-8bce-48f0-a45a-f12c309f0155"],
 ") to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "n"], TraditionalForm]],ExpressionUUID->
  "813d62dc-ec9c-4794-8a9d-cb16578a9a87"],
 ". These characters decompose into sums of irreducible characters and are \
instrumental in building the character table of the symmetric group via the \
Frobenius theorem."
}], "TechNoteText",
 CellID->1660992349,ExpressionUUID->"fbcc156a-002d-4324-8b32-c37abbc042df"],

Cell[TextData[{
 StyleBox["N.B.",
  FontWeight->"Bold"],
 " Since Q3 v4.2.4, the elements of ",
 StyleBox["CompoundYoungCharacters[shape]", "Input"],
 " and the columns of ",
 StyleBox["CompoundYoungCharacters[n]", "Input"],
 " are arranged in the reversed order of ",
 StyleBox["YoungShapes[n]", "Input"],
 "."
}], "TechNoteText",
 CellID->1275396547,ExpressionUUID->"cae4329d-985c-4c0e-a269-f43b6890688c"],

Cell[BoxData[
 RowBox[{"Get", "[", "\"\<QuantumMob`Q3`YoungPlus`\>\"", "]"}]], "Input",
