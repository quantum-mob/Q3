Cell["\<\
This tech note explains some computations involving characters and \
representations of the symmetric group. Although elementary in presentation \
style, it is not intended as textbook on representation theory.\
\>", "TechNoteText",
 CellID->1021212174,ExpressionUUID->"c7ec9e44-a4fd-40f1-8f33-1e79bf1e9de3"],

Cell["\<\
The demonstrations in this document requires an additional package:\
\>", "TechNoteMathCaption",
 CellID->836781195,ExpressionUUID->"049220c9-d34d-4156-8aec-084301440ba6"],

Cell[BoxData[
