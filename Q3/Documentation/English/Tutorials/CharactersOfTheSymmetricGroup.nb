Cell[CellGroupData[{

Cell["Character Scalar Product", "TechNoteSection",
 CellID->409762120,ExpressionUUID->"2ab9a89e-019d-4f2e-ba64-f21a38456f47"],

Cell["\<\
One of the troubles in representation theory is to keep track of which scalar \
product to use in which context. For characters, the inverses of the sizes of \
centralizers must be used as weights (notice that up to a factor of the group \
order, this coincides with the size of the conjugacy class):\
\>", "TechNoteText",
 CellID->2039378558,ExpressionUUID->"5ff5e2f3-562f-4a04-9855-3d7c4fbb9f60"],

Cell["|\[ScriptCapitalZ](g)| = |\[ScriptCapitalG]] / |\[ScriptCapitalC](g)| \
,", "DisplayMath",
 CellID->584172353,ExpressionUUID->"f94db186-e6d8-4a6c-b3db-c2d8be334119"],

Cell["\<\
where \[ScriptCapitalZ](g) is the centralizer of the element g and \
\[ScriptCapitalC](g) is the conjugacy class containing g.\
\>", "TechNoteText",
 CellID->1562729267,ExpressionUUID->"a41df595-7612-4185-86d2-4b6187cfe54e"],

Cell["Thus, in matrix form, the scalar product is defined by", \
"TechNoteMathCaption",
 CellID->1989248471,ExpressionUUID->"89ee4f6a-2c4b-454c-a276-3af2fbda630d"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"matJ", "=", 
   RowBox[{"YoungCentralizerSize", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"matJ", "=", 
   RowBox[{"DiagonalMatrix", "[", 
    RowBox[{"1", "/", "matJ"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"matJ", "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[680]:=",
 CellID->369961429,ExpressionUUID->"045b31fd-a155-4915-a807-2da6864e3fb1"],

