Cell["\<\
The complete set of irreducible representations can be obtained from it by \
reduction, as can be seen by checking the multiplicities of the irreducible \
characters in these compound characters using our scalar product:\
\>", "TechNoteMathCaption",
 CellID->1816316843,ExpressionUUID->"06fd65c4-d27d-480f-bb49-ad09f3602ead"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"matJ", "=", 
