Cell["\<\
The complete set of irreducible representations can be obtained therefore by \
reduction, as can be seen by checking the multiplicities of the irreducible \
characters in these compound characters using our scalar product:\
\>", "TechNoteMathCaption",
 CellID->219117505,ExpressionUUID->"af860905-5e15-4390-aa58-20299bd25023"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"mm", "=", 
   RowBox[{"chr", ".", "matJ", ".", 
    RowBox[{"Transpose", "[", "cmp", "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"mm", "//", "MatrixForm"}]}], "Input",
