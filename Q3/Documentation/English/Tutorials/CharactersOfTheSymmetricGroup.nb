 RowBox[{
  RowBox[{"matJ", "=", 
   RowBox[{"DiagonalMatrix", "[", 
    RowBox[{"1", "/", "matJ"}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[62]:=",
