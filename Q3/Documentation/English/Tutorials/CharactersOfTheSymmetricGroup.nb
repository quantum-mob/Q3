Cell[CellGroupData[{

Cell["The Coxeter Relations", "TechNoteSection",
 CellID->2131844516,ExpressionUUID->"321cf612-65c0-48ca-a6c3-9fdc6d29bb29"],

Cell[TextData[{
 "Notice that the symmetric group ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "09d1be38-9d7d-4559-bb5a-f97ff4de2159"],
 " is defined by the generators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Tau]", "i"], "=", 
    RowBox[{"(", 
     RowBox[{"i", ",", 
      RowBox[{"i", "+", "1"}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "130bc9e8-ff61-426d-8bca-44fc12fe8aaf"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[LessEqual]", "i", "<", "n"}], TraditionalForm]],
  ExpressionUUID->"e93d5216-9ea0-4cef-9290-2b42baebb5b0"],
 ", i.e. the transpositions of neighboring elements that satisfy the relations"
}], "TechNoteText",
 CellID->1293613864,ExpressionUUID->"ac918a77-0b0b-4bbe-ade0-2de2ffc21d2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox[
    SubscriptBox["\[Tau]", "i"], "2"], "=", "1"}], ",", " ", 
  RowBox[{"1", "\[LessEqual]", "i", "<", "n"}]}]], "DisplayMath",
 CellID->643770020,ExpressionUUID->"c6f6c740-c7d2-4d64-be74-ada39213721e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Tau]", "i"], 
      SubscriptBox["\[Tau]", 
       RowBox[{"i", "+", "1"}]]}], ")"}], "3"], "=", "1"}], ",", " ", 
  RowBox[{"1", "\[LessEqual]", "i", "<", 
   RowBox[{"n", "-", "2"}]}]}]], "DisplayMath",
 CellID->820112554,ExpressionUUID->"665d3bf0-ff5d-41fb-b61f-627f969d316e"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["\[Tau]", "i"], 
    SubscriptBox["\[Tau]", "j"]}], "=", 
   RowBox[{
    SubscriptBox["\[Tau]", "j"], 
    SubscriptBox["\[Tau]", "i"]}]}], ",", " ", 
  RowBox[{"1", "\[LessEqual]", "i"}], ",", 
  RowBox[{"j", "<", "n"}], ",", " ", 
  RowBox[{"\[LeftBracketingBar]", 
   RowBox[{"i", "-", 
    RowBox[{"j", 
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"\[GreaterEqual]", "2"}]}]}]}]}]}]], "DisplayMath",
 CellID->1081648632,ExpressionUUID->"d68516c7-4f44-4cc7-bb71-d833cb0af937"],

Cell[TextData[{
 "They are known as ",
 StyleBox["Coxeter relations",
  FontSlant->"Italic"],
 ", although Coxeter himself attributes them to Moore. This means that it is \
perfectly legitimate to define a representation of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["S", "n"], TraditionalForm]],ExpressionUUID->
  "167d8c21-fd67-4dee-ab26-a44d9cc7fd60"],
 " by dreaming up a list of matrices ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["A", "1"], ",", 
    RowBox[{"...", 
     SubscriptBox["A", "n"]}]}], TraditionalForm]],ExpressionUUID->
  "348ae06c-f8c6-4725-acf8-139b30d32b03"],
 ", showing that they satisfy the Coxeter relations with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "i"], TraditionalForm]],ExpressionUUID->
  "74f21d27-d749-4bcc-80f7-3464f15e2395"],
 " replaced by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "i"], TraditionalForm]],ExpressionUUID->
  "0ea45235-d4f5-4190-9f3f-c969e7aec5bf"],
 " and designating ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["A", "i"], TraditionalForm]],ExpressionUUID->
  "77a22638-85a7-441b-8bbb-ab34db98da98"],
 " as the image of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "i"], TraditionalForm]],ExpressionUUID->
  "6d7e79a4-8de4-4280-b96b-7f5d7ae952bf"],
 "."
}], "TechNoteText",
 CellID->819486169,ExpressionUUID->"49d823da-8b50-48ad-a8d1-6b1f2872a6c3"],

Cell[BoxData[
 RowBox[{"Get", "[", "\"\<QuantumMob`Q3`YoungPlus`\>\"", "]"}]], "Input",
 CellLabel->"In[694]:=",
 CellID->268518328,ExpressionUUID->"5c4d6a49-1667-4256-b0e7-a88df052382a"],

