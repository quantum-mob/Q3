 RowBox[{"TableForm", "[", 
  RowBox[{"cmp", ",", 
   RowBox[{"TableHeadings", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"irrep", ",", "classes"}], "}"}]}]}], "]"}]}], "Input",
