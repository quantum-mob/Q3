Cell[CellGroupData[{

Cell["Quantum Jump Approach", "Subsection",
 CellID->248642970,ExpressionUUID->"155658c2-3700-4828-ac97-08cf1c84040e"],

Cell[BoxData[GridBox[{
   {
    TemplateBox[{
      Cell[
       TextData["LindbladSimulate"]], 
      "paclet:QuantumMob/Q3/ref/LindbladSimulate", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->{"DefinitionBox", CellFrame -> 0}], Cell["\<\
Solve a quantum master equation using the quantum jump approach (Monte Carlo \
method).\
\>", "TechNoteTableText",ExpressionUUID->
     "621244e8-3b93-487f-b5f0-2ad8e1ac2870"]}
  }]], "DefinitionBox",
 CellID->913895715,ExpressionUUID->"0d4acc2f-2230-4ac2-8a2c-284fb1585452"],

Cell[TextData[{
 "Integrating quantum master equation gets quickly intractable as the system \
increases in size. For example, for a system of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "54398840-4f60-4a5d-ad76-59ff7983b480"],
 " qubits, one has to deal with an order of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["4", "n"], "\[Times]", 
    SuperscriptBox["4", "n"]}], TraditionalForm]],ExpressionUUID->
  "2ea05768-c5e3-4f9b-bdb3-4fb3a4afb65c"],
 "matrix; see ",
 ButtonBox["Equations (16)",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#207578088"],
 " and ",
 ButtonBox["(17)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#1207975698"],
 ". The required memory is simply too large for most available computers. \
This is where the quantum jump approach  becomes extremely useful."
}], "TechNoteText",
 CellID->2086703375,ExpressionUUID->"2c0dcafd-b47c-4999-9b14-9e5fce6be567"],

Cell[TextData[{
 "\tTo understand the idea behind the quantum jump approach (",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Plenio and Knight, 1998"]], 
    "https://doi.org/10.1103/RevModPhys.70.101"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "8c9a1f5e-8d7d-452d-a8bc-e54603fc240b"],
 "), note that for a short elapse ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], TraditionalForm]],
  ExpressionUUID->"04a5cf24-2188-4703-8d94-b829d6e934d2"],
 " of time from ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "5848efa6-bcff-4186-bb87-0f87d1c1d32f"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "+", 
    RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}]}], TraditionalForm]],
  ExpressionUUID->"52c88163-fcfa-460a-a54e-30c6e60b7988"],
 ", the density operator evolves as"
}], "TechNoteText",
 CellID->668184468,ExpressionUUID->"72fa9cd0-1d40-47ac-aa7a-a70b403c4fd3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", 
     RowBox[{"t", "+", 
      RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}]}], ")"}], "\[TildeTilde]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"I", "-", 
        RowBox[{
        "\[ImaginaryI]", "\[VeryThinSpace]", "\[Delta]", "\[VeryThinSpace]", 
         "t", "\[VeryThinSpace]", 
         SubscriptBox["L", "0"]}]}], ")"}], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"I", "-", 
         RowBox[{
         "\[ImaginaryI]", "\[VeryThinSpace]", "\[Delta]", "\[VeryThinSpace]", 
          "t", "\[VeryThinSpace]", 
          SubscriptBox["L", "0"]}]}], ")"}], "\[Dagger]"]}], "+", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Mu]", "=", "1"}], 
       RowBox[{
        SuperscriptBox["d", "2"], "-", "1"}]], 
      SubscriptBox["L", "\[Mu]"], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}], "\[TildeTilde]", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["U", "non"], "(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      RowBox[{
       SubsuperscriptBox["U", "non", "\[Dagger]"], "(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}]}], "+", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Mu]", "=", "1"}], 
       RowBox[{
        SuperscriptBox["d", "2"], "-", "1"}]], 
      SubscriptBox["L", "\[Mu]"], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"341be260-429a-4f63-9b65-5c5c7f5bb5ae"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->984363513,ExpressionUUID->"4f743c71-c985-41d4-b04c-94cf5674dd04"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "non"], "(", "t", ")"}], TraditionalForm]],
  ExpressionUUID->"0b6b758b-8b80-49f3-bf07-7aa1e9828ffb"],
 " is the non-unitary time-evolution operator associated with the effective \
non-Hermitian Hamiltonian ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "non"], TraditionalForm]],ExpressionUUID->
  "7955b8bd-35dc-4210-b921-27ac14a5df38"],
 "; that is,"
}], "TechNoteText",
 CellID->2131030150,ExpressionUUID->"5b694f19-2d7c-438f-99e5-eff44996a1fb"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "non"], "(", "t", ")"}], ":=", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
      SubscriptBox["H", "non"]}]]}], TraditionalForm]],ExpressionUUID->
  "95178191-45b1-4438-b832-45010bd08715"],
 " ."
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->491466384,ExpressionUUID->"88a63b4c-11c5-453d-b191-ea208ec3459b"],

Cell[TextData[{
 "We have ignored the term of the second and higher orders in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], TraditionalForm]],
  ExpressionUUID->"645b86e6-2377-47ed-9f7a-3e9f1857dc4c"],
 "."
}], "TechNoteText",
 CellID->853409526,ExpressionUUID->"d5207b81-0c46-4829-838c-c7a21a7b6f25"],

Cell[TextData[{
 "\tConceptually, the key observation is that each term in ",
 ButtonBox["Equation (19)",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#984363513"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["U", "non"], "(", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], 
    RowBox[{"\[Rho]", "(", "t", ")"}], 
    RowBox[{
     SubsuperscriptBox["U", "non", "\[Dagger]"], "(", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"1a60c677-2b49-4074-b5d7-e064fb345bc9"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Delta]", "\[VeryThinSpace]", "t", " ", 
    SubscriptBox["L", "\[Mu]"], 
    RowBox[{"\[Rho]", "(", "t", ")"}], 
    SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}], TraditionalForm]],
  ExpressionUUID->"9fc8c23f-fd3e-4391-a84f-41a884684166"],
 ", represents a possible quantum state that is determined randomly with \
probability \t"
}], "TechNoteText",
 CellID->210625169,ExpressionUUID->"8e743d32-6bf7-43ca-8377-1bcf41963970"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], ":=", 
    RowBox[{"Tr", "[", 
     RowBox[{
      RowBox[{
       SubscriptBox["U", "non"], "(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      RowBox[{
       SubsuperscriptBox["U", "non", "\[Dagger]"], "(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}]}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"8a601da5-87f9-4efe-af9f-2b2065d84b52"]
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->2048515405,ExpressionUUID->"5d601c13-6581-47a8-b98d-43f96eae4680"],

Cell["or", "TechNoteText",
 CellID->103624565,ExpressionUUID->"e93437b6-16c2-4e5d-8286-fe8b7994b047"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "\[Mu]"], ":=", 
    RowBox[{"Tr", "[", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t", " ", 
      SubscriptBox["L", "\[Mu]"], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}], "]"}]}], 
   TraditionalForm]],ExpressionUUID->"4cd83260-19b2-46ed-8ea1-ca20d6494801"],
 ". "
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1204485777,ExpressionUUID->"13d0a1aa-714c-4b53-83c5-7b0e6fa84e7c"],

Cell[TextData[{
 "This means that to generate a trajectory of quantum state in the Hilbert \
space, we may just follow the spirit of Monte Carlo method and randomly apply \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Delta]", "\[VeryThinSpace]", 
     SubscriptBox["F", "0"]}], ":=", 
    RowBox[{
     SubscriptBox["U", "non"], "(", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"d38d221f-62c6-4d82-af8a-60374f639fda"],
 " or ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Delta]", "\[VeryThinSpace]", 
     SubscriptBox["F", "\[Mu]"]}], ":=", 
    RowBox[{
     SqrtBox[
      RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}]], 
     SubscriptBox["L", "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "7f68f840-d454-449c-9005-f1160355f363"],
 " with aforementioned probability at each time step ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["t", "k"], ":=", 
    RowBox[{"k", "\[VeryThinSpace]", "\[Delta]", "\[VeryThinSpace]", "t"}]}], 
   TraditionalForm]],ExpressionUUID->"b47eafe5-052b-4696-b2a9-8d80558c32d5"],
 ". For example, starting with an initial pure state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"in"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "4659c5ea-abac-47d9-ab3a-41f2961b48c6"],
 ","
}], "TechNoteText",
 CellID->1690749513,ExpressionUUID->"79e745af-5061-4c18-985d-74e8a901fc77"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Psi]", "(", 
         SubscriptBox["t", "0"], ")"}]},
      "Ket"], "=", 
     TemplateBox[{"in"},
      "Ket"]}], ",", "\[LineSeparator]", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Psi]", "(", 
         SubscriptBox["t", "1"], ")"}]},
      "Ket"], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "0"]}], ")"}], 
      TemplateBox[{"in"},
       "Ket"]}]}], ",", "\[IndentingNewLine]", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Psi]", "(", 
         SubscriptBox["t", "2"], ")"}]},
      "Ket"], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "2"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "0"]}], ")"}], 
      TemplateBox[{"in"},
       "Ket"]}]}], ",", "\[IndentingNewLine]", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Psi]", "(", 
         SubscriptBox["t", "3"], ")"}]},
      "Ket"], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "0"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "2"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "0"]}], ")"}], 
      TemplateBox[{"in"},
       "Ket"]}]}], ",", "\[IndentingNewLine]", 
    RowBox[{
     TemplateBox[{
       RowBox[{"\[Psi]", "(", 
         SubscriptBox["t", "4"], ")"}]},
      "Ket"], "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "1"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "0"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "2"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", 
        SubscriptBox["F", "0"]}], ")"}], 
      TemplateBox[{"in"},
       "Ket"]}]}], ",", "\[IndentingNewLine]", "\[Ellipsis]"}], 
   TraditionalForm]],ExpressionUUID->"829343d6-9b10-4634-896f-6bfd25e70a32"]
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->924165127,ExpressionUUID->"cd5975f4-1e36-4919-a2a6-ee3ab0efd02f"],

Cell[TextData[{
 "is a possible trajectory. By repeating the same procedure, one can realize \
many trajectories. The density matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "(", 
    SubscriptBox["t", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "6b8df001-c469-468c-8a3e-f0b16e1fcb5a"],
 " at each time step ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["t", "k"], TraditionalForm]],ExpressionUUID->
  "a8e98af8-1f72-474b-a17e-9f6985c615c8"],
 " can be obtained by taking the statistical mixture from all resulting \
trajectories,"
}], "TechNoteText",
 CellID->1841554385,ExpressionUUID->"e9efabca-1c32-451c-88d1-36083dbc56e2"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", 
     SubscriptBox["t", "k"], ")"}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "trajectories"], 
     TemplateBox[{
       RowBox[{"\[Psi]", "(", 
         SubscriptBox["t", "k"], ")"}]},
      "Ket"], 
     TemplateBox[{
       RowBox[{"\[Psi]", "(", 
         SubscriptBox["t", "k"], ")"}]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "e1f162e8-1807-4c0f-bbc7-f0125c6cd31d"],
 " ."
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1470228131,ExpressionUUID->"7f89f7f0-b0c8-41b5-bf48-bf66769c1ba6"],

Cell[TextData[{
 "\tTechnically, the key advantage of the quantum jump approach is that it \
only requires memory to store a complex vector of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]],ExpressionUUID->
  "364c469a-06f5-4963-a077-b59352439073"],
 " components for updating the state at each time step. Additional memory is \
needed to store the trajectories, but for the trajectory data, one can also \
utilize external storage."
}], "TechNoteText",
 CellID->1177355335,ExpressionUUID->"e14ff406-9269-4128-9f69-205911dcc800"],

Cell[CellGroupData[{

Cell["Example", "Subsubsection",
 CellID->400079759,ExpressionUUID->"bc0839c0-d318-4a48-a348-c737f4a6af8d"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[18]:=",
 CellID->974935498,ExpressionUUID->"88f684ca-595f-445b-8a17-bab7c6c77479"],

Cell["Let us consider a system of qubits.", "TechNoteMathCaption",
 CellID->501695840,ExpressionUUID->"5b4ff304-889d-416d-af46-52bb9ce6960b"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[19]:=",
 CellID->208984626,ExpressionUUID->"8e234bb7-ac76-404a-9038-b6467748e8e3"],

Cell["Take an effective Hamiltonian.", "TechNoteMathCaption",
 CellID->1723732938,ExpressionUUID->"fd73c79c-1c49-4ab0-ba6f-c70d80159511"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"opH", "=", 
  RowBox[{"S", "[", "3", "]"}]}]], "Input",
 CellLabel->"In[20]:=",
 CellID->1225090936,ExpressionUUID->"af170dda-049e-4b88-a4f6-2b2d470a52ed"],

Cell[BoxData[
 InterpretationBox[
  TemplateBox[{"S", 
    TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"Z\""}, 
     "RowWithSeparators"]},
   "Superscript"],
  $CellContext`S[3]]], "Output",
 CellLabel->"Out[20]=",
 CellID->724960039,ExpressionUUID->"532a21f2-dea1-487b-b94f-d98433fa1daf"]
}, Open  ]],

Cell["Consider the bit-flip noises as quantum jump operators.", \
"TechNoteMathCaption",
 CellID->2138209167,ExpressionUUID->"7f53f4c8-b889-469a-9acb-38628a727ff2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Real", ",", "\[CapitalGamma]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"opL", "=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{"\[CapitalGamma]", "[", "\"\<+\>\"", "]"}], "]"}], " ", 
     RowBox[{"S", "[", "4", "]"}]}], ",", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{"\[CapitalGamma]", "[", "\"\<-\>\"", "]"}], "]"}], 
     RowBox[{"S", "[", "5", "]"}]}]}], "}"}]}]}], "Input",
 CellLabel->"In[21]:=",
 CellID->890120871,ExpressionUUID->"430e3cc9-a760-4744-9ff0-3337e465d357"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    InterpretationBox[
     TemplateBox[{"S", 
       TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"+\""}, 
        "RowWithSeparators"]},
      "Superscript"],
     $CellContext`S[4]], " ", 
    SqrtBox[
     InterpretationBox[
      SubscriptBox["\[CapitalGamma]", 
       TemplateBox[{",", "\",\"", "\"+\""},
        "RowWithSeparators"]],
      $CellContext`\[CapitalGamma]["+"]]]}], ",", 
   RowBox[{
    InterpretationBox[
     TemplateBox[{"S", 
       TemplateBox[{"\[ThinSpace]", "\"\[ThinSpace]\"", "\"-\""}, 
        "RowWithSeparators"]},
      "Superscript"],
     $CellContext`S[5]], " ", 
    SqrtBox[
     InterpretationBox[
      SubscriptBox["\[CapitalGamma]", 
       TemplateBox[{",", "\",\"", "\"-\""},
        "RowWithSeparators"]],
      $CellContext`\[CapitalGamma]["-"]]]}]}], "}"}]], "Output",
 CellLabel->"Out[22]=",
 CellID->1728646042,ExpressionUUID->"31375e23-55ca-4b90-8369-d04a348f839c"]
}, Open  ]],

Cell["Take an initial state.", "TechNoteMathCaption",
 CellID->1184140969,ExpressionUUID->"7a12e7b9-5a9f-4555-881e-3e6a5a56b9f0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"in", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Ket", "[", "]"}], "+", 
      RowBox[{"Ket", "[", 
       RowBox[{"S", "->", "1"}], "]"}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}], "//", "KetRegulate"}]}]], "Input",
 CellLabel->"In[23]:=",
 CellID->1126309234,ExpressionUUID->"ce20620b-5bbf-4eb6-86c5-726dd3169a57"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox["S", 
            $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 0|>]], "+", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox["S", 
            $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 1|>]]}], 
  SqrtBox["2"]]], "Output",
 CellLabel->"Out[23]=",
 CellID->47767631,ExpressionUUID->"3030d69d-8438-4c25-becc-f9def3c8bab7"]
}, Open  ]],

Cell["\<\
Pick the time slices at which the trajectory points are fixed.\
\>", "TechNoteMathCaption",
 CellID->1174017344,ExpressionUUID->"8506b004-c07e-417e-801c-967bc7379997"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"Range", "[", 
    RowBox[{"0", ",", "10", ",", "0.05"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[24]:=",
 CellID->1225147428,ExpressionUUID->"120b8266-aae7-4aa2-b889-afd8915e54ed"],

Cell["\<\
Simulate the Lindblad equation using the quantum jump approach.\
\>", "TechNoteMathCaption",
 CellID->1958431180,ExpressionUUID->"48dd2af1-9c8e-4a4a-bac5-022993cce9bd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"EchoTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Block", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[CapitalGamma]", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalGamma]", "[", "\"\<+\>\"", "]"}], "=", ".3"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\[CapitalGamma]", "[", "\"\<-\>\"", "]"}], "=", ".7"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"LindbladSimulate", "[", 
        RowBox[{
        "opH", ",", "opL", ",", "in", ",", "tt", ",", "\[IndentingNewLine]", 
         RowBox[{"\"\<Samples\>\"", "->", "100"}]}], "]"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellLabel->"In[25]:=",
 CellID->870984691,ExpressionUUID->"516d7942-fbe0-4f71-9ff7-579c031ba9f3"],

Cell[BoxData["0.201879`"], "EchoTiming",
 CellID->1130819663,ExpressionUUID->"baa985b0-06a3-45c5-8c0a-cb3e2a48345a"]
}, Open  ]],

Cell[TextData[{
 "Construct the density matrix at each times. Again, notice ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Transpose"]], "paclet:ref/Transpose"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "eb8a8562-e8db-47cf-aa22-07bbe0089acb"],
 " here; for the form of the output data, see the ",
 ButtonBox["Details and Options",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/LindbladSimulate#1226658091"],
 " section section above."
}], "TechNoteMathCaption",
 CellID->1382089322,ExpressionUUID->"8af2191e-81b1-4e01-a674-9f918b14cf03"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rho", "=", 
   RowBox[{"Mean", "/@", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Dyad", "[", 
        RowBox[{"#", ",", "#"}], "]"}], "&"}], ",", 
      RowBox[{"Transpose", "@", "data"}], ",", 
      RowBox[{"{", "2", "}"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Dimensions", "[", "rho", "]"}]}], "Input",
 CellLabel->"In[26]:=",
 CellID->988622654,ExpressionUUID->"740f314a-92ca-4d81-ad1b-7f87bac93fc0"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"201", ",", "2", ",", "2"}], "}"}]], "Output",
 CellLabel->"Out[27]=",
 CellID->455800091,ExpressionUUID->"d24c00d1-e5cc-496a-8687-5b0701c5114a"]
}, Open  ]],

Cell["\<\
As an example, calculate the averages of the Pauli X, Y, and Z operators.\
\>", "TechNoteMathCaption",
 CellID->1459452562,ExpressionUUID->"7e8d114c-c851-4bb8-b57f-45957de7f1cb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"II", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", "#", "]"}], "&"}], ",", "rho"}], "]"}]}], 
     "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"XX", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ThePauli", "[", "1", "]"}], ".", "#"}], "]"}], "&"}], ",",
         "rho"}], "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"YY", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ThePauli", "[", "2", "]"}], ".", "#"}], "]"}], "&"}], ",",
         "rho"}], "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ZZ", "=", 
   RowBox[{"Transpose", "@", 
    RowBox[{"{", 
     RowBox[{"tt", ",", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Tr", "[", 
          RowBox[{
           RowBox[{"ThePauli", "[", "3", "]"}], ".", "#"}], "]"}], "&"}], ",",
         "rho"}], "]"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"XX", ",", "YY", ",", "ZZ"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Joined", "->", "True"}], ",", "\[IndentingNewLine]", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(B\), \(z\)]\) t\>\"", 
      ",", "\"\<\[LeftAngleBracket]X\[RightAngleBracket], \
\[LeftAngleBracket]Y\[RightAngleBracket], \[LeftAngleBracket]Z\
\[RightAngleBracket]\>\""}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotLegends", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], "Input",
 CellLabel->"In[28]:=",
 CellID->460993500,ExpressionUUID->"c1b4567f-eaee-41e1-b484-aaaa0056d2e9"],

