Cell[CellGroupData[{

Cell["General Form", "TechNoteSection",
 CellID->829965404,ExpressionUUID->"2b31e084-1320-4d6c-a748-73735322c192"],

Cell[TextData[{
 "Within the Markov approximation, the density operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "3dd8fd32-d6b0-4531-919c-8a72e68b53b6"],
 " satisfies a differential equation of the form,"
}], "TechNoteText",
 CellID->1322257763,ExpressionUUID->"4e4f17fd-88ec-4ca2-a05f-842090a59c36"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["d\[Rho]", 
     RowBox[{"d", "\[VeryThinSpace]", "t"}]], "=", 
    RowBox[{"\[ScriptCapitalL]", "(", "\[Rho]", ")"}]}], TraditionalForm]],
  ExpressionUUID->"fa5d06a6-ca01-49fb-b631-be824e0c2bb1"],
 ","
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->356024661,ExpressionUUID->"4d7c74d5-bec6-41d0-90fd-1d1ecc7a246e"],

Cell[TextData[{
 "which is called the ",
 StyleBox["quantum master equation",
  FontSlant->"Italic"],
 " or ",
 StyleBox["Lindblad equation",
  FontSlant->"Italic"],
 ". Here, the superoperator ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalL]", TraditionalForm]],ExpressionUUID->
  "63adbd98-e99a-4bb8-9475-11459a2daac8"],
 " defined by"
}], "TechNoteText",
 CellID->1025443585,ExpressionUUID->"a4c0764c-4a42-4781-879f-0c8e69c10b6a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[ImaginaryI]", "[", 
       RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "+", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "\[Mu]"], "(", 
      RowBox[{
       RowBox[{
        SubscriptBox["L", "\[Mu]"], "\[Rho]", " ", 
        SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}], "-", 
       RowBox[{
        FractionBox["1", "2"], 
        SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], 
        SubscriptBox["L", "\[Mu]"], "\[Rho]"}], "-", 
       RowBox[{
        FractionBox["1", "2"], "\[Rho]", " ", 
        SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], 
        SubscriptBox["L", "\[Mu]"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"d76897da-8576-4e30-9b79-531e71ee050d"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1074065920,ExpressionUUID->"0e2d8019-0343-478e-a07a-a0e76dfa41fb"],

Cell[TextData[{
 "generates the quantum Markovian dynamics and is called the ",
 StyleBox["Lindblad generator",
  FontSlant->"Italic"],
 ". The Hermitian operator ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "b32968c5-dd3b-4cf5-89ed-c981bdb27ab0"],
 " in the above equation describes the unitary part of the dynamics. For this \
reason, ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "62cb54f6-d196-4243-a8b8-9949fd3fc09e"],
 " is often called the ",
 StyleBox["effective Hamiltonian",
  FontSlant->"Italic"],
 " of the system, but in general it is not the same as the Hamiltonian when \
the system is isolated. The operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "b0b1ea36-b178-4179-960e-2e33c66c9333"],
 " are responsible for the non-unitary dynamics and are called the ",
 StyleBox["Lindblad operators",
  FontSlant->"Italic"],
 " or ",
 StyleBox["quantum jump operators",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->78380758,ExpressionUUID->"46d96484-dcda-4c06-b059-156c82d9b5c7"],

Cell["\<\
\tIt is also customary to rewrite the Lindblad generator into the form\
\>", "TechNoteText",
 CellID->937924095,ExpressionUUID->"ac12763a-6be6-4a5c-9ed1-858172ec6df3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalL]", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[ImaginaryI]", "[", 
       RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "-", 
     RowBox[{"{", 
      RowBox[{"G", ",", "\[Rho]"}], "}"}], "+", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
      SubscriptBox["L", "\[Mu]"], "\[Rho]", " ", 
      SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"8f000814-ad73-40e9-b430-f465840ede34"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1160295685,ExpressionUUID->"c03c254e-2cb4-4edb-94b6-332f193d9634"],

Cell["where", "TechNoteText",
 CellID->1938063035,ExpressionUUID->"b0ed0f7b-08a9-4fe1-a6b8-f48aec47dae8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{
     FractionBox["1", "2"], 
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["L", "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "6ae9e92a-b712-4509-af35-460d75c250cf"],
 " ."
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->2140955196,ExpressionUUID->"99fb338d-572d-49f7-bd5b-6052d3ed1256"],

Cell["\<\
Interestingly, ignoring the last term in the quantum jump operators, the \
solution to the approximate quantum master equation,\
\>", "TechNoteText",
 CellID->1945473687,ExpressionUUID->"dcd1513c-1c9f-4ee6-a1d4-4513870afb85"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["d\[Rho]", 
     RowBox[{"d", "\[VeryThinSpace]", "t"}]], "\[TildeTilde]", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[ImaginaryI]", "[", 
       RowBox[{"H", ",", "\[Rho]"}], "]"}]}], "-", 
     RowBox[{"{", 
      RowBox[{"G", ",", "\[Rho]"}], "}"}]}]}], TraditionalForm]],
  ExpressionUUID->"52f0fd53-a809-4c1b-9c1a-3f5d344387c9"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->2137731834,ExpressionUUID->"2dcc233d-27bb-4f1c-8b85-599edf8268ef"],

Cell["is simply given by ", "TechNoteText",
 CellID->1457519728,ExpressionUUID->"5aaa55b9-c83c-4a12-98e6-0dd6c218a7a1"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", "t", ")"}], "\[TildeTilde]", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
       SubscriptBox["H", "non"]}]], 
     RowBox[{"\[Rho]", "(", "0", ")"}], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"+", "\[ImaginaryI]"}], "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
       SubsuperscriptBox["H", "non", "\[Dagger]"]}]]}]}], TraditionalForm]],
  ExpressionUUID->"f8b6d058-20e2-4386-b758-0584e8606498"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->188107167,ExpressionUUID->"650a8436-d664-4d49-948e-41cc38ddb335"],

Cell[TextData[{
 "which resembles the unitary dynamics with Hamiltonian ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "bc7b1498-eaec-44ef-a063-7eee6509886f"],
 " replaced with the effective non-Hermitian Hamiltonian "
}], "TechNoteText",
 CellID->421227385,ExpressionUUID->"03c85d7b-7acd-4f82-99ad-279da0521d72"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["H", "non"], ":=", 
    RowBox[{"H", "-", 
     RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "G"}]}]}], 
   TraditionalForm]],ExpressionUUID->"f5e337fd-08c7-48ce-ab45-41968702b103"],
 " ."
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1462559183,ExpressionUUID->"807d6f1c-959e-4e37-b5e0-f19d3b36a1b2"],

Cell[TextData[{
 "The additional term in ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "7b1d592d-7d5e-4aee-81cf-22b06a9bb67a"],
 " of the non-Hermitian Hamiltonian makes a significant difference in the \
evolution governed  ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
     SubscriptBox["H", "non"]}]], TraditionalForm]],ExpressionUUID->
  "7c52dbd4-7e63-496d-8fe9-1ab305c1162c"],
 " since it causes damping and leads to irreversible population loss in the \
eigenstates of ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "e1c4d000-b686-4e15-876f-c42e73e6d8a6"],
 ". To put it in another way, probability is not conserved any longer,"
}], "TechNoteText",
 CellID->1134365119,ExpressionUUID->"d826acc3-3683-4e39-9f75-13c45364ba49"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
        SubscriptBox["H", "non"]}]], 
      RowBox[{"\[Rho]", "(", "0", ")"}], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"+", "\[ImaginaryI]"}], "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
        SubsuperscriptBox["H", "non", "\[Dagger]"]}]]}], "]"}], "=", 
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{
       RowBox[{"\[Rho]", "(", "0", ")"}], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "G"}], "+", 
         RowBox[{
         "\[ImaginaryI]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
          "H"}]}]], 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"-", "G"}], "-", 
         RowBox[{
         "\[ImaginaryI]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
          "H"}]}]]}], "]"}], "<", "1"}]}], TraditionalForm]],ExpressionUUID->
  "c8090114-16d0-4857-876c-83a7dbafc1ce"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->2062220614,ExpressionUUID->"fe01305a-63ea-438e-a743-9f4ddbe32920"],

Cell[TextData[{
 "because ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "98e74b6f-d9f2-435c-b8d5-c9a9af33a97a"],
 " is positive. In this sense, we call ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "d722a34c-21a6-4fd1-9145-3c0e6f5a4dc5"],
 " the ",
 StyleBox["effective damping operator",
  FontSlant->"Italic"],
 ". Physically, other processes described by Lindblad operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "\[Mu]"], " "}], TraditionalForm]],ExpressionUUID->
  "7147c9da-d012-43eb-ba7b-378e87ca4877"],
 " account for the loss in probability."
}], "TechNoteText",
 CellID->1503280565,ExpressionUUID->"41c12ccf-04dd-4438-b18a-9eddb445bc99"],

Cell[TextData[{
 "\tAlthough the non-Hermitian Hamiltonian approach does not explain all \
decoherence processes, it lays out an intuitively appealing picture of open \
systems and has been widely used to describe the effects of a finite life \
time of (effective) energy levels. The non-Hermitian Hamiltonian also \
provides a good starting point for various more elaborate methods to \
investigate decoherence processes. A common example is the so-called ",
 StyleBox[ButtonBox["quantum jump approach",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#248642970"],
  FontSlant->"Italic"],
 ". It is an approximate method to solve the quantum master equation \
combining the aforementioned non-unitary evolution due to the non-Hermitian \
Hamiltonian and the \[OpenCurlyDoubleQuote]quantum jumps\
\[CloseCurlyDoubleQuote] due to the quantum jump operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "fe8b392a-958c-47a7-bee2-4081b4dc031e"],
 " (Dum ",
 StyleBox["et al",
  FontSlant->"Italic"],
 "., 1992; Plenio and Knight, 1998)."
}], "TechNoteText",
 CellID->491349000,ExpressionUUID->"f15dbf70-4964-4f12-9e41-a958f04356b0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Derivation", "TechNoteSection",
 CellID->1028020285,ExpressionUUID->"3649d434-25fa-446e-93be-203a0214cea3"],

Cell[TextData[{
 "It is straightforward to derive the quantum master equation starting from \
the ",
 ButtonBox["Kraus representation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOperations#982874389"],
 " under the Markov assumption (see, e.g., Breuer and Petruccione (2002) for \
details). Here, we take a heuristic approach, which is more useful to \
understand the underlying physics. More common approach is to reduce, often \
approximately, the ",
 ButtonBox["unitary dynamics of the total system",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOperations#1215528911"],
 " consisting of the system and environment (see also Section 5.2.3) to the \
quantum master equation for the system only. Some examples including \
perturbative methods are discussed in Breuer and Petruccione (2002)."
}], "TechNoteText",
 CellID->1991605227,ExpressionUUID->"4ac85e33-dc49-4b3b-880d-48fb603e36fa"],

Cell[TextData[{
 "\tConsider an infinitesimal elapse ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], TraditionalForm]],
  ExpressionUUID->"678381e8-cae1-4361-b217-768d7a63cc6a"],
 " of time from ",
 Cell[BoxData[
  FormBox["t", TraditionalForm]],ExpressionUUID->
  "579abe66-f510-417b-b1e4-20672b7dc66e"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"t", "'"}], ":=", 
    RowBox[{"t", "+", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}]}]}], TraditionalForm]],
  ExpressionUUID->"d316f8b9-b06d-4d82-96a9-ed30d35a73c9"],
 ". The density operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "(", 
    RowBox[{"t", "'"}], ")"}], TraditionalForm]],ExpressionUUID->
  "4aa91211-a2b7-45da-917b-f470343d1421"],
 " is related to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "(", "t", ")"}], TraditionalForm]],ExpressionUUID->
  "e13f97da-f82c-4e04-9a22-f1a51548f1fd"],
 " by the Kraus representation"
}], "TechNoteText",
 CellID->1430989880,ExpressionUUID->"4058c19b-b04b-45da-9c21-06e989afbcef"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", 
     RowBox[{"t", "'"}], ")"}], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
     RowBox[{
      SubscriptBox["F", "\[Mu]"], "(", 
      RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], 
     RowBox[{"\[Rho]", "(", "t", ")"}], " ", 
     RowBox[{
      SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"], "(", 
      RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"398386a7-3473-40fa-adc6-39bfa53ebca4"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->909584588,ExpressionUUID->"4da45016-495d-44f2-aa88-4f72904aca11"],

Cell[TextData[{
 "where we have imposed the Markovian approximation.  For ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], "\[TildeTilde]", "0"}], 
   TraditionalForm]],ExpressionUUID->"cbd4efcb-34bb-454e-8774-c6fdebd6ff1b"],
 ", it is physically required that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", 
     RowBox[{"t", "'"}], ")"}], "\[TildeTilde]", 
    RowBox[{"\[Rho]", "(", "t", ")"}]}], TraditionalForm]],ExpressionUUID->
  "b8b709f6-36e3-48f9-b877-fe3bdf0cfbff"],
 ". This implies that one and only one of ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", 
     RowBox[{"\[Mu]", " "}]], "(", 
    RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], TraditionalForm]],
  ExpressionUUID->"66cdf8d5-26bb-4bf7-8c16-149b95bf9146"],
 " must approach the identity operator ",
 Cell[BoxData[
  FormBox["I", TraditionalForm]],ExpressionUUID->
  "37d99be6-293d-44df-a7fc-a552fe83652a"],
 ". Let us denote it by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "0"], "(", 
    RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], TraditionalForm]],
  ExpressionUUID->"4dd0891f-ed7b-4949-b28e-2a51fb5542e7"],
 ". Up to the first order in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], TraditionalForm]],
  ExpressionUUID->"18b6b1a7-8d40-4434-a442-04f97207621f"],
 ","
}], "TechNoteText",
 CellID->977550407,ExpressionUUID->"58957d15-5214-4d2d-87f0-5b7c67023cf1"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["F", "0"], "(", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], "\[TildeTilde]", 
    RowBox[{"I", "-", 
     RowBox[{
     "\[ImaginaryI]", "\[VeryThinSpace]", "\[Delta]", "\[VeryThinSpace]", "t",
       " ", 
      SubscriptBox["L", "0"]}]}]}], TraditionalForm]],ExpressionUUID->
  "1515e070-540c-4fd0-984b-c6038f642da4"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1439790899,ExpressionUUID->"882f1106-3420-4083-bf90-dd37ade9d018"],

Cell[TextData[{
 "where the additional factor ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "\[ImaginaryI]"}], TraditionalForm]],ExpressionUUID->
  "3f43168e-499b-4599-bdff-8c563ba2d96d"],
 " is completely arbitrary at this stage but is introduced here for later \
convenience. The rest should vanish ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["F", "\[Mu]"], "(", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], "\[RightArrow]", 
    "0"}], TraditionalForm]],ExpressionUUID->
  "3e1d8347-7e10-4788-baf5-4cbaae8df3f8"],
 " for any ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "0"}], TraditionalForm]],ExpressionUUID->
  "e0c47133-309d-4593-bee5-1589a2e96c6e"],
 ". Since we physically expect that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", 
     RowBox[{"t", "'"}], ")"}], "\[TildeTilde]", 
    RowBox[{
     RowBox[{"\[Rho]", "(", "t", ")"}], "+", 
     RowBox[{"\[ScriptCapitalO]", "(", 
      RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}]}]}], 
   TraditionalForm]],ExpressionUUID->"c7569c28-6168-4a8d-8acb-ca218ee26996"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "\[Mu]"], "(", 
    RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], TraditionalForm]],
  ExpressionUUID->"595f0149-cf70-4dad-b830-498cc3db64fb"],
 " must vanish like ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}]], TraditionalForm]],
  ExpressionUUID->"744bf899-a378-4d72-8df8-b317d85dd109"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], TraditionalForm]],
  ExpressionUUID->"2b316b6c-45df-475c-8250-62eebce23b7e"],
 " so that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["F", "\[Mu]"], "(", 
      RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], 
     RowBox[{"\[Rho]", "(", "t", ")"}], 
     RowBox[{
      SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"], "(", 
      RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}]}], "\[TildeTilde]", 
    RowBox[{"\[ScriptCapitalO]", "(", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"f3329721-fccb-48c0-8185-a8b345fa5dfc"],
 ". We put"
}], "TechNoteText",
 CellID->719905097,ExpressionUUID->"36bd5a87-cc92-4eae-8f6d-7d9681fa3ac0"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["F", "\[Mu]"], "(", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}], ")"}], "\[TildeTilde]", 
    RowBox[{
     SqrtBox[
      RowBox[{" ", 
       RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}]}]], 
     SubscriptBox["L", "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "fb7c53ba-8046-4d6a-96bc-75f729ad05d3"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{"\[Mu]", "\[NotEqual]", "0"}], ")"}], TraditionalForm]],
  ExpressionUUID->"8681bf76-b646-4706-87c0-0dc8a5dac45d"],
 " ."
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->522098081,ExpressionUUID->"85981a18-f043-46a9-b766-ff510455d796"],

Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "52f4cd4f-2eb6-457a-9cd5-ab345da73a0a"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "0"}], TraditionalForm]],ExpressionUUID->
  "62e50a0d-57ed-45a4-ad41-b70b7eb9029d"],
 ") directly proportional to ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "48a19f96-70fa-4260-bc1f-95f35bdc7853"],
 ", they are all traceless and mutually orthogonal; i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", 
     RowBox[{
      SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], 
      SubscriptBox["L", "\[Mu]"]}], "]"}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"23fff916-4311-4b78-a7c6-8f4b266a867f"],
 " for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "\[Nu]"}], TraditionalForm]],
  ExpressionUUID->"c6f21034-3e02-4866-ac91-3fcac97aff3c"],
 ". Putting these approximations back into the equation for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "(", 
    RowBox[{"t", "'"}], ")"}], TraditionalForm]],ExpressionUUID->
  "7a48ec82-af12-4c73-9b28-4b54d32c91f9"],
 " at the beginning of this section leads to"
}], "TechNoteText",
 CellID->284265725,ExpressionUUID->"22676004-3b65-4b34-93c3-6172be3e19eb"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Rho]", "(", 
     RowBox[{"t", "+", 
      RowBox[{"\[Delta]", "\[VeryThinSpace]", "t"}]}], ")"}], "\[TildeTilde]", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"I", "-", 
        RowBox[{
        "\[ImaginaryI]", "\[VeryThinSpace]", "\[Delta]", "\[VeryThinSpace]", 
         "t", "\[VeryThinSpace]", 
         SubscriptBox["L", "0"]}]}], ")"}], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"I", "-", 
         RowBox[{
         "\[ImaginaryI]", "\[VeryThinSpace]", "\[Delta]", "\[VeryThinSpace]", 
          "t", "\[VeryThinSpace]", 
          SubscriptBox["L", "0"]}]}], ")"}], "\[Dagger]"]}], "+", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Mu]", "=", "1"}], 
       RowBox[{
        SuperscriptBox["d", "2"], "-", "1"}]], 
      SubscriptBox["L", "\[Mu]"], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}], "\[TildeTilde]", 
    RowBox[{
     RowBox[{"\[Rho]", "(", "t", ")"}], "-", 
     RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "\[Delta]", "\[VeryThinSpace]", 
      RowBox[{"t", "[", 
       RowBox[{
        RowBox[{
         SubscriptBox["L", "0"], 
         RowBox[{"\[Rho]", "(", "t", ")"}]}], "-", 
        RowBox[{
         RowBox[{"\[Rho]", "(", "t", ")"}], 
         SubsuperscriptBox["L", "0", "\[Dagger]"]}]}], "]"}]}], "+", 
     RowBox[{"\[Delta]", "\[VeryThinSpace]", "t", "\[VeryThinSpace]", 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"\[Mu]", "=", "1"}], 
       RowBox[{
        SuperscriptBox["d", "2"], "-", "1"}]], 
      SubscriptBox["L", "\[Mu]"], 
      RowBox[{"\[Rho]", "(", "t", ")"}], 
      SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"ab8ceaf7-fe69-4a4e-b56c-71802036d6ff"],
 " ."
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1650409147,ExpressionUUID->"734e8c1d-d506-4873-98f6-1111c910df2e"],

Cell["The conservation of probability then implies that", "TechNoteText",
 CellID->1527748977,ExpressionUUID->"74a24047-c816-401f-a828-c3bfc761f4d8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["L", "0"], "-", 
     SubsuperscriptBox["L", "0", "\[Dagger]"]}], "=", 
    RowBox[{
     RowBox[{"-", "\[ImaginaryI]"}], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "=", "1"}], 
      RowBox[{
       SuperscriptBox["d", "2"], "-", "1"}]], 
     SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["L", "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "915b7320-88b6-41b0-ba35-f72fc3aad130"],
 " ."
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1562572907,ExpressionUUID->"a7a4d686-0a60-4193-a0ff-fc87892cf089"],

Cell[TextData[{
 "This suggests that it will be convenient to split ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "0"], TraditionalForm]],ExpressionUUID->
  "7aa4c1fe-e405-4bed-b8fd-f6f8edb38ff9"],
 " into the Hermitian and anti-Hermitian parts as"
}], "TechNoteText",
 CellID->585328786,ExpressionUUID->"abb21e1d-2e73-401c-bd93-7541c9830b8b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "0"], "=", 
    RowBox[{"H", "-", 
     RowBox[{"\[ImaginaryI]", "\[VeryThinSpace] ", "G"}]}]}], 
   TraditionalForm]],ExpressionUUID->"1687e1f7-798a-42c9-8874-e56413cf4c4e"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->2145803042,ExpressionUUID->"f11e79ca-6412-4253-811c-03de88c43fe2"],

Cell[TextData[{
 "which is identical to the non-Hermitian Hamiltonian as we already mentioned \
above. Indeed, the anti-Hermitian part, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "G"}], 
   TraditionalForm]],ExpressionUUID->"8aa4e94e-87cb-4474-a121-365436aa3e37"],
 ", is then fixed by operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "dd16f1af-46ee-418c-a21a-4c10afe6d648"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "0"}], TraditionalForm]],ExpressionUUID->
  "01f8de37-96ad-4d7d-9566-dedc49b3a148"],
 " through the relation"
}], "TechNoteText",
 CellID->1818842823,ExpressionUUID->"f3738965-39c6-4235-9b98-28940a4cce40"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{
     FractionBox["1", "2"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "=", "1"}], 
      RowBox[{
       SuperscriptBox["d", "2"], "-", "1"}]], 
     SubsuperscriptBox["L", "\[Mu]", "\[Dagger]"], 
     SubscriptBox["L", "\[Mu]"]}]}], TraditionalForm]],ExpressionUUID->
  "f2b99298-9f9e-4c2c-8328-cdfb6e0f0a58"],
 " ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->2009094763,ExpressionUUID->"8ed73807-e5f3-4ce3-b3b9-f48a6402b917"],

Cell[TextData[{
 "where the Hermitian part ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "26b1baf2-d6c9-451f-9bed-ac075953c086"],
 " remains arbitrary and is determined only by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "0"], TraditionalForm]],ExpressionUUID->
  "453fdc01-4793-46c4-a9cd-6b5820f87f3a"],
 ", which is linearly independent of any ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "0f66c24c-d833-4cdb-92f8-d073648bb9a6"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", "\[NotEqual]", "0"}], TraditionalForm]],ExpressionUUID->
  "9f5654ca-de9f-42d0-a780-084a702fac32"],
 ". In passing, it is important to note that ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "bc191d10-df35-4c5b-829d-fa66ec975205"],
 " is positive, and as previously remarked, the probability conservation \
breaks down in the dynamics governed by the non-Hermitian Hamiltonian ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", "non"], TraditionalForm]],ExpressionUUID->
  "0117fc0c-4f6b-48a4-a26f-cde12850e566"],
 " (or, equivalently, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "0"], TraditionalForm]],ExpressionUUID->
  "34b9892a-fc80-4a6e-90af-92abd9f1359d"],
 ")."
}], "TechNoteText",
 CellID->1970299960,ExpressionUUID->"887c4c8e-01b1-4be0-852f-f490db5ada39"],

Cell[TextData[{
 "\tFinally, putting ",
 ButtonBox["Equations (14)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#2145803042"],
 " and ",
 ButtonBox["(15)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#2009094763"],
 " into ",
 ButtonBox["Equation (12)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#1650409147"],
 " leads to the ",
 ButtonBox["desired equations (2)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#1074065920"],
 " or, equivalently, ",
 ButtonBox["(3)",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumMasterEquation#1160295685"],
 ". Note that in this particular derivation, Lindblad operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "e7db1738-cb5a-4305-979d-87b83616d1e0"],
 " turn out to be traceless and mutually orthogonal automatically. Here, \
these properties inherit from the orthogonality of Kraus elements ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "354b731e-2359-43ef-8b81-01a561ead6a5"],
 "."
}], "TechNoteText",
 CellID->2030521791,ExpressionUUID->"95e49e5e-9f75-4164-9990-5e6b45e0c1c1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solution Methods", "TechNoteSection",
 CellID->633590980,ExpressionUUID->"e31bd602-a2b5-4a4d-a1a4-353c893132db"],

Cell[CellGroupData[{

Cell["Integrating the Differential Equation", "Subsection",
 CellID->1732673218,ExpressionUUID->"fafcea44-8559-4602-aa8c-431e8de54c8d"],

Cell[BoxData[GridBox[{
   {
    TemplateBox[{
      Cell[
       TextData["LindbladSolve"]], "paclet:QuantumMob/Q3/ref/LindbladSolve", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->{"DefinitionBox", CellFrame -> 0}], Cell[
    "Solves the quantum master equation", "TechNoteTableText",ExpressionUUID->
     "a4d21e42-f54d-40cd-a5f0-7b494e77845e"]},
   {
    TemplateBox[{
      Cell[
       TextData["NLindbladSolve"]], "paclet:QuantumMob/Q3/ref/NLindbladSolve",
       "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->{"DefinitionBox", CellFrame -> 0}], Cell[
    "Numerically solves the quantum master equation", "TechNoteTableText",
     ExpressionUUID->"2a54b462-bdf4-49ca-9ac9-81bb8cf368e0"]}
  }]], "DefinitionBox",
 CellID->1070647715,ExpressionUUID->"76ae5924-a66a-4180-a201-c59928b9e4bd"],

Cell["\<\
The Lindblad equation is a linear equation without an explicit time \
dependence, and it can always be solved by means of common methods for linear \
differential equations. More explicitly, in the standard basis, the Lindblad \
equation can be written as\
\>", "TechNoteText",
 CellID->1539679034,ExpressionUUID->"a9171c5d-6b58-4396-a897-247a68297893"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["\[Rho]", "."], 
     RowBox[{"j", "\[VeryThinSpace]", "k"}]], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", 
      RowBox[{
       RowBox[{"j", "'"}], 
       RowBox[{"k", "'"}]}]], 
     SubscriptBox["M", 
      RowBox[{
       RowBox[{"j", "\[VeryThinSpace]", "k"}], ";", 
       RowBox[{
        RowBox[{"j", "'"}], 
        RowBox[{"k", "'"}]}]}]], 
     SubscriptBox["\[Rho]", 
      RowBox[{
       RowBox[{"j", "'"}], 
       RowBox[{"k", "'"}]}]]}]}], TraditionalForm]],ExpressionUUID->
  "cff1162a-e25e-43ed-a9a9-5a758b4d64be"],
 " "
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->207578088,ExpressionUUID->"a9a143bc-a368-4757-bcde-52e5b80816a5"],

Cell["wit", "TechNoteText",
 CellID->1251482288,ExpressionUUID->"9397c754-3536-42b3-a30a-7e438b236d5d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", 
     RowBox[{
      RowBox[{"j", "\[VeryThinSpace]", "k"}], ";", 
      RowBox[{
       RowBox[{"j", "'"}], 
       RowBox[{"k", "'"}]}]}]], ":=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"\[ImaginaryI]", "(", 
       RowBox[{
        RowBox[{
         SubscriptBox["H", 
          RowBox[{"j", "\[VeryThinSpace]", 
           RowBox[{"j", "'"}]}]], 
         SubscriptBox["\[Delta]", 
          RowBox[{"k", "\[VeryThinSpace]", 
           RowBox[{"k", "'"}]}]]}], "-", 
        RowBox[{
         SubscriptBox["\[Delta]", 
          RowBox[{"j", "\[VeryThinSpace]", 
           RowBox[{"j", "'"}]}]], 
         SubscriptBox["H", 
          RowBox[{"k", "\[VeryThinSpace]", 
           RowBox[{"k", "'"}]}]]}]}], ")"}]}], "-", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SubscriptBox["G", 
         RowBox[{"j", "\[VeryThinSpace]", 
          RowBox[{"j", "'"}]}]], 
        SubscriptBox["\[Delta]", 
         RowBox[{"k", "\[VeryThinSpace]", 
          RowBox[{"k", "'"}]}]]}], "+", 
       RowBox[{
        SubscriptBox["\[Delta]", 
         RowBox[{"j", "\[VeryThinSpace]", 
          RowBox[{"j", "'"}]}]], 
        SubscriptBox["G", 
         RowBox[{"k", "\[VeryThinSpace]", 
          RowBox[{"k", "'"}]}]]}]}], ")"}], "+", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "\[Mu]"], 
      SubscriptBox["L", 
       RowBox[{"\[Mu]", ";", 
        RowBox[{"j", "\[VeryThinSpace]", 
         RowBox[{"j", "'"}]}]}]], 
      SubsuperscriptBox["L", 
       RowBox[{"\[Mu]", ";", 
        RowBox[{"k", "\[VeryThinSpace]", 
         RowBox[{"k", "'"}]}]}], "*"]}]}]}], TraditionalForm]],ExpressionUUID->
  "6adb6947-d836-4116-90cd-1eb51a6a2099"],
 " ."
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->1207975698,ExpressionUUID->"470e098a-ec32-4716-9cba-64551b5b0479"],

Cell[TextData[{
 "Regarding ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Mu]", ":=", 
    RowBox[{"(", 
     RowBox[{"j", "\[VeryThinSpace]", "k"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"49111ee4-ada1-4f5b-a1eb-ec74393dd621"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Nu]", ":=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"j", "'"}], 
      RowBox[{"k", "'"}]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "a65fb30e-13ce-4959-8608-ad31d34a33ca"],
 " as collective indices, the differential equation above reads as"
}], "TechNoteText",
 CellID->137157548,ExpressionUUID->"8d75f814-36fa-4a33-ba81-87157b971e06"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     OverscriptBox["\[Rho]", "."], "\[Mu]"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "\[Nu]"], 
     SubscriptBox["M", 
      RowBox[{"\[Mu]", "\[VeryThinSpace]", "\[Nu]"}]], 
     SubscriptBox["\[Rho]", "\[Nu]"]}]}], TraditionalForm]],ExpressionUUID->
  "93ab4d9f-327e-472c-91b6-78074429cfe7"],
 "  ,"
}], "TechNoteText",
 CellFrameLabels->{{None, 
    Cell[
     TextData[{"(", 
       CounterBox["DisplayFormulaNumbered"], ")"}], 
     "DisplayFormulaEquationNumber"]}, {None, None}},
 CounterIncrements->"DisplayFormulaNumbered",
 CellID->956956005,ExpressionUUID->"0d75eaec-8781-447a-8052-0df0b169dd61"],

Cell[TextData[{
 "which is a typical first-order differential equation for the column vector ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "\[Nu]"], TraditionalForm]],ExpressionUUID->
  "acbd1955-af55-4c5a-9b15-ae3a46de5039"],
 "."
}], "TechNoteText",
 CellID->1054543652,ExpressionUUID->"ef385bb8-0d6d-49fa-a569-a06a961af216"],

Cell[TextData[{
 "\tTechnically, the differential equation (18) is not adequate yet to solve \
because of the conditions that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Rho]", "\[Dagger]"], "=", "\[Rho]"}], TraditionalForm]],
  ExpressionUUID->"37d1a306-d598-45e7-b38f-3e443db9b1f7"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", "\[Rho]", "]"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"4416a161-2486-4e70-a8e0-931c7a8e35a4"],
 "; that is, the components ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"i", "\[VeryThinSpace]", "j"}]], TraditionalForm]],ExpressionUUID->
  "d9b0abd9-1671-4108-8268-2157a3adc900"],
 " are not independent of each other. These conditions are reflected in the \
fact that the determinant of the matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "23644e39-ddfa-47a4-b3be-549c18bb9953"],
 " is always zero."
}], "TechNoteText",
 CellID->56787535,ExpressionUUID->"e5f43a59-a4e1-4f0d-9ac0-87284cce5727"],

Cell["\<\
For example, consider a single-qubit system. Suppose that the Lindblad \
equation is characterized by the effective Hamiltonian\
\>", "TechNoteText",
 CellID->443996717,ExpressionUUID->"8de7806f-7445-4829-9cac-df6c2a8e2d38"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "\[CapitalOmega]", "\[VeryThinSpace]", 
      SuperscriptBox["S", "Z"]}], "+", 
     RowBox[{
      FractionBox["1", "2"], "\[CapitalDelta]", "\[VeryThinSpace]", 
      SuperscriptBox["S", "X"]}]}]}], TraditionalForm]],ExpressionUUID->
  "4e963e2a-56b4-4086-a70a-08b6eec9e0ff"]
}], "TechNoteText",
 CellID->955068142,ExpressionUUID->"e10d66e9-e28f-4312-935c-3e3bc0628484"],

Cell[TextData[{
 "and the quantum jump operators ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SqrtBox[
     SubscriptBox["\[CapitalGamma]", "\[PlusMinus]"]], 
    SuperscriptBox["S", "\[PlusMinus]"]}], TraditionalForm]],ExpressionUUID->
  "87d6deb9-b8b6-4f02-989a-30be27447445"],
 ". In the matrix form, the quantum master equation is given by"
}], "TechNoteText",
 CellID->722520673,ExpressionUUID->"b3849ec4-ea97-416d-9c48-a9140417ec48"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["d", 
      RowBox[{"d", "\[VeryThinSpace]", "t"}]], 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["\[Rho]", "11"]},
        {
         SubscriptBox["\[Rho]", "12"]},
        {
         SubscriptBox["\[Rho]", "21"]},
        {
         SubscriptBox["\[Rho]", "22"]}
       }], ")"}]}], "=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", GridBox[{
        {
         RowBox[{
          RowBox[{"-", "2"}], 
          SubscriptBox["\[CapitalGamma]", "-"]}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "\[CapitalDelta]"}], 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
          "\[CapitalDelta]"}], 
         RowBox[{"2", 
          SubscriptBox["\[CapitalGamma]", "+"]}]},
        {
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "\[CapitalDelta]"}], 
         RowBox[{
          RowBox[{"-", 
           SubscriptBox["\[CapitalGamma]", "-"]}], "-", 
          SubscriptBox["\[CapitalGamma]", "+"], "-", 
          RowBox[{
          "2", "\[ImaginaryI]", "\[VeryThinSpace]", "\[CapitalOmega]"}]}], 
         "0", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
          "\[CapitalDelta]"}]},
        {
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
          "\[CapitalDelta]"}], "0", 
         RowBox[{
          RowBox[{"-", 
           SubscriptBox["\[CapitalGamma]", "-"]}], "-", 
          SubscriptBox["\[CapitalGamma]", "+"], "+", 
          RowBox[{
          "2", "\[ImaginaryI]", "\[VeryThinSpace]", "\[CapitalOmega]"}]}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "\[CapitalDelta]"}]},
        {
         RowBox[{"2", 
          SubscriptBox["\[CapitalGamma]", "-"]}], 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
          "\[CapitalDelta]"}], 
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "\[CapitalDelta]"}], 
         RowBox[{
          RowBox[{"-", "2"}], 
          SubscriptBox["\[CapitalGamma]", "+"]}]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["\[Rho]", "11"]},
        {
         SubscriptBox["\[Rho]", "12"]},
        {
         SubscriptBox["\[Rho]", "21"]},
        {
         SubscriptBox["\[Rho]", "22"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "3eea6f65-935a-4495-8b81-a6645214bb46"]
}], "TechNoteText",
 CellID->866849901,ExpressionUUID->"c6e5b4a5-6f7d-4142-9dbe-fd755b5cd546"],

Cell[TextData[{
 "Imposing the conditions ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Rho]", "\[Dagger]"], "=", "\[Rho]"}], TraditionalForm]],
  ExpressionUUID->"e8e5f469-b505-4832-a19f-f1dd2f469397"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", "\[Rho]", "]"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"a38e76c0-8406-4d49-b956-f1dfa6d62f5a"],
 ", the above equation reads as"
}], "TechNoteText",
 CellID->348556883,ExpressionUUID->"8d315be3-4ba2-4c88-abd1-b8b515d64abd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["d", 
      RowBox[{"d", "\[VeryThinSpace]", "t"}]], 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["\[Rho]", "11"]},
        {
         RowBox[{"Re", "\[VeryThinSpace]", 
          SubscriptBox["\[Rho]", "21"]}]},
        {
         RowBox[{"Im", "\[VeryThinSpace]", 
          SubscriptBox["\[Rho]", "21"]}]}
       }], ")"}]}], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", GridBox[{
         {
          RowBox[{
           RowBox[{"-", "2"}], "\[CapitalGamma]"}], "0", "0"},
         {"0", 
          RowBox[{
           RowBox[{"-", "\[CapitalGamma]"}], "/", "2"}], 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], "\[ThinSpace]", 
           RowBox[{"\[CapitalGamma]", "/", "2"}]}]},
         {
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
           "\[CapitalDelta]"}], 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], "\[ThinSpace]", 
           "\[CapitalOmega]"}], 
          RowBox[{"-", "\[CapitalOmega]"}]}
        }], ")"}], 
      RowBox[{"(", GridBox[{
         {
          SubscriptBox["\[Rho]", "11"]},
         {
          RowBox[{"Re", "\[VeryThinSpace]", 
           SubscriptBox["\[Rho]", "21"]}]},
         {
          RowBox[{"Im", "\[VeryThinSpace]", 
           SubscriptBox["\[Rho]", "21"]}]}
        }], ")"}]}], "+", 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["\[CapitalGamma]", "+"]},
        {"0"},
        {
         RowBox[{"\[CapitalDelta]", "/", "2"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "e0021472-e1e5-42f5-b2f6-1b2b15878fd8"],
 " ,"
}], "TechNoteText",
 CellID->694839095,ExpressionUUID->"a877e581-3429-4eab-bf2e-b6a272f51585"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalGamma]", ":=", 
    RowBox[{
     SubscriptBox["\[CapitalGamma]", "+"], "+", 
     SubscriptBox["\[CapitalGamma]", "-"]}]}], TraditionalForm]],
  ExpressionUUID->"42ddcb93-1ada-4290-92af-9332f7c0cf28"],
 ". It is a typical inhomogeneous first-order differential equation and can \
be solved using the standard methods. If necessary, various numerical methods \
can also be applied.  This method is extensively discussed in Blum (2012) ."
}], "TechNoteText",
 CellID->966710621,ExpressionUUID->"3d88aa96-6136-4653-acfb-d923d9bfdaea"],

Cell[TextData[{
 "\tIn the above discussion, the constraints ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Rho]", "\[Dagger]"], "=", "\[Rho]"}], TraditionalForm]],
  ExpressionUUID->"75360271-6833-4fbc-b85c-773ca8f399a9"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "[", "\[Rho]", "]"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"696636ef-4712-4758-bf15-2cd1f65a2a75"],
 " have been handled in an ad hoc fashion. More systematic and efficient way \
is explained in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "271641c7-795a-4028-8700-c32cbef97750"],
 "."
}], "TechNoteText",
 CellID->1070338383,ExpressionUUID->"1100f37d-c7c3-4b3f-a9e7-37e2638da5bc"],

