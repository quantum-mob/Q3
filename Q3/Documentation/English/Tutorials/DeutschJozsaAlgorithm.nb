Cell["\<\
Here is a quantum circuit for the Deutsch-Jozsa algorithm. The final Hadamard \
gate on the third qubit is not necessary, but we put it here to make the \
output state more readable:\
\>", "TechNoteMathCaption",
 CellID->1904624712,ExpressionUUID->"c927d8d7-a5fb-4b1d-bc4c-c136922cfa77"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SS", "=", 
   RowBox[{"S", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", "$"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TT", "=", 
   RowBox[{"T", "@", 
    RowBox[{"{", "$", "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"all", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"SS", ",", "TT"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"Ket", "[", "SS", "]"}], ",", 
    RowBox[{"Ket", "[", 
     RowBox[{"TT", "->", "1"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Through", "[", 
     RowBox[{"all", "[", "6", "]"}], "]"}], ",", 
    RowBox[{"Oracle", "[", 
     RowBox[{"f", ",", "SS", ",", "TT"}], "]"}], ",", 
    RowBox[{"Through", "[", 
     RowBox[{"all", "[", "6", "]"}], "]"}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellLabel->"In[64]:=",
 CellID->636292402,ExpressionUUID->"06cb70c6-1e5e-4052-b320-02a5a8b96c5d"],

