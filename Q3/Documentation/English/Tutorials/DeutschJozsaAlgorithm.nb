Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". A quantum circuit for the Deutsch-Jozsa algorithm."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->197232399,ExpressionUUID->"bcd690f9-35b4-400f-95b2-983a9eb005ae"],

Cell["\<\
The Hadamard gates on the native register before the quantum oracle create a \
linear superposition of all the logical basis states of the n-qubit native \
register (normalization ignored)\
\>", "TechNoteText",
 CellID->73698941,ExpressionUUID->"62c96500-67b8-49f6-9ee5-43ef8b26272d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], "\[RightTeeArrow]", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     TemplateBox[{"x"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "00d55f6c-fbc0-4bb7-ae3c-21e9e572bb67"],
 "."
}], "TechNoteText",
 CellID->1707520715,ExpressionUUID->"13ca270b-3256-4106-b5ae-150d202a9644"],

Cell["\<\
Next, the quantum oracle induces the conditional phase shifts\
\>", "TechNoteText",
 CellID->1476682144,ExpressionUUID->"43954b16-7741-473b-8a21-4657ffc5b958"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     TemplateBox[{"x"},
      "Ket"]}], "\[RightTeeArrow]", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"x"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"f", "(", "x", ")"}]]}]}], TraditionalForm]],ExpressionUUID->
  "116ad9f9-a40c-4ccc-bff7-97561ae3da64"],
 " ."
}], "TechNoteText",
 CellID->128285829,ExpressionUUID->"6fe50cdc-eed3-416d-bb39-eea9f275afae"],

Cell["\<\
Another operation of the Hadamard gates shuffles and causes additional phase \
factors specific to the Hadamard gate, and it leads to the output state to be \
measured\
\>", "TechNoteText",
 CellID->26346415,ExpressionUUID->"fafa4118-9f3f-4c88-9f20-bbb1a3f7cbb8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"x"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"f", "(", "x", ")"}]]}], "\[RightTeeArrow]", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", "n"]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"y", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     TemplateBox[{"y"},
      "Ket"], 
     SuperscriptBox[
      RowBox[{
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"x", "=", "0"}], 
        RowBox[{
         SuperscriptBox["2", "n"], "-", "1"}]], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{
       RowBox[{"f", "(", "x", ")"}], "+", 
       RowBox[{"x", "\[CenterDot]", "y"}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"fd70957e-3986-48d4-9073-527bc975593d"],
 "."
}], "TechNoteText",
 CellID->422565623,ExpressionUUID->"122f955a-a54f-423e-abbc-0581e981b7f5"],

Cell[TextData[{
 "\tTo see the effect of the function ",
 StyleBox["f",
  FontSlant->"Italic"],
 " on the final state, suppose that ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "edc3751b-3302-4466-ac99-6e7e3dd6e886"],
 " is a constant function. Then, the output state is given by"
}], "TechNoteText",
 CellID->332005132,ExpressionUUID->"a7a0d5ff-7d66-48b8-8e4e-7b0f3d2f6fd7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"f", "(", "0", ")"}]], 
      SuperscriptBox["2", "n"]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"y", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     TemplateBox[{"y"},
      "Ket"], 
     SuperscriptBox[
      RowBox[{
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"x", "=", "0"}], 
        RowBox[{
         SuperscriptBox["2", "n"], "-", "1"}]], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"x", "\[CenterDot]", "y"}]]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"f", "(", "0", ")"}]], 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "12a5e8d3-3d0d-43d9-a350-ee98cb1fdaca"],
 "."
}], "TechNoteText",
 CellID->847738618,ExpressionUUID->"3cc71161-aa1f-453e-a44d-2045bdbeff0e"],

Cell[TextData[{
 "Every measurement on each of the ",
 StyleBox["n",
  FontSlant->"Italic"],
 " qubits should yield zero with unit probability."
}], "TechNoteText",
 CellID->1536438528,ExpressionUUID->"a8c8d880-05d2-410f-b8e4-adc82e6fb0bd"],

Cell[TextData[{
 "\tTo make the analysis more explicit, consider the probability to find the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b46e6f47-7d0a-4af5-8e3b-d9dc48596d28"],
 "-qubit register in the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"0"},
     "Ket"], "\[Congruent]", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", "\[CenterEllipsis]", "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "f65e443b-bbae-43f7-b674-adf8741cc598"]
}], "TechNoteText",
 CellID->1578968568,ExpressionUUID->"263a12d9-58d2-4146-a6f5-31aad1f4e4ed"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", "n"]], 
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       SuperscriptBox[
        RowBox[{
         UnderoverscriptBox["\[CapitalSigma]", 
          RowBox[{"x", "=", "0"}], 
          RowBox[{
           SuperscriptBox["2", "n"], "-", "1"}]], "(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"f", "(", "x", ")"}]], "\[RightBracketingBar]"}], "2"]}]}], 
   TraditionalForm]],ExpressionUUID->"77da87cc-611b-47ab-ac2e-3975c08d3aba"],
 "."
}], "TechNoteText",
 CellID->1269296397,ExpressionUUID->"ec23f6eb-6468-4547-9a71-3c541ae106d4"],

Cell[TextData[{
 "This assures that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "b39749e4-3c87-4ccf-b055-d34798356a67"],
 " for a constant function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "64e1c664-94a0-4bda-b125-cad6071d6be8"],
 ". When the function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "8e7d205a-ff19-4bb4-86e7-3cfdb4726bae"],
 " is balanced, there are as many terms with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Minus]", "1"}], TraditionalForm]],ExpressionUUID->
  "1afdd048-8e35-4fc6-b85c-339f7a2ebefe"],
 " as 1, and the sum is always zero. There must be at least one qubit in the \
state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8f8049f6-af04-4c86-87e5-f72569cab478"],
 " if the function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "609ff6d3-1898-43de-8c94-03704bf51764"],
 " is balanced. Therefore, to determine whether a given function ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "d99f01d9-273d-4056-a256-4347707fb071"],
 " is constant or balanced, one needs to run the quantum oracle just once, \
and then check whether the measurement outcome is 0. If the outcome is 0, \
then the function must be constant; and balanced otherwise."
}], "TechNoteText",
 CellID->2109478728,ExpressionUUID->"560a9fbc-bbcb-4910-8283-6ab43546c56c"]
}, Open  ]],

