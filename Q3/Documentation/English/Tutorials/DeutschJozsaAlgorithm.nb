     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"Text"}]],ExpressionUUID->
  "a38ff423-7e55-4c04-a862-7c70f3cd894b"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"c1657426-95c5-4270-bda9-4517b6501399"],

