     RowBox[{"{", 
      RowBox[{"1", ",", "0"}], "}"}], "]"}], "=", "1"}]}], ";"}]}], "Input",
 CellLabel->"In[50]:=",
 CellID->611471017,ExpressionUUID->"a6b0b4a3-6a05-4b0d-97bb-0eacd32954c6"],

Cell["\<\
Here is a quantum circuit for the Deutsch-Jozsa algorithm. The final Hadamard \
gate on the third qubit is not necessary, but we put it here to make the \
output state more readable:\
\>", "TechNoteMathCaption",
 CellID->1284131824,ExpressionUUID->"76bde1c2-1be2-447a-abd6-86f16bb015ec"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SS", "=", 
   RowBox[{"S", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "2"}], "}"}], ",", "$"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"TT", "=", 
   RowBox[{"T", "@", 
    RowBox[{"{", "$", "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"all", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"SS", ",", "TT"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"Ket", "[", "SS", "]"}], ",", 
    RowBox[{"Ket", "[", 
     RowBox[{"TT", "->", "1"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Through", "[", 
     RowBox[{"all", "[", "6", "]"}], "]"}], ",", 
    RowBox[{"Oracle", "[", 
     RowBox[{"f", ",", "SS", ",", "TT"}], "]"}], ",", 
    RowBox[{"Through", "[", 
     RowBox[{"all", "[", "6", "]"}], "]"}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellLabel->"In[53]:=",
 CellID->192913618,ExpressionUUID->"f41f419a-6a14-4c37-9bea-afb29fc1c776"],

