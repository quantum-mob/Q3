 CellID->530306869,ExpressionUUID->"ffbff50b-2afd-4d9b-8b46-141f427120da"],

Cell[TextData[{
 "Define the ",
 StyleBox["Dirac and Majorana spinors, respectively, ",
  FontSlant->"Italic"],
 "by"
}], "TechNoteText",
 CellID->1094791532,ExpressionUUID->"e432a68c-58fe-4417-9258-3a31d06b3f32"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["a", "_"], ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["a", "1"]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["a", "n"]},
       {
        SubsuperscriptBox["a", "1", "\[Dagger]"]},
       {"\[VerticalEllipsis]"},
       {
        SubsuperscriptBox["a", "n", "\[Dagger]"]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "fcb2451e-c09e-4ed1-b919-4d57dfa7cbfd"],
 ". \t",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", ":=", 
    RowBox[{"(", GridBox[{
       {
        SubscriptBox["c", "1"]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["c", "n"]},
       {
        SubscriptBox["c", 
         RowBox[{"n", "+", "1"}]]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["c", 
         RowBox[{"2", "n"}]]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "ab804281-6794-48da-9ea2-cb2b09eef7d0"],
 "."
}], "TechNoteText",
 CellID->1747941533,ExpressionUUID->"965ef36e-6398-4006-805d-06fb419b459a"],

Cell["The transformation between the two spinors are given by", "TechNoteText",
 CellID->473617434,ExpressionUUID->"c37a114b-ca2c-4849-865c-b428312dfaca"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["a", "_"], "=", 
    RowBox[{"D", "\[VeryThinSpace]", "c"}]}], TraditionalForm]],
  ExpressionUUID->"64d9b40a-a7eb-41ab-824f-1bf8814dc4fa"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"c", "=", 
    RowBox[{"M", "\[VeryThinSpace]", 
     UnderscriptBox["a", "_"]}]}], TraditionalForm]],ExpressionUUID->
  "2b80da9c-301b-4703-b6bb-130927097aba"],
 "."
}], "TechNoteText",
 CellID->2062792293,ExpressionUUID->"3bf73656-6b60-4ba7-81ee-23a198e5b135"],

Cell[TextData[{
 "For a single mode (",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "3d708827-558e-47c2-a73d-ed77705576fd"],
 "),"
}], "TechNoteText",
 CellID->1148268085,ExpressionUUID->"8fe82e86-9fcb-4d60-8548-b873ea8a4778"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"D", "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", GridBox[{
         {"1", 
          RowBox[{"+", "\[ImaginaryI]"}]},
         {"1", 
          RowBox[{"-", "\[ImaginaryI]"}]}
        }], ")"}]}], "=", 
     RowBox[{
      FractionBox["1", "2"], 
      SuperscriptBox["M", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"099f3036-4c32-4ae5-83e5-3cc04c816879"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"1", "1"},
        {
         RowBox[{"-", "\[ImaginaryI]"}], 
         RowBox[{"+", "\[ImaginaryI]"}]}
       }], ")"}], "=", 
     RowBox[{"2", 
      SuperscriptBox["D", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"d9ce90d5-aa3e-458e-b690-86f71c9b10d8"],
 " ."
}], "TechNoteText",
 CellID->1378857824,ExpressionUUID->"33acb6b6-47bb-464a-be44-faf6d19a0322"],

Cell[TextData[{
 "Note that matrices ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "dc97b752-45d7-42eb-a296-8e3f8c44af4c"],
 " and ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "81dd08d9-ab74-49cc-8903-92892782b677"],
 " are not unitary due to the pre-factors:"
}], "TechNoteText",
 CellID->396781122,ExpressionUUID->"9ca79dec-5644-4790-9615-b1da6cb23ed3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["D", "\[Dagger]"], "D"}], "=", 
    RowBox[{
     FractionBox["1", "2"], "I"}]}], TraditionalForm]],ExpressionUUID->
  "d928eac7-c41b-4749-bfc1-ce739d3a701c"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["M", "\[Dagger]"], "M"}], "=", 
    RowBox[{"2", "I"}]}], TraditionalForm]],ExpressionUUID->
  "bb14d216-9026-4227-82a9-205c4a1b2dba"],
 " ,\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"D", "\[VeryThinSpace]", "M"}], "=", 
    RowBox[{
     RowBox[{"M", "\[VeryThinSpace]", "D"}], "=", "I"}]}], TraditionalForm]],
  ExpressionUUID->"859258cb-48ee-432e-88ac-8199eb90eb99"],
