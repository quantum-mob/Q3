Cell["Related functions", "TechNoteCaption",
 CellID->673419754,ExpressionUUID->"1bcc4aa6-a6fc-4648-b733-b66b37390b74"],

Cell[TextData[{
 "Consider a many-body unitary operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["U", "^"], ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
      OverscriptBox["H", "^"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "90ec3463-1563-46b7-b15c-366b9289b875"],
 " governed by the above many-body Hamiltonian ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "61f89b8d-cf74-4d6e-b4b4-4bafa1981f22"],
 ". It represents the canonical transformations of the Dirac and Majorana \
spinors:"
}], "TechNoteText",
 CellID->808392804,ExpressionUUID->"50301928-b80a-4b89-a7ec-934e5b88bf8c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox[
      UnderscriptBox["a", "_"], "^"], "'"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["U", "^"], "\[Dagger]"], 
      OverscriptBox[
       UnderscriptBox["a", "_"], "^"], "\[VeryThinSpace]", 
      OverscriptBox["U", "^"]}], "=", 
     RowBox[{"U", 
      OverscriptBox[
       UnderscriptBox["a", "_"], "^"]}]}]}], TraditionalForm]],ExpressionUUID->
  "671fef7f-80c8-4778-9381-c892cf8280c0"],
 " ,\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     OverscriptBox["c", "^"], "'"}], ":=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       OverscriptBox["U", "^"], "\[Dagger]"], 
      OverscriptBox["c", "^"], "\[VeryThinSpace]", 
      OverscriptBox["U", "^"]}], "=", 
     RowBox[{"R", 
      OverscriptBox["c", "^"]}]}]}], TraditionalForm]],ExpressionUUID->
  "bed0e19e-e014-427b-892b-ef5675d3b21e"],
 " ."
}], "TechNoteText",
 CellID->1708574668,ExpressionUUID->"28bfb2c1-9576-4270-9a75-5d93350804fb"],

Cell[TextData[{
 "Here, the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "945013f6-6303-4a9c-9177-d3268f94c740"],
 " ",
 StyleBox["unitary",
  FontSlant->"Italic"],
 " matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", ":=", 
    RowBox[{"exp", "(", 
     RowBox[{
      RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "H"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"8421f746-c857-441d-b581-55a949f551a8"],
 " (the symbols refer to the matrices ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "0440df8b-a57f-452f-9e9e-7ab74b50b7c5"],
 " and ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "b2d54b35-16bf-4bb7-be29-bdece4e46db6"],
 "; not the many-body operators ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["U", "^"], TraditionalForm]],ExpressionUUID->
  "52e06389-a9ef-408a-8eb4-68ee739dd30e"],
 " and ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["H", "^"], TraditionalForm]],ExpressionUUID->
  "3ebbe125-b479-4802-8a84-6f0becf909bf"],
 ") represents the many-body unitary operator ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["U", "^"], TraditionalForm]],ExpressionUUID->
  "c01bd0fc-f155-4e5d-9e63-6f906d8c0ba7"],
 " in the space of Dirac spinors; in the same way, the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "5463027f-97ac-416b-9cdb-70c7fb9fccc8"],
 " ",
 StyleBox["real orthogonal",
  FontSlant->"Italic"],
 " matrix ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", ":=", 
    RowBox[{"exp", "(", "A", ")"}]}], TraditionalForm]],ExpressionUUID->
  "150242b9-dbc5-46ce-84a1-96234a2e71c0"],
 " represents ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["U", "^"], TraditionalForm]],ExpressionUUID->
  "bca47ae9-b72f-4783-a823-710f7dcafd9a"],
 " in the space of Majorana spinors. The two matrices are related to each \
other by"
}], "TechNoteText",
 CellID->866784807,ExpressionUUID->"dad7d24b-3147-45cd-ad45-8b6eac48f01d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"U", "=", 
    RowBox[{
     FractionBox["1", "2"], 
     SuperscriptBox["M", "\[Dagger]"], "R", " ", "M"}]}], TraditionalForm]],
  ExpressionUUID->"c2cef5c6-06af-483c-9fe8-17479f4e1a17"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{"2", 
     SuperscriptBox["D", "\[Dagger]"], "U", " ", "D"}]}], TraditionalForm]],
  ExpressionUUID->"829250bd-155c-4b90-b355-e11a4a891473"],
 " ."
}], "TechNoteText",
 CellID->42690027,ExpressionUUID->"6675e2ca-d00f-4545-8bc9-6c75227609e7"]
}, Open  ]],

