Cell["Related functions", "TechNoteCaption",
 CellID->1090222322,ExpressionUUID->"3cb8dba0-083b-405a-81bc-5860a00668fe"],

Cell[TextData[{
 "Any fermionic Gaussian state of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "bf9c929a-3114-456c-a2bf-c81f99d35bd1"],
 " fermion modes can be written as"
}], "TechNoteText",
 CellID->52239125,ExpressionUUID->"f34d0abf-8233-47d0-ac85-243b471e45c9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     FractionBox["\[ScriptCapitalN]", 
      SuperscriptBox["2", "n"]], 
     UnderoverscriptBox["\[CapitalPi]", 
      RowBox[{"k", "=", "1"}], "n"]}]}], TraditionalForm]],ExpressionUUID->
  "6b439305-2650-468f-a3f4-217e1030cbfd"],
 "(1+\[ImaginaryI]\[VeryThinSpace]",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Lambda]", "k"], 
     SubscriptBox["c", 
      RowBox[{
       RowBox[{"2", "k"}], "-", "1"}]], 
     SubscriptBox["c", 
      RowBox[{"2", "k"}]]}], ")"}], TraditionalForm]],ExpressionUUID->
  "4e996dcc-34e3-4266-b3a0-cd5be28cc381"],
 ","
}], "TechNoteText",
 CellID->596265470,ExpressionUUID->"edeb7e8b-9016-4ae8-b252-7ee05f8149ae"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "9819af61-85d2-45bf-986e-b96202f1046a"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", 
    RowBox[{"2", "n"}]}], TraditionalForm]],ExpressionUUID->
  "ff243c0a-4b61-433e-9b10-add9766d891e"],
 ") are Majorana fermion operators corresponding to the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "9cabb193-db1f-41cb-8197-ad89dc6b47f7"],
 " Dirac fermion modes, ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalN]", TraditionalForm]],ExpressionUUID->
  "e4534f5b-fec8-4ebd-9a26-dedc3c1084ca"],
 " is the norm square of the state (i.e., note that some quantum channels do \
not preserve the trace of the state and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "\[VeryThinSpace]", "\[Rho]"}], "=", "\[ScriptCapitalN]"}], 
   TraditionalForm]],ExpressionUUID->"9983c12e-968a-4e9b-a8f4-dc84f104f266"],
 "), and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[PlusMinus]", "\[ImaginaryI]"}], "\[VeryThinSpace]", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "4fdb255a-fce5-4a9a-b3e4-393b8809db06"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Lambda]", "k"], "\[Element]", 
    RowBox[{"[", 
     RowBox[{
      RowBox[{"-", "1"}], ",", "1"}], "]"}]}], TraditionalForm]],
  ExpressionUUID->"2dad3dfb-ce96-4828-a555-9746142c9533"],
 ") are eigenvalues of the ",
 StyleBox["covariance matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ae8628f1-6458-4450-ab02-4fcf78ffd5f3"],
 ", which is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "4e210236-9ead-4653-8999-82da50a8e63e"],
 " real anti-symmetric matrix (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["V", "T"], "=", 
    RowBox[{"-", "V"}]}], TraditionalForm]],ExpressionUUID->
  "a4c32f75-f2f0-4f85-8405-c6f384e3145e"],
 ") in the Majorana spinor space [",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
      StyleBox[{
        StyleBox["Bravyi", IgnoreSpellCheck -> True], " (2005)"}]]], 
    "https://dl.acm.org/doi/abs/10.5555/2011637.2011640"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "609c4371-77e4-41fa-b416-13bdc884ed58"],
 "]."
}], "TechNoteText",
 CellID->1791798107,ExpressionUUID->"9d2f1047-9405-43bf-b7b2-733e76dfe5cc"],

Cell[TextData[{
 "Introducing ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n"}], TraditionalForm]],ExpressionUUID->
  "eb7dab58-39ff-453a-962f-eb2f2d8d9564"],
 " ",
 ButtonBox["Grassmann variables",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Grassmann"],
 " ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "i"], TraditionalForm]],ExpressionUUID->
  "8fd82ac6-516f-4e65-af90-b62e05807f08"],
 " respectively corresponding to the Majorana modes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "i"], TraditionalForm]],ExpressionUUID->
  "606da3d1-9db5-4c70-966b-3acb30d668c3"],
 ", the fermionic Gaussian state reads as"
}], "TechNoteText",
 CellID->1331370085,ExpressionUUID->"9d79ef12-cb94-4875-8265-e26e6d97fe94"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "\[DotEqual]", 
    RowBox[{
     FractionBox["\[ScriptCapitalN]", 
      SuperscriptBox["2", "n"]], 
     RowBox[{"exp", "(", 
      RowBox[{
       FractionBox["\[ImaginaryI]", "2"], 
       UnderoverscriptBox["\[CapitalSigma]", 
        RowBox[{"i", ",", 
         RowBox[{"j", "=", "1"}]}], 
        RowBox[{"2", "n"}]], 
       SubscriptBox["x", "i"], 
       SubscriptBox["V", 
        RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
       SubscriptBox["x", "j"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c9789fb9-8bd3-48c4-9887-dfcd46199123"],
 " ,"
}], "TechNoteText",
 CellID->1331597561,ExpressionUUID->"e79e459e-0597-4f66-a086-25c0fc625759"],

Cell[TextData[{
 "expressed directly in terms of the covariance matrix ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "2c5e6bce-64ba-4bcd-932c-c3c39c23f43a"],
 " [",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData[
      StyleBox[{
        StyleBox["Bravyi", IgnoreSpellCheck -> True], " (2005)"}]]], 
    "https://dl.acm.org/doi/abs/10.5555/2011637.2011640"},
   "WebLink",
   BaseStyle->{"Notes"}]],ExpressionUUID->
  "da4c2452-6666-4c04-b7da-e039cfc8b1a7"],
 "]."
}], "TechNoteText",
 CellID->1941127793,ExpressionUUID->"78d7ddff-0253-449f-8ee0-d0098e5e9fc0"],

Cell[TextData[{
 "The ",
 StyleBox["covariance matrix",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "ea68d0b2-c6b1-4738-9f08-04353ede8973"],
 " is related to the matrix ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "959ae126-6e5d-425d-a1f3-91a1a6df0ede"],
 " of ",
 ButtonBox["Green\[CloseCurlyQuote]s functions",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BravyiGreen"],
 " by"
}], "TechNoteText",
 CellID->1077220984,ExpressionUUID->"b80b690c-c77f-44e2-873c-97ec3b73708b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"D", "(", 
       RowBox[{"I", "-", 
        RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "V"}]}], ")"}], 
      SuperscriptBox["D", "\[Dagger]"]}], "=", 
     RowBox[{
      FractionBox["1", "4"], 
      RowBox[{
       SuperscriptBox["M", "\[Dagger]"], "(", 
       RowBox[{"I", "-", 
        RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]\[VeryThinSpace]", "V"}]}], 
       ")"}], "M"}]}]}], TraditionalForm]],ExpressionUUID->
  "f92cb58f-2632-40e9-88dd-b6011913eec6"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"I", "-", 
     RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "V"}]}], "=", 
    RowBox[{
     RowBox[{"M", "\[VeryThinSpace]", "G", "\[VeryThinSpace]", 
      SuperscriptBox["M", "\[Dagger]"]}], "=", 
     RowBox[{"4", 
      SuperscriptBox["D", "\[Dagger]"], "G", " ", "D"}]}]}], 
   TraditionalForm]],ExpressionUUID->"f1bd8f11-ed63-49f1-9687-61ef5eaaf1fc"],
 " ."
}], "TechNoteText",
 CellID->1523081043,ExpressionUUID->"d04641f6-7989-4908-99ce-0319f32ce712"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["G", TraditionalForm]],ExpressionUUID->
  "41a99e49-9b70-45bc-a4d0-74982113a888"],
 " is the Green\[CloseCurlyQuote]s functions matrix is in the ",
 ButtonBox["block form",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/NambuGreen"],
 "\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"G", ":=", 
    RowBox[{"(", GridBox[{
       {"g", "f"},
       {
        SuperscriptBox["f", "\[Dagger]"], 
        RowBox[{"I", "-", 
         SuperscriptBox["g", "T"]}]}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8f751493-cf25-41ed-9a31-aee250ce7818"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["g", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubsuperscriptBox["a", "j", "\[Dagger]"]}], "\[RightAngleBracket]"}]}], 
   TraditionalForm]],ExpressionUUID->"629b5344-18a9-4195-8dc9-1ad99451f33b"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", 
     RowBox[{"i", "\[VeryThinSpace]", "j"}]], ":=", 
    RowBox[{"\[LeftAngleBracket]", 
     RowBox[{
      SubscriptBox["a", "i"], 
      SubscriptBox["a", "j"]}], "\[RightAngleBracket]"}]}], TraditionalForm]],
  ExpressionUUID->"be3d9733-d24d-46b0-94e0-66a030d4123a"],
 " ."
}], "TechNoteText",
 CellID->1295337644,ExpressionUUID->"e818e41e-403c-48ca-9b7a-6680255ead41"]
}, Open  ]]
}, Open  ]],

