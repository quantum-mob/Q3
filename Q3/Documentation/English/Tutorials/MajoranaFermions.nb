Cell[TextData[{
 StyleBox["Majorana fermions",
  FontSlant->"Italic"],
 ", also known as Majorana particles, are a class of fermions that are their \
own antiparticles. This unique property distinguishes them from ",
 StyleBox["Dirac fermions",
  FontSlant->"Italic"],
 ", which have distinct particles and antiparticles. The concept was first \
proposed by Italian physicist ",
 StyleBox["Ettore",
  IgnoreSpellCheck->True],
 " Majorana in 1937."
}], "TechNoteText",
 CellID->672067415,ExpressionUUID->"139bb2f9-3056-4623-a048-96b8399006ba"],

