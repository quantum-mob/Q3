      Cell[
       TextData["Fermion"]], "paclet:QuantumMob/Q3/ref/Fermion", 
      "QuantumMob Package Symbol"},
     "PackageLink",
     BaseStyle->{"DefinitionBox", CellFrame -> 0}], Cell[
    "Represents Dirac fermions", "TechNoteTableText",ExpressionUUID->
     "517b5e6e-100f-4d41-a3ff-37b26c1999b9"]}
  }]], "DefinitionBox",
 CellID->1820544332,ExpressionUUID->"41ae569e-e948-45c7-bf89-fa4e7c975a93"],

