     SuperscriptBox["M", "\[Dagger]"], "\[Gamma]", " ", "M"}]}], 
   TraditionalForm]],ExpressionUUID->"adced316-2fa5-4d2f-8061-c33cc566c892"],
 "  ,\t\t",
