 CellID->1701787266,ExpressionUUID->"479efe0b-330c-454a-b1ac-0f8ac08735c2"],

Cell["Consider a many-body Hamiltonian", "TechNoteText",
 CellID->430066759,ExpressionUUID->"8f6f0d5b-136d-477c-94cc-b75f4fa93e45"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], ":=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      SubscriptBox["\[CapitalSigma]", 
       RowBox[{"i", ",", "j"}]], 
      SuperscriptBox[
       UnderscriptBox["a", "_"], "\[Dagger]"], 
      SubscriptBox["H", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
      SubscriptBox[
       OverscriptBox["a", "^"], "j"]}], "=", 
     RowBox[{
      FractionBox["\[ImaginaryI]", "4"], 
      SubscriptBox["\[CapitalSigma]", 
       RowBox[{"i", ",", "j"}]], 
      SubscriptBox[
       OverscriptBox["c", "^"], "i"], 
      SubscriptBox["A", 
       RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
      SubscriptBox[
       OverscriptBox["c", "^"], "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "0a438777-cfe3-4658-af7e-ef09d82adfbd"],
 " ,"
}], "TechNoteText",
 CellID->1414119016,ExpressionUUID->"c34be427-7101-4033-b821-35a28e11b5d8"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "23e4fcb1-cb0e-43b0-aaf5-3e2d53fbd8c1"],
 " is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n", " "}], TraditionalForm]],
  ExpressionUUID->"971aef9e-718b-4fca-b140-ba052cf5bf4c"],
 StyleBox["Hermitian",
  FontSlant->"Italic"],
 " matrix and ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "fc87dfdf-6015-4c14-88bc-11028b7b3699"],
 " is a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "n", "\[Times]", "2", "n"}], TraditionalForm]],ExpressionUUID->
  "94e17d9d-b906-4e47-ae83-41281a8653a8"],
 " real ",
 StyleBox["anti-symmetric",
  FontSlant->"Italic"],
 " matrix. Here, the many-body operators are denoted by hatted symbols; not \
to be confused with matrices denoted by pristine upper-case letters. Because \
of the explicit factors, the relation between ",
 Cell[BoxData[
  FormBox["H", TraditionalForm]],ExpressionUUID->
  "f2c26cd4-80a5-4ca8-a7bb-1c809c455962"],
 " and ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "8d429bad-7b38-4849-9ad6-b3955dd68225"],
 " are slightly different:"
}], "TechNoteText",
 CellID->358077209,ExpressionUUID->"c7f6544c-0dca-46f7-903f-b92b40894e0f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "=", 
    RowBox[{
     FractionBox["\[ImaginaryI]", "2"], 
     SuperscriptBox["M", "\[Dagger]"], "A", " ", "M"}]}], TraditionalForm]],
  ExpressionUUID->"97935c74-a7b1-4829-9f45-38aff5b57c09"],
 " , \t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{
     RowBox[{"-", "2"}], "\[ImaginaryI]", " ", 
     SuperscriptBox["D", "\[Dagger]"], "H", " ", "D"}]}], TraditionalForm]],
  ExpressionUUID->"fd5cf4dc-852d-4858-a152-a585b1850fe7"],
 " ."
}], "TechNoteText",
 CellID->243940430,ExpressionUUID->"5ec3611b-eca1-4291-95a1-9f504ef3d488"]
}, Open  ]],

