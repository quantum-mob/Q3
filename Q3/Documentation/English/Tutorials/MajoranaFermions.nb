Cell[TextData[{
 "Consider a linear combination ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "i"], 
     SubscriptBox["\[Alpha]", "i"], 
     UnderscriptBox["a", "_"]}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "i"], 
     SubscriptBox["\[Gamma]", "i"], 
     SubscriptBox["c", "i"]}]}], TraditionalForm]],ExpressionUUID->
  "854d827d-deea-4653-881c-5ec9462c26f7"],
 " . Then, the two row vectors ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", ":=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["\[Alpha]", "1"], ",", 
      SubscriptBox["\[Alpha]", "2"], ",", "\[Ellipsis]"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"6ac831e9-5bdf-4fcc-a393-b2d604989f1f"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", ":=", 
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["\[Gamma]", "1"], ",", 
      SubscriptBox["\[Gamma]", "2"], ",", "\[Ellipsis]"}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"fd7e8e03-4ad0-405c-9cd7-921d2fc3ab8d"],
 " are related to each other by"
}], "TechNoteText",
 CellID->1501057669,ExpressionUUID->"45815bc5-8cb7-40ab-89be-4e22b0b8faf7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Alpha]", "=", 
    RowBox[{"\[Gamma]", "\[VeryThinSpace]", "M"}]}], TraditionalForm]],
  ExpressionUUID->"9d3aa7df-37ff-405f-8062-e04d5ae6319b"],
 " ,\t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Gamma]", "=", 
    RowBox[{"\[Alpha]", "\[VeryThinSpace]", "D"}]}], TraditionalForm]],
  ExpressionUUID->"eb942797-eeed-485b-9550-291ea00d9010"],
 " ."
}], "TechNoteText",
 CellID->1199058434,ExpressionUUID->"7cec3d21-8144-48dc-b8da-59f66f88173c"],

Cell[TextData[{
 "Consider a bilinear combination ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", "j"}]], 
     SubsuperscriptBox[
      UnderscriptBox["a", "_"], "i", "\[Dagger]"], 
     SubscriptBox[
      RowBox[{"\[Alpha]", "\[VeryThinSpace]"}], 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox[
      UnderscriptBox["a", "_"], "j"]}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalSigma]", 
      RowBox[{"i", ",", "j"}]], 
     SubscriptBox["c", "i"], 
     SubscriptBox["\[Gamma]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]], 
     SubscriptBox["c", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "8e2cec42-2bd3-48d8-918f-150bedaea614"],
 ". The two coefficients matrices ",
 Cell[BoxData[
  FormBox["\[Alpha]", TraditionalForm]],ExpressionUUID->
  "6400b8f8-59e3-43e4-9d53-415ef59b73cf"],
 " and ",
 Cell[BoxData[
  FormBox["\[Gamma]", TraditionalForm]],ExpressionUUID->
  "364bb612-a9c6-4fc8-bc69-053ec72845a2"],
 " are related with each other by"
}], "TechNoteText",
 CellID->1255090529,ExpressionUUID->"a2f74721-acf3-4dc5-8d33-933c5cad25a5"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
