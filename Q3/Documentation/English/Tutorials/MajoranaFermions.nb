Cell[CellGroupData[{

Cell["Conversion between Dirac and Majorana Fermions", "TechNoteSection",
 CellID->181417294,ExpressionUUID->"e0988127-0dc8-4b02-961f-c9d6fd764c06"],

Cell["\<\
Mathematically, any fermionic system may be describe in terms of either Dirac \
or Majorana fermions. Roughly, one may regard a Majorana fermion as a half of \
Dirac fermion; in other words, a Dirac fermion may be regarded to consist of \
two Majorana fermions.\
\>", "TechNoteText",
 CellID->1338494812,ExpressionUUID->"a0313033-1818-4aa5-adcd-ae8ec84c567b"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "1"], ",", "\[Ellipsis]", ",", " ", 
    SubscriptBox["a", "n"]}], TraditionalForm]],ExpressionUUID->
  "8266c2e8-cf3f-4a08-93fb-6633d2385ffe"],
 " be Dirac fermion modes, and suppose that  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "1"], ",", 
    SubscriptBox["c", "2"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["c", 
     RowBox[{
      RowBox[{"2", "n"}], "-", "1"}]], ",", 
    SubscriptBox["c", 
     RowBox[{"2", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "a6d7d45d-0298-428c-91c8-28470a63921b"],
 " be the corresponding Majorana modes. The transformation rules between \
Dirac fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["a", "k"], TraditionalForm]],ExpressionUUID->
  "e4e213a5-8216-4a6f-a835-3af6da9ffc86"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["a", "k", "\[Dagger]"], TraditionalForm]],ExpressionUUID->
  "fc509517-cf37-41f6-9a79-97a61fa67c80"],
 " and the Majorana fermion operators ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{
     RowBox[{"2", "k"}], "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "9ed6b760-a849-445c-a2bb-8d9fa286a722"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", 
    RowBox[{"2", "k"}]], TraditionalForm]],ExpressionUUID->
  "861a968f-e336-4744-ac6f-97ec678efc45"],
 " are given by"
}], "TechNoteText",
 CellID->1234513517,ExpressionUUID->"470b59f8-a508-4230-9107-6186ea6e6468"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "k"], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "+", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"2ee1a7a1-4494-4182-bed5-ecc6720d753a"],
 " ,  \t\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
     SubscriptBox["c", 
      RowBox[{"n", "+", "k"}]]}], ":=", 
    RowBox[{
     SubscriptBox["a", "k"], "-", 
     SubsuperscriptBox["a", "k", "\[Dagger]"]}]}], TraditionalForm]],
  ExpressionUUID->"c842094e-8afe-4da5-b39d-d19eab4b11af"],
 " ."
}], "TechNoteText",
 CellID->1790587256,ExpressionUUID->"207f584f-7c64-4f99-bc95-9abfb6b8e372"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["a", "k"], ":=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["c", "k"], "+", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["c", 
         RowBox[{"n", "+", "k"}]]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"41a453e9-e4b1-4e38-8235-491e4d35b195"],
 " ,\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["a", "k", "\[Dagger]"], ":=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["c", "k"], "-", 
       RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
        SubscriptBox["c", 
         RowBox[{"n", "+", "k"}]]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"77e8746d-5c8a-44dc-b49d-0d583c8bdef9"]
}], "TechNoteText",
 CellID->1562557471,ExpressionUUID->"48d160e5-cde6-4065-97c9-3fc4fbf2ae60"],

Cell[TextData[{
 "Note that the Majorana operators are normalized as \[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      SubscriptBox["c", "i"], ",", 
      SubscriptBox["c", "j"]}], "}"}], "=", 
    RowBox[{"2", 
     SubscriptBox["\[Delta]", 
      RowBox[{"i", "\[VeryThinSpace]", "j"}]]}]}], TraditionalForm]],
  ExpressionUUID->"348894da-444d-4388-b706-5be677aa3b83"],
 " ,    i.e.,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["c", "i", "2"], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"ba669246-d546-48c7-aff7-85ec8c96e324"],
 "."
}], "TechNoteText",
 CellID->1677403214,ExpressionUUID->"bdbb6053-8ab7-4d1c-9977-d7f84be2c014"],

