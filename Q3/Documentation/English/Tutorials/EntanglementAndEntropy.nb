Cell[TextData[{
 "This shows the eigenvalues of the partial transposition of ",
 StyleBox["rho", "Input"],
 ". For p<1/3, all eigenvalues are positive and the positive partial \
transposition is satisfied. However, two of the eigenvalues get negative for \
p>1/3, and hence the state must be entangled."
}], "TechNoteMathCaption",
 CellID->1479676909,ExpressionUUID->"cda17d36-9d02-43ff-aef1-9f7d4476e979"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Evaluate", "@", 
    RowBox[{"ProperValues", "[", "new", "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"p", ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\"\<p\>\"", ",", "\"\<Eigenvalues\>\""}], "}"}]}], ",", 
   RowBox[{"PlotLegends", "->", "Automatic"}]}], "]"}]], "Input",
 CellLabel->"In[134]:=",
 CellID->1069177303,ExpressionUUID->"ba131a28-af16-47c6-957f-5c7b80f798b3"],

