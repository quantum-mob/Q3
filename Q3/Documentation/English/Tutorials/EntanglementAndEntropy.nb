Cell["\<\
We apply the positive partial transposition criterion to another example. \
Again, we first prepare two qubits in the singlet state.\
\>", "TechNoteMathCaption",
 CellID->1595665886,ExpressionUUID->"fe5acc50-74a0-42a0-be78-e1ede48c2402"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"singlet", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Ket", "[", 
       RowBox[{
        RowBox[{"S", "[", "2", "]"}], "->", "1"}], "]"}], "-", 
      RowBox[{"Ket", "[", 
       RowBox[{
        RowBox[{"S", "[", "1", "]"}], "->", "1"}], "]"}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}], "//", "KetRegulate"}]}]], "Input",
 CellLabel->"In[135]:=",
 CellID->580762266,ExpressionUUID->"9d84fd5e-468d-4442-bc16-5370b427b523"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      0, $CellContext`S[2, QuantumMob`Q3`$] -> 1|>]], "-", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      1, $CellContext`S[2, QuantumMob`Q3`$] -> 0|>]]}], 
  SqrtBox["2"]]], "Output",
 CellLabel->"Out[135]=",
 CellID->1343924278,ExpressionUUID->"b0920db2-308d-40a9-a259-16b7ecbb3524"]
}, Open  ]],

Cell[TextData[{
 "The state we are concerned with is a mixture of the singlet state and a \
fully polarized state, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", 
     TemplateBox[{"S"},
      "Ket"], 
     TemplateBox[{"S"},
      "Bra"]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "p"}], ")"}], 
     TemplateBox[{"00"},
      "Ket"], 
     TemplateBox[{"00"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "367af55d-a7ad-467b-a876-e0ca48a69554"],
 "."
}], "TechNoteMathCaption",
 CellID->558229047,ExpressionUUID->"ab467602-c142-4b14-990a-7e68ba38a79a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"rho", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"p", "*", 
     RowBox[{"Dyad", "[", 
      RowBox[{"singlet", ",", "singlet", ",", 
       RowBox[{"S", "@", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}]}]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "p"}], ")"}], 
     RowBox[{"Dyad", "[", 
      RowBox[{
       RowBox[{"Ket", "[", "]"}], ",", 
       RowBox[{"Ket", "[", "]"}], ",", 
       RowBox[{"S", "@", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}]}]}], "]"}]}]}], "//", 
   "Elaborate"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rho", "//", "Matrix"}], "//", "Simplify"}], "//", 
  "MatrixForm"}]}], "Input",
 CellLabel->"In[136]:=",
 CellID->1947022833,ExpressionUUID->"c68a20d1-5be8-41a1-8be6-3b237e74128c"],

