Cell["\<\
Next, we consider the mixed state of qubits 1 and 3 that results from tracing \
out qubits 2 and 4.\
\>", "TechNoteMathCaption",
 CellID->1696411553,ExpressionUUID->"8bda9324-ceb8-412c-8602-889c7fdeed01"],

