Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". The probability ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "m"], TraditionalForm]],ExpressionUUID->
  "8e5a79c5-73d4-4691-98fe-19c148e303b3"],
 " for outcome ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "5f81e534-62b9-4200-be5b-f0e1559839f4"],
 " from the measurement of the total spin along the z-axis, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["S", "total", "z"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"j", "=", "1"}], "n"], 
     SubsuperscriptBox["S", "j", "z"]}]}], TraditionalForm]],ExpressionUUID->
  "b32d349c-8148-4ec3-ab91-b73167d69ea9"],
 ", on Alice\[CloseCurlyQuote]s qubits. The plot is for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "100"}], TraditionalForm]],ExpressionUUID->
  "72b9a166-67e9-4f3a-9573-7fda733118cf"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "=", 
    RowBox[{"3", "/", "5"}]}], TraditionalForm]],ExpressionUUID->
  "a1c30ffe-db2f-4465-85af-c54e405ccd32"],
 "."
}], "TechNoteCaption",
 CellID->72383131,ExpressionUUID->"714ebbac-d120-40e1-9f04-9c1fc0bee810"],

Cell[TextData[{
 "Next, Alice and Bob are to convert ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[CapitalPsi]", "m"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a3a62a3e-8c75-4058-8c11-b29cc184a39a"],
 " to independent copies of maximally entangled pairs.Suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"R", "\[TildeTilde]", 
     RowBox[{"(", GridBox[{
        {"n"},
        {
         RowBox[{"n", "\[VeryThinSpace]", "p"}]}
       }], ")"}]}], " ", "=", " ", 
    SuperscriptBox["2", "k"]}], TraditionalForm]],ExpressionUUID->
  "48237228-2101-4861-b1c2-7ae9ff85fa9d"],
 " for some integer ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "\[LessEqual]", "n"}], TraditionalForm]],ExpressionUUID->
  "bfa4be05-5574-4c97-97d6-0315bf1d9efa"],
 ". Then, recalling that"
}], "TechNoteText",
 CellID->2057390214,ExpressionUUID->"fc1061c4-9c5d-41dd-af14-5f26735e3bb7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     RowBox[{
      TemplateBox[{"x"},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{"x"},
       "Ket"]}]}], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CircleTimes]", 
      RowBox[{"j", "=", "1"}], "n"], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SubscriptBox[
         TemplateBox[{"0"},
          "Ket"], "j"], "\[CircleTimes]", 
        SubscriptBox[
         TemplateBox[{"0"},
          "Ket"], 
         RowBox[{"n", "+", "j"}]]}], "+", 
       RowBox[{
        SubscriptBox[
         TemplateBox[{"1"},
          "Ket"], "j"], "\[CircleTimes]", 
        SubscriptBox[
         TemplateBox[{"1"},
          "Ket"], 
         RowBox[{"n", "+", "j"}]]}]}], ")"}]}]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "8864b280-ba5b-48d0-9d23-fc1dfeabb469"],
 " ,"
}], "TechNoteText",
 CellID->598994750,ExpressionUUID->"d4c589f9-a10d-426c-a563-e3838f6741eb"],

Cell[TextData[{
 "it is possible to transform the state to ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "dfb170e5-37eb-4c9c-9e16-f9af0851d7bc"],
 " copies of maximally entangled pairs. To do that, both Alice and Bob \
perform a transformation bringing the ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "k"], TraditionalForm]],ExpressionUUID->
  "8c4e1ee8-08e5-4e32-b395-c99776101bea"],
 "-dimensional support of her and his respective density operators to the \
Hilbert space of ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "642b1271-a27f-40cf-ac33-c7432382767d"],
 " qubits."
}], "TechNoteText",
 CellID->1016520641,ExpressionUUID->"47f96d03-ad1c-4307-9107-24d669379afd"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->2109771456,ExpressionUUID->"69123951-0e7c-4cef-9ba0-bd36434f7392"],

Cell["\<\
Here, we start with a number of partially entangled pairs and \
\[OpenCurlyDoubleQuote]distills\[CloseCurlyDoubleQuote] a smaller number of \
maximally entangled pairs.\
\>", "TechNoteText",
 CellID->444601366,ExpressionUUID->"f33b4c6e-4c4b-4c86-ac7b-8f031483f470"],

Cell["\<\
We have two parties Alice (A) and Bob (B). Teddy (T)  is an ancillary \
register to perform a measurement of the total Pauli Z.\
\>", "TechNoteText",
