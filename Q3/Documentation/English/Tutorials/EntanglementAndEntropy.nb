Cell[TextData[{
 StyleBox["Remark",
  FontWeight->"Bold"],
 ": So, we have successfully generated two maximally entangled pairs from \
four partially entangled pairs. Note that this was possible because we \
assumed that the measurement outcome was ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "3"}], TraditionalForm]],ExpressionUUID->
  "4b5077f0-993f-494a-a39d-d0d28f5377fd"],
 ". The case with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "46f591f0-e0ee-4d93-bc58-a0a8998feb23"],
 " is also handled following a similar procedure."
}], "TechNoteText",
 CellID->862841207,ExpressionUUID->"9e8d9f60-c440-4ee1-aee9-fd2ca0129d5b"],

Cell[TextData[{
 "However, if the measurement outcome is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "2"}], TraditionalForm]],ExpressionUUID->
  "2925ddf8-d33c-48f9-850b-9c87a7685e71"],
 ", resulting in the post-measurement state"
}], "TechNoteText",
 CellID->719303896,ExpressionUUID->"2db10d10-555e-4ece-9ad1-bd7b8db7de76"],

