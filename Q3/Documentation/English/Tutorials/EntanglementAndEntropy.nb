   QuantumMob`Q3`CNOT[{$CellContext`A[2, QuantumMob`Q3`$] -> 1}, {
     $CellContext`B[2, QuantumMob`Q3`$]}], 
   QuantumMob`Q3`CNOT[{$CellContext`A[3, QuantumMob`Q3`$] -> 1}, {
     $CellContext`B[3, QuantumMob`Q3`$]}], 
   QuantumMob`Q3`CNOT[{$CellContext`A[4, QuantumMob`Q3`$] -> 1}, {
     $CellContext`B[4, QuantumMob`Q3`$]}], "Separator", 
   QuantumMob`Q3`CNOT[{$CellContext`B[1, QuantumMob`Q3`$] -> 1}, {
     $CellContext`T[1, QuantumMob`Q3`$]}], 
