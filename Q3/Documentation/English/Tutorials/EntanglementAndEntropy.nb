Cell[CellGroupData[{

Cell["Quantum Entanglement", "TechNoteSection",
 CellID->1806116627,ExpressionUUID->"e3b3e346-2e3c-4ddc-8c7c-4746b3f39643"],

Cell[TextData[{
 "We consider a composite system ",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "\[VeryThinSpace]", "B"}], TraditionalForm]],ExpressionUUID->
  "134e2b66-e232-48a3-b61f-42185a1ba368"],
 " consisting of two subsystems ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "e553ae98-2829-486d-882e-f61cbd54e313"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "35b22c85-f51a-4c48-9a04-a1bd36fad8ea"],
 ". The two systems are associated with the Hilbert space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "24b14ba9-95ae-4944-b038-1936987509ea"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "6e1e3cc2-1e2d-487e-aa11-bd7e0dff1971"],
 ", respectively. We suppose that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["v", "i"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "974dabff-8b28-447b-a6fc-4b9f500ba1c5"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["w", "j"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "63b87367-aef8-434a-b1e2-c7ae180aa340"],
 " are orthonormal bases of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "8f0b8622-9e1b-4315-8b32-3039c74e2d9a"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "4def4cda-84ae-4a6f-9b63-2d94548c9fb1"],
 ", respectively. We often use the shorthand notation ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{
        SubscriptBox["v", "i"], 
        SubscriptBox["w", "j"]}]},
     "Ket"], "\[Congruent]", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["v", "i"]},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["w", "j"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "5810a0d6-c9f3-4092-8ee4-86223dd991e6"],
 " for the tensor-product basis states. Entanglement across more than two \
parties is also an important subject, but here we will only discuss bipartite \
case."
}], "TechNoteText",
 CellID->2070110766,ExpressionUUID->"193b9cd6-39d7-4a54-9d80-ba83d4c14e97"],

Cell[TextData[{
 "Suppose that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "88d3504e-656e-4ea4-a4e0-093fc49585c4"],
 " is a pure state of the composite system. ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "565e2254-5853-4347-9dd9-3d2ad2254fe0"],
 " is a separable state if it can be written in a product form"
}], "TechNoteText",
 CellID->969079115,ExpressionUUID->"c807fd5d-2090-455a-9494-be034527f69c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"], 
     RowBox[{"A", "\[VeryThinSpace]", "B"}]], "=", 
    RowBox[{
     SubscriptBox[
      TemplateBox[{"\[Alpha]"},
       "Ket"], "A"], "\[CircleTimes]", 
     SubscriptBox[
      TemplateBox[{"\[Beta]"},
       "Ket"], "B"]}]}], TraditionalForm]],ExpressionUUID->
  "18d3f29b-1edb-4071-9986-b72b780e4c65"],
 " ."
}], "TechNoteText",
 CellID->796706957,ExpressionUUID->"f21d1913-8f0e-4144-8f48-5fc4f03cd53f"],

Cell["Otherwise, it is an entangled state.", "TechNoteText",
 CellID->693287254,ExpressionUUID->"4fd748e9-21e4-4972-837d-a5d71e5cf148"],

Cell[TextData[{
 "As for mixed states, the separability allows not only product states but \
also any convex linear combination of product states. In other words, a mixed \
state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "4f29144b-c23b-4587-b9ab-e8db3a6dae9e"],
 " of the composite system is said to be separable if it can be written in \
the form"
}], "TechNoteText",
 CellID->1980093003,ExpressionUUID->"ec359590-0874-4e23-a7cd-43fd681198cd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", 
     RowBox[{"A", "\[VeryThinSpace]", "B"}]], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     SubscriptBox["p", "j"], 
     RowBox[{
      SubscriptBox["\[Rho]", "j"], "\[CircleTimes]", 
      SubscriptBox["\[Sigma]", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "55ee8e8f-145b-4468-a21a-82a1075c95b7"],
 " ,"
}], "TechNoteText",
 CellID->2016507509,ExpressionUUID->"a0cfa7be-5f02-49da-bf22-944685e91bdc"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "j"], TraditionalForm]],ExpressionUUID->
  "673c1ac4-519f-4bdd-9545-1eda04e32cdb"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "j"], TraditionalForm]],ExpressionUUID->
  "5302429c-9fda-40f8-b84f-553fd9117cbb"],
 " are density operators on ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "10a475fa-c6a3-45c6-82c2-b09416d15672"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "e6f43d94-0bd5-4d58-b72f-4eee68542189"],
 ", respectively, and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    SubscriptBox["p", "j"], "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"edddedcc-1871-41a9-9e5d-3cb8551e9ad2"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalSigma]", "j"], " ", 
     SubscriptBox["p", "j"]}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "730fa39d-c8d4-460b-aa5f-d6babe801ff5"],
 ". If not, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "81bbbf44-fb3a-41a1-8fac-f89f76a45dba"],
 " is said to be entangled."
}], "TechNoteText",
 CellID->2002270456,ExpressionUUID->"9e5676d7-676d-491a-bac4-c13c16b73f78"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Separability Tests", "TechNoteSection",
 CellID->16197061,ExpressionUUID->"d075f0d6-b4da-4220-b10a-0c9f8c350cd1"],

Cell[TextData[{
 "Given a quantum state, how can we tell if it is separable or entangled? For \
pure states, the ",
 ButtonBox["Schmidt decomposition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchmidtDecomposition"],
 " provides a straightforward method. See Appendix A.6.1 of the Quantum \
Workbook for details."
}], "TechNoteText",
 CellID->1160144395,ExpressionUUID->"8b66e24c-86cc-4f47-b93a-9f89e06e4656"],

Cell["\<\
For a mixed state, there is no simple method available to check if it is \
separable or entangled. Here, we introduce a few well-known methods.\
\>", "TechNoteText",
 CellID->1664280286,ExpressionUUID->"31933449-56e9-47db-b19c-210c78a9c44c"],

Cell[TextData[{
 "A powerful method is to use the ",
 ButtonBox["partial transposition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PartialTranspose"],
 " (Appendix B.4 of the Quantum Workbook). It was discovered by Peres (1996) \
and has inspired many other methods for separability tests of mixed states. \
Let ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "4f098de9-cb36-4cea-ab17-3e2f0146b7e8"],
 " be a linear operator on the composite system consisting of subsystems ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "fc2431be-06be-4a00-b63d-a958ffb8860f"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "fda4d953-4b93-4151-b869-e28d5e0513ad"],
 ". In the standard tensor-product basis, the partial transposition of ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "17a727a4-14ce-4362-9615-d60a52ffe256"],
 " with respect to ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "4cb72ff7-feb2-4b44-9717-86bbeb8d991f"],
 " is defined by the relation"
}], "TechNoteText",
 CellID->540639510,ExpressionUUID->"5c6af483-7c5e-435f-aa06-6470464f6e27"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{
       RowBox[{
         SubscriptBox["v", "i"], 
         SubscriptBox["w", "j"]}]},
      "Bra"], 
     SuperscriptBox["L", 
      SubscriptBox["T", "B"]], 
     TemplateBox[{
       RowBox[{
         SubscriptBox["v", "k"], 
         SubscriptBox["w", "l"]}]},
      "Ket"]}], "=", 
    RowBox[{
     TemplateBox[{
       RowBox[{
         SubscriptBox["v", "i"], 
         SubscriptBox["w", "l"]}]},
      "Bra"], "L", 
     TemplateBox[{
       RowBox[{
         SubscriptBox["v", "k"], 
         SubscriptBox["w", "j"]}]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "28b12c0c-b7ab-46ae-b863-ffadeca9a0ac"],
 " ."
}], "TechNoteText",
 CellID->1781469575,ExpressionUUID->"7a740597-9d1d-4d57-96e8-ade055d9d844"],

Cell[TextData[{
 "The partial transposition ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["L", 
    SubscriptBox["T", "A"]], TraditionalForm]],ExpressionUUID->
  "dac2ee4c-be36-4d7c-b88c-8a44123158b8"],
 " of ",
 Cell[BoxData[
  FormBox["L", TraditionalForm]],ExpressionUUID->
  "eb4eeee5-e6a2-4fbe-93ff-d96c6124a43a"],
 " with respect to ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "7841654d-3f3f-4079-8bb2-c09eca2e9a57"],
 " is defined analogously."
}], "TechNoteText",
 CellID->1447152504,ExpressionUUID->"d58c77f2-c39f-4bc0-8e2a-aae3eaab749c"],

Cell[TextData[{
 "The so-called ",
 StyleBox["positive partial transposition",
  FontSlant->"Italic"],
 " criterion states that if ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "581a1d77-0425-466f-83a2-dd01a3ee852f"],
 " is separable, then the partial transposition ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}], 
    SubscriptBox["T", "B"]], TraditionalForm]],ExpressionUUID->
  "27720155-b283-4eeb-aa07-c996493a7b3c"],
 " of \[Rho] is positive. As an example, consider a Werner state,"
}], "TechNoteText",
 CellID->1439207393,ExpressionUUID->"d2bfd87f-541a-48f5-bfd4-b2f68e49f2b8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", 
     RowBox[{"A", "\[VeryThinSpace]", "B"}]], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", "4"], 
      RowBox[{"I", "\[CircleTimes]", "I"}]}], "-", 
     RowBox[{
      FractionBox["p", "4"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"X", "\[CircleTimes]", "X"}], "+", 
        RowBox[{"Y", "\[CircleTimes]", "Y"}], "+", 
        RowBox[{"Z", "\[CircleTimes]", "Z"}]}], ")"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"21dc7bba-2321-42e7-a5af-2725e7095de0"],
 " ."
}], "TechNoteText",
 CellID->489561613,ExpressionUUID->"ff7e392a-38e5-4bc9-a7ed-8c262847101f"],

Cell[TextData[{
 "The partial transposition of it with respect to ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "bff433ff-4c55-40ed-b601-fe18269dfaec"],
 " is given by"
}], "TechNoteText",
 CellID->96823284,ExpressionUUID->"7a8d39cb-02f8-4fd3-a7c0-c5f5c7674002"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Rho]", 
     RowBox[{"A", "\[VeryThinSpace]", "B"}], 
     SubscriptBox["T", "B"]], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["1", "4"], 
       RowBox[{"I", "\[CircleTimes]", 
        SuperscriptBox["I", "T"]}]}], "-", 
      RowBox[{
       FractionBox["p", "4"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"X", "\[CircleTimes]", 
          SuperscriptBox["X", "T"]}], "+", 
         RowBox[{"Y", "\[CircleTimes]", 
          SuperscriptBox["Y", "T"]}], "+", 
         RowBox[{"Z", "\[CircleTimes]", 
          SuperscriptBox["Z", "T"]}]}], ")"}]}]}], "=", 
     RowBox[{
      RowBox[{
       FractionBox["1", "4"], 
       RowBox[{"I", "\[CircleTimes]", "I"}]}], "-", 
      RowBox[{
       FractionBox["p", "4"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"X", "\[CircleTimes]", "X"}], "-", 
         RowBox[{"Y", "\[CircleTimes]", "Y"}], "+", 
         RowBox[{"Z", "\[CircleTimes]", "Z"}]}], ")"}]}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"9e9ea542-2f49-4143-8663-f03b8758d997"],
 " ."
}], "TechNoteText",
 CellID->647715504,ExpressionUUID->"27454105-da42-4552-8976-97ea4d1473b4"],

Cell[TextData[{
 "A direct inspection of the eigenvalues of ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}], 
    SubscriptBox["T", "B"]], TraditionalForm]],ExpressionUUID->
  "922e5c0b-a528-475d-97ea-29005459e642"],
 " reveals that for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", ">", 
    RowBox[{"1", "/", "3"}]}], TraditionalForm]],ExpressionUUID->
  "0a6dbe2a-22d8-45af-b2f4-5b02051e7e75"],
 ", two of the eigenvalues become negative. The positive partial \
transposition criterion is violated and the state must be an entangled \
state."
}], "TechNoteText",
 CellID->1890660720,ExpressionUUID->"7b8b69a0-b2f0-49fd-9977-0c82999c4f07"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->801529410,ExpressionUUID->"9162d71f-4b18-4332-88cc-5eb13718586d"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[127]:=",
 CellID->1949828751,ExpressionUUID->"5e81c847-b613-4a30-a720-84c817159ed8"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[128]:=",
 CellID->1554508183,ExpressionUUID->"fd1970f8-4c32-4029-93bf-2ec2154d500d"],

Cell["\<\
We consider a Werner state, and apply the positive partial transposition \
criterion.\
\>", "TechNoteMathCaption",
 CellID->2079525641,ExpressionUUID->"08dfcc25-fb5c-41b3-a69f-e9d0d720d3ab"],

Cell["We first prepare two qubits in the singlet state.", \
"TechNoteMathCaption",
 CellID->291093362,ExpressionUUID->"1a41181d-0cda-4775-9b58-e4de58c5e1a8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"singlet", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Ket", "[", 
       RowBox[{
        RowBox[{"S", "[", "2", "]"}], "->", "1"}], "]"}], "-", 
      RowBox[{"Ket", "[", 
       RowBox[{
        RowBox[{"S", "[", "1", "]"}], "->", "1"}], "]"}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}], "//", "KetRegulate"}]}]], "Input",
 CellLabel->"In[129]:=",
 CellID->438387268,ExpressionUUID->"32b8d635-b16d-4174-b881-cc1458426d93"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      0, $CellContext`S[2, QuantumMob`Q3`$] -> 1|>]], "-", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      1, $CellContext`S[2, QuantumMob`Q3`$] -> 0|>]]}], 
  SqrtBox["2"]]], "Output",
 CellLabel->"Out[129]=",
 CellID->767240185,ExpressionUUID->"31508243-4d5c-41b3-b389-f98298b5e95a"]
}, Open  ]],

Cell["\<\
A Werner state is a convex linear superposition of the single state and the \
completely random mixture.\
\>", "TechNoteMathCaption",
 CellID->2105904066,ExpressionUUID->"92b6b6a4-4df2-4bed-98cf-7af22ce5129d"],

Cell[CellGroupData[{

