Cell[TextData[{
 "In general, ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "cfe6c800-9795-4cc5-a9fa-95ebd6241dd3"],
 " is not close to a power of 2. However, one can increase the chance by \
dividing the entire pairs into ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],ExpressionUUID->
  "26f9f446-1ae2-4a72-af3e-150807e4ea8c"],
 " blocks of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "898ee5de-f7a8-4c35-b17a-45db374400a6"],
 " pairs. Alice perform the previously prescribed measurement on each block. \
Then, the total Schmidt rank becomes"
}], "TechNoteText",
 CellID->1084388470,ExpressionUUID->"eb347e72-8575-42bd-b26f-b970acaab021"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[TildeTilde]", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"n"},
        {
         SubscriptBox["m", "1"]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {"n"},
        {
         SubscriptBox["m", "2"]}
       }], ")"}], 
     RowBox[{"\[Ellipsis]", "(", GridBox[{
        {"n"},
        {
         SubscriptBox["m", "l"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "b64595ce-0673-40d0-b156-7fa08507028b"]
}], "TechNoteText",
 CellID->997581878,ExpressionUUID->"1d79f59b-9508-495a-b86a-bdb0a746fcdc"],

Cell[TextData[{
 "with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["m", "j"], "\[TildeTilde]", 
    RowBox[{"n", "\[VeryThinSpace]", "p"}]}], TraditionalForm]],
  ExpressionUUID->"4afd3f4a-9758-4f6e-956a-5991b99e1c99"],
 " for every ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "fb25d296-6dca-42b4-8feb-c3b2d4b5d2cc"],
 ". For some ",
 Cell[BoxData[
  FormBox["l", TraditionalForm]],ExpressionUUID->
  "03c63ae5-f406-436f-8df0-5a008a4bc3b7"],
 ", ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "c022c381-68c3-425d-84f9-d3b4e12a83b1"],
 " now approaches ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "k"], TraditionalForm]],ExpressionUUID->
  "8ed6b9f1-d452-4e8a-851d-fcc892100997"],
 "."
}], "TechNoteText",
 CellID->1555869737,ExpressionUUID->"1a116cca-e101-4de1-b255-9122809bcba6"],

Cell[TextData[{
 "How many maximally entangled pairs can one extract from ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[VeryThinSpace]", "l"}], TraditionalForm]],ExpressionUUID->
  "7736ae7f-07ac-48ff-8d31-2958a3f300a0"],
 " partially entangled pairs? Recall that for large ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "3c84f586-7d9b-47d9-a0e9-9ca2ab82344e"],
 ","
}], "TechNoteText",
 CellID->1057616090,ExpressionUUID->"c991a92c-484d-4c0f-9363-f886c589a251"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", GridBox[{
       {"n"},
       {"m"}
      }], ")"}], "\[TildeTilde]", 
    SuperscriptBox["2", 
     RowBox[{"n", "\[VeryThinSpace]", 
      RowBox[{"H", "(", 
       RowBox[{"m", "/", "n"}], ")"}]}]]}], TraditionalForm]],ExpressionUUID->
  "74087419-1c0a-4601-9ffa-342bc20df58f"],
 " ,"
}], "TechNoteText",
 CellID->1946641184,ExpressionUUID->"524c339a-d8d8-4043-ab07-bd368d0d0848"],

Cell["where", "TechNoteText",
 CellID->1969584389,ExpressionUUID->"1b4cb83e-ad23-4b80-939b-2bcecc98e7dc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", "(", "p", ")"}], ":=", 
    RowBox[{
     RowBox[{"H", "(", 
      RowBox[{"{", 
       RowBox[{"p", ",", 
        RowBox[{"1", "-", "p"}]}], "}"}], ")"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "p"}], "\[VeryThinSpace]", "log", "\[VeryThinSpace]", 
       "p"}], "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "p"}], ")"}], 
       RowBox[{"log", "(", 
        RowBox[{"1", "-", "p"}], ")"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"07cbf97c-9a4d-4721-bcaa-f597fdaa792c"]
}], "TechNoteText",
 CellID->1705342896,ExpressionUUID->"f94cc446-3487-49f9-a54c-ceb8aed11a44"],

Cell[TextData[{
 "is the ",
 ButtonBox["binary entropy function",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ShannonEntropy#1166102292"],
 ". Then, we have"
}], "TechNoteText",
 CellID->727185565,ExpressionUUID->"b4bffd11-29ba-4713-9220-73d7f453dc97"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[TildeTilde]", 
    SuperscriptBox["2", 
     RowBox[{"n", "\[VeryThinSpace]", 
      RowBox[{"H", "(", "p", ")"}]}]], "\[TildeTilde]", 
    SuperscriptBox["2", "k"]}], TraditionalForm]],ExpressionUUID->
  "a4ace396-da29-4ef7-9dec-cb9e2f0987c1"],
 ","
}], "TechNoteText",
 CellID->1461439618,ExpressionUUID->"fe3f49a0-32a8-4b8e-9d5a-ac4449ee7d01"],

Cell[TextData[{
 "which implies that the ratio is governed by the ",
 ButtonBox["von Neumann entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/VonNeumannEntropy"]
}], "TechNoteText",
 CellID->262658372,ExpressionUUID->"7b36331c-79ea-4db5-ae8e-bd7177f37eec"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["k", 
     RowBox[{"n", "\[VeryThinSpace]", "l"}]], "=", 
    RowBox[{
     RowBox[{"H", "(", "p", ")"}], "=", 
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", "A"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"a35c0132-40bc-4513-ab3b-5c67f77372e9"],
 " ."
}], "TechNoteText",
 CellID->1345615970,ExpressionUUID->"5639824c-b1d6-4896-825f-52c77f465b9d"],

Cell[TextData[{
 "In the above demonstration, we have used a particular form of partially \
entangled state. However, the result holds true in general: Given ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "48ee126c-cad1-4f39-8805-461c75b13f90"],
 " copies of partially entangled pure state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "4c511558-d053-41c0-99b8-74e3b3227c6e"],
 ", one can extract at most ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["k", "max"], "=", 
    RowBox[{"n", "\[VeryThinSpace]", 
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", "A"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"2dcd1448-7ffa-4cea-ad91-96d437a47822"],
 " maximally entangled pairs. The ratio ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["k", "max"], "/", "n"}], TraditionalForm]],ExpressionUUID->
  "dda08ba9-8f01-4de0-827f-c3322c2a6b26"],
 " in the large ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "dad6b54d-49cd-4cb6-a129-4cf89716fdb5"],
 " limit thus characterizes to what extent the state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "4d274746-b18e-4fd4-b50b-20927d3a09b1"],
 " is entangled. Clearly, for pure state, it happens to be given by the ",
 ButtonBox["von Neumann entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/VonNeumannEntropy"],
 ". In the subsection, we will see that this is a good measure of \
entanglement for mixed states as well."
}], "TechNoteText",
 CellID->979372938,ExpressionUUID->"698776be-6f42-4b4f-a985-0518f9126c51"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entanglement Measures", "TechNoteSection",
 CellID->1685747456,ExpressionUUID->"6b17826a-da91-4886-93d5-4b60dc345164"],

Cell[TextData[{
 "For both operational purposes and fundamental reasons, it is desired to \
quantify entanglement in a quantum state. For a pure state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "285c7d4c-6875-495d-a658-39f6fff8a449"],
 ", the Schmidt decomposition"
}], "TechNoteText",
 CellID->1435781766,ExpressionUUID->"81e6e36b-803e-41f5-a379-c06ddb126f5c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"], 
     RowBox[{"A", "\[VeryThinSpace]", "B"}]], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[Alpha]", "j"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["\[Beta]", "j"]},
       "Ket"]}], 
     SubscriptBox["s", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "8279ad01-fe9d-4bf6-a3a7-ebcdcb5dcc18"]
}], "TechNoteText",
 CellID->417603626,ExpressionUUID->"e9d248c6-4bcb-47b2-856d-ce7c57274cff"],

Cell[TextData[{
 "is a good starting point. We see that the more uniformly the Schmidt values \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["s", "j"], "}"}], TraditionalForm]],ExpressionUUID->
  "7eec55a6-b56c-4c40-8095-bd7d9679a841"],
 " are distributed, the more extensive the entanglement is. Therefore, it is \
reasonable to quantify the entanglement of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "9d1fdad5-e8cc-482b-9723-72947efc975c"],
 " by the Shannon entropy ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "(", 
    RowBox[{"{", 
     SubscriptBox["s", "j"], "}"}], ")"}], TraditionalForm]],ExpressionUUID->
  "19df7516-552a-4798-928e-cdec3edaecdd"],
 " associated with the distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    SubscriptBox["s", "j"], "}"}], TraditionalForm]],ExpressionUUID->
  "a236a8e1-b9a5-45af-af2a-14a36690a83d"],
 ". Since it is identical to the von Neumann entropy of subsystems,"
}], "TechNoteText",
 CellID->1068353535,ExpressionUUID->"8929eb85-31ec-48d4-ba56-ebc22901b903"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     SubscriptBox["\[Rho]", "A"], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", "B"], ")"}], "=", 
     RowBox[{"H", "(", 
      RowBox[{"{", 
       SubscriptBox["s", "j"], "}"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"8b58ded2-9b43-49ea-bf04-4273ba654074"],
 " ,"
}], "TechNoteText",
 CellID->403454997,ExpressionUUID->"5eeee41f-d78a-428b-87fe-9f7f94a3f3b7"],

Cell["we define the entanglement measure by", "TechNoteText",
 CellID->94718716,ExpressionUUID->"22f50b6c-0e1f-441d-9169-927199303e83"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"E", ":=", 
    RowBox[{
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", "A"], ")"}], "=", 
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", "B"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"31c28136-44e1-46a1-8f78-3667a0fcdd52"],
 " ."
}], "TechNoteText",
 CellID->1978003913,ExpressionUUID->"c32c9a6c-5d34-4f20-96de-addc0318078d"],

Cell[TextData[{
 "It is called the ",
 StyleBox["entropy of entanglement",
  FontSlant->"Italic"],
 " or simply ",
 StyleBox["entanglement entropy",
  FontSlant->"Italic"],
 ". In the previous section, we have seen that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "(", 
    SubscriptBox["\[Rho]", "A"], ")"}], TraditionalForm]],ExpressionUUID->
  "efbdd7a3-af98-43fd-9d43-ad159279b146"],
 " also determines the entanglement distillation ratio for pure states. The \
initial idea to quantify entanglement was elevated by the view of \
entanglement as a resource for quantum communication. Since a maximally \
entangled state can quantum teleport one qubit, it is natural to compare the \
given state with the maximally entangled state. Many entanglement measures \
are based on this idea. The most common examples are the ",
 StyleBox["distillable entanglement",
  FontSlant->"Italic"],
 " and ",
 StyleBox["entanglement cost",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->489860684,ExpressionUUID->"23b590d6-241c-4862-9765-06d787f4779b"],

Cell[TextData[{
 "The ",
 StyleBox["distillable entanglement ",
  FontSlant->"Italic"],
 "arises in the situation that we have already encountered in the ",
 ButtonBox["previous section",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/EntanglementAndEntropy#2030356719"],
 ". There, we have considered only pure states. Now, consider a partially \
entangled mixed state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "bccd5b78-898c-4a78-a7dc-0cd689264f2f"],
 ". Suppose that Alice (",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b7708a06-b7a0-461f-b35e-cefe8bedf5dd"],
 ") and Bob (",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "9a394270-ba8c-4c51-a63b-bebdffe3f8fe"],
 ") share ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "e003b478-f9ee-4a44-80a5-50670a260385"],
 " copies of pairs with each in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "cb565366-76cb-4012-b6d1-04d5aea83799"],
 ". We ask what is the maximum number ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "max"], TraditionalForm]],ExpressionUUID->
  "67fb5f11-cc0a-451c-86ad-6c835d37a3bc"],
 " of maximally entangled pairs that can be extracted from the partially \
entangled pairs. The distillable entanglement is defined by the ratio,"
}], "TechNoteText",
 CellID->771528229,ExpressionUUID->"1a9432ac-6255-4b9a-9b19-c9c986e508c9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "D"], ":=", 
    RowBox[{
     SubscriptBox["k", "max"], "/", "n"}]}], TraditionalForm]],ExpressionUUID->
  "e595b2e6-4881-4116-a3fd-333a1daeefc8"]
}], "TechNoteText",
 CellID->1170732630,ExpressionUUID->"8d1e629c-93a0-4fc9-bd53-c1815a70abba"],

Cell[TextData[{
 "in the large ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b20bc734-0b86-4561-b1ba-8edfdf4733e8"],
 " limit."
}], "TechNoteText",
 CellID->1157513038,ExpressionUUID->"8d0403f3-fcbd-483e-8413-fbb5a4228c78"],

Cell[TextData[{
 "The ",
 StyleBox["entanglement cost",
  FontSlant->"Italic"],
 " arises in the opposite situation. Suppose that Alice and Bob share ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "dbfa76c3-ebe3-4243-a997-254b00e81f3b"],
 " maximally entangled pairs. Alice and Bob want to generate ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "1a138814-736d-4865-aca8-9265253731fa"],
 " pairs with each in a given state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "516c2498-b55a-468c-a2c5-140e7f1d5b6f"],
 ". We ask what is the minimum value ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["k", "min"], TraditionalForm]],ExpressionUUID->
  "72b27184-f41d-4c1e-b435-66b966d735f0"],
 " of ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "02dfb5b7-0942-4ef6-825c-7ab5ece1f86d"],
 "? We define the entanglement cost by"
}], "TechNoteText",
 CellID->193532442,ExpressionUUID->"41756ff8-62f7-459e-9d38-4bc08ef2535a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "C"], ":=", 
    RowBox[{
     SubscriptBox["k", "min"], "/", "n"}]}], TraditionalForm]],ExpressionUUID->
  "1b58a46b-e6c4-4bb4-bba7-81bcbdad6cd1"]
}], "TechNoteText",
 CellID->411487831,ExpressionUUID->"8f066ed4-f8b1-465d-b83b-5f05105dd0c8"],

Cell[TextData[{
 "in the large ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b5ce0cbd-b721-4a85-82ac-ca3e84df58bc"],
 " limit."
}], "TechNoteText",
 CellID->978632277,ExpressionUUID->"3c19cd5c-10af-4386-915f-9627dfd6998b"],

Cell["\<\
For pure states, both are identical to the entropy of entanglement,\
\>", "TechNoteText",
 CellID->1652403347,ExpressionUUID->"63be8d93-d724-4474-88c9-d4b6673a3a20"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "D"], "=", 
    RowBox[{
     SubscriptBox["E", "C"], "=", 
     RowBox[{"E", "=", 
      RowBox[{
       RowBox[{"S", "(", 
        SubscriptBox["\[Rho]", "A"], ")"}], "=", 
       RowBox[{"S", "(", 
        SubscriptBox["\[Rho]", "B"], ")"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"75bd9a01-430f-419f-b1d0-eb3fa8a7c642"],
 " ."
}], "TechNoteText",
 CellID->872063670,ExpressionUUID->"64c93a60-ad50-4284-abf8-ececec37e526"],

Cell[TextData[{
 "Unfortunately, for mixed state, both ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "D"], TraditionalForm]],ExpressionUUID->
  "95192d86-3d23-4a86-ae85-68243d337a35"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["E", "C"], TraditionalForm]],ExpressionUUID->
  "68b14981-78cb-466b-92ba-c5793b1e9f3b"],
 " are usually very difficult to\ncalculate."
}], "TechNoteText",
 CellID->392749243,ExpressionUUID->"a58c0644-0ac0-4e19-a3b4-ec8ca5813bed"],

Cell[TextData[{
 "Another noteworthy entanglement measure is the ",
 StyleBox["logarithmic negativity",
  FontSlant->"Italic"],
 ". It is inspired by the positive partial transposition criterion in the \
\[OpenCurlyDoubleQuote]",
 ButtonBox["Separability Tests",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/EntanglementAndEntropy#16197061"],
 "\[CloseCurlyDoubleQuote] section, and defined by"
}], "TechNoteText",
 CellID->1500889045,ExpressionUUID->"3d182dda-8dac-4722-bffc-11bc95ec8364"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["E", "N"], ":=", 
    RowBox[{"log", "\[VeryThinSpace]", 
     SubscriptBox[
      RowBox[{"\[LeftDoubleBracketingBar]", 
       SubsuperscriptBox["\[Rho]", 
        RowBox[{"A", "\[VeryThinSpace]", "B"}], 
        SubscriptBox["T", "B"]], "\[RightDoubleBracketingBar]"}], "tr"]}]}], 
   TraditionalForm]],ExpressionUUID->"a45a5751-851b-4c9e-85f8-2a83f671c98f"]
}], "TechNoteText",
 CellID->1102527195,ExpressionUUID->"b301c1fc-bd7d-42ec-9e46-af0063cd8f6f"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DoubleVerticalBar]", 
    RowBox[{"\[CenterDot]", 
     SubscriptBox["\[DoubleVerticalBar]", "tr"]}]}], TraditionalForm]],
  ExpressionUUID->"6fe99334-1b48-4d75-8789-927f1689c683"],
 " denotes the ",
 ButtonBox["trace norm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/TraceNorm"],
 ". Unlike other entanglement measures for mixed states, the logarithmic \
negativity is easy to evaluate. However, it does not reduce to the entropy of \
entanglement for all pure states."
}], "TechNoteText",
 CellID->1846629461,ExpressionUUID->"9c2bec3e-81d0-48ec-838a-552801b8debc"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1739091054,ExpressionUUID->"4a3bd42a-0343-447b-b37d-357256b9f7c3"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[190]:=",
 CellID->1966570133,ExpressionUUID->"def014a8-3220-4201-93f0-47fa02a1be8d"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[191]:=",
 CellID->223414354,ExpressionUUID->"a9247d20-4b28-4bc4-9f1e-b00df077dff9"],

Cell[TextData[{
 "The entanglement measures for mixed states enable to investigate \
multi-partite entanglement. As an example, we consider the control and target \
registers each of which is consisting of ",
 StyleBox["n",
  FontSlant->"Italic"],
 " qubits and use the ",
 StyleBox["logarithmic negativity",
  FontSlant->"Italic"],
 " to characterize the multi-partite entanglement in the system."
}], "TechNoteMathCaption",
 CellID->1172321909,ExpressionUUID->"04681e28-7a2e-4fb4-bdc0-9ba3cf7ca0e8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cc", "=", 
   RowBox[{"Range", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"$n", "+", "cc"}]}], ";"}]}], "Input",
 CellLabel->"In[192]:=",
 CellID->309908362,ExpressionUUID->"e222b7b3-410a-4a5c-a66c-8d6f55768699"],

Cell["\<\
We generate a quantum state with a maximally entanglement between the control \
and target registers.\
\>", "TechNoteMathCaption",
 CellID->669563673,ExpressionUUID->"01c2f0d5-0c8e-4187-a04b-c20a26706f9e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"cc", ",", "6"}], "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Sequence", "@@", 
     RowBox[{"MapThread", "[", 
      RowBox[{"CNOT", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"S", "[", "cc", "]"}], ",", 
         RowBox[{"S", "[", "tt", "]"}]}], "}"}]}], "]"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"\"\<Invisible\>\"", "->", 
     RowBox[{"S", "[", 
      RowBox[{"$n", "+", 
       RowBox[{"1", "/", "2"}]}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[195]:=",
 CellID->981996159,ExpressionUUID->"05d77248-6c79-4628-ac78-aa9353497dd3"],

Cell[BoxData[
 InterpretationBox[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {4, -1}}, {{0, -2}, {4, -2}}, {{0, -4}, {4, -4}}, {{
     0, -5}, {4, -5}}}], {{
      {LightDarkSwitched[
        GrayLevel[1]], EdgeForm[Opacity[1]], 
       RectangleBox[{0.6, -1.4}, {1.4, -0.6}]}, InsetBox[
       StyleBox["\<\"H\"\>",
        StripOnInput->False,
        FontSize->Scaled[0.1],
        FontWeight->"Light",
        FontSlant->Italic], {1., -1.}, NCache[
       ImageScaled[{Rational[1, 2], Rational[1, 2]}], 
        ImageScaled[{0.5, 0.5}]], Automatic, {1, 0}]}, {
      {LightDarkSwitched[
        GrayLevel[1]], EdgeForm[Opacity[1]], 
       RectangleBox[{0.6, -2.4}, {1.4, -1.6}]}, InsetBox[
       StyleBox["\<\"H\"\>",
        StripOnInput->False,
        FontSize->Scaled[0.1],
        FontWeight->"Light",
        FontSlant->Italic], {1., -2.}, NCache[
       ImageScaled[{Rational[1, 2], Rational[1, 2]}], 
        ImageScaled[{0.5, 0.5}]], Automatic, {1, 0}]}}, {
     LineBox[{{2, -1}, {2, -4}}], 
     DiskBox[{2, -1}, 0.09], {CircleBox[{2, -4}, 0.26666666666666666], 
      LineBox[{{{1.7333333333333334`, -4}, {2.2666666666666666`, -4}}, {{
         2, -4.266666666666667}, {2, -3.7333333333333334`}}}]}}, {
     LineBox[{{3, -2}, {3, -5}}], 
     DiskBox[{3, -2}, 0.09], {CircleBox[{3, -5}, 0.26666666666666666], 
      LineBox[{{{2.7333333333333334`, -5}, {3.2666666666666666`, -5}}, {{
         3, -5.266666666666667}, {3, -4.733333333333333}}}]}}},
   ImagePadding->{{25.56, 25.56}, {7.2, 7.2}},
   ImageSize->190.79999999999998`,
   PlotRange->{{0, 4}, {-5.5, -0.5}},
   PlotRangePadding->Scaled[0.025]],
  QuantumMob`Q3`QuantumCircuit[{
    $CellContext`S[1, 6], 
    $CellContext`S[2, 6]}, 
   QuantumMob`Q3`CNOT[{$CellContext`S[1, QuantumMob`Q3`$] -> 1}, {
     $CellContext`S[3, QuantumMob`Q3`$]}], 
   QuantumMob`Q3`CNOT[{$CellContext`S[2, QuantumMob`Q3`$] -> 1}, {
     $CellContext`S[4, QuantumMob`Q3`$]}], "Invisible" -> $CellContext`S[
     Rational[5, 2]]]]], "Output",
 CellLabel->"Out[195]=",
 CellID->40927686,ExpressionUUID->"e59bc075-c91a-41d9-a53e-acdcff8039e4"]
}, Open  ]],

Cell["This is the desired state.", "TechNoteMathCaption",
 CellID->1365069196,ExpressionUUID->"95b7616c-25be-4fa8-850e-bfd58e5b9162"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"out", "=", 
  RowBox[{"qc", "**", 
   RowBox[{"Ket", "[", "]"}]}]}]], "Input",
 CellLabel->"In[196]:=",
 CellID->1546070097,ExpressionUUID->"6bfa123e-ab6f-443d-8435-8627bda578b4"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   FractionBox["1", "2"], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "3"}, "RowWithSeparators"]], 
            $CellContext`S[3, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "4"}, "RowWithSeparators"]], 
            $CellContext`S[4, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      0, $CellContext`S[2, QuantumMob`Q3`$] -> 
      0, $CellContext`S[3, QuantumMob`Q3`$] -> 
      0, $CellContext`S[4, QuantumMob`Q3`$] -> 0|>]]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "3"}, "RowWithSeparators"]], 
            $CellContext`S[3, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "4"}, "RowWithSeparators"]], 
            $CellContext`S[4, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      0, $CellContext`S[2, QuantumMob`Q3`$] -> 
      1, $CellContext`S[3, QuantumMob`Q3`$] -> 
      0, $CellContext`S[4, QuantumMob`Q3`$] -> 1|>]]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "3"}, "RowWithSeparators"]], 
            $CellContext`S[3, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["0", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "4"}, "RowWithSeparators"]], 
            $CellContext`S[4, QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
       "RowWithSeparators"]},
     "Ket"],
    Ket[<|$CellContext`S[1, QuantumMob`Q3`$] -> 
      1, $CellContext`S[2, QuantumMob`Q3`$] -> 
      0, $CellContext`S[3, QuantumMob`Q3`$] -> 
      1, $CellContext`S[4, QuantumMob`Q3`$] -> 0|>]]}], "+", 
  RowBox[{
   FractionBox["1", "2"], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "1"}, "RowWithSeparators"]], 
            $CellContext`S[1, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "2"}, "RowWithSeparators"]], 
            $CellContext`S[2, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
        SubscriptBox["1", 
         TemplateBox[{",", "\",\"", 
           InterpretationBox[
            SubscriptBox["S", 
             TemplateBox[{",", "\",\"", "3"}, "RowWithSeparators"]], 
            $CellContext`S[3, QuantumMob`Q3`$]]}, "RowWithSeparators"]], 
