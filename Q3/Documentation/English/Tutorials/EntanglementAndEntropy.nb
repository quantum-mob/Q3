Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1352100682,ExpressionUUID->"6171ee98-69ff-4892-b1d3-d86bc31acfcf"],

Cell[TextData[{
 "Unfortunately, the positive partial transposition is a necessary but not \
sufficient condition for separability. Nevertheless, it is a very strong \
condition and gives a good guide for separability of the quantum state in \
question. Moreover, it is a necessary and sufficient condition in the ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[CircleTimes]", "2"}], TraditionalForm]],ExpressionUUID->
  "0b5de4dd-43c0-4da1-8f11-0dbe8bdd37bb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[CircleTimes]", "3"}], TraditionalForm]],ExpressionUUID->
  "77f3914f-1eb9-4982-9ddc-c763cb887559"],
 " cases, that is, when ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"dim", "\[VeryThinSpace]", "V"}], "=", "2"}], TraditionalForm]],
  ExpressionUUID->"9a4d2bbb-e46e-41d3-a45c-3c98d877cf6a"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"dim", "\[VeryThinSpace]", "W"}], "=", "2"}], ",", "3"}], 
   TraditionalForm]],ExpressionUUID->"ca733e82-c9b6-400a-bc8a-528423e69eb1"],
 "."
}], "TechNoteText",
 CellID->1966719865,ExpressionUUID->"02c1f1ef-6097-45ff-9a17-745496bbae6c"],

Cell[TextData[{
 "Later, people realized that it was not by chance that the positive partial \
transposition criterion gives a strong necessary condition for separability. \
The crucial point is that the transposition, regarded as a supermap, is \
positive but not completely positive (Appendix B.4 of the Quantum Workbook). \
Let ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "0e15bd24-4c75-4706-8e56-38ace5ed8296"],
 " be the transposition supermap, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", ":", 
    RowBox[{"A", "\[RightArrow]", " ", 
     SuperscriptBox["A", "T"], " "}]}], TraditionalForm]],ExpressionUUID->
  "23a3283b-c504-473d-93dc-ec3c398ea538"],
 ". Then, the partial transposition corresponds to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalI]", "\[CircleTimes]", " ", "\[ScriptCapitalF]"}], 
   TraditionalForm]],ExpressionUUID->"cb9f4a3e-3cb2-4f91-9e9b-4f770a7fb0f5"],
 " (or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalF]", "\[CircleTimes]", "\[ScriptCapitalI]"}], 
   TraditionalForm]],ExpressionUUID->"274bf786-a568-49c6-b480-81cb6477f23b"],
 "). It turns out that any positive but not completely positive supermap ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "d3bf3945-fcfa-4a15-979d-ff70aae7e45b"],
 " gives rise to a necessary condition for separability. If ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "6e759798-c0b7-4632-b130-04accff51c52"],
 " is separable, then ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
     "\[ScriptCapitalI]", "\[CircleTimes]", " ", "\[ScriptCapitalF]"}], ")"}], 
    RowBox[{"(", 
     SubscriptBox["\[Rho]", 
      RowBox[{"A", "\[VeryThinSpace]", "B"}]], ")"}]}], TraditionalForm]],
  ExpressionUUID->"7bde52b6-72d6-4e11-9633-4aa4eec1bea9"],
 " must be positive."
}], "TechNoteText",
 CellID->592476431,ExpressionUUID->"966f3462-6d38-46dd-a712-38306b04eced"],

Cell[TextData[{
 "We now introduce the method based on ",
 StyleBox["entanglement witness",
  FontSlant->"Italic"],
 ". An observable ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "be40fb56-2ef9-4b58-b9b4-d0141913dae1"],
 " is called an entanglement witness if it has at least one negative \
eigenvalue and satisfies"
}], "TechNoteText",
 CellID->327013166,ExpressionUUID->"62dfcf3d-6ec7-40ca-8902-827513f1c80e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"\[Alpha]"},
        "Bra"], "\[CircleTimes]", 
       TemplateBox[{"\[Beta]"},
        "Bra"]}], ")"}], 
     RowBox[{"W", "(", 
      RowBox[{
       TemplateBox[{"\[Alpha]"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{"\[Beta]"},
        "Ket"]}], ")"}]}], "\[GreaterEqual]", "0"}], TraditionalForm]],
  ExpressionUUID->"abcf7c63-f222-422f-9ade-a094912fec43"]
}], "TechNoteText",
 CellID->510621316,ExpressionUUID->"5ea2d84e-b855-406b-963e-6f1f0b164423"],

Cell[TextData[{
 "for all pure states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Alpha]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "94f677c2-f0d9-485e-8985-d65f330d4137"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Beta]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f1baf09a-e9d8-48b6-b23b-e08a9cfa4195"],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "e9bcf47e-8735-49f1-891d-4dd86fbd4107"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "e47311ff-b437-43e5-9e4d-b017e5f70195"],
 ", respectively. A quantum state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "37cd12fb-6b38-4671-88c1-558f8f561499"],
 " is a separable state if"
}], "TechNoteText",
 CellID->496166250,ExpressionUUID->"026a2487-e7b1-4b1d-8b7b-9049e9bd431c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "\[VeryThinSpace]", "[", 
     RowBox[{"W", "\[VeryThinSpace]", 
      SubscriptBox["\[Rho]", 
       RowBox[{"A", "\[VeryThinSpace]", "B"}]]}], "]"}], "\[GreaterEqual]", 
    "0"}], TraditionalForm]],ExpressionUUID->
  "1f04dc0b-852f-4b17-899a-737b49d2baee"]
}], "TechNoteText",
 CellID->1182165028,ExpressionUUID->"a2af66c8-36c7-40ba-a362-e057e078cd8a"],

Cell[TextData[{
 "for all entanglement witnesses. On the other hand, the entanglement of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "e820d67f-c953-4a0b-b8ee-c34198d29486"],
 " is detected by an entanglement witness ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "fbc387e6-90ae-4fee-bbdb-62c92a81f859"],
 " if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", "\[VeryThinSpace]", "[", 
     RowBox[{"W", "\[VeryThinSpace]", 
      SubscriptBox["\[Rho]", 
       RowBox[{"A", "\[VeryThinSpace]", "B"}]]}], "]"}], "<", "0"}], 
   TraditionalForm]],ExpressionUUID->"4072dd70-a676-49f3-9f8a-b67a5da13540"],
 ". This method works for a geometrical reason. The set of separable states \
is a convex subset in the entire Hilbert space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", "\[CircleTimes]", "\[ScriptCapitalW]"}], 
   TraditionalForm]],ExpressionUUID->"5d68b996-5d32-4d9d-9ef7-61bbed12e9ef"],
 " and can be described by hyperplanes. An entanglement witness represents a \
hyperplane."
}], "TechNoteText",
 CellID->514871296,ExpressionUUID->"8ea7591f-c4d7-4823-a4ea-2de9975d901f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entanglement Distillation", "TechNoteSection",
 CellID->2030356719,ExpressionUUID->"e6b83ab2-ed40-4fdc-acbc-40f69dad0bbf"],

Cell["\<\
Suppose that Alice and Bob share a pair of entangled but not maximally \
entangled state. By now they are separated far way and no quantum channel is \
available. Luckily, they can still communicate through a classical channel. \
Is it possible for them to transform their partially entangled state to a \
maximally entangled state? The answer is no. Local operations and classical \
communications (often called LOCC) cannot generate or increase entanglement.\
\>", "TechNoteText",
 CellID->1320424964,ExpressionUUID->"fe72db8b-8beb-41c0-bb9b-5f79e5646fdf"],

Cell[TextData[{
 "Now, suppose that they have a large number n of copies of a partially \
entangled state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f27238ca-0039-4553-890a-9b41da99ec4f"],
 ". Although they cannot transform each pair to a maximally entangled state, \
they can extract a smaller number ",
 Cell[BoxData[
  FormBox["k", TraditionalForm]],ExpressionUUID->
  "d5bd893c-5dc1-4c76-a280-4b925ed970f1"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "<", "n"}], TraditionalForm]],ExpressionUUID->
  "4f64c9e4-ae1d-4e23-89d8-9f6fa8026814"],
 ") of maximally entangled pairs. This is called the ",
 StyleBox["entanglement distillation",
  FontSlant->"Italic"],
 ". The entanglement distillation is not only useful for practical \
applications but also valuable for a fundamental reason. It can quantify \
entanglement. We will come back to this point later."
}], "TechNoteText",
 CellID->767908262,ExpressionUUID->"4294953d-fbce-479e-8988-6c7143f8a5cb"],

Cell[TextData[{
 "So, how can Alice and Bob extract maximally entangled pairs from partially \
entangled pairs using only local operations and classical communications? For \
an illustration, we follow ",
 StyleBox["Preskill",
  IgnoreSpellCheck->True],
 " (1998) and suppose that the state of each partially entangled pair is"
}], "TechNoteText",
 CellID->1127979163,ExpressionUUID->"eab673ba-3aa1-4b0e-8707-2a50b77e2639"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{"0"},
        "Ket"]}], 
      SqrtBox[
       RowBox[{"1", "-", "p"}]]}], "+", 
     RowBox[{
      RowBox[{
       TemplateBox[{"1"},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{"1"},
        "Ket"]}], 
      SqrtBox["p"]}]}]}], TraditionalForm]],ExpressionUUID->
  "0acf8294-bc2c-473f-9a7d-769b25123ff4"],
 " ."
}], "TechNoteText",
 CellID->1417859089,ExpressionUUID->"9745064c-5105-4dcc-af52-1f65f5e1f3c2"],

Cell[TextData[{
 "The overall state of the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b7a3639f-0d5d-4072-a987-2e6cd829a30b"],
 " pairs is given by"
}], "TechNoteText",
 CellID->427950084,ExpressionUUID->"84b0d009-25de-4ca6-ad70-620c318372ee"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"], 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{
         TemplateBox[{"0"},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{"0"},
          "Ket"]}], 
        SqrtBox[
         RowBox[{"1", "-", "p"}]]}], "+", 
       RowBox[{
        RowBox[{
         TemplateBox[{"1"},
          "Ket"], "\[CircleTimes]", 
         TemplateBox[{"1"},
          "Ket"]}], 
        SqrtBox["p"]}]}], ")"}], 
     RowBox[{"\[CircleTimes]", "n"}]]}], TraditionalForm]],ExpressionUUID->
  "0d7e1d4d-e762-4e00-bdb9-1c23605e29f3"],
 " ."
}], "TechNoteText",
 CellID->1383051164,ExpressionUUID->"c46778b3-e462-48d6-82b2-85abeb718949"],

Cell["\<\
The binomial expansion of the right-hand side of the above expression leads to\
\>", "TechNoteText",
 CellID->1450380629,ExpressionUUID->"0d19ed1f-8464-429c-9c05-40c70a1b455b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"], 
     RowBox[{"\[CircleTimes]", "n"}]], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"m", "=", "0"}], "n"], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{
         SubscriptBox["\[CapitalPsi]", "m"]},
        "Ket"], "\[VeryThinSpace]", "(", GridBox[{
         {"n"},
         {"m"}
        }], ")"}], 
      RowBox[{"1", "/", "2"}]], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "-", "p"}], ")"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"n", "-", "m"}], ")"}], "/", "2"}]], 
     SuperscriptBox["p", 
      RowBox[{"m", "/", "2"}]]}]}], TraditionalForm]],ExpressionUUID->
  "9514f3eb-7203-48ce-bef4-0d55210de8c7"],
 " ,"
}], "TechNoteText",
 CellID->1784372628,ExpressionUUID->"94660ed6-5d0a-4796-a050-624a8c93439a"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[CapitalPsi]", "m"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "24f5adfa-260a-44e6-afb6-a7d63a5af811"],
 " is an entangled state of the form"
}], "TechNoteText",
 CellID->671061954,ExpressionUUID->"0dc91142-d3dd-49c7-ac0e-d858e6bbe862"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[CapitalPsi]", "m"]},
     "Ket"], ":=", "\[VeryThinSpace]", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", GridBox[{
         {"n"},
         {"m"}
        }], ")"}], 
      RowBox[{
       RowBox[{"-", "1"}], "/", "2"}]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        TemplateBox[{
          RowBox[{"00", "\[Ellipsis]"}]},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{
          RowBox[{"00", "\[Ellipsis]"}]},
         "Ket"]}], "+", 
       RowBox[{
        TemplateBox[{
          RowBox[{"01", "\[Ellipsis]"}]},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{
          RowBox[{"01", "\[Ellipsis]"}]},
         "Ket"]}], "+", "\[Ellipsis]"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"4a081be8-5585-4580-aa76-abea3c8c828e"]
}], "TechNoteText",
 CellID->1661837831,ExpressionUUID->"25d77f24-bf54-4a5c-ba56-093043e0f4f8"],

Cell[TextData[{
 "with Schmidt rank ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{"(", GridBox[{
       {"n"},
       {"m"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "8f3444f0-11ac-497f-9812-459bef4d2442"],
 ", and each term has exactly ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "72e476c2-c2ff-4b20-adf5-2289e165a09c"],
 " of Alice\[CloseCurlyQuote]s (and Bob\[CloseCurlyQuote]s) qubits in state \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "c9f34527-832b-49d3-ad8f-d9b57790212c"],
 ". Now, Alice measures the total spin of her ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "7842b453-84b3-4657-880f-6a14df7e3173"],
 " qubits along the z-axis"
}], "TechNoteText",
 CellID->1670403177,ExpressionUUID->"57730476-b9ae-4554-ad5b-bd65b892ed15"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["S", "total", "z"], ":=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"j", "=", "1"}], "n"], 
     SubsuperscriptBox["S", "j", "z"]}]}], TraditionalForm]],ExpressionUUID->
  "68ac7051-ad1f-4af4-8ee0-7c9d4f470c21"],
 " ."
}], "TechNoteText",
 CellID->1815056494,ExpressionUUID->"a5599303-c05c-4153-9a5f-62efc6193fb5"],

Cell[TextData[{
 "The possible outcomes are ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"m", "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", "n"}], 
   TraditionalForm]],ExpressionUUID->"d22f4a49-2bcd-4816-ac6b-5ab154029596"],
 ". For each outcome ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "b73f2d02-a502-48b2-85f3-5bf6a8cdbd0c"],
 ", the post-measurement state is nothing but ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[CapitalPsi]", "m"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "92c41724-2eda-4e48-b6cc-a2faedfd7e28"],
 ". The probability for a particular outcome ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "0973f072-5478-46c0-a12a-76bedb69465b"],
 " is given by"
}], "TechNoteText",
 CellID->1904740098,ExpressionUUID->"8b9d2e8a-06e9-4cd6-a8a0-78c822c7a1e9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "m"], "=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"n"},
        {"m"}
       }], ")"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "-", "p"}], ")"}], 
      RowBox[{"n", "-", "m"}]], 
     SuperscriptBox["p", "m"]}]}], TraditionalForm]],ExpressionUUID->
  "292d08c7-70a8-40fd-bd7a-7c59f5c3e276"],
 " ."
}], "TechNoteText",
 CellID->2145473356,ExpressionUUID->"4571d2f4-6a35-44b8-b245-2f503e88394e"],

Cell[TextData[{
 "As illustrated in Figure 1, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "m"], TraditionalForm]],ExpressionUUID->
  "df8953c9-bea7-41c1-8153-2a7cccb802f4"],
 " has a sharp peak at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", 
    RowBox[{"n", "\[VeryThinSpace]", "p"}]}], TraditionalForm]],
  ExpressionUUID->"7098d652-9ef0-4d2b-95ca-3a34fed8bf53"],
 " for large ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "3afb0af7-6303-4c71-9041-114419602808"],
 ". Therefore, from now on, we will assume that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", 
    RowBox[{"n", "\[VeryThinSpace]", "p"}]}], TraditionalForm]],
  ExpressionUUID->"6b412940-3385-4956-bdc1-257b57fa0725"],
 "."
}], "TechNoteText",
 CellID->1496547366,ExpressionUUID->"ee763131-2b44-4427-8428-6bce1c2fd861"],

