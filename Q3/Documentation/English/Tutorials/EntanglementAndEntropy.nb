 RowBox[{"rho", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"p", "*", 
     RowBox[{"Dyad", "[", 
      RowBox[{"singlet", ",", "singlet", ",", 
       RowBox[{"S", "@", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}]}]}], "]"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", "p"}], ")"}], "/", "4"}]}], "//", "Elaborate"}]}], "\[IndentingNewLine]", 
 RowBox[{
