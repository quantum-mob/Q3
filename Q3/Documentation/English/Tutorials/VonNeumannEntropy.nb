Cell[TextData[{
 "Here is the von Neumann entropy of the density operator as a function of ",
 StyleBox["p",
  FontSlant->"Italic"],
 "."
}], "TechNoteMathCaption",
 CellID->984093601,ExpressionUUID->"4a99c469-f318-4729-b71f-d12a91d73fca"],

