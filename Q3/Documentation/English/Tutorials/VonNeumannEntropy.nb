Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1125413063,ExpressionUUID->"b163173b-28e3-4ad7-8f7c-e9989bb40763"],

Cell["\<\
A convex linear superposition of different quantum states gives rise to \
another quantum state,\
\>", "TechNoteText",
 CellID->231644519,ExpressionUUID->"f17735fa-fdfb-4556-afcd-3f1b86414e4e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     SubscriptBox["p", "j"], 
     SubscriptBox["\[Rho]", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "7986820d-c0fa-486b-a3c2-7cfa76f92b91"]
}], "TechNoteText",
 CellID->888432230,ExpressionUUID->"2f64b4ab-7dc4-44b5-a540-fc5863972f4b"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "j"], TraditionalForm]],ExpressionUUID->
  "f299316c-0e0b-4020-99e7-846b6a3152c1"],
 " are probabilities, that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    SubscriptBox["p", "j"], "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"e76ac0cb-993a-43f8-b080-7f25cff244e8"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Sum]", "j"], " ", 
     SubscriptBox["p", "j"]}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "49a0c522-2072-4357-ad70-123a6e13c91e"],
 ". Intuitively, we expect that the uncertainty about \[Rho] is larger than \
the average uncertainty of individual ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "j"], TraditionalForm]],ExpressionUUID->
  "96f6300f-2f10-447f-a657-2ee167e7d78f"],
 " because we are not only ignorant of each state ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "j"], TraditionalForm]],ExpressionUUID->
  "e1a353fa-170f-47a4-a2b9-d8ebe36b4b0d"],
 " but also of which of those states to be selected upon a random choice. \
This implies that the von Neumann entropy is a concave function of density \
operator,"
}], "TechNoteText",
 CellID->166635143,ExpressionUUID->"7aa30253-57a6-4995-a983-177eabfdc2ee"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     SubscriptBox["p", "j"], 
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", "j"], ")"}]}], "\[LessEqual]", 
    RowBox[{"S", "(", 
     RowBox[{
      SubscriptBox["\[Sum]", "j"], 
      RowBox[{
       SubscriptBox["p", "j"], 
       SubscriptBox["\[Rho]", "j"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"4165089f-d876-4a6e-8d73-69dca93590a2"],
 " ."
}], "TechNoteText",
 CellID->1193459346,ExpressionUUID->"174a3d28-9023-4099-958a-a6951a82347e"],

Cell[TextData[{
 "Following the above intuitive argument, we may add the ",
 ButtonBox["Shannon entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ShannonEntropy"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"H", "(", 
    RowBox[{"{", 
     SubscriptBox["p", "j"], "}"}], ")"}], TraditionalForm]],ExpressionUUID->
  "d6cf4d2c-6718-4c51-9c98-a1467d3f4ac0"],
 " to account for our ignorance of which to be selected from the ensemble of \
states \[Rho]. One can show that if the states \[Rho] are all distinguishable \
with certainty, then the addition of the contributions indeed gives the \
entropy of \[Rho]. In general, however, it overestimates the von Neumann \
entropy of \[Rho], and we have the inequality"
}], "TechNoteText",
 CellID->73675365,ExpressionUUID->"f3d488e7-53ac-4ea6-993a-d997d87e3513"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{
      SubscriptBox["\[Sum]", "j"], 
      RowBox[{
       SubscriptBox["p", "j"], 
       SubscriptBox["\[Rho]", "j"]}]}], ")"}], "\[LessEqual]", 
    RowBox[{
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "j"], 
      SubscriptBox["p", "j"], 
      RowBox[{"S", "(", 
       SubscriptBox["\[Rho]", "j"], ")"}]}], "+", 
     RowBox[{"H", "(", 
      RowBox[{"{", 
       SubscriptBox["p", "j"], "}"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"5bee3a85-0224-4622-958a-d530ccc7cc28"],
 " ."
}], "TechNoteText",
 CellID->950639876,ExpressionUUID->"d914a18a-2f6e-43a9-b37f-e2783cfe4ce8"],

Cell[TextData[{
 "To prove the above two inequalities rigorously, we would need more \
mathematical tools and entropic relations to be discussed below. Interested \
readers are encouraged to try Problem 7.6 of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "dd1ec651-8d44-498c-a6d4-1eda94ece23d"],
 " after we introduce required materials."
}], "TechNoteText",
 CellID->1193450438,ExpressionUUID->"ff2e5c72-cefe-41eb-85b9-9824f8ce892f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum Relative Entropy", "TechNoteSection",
 CellID->1419154497,ExpressionUUID->"e85c1382-97e8-4ee9-81fb-cb0fd3e749b0"],

Cell[CellGroupData[{

Cell["Definition", "Subsection",
 CellID->1493046244,ExpressionUUID->"e1478c2c-afb6-4e8c-a9f4-6406f54dbab8"],

Cell[TextData[{
 "We introduce the relative von Neumann entropy as the quantum counterpart of \
the ",
 ButtonBox["relative Shannon entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ShannonEntropy#240193879"],
 ". One can regard it as a measure of the closeness of two quantum states \
just as the ",
 ButtonBox["relative Shannon entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ShannonEntropy#240193879"],
 " is a measure of closeness of two classical probability distribution. \
However, like the ",
 ButtonBox["relative Shannon entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ShannonEntropy#240193879"],
 ", relative von Neumann entropy is of little use in its own right. Rather, \
it provides powerful mathematical techniques that can be employed to \
investigate various entropic quantities and relations."
}], "TechNoteText",
 CellID->775961692,ExpressionUUID->"0a5714e0-9bdf-4169-be04-efe9e6d2cf94"],

Cell[TextData[{
 "Let \[Rho] and \[Sigma] be two density operators on a vector space. We \
define the relative von Neumann entropy or simply ",
 StyleBox["relative entropy",
  FontSlant->"Italic"],
 " of \[Rho] to \[Sigma] by"
}], "TechNoteText",
 CellID->260405746,ExpressionUUID->"92874504-9060-40e4-b3a1-ec37c5d6765d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"Tr", "[", 
       RowBox[{
       "\[Rho]", "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "\[Rho]"}], 
       "]"}], "-", 
      RowBox[{"Tr", "[", 
       RowBox[{
       "\[Rho]", "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "\[Sigma]"}], 
       "]"}]}], "=", 
     RowBox[{
      RowBox[{"-", 
       RowBox[{"S", "(", "\[Rho]", ")"}]}], "-", 
      RowBox[{"Tr", "[", 
       RowBox[{
       "\[Rho]", "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "\[Sigma]"}], 
       "]"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "2668e572-efa7-419b-a596-289addc2be8a"],
 " ."
}], "TechNoteText",
 CellID->89979787,ExpressionUUID->"a3a4cf20-5463-4467-a71d-4230117c8f91"],

Cell["\<\
We have already explained how to calculate the first term. The second term is \
more complicated to calculate. One way is to use the spectral decomposition \
of \[Sigma]\
\>", "TechNoteText",
 CellID->1715528234,ExpressionUUID->"161390db-f62a-46dc-8b22-83bd3e1357ef"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "s"], 
     TemplateBox[{"s"},
      "Ket"], "s", 
     TemplateBox[{"s"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "9307d2e4-c8af-4fec-acac-4919879da43d"],
 " ,"
}], "TechNoteText",
 CellID->266811275,ExpressionUUID->"7a3e2a6e-94e3-4d07-a451-95f501018d82"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"s"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2dd58e55-5749-4ea5-90b3-80e2b0f491cb"],
 " is an eigenstate with eigenvalue ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "1719c62e-1e81-456c-837a-1e0791b3016d"],
 " of \[Sigma],"
}], "TechNoteText",
 CellID->1999750711,ExpressionUUID->"04ba35eb-3a59-4ac9-82d8-0625a9ccb92b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"S", "(", "\[Rho]", ")"}]}], "-", 
     RowBox[{
      UnderscriptBox["\[CapitalSigma]", "s"], 
      TemplateBox[{"s"},
       "Bra"], "\[Rho]", 
      TemplateBox[{"s"},
       "Ket"], "\[VeryThinSpace]", "log", "\[VeryThinSpace]", "s"}]}]}], 
   TraditionalForm]],ExpressionUUID->"d42a7ea4-f992-4473-881e-10f1f07e4237"],
 " ."
}], "TechNoteText",
 CellID->968821962,ExpressionUUID->"9376d2ae-432e-4362-a63d-7f797bf77570"],

Cell[TextData[{
 "We note that when an eigenvalue ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "e696dcd4-0fb2-4cbd-81ea-d13762e1f137"],
 " of \[Sigma] vanishes with the finite expectation value ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"s"},
     "Bra"], "\[Rho]", 
    TemplateBox[{"s"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "9f0c1a39-d709-4fcd-a3a8-96d1f42b699c"],
 ", the second term diverges to \[Infinity]. In general, the relative entropy \
diverges when the support of \[Rho] (i.e., the subspace belonging to non-zero \
eigenvalues) has a finite overlap with the null space of \[Sigma] (i.e., the \
subspace belonging to eigenvalue zero)."
}], "TechNoteText",
 CellID->309109044,ExpressionUUID->"869fa720-78a7-4eae-84de-c76a8ff83823"],

Cell["For example, consider the two quantum states", "TechNoteText",
 CellID->173919650,ExpressionUUID->"3cda41b6-24c7-4ff4-ad2e-751560f967f1"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["1", "2"], "I"}], "+", 
      RowBox[{
       FractionBox["1", "4"], "Z"}]}], "\[DotEqual]", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"3", "/", "4"}], "0"},
        {"0", 
         RowBox[{"1", "/", "4"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "380ba213-78f7-455e-a3cc-87e48a7216e9"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["1", "2"], "I"}], "+", 
      RowBox[{
       FractionBox["1", "4"], "X"}]}], "\[DotEqual]", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"1", "/", "2"}], 
         RowBox[{"1", "/", "4"}]},
        {
         RowBox[{"1", "/", "4"}], 
         RowBox[{"1", "/", "2"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "69d74939-20b1-45b0-883c-6b572d5b7d12"],
 " ."
}], "TechNoteText",
 CellID->374300839,ExpressionUUID->"b4cb9538-5c5f-4394-ae90-cd4299bb3f50"],

Cell["\<\
Both have the same eigenvalues 3/4 and 1/4 and hence the same von Neumann \
entropy\
\>", "TechNoteText",
 CellID->546039478,ExpressionUUID->"cc00cb46-e746-4187-a2c1-c815d530553a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "\[Rho]", ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", "\[Sigma]", ")"}], "=", 
     RowBox[{
      FractionBox["1", "2"], "-", 
      RowBox[{
       FractionBox["3", "4"], "log", 
       FractionBox["3", "4"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "83712c3b-5274-48e2-8270-836cd52c2a54"],
 " ."
}], "TechNoteText",
 CellID->1730646743,ExpressionUUID->"0e517ae1-945e-4383-9c87-d7770d1b5751"],

Cell[TextData[{
 "On the other hand, the eigenvectors of \[Sigma] are ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[PlusMinus]"},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "\[PlusMinus]", 
       TemplateBox[{"1"},
        "Ket"]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "974eb5f3-3708-4640-baf7-e1e31ca057a9"],
 ". Therefore, the relative entropy is given by"
}], "TechNoteText",
 CellID->455740897,ExpressionUUID->"e267e4a9-b512-4adf-a5fb-ac25785d24df"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"S", "(", "\[Rho]", ")"}]}], "-", 
      RowBox[{
       TemplateBox[{"+"},
        "Bra"], "\[Rho]", 
       TemplateBox[{"+"},
        "Ket"], "log", 
       FractionBox["3", "4"]}], "-", 
      RowBox[{
       TemplateBox[{"-"},
        "Bra"], "\[Rho]", 
       TemplateBox[{"-"},
        "Ket"], "log", 
       FractionBox["1", "4"]}]}], "=", 
     RowBox[{
      FractionBox["1", "2"], "-", 
      RowBox[{
       FractionBox["1", "4"], "log", 
       FractionBox["3", "4"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "b969b5c6-8b83-4ff1-a3e5-111783427364"],
 " ."
}], "TechNoteText",
 CellID->716127935,ExpressionUUID->"9dd19375-8061-435b-9555-84bb3ef264a3"],

Cell["Now, consider still another density operator", "TechNoteText",
 CellID->1705601479,ExpressionUUID->"e896f1c8-3a08-4dd9-9e3b-5a36412ccb35"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tau]", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["1", "2"], "I"}], "+", 
      RowBox[{
       FractionBox["1", "2"], "Y"}]}], "\[DotEqual]", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"(", GridBox[{
         {"1", 
          RowBox[{"-", "\[ImaginaryI]"}]},
         {"\[ImaginaryI]", "1"}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "e7dec092-554f-49b5-90e2-e4e80d1af8e9"],
 " ."
}], "TechNoteText",
 CellID->163466882,ExpressionUUID->"8b54b8a6-48d6-4748-8c53-bb33a842469d"],

Cell[TextData[{
 "It has two eigenvectors, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"L"},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "+", 
       RowBox[{"\[ImaginaryI]", 
        TemplateBox[{"1"},
         "Ket"]}]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "2b2bc1b0-49b5-4015-9dd6-a82af6f0eb0b"],
 " with eigenvalue 1 and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"L"},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       TemplateBox[{"0"},
        "Ket"], "-", 
       RowBox[{"\[ImaginaryI]", 
        TemplateBox[{"1"},
         "Ket"]}]}], ")"}], "/", 
     SqrtBox["2"]}]}], TraditionalForm]],ExpressionUUID->
  "f082bee5-edf0-42fb-97f0-506497573a09"],
 " with eigenvalue 0. That is, \[Tau] has a null space spanned by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"R"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "fade480e-9162-4e00-a12a-2ccb4e0f6b75"],
 ". Note that both \[Rho] and \[Sigma] have a finite overlap, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"R"},
      "Bra"], "\[Rho]", 
     TemplateBox[{"R"},
      "Ket"]}], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"R"},
       "Bra"], "\[Sigma]", 
      TemplateBox[{"R"},
       "Ket"]}], "=", 
     RowBox[{"1", "/", "2"}]}]}], TraditionalForm]],ExpressionUUID->
  "2a5ac9e5-1873-41e9-a0fc-d1b06d31d094"],
 ". The relative entropies of both \[Rho] and \[Sigma] to \[Tau] diverge, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Tau]"}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", 
      RowBox[{"\[Sigma]", "\[DoubleVerticalBar]", "\[Tau]"}], ")"}], "=", 
     "\[Infinity]"}]}], TraditionalForm]],ExpressionUUID->
  "f21815b8-3a2d-432c-8a8a-2ca70c001e4c"],
 ", whereas ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "(", 
    RowBox[{"\[Tau]", "\[DoubleVerticalBar]", "\[Rho]"}], ")"}], 
   TraditionalForm]],ExpressionUUID->"5bc165bc-4f7c-4173-bb5c-c531377e4037"],
 "\nand ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", "(", 
    RowBox[{"\[Tau]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], 
   TraditionalForm]],ExpressionUUID->"9beeee0f-67e4-4eb3-b8f8-1cd176bdcb2b"],
 " are finite."
}], "TechNoteText",
 CellID->1933021076,ExpressionUUID->"34da06f3-4a24-421e-b0b1-4259b241f8f7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples", "Subsection",
 CellID->127646439,ExpressionUUID->"97fdd897-95f3-4a4c-a3b8-9f958d395ace"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",
 CellID->942294779,ExpressionUUID->"c0d90385-aad8-4aa5-9887-9e6cea6e5ef6"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[27]:=",
 CellID->8480550,ExpressionUUID->"8e992a7f-b2ca-454d-86e8-02f66e75cff7"],

Cell["\<\
Consider a quantum state described by the following density operator.\
\>", "TechNoteMathCaption",
 CellID->831059677,ExpressionUUID->"1b4fafe8-610c-4aea-9cb7-1ddd9f527409"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"rho", "=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], "+", 
    RowBox[{
     RowBox[{"S", "[", "3", "]"}], "/", "4"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rho", "//", "Matrix"}], "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[28]:=",
 CellID->386351251,ExpressionUUID->"4241fe8f-334c-4972-9430-e823bac849fe"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["3", "4"], "0"},
     {"0", 
      FractionBox["1", "4"]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {2, 2}, 0, {
     1, {{0, 1, 2}, {{1}, {2}}}, {
      Rational[3, 4], Rational[1, 4]}}]]]]], "Output",
 CellLabel->"Out[29]//MatrixForm=",
 CellID->1282067975,ExpressionUUID->"b88246b0-c4e7-42e7-9489-a1707bf328e4"]
}, Open  ]],

Cell["Here is the von Neumann entropy of the above state.", \
"TechNoteMathCaption",
 CellID->1562410676,ExpressionUUID->"6d858dab-5f74-42d8-ac10-fe0ad9c8298e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"VonNeumannEntropy", "[", "rho", "]"}]], "Input",
 CellLabel->"In[30]:=",
 CellID->6196016,ExpressionUUID->"3c88f90c-d279-4c7c-a6d9-c0a3f66cf56f"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], "+", 
  FractionBox[
   RowBox[{"3", " ", 
    RowBox[{"Log", "[", 
     FractionBox["4", "3"], "]"}]}], 
   RowBox[{"4", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]]}]], "Output",
 CellLabel->"Out[30]=",
 CellID->978658876,ExpressionUUID->"52be82ea-bd25-4f97-b783-e3645bd1a9ef"]
}, Open  ]],

Cell["Consider another density operator.", "TechNoteMathCaption",
 CellID->1057225856,ExpressionUUID->"0ad8644c-b249-42d2-be5b-59ec40a2e7e0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"sgm", "=", 
   RowBox[{
    RowBox[{"S", "[", "6", "]"}], "**", "rho", "**", 
    RowBox[{"S", "[", "6", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sgm", "//", "Matrix"}], "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[31]:=",
 CellID->515266514,ExpressionUUID->"03c45272-981e-42a0-ac68-f2fd2f8ec3fb"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["1", "2"], 
      FractionBox["1", "4"]},
     {
      FractionBox["1", "4"], 
      FractionBox["1", "2"]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellLabel->"Out[32]//MatrixForm=",
 CellID->627739304,ExpressionUUID->"804aa1d9-8028-4106-bfb3-9590d3cd399c"]
}, Open  ]],

Cell[TextData[{
 "It has the same eigenvalues as ",
 StyleBox["rho", "Input"],
 " and hence the same von Neumann entropy."
}], "TechNoteMathCaption",
 CellID->1430236094,ExpressionUUID->"bede5d11-e80f-405d-9aae-e76e501ea1af"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"VonNeumannEntropy", "[", "sgm", "]"}]], "Input",
 CellLabel->"In[33]:=",
 CellID->1193570987,ExpressionUUID->"3f9370c0-38ae-4d20-b2b6-1c2e286eac32"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], "+", 
  FractionBox[
   RowBox[{"3", " ", 
    RowBox[{"Log", "[", 
     FractionBox["4", "3"], "]"}]}], 
   RowBox[{"4", " ", 
    RowBox[{"Log", "[", "2", "]"}]}]]}]], "Output",
 CellLabel->"Out[33]=",
 CellID->1974808264,ExpressionUUID->"a2c0fbf2-9faa-4618-82e0-986ac698a594"]
}, Open  ]],

Cell[TextData[{
 "This gives the relative entropy of ",
 StyleBox["rho", "Input"],
 " to ",
 StyleBox["sgm", "Input"],
 "."
}], "TechNoteMathCaption",
 CellID->702831882,ExpressionUUID->"be25d07c-8fb0-4f9d-80b7-818cfcd24b94"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"VonNeumannEntropy", "[", 
  RowBox[{"rho", ",", "sgm"}], "]"}]], "Input",
 CellLabel->"In[34]:=",
 CellID->1335382274,ExpressionUUID->"40a60ba3-4544-48df-89e0-19c081f81924"],

Cell[BoxData["0.39624062518028874`"], "Output",
 CellLabel->"Out[34]=",
 CellID->1242728663,ExpressionUUID->"da156a17-6b51-49c7-a2ac-83eab7d0beb3"]
}, Open  ]],

Cell["Let us consider still another density operator.", "TechNoteMathCaption",
 CellID->1167270714,ExpressionUUID->"5922d6f0-d391-47b9-9ebb-11922e2fe3fd"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"tau", "=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], "+", 
    RowBox[{
     RowBox[{"S", "[", "2", "]"}], "/", "2"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tau", "//", "Matrix"}], "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[35]:=",
 CellID->2110866041,ExpressionUUID->"e17ad227-ca22-47eb-9f11-d61d62ab626e"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["1", "2"], 
      RowBox[{"-", 
       FractionBox["\[ImaginaryI]", "2"]}]},
     {
      FractionBox["\[ImaginaryI]", "2"], 
      FractionBox["1", "2"]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {2, 2}, 0, {
     1, {{0, 2, 4}, {{1}, {2}, {2}, {1}}}, {
      Rational[1, 2], Complex[0, Rational[-1, 2]], Rational[1, 2], Complex[
       0, Rational[1, 2]]}}]]]]], "Output",
 CellLabel->"Out[36]//MatrixForm=",
 CellID->114688319,ExpressionUUID->"5e967b3b-e6ed-4684-93a8-2e4645a574a5"]
}, Open  ]],

Cell["Note that it has one zero eigenvalue.", "TechNoteMathCaption",
 CellID->1844018300,ExpressionUUID->"91651264-f348-4417-bd0c-1a1a7bdb0a54"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"val", ",", "vec"}], "}"}], "=", 
   RowBox[{"ProperSystem", "[", "tau", "]"}]}], 
  ";"}], "\[IndentingNewLine]", "val"}], "Input",
 CellLabel->"In[37]:=",
 CellID->1697414302,ExpressionUUID->"25907230-b293-4519-b19a-98647093d4be"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "0"}], "}"}]], "Output",
 CellLabel->"Out[38]=",
 CellID->1273746074,ExpressionUUID->"6ea07029-71c8-4e18-b1c1-31df4b4063af"]
}, Open  ]],

Cell[TextData[{
 "The null space (the subspace belonging to the zero eigenvalue) is spanned \
by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"i", 
       TemplateBox[{"0"},
        "Ket"]}], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}], TraditionalForm]],ExpressionUUID->
  "22372aaa-15bb-406e-8397-80383d78fea3"],
 "."
}], "TechNoteMathCaption",
 CellID->2119021417,ExpressionUUID->"5a0f33d4-8467-4891-b458-b0638226314a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"vec", "=", 
  RowBox[{"KetNormalize", "/@", "vec"}]}]], "Input",
 CellLabel->"In[39]:=",
 CellID->1813606732,ExpressionUUID->"71e88dd6-63af-43d3-ba0b-21453efb3428"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", 
       InterpretationBox[
        TemplateBox[{
          TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
            SubscriptBox["0", 
             TemplateBox[{",", "\",\"", 
               InterpretationBox["S", 
                $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
           "RowWithSeparators"]},
         "Ket"],
        Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 0|>]]}], 
      SqrtBox["2"]]}], "+", 
    FractionBox[
     InterpretationBox[
      TemplateBox[{
        TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
          SubscriptBox["1", 
           TemplateBox[{",", "\",\"", 
             InterpretationBox["S", 
              $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
         "RowWithSeparators"]},
       "Ket"],
      Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 1|>]], 
     SqrtBox["2"]]}], ",", 
   RowBox[{
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
           SubscriptBox["0", 
            TemplateBox[{",", "\",\"", 
              InterpretationBox["S", 
               $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
          "RowWithSeparators"]},
        "Ket"],
       Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 0|>]]}], 
     SqrtBox["2"]], "+", 
    FractionBox[
     InterpretationBox[
      TemplateBox[{
        TemplateBox[{"\[VeryThinSpace]", "\"\[VeryThinSpace]\"", 
          SubscriptBox["1", 
           TemplateBox[{",", "\",\"", 
             InterpretationBox["S", 
              $CellContext`S[QuantumMob`Q3`$]]}, "RowWithSeparators"]]}, 
         "RowWithSeparators"]},
       "Ket"],
      Ket[<|$CellContext`S[QuantumMob`Q3`$] -> 1|>]], 
     SqrtBox["2"]]}]}], "}"}]], "Output",
 CellLabel->"Out[39]=",
 CellID->1733272422,ExpressionUUID->"e8f87051-528d-4afd-8799-2dcc044a2216"]
}, Open  ]],

Cell[TextData[{
 "Note that the both density operators ",
 StyleBox["rho", "Input"],
 " and ",
 StyleBox["sgm", "Input"],
 " has a finite overlap with the null space of ",
 StyleBox["tau", "Input"],
 "."
}], "TechNoteMathCaption",
 CellID->691384929,ExpressionUUID->"82d84f69-a186-456e-b1dc-b1346a61eb71"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Dagger", "[", 
   RowBox[{"vec", "[", 
    RowBox[{"[", "2", "]"}], "]"}], "]"}], "**", "sgm", "**", 
  RowBox[{"vec", "[", 
   RowBox[{"[", "2", "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Dagger", "[", 
   RowBox[{"vec", "[", 
    RowBox[{"[", "2", "]"}], "]"}], "]"}], "**", "sgm", "**", 
  RowBox[{"vec", "[", 
   RowBox[{"[", "2", "]"}], "]"}]}]}], "Input",
 CellLabel->"In[40]:=",
 CellID->278185404,ExpressionUUID->"6085e1f8-cf34-4f07-88ce-91c76427cf3d"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellLabel->"Out[40]=",
 CellID->493924999,ExpressionUUID->"44ab70c3-d0e4-4fdc-aa79-a51c63d40221"],

Cell[BoxData[
 FractionBox["1", "2"]], "Output",
 CellLabel->"Out[41]=",
 CellID->1373162538,ExpressionUUID->"56d1248b-ca8f-4444-8d57-e28ef4fe55ad"]
}, Open  ]],

Cell[TextData[{
 "This means that the relative entropy of ",
 StyleBox["rho", "Input"],
 " and ",
 StyleBox["smg", "Input"],
 " to ",
 StyleBox["tau", "Input"],
 " diverge (however close ",
 StyleBox["rho", "Input"],
 " and ",
 StyleBox["smg", "Input"],
 " may look to ",
 StyleBox["tau", "Input"],
 ")."
}], "TechNoteMathCaption",
 CellID->1816019193,ExpressionUUID->"d2cd46dc-8f7f-4966-8c89-4616b27a1621"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"VonNeumannEntropy", "[", 
  RowBox[{"rho", ",", "tau"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"VonNeumannEntropy", "[", 
  RowBox[{"sgm", ",", "tau"}], "]"}]}], "Input",
 CellLabel->"In[42]:=",
 CellID->1823144470,ExpressionUUID->"9388a4d1-439f-478c-b721-5886cf469968"],

Cell[BoxData["\[Infinity]"], "Output",
 CellLabel->"Out[42]=",
 CellID->1883505504,ExpressionUUID->"791b478c-db91-4377-b625-aefaa8c8dc4c"],

Cell[BoxData["\[Infinity]"], "Output",
 CellLabel->"Out[43]=",
 CellID->20565301,ExpressionUUID->"0bad903d-62f6-41dc-a9ea-86213b0c2d46"]
}, Open  ]],

Cell[TextData[{
 "On the other hand, the relative entropies of ",
 StyleBox["tau", "Input"],
 " to ",
 StyleBox["rho", "Input"],
 " and ",
 StyleBox["sgm", "Input"],
 " are finite."
}], "TechNoteMathCaption",
 CellID->546929820,ExpressionUUID->"75cd7921-4d00-40a6-beea-a572b51a23e8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"VonNeumannEntropy", "[", 
  RowBox[{"tau", ",", "rho"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"VonNeumannEntropy", "[", 
  RowBox[{"tau", ",", "sgm"}], "]"}]}], "Input",
 CellLabel->"In[44]:=",
 CellID->283273746,ExpressionUUID->"7d3cdde5-4aed-44ad-b5dd-2ff3a387488c"],

Cell[BoxData["1.2075187496394215`"], "Output",
 CellLabel->"Out[44]=",
 CellID->2043630387,ExpressionUUID->"daec0233-b786-4517-b34d-236aca61bcdb"],

Cell[BoxData["1.2075187496394213`"], "Output",
 CellLabel->"Out[45]=",
 CellID->442464191,ExpressionUUID->"49c421f8-40d5-4d96-a520-d5b50f709d81"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Properties", "Subsection",
 CellID->1963880837,ExpressionUUID->"5955be3f-2eaa-4ad6-b276-39e0d79f85e4"],

Cell["When \[Rho] and \[Sigma] are diagonal simultaneously,", "TechNoteText",
 CellID->1874984638,ExpressionUUID->"c92f7e55-d55d-4492-9df9-20b49ebd268e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     TemplateBox[{
       SubscriptBox["\[Lambda]", "j"]},
      "Ket"], 
     SubscriptBox["r", "j"], 
     TemplateBox[{
       SubscriptBox["\[Lambda]", "j"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "d930f12b-da8b-4389-ab71-ed5b028e3925"],
 " ,     ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     TemplateBox[{
       SubscriptBox["\[Lambda]", "j"]},
      "Ket"], 
     SubscriptBox["s", "j"], 
     TemplateBox[{
       SubscriptBox["\[Lambda]", "j"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "fa95088e-5c45-49a0-a555-cdc0610ef5fe"]
}], "TechNoteText",
 CellID->1854435085,ExpressionUUID->"28d280e7-0036-4e49-9d97-82e7812956db"],

Cell[TextData[{
 "the relative von Neumann entropy is simple to evaluate and reduces to the \
",
 ButtonBox["relative Shannon entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ShannonEntropy#240193879"],
 ","
}], "TechNoteText",
 CellID->1112869761,ExpressionUUID->"bc0748d5-6035-490b-a382-15b28a469ed4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], "=", 
    RowBox[{"H", "(", 
     RowBox[{
      RowBox[{"{", 
       SubscriptBox["r", "j"], "}"}], "\[DoubleVerticalBar]", 
      RowBox[{"{", 
       SubscriptBox["s", "j"], "}"}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"76fc44ee-d3f8-4d26-bd60-e44401fc684b"],
 " ."
}], "TechNoteText",
 CellID->1792945688,ExpressionUUID->"67a4d0a7-6ca5-4d00-b3d9-515c16b38c1c"],

Cell[TextData[{
 "The power of the relative entropy as a mathematical tool comes from ",
 StyleBox["Klein\[CloseCurlyQuote]s inequality",
  FontSlant->"Italic"],
 ","
}], "TechNoteText",
 CellID->605304552,ExpressionUUID->"b51172f9-0240-43c7-8833-4ff1b7ab1472"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], " ", "\[GreaterEqual]",
     " ", "0"}], TraditionalForm]],ExpressionUUID->
  "b2d982b4-fe7f-4922-a818-376c8fe98eb8"]
}], "TechNoteText",
 CellID->1367744794,ExpressionUUID->"717cc627-9a37-4b90-9a01-e9e0872dd91e"],

Cell[TextData[{
 "with equality if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", "\[Sigma]"}], TraditionalForm]],ExpressionUUID->
  "23fef2f5-7c5a-4056-87e8-5a566480ebe5"],
 ", to be compared to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Gibbs", "'"}], " ", "inequality"}], TraditionalForm]],
  ExpressionUUID->"1d099cf0-a2a0-420f-b594-3d1b2131fe06"],
 " for the ",
 ButtonBox["relative Shannon entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ShannonEntropy#240193879"],
 ". Like Gibbs\[CloseCurlyQuote] inequality, one can prove Klein\
\[CloseCurlyQuote]s inequality based on the convexity of the logarithm \
function. But it is slightly more complicated since \[Rho] and \[Sigma] do \
not commute with each other in general. Interested readers are referred to \
Problem 7.3 of the ",
 ButtonBox["Quantum Workbook",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1007/978-3-030-91214-7"], None}],
 "."
}], "TechNoteText",
 CellID->1657828346,ExpressionUUID->"d72eab09-375c-41bb-8388-de87f4d76d0a"],

Cell[TextData[{
 "For a basic application of Klein\[CloseCurlyQuote]s inequality, we put ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Sigma]", " ", "=", 
    RowBox[{"I", "/", "d"}]}], TraditionalForm]],ExpressionUUID->
  "dc8d92f6-b958-4aa5-a820-98aea009ecee"],
 ", where ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]],ExpressionUUID->
  "10654f45-1e39-4450-ad74-2b232e11b483"],
 " is the dimension of the Hilbert space (that is,  ",
 Cell[BoxData[
  FormBox["\[Sigma]", TraditionalForm]],ExpressionUUID->
  "fd476679-b02f-4cdc-a4e4-026637638f1b"],
 " is the maximally mixed state), into the inequality. It follows that"
}], "TechNoteText",
 CellID->968026077,ExpressionUUID->"715990e2-cae5-4405-8ef4-4d3376faea05"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"\[Rho]", "\[DoubleVerticalBar]", "\[Sigma]"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"S", "(", "\[Rho]", ")"}]}], "-", 
      RowBox[{"Tr", "\[VeryThinSpace]", "\[Rho]", " ", "log", 
       FractionBox["1", "d"]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"S", "(", "\[Rho]", ")"}]}], "+", 
       RowBox[{"log", "\[VeryThinSpace]", "d"}]}], "\[GreaterEqual]", 
      "0"}]}]}], TraditionalForm]],ExpressionUUID->
  "412fccce-2afa-4cf5-86de-fc212a2f9ea5"]
}], "TechNoteText",
 CellID->1219917123,ExpressionUUID->"013c610e-2b1c-44d0-8be1-6223bcda75ea"],

Cell[TextData[{
 "with equality if and only if ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{"I", "/", "d"}]}], TraditionalForm]],ExpressionUUID->
  "f2b61275-f1a0-40b4-b5c0-9be9f46a2c4d"],
 ". This proves the deferred claim that"
}], "TechNoteText",
 CellID->833445121,ExpressionUUID->"acd98644-9585-4a45-ad5c-012ef2c141f9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    RowBox[{"S", "(", "\[Rho]", ")"}], "\[LessEqual]", 
    RowBox[{"log", "\[VeryThinSpace]", "d"}]}], TraditionalForm]],
  ExpressionUUID->"05ae2c15-584a-4167-8890-effcafc44124"],
 " ."
}], "TechNoteText",
 CellID->2121192254,ExpressionUUID->"8756cef6-14f7-4f6c-b677-aeefca749798"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantum Mutual Information", "TechNoteSection",
 CellID->2123841012,ExpressionUUID->"06f8ff3e-af38-44c2-a0fc-d88cf2642da3"],

Cell[CellGroupData[{

Cell["Definition", "Subsection",
 CellID->1812381131,ExpressionUUID->"051210d2-8797-4e13-a8ec-3e3957031595"],

Cell[TextData[{
 "For the ",
 ButtonBox["Shannon entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/ShannonEntropy"],
 ", we introduced the joint and conditional entropies by considering multiple \
random variables. To generalize those concepts to the quantum entropy, we \
consider a composite system of two subsystems ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "fee9999d-342a-477c-aaa2-557008d0c2ac"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "d1040df6-b871-46a0-821d-083f18132b63"],
 "."
}], "TechNoteText",
 CellID->1998529243,ExpressionUUID->"77556916-8d20-4de3-a216-02db640d2ae0"],

Cell[TextData[{
 "Suppose that ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "5b8c87cb-dada-435b-8ef4-979a333abda1"],
 " is a density operator of the total system. The quantum joint entropy, or \
simply ",
 StyleBox["joint entropy",
  FontSlant->"Italic"],
 " if there is no risk of confusion, of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "6e9abe90-88ac-4fdd-a7f6-50470aa95ecc"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "65332e86-3753-46ac-992b-f594b92a1151"],
 " is nothing but the von Neumann entropy associated with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "082d87ce-5e85-4ec9-9e8d-a8488b9b88fc"],
 ","
}], "TechNoteText",
 CellID->925379048,ExpressionUUID->"be7aec2d-adec-4d5a-8b85-14279bde9a20"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"A", ",", "B"}], ")"}], ":=", 
    RowBox[{
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", 
       RowBox[{"A", "\[VeryThinSpace]", "B"}]], ")"}], "=", 
     RowBox[{"-", 
      RowBox[{"Tr", "\[VeryThinSpace]", "[", 
       RowBox[{
        SubscriptBox["\[Rho]", 
         RowBox[{"A", "\[VeryThinSpace]", "B"}]], "log", "\[VeryThinSpace]", 
        SubscriptBox["\[Rho]", 
         RowBox[{"A", "\[VeryThinSpace]", "B"}]]}], "]"}]}]}]}], 
   TraditionalForm]],ExpressionUUID->"337fe0df-7305-46e8-8cc9-a6a4e7cc4d65"],
 " ."
}], "TechNoteText",
 CellID->1240057788,ExpressionUUID->"758905d1-fba0-497a-867b-432e06204b4b"],

Cell[TextData[{
 "For a product state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", 
     RowBox[{"A", "\[VeryThinSpace]", "B"}]], "=", 
    RowBox[{
     SubscriptBox["\[Rho]", "A"], "\[CircleTimes]", 
     SubscriptBox["\[Rho]", "B"]}]}], TraditionalForm]],ExpressionUUID->
  "9f021313-19ce-4fcb-8286-a9dc60143efe"],
 ", the joint entropy is the sum of the entropies of the individual \
entropies"
}], "TechNoteText",
 CellID->1647817823,ExpressionUUID->"c58f378c-f8f2-4efd-9ec2-2d7f95cbe6fa"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{
      SubscriptBox["\[Rho]", "A"], "\[CircleTimes]", 
      SubscriptBox["\[Rho]", "B"]}], ")"}], "=", 
    RowBox[{
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", "A"], ")"}], "+", 
     RowBox[{"S", "(", 
      SubscriptBox["\[Rho]", "B"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"d6f7db38-1c90-41b8-be69-1bec8f8e7282"],
 " ."
}], "TechNoteText",
 CellID->1584332431,ExpressionUUID->"3004e208-4d89-4237-b420-2e78b57c1278"],

Cell[TextData[{
 "In analogy with the classical case, we also define the ",
 StyleBox["quantum conditional entropy",
  FontSlant->"Italic"],
 " of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "ba69c13e-bac5-41f4-b810-12ec014403d7"],
 " on ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "4ea234c5-c356-4b54-9d53-c90b9183363b"],
 " by"
}], "TechNoteText",
 CellID->709426696,ExpressionUUID->"fbac3357-7aef-4c29-a038-17acb9a782fa"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"A", "|", "B"}], ")"}], ":=", 
    RowBox[{
     RowBox[{"S", "(", 
      RowBox[{"A", ",", "B"}], ")"}], "-", 
     RowBox[{"S", "(", "B", ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "2fb4371c-4ceb-458c-8c47-5a997a974ee6"],
 " ,"
}], "TechNoteText",
 CellID->479668919,ExpressionUUID->"5381fff3-0c03-4942-a050-ec44941c23d7"],

Cell[TextData[{
 "and the quantum mutual information of ",
 Cell[BoxData[
  FormBox["A", TraditionalForm]],ExpressionUUID->
  "b04e8337-e6c2-419f-b9bd-ec2b76dd0619"],
 " and ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "69934723-43c4-44b9-b21b-0e672e74e0d1"],
 " by"
}], "TechNoteText",
 CellID->1788468425,ExpressionUUID->"c8a960be-f390-4744-9307-3072b9486122"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"A", ":", "B"}], ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"S", "(", "A", ")"}], "+", 
      RowBox[{"S", "(", "B", ")"}], "-", 
      RowBox[{"S", "(", 
       RowBox[{"A", ",", "B"}], ")"}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"S", "(", "A", ")"}], "-", 
       RowBox[{"S", "(", 
        RowBox[{"A", "|", "B"}], ")"}]}], "=", 
      RowBox[{
       RowBox[{"S", "(", "B", ")"}], "-", 
       RowBox[{"S", "(", 
        RowBox[{"B", "|", "A"}], ")"}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"92f8f767-04ab-48b9-baf9-970549e4f351"],
 " ."
}], "TechNoteText",
 CellID->1407242816,ExpressionUUID->"3fea9ddc-0d90-45cf-8c6c-3417c38d44c3"],

Cell[TextData[{
 "Here, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "A", ")"}], ":=", 
    RowBox[{"S", "(", 
     SubscriptBox["\[Rho]", "A"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "7b3d1b34-bca6-4efd-a838-36fc86459eb6"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "B", ")"}], ":=", 
    RowBox[{"S", "(", 
     SubscriptBox["\[Rho]", "B"], ")"}]}], TraditionalForm]],ExpressionUUID->
  "fd98c713-399c-47ab-bda0-aa477ccf8ba6"],
 " are associated with the reduced density operators"
}], "TechNoteText",
 CellID->2080269415,ExpressionUUID->"9565f4ec-67cf-4145-abf2-519b938fa173"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", "A"], "=", 
    RowBox[{
     UnderscriptBox["Tr", "B"], 
     SubscriptBox["\[Rho]", 
      RowBox[{"A", "\[VeryThinSpace]", "B"}]]}]}], TraditionalForm]],
  ExpressionUUID->"441504a4-baa2-4cb3-9ce8-e43f5e8abb69"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", "B"], "=", 
    RowBox[{
     UnderscriptBox["Tr", "A"], 
     SubscriptBox["\[Rho]", 
      RowBox[{"A", "\[VeryThinSpace]", "B"}]]}]}], TraditionalForm]],
  ExpressionUUID->"578fcd38-2a3f-4172-a8b3-bc5e7dce73cc"],
 " ,"
}], "TechNoteText",
 CellID->1712405853,ExpressionUUID->"f6a7726b-7bb3-440a-9dbc-19a753292952"],

Cell[TextData[{
 "respectively. In comparison with the classical case, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"A", "\[VeryThinSpace]", "B"}]], TraditionalForm]],ExpressionUUID->
  "2f815248-a154-4bec-ad9f-e050bf88bff6"],
 " corresponds to a joint probability distribution ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "(", 
    RowBox[{"x", ",", "y"}], ")"}], TraditionalForm]],ExpressionUUID->
  "4a609948-4f4b-46be-8d1d-cca818f5babf"],
 ", and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "A"], TraditionalForm]],ExpressionUUID->
  "0e428354-694c-49fa-93bd-30d0d3674c7b"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", "B"], TraditionalForm]],ExpressionUUID->
  "2dfaff13-b29b-4816-9ae9-1a0a34fd92fe"],
 " to ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", "x", ")"}]}], TraditionalForm]],ExpressionUUID->
  "1fad150c-8ea7-4eeb-b87a-4613139fa6bb"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", 
    RowBox[{"(", "y", ")"}]}], TraditionalForm]],ExpressionUUID->
  "9b64fa54-9cdf-448b-a0d2-4119e2c848a7"],
 ", respectively. Note that for a pure state, we have"
}], "TechNoteText",
 CellID->490639446,ExpressionUUID->"602ca1fb-b9cf-4d9a-9aef-30983b129964"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "A", ")"}], "=", 
    RowBox[{"S", "(", "B", ")"}]}], TraditionalForm]],ExpressionUUID->
  "1ca8bbb7-98df-407c-acee-d375224cd728"]
}], "TechNoteText",
 CellID->247237988,ExpressionUUID->"43f92402-4dc0-4f26-8d27-e0a26d5915cc"],

Cell["and hence", "TechNoteText",
 CellID->1189312288,ExpressionUUID->"f7cbb1b2-870e-46fa-869e-80a2455a97ad"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", 
     RowBox[{"A", ":", "B"}], ")"}], "=", 
    RowBox[{
     RowBox[{"2", 
      RowBox[{"S", "(", "A", ")"}]}], "=", 
     RowBox[{"2", 
      RowBox[{"S", "(", "B", ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "1bba7ded-3715-4be4-9d84-b2abcfd9e81a"],
 " ."
}], "TechNoteText",
 CellID->1908679889,ExpressionUUID->"a8012ee1-071e-4a4f-aa7e-94230b817ca1"]
}, Open  ]],

