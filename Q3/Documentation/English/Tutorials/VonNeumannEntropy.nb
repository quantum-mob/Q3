Cell["\<\
The Shannon entropy is a measure of uncertainty associated with a classical \
probability distribution. We now generalize the notion to quantum states \
described by density operators.\
\>", "TechNoteText",
 CellID->2046238193,ExpressionUUID->"b41811d5-5322-4a0e-955d-fb74fa82eaf2"],

Cell[TextData[{
 "See also Section 7.2 of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "6f300829-20c7-49e7-a2ab-eed43a756b9a"],
 "."
}], "TechNoteText",
 CellID->1804678267,ExpressionUUID->"257eef33-5c1a-45ca-9ae0-08661665d1d9"],

Cell[BoxData[GridBox[{
   {
