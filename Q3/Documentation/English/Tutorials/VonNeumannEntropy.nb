Cell[TextData[{
 "Let us consider a simple example. The density operator describes an \
ensemble of two pure states ",
 Cell[BoxData[
  TemplateBox[{"0"},
   "Ket"]],ExpressionUUID->"24907f20-94d5-40ad-9eb1-e8116b3e441c"],
 " and ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{"+"},
    "Ket"], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "/", 
    SqrtBox["2"]}]}]],ExpressionUUID->
  "b0aa6e48-065f-4814-8ab5-af0ac18d97a6"],
 "."
}], "TechNoteMathCaption",
 CellID->1058952787,ExpressionUUID->"1f497a70-e2ec-4848-a8c6-fc122760d587"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", "p", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vec", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Ket", "[", "]"}], "+", 
      RowBox[{"Ket", "[", 
       RowBox[{"S", "->", "1"}], "]"}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"rho", "=", 
  RowBox[{
   RowBox[{"p", "*", 
    RowBox[{"Dyad", "[", 
     RowBox[{
      RowBox[{"Ket", "[", "]"}], ",", 
      RowBox[{"Ket", "[", "]"}], ",", "S"}], "]"}]}], "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", "p"}], ")"}], "*", 
    RowBox[{"Dyad", "[", 
     RowBox[{"vec", ",", "vec", ",", "S"}], "]"}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Matrix", "[", "rho", "]"}], "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[21]:=",
 CellID->1622508420,ExpressionUUID->"24fc2082-de83-4667-b86c-05e9ea6a771c"],

Cell[BoxData[
 RowBox[{
