Cell[TextData[{
 "Block encoding is a method to get a quantum computer accessible to the \
information in a matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "75650129-8fcb-436c-8981-5840f599ed59"],
 ". Typically, the resulting bigger embedding matrix is denoted by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "c7e28287-1125-4397-8a2b-aeb8bef359fc"],
 " and has the block form"
}], "TechNoteText",
 CellID->495219038,ExpressionUUID->"2eea85ef-4149-455c-a52e-7a883899cbed"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "M"], ":=", 
    RowBox[{"(", GridBox[{
       {"M", "*"},
       {"*", "*"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "146dd7b1-f189-4106-a75c-32bdf208e54e"],
 " ,"
}], "TechNoteText",
 CellID->914482391,ExpressionUUID->"eb51cf61-f468-4d69-99e4-f0e71c4e6374"],

Cell["where * indicates the corresponding block is irrelevant.", \
"TechNoteText",
 CellID->737417743,ExpressionUUID->"9529c6df-f79d-4f1e-9979-17839c176695"],

