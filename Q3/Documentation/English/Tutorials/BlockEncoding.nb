Cell[TextData[{
 "Throughout this document, symbol ",
 StyleBox["S", "Input"],
 " will be used to refer to a quantum register of qubits. Similarly, symbol c \
will be used to denote complex-valued coefficients."
}], "TechNoteMathCaption",
 CellID->1937193009,ExpressionUUID->"1147d783-ddc2-42a1-93d2-2fd6fd4e5cdf"],

