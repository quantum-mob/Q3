   0.025]]],ExpressionUUID->"25ad7c5b-c88c-4e5e-9e17-33852082c5e2"]], \
"Picture",
 CellID->1553194480,ExpressionUUID->"07464cbd-4c63-4164-9c62-cbed33ecc9b4"],

Cell[TextData[{
 StyleBox["Figure 4",
  FontWeight->"Bold"],
 ". A geometric view of the effects of the reflection ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "80e02954-5e2a-41cb-811e-1bf670a32c1f"],
 " in the line along the computational basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b23d7881-4157-4125-97db-b0dd23e60bcb"],
 " (from blue to red arrows) and the reflection ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"885e3dd6-3ba2-48b2-b0ff-e451de8f4c87"],
 " in the line along the rotated basis vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"x", ":", 
        RowBox[{"-", "\[Theta]"}]}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["R", "x", "\[Dagger]"], "(", "\[Theta]", ")"}], 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "5f2efbc1-5ded-4764-972a-e590f878ab5d"],
 " (from red to blue arrows). The combining ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"5406e729-4e31-463a-b41e-acc8aea2f769"],
 " with ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "05906de0-4fb1-46d0-ac7c-b9c7d8fe8ac7"],
 " gives rise to the Grover rotation (from blue to blue arrows). Shown is the \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[VeryThinSpace]", "z"}], TraditionalForm]],ExpressionUUID->
  "ebd98449-8f78-4ec9-adfd-bc8f624abd83"],
 "-plane in the Bloch space with the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "acea0408-9587-42c9-8779-481a295754ad"],
 "-axis in the vertical direction and the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "cdb7d7c3-0f50-480f-8d18-ea6a5c036ebe"],
 "-axis pointing out of the screen."
}], "TechNoteCaption",
 CellID->1875896075,ExpressionUUID->"2aaa8454-11fa-4360-a476-c1925cf0ee5b"],

Cell["\<\
\[LineSeparator]Moreover, recalling the relation the Grover-like rotations \
around x- and y-axis\
\>", "TechNoteText",
 CellID->352881349,ExpressionUUID->"6214f80c-9971-42a0-8258-066ed74ee1eb"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "Z", "\[VeryThinSpace]", 
       RowBox[{"\[Pi]", "/", "4"}]}]], 
     RowBox[{
      SubscriptBox["G", "y"], "(", "\[Lambda]", ")"}], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "Z", "\[VeryThinSpace]", 
       RowBox[{"\[Pi]", "/", "4"}]}]]}]}], TraditionalForm]],ExpressionUUID->
  "8f428ea9-ea6c-48b6-a2a5-7f9274416c03"],
 " ,"
}], "TechNoteText",
 CellID->1850840532,ExpressionUUID->"1beadf86-44cf-4812-a83e-cffae84956b0"],

