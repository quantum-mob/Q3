Cell[TextData[{
 StyleBox["Figure 3",
  FontWeight->"Bold"],
 ". Equivalent quantum circuits representing the GSLW block encoding of \
matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "9db95f49-d41d-4b40-a190-596742906616"],
 " that has singular value decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"V", "\[VeryThinSpace]", "\[CapitalLambda]", "\[VeryThinSpace]", 
     SuperscriptBox["W", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "bb15218d-cbcc-49c2-a654-e1799a6cfc0c"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", ":=", 
    RowBox[{"diag", "(", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", 
       SubscriptBox["\[Lambda]", "2"]}], "\[InvisibleComma]", 
      RowBox[{",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Lambda]", "n"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"535f5ae5-b68d-4139-9eeb-55c1b293c79b"],
 ". Here, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "k"], TraditionalForm]],ExpressionUUID->
  "10e15247-4de6-4a2c-aba6-3fedbba47e2d"],
 " is a short-hand notation for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "k"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["G", "x"], "(", 
      SubscriptBox["\[Lambda]", "k"], ")"}], "=", 
     RowBox[{
      SubscriptBox["G", "x"], "(", 
      SubscriptBox["cos\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"0a9f3966-23de-454b-9ad1-08bb41e13935"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "(", 
     SubscriptBox["\[Theta]", "k"], ")"}], ":=", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "de1e9e4d-b731-4b97-9c97-191673b37a59"],
 "."
}], "TechNoteCaption",
 CellID->1045391992,ExpressionUUID->"7f3ad58b-c46a-4c3e-8e89-b93fa10eee5f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Geometric View: Relation to the Grover Rotation", "Subsection",
 CellID->1339493437,ExpressionUUID->"cefec197-ee53-4077-b3f1-f09aef3c711b"],

Cell["\<\
The GSLW form of block encoding also allows a similar geometric \
interpretation as the standard form in the above. To see this, let us \
introduce the rotated basis vector\
\>", "TechNoteText",
 CellID->795124158,ExpressionUUID->"c1a50422-26c0-40bb-9b7c-a0a595c68283"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"x", ":", 
        RowBox[{"-", "\[Theta]"}]}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubsuperscriptBox["R", "x", "\[Dagger]"], "(", "\[Theta]", ")"}], 
      TemplateBox[{"0"},
       "Ket"]}], "\[DotEqual]", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"cos", "(", 
          RowBox[{"\[Theta]", "/", "2"}], ")"}]},
        {
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"sin", "(", 
           RowBox[{"\[Theta]", "/", "2"}], ")"}]}]}
       },
       GridBoxAlignment->{"Columns" -> {{Right}}, "Rows" -> {{Baseline}}}], 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "98222a37-f1f3-4680-a392-3f1462402e77"],
 " "
}], "TechNoteText",
 CellID->2008471872,ExpressionUUID->"4b0ed2e7-639e-4cbf-b5e3-4c95c9f0b8b7"],

Cell[TextData[{
 "and the ",
 StyleBox["reflection",
  FontSlant->"Italic"],
 " in the line along the vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"x", ":", 
       RowBox[{"-", "\[Theta]"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "fd171c3a-3a8e-4368-a865-d1d0bb159631"],
 " (see also ",
 ButtonBox["Figure 4",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1875896075"],
 " for a geometric interpretation)"
}], "TechNoteText",
 CellID->91305511,ExpressionUUID->"2398e80e-7d0f-4093-9b34-ef83876716ef"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"2", 
       TemplateBox[{
         RowBox[{"x", ":", 
           RowBox[{"-", "\[Theta]"}]}]},
        "Ket"], 
       TemplateBox[{
         RowBox[{"x", ":", 
           RowBox[{"-", "\[Theta]"}]}]},
        "Bra"]}], "-", "1"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["R", "x"], "(", 
        RowBox[{"-", "\[Theta]"}], ")"}], "Z", "\[VeryThinSpace]", 
       RowBox[{
        SubsuperscriptBox["R", "x", "\[Dagger]"], "(", 
        RowBox[{"-", "\[Theta]"}], ")"}]}], "\[DotEqual]", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "sin", "\[VeryThinSpace]",
            "\[Theta]"}]},
         {
          RowBox[{
          "\[ImaginaryI]", "\[VeryThinSpace]", "sin", "\[VeryThinSpace]", 
           "\[Theta]"}], 
          RowBox[{
           RowBox[{"-", "cos"}], "\[VeryThinSpace]", "\[Theta]"}]}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "b3b4fbc7-7add-4556-b38d-42b2fc917622"],
 "."
}], "TechNoteText",
 CellID->1268399419,ExpressionUUID->"71191d7b-5a8c-4990-be28-a2f8fa3b4143"],

Cell["Now, note that", "TechNoteText",
 CellID->2066355011,ExpressionUUID->"7ceed1de-6ad7-49dc-809e-36b0f82b0e52"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], "\[DotEqual]", 
     RowBox[{"(", GridBox[{
        {"\[Lambda]", 
         RowBox[{"\[ImaginaryI]", 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["\[Lambda]", "2"]}]]}]},
        {
         RowBox[{"\[ImaginaryI]", 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["\[Lambda]", "2"]}]]}], "\[Lambda]"}
       }], ")"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalOmega]", "x"], "(", "\[Lambda]", ")"}], "Z"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], 
       "Z"}], "=", 
      RowBox[{
       SubsuperscriptBox["R", "x", "\[Dagger]"], "(", 
       RowBox[{"2", "\[Theta]"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"67415425-288a-4721-a3c8-1c8475d2e9a9"],
 "."
}], "TechNoteText",
 CellID->123130593,ExpressionUUID->"2847c54e-3acf-4729-8c7c-d45c01420aba"],

Cell[TextData[{
 "In other words, combined with the Pauli ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "eadb91db-1c5e-432e-99b0-51228ac5b2b7"],
 " operator, the reflection ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"0a685361-d048-4e92-a9af-38b60e693a1b"],
 " in the line along the vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"x", ":", 
       RowBox[{"-", "\[Theta]"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b2220bf2-c79f-438f-a433-557d52f526cb"],
 " gives rise to the rotation around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "e24b0270-d8cd-49f5-ab6f-42450c4828e9"],
 "-axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Theta]"}], TraditionalForm]],ExpressionUUID->
  "23a6827d-df0e-461f-b98f-61257e2cd015"]
}], "TechNoteText",
 CellID->1429124490,ExpressionUUID->"21c87e96-cfe6-4544-9acb-562fb91f5e93"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], "Z"}], 
    "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["R", "x"], "(", 
       RowBox[{"-", "\[Theta]"}], ")"}], "Z", "\[VeryThinSpace]", 
      RowBox[{
       SubsuperscriptBox["R", "x", "\[Dagger]"], "(", 
       RowBox[{"-", "\[Theta]"}], ")"}], "Z"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["R", "x"], "(", 
        RowBox[{"-", "\[Theta]"}], ")"}], 
       RowBox[{
        SubscriptBox["R", "x"], "(", 
        RowBox[{"-", "\[Theta]"}], ")"}]}], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox["R", "x"], "(", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Theta]"}], ")"}], "\[DotEqual]", 
       RowBox[{"(", GridBox[{
          {
           RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
           RowBox[{
           "\[ImaginaryI]", "\[VeryThinSpace]", "sin", "\[VeryThinSpace]", 
            "\[Theta]"}]},
          {
           RowBox[{
           "\[ImaginaryI]", " ", "sin", "\[VeryThinSpace]", "\[Theta]"}], 
           RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}]}
         }], ")"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "b49b586a-dd33-424b-bd10-81a2289be976"],
 " ."
}], "TechNoteText",
 CellID->1838195382,ExpressionUUID->"50cdabc2-1529-485e-8042-202384e2766f"],

Cell[TextData[{
 "This relation becomes even clearer with a geometrical view as shown in ",
 ButtonBox["Figure 4",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1875896075"],
 "."
}], "TechNoteText",
 CellID->850039532,ExpressionUUID->"b48de87f-f56d-4e7b-92d9-eb6d679dd460"],

