Cell[TextData[{
 StyleBox["Figure 3",
  FontWeight->"Bold"],
 ". Equivalent quantum circuits representing the GSLW block encoding of \
matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "a0fac6b9-eab4-4038-90b5-ae10ccf6d27e"],
 " that has singular value decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"V", "\[VeryThinSpace]", "\[CapitalLambda]", "\[VeryThinSpace]", 
     SuperscriptBox["W", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "1d331166-6be4-4ff8-b6f4-af1b8ae1046e"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", ":=", 
    RowBox[{"diag", "(", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", 
       SubscriptBox["\[Lambda]", "2"]}], "\[InvisibleComma]", 
      RowBox[{",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Lambda]", "n"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"17bf743e-b692-4a08-abe5-83344398ce78"],
 ". Here, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["G", "k"], TraditionalForm]],ExpressionUUID->
  "ed4d4077-14c1-4f1a-b13c-7ce217fa9eb3"],
 " is a short-hand notation for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "k"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["G", "x"], "(", 
      SubscriptBox["\[Lambda]", "k"], ")"}], "=", 
     RowBox[{
      SubscriptBox["G", "x"], "(", 
      SubscriptBox["cos\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"4a11fe5d-5dc0-4a50-abf6-1f63a977184f"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "(", 
     SubscriptBox["\[Theta]", "k"], ")"}], ":=", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "9ab322de-8282-4b7b-9585-fbbac79c793b"],
 "."
}], "TechNoteCaption",
 CellID->1045391992,ExpressionUUID->"4747077f-fda9-48af-ba4e-e2b0465e827a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Geometric View: Relation to the Grover Rotation", "Subsection",
 CellID->1339493437,ExpressionUUID->"b8dfb095-82d3-423b-9eb5-acb70da6d9c5"],

Cell["\<\
The GSLW form of block encoding also allows a similar geometric \
interpretation as the standard form in the above. To see this, let us \
introduce the rotated basis vector\
\>", "TechNoteText",
 CellID->795124158,ExpressionUUID->"55661692-44cf-46a7-b710-53deeb70ab8d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"x", ":", 
        RowBox[{"-", "\[Theta]"}]}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubsuperscriptBox["R", "x", "\[Dagger]"], "(", "\[Theta]", ")"}], 
      TemplateBox[{"0"},
       "Ket"]}], "\[DotEqual]", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"cos", "(", 
          RowBox[{"\[Theta]", "/", "2"}], ")"}]},
        {
         RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", 
          RowBox[{"sin", "(", 
           RowBox[{"\[Theta]", "/", "2"}], ")"}]}]}
       },
       GridBoxAlignment->{"Columns" -> {{Right}}, "Rows" -> {{Baseline}}}], 
      ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "78ca232c-dc96-4a3f-87c0-1a7e8ff5be1b"],
 " "
}], "TechNoteText",
 CellID->2008471872,ExpressionUUID->"5c60e724-cedb-4b96-a86e-64ff45540f30"],

Cell[TextData[{
 "and the ",
 StyleBox["reflection",
  FontSlant->"Italic"],
 " in the line along the vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"x", ":", 
       RowBox[{"-", "\[Theta]"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "5d1e5419-ebf5-4f09-85fb-7563bd763372"],
 " (see also ",
 ButtonBox["Figure 4",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1875896075"],
 " for a geometric interpretation)"
}], "TechNoteText",
 CellID->91305511,ExpressionUUID->"537e74e7-9f73-47a6-8b9c-14b7926bd1cb"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"2", 
       TemplateBox[{
         RowBox[{"x", ":", 
           RowBox[{"-", "\[Theta]"}]}]},
        "Ket"], 
       TemplateBox[{
         RowBox[{"x", ":", 
           RowBox[{"-", "\[Theta]"}]}]},
        "Bra"]}], "-", "1"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["R", "x"], "(", 
        RowBox[{"-", "\[Theta]"}], ")"}], "Z", "\[VeryThinSpace]", 
       RowBox[{
        SubsuperscriptBox["R", "x", "\[Dagger]"], "(", 
        RowBox[{"-", "\[Theta]"}], ")"}]}], "\[DotEqual]", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
          RowBox[{
           RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "sin", "\[VeryThinSpace]",
            "\[Theta]"}]},
         {
          RowBox[{
          "\[ImaginaryI]", "\[VeryThinSpace]", "sin", "\[VeryThinSpace]", 
           "\[Theta]"}], 
          RowBox[{
           RowBox[{"-", "cos"}], "\[VeryThinSpace]", "\[Theta]"}]}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "b08a5890-fd6b-4e22-b4e3-97620558d808"],
 "."
}], "TechNoteText",
 CellID->1268399419,ExpressionUUID->"f7b93b0d-d4ee-4d1f-aa34-2b9775301bb3"],

Cell["Now, note that", "TechNoteText",
 CellID->2066355011,ExpressionUUID->"6b73a16d-cf98-4244-bf76-ea66ad83202c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], "\[DotEqual]", 
     RowBox[{"(", GridBox[{
        {"\[Lambda]", 
         RowBox[{"\[ImaginaryI]", 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["\[Lambda]", "2"]}]]}]},
        {
         RowBox[{"\[ImaginaryI]", 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["\[Lambda]", "2"]}]]}], "\[Lambda]"}
       }], ")"}]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalOmega]", "x"], "(", "\[Lambda]", ")"}], "Z"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], 
       "Z"}], "=", 
      RowBox[{
       SubsuperscriptBox["R", "x", "\[Dagger]"], "(", 
       RowBox[{"2", "\[Theta]"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"614c356e-987f-41a4-b434-622647f0f5eb"],
 "."
}], "TechNoteText",
 CellID->123130593,ExpressionUUID->"cd9fbc0f-b02b-4576-921f-f2041b89d3e4"],

Cell[TextData[{
 "In other words, combined with the Pauli ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "6fce7c69-0364-45c9-a46e-9ce69f0a5d42"],
 " operator, the reflection ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"8e28a8cf-0adb-427f-ae98-735369aedc85"],
 " in the line along the vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"x", ":", 
       RowBox[{"-", "\[Theta]"}]}]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "44599370-972b-4823-8fc5-857be21f27e4"],
 " gives rise to the rotation around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "2a2f34d9-8e64-4f35-9e2b-11657f9aa2c2"],
 "-axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Theta]"}], TraditionalForm]],ExpressionUUID->
  "95883f51-6dbb-422f-8a9f-cad3b861fb5d"]
}], "TechNoteText",
 CellID->1429124490,ExpressionUUID->"2bda06b3-dabd-4f02-9954-cf5ac22ed5cc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], "Z"}], 
    "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["R", "x"], "(", 
       RowBox[{"-", "\[Theta]"}], ")"}], "Z", "\[VeryThinSpace]", 
      RowBox[{
       SubsuperscriptBox["R", "x", "\[Dagger]"], "(", 
       RowBox[{"-", "\[Theta]"}], ")"}], "Z"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["R", "x"], "(", 
        RowBox[{"-", "\[Theta]"}], ")"}], 
       RowBox[{
        SubscriptBox["R", "x"], "(", 
        RowBox[{"-", "\[Theta]"}], ")"}]}], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox["R", "x"], "(", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Theta]"}], ")"}], "\[DotEqual]", 
       RowBox[{"(", GridBox[{
          {
           RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
           RowBox[{
           "\[ImaginaryI]", "\[VeryThinSpace]", "sin", "\[VeryThinSpace]", 
            "\[Theta]"}]},
          {
           RowBox[{
           "\[ImaginaryI]", " ", "sin", "\[VeryThinSpace]", "\[Theta]"}], 
           RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}]}
         }], ")"}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "4b0df07f-0c0b-4bc2-be34-22b518662fb7"],
 " ."
}], "TechNoteText",
 CellID->1838195382,ExpressionUUID->"f883cab2-91cf-4ff5-bc7d-b6963d60efa4"],

Cell[TextData[{
 "This relation becomes even clearer with a geometrical view as shown in ",
 ButtonBox["Figure 4",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1875896075"],
 "."
}], "TechNoteText",
 CellID->850039532,ExpressionUUID->"67c886d6-8a20-4baa-aefb-affae2f8e8aa"],

