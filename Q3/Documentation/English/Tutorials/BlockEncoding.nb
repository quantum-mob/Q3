Cell[TextData[{
 "Block encoding is a method to get a quantum computer accessible to the \
information in a matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "c76bbee0-52f5-4ad6-9b8d-bc918d703cd4"],
 ". Typically, the resulting bigger embedding matrix is denoted by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "fe8831d8-0e8b-4228-85d1-9f730400c515"],
 " and has the block form"
}], "TechNoteText",
 CellID->495219038,ExpressionUUID->"e411b7f5-554e-40fd-9321-1635cabc368a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "M"], ":=", 
    RowBox[{"(", GridBox[{
       {"M", "*"},
       {"*", "*"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "59d385fd-09ab-41b8-959e-a845f4b9c3c5"],
 " ,"
}], "TechNoteText",
 CellID->914482391,ExpressionUUID->"f0ba3a40-6936-44ff-9747-5ad4fcb92783"],

Cell["where * indicates the corresponding block is irrelevant.", \
"TechNoteText",
 CellID->737417743,ExpressionUUID->"a66048a7-d901-4b90-85a0-c4e62c1e0d1d"],

