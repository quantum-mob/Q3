Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Equivalent quantum circuits representing the block encoding of matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "e1c5a24a-692d-47f5-a78a-501c9731defc"],
 " that has singular value decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"V", "\[VeryThinSpace]", "\[CapitalLambda]", "\[VeryThinSpace]", 
     SuperscriptBox["W", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "801b13b5-6f18-4617-ac22-979e5d89bd7f"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", ":=", 
    RowBox[{"diag", "(", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", 
       SubscriptBox["\[Lambda]", "2"]}], "\[InvisibleComma]", 
      RowBox[{",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Lambda]", "n"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"e6a3d9dc-32ab-424a-a76f-c83a316b35c9"],
 ". Here, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalOmega]", "k"], TraditionalForm]],ExpressionUUID->
  "4082396a-317d-4c49-b96c-9f4c2b2c971b"],
 " is a short-hand notation for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "k"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "y"], "(", 
      SubscriptBox["\[Lambda]", "k"], ")"}], "=", 
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "y"], "(", 
      SubscriptBox["cos\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"712704bf-3b07-40ee-9e05-3937e08c329c"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "(", 
     SubscriptBox["\[Theta]", "k"], ")"}], ":=", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "1ce84db2-cf0e-4e9e-a240-4340991da1fd"],
 "."
}], "TechNoteCaption",
 CellID->1930729324,ExpressionUUID->"ab787a80-46b0-4b52-9c2d-3af7e7dfe505"],

Cell[TextData[{
 "As one can see in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1930729324"],
 ", the computational cost of block encoding is exponentially high in \
general. Recently, an approximation method has been proposed to overcome \
this; see ",
 ButtonBox["Camps and Van Beeumen (2022)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1109/QCE53715.2022.00029"], None}],
 "."
}], "TechNoteText",
 CellID->1166358748,ExpressionUUID->"c1c1e115-2569-4b56-9e31-6cd07d70165c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Remark: Alternative Block Encoding", "Subsection",
 CellID->1461512543,ExpressionUUID->"a255d018-3eab-4e1d-9657-432335319c69"],

Cell["\<\
Another common implementation of block encoding is through the mapping [see, \
e.g., Lin (2022)]\
\>", "TechNoteText",
 CellID->1384037681,ExpressionUUID->"021b17f8-edd7-49d7-b3b0-999a92950b9e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"V", "0"},
        {"0", "I"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {"\[CapitalLambda]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[CapitalLambda]", "2"]}]]},
        {
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[CapitalLambda]", "2"]}]], 
         RowBox[{"-", "\[CapitalLambda]"}]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox["W", "\[Dagger]"], "0"},
        {"0", "I"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "94bd9117-4037-4968-8f4d-5463eaa3f1eb"],
 " ."
}], "TechNoteText",
 CellID->1890969919,ExpressionUUID->"e0ca6377-f1bc-4207-82ad-5e1d4b6544d7"],

Cell[TextData[{
 "Q3 does not consider this because ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"V", "0"},
      {"0", "I"}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "7d160d49-94c6-4c03-8b57-d4546a95eeee"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SuperscriptBox["W", "\[Dagger]"], "0"},
      {"0", "I"}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "3f7f12d2-7919-4b88-9120-d11c3305e638"],
 " correspond to controlled-unitary gates. When ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "41840db8-b149-4878-9570-3708e5c27da8"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "05a28cda-882c-41b2-b596-349249fda61c"],
 " are large, the actual implementation of those controlled-unitary gates may \
be computationally expensive."
}], "TechNoteText",
 CellID->1640996415,ExpressionUUID->"70441f10-479b-4e7b-b8cd-7755a8b68eaf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Geometric View: Relation to the Grover Rotation", "Subsection",
 CellID->1532784647,ExpressionUUID->"0ca9026f-f9cc-471c-aba7-38e4c00397cc"],

Cell[TextData[{
 "The reflection ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"dd214115-6ce9-46de-901f-4cd406c886e6"],
 " in the line along the vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Theta]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "6816507e-4ddc-47af-8cbe-643f1bfbc182"],
 " can be converted to the rotation around the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "9894458f-e036-41c1-9d06-d56a5ca151d3"],
 "-axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Theta]"}], TraditionalForm]],ExpressionUUID->
  "ac212d12-ba54-40a4-a76a-bbeac806600b"],
 " by multiplying the Pauli ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "8fea9672-72bb-4253-bf4b-6b3853ca13f7"],
 " operator. In other words, it is useful to define a Grover-like rotation \
around the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "54c706eb-b26f-482d-a2ad-cdee4ac6dbb7"],
 "-axis by"
}], "TechNoteText",
 CellID->465522068,ExpressionUUID->"682b07c4-bf83-4805-8793-a86e795c8a68"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "y"], "(", "\[Lambda]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], "Z"}],
      "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], "Z", "\[VeryThinSpace]", 
       RowBox[{
        SubsuperscriptBox["R", "y", "\[Dagger]"], "(", "\[Theta]", ")"}], 
       "Z"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], 
        RowBox[{
         SubscriptBox["R", "y"], "(", "\[Theta]", ")"}]}], "=", 
       RowBox[{
        RowBox[{
         SubscriptBox["R", "y"], "(", 
         RowBox[{"2", "\[Theta]"}], ")"}], "\[DotEqual]", 
        RowBox[{"(", GridBox[{
           {
            RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
            RowBox[{
             RowBox[{"-", "sin"}], "\[VeryThinSpace]", "\[Theta]"}]},
           {
            RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}], 
            RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}]}
          },
          GridBoxAlignment->{"Columns" -> {{Right}}, "Rows" -> {{Baseline}}}],
          ")"}]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "5a8c55f9-e251-4cc3-b543-c783c14e6f09"],
 " ."
}], "TechNoteText",
 CellID->746470855,ExpressionUUID->"e7bc7706-e904-4f15-892e-910ab89ea9d0"],

Cell[TextData[{
 "This relation can also be understood with a geometrical view as shown in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#529413056"],
 ". The ",
 ButtonBox["Grover rotation",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumSearchAlgorithm#1497043023"],
 " in ",
 ButtonBox["quantum search algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumSearchAlgorithm"],
 " has also a similar geometric interpretation."
}], "TechNoteText",
 CellID->62712795,ExpressionUUID->"63f14613-81df-454f-a0e1-b5cc4bbc2ae2"],

Cell[TextData[Cell[BoxData[
 GraphicsBox[{CircleBox[{0, 0}], 
   {GrayLevel[0.8], ArrowBox[{{1.2, 0}, {-1.2, 0}}], 
    LineBox[{{0, -1.2}, {0, 1.2}}], InsetBox[
     StyleBox["\<\"X\"\>",
      StripOnInput->False,
      FontSize->Large,
      FontSlant->Italic], {-1.2, 0}, NCache[
     ImageScaled[{0, Rational[-1, 2]}], ImageScaled[{0, -0.5}]]]}, 
   ArrowBox[{{0, 0}, {0, 1.2}}], 
   {RGBColor[0, 0, 1], Thickness[Large], 
    ArrowBox[{{0, 0}, {-0.19509032201612825`, 0.9807852804032304}}], 
    {RGBColor[1, 0, 0], 
     ArrowBox[{{0, 0}, {0.19509032201612825`, 0.9807852804032304}}]}, 
    {RGBColor[0, 0, 1], 
     ArrowBox[{{0, 0}, {-0.5555702330196022, 0.8314696123025452}}]}, 
    {RGBColor[1, 0, 0], 
     ArrowBox[{{0, 0}, {0.5555702330196022, 0.8314696123025452}}]}, 
    {RGBColor[0, 0, 1], 
     ArrowBox[{{0, 0}, {-0.8314696123025451, 0.5555702330196023}}]}}, 
   {LightDarkSwitched[
     GrayLevel[0]], Dashing[{Small, Small}], 
    ArrowBox[{{-0.19509032201612825`, 0.9807852804032304}, {
     0.19509032201612825`, 0.9807852804032304}}], 
    ArrowBox[{{0.19509032201612825`, 
     0.9807852804032304}, {-0.5555702330196022, 0.8314696123025452}}], 
    ArrowBox[{{-0.5555702330196022, 0.8314696123025452}, {0.5555702330196022, 
     0.8314696123025452}}], 
    ArrowBox[{{0.5555702330196022, 0.8314696123025452}, {-0.8314696123025451, 
     0.5555702330196023}}], InsetBox[
     StyleBox["\<\"Z\"\>",
      StripOnInput->False,
      FontSize->Large,
      FontSlant->Italic], {0, 1.2}, ImageScaled[{-1, 1}]]}},
  ImageSize->Large,
  PlotRangePadding->Scaled[
   0.025]]],ExpressionUUID->"d134b71b-08b6-4b2f-a043-bc31a58b9d2a"]], \
"Picture",
 CellID->1153346113,ExpressionUUID->"250f37a8-b569-44a8-94ee-9e3a0804cfa7"],

Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ". A geometric view of the effects of the reflection ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "88b6e441-4aea-40d5-9b7f-4a339ffc5c8a"],
 " in the line along the computational basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "d404b016-23e9-4841-940b-d27b005a1fc7"],
 " (from blue to red arrows) and the reflection ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"e75c62d1-5dea-4b98-9633-0ace4f66cc1d"],
 " in the line along the rotated basis vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Theta]"},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "fbb3bcf3-8774-464c-a8ca-aad9dd8c85c4"],
 " (from red to blue arrows). Combining  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"583fc40e-e621-4a3a-8b69-6a1c61775b9d"],
 " with ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "3c7a5899-fda4-48ed-91c1-2a7f433a66dd"],
 " gives rise to the Grover rotation (from blue to blue arrows). Shown is the \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "\[VeryThinSpace]", "x"}], TraditionalForm]],ExpressionUUID->
  "7dec8495-4ba6-4559-a848-5bd88d6fd42a"],
 "-plane in the Bloch space with the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "b03252bc-4a71-4384-8859-a3f4d2027e99"],
 "-axis in the vertical direction and the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "12626281-653a-429a-9d71-b81a3ed10d4f"],
 "-axis pointing out of the screen."
}], "TechNoteCaption",
 CellID->529413056,ExpressionUUID->"8b72857d-3e12-421c-96be-ba280347ff89"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The GSLW Convention", "TechNoteSection",
 CellID->618934295,ExpressionUUID->"5c4b46eb-4e1d-4f58-adda-d7de5990a5a4"],

Cell["\<\
In GSLW (Gily\[EAcute]n, Su, Low and Wiebe, 2019),  the block encoding is \
implemented as\
\>", "TechNoteText",
 CellID->17909997,ExpressionUUID->"29f80deb-90e3-4829-96e1-9804979af114"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"M", "\[RightTeeArrow]", 
     SubscriptBox["U", "M"]}], ":=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"V", "0"},
        {"0", "V"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {"\[CapitalLambda]", 
         RowBox[{"\[ImaginaryI]", 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["\[CapitalLambda]", "2"]}]]}]},
        {
         RowBox[{"\[ImaginaryI]", 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["\[CapitalLambda]", "2"]}]]}], "\[CapitalLambda]"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox["W", "\[Dagger]"], "0"},
        {"0", 
         SuperscriptBox["W", "\[Dagger]"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "f7536440-2abc-4857-8ffe-048f0a6951fd"],
 " ."
}], "TechNoteText",
 CellID->365608999,ExpressionUUID->"0ad9d622-0aa8-4271-8223-4a958544c1ee"],

Cell[CellGroupData[{

Cell["Quantum Circuit Model", "Subsection",
 CellID->950427654,ExpressionUUID->"31a51267-05cb-4056-a05c-ae64013124bc"],

Cell[TextData[{
 "For a quantum circuit model of this implementation, we introduce a \
Grover-like rotation around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "6c8fb93c-1baa-44a4-adf7-62d76b4fc8c6"],
 "-axis,"
}], "TechNoteText",
 CellID->1012258301,ExpressionUUID->"f1568c34-d2a1-460c-aa47-c8d37d615d16"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"\[Lambda]", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[Lambda]", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[Lambda]", "2"]}]]}], "\[Lambda]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "fa24591b-98e5-45da-a0f0-3339eb0ab000"],
 "."
}], "TechNoteText",
 CellID->1216167028,ExpressionUUID->"82dbb96c-ca16-4297-bc30-af3a0b844500"],

Cell[TextData[{
 "It turns out that with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], ":=", "\[Lambda]"}], 
   TraditionalForm]],ExpressionUUID->"7f6b23d2-1aa3-4aa0-a4d8-6afdb963e749"],
 " (i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}], "=", 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox["\[Lambda]", "2"]}]]}], TraditionalForm]],ExpressionUUID->
  "931f9558-1856-4fad-a335-d484f5f144b2"],
 "),\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["G", "x"], "(", "cos\[Theta]", ")"}], "=", 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["R", "x", "\[Dagger]"], "(", 
       RowBox[{"2", "\[Theta]"}], ")"}], "\[DotEqual]", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
          RowBox[{
          "\[ImaginaryI]", "\[VeryThinSpace]", "sin", "\[VeryThinSpace]", 
           "\[Theta]"}]},
         {
          RowBox[{
          "\[ImaginaryI]", "\[VeryThinSpace]", "sin", "\[VeryThinSpace]", 
           "\[Theta]"}], 
          RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}]}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "94f0d95b-d052-4ebd-adbe-33e156881d25"],
 " ."
}], "TechNoteText",
 CellID->1044549548,ExpressionUUID->"d9115d97-41ac-4eb3-808d-be1ff3ec1580"],

Cell[TextData[{
 "In passing, note  that the Grover-like rotation around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "091012ee-f7e4-4209-86f8-b134304d9e10"],
 "-axis and the one around ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "d2380a24-ce1f-4388-9b33-56b6b92d8902"],
 "-axis seen before are related to each other by"
}], "TechNoteText",
 CellID->1940545583,ExpressionUUID->"55537792-1d03-4f50-b964-3db976510aad"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "Z", "\[VeryThinSpace]", 
       RowBox[{"\[Pi]", "/", "4"}]}]], 
     RowBox[{
      SubscriptBox["G", "y"], "(", "\[Lambda]", ")"}], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "Z", "\[VeryThinSpace]", 
       RowBox[{"\[Pi]", "/", "4"}]}]]}]}], TraditionalForm]],ExpressionUUID->
  "ec08c9f5-9b06-4647-8e1e-5c7ffa7daa9f"],
 " ."
}], "TechNoteText",
 CellID->47109639,ExpressionUUID->"b898cf24-b0fd-4b31-8872-2b90bc25d272"],

Cell[TextData[{
 "The GSLW form of block encoding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "6a761acd-7322-404f-9092-68d9c340aead"],
 " can be rewritten as"
}], "TechNoteText",
 CellID->352901706,ExpressionUUID->"498e6dd9-f31a-4a70-b787-d622c02f2d90"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "M"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", "V"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", "k"], 
       RowBox[{
        RowBox[{
         SubscriptBox["G", "x"], "(", 
         SubscriptBox["\[Lambda]", "k"], ")"}], "\[CircleTimes]", 
        TemplateBox[{"k"},
         "Ket"]}], 
       TemplateBox[{"k"},
        "Bra"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", 
       SuperscriptBox["W", "\[Dagger]"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"55d93949-5143-4ce9-b1c7-ec3785c1fae4"],
 "."
}], "TechNoteText",
 CellID->2016623375,ExpressionUUID->"5c90d252-1b32-4512-b145-a90341ffd8b7"],

Cell[TextData[{
 "where again ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"k"},
        "Ket"], ":", "k"}], "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"c81b7397-7eb5-4601-8477-629239259c9c"],
 " is the computational basis of the system register. Clearly, the expression \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["\[CapitalSigma]", "k"], 
    RowBox[{
     RowBox[{
      SubscriptBox["G", "x"], "(", 
      SubscriptBox["\[Lambda]", "k"], ")"}], "\[CircleTimes]", 
     TemplateBox[{"k"},
      "Ket"]}], 
    TemplateBox[{"k"},
     "Bra"]}], TraditionalForm]],ExpressionUUID->
  "9cc772dd-878a-478e-b5ef-ebb99501af3f"],
 " in the middle is nothing but the ",
 ButtonBox["uniformly-controlled unitary gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/UniformlyControlledGate"],
 " operating ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "x"], "(", 
    SubscriptBox["\[Lambda]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "2d346d71-aa79-42ec-8b93-9a08fad71aea"],
 "conditioned on the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"k"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "c20e4193-9d88-4ca1-9ec3-a2bf7af29599"],
 " of the system register."
}], "TechNoteText",
 CellID->1802146671,ExpressionUUID->"c60bc968-fc7f-435b-a030-67157513ae25"],

Cell[TextData[{
 "Putting all together, the block encoding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "04795394-981f-4ae1-99d3-54849bb24261"],
 " may be described by the quantum circuit in ",
 ButtonBox["Figure 3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1045391992"],
 "."
}], "TechNoteText",
 CellID->839732126,ExpressionUUID->"283eee72-5c59-4b51-a0b5-85ff2459e134"],

Cell[TextData[{
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {2, -1}}, {{0, -3}, {2, -3}}, {{0, -4}, {2, -4}}, {{
     0, -5}, {2, -5}}}], {LineBox[{{1, -1}, {1, -3}, {1, -4}, {1, -5}}], 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -1.4}, {1.4, -0.6},
       RoundingRadius->0.4]}, InsetBox[
      StyleBox["\<\"enc\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.2],
       FontWeight->"Light",
       FontSlant->Italic], {1., -1.}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {0, 1}], 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -5.4}, {1.4, -2.6}]}, InsetBox[
      StyleBox["\<\"M\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.2],
       FontWeight->"Light",
       FontSlant->Italic], {1., -4.}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}},
   ImagePadding->{{25.56, 25.56}, {7.2, 7.2}},
   ImageSize->118.8,
   PlotRange->{{0, 2}, {-5.5, -0.5}},
   PlotRangePadding->Scaled[0.025]]],ExpressionUUID->
  "475ab11b-2b3b-45a8-a45d-66fa473aee2e"],
 "=",
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {4, -1}}, {{0, -3}, {4, -3}}, {{0, -4}, {4, -4}}, {{
     0, -5}, {4, -5}}}], {
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -5.4}, {1.4, -2.6}]}, InsetBox[
      StyleBox[
       TemplateBox[{"\"W\"", "\"\[Dagger]\""},
        "Superscript"],
       StripOnInput->False,
       FontSize->Scaled[0.1],
       FontWeight->"Light",
       FontSlant->Italic], {1., -4.}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}, {LineBox[{{2, -3}, {2, -4}, {2, -5}, {2, -1}}], 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      DiskBox[{2, -3}, 0.09, 
       NCache[{Rational[1, 4] Pi, Rational[5, 4] Pi}, {0.7853981633974483, 
        3.9269908169872414`}]], 
      {LightDarkSwitched[
        GrayLevel[0]], 
       DiskBox[{2, -3}, 0.09, 
        NCache[{Rational[-3, 4] Pi, Rational[1, 4] Pi}, {-2.356194490192345, 
         0.7853981633974483}]]}}, 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      DiskBox[{2, -4}, 0.09, 
       NCache[{Rational[1, 4] Pi, Rational[5, 4] Pi}, {0.7853981633974483, 
        3.9269908169872414`}]], 
      {LightDarkSwitched[
        GrayLevel[0]], 
       DiskBox[{2, -4}, 0.09, 
        NCache[{Rational[-3, 4] Pi, Rational[1, 4] Pi}, {-2.356194490192345, 
