Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ThePauli", "[", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3", ",", "1"}], "}"}], "]"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"I", "/", "2"}], ")"}], "*", 
       RowBox[{"ThePauli", "[", 
        RowBox[{"{", 
         RowBox[{"3", ",", "2", ",", "2"}], "}"}], "]"}]}]}], ")"}], "/", 
    "4"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"in", "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[410]:=",
 CellID->959780981,ExpressionUUID->"c4653096-036d-4406-98ca-9054f9b931d8"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"0", "0", "0", 
      RowBox[{"-", 
       FractionBox["\[ImaginaryI]", "8"]}], "0", 
      RowBox[{"-", 
       FractionBox["\[ImaginaryI]", "4"]}], "0", "0"},
