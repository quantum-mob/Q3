 CellID->403330096,ExpressionUUID->"99662693-9694-447f-b23d-71125e7192e9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Block Encoding", "TechNoteSection",
 CellID->1159336212,ExpressionUUID->"bf8c412e-a2dc-4f69-bca6-f68eeefe1727"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "b38614a1-e95a-43ef-bfc7-c5db403b966b"],
 " be a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "\[Times]", "N"}], TraditionalForm]],ExpressionUUID->
  "d6f1ae2c-4492-4030-8400-91429632bc8a"],
 " (with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", ":=", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "b71ef9aa-47d8-4683-ab4f-5ad595353752"],
 ") complex matrix, which is not unitary in general. Suppose that ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "d36dea89-e62e-43ae-81c8-86350e81e402"],
 " has the singular-value decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"V", "\[VeryThinSpace]", "\[CapitalLambda]", "\[VeryThinSpace]", 
     SuperscriptBox["W", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "dbd1e327-a7e2-42a3-a933-10bdcd7a5965"],
 ", where ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "f8585097-ada4-4d01-9a65-42b2ded7fbbd"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "87f4ebc7-22c0-4901-a4cd-bf22ff1d5159"],
 " are unitary matrices and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", ":=", 
    RowBox[{
     RowBox[{"diagonal", "(", 
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", 
       SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Lambda]", "N"]}], ")"}], "\[GreaterEqual]", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"21ab5e7b-3075-4410-b953-7fa127401f75"],
 " is the diagonal matrix of singular values. We assume that the singular \
values are all less than 1; ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    SubscriptBox["\[Lambda]", "k"], "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"28710204-e5c1-425d-a381-0e26da93059d"],
 ". Note that this is not a restriction since one can always rescale the \
matrix by a constant factor."
}], "TechNoteText",
 CellID->924234893,ExpressionUUID->"1a668bb7-0e0b-4022-8e35-86848b5b0ce4"],

Cell["In Q3, the block encoding is implemented as", "TechNoteText",
 CellID->421835684,ExpressionUUID->"18eadd80-f3d3-4935-bddb-a2c791cc721d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"M", "\[RightTeeArrow]", 
     SubscriptBox["U", "M"]}], ":=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"V", "0"},
        {"0", "V"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {"\[CapitalLambda]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[CapitalLambda]", "2"]}]]},
        {
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[CapitalLambda]", "2"]}]], 
         RowBox[{"-", "\[CapitalLambda]"}]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox["W", "\[Dagger]"], "0"},
        {"0", 
         SuperscriptBox["W", "\[Dagger]"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "c7eb8f30-f2a7-45a7-87ab-3d86470b17ec"],
 " ."
}], "TechNoteText",
 CellID->335632754,ExpressionUUID->"dee41647-33ff-4ee1-ab8b-c37f6a1e592d"],

Cell[CellGroupData[{

Cell["Quantum Circuit Model", "Subsection",
 CellID->202996542,ExpressionUUID->"7ff1ad6b-2102-4661-a165-42eda3327998"],

Cell["\<\
For a quantum circuit model of this implementation, we introduce a rotated \
basis state\
\>", "TechNoteText",
 CellID->558350187,ExpressionUUID->"49aaed06-0882-4cd2-9544-637ee4f5a34e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Theta]"},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], 
      TemplateBox[{"0"},
       "Ket"]}], "\[DotEqual]", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"cos", "(", 
          RowBox[{"\[Theta]", "/", "2"}], ")"}]},
        {
         RowBox[{"sin", "(", 
          RowBox[{"\[Theta]", "/", "2"}], ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "be133b96-b7e5-49f0-92c0-edf2cd46cde5"],
 " "
}], "TechNoteText",
 CellID->2075704915,ExpressionUUID->"9a111ce9-1f1f-4e39-b6fb-cce2f522979a"],

Cell[TextData[{
 "and the ",
 StyleBox["reflection",
  FontSlant->"Italic"],
 " in the line along the vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Theta]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "cd9d3bd9-7595-4bae-8a77-20d227909042"],
 " (see also ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#529413056"],
 " for a geometric interpretation)"
}], "TechNoteText",
 CellID->859223815,ExpressionUUID->"3e5ba6c0-f7cc-4551-b933-a431caebbb3c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"2", 
       TemplateBox[{"\[Theta]"},
        "Ket"], 
       TemplateBox[{"\[Theta]"},
        "Bra"]}], "-", "1"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], "Z", "\[VeryThinSpace]", 
       RowBox[{
        SubsuperscriptBox["R", "y", "\[Dagger]"], "(", "\[Theta]", ")"}]}], "\[DotEqual]", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
          RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}]},
         {
          RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}], 
          RowBox[{
           RowBox[{"-", "cos"}], "\[VeryThinSpace]", "\[Theta]"}]}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "23a41160-6d7a-46f8-a74a-efb67b16db2a"],
 "."
}], "TechNoteText",
 CellID->2017529232,ExpressionUUID->"d7047f04-d2d3-4427-9a9e-d406e68b9594"],

Cell["Now, note that", "TechNoteText",
 CellID->1406247985,ExpressionUUID->"1f132372-1146-4dd7-bd37-8982ead6bd12"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", GridBox[{
        {"\[Lambda]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[Lambda]", "2"]}]]},
        {
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[Lambda]", "2"]}]], 
         RowBox[{"-", "\[Lambda]"}]}
       }], ")"}], "\[DotEqual]", 
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "y"], "(", "\[Lambda]", ")"}]}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}]}], 
   TraditionalForm]],ExpressionUUID->"a988a968-3588-4c55-b90a-47b9d0719c4d"]
}], "TechNoteText",
 CellID->1586859734,ExpressionUUID->"25f4bb45-5c0e-47e8-82e9-cb103b6d492f"],

Cell[TextData[{
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], ":=", "\[Lambda]"}], 
   TraditionalForm]],ExpressionUUID->"aa7b2546-2751-4191-930f-4c25dcb9b874"],
 " (i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}], "=", 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox["\[Lambda]", "2"]}]]}], TraditionalForm]],ExpressionUUID->
  "7743b081-c3c8-4062-bf54-cd1fcbd55ba6"],
 "). Therefore, the block encoding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "68d49a47-5479-4760-9873-30d9017ba985"],
 " can be rewritten as"
}], "TechNoteText",
 CellID->752137245,ExpressionUUID->"a41bc79a-6fe0-49e2-97ff-282565ffd695"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "M"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", "V"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", "k"], 
       RowBox[{
        RowBox[{
         SubscriptBox["\[CapitalOmega]", "y"], "(", 
         SubscriptBox["\[Lambda]", "k"], ")"}], "\[CircleTimes]", 
        TemplateBox[{"k"},
         "Ket"]}], 
       TemplateBox[{"k"},
        "Bra"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", 
       SuperscriptBox["W", "\[Dagger]"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"da06f054-62cc-416f-9476-d5ce17452dae"],
 ","
}], "TechNoteText",
 CellID->1134072701,ExpressionUUID->"f6371a3e-cb36-49bf-9ae8-fa951e7d07b6"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "\[VeryThinSpace]", 
     SubscriptBox["\[Theta]", "k"]}], ":=", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "ba1b04ec-053a-49b3-b12c-8228a84ced6d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"k"},
        "Ket"], ":", "k"}], "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"4e198ac5-ae48-4124-81a8-f1346bdb6932"],
 " is the computational basis of the system register. In particular, the \
expression ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["\[CapitalSigma]", "k"], 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "y"], "(", 
      SubscriptBox["\[Lambda]", "k"], ")"}], "\[CircleTimes]", 
     TemplateBox[{"k"},
      "Ket"]}], 
    TemplateBox[{"k"},
     "Bra"]}], TraditionalForm]],ExpressionUUID->
  "7b692828-79e6-486c-a655-7270ed95e80f"],
 " in the middle is nothing but the ",
 ButtonBox["uniformly-controlled unitary gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/UniformlyControlledGate"],
 " operating ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "y"], "(", 
    SubscriptBox["\[Lambda]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "b2b79ad6-d73d-4fb2-aa54-db3d28f6d4b6"],
 " conditioned on the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"k"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3a8404f2-360a-4e52-a6dc-d201baf9ed54"],
 " of the system register."
}], "TechNoteText",
 CellID->141741977,ExpressionUUID->"8aacb2ed-2626-436f-a28c-299f4b917213"],

Cell[TextData[{
 "Putting all together, the block encoding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "7953c0d8-767e-4f03-9582-e490f61a3714"],
 " may be described by the quantum circuit in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1930729324"],
 "."
}], "TechNoteText",
 CellID->1164104608,ExpressionUUID->"3cc442bb-d22b-4ec4-b619-1042e3f3b84f"],

