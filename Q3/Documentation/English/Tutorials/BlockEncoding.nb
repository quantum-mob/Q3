 CellLabel->"In[400]:=",
 CellID->403330096,ExpressionUUID->"e598af94-5b28-41f1-9be9-48470d7108ca"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Block Encoding", "TechNoteSection",
 CellID->1159336212,ExpressionUUID->"39777793-1a76-4443-9f61-f21031081af2"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "7c37681e-e141-4d52-843a-f88f18d27163"],
 " be a ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", "\[Times]", "N"}], TraditionalForm]],ExpressionUUID->
  "8241fd67-03fa-4420-8e98-2f4359d7df5e"],
 " (with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", ":=", 
    SuperscriptBox["2", "n"]}], TraditionalForm]],ExpressionUUID->
  "7f4232c3-e263-4818-adb8-1ef267938e2e"],
 ") complex matrix, which is not unitary in general. Suppose that ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "fd21d904-6ee6-4c66-8fa1-ada53d0c1152"],
 " has the singular-value decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"V", "\[VeryThinSpace]", "\[CapitalLambda]", "\[VeryThinSpace]", 
     SuperscriptBox["W", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "fbeee6b0-b19a-4949-8a48-3c1a32418295"],
 ", where ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "e8e573e5-0f85-4e43-a67c-3ec6d689e19e"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "9ec1b98f-150d-4a76-af59-d1b9871cb889"],
 " are unitary matrices and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", ":=", 
    RowBox[{
     RowBox[{"diagonal", "(", 
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", 
       SubscriptBox["\[Lambda]", "2"], ",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Lambda]", "N"]}], ")"}], "\[GreaterEqual]", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"cb0cfbf5-0fa6-470d-b257-d1dab2d8e74c"],
 " is the diagonal matrix of singular values. We assume that the singular \
values are all less than 1; ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    SubscriptBox["\[Lambda]", "k"], "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"557db9c8-7aca-4316-b286-1ada5ac76c53"],
 ". Note that this is not a restriction since one can always rescale the \
matrix by a constant factor."
}], "TechNoteText",
 CellID->924234893,ExpressionUUID->"3831051c-ac9b-4dc5-97a7-c80d4a59c978"],

Cell["In Q3, the block encoding is implemented as", "TechNoteText",
 CellID->421835684,ExpressionUUID->"b983399e-6a3a-4cf6-afef-69ba5fdd1366"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"M", "\[RightTeeArrow]", 
     SubscriptBox["U", "M"]}], ":=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"V", "0"},
        {"0", "V"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {"\[CapitalLambda]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[CapitalLambda]", "2"]}]]},
        {
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[CapitalLambda]", "2"]}]], 
         RowBox[{"-", "\[CapitalLambda]"}]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox["W", "\[Dagger]"], "0"},
        {"0", 
         SuperscriptBox["W", "\[Dagger]"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "97dcebfc-ca37-4c2a-ab1b-9b09e5db9420"],
 " ."
}], "TechNoteText",
 CellID->335632754,ExpressionUUID->"85f1908e-2a39-4708-88e0-35553be5d69b"],

Cell[CellGroupData[{

Cell["Quantum Circuit Model", "Subsection",
 CellID->202996542,ExpressionUUID->"161f8077-dcec-4f47-8369-5b5801ed0689"],

Cell["\<\
For a quantum circuit model of this implementation, we introduce a rotated \
basis state\
\>", "TechNoteText",
 CellID->558350187,ExpressionUUID->"ab3c931a-52b7-4d53-9b16-997340a49768"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Theta]"},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], 
      TemplateBox[{"0"},
       "Ket"]}], "\[DotEqual]", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"cos", "(", 
          RowBox[{"\[Theta]", "/", "2"}], ")"}]},
        {
         RowBox[{"sin", "(", 
          RowBox[{"\[Theta]", "/", "2"}], ")"}]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "fd508b70-6562-4b08-9ca2-0d1c6d029675"],
 " "
}], "TechNoteText",
 CellID->2075704915,ExpressionUUID->"22aff54f-1cb0-49b9-aaca-aa62424f8259"],

Cell[TextData[{
 "and the ",
 StyleBox["reflection",
  FontSlant->"Italic"],
 " in the line along the vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Theta]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f8f36cf6-1ad7-4b88-ac53-35be86071b7e"],
 " (see also ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#529413056"],
 " for a geometric interpretation)"
}], "TechNoteText",
 CellID->859223815,ExpressionUUID->"8411b57f-254e-4535-afa7-9f9f182c863d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"2", 
       TemplateBox[{"\[Theta]"},
        "Ket"], 
       TemplateBox[{"\[Theta]"},
        "Bra"]}], "-", "1"}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], "Z", "\[VeryThinSpace]", 
       RowBox[{
        SubsuperscriptBox["R", "y", "\[Dagger]"], "(", "\[Theta]", ")"}]}], "\[DotEqual]", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
          RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}]},
         {
          RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}], 
          RowBox[{
           RowBox[{"-", "cos"}], "\[VeryThinSpace]", "\[Theta]"}]}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "ae992c05-0755-4138-9e86-4cb9dfdcd1de"],
 "."
}], "TechNoteText",
 CellID->2017529232,ExpressionUUID->"c6da0522-00fc-4fe8-8017-16c5824f190c"],

Cell["Now, note that", "TechNoteText",
 CellID->1406247985,ExpressionUUID->"ef237680-551a-4080-bee7-1cc407a986e9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"(", GridBox[{
        {"\[Lambda]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[Lambda]", "2"]}]]},
        {
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[Lambda]", "2"]}]], 
         RowBox[{"-", "\[Lambda]"}]}
       }], ")"}], "\[DotEqual]", 
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "y"], "(", "\[Lambda]", ")"}]}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}]}], 
   TraditionalForm]],ExpressionUUID->"436e3b79-4cd6-48b7-a941-0170b55dd9c2"]
}], "TechNoteText",
 CellID->1586859734,ExpressionUUID->"27f90a11-bfaf-4ab0-bd7f-d05c1b30fa7e"],

Cell[TextData[{
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], ":=", "\[Lambda]"}], 
   TraditionalForm]],ExpressionUUID->"f902deb9-076c-4479-910d-6227eb0fc67b"],
 " (i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}], "=", 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox["\[Lambda]", "2"]}]]}], TraditionalForm]],ExpressionUUID->
  "7a8ec9b0-3b64-47d5-8243-06dfa3a514b5"],
 "). Therefore, the block encoding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "0e161609-eafe-416c-850e-32b0d70813d3"],
 " can be rewritten as"
}], "TechNoteText",
 CellID->752137245,ExpressionUUID->"53719acf-7ec1-4cb5-b91c-338d385bfe1f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "M"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", "V"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", "k"], 
       RowBox[{
        RowBox[{
         SubscriptBox["\[CapitalOmega]", "y"], "(", 
         SubscriptBox["\[Lambda]", "k"], ")"}], "\[CircleTimes]", 
        TemplateBox[{"k"},
         "Ket"]}], 
       TemplateBox[{"k"},
        "Bra"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", 
       SuperscriptBox["W", "\[Dagger]"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"7f0b9ed1-1ca1-41e3-963d-0b554c017c91"],
 ","
}], "TechNoteText",
 CellID->1134072701,ExpressionUUID->"f2255f69-4734-46a7-a655-ea5da1471d94"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "\[VeryThinSpace]", 
     SubscriptBox["\[Theta]", "k"]}], ":=", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "43fff9a0-7a1d-4458-bfd8-72bb5104ab85"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"k"},
        "Ket"], ":", "k"}], "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"b58405d1-9a73-42ae-a81f-d7eb307955b7"],
 " is the computational basis of the system register. In particular, the \
expression ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["\[CapitalSigma]", "k"], 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "y"], "(", 
      SubscriptBox["\[Lambda]", "k"], ")"}], "\[CircleTimes]", 
     TemplateBox[{"k"},
      "Ket"]}], 
    TemplateBox[{"k"},
     "Bra"]}], TraditionalForm]],ExpressionUUID->
  "ed8ad160-e17e-4cd2-9514-54a46cf69681"],
 " in the middle is nothing but the ",
 ButtonBox["uniformly-controlled unitary gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/UniformlyControlledGate"],
 " operating ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "y"], "(", 
    SubscriptBox["\[Lambda]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "eaa1ed6c-2125-4306-aad2-709aa9999eb3"],
 " conditioned on the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"k"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "afdfbe31-b671-4fd6-b675-c83b3a7f37c4"],
 " of the system register."
}], "TechNoteText",
 CellID->141741977,ExpressionUUID->"d9acab3f-bb72-4885-bcbe-5bebadde57cc"],

Cell[TextData[{
 "Putting all together, the block encoding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "f12bd751-1e1c-46e0-ac1f-7469eaffb4bd"],
 " may be described by the quantum circuit in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1930729324"],
 "."
}], "TechNoteText",
 CellID->1164104608,ExpressionUUID->"8bc89466-bfc0-4a29-8ecf-c145d431a76a"],

