Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Equivalent quantum circuits representing the block encoding of matrix ",
 Cell[BoxData[
  FormBox["M", TraditionalForm]],ExpressionUUID->
  "4c241222-d060-473e-a719-95006793966a"],
 " that has singular value decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "=", 
    RowBox[{"V", "\[VeryThinSpace]", "\[CapitalLambda]", "\[VeryThinSpace]", 
     SuperscriptBox["W", "\[Dagger]"]}]}], TraditionalForm]],ExpressionUUID->
  "a2190299-3bd6-49b8-b33e-d1a9a02aec4b"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalLambda]", ":=", 
    RowBox[{"diag", "(", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Lambda]", "1"], ",", 
       SubscriptBox["\[Lambda]", "2"]}], "\[InvisibleComma]", 
      RowBox[{",", "\[Ellipsis]", ",", 
       SubscriptBox["\[Lambda]", "n"]}]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"8ddf8273-06e3-429f-8b17-af359d8e541d"],
 ". Here, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[CapitalOmega]", "k"], TraditionalForm]],ExpressionUUID->
  "743c0910-7dd4-486d-a6fa-6168ec9760ae"],
 " is a short-hand notation for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "k"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "y"], "(", 
      SubscriptBox["\[Lambda]", "k"], ")"}], "=", 
     RowBox[{
      SubscriptBox["\[CapitalOmega]", "y"], "(", 
      SubscriptBox["cos\[Theta]", "k"], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"6327d7ec-64b4-4a97-accd-8786c4df0a64"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "(", 
     SubscriptBox["\[Theta]", "k"], ")"}], ":=", 
    SubscriptBox["\[Lambda]", "k"]}], TraditionalForm]],ExpressionUUID->
  "924a654f-d95d-4c39-a4d0-37de81c39592"],
 "."
}], "TechNoteCaption",
 CellID->1930729324,ExpressionUUID->"d292dd94-dfdb-4bd7-9515-4cf846ba7a65"],

Cell[TextData[{
 "As one can see in ",
 ButtonBox["Figure 1",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1930729324"],
 ", the computational cost of block encoding is exponentially high in \
general. Recently, an approximation method has been proposed to overcome \
this; see ",
 ButtonBox["Camps and Van Beeumen (2022)",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://doi.org/10.1109/QCE53715.2022.00029"], None}],
 "."
}], "TechNoteText",
 CellID->1166358748,ExpressionUUID->"58bcd4db-d2ba-4638-a0fe-ef86f77eef5a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Remark: Alternative Block Encoding", "Subsection",
 CellID->1461512543,ExpressionUUID->"be632136-356b-4fe1-aee2-8ce2ab4067da"],

Cell["\<\
Another common implementation of block encoding is through the mapping [see, \
e.g., Lin (2022)]\
\>", "TechNoteText",
 CellID->1384037681,ExpressionUUID->"627ad3d8-bbc5-40a4-b453-901a65893cca"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"M", "\[RightTeeArrow]", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"V", "0"},
        {"0", "I"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {"\[CapitalLambda]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[CapitalLambda]", "2"]}]]},
        {
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[CapitalLambda]", "2"]}]], 
         RowBox[{"-", "\[CapitalLambda]"}]}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox["W", "\[Dagger]"], "0"},
        {"0", "I"}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "9789396d-e6e0-4ac2-be33-0ab88541e5e2"],
 " ."
}], "TechNoteText",
 CellID->1890969919,ExpressionUUID->"bbc5cb76-7865-4952-a087-e698350aadd4"],

Cell[TextData[{
 "Q3 does not consider this because ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"V", "0"},
      {"0", "I"}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "f731c9aa-6a36-45ed-93fb-cc59eb4d4b5e"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SuperscriptBox["W", "\[Dagger]"], "0"},
      {"0", "I"}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "35fc37e7-709d-433d-a00f-cf923ce53474"],
 " correspond to controlled-unitary gates. When ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]],ExpressionUUID->
  "93f66116-edfd-4819-9192-ecd8b0cbac89"],
 " and ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "ea915e1a-dae7-4495-a0d8-6092213356e8"],
 " are large, the actual implementation of those controlled-unitary gates may \
be computationally expensive."
}], "TechNoteText",
 CellID->1640996415,ExpressionUUID->"8c0e0dd4-1ab3-4ea3-b91c-a641e376d9f4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Geometric View: Relation to the Grover Rotation", "Subsection",
 CellID->1532784647,ExpressionUUID->"d2d0d107-77f9-4275-99f2-201cc536a3bf"],

Cell[TextData[{
 "The reflection ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"a4df9df5-f355-4b55-bacf-893564305c54"],
 " in the line along the vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Theta]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "0eac81e3-d888-4e63-a3c0-d8bf56771c82"],
 " can be converted to the rotation around the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "41df72f2-59dc-4d51-aba4-2f5c5a0b3712"],
 "-axis by angle ",
 Cell[BoxData[
  FormBox[
   RowBox[{"2", "\[Theta]"}], TraditionalForm]],ExpressionUUID->
  "1fbe0c72-c021-404f-9644-61c505799954"],
 " by multiplying the Pauli ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "03e36261-9b44-427b-a68c-060dfd2ca6e2"],
 " operator. In other words, it is useful to define a Grover-like rotation \
around the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "ffa6fa8a-25fb-4f74-b2a6-963ea9ab17d6"],
 "-axis by"
}], "TechNoteText",
 CellID->465522068,ExpressionUUID->"ff18ff12-2dea-418a-a76d-50ff1ef7a73e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "y"], "(", "\[Lambda]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], "Z"}],
      "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], "Z", "\[VeryThinSpace]", 
       RowBox[{
        SubsuperscriptBox["R", "y", "\[Dagger]"], "(", "\[Theta]", ")"}], 
       "Z"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], 
        RowBox[{
         SubscriptBox["R", "y"], "(", "\[Theta]", ")"}]}], "=", 
       RowBox[{
        RowBox[{
         SubscriptBox["R", "y"], "(", 
         RowBox[{"2", "\[Theta]"}], ")"}], "\[DotEqual]", 
        RowBox[{"(", GridBox[{
           {
            RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
            RowBox[{
             RowBox[{"-", "sin"}], "\[VeryThinSpace]", "\[Theta]"}]},
           {
            RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}], 
            RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}]}
          },
          GridBoxAlignment->{"Columns" -> {{Right}}, "Rows" -> {{Baseline}}}],
          ")"}]}]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "283bc912-f589-470d-b365-558ea5857395"],
 " ."
}], "TechNoteText",
 CellID->746470855,ExpressionUUID->"7b874e65-ed54-4529-b1a8-aed354c1ffbf"],

Cell[TextData[{
 "This relation can also be understood with a geometrical view as shown in ",
 ButtonBox["Figure 2",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#529413056"],
 ". The ",
 ButtonBox["Grover rotation",
  BaseStyle->"Link",
  ButtonData->
   "paclet:QuantumMob/Q3/tutorial/QuantumSearchAlgorithm#1497043023"],
 " in ",
 ButtonBox["quantum search algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumSearchAlgorithm"],
 " has also a similar geometric interpretation."
}], "TechNoteText",
 CellID->62712795,ExpressionUUID->"9721730b-ea12-4754-914b-e6cdc9d8f6b0"],

Cell[TextData[Cell[BoxData[
 GraphicsBox[{CircleBox[{0, 0}], 
   {GrayLevel[0.8], ArrowBox[{{1.2, 0}, {-1.2, 0}}], 
    LineBox[{{0, -1.2}, {0, 1.2}}], InsetBox[
     StyleBox["\<\"X\"\>",
      StripOnInput->False,
      FontSize->Large,
      FontSlant->Italic], {-1.2, 0}, NCache[
     ImageScaled[{0, Rational[-1, 2]}], ImageScaled[{0, -0.5}]]]}, 
   ArrowBox[{{0, 0}, {0, 1.2}}], 
   {RGBColor[0, 0, 1], Thickness[Large], 
    ArrowBox[{{0, 0}, {-0.19509032201612825`, 0.9807852804032304}}], 
    {RGBColor[1, 0, 0], 
     ArrowBox[{{0, 0}, {0.19509032201612825`, 0.9807852804032304}}]}, 
    {RGBColor[0, 0, 1], 
     ArrowBox[{{0, 0}, {-0.5555702330196022, 0.8314696123025452}}]}, 
    {RGBColor[1, 0, 0], 
     ArrowBox[{{0, 0}, {0.5555702330196022, 0.8314696123025452}}]}, 
    {RGBColor[0, 0, 1], 
     ArrowBox[{{0, 0}, {-0.8314696123025451, 0.5555702330196023}}]}}, 
   {LightDarkSwitched[
     GrayLevel[0]], Dashing[{Small, Small}], 
    ArrowBox[{{-0.19509032201612825`, 0.9807852804032304}, {
     0.19509032201612825`, 0.9807852804032304}}], 
    ArrowBox[{{0.19509032201612825`, 
     0.9807852804032304}, {-0.5555702330196022, 0.8314696123025452}}], 
    ArrowBox[{{-0.5555702330196022, 0.8314696123025452}, {0.5555702330196022, 
     0.8314696123025452}}], 
    ArrowBox[{{0.5555702330196022, 0.8314696123025452}, {-0.8314696123025451, 
     0.5555702330196023}}], InsetBox[
     StyleBox["\<\"Z\"\>",
      StripOnInput->False,
      FontSize->Large,
      FontSlant->Italic], {0, 1.2}, ImageScaled[{-1, 1}]]}},
  ImageSize->Large,
  PlotRangePadding->Scaled[
   0.025]]],ExpressionUUID->"dedcc4ea-0474-4952-b109-6042d85c7184"]], \
"Picture",
 CellID->1153346113,ExpressionUUID->"f659b698-55d5-4464-a32c-ad175c4790eb"],

Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ". A geometric view of the effects of the reflection ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "e5b41dda-8dbc-4f86-9dfa-82a1b7b2ea22"],
 " in the line along the computational basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e6165d15-e2ac-4ad8-9a7d-374c340c66b8"],
 " (from blue to red arrows) and the reflection ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"83afd359-c332-48f4-9010-5b57c341e05d"],
 " in the line along the rotated basis vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Theta]"},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["R", "y"], "(", "\[Theta]", ")"}], 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "6214fe51-9bde-45d7-b101-ab5cd801028d"],
 " (from red to blue arrows). Combining  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "y"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"6043f662-6ee1-4db1-98c8-ad4bd10a80d3"],
 " with ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "9889bc05-3dae-48c4-8d78-ad7ebf8e0d4b"],
 " gives rise to the Grover rotation (from blue to blue arrows). Shown is the \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "\[VeryThinSpace]", "x"}], TraditionalForm]],ExpressionUUID->
  "df6ca528-30d1-40be-bff7-9796c2be03d9"],
 "-plane in the Bloch space with the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "44941625-29bc-435c-a038-fe9be4adbd02"],
 "-axis in the vertical direction and the ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "57990f6f-c7dc-49de-9a24-3e82e362ca32"],
 "-axis pointing out of the screen."
}], "TechNoteCaption",
 CellID->529413056,ExpressionUUID->"2f3b8597-f4df-48d7-b99a-c0c1aaff0a2d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["The GSLW Convention", "TechNoteSection",
 CellID->618934295,ExpressionUUID->"050842b4-5901-4f5b-9c63-f327d30a01c9"],

Cell["\<\
In GSLW (Gily\[EAcute]n, Su, Low and Wiebe, 2019),  the block encoding is \
implemented as\
\>", "TechNoteText",
 CellID->17909997,ExpressionUUID->"53481204-16e5-48c3-8777-4571f9a9eb1f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"M", "\[RightTeeArrow]", 
     SubscriptBox["U", "M"]}], ":=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {"V", "0"},
        {"0", "V"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {"\[CapitalLambda]", 
         RowBox[{"\[ImaginaryI]", 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["\[CapitalLambda]", "2"]}]]}]},
        {
         RowBox[{"\[ImaginaryI]", 
          SqrtBox[
           RowBox[{"1", "-", 
            SuperscriptBox["\[CapitalLambda]", "2"]}]]}], "\[CapitalLambda]"}
       }], ")"}], 
     RowBox[{"(", GridBox[{
        {
         SuperscriptBox["W", "\[Dagger]"], "0"},
        {"0", 
         SuperscriptBox["W", "\[Dagger]"]}
       }], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "75627e00-b306-4380-acd3-fc6cba2c9fb8"],
 " ."
}], "TechNoteText",
 CellID->365608999,ExpressionUUID->"2d16018e-77b1-43b4-aa57-3f48864b6d53"],

Cell[CellGroupData[{

Cell["Quantum Circuit Model", "Subsection",
 CellID->950427654,ExpressionUUID->"0f399833-e23a-4241-8692-c257b3d1d6b9"],

Cell[TextData[{
 "For a quantum circuit model of this implementation, we introduce a \
Grover-like rotation around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "72423783-b25a-4d79-a51a-f95cb48abae9"],
 "-axis,"
}], "TechNoteText",
 CellID->1012258301,ExpressionUUID->"d64c186b-4f60-4236-aaa3-ff3af9fb6829"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], ":=", 
    RowBox[{"(", GridBox[{
       {"\[Lambda]", 
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[Lambda]", "2"]}]]}]},
       {
        RowBox[{"\[ImaginaryI]", 
         SqrtBox[
          RowBox[{"1", "-", 
           SuperscriptBox["\[Lambda]", "2"]}]]}], "\[Lambda]"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "59743cbd-1297-4056-a5ee-ccfbd341edfc"],
 "."
}], "TechNoteText",
 CellID->1216167028,ExpressionUUID->"01cac65a-bf83-45b9-b40a-200c38e75ffd"],

Cell[TextData[{
 "It turns out that with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], ":=", "\[Lambda]"}], 
   TraditionalForm]],ExpressionUUID->"c4f7959d-222e-4a83-bc0f-1430ebf33257"],
 " (i.e., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"sin", "\[VeryThinSpace]", "\[Theta]"}], "=", 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox["\[Lambda]", "2"]}]]}], TraditionalForm]],ExpressionUUID->
  "eaa13347-d128-434e-ba6d-5a82a1b2214d"],
 "),\[LineSeparator]\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["G", "x"], "(", "cos\[Theta]", ")"}], "=", 
     RowBox[{
      RowBox[{
       SubsuperscriptBox["R", "x", "\[Dagger]"], "(", 
       RowBox[{"2", "\[Theta]"}], ")"}], "\[DotEqual]", 
      RowBox[{"(", GridBox[{
         {
          RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}], 
          RowBox[{
          "\[ImaginaryI]", "\[VeryThinSpace]", "sin", "\[VeryThinSpace]", 
           "\[Theta]"}]},
         {
          RowBox[{
          "\[ImaginaryI]", "\[VeryThinSpace]", "sin", "\[VeryThinSpace]", 
           "\[Theta]"}], 
          RowBox[{"cos", "\[VeryThinSpace]", "\[Theta]"}]}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "e9efb08f-89d5-4ac9-b7a0-000d634e0234"],
 " ."
}], "TechNoteText",
 CellID->1044549548,ExpressionUUID->"55a55c8c-33c7-4097-9124-f52d4c17edda"],

Cell[TextData[{
 "In passing, note  that the Grover-like rotation around the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "733015a3-dd9f-4707-a30d-b500c1c154c2"],
 "-axis and the one around ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]],ExpressionUUID->
  "5e121757-d4d5-41cf-a2dd-33c3a03b58a4"],
 "-axis seen before are related to each other by"
}], "TechNoteText",
 CellID->1940545583,ExpressionUUID->"8d6eb5bc-06fd-4010-8f7a-06c69cc8b4b4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "Z", "\[VeryThinSpace]", 
       RowBox[{"\[Pi]", "/", "4"}]}]], 
     RowBox[{
      SubscriptBox["G", "y"], "(", "\[Lambda]", ")"}], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "Z", "\[VeryThinSpace]", 
       RowBox[{"\[Pi]", "/", "4"}]}]]}]}], TraditionalForm]],ExpressionUUID->
  "bb5ec06c-993f-4617-9f5c-fc4d5f2b2a74"],
 " ."
}], "TechNoteText",
 CellID->47109639,ExpressionUUID->"dfa2694a-3112-4284-9850-2b5fddd18bf1"],

Cell[TextData[{
 "The GSLW form of block encoding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "428ee2f2-8c35-497d-8926-fedc1474268d"],
 " can be rewritten as"
}], "TechNoteText",
 CellID->352901706,ExpressionUUID->"70fc89aa-0a1f-4bdd-8db1-2bbf9a5b9b61"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["U", "M"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", "V"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       UnderscriptBox["\[CapitalSigma]", "k"], 
       RowBox[{
        RowBox[{
         SubscriptBox["G", "x"], "(", 
         SubscriptBox["\[Lambda]", "k"], ")"}], "\[CircleTimes]", 
        TemplateBox[{"k"},
         "Ket"]}], 
       TemplateBox[{"k"},
        "Bra"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", 
       SuperscriptBox["W", "\[Dagger]"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"df3ec90c-5a29-4d80-8668-b83cda4b0fc8"],
 "."
}], "TechNoteText",
 CellID->2016623375,ExpressionUUID->"7746a1a4-9e18-4c05-afff-632f1db73f7c"],

Cell[TextData[{
 "where again ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{"k"},
        "Ket"], ":", "k"}], "=", "0"}], ",", "1", ",", "\[Ellipsis]", ",", 
     RowBox[{
      SuperscriptBox["2", "n"], "-", "1"}]}], "}"}], TraditionalForm]],
  ExpressionUUID->"01b99220-635e-44b4-9149-61f00747c103"],
 " is the computational basis of the system register. Clearly, the expression \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    UnderscriptBox["\[CapitalSigma]", "k"], 
    RowBox[{
     RowBox[{
      SubscriptBox["G", "x"], "(", 
      SubscriptBox["\[Lambda]", "k"], ")"}], "\[CircleTimes]", 
     TemplateBox[{"k"},
      "Ket"]}], 
    TemplateBox[{"k"},
     "Bra"]}], TraditionalForm]],ExpressionUUID->
  "b78157c7-5055-45d0-92ae-28f460a08547"],
 " in the middle is nothing but the ",
 ButtonBox["uniformly-controlled unitary gate",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/UniformlyControlledGate"],
 " operating ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["G", "x"], "(", 
    SubscriptBox["\[Lambda]", "k"], ")"}], TraditionalForm]],ExpressionUUID->
  "e9563136-2ea0-45af-aba3-f8608ebc8569"],
 "conditioned on the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"k"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "1e179a77-cf92-4e8c-bdf8-1a3da1be3b2b"],
 " of the system register."
}], "TechNoteText",
 CellID->1802146671,ExpressionUUID->"233325bd-6349-4177-bedb-2ad9d7f88282"],

Cell[TextData[{
 "Putting all together, the block encoding ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "M"], TraditionalForm]],ExpressionUUID->
  "7f2340da-7abc-459c-93b5-9922446ea132"],
 " may be described by the quantum circuit in ",
 ButtonBox["Figure 3",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/BlockEncoding#1045391992"],
 "."
}], "TechNoteText",
 CellID->839732126,ExpressionUUID->"60e6828a-5359-4df1-83d9-3416399e5dfd"],

Cell[TextData[{
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {2, -1}}, {{0, -3}, {2, -3}}, {{0, -4}, {2, -4}}, {{
     0, -5}, {2, -5}}}], {LineBox[{{1, -1}, {1, -3}, {1, -4}, {1, -5}}], 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -1.4}, {1.4, -0.6},
       RoundingRadius->0.4]}, InsetBox[
      StyleBox["\<\"enc\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.2],
       FontWeight->"Light",
       FontSlant->Italic], {1., -1.}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {0, 1}], 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -5.4}, {1.4, -2.6}]}, InsetBox[
      StyleBox["\<\"M\"\>",
       StripOnInput->False,
       FontSize->Scaled[0.2],
       FontWeight->"Light",
       FontSlant->Italic], {1., -4.}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}},
   ImagePadding->{{25.56, 25.56}, {7.2, 7.2}},
   ImageSize->118.8,
   PlotRange->{{0, 2}, {-5.5, -0.5}},
   PlotRangePadding->Scaled[0.025]]],ExpressionUUID->
  "94365cde-49ff-4f99-ac1b-f4ee43687f73"],
 "=",
 Cell[BoxData[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {4, -1}}, {{0, -3}, {4, -3}}, {{0, -4}, {4, -4}}, {{
     0, -5}, {4, -5}}}], {
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      RectangleBox[{0.6, -5.4}, {1.4, -2.6}]}, InsetBox[
      StyleBox[
       TemplateBox[{"\"W\"", "\"\[Dagger]\""},
        "Superscript"],
       StripOnInput->False,
       FontSize->Scaled[0.1],
       FontWeight->"Light",
       FontSlant->Italic], {1., -4.}, NCache[
      ImageScaled[{Rational[1, 2], Rational[1, 2]}], ImageScaled[{0.5, 0.5}]],
       Automatic, {1, 0}]}, {LineBox[{{2, -3}, {2, -4}, {2, -5}, {2, -1}}], 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      DiskBox[{2, -3}, 0.09, 
       NCache[{Rational[1, 4] Pi, Rational[5, 4] Pi}, {0.7853981633974483, 
        3.9269908169872414`}]], 
      {LightDarkSwitched[
        GrayLevel[0]], 
       DiskBox[{2, -3}, 0.09, 
        NCache[{Rational[-3, 4] Pi, Rational[1, 4] Pi}, {-2.356194490192345, 
         0.7853981633974483}]]}}, 
     {LightDarkSwitched[
       GrayLevel[1]], EdgeForm[Opacity[1]], 
      DiskBox[{2, -4}, 0.09, 
       NCache[{Rational[1, 4] Pi, Rational[5, 4] Pi}, {0.7853981633974483, 
        3.9269908169872414`}]], 
      {LightDarkSwitched[
