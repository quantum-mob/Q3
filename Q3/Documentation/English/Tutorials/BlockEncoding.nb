Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"in", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ThePauli", "[", 
       RowBox[{"{", 
        RowBox[{"2", ",", "3", ",", "1"}], "}"}], "]"}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"I", "/", "2"}], ")"}], "*", 
       RowBox[{"ThePauli", "[", 
        RowBox[{"{", 
         RowBox[{"3", ",", "2", ",", "2"}], "}"}], "]"}]}]}], ")"}], "/", 
    "4"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"in", "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[410]:=",
