  ImageSize->Large,
  PlotRangePadding->Scaled[
   0.025]]],ExpressionUUID->"6ad45f35-dd68-48dc-8bdd-c5bbea72c4b6"]], \
"Picture",
 CellID->1553194480,ExpressionUUID->"01b82d76-9dcf-43e0-a371-3f0b1baf80f7"],

Cell[TextData[{
 StyleBox["Figure 4",
  FontWeight->"Bold"],
 ". A geometric view of the effects of the reflection ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "c2fcea3d-6427-4e6a-a00b-0ba4a97de839"],
 " in the line along the computational basis vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "b8678ed5-f438-433e-ae7a-b9a4e012f36a"],
 " (from blue to red arrows) and the reflection ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"6a0a940c-80ee-4f4a-880e-d9c7dd8fe8cc"],
 " in the line along the rotated basis vector ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      RowBox[{"x", ":", 
        RowBox[{"-", "\[Theta]"}]}]},
     "Ket"], ":=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["R", "x", "\[Dagger]"], "(", "\[Theta]", ")"}], 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "a17dfa34-01be-4260-b5be-716b8220cae6"],
 " (from red to blue arrows). The combining ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalOmega]", "x"], "(", "cos\[Theta]", ")"}], 
   TraditionalForm]],ExpressionUUID->"eed55851-9f41-4ee2-9693-ad9c67f8c59a"],
 " with ",
 Cell[BoxData[
  FormBox["Z", TraditionalForm]],ExpressionUUID->
  "6c79a446-7f8f-4914-864e-48e1f0caf973"],
 " gives rise to the Grover rotation (from blue to blue arrows). Shown is the \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "\[VeryThinSpace]", "z"}], TraditionalForm]],ExpressionUUID->
  "1c1af08a-dfda-419b-bae6-7ba278539d2d"],
 "-plane in the Bloch space with the ",
 Cell[BoxData[
  FormBox["z", TraditionalForm]],ExpressionUUID->
  "996d5b93-a81f-417e-a795-2847943b1a21"],
 "-axis in the vertical direction and the ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "e2410a9e-0e4d-4b08-8063-706985d3ad43"],
 "-axis pointing out of the screen."
}], "TechNoteCaption",
 CellID->1875896075,ExpressionUUID->"631719e2-129d-462d-b99b-e0440b0af6e7"],

Cell["\<\
\[LineSeparator]Moreover, recalling the relation the Grover-like rotations \
around x- and y-axis\
\>", "TechNoteText",
 CellID->352881349,ExpressionUUID->"af8917da-5f00-45f3-ba5e-ced1687148b4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["G", "x"], "(", "\[Lambda]", ")"}], "=", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[ImaginaryI]"}], "\[VeryThinSpace]", "Z", "\[VeryThinSpace]", 
       RowBox[{"\[Pi]", "/", "4"}]}]], 
     RowBox[{
      SubscriptBox["G", "y"], "(", "\[Lambda]", ")"}], 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"\[ImaginaryI]", "\[VeryThinSpace]", "Z", "\[VeryThinSpace]", 
       RowBox[{"\[Pi]", "/", "4"}]}]]}]}], TraditionalForm]],ExpressionUUID->
  "b3e0fcb3-cd38-468a-9baf-b515396b4951"],
 " ,"
}], "TechNoteText",
 CellID->1850840532,ExpressionUUID->"46333546-d9df-4395-a411-d03eed32549c"],

