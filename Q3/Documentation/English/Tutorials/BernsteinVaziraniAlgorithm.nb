Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". A quantum circuit for the Bernstein-Vazirani (and Deutsch-Jozsa) \
algorithm."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->197232399,ExpressionUUID->"65a84778-6a31-40c7-aaa5-bd83e01b55bd"],

Cell[TextData[{
 "The first set of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "41a3326f-05b3-480e-baf6-3a4718dcf4f2"],
 " gates and the ",
 ButtonBox["quantum oracle",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumOracle"],
 " lead the ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "0b656e17-1c5b-4c92-87a0-7240fef9a763"],
 "-qubit register to the state"
}], "TechNoteText",
 CellID->173717502,ExpressionUUID->"7c09d827-d646-4bbe-a8b1-b34df0010cfa"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"x"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"f", "(", "x", ")"}]]}], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"x"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"x", "\[CenterDot]", "s"}]]}]}], TraditionalForm]],
  ExpressionUUID->"1a5c023b-9028-4513-a025-af8d0a048de6"],
 "."
}], "DisplayMath",
 CellID->1239779841,ExpressionUUID->"2b2161f2-bb11-49ca-90f6-5996b7c41780"],

Cell["Taking the inverse of the mapping", "TechNoteText",
 CellID->2093444493,ExpressionUUID->"ed757f54-d41e-4e90-9d1a-c3a33cdc1feb"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox["H", 
      RowBox[{"\[CircleTimes]", "n"}]], 
     TemplateBox[{"y"},
      "Ket"]}], "=", 
    RowBox[{
     FractionBox["1", 
      SuperscriptBox["2", 
       RowBox[{"n", "/", "2"}]]], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"x", "=", "0"}], 
      RowBox[{
       SuperscriptBox["2", "n"], "-", "1"}]], 
     SuperscriptBox[
      RowBox[{
       TemplateBox[{"x"},
        "Ket"], "(", 
       RowBox[{"-", "1"}], ")"}], 
      RowBox[{"x", "\[CenterDot]", "y"}]]}]}], TraditionalForm]],
  ExpressionUUID->"bb4aeee3-34e7-4df1-83d9-5d6bc4aa3838"],
 ","
}], "DisplayMath",
 CellID->149521403,ExpressionUUID->"b37f6735-ff8b-4145-8b33-c32f8681212a"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", "\[CenterDot]", "y"}], TraditionalForm]],ExpressionUUID->
  "9efc5199-5f89-4eba-940f-d47197003385"],
 " denotes the bitwise inner product"
}], "TechNoteText",
 CellID->450353231,ExpressionUUID->"d68bc930-a111-4ba2-9bef-703a94148b0a"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"x", "\[CenterDot]", "y"}], ":=", 
    RowBox[{
     RowBox[{
      SubscriptBox["x", "1"], 
      SubscriptBox["y", "1"]}], "+", 
     RowBox[{
      SubscriptBox["x", "2"], 
      SubscriptBox["y", "2"]}], "+", "\[CenterEllipsis]", "+", 
     RowBox[{
      SubscriptBox["x", "n"], 
      SubscriptBox["y", "n"], "  ", 
      RowBox[{"(", 
       RowBox[{"mod", " ", "2"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"18063d8c-3c62-470e-9718-46c36dde87bc"],
 ","
}], "DisplayMath",
 CellID->1354381389,ExpressionUUID->"160177a8-bed1-4a73-bdc8-a0d239d08f1b"],

Cell[TextData[{
 "one can observe that the second set of the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Hadamard"]], "paclet:QuantumMob/Q3/ref/Hadamard", 
    "QuantumMob Package Symbol"},
   "PackageLink",
   BaseStyle->"InlineFormula"]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3c1b8006-b519-4265-baa9-084ba6cf88e6"],
 " gates converts the above state to the final state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"s"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "e731eb19-6fbb-48bb-b0a6-4ab279f819d6"],
 " corresponding to the secret bit string ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "4a85b814-da78-45c6-9e0c-5665487a3caf"],
 "; that is,"
}], "TechNoteText",
 CellID->1908830370,ExpressionUUID->"e72efa5b-632a-4217-8864-94a495925d34"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", 
        RowBox[{"n", "/", "2"}]]], 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"x", "=", "0"}], 
       RowBox[{
        SuperscriptBox["2", "n"], "-", "1"}]], 
      SuperscriptBox[
       RowBox[{
        TemplateBox[{"x"},
         "Ket"], "(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"x", "\[CenterDot]", "s"}]]}], "\[RightArrow]", 
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", 
        RowBox[{"n", "/", "2"}]]], 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"y", "=", "0"}], 
       RowBox[{
        SuperscriptBox["2", "n"], "-", "1"}]], 
      TemplateBox[{"y"},
       "Ket"], 
      SuperscriptBox[
       RowBox[{
        UnderoverscriptBox["\[CapitalSigma]", 
         RowBox[{"x", "=", "0"}], 
         RowBox[{
          SuperscriptBox["2", "n"], "-", "1"}]], "(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{
        RowBox[{"x", "\[CenterDot]", "s"}], "+", 
        RowBox[{"x", "\[CenterDot]", "y"}]}]]}]}], "=", 
    RowBox[{
     RowBox[{
      FractionBox["1", 
       SuperscriptBox["2", 
        RowBox[{"n", "/", "2"}]]], 
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"y", "=", "0"}], 
       RowBox[{
        SuperscriptBox["2", "n"], "-", "1"}]], 
      TemplateBox[{"y"},
       "Ket"], 
      SuperscriptBox[
       RowBox[{
        UnderoverscriptBox["\[CapitalSigma]", 
         RowBox[{"x", "=", "0"}], 
         RowBox[{
          SuperscriptBox["2", "n"], "-", "1"}]], "(", 
        RowBox[{"-", "1"}], ")"}], 
       RowBox[{"x", "\[CenterDot]", 
        RowBox[{"(", 
         RowBox[{"s", "\[CirclePlus]", "y"}], ")"}]}]]}], "=", 
     TemplateBox[{"s"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "05c3c54e-64a8-448a-9ccc-e6037391c0f8"],
 ","
}], "DisplayMath",
 CellID->205220394,ExpressionUUID->"ee60674b-bb68-42d0-9ff9-0531bfc7eaad"],

Cell["where we have used the identity", "TechNoteText",
 CellID->230241275,ExpressionUUID->"06ce4b6d-3631-48b7-98f9-4fe629bf1d52"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     RowBox[{
      UnderoverscriptBox["\[CapitalSigma]", 
       RowBox[{"x", "=", "0"}], 
       RowBox[{
        SuperscriptBox["2", "n"], "-", "1"}]], "(", 
      RowBox[{"-", "1"}], ")"}], 
     RowBox[{"x", "\[CenterDot]", 
      RowBox[{"(", 
       RowBox[{"s", "\[CirclePlus]", "y"}], ")"}]}]], "=", 
    RowBox[{
     SuperscriptBox["2", "n"], 
     SubscriptBox["\[Delta]", "ys"]}]}], TraditionalForm]],ExpressionUUID->
  "c246a9a2-c872-4be7-8dcf-c7381986d186"],
 ","
}], "DisplayMath",
 CellID->896954653,ExpressionUUID->"fe018ace-11e3-4b81-bc1f-435be3c92b31"],

Cell["\<\
Therefore, a simple measurement of the final state in the logical basis will \
just reveal the secret string.\
\>", "TechNoteText",
 CellID->1284808943,ExpressionUUID->"7f95cdb7-f165-4eda-9d02-d659294eae43"]
}, Open  ]],

