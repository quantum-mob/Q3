Cell[TextData[{
 "Suppose that we are given a binary function ",
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "n"], "\[RightArrow]", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1"}], "}"}]}]}], TraditionalForm]],ExpressionUUID->
  "065e7cec-fa7c-414b-b066-43d4ea11b425"],
 ", the value of which is determined by a secret string ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "81e364cd-0585-4894-8399-3a676d70c8f5"],
 " of ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "a5f4088d-85ac-407e-ba3e-0e8d0236855a"],
 " bits"
}], "TechNoteText",
 CellID->756185225,ExpressionUUID->"2696e04d-36c6-4af2-84da-560c32883e70"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"f", ":", 
    RowBox[{"x", "\[RightTeeArrow]", 
     RowBox[{
      RowBox[{"x", "\[CenterDot]", "s"}], "   ", 
      RowBox[{"(", 
       RowBox[{"mod", " ", "2"}], ")"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"f4068906-65ec-4e6b-9e28-fdf25a72d877"],
 "."
}], "DisplayMath",
 CellID->396853629,ExpressionUUID->"42d495a0-1266-4ddb-96d8-c0a471a9610c"],

Cell[TextData[{
 "The Bernstein-Vazirani problem finds the secret bit string ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "64faae46-cc22-43cd-8042-ece796a05df1"],
 " by making queries to the oracle ",
 Cell[BoxData[
  FormBox["f", TraditionalForm]],ExpressionUUID->
  "294fcf0a-17d5-449b-93e7-c1159a54056f"],
 ". Classically, one needs ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "b0dbaa12-01cb-45fe-8038-a43cb0c94fef"],
 " queries to the function f to infer the secret string ",
 Cell[BoxData[
  FormBox["s", TraditionalForm]],ExpressionUUID->
  "0da9132f-dbf6-4764-8ddf-696bc3361229"],
 "."
}], "TechNoteText",
 CellID->1982218668,ExpressionUUID->"3069b478-7d0e-446c-8852-d46ef14284b6"],

