Cell[CellGroupData[{

Cell["Quantum Implementation", "TechNoteSection",
 CellTags->"Section14",
 CellID->89537285,ExpressionUUID->"4da24548-8228-4f84-b488-74400bd93601"],

Cell[TextData[{
 "The Bernstein-Vazirani algorithm (Bernstein & Vazirani, 1993, 1997) is \
implemented in the same quantum circuit in Figure 1 as the ",
 ButtonBox["Deutsch-Jozsa algorithm",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/DeutschJozsaAlgorithm"],
 ", only that the analysis of the final readout is different."
}], "TechNoteText",
 CellID->1614596095,ExpressionUUID->"f3a87a89-ecf4-4ff4-b2a3-55e728fb729f"],

