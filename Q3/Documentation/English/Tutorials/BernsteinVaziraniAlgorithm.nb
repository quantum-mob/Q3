Cell["\<\
Here is a quantum circuit of the Bernstein-Vazirani algorithm. The final \
Hadamard gate on the third qubit is not necessary, and we put it here to make \
the output state more readable:\
\>", "TechNoteText",
 CellID->376251056,ExpressionUUID->"906cb1b5-ae12-43b0-be39-3d54b1279728"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cc", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tt", "=", 
   RowBox[{"{", "3", "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"all", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"S", "[", "3", "]"}], "\[Rule]", "1"}], ",", 
      RowBox[{"S", "@", "all"}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"all", ",", "6"}], "]"}], ",", 
    RowBox[{"Oracle", "[", 
     RowBox[{"f", ",", 
      RowBox[{"S", "@", "cc"}], ",", 
      RowBox[{"S", "@", "tt"}]}], "]"}], ",", 
    RowBox[{"S", "[", 
     RowBox[{"all", ",", "6"}], "]"}]}], "]"}]}]}], "Input",
 CellLabel->"In[80]:=",
 CellID->1459641424,ExpressionUUID->"4cf8b3e7-b67b-4883-bb43-c7bee9eec874"],

