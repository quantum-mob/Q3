Cell[TextData[{
 ButtonBox["Q3: Symbolic Quantum Simulation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 " is a symbolic quantum simulation framework written in the ",
 ButtonBox["Wolfram Language",
  BaseStyle->"Link",
  ButtonData->"paclet:guide/LanguageOverview"],
 " to help study ",
 StyleBox["quantum information systems",
  FontSlant->"Italic"],
 ", ",
 StyleBox["quantum many-body systems",
  FontSlant->"Italic"],
 ", and ",
 StyleBox["quantum spin systems",
  FontSlant->"Italic"],
 ". It provides various tools and utilities for symbolic and numerical \
calculations on these representative quantum systems."
}], "TechNoteText",
 CellID->2001916300,ExpressionUUID->"8b87efab-bea0-42ee-b80a-a4054c370b39"],

Cell[TextData[{
 "The first thing to do is loading the ",
 ButtonBox["Q3: Symbolic Quantum Simulation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/guide/Q3"],
 " package."
}], "TechNoteMathCaption",
 CellID->1904370893,ExpressionUUID->"c4c1f869-3090-4738-a343-36ca561f1db7"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
