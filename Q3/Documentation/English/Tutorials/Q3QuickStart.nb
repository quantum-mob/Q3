 CellLabel->"Out[46]=",
 CellID->1969092808,ExpressionUUID->"89f184e8-fdab-4e5a-9601-0fb218faf1b1"]
}, Open  ]],

Cell[TextData[{
 "The computational basis state are specified by ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{
     Cell[
      TextData["Ket"]], "paclet:QuantumMob/Q3/ref/Ket", 
     "QuantumMob Package Symbol"},
    "PackageLink",
    BaseStyle->"InlineFormula"], "[", 
   RowBox[{"<|", "\[Ellipsis]", "|>"}], "]"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4856b13c-221b-406e-991e-bbb5654cffbf"],
 ". As in many other Q3 functions, one can skip the final ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["$"]], "paclet:ref/$"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "40cf2978-f9c3-4b64-9a26-9872bd47e42d"],
 " for each qubit; it is added automatically. Therefore, the following two \
expressions give the identical result."
}], "TechNoteMathCaption",
 CellID->847679751,ExpressionUUID->"ee020242-6765-4737-b2ca-b6c7bbed2cae"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Ket", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"1", ",", "$"}], "]"}], "\[Rule]", "1"}], ",", 
   RowBox[{
    RowBox[{"S", "[", 
     RowBox[{"2", ",", "$"}], "]"}], "\[Rule]", "1"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Ket", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"S", "[", "1", "]"}], "\[Rule]", "1"}], ",", 
   RowBox[{
    RowBox[{"S", "[", "2", "]"}], "\[Rule]", "1"}]}], "]"}]}], "Input",
 CellLabel->"In[47]:=",
 CellID->994771809,ExpressionUUID->"9dc87aff-3b1c-44ec-ab8b-6fd281541c4d"],

Cell[BoxData[
 InterpretationBox[
  TemplateBox[{
