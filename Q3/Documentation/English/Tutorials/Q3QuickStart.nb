   RowBox[{
    RowBox[{"c", "[", "1", "]"}], "**", 
    RowBox[{"Dagger", "[", 
     RowBox[{"c", "[", "1", "]"}], "]"}], "**", 
    RowBox[{"c", "[", "2", "]"}], "**", 
    RowBox[{"Dagger", "[", 
     RowBox[{"c", "[", "2", "]"}], "]"}]}], "+", 
   RowBox[{
    RowBox[{"Dagger", "[", 
     RowBox[{"c", "[", "2", "]"}], "]"}], "**", 
    RowBox[{"c", "[", "2", "]"}]}]}]}]], "Input",
 CellLabel->"In[53]:=",
