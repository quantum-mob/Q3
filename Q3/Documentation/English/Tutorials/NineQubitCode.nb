Cell[TextData[{
 StyleBox["Figure 2",
  FontWeight->"Bold"],
 ". Equivalent quantum circuits that can correct single-qubit phase-flip \
errors."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->486420785,ExpressionUUID->"75e2bcaa-d2c2-4315-95c4-12c4a2346208"],

Cell[TextData[{
 "Compared to the corresponding quantum circuits for the bit-flip correction \
code, the above quantum circuits have additional Hadamard gates, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["H", 
    RowBox[{"\[CircleTimes]", "3"}]], TraditionalForm]],ExpressionUUID->
  "36c68dca-68c6-4838-bcdf-c4f6dbb0eb54"],
 ", to account for the basis change mentioned above. Phase-flip errors on one \
or fewer qubits of the three can be detected by measuring the observables"
}], "TechNoteText",
 CellID->1728542852,ExpressionUUID->"0cf2a65d-69d3-4fb9-8e88-8c5e97951fb9"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["M", "1", "\[Prime]"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["H", 
       RowBox[{"\[CircleTimes]", "3"}]], 
      SubscriptBox["M", "1"], 
      SuperscriptBox["H", 
       RowBox[{"\[CircleTimes]", "3"}]]}], "=", 
     RowBox[{"X", "\[CircleTimes]", "X", "\[CircleTimes]", "I"}]}]}], 
   TraditionalForm]],ExpressionUUID->"ead86c89-023b-453b-89ee-a1661d1b9b9b"],
 " ,"
}], "TechNoteText",
 CellID->460936948,ExpressionUUID->"eefcd547-3c7e-4f4d-8538-ff7af7a6a632"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["M", "2", "\[Prime]"], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox["H", 
       RowBox[{"\[CircleTimes]", "3"}]], 
      SubscriptBox["M", "2"], 
      SuperscriptBox["H", 
       RowBox[{"\[CircleTimes]", "3"}]]}], "=", 
     RowBox[{"I", "\[CircleTimes]", "X", "\[CircleTimes]", "X"}]}]}], 
   TraditionalForm]],ExpressionUUID->"3d6fcea2-1991-439e-ba77-5165033dc6cd"],
 " ,"
}], "TechNoteText",
 CellID->993770307,ExpressionUUID->"ff4b20e3-5c2e-498e-ba8b-83c0c718b840"],

Cell[TextData[{
 "as ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"H", " ", "Z", " ", "H"}], "=", "X"}], TraditionalForm]],
  ExpressionUUID->"6b1d66a6-e53a-457c-a334-a1e11806a852"],
 ". That is, the phase-flip error on the first, second, and third qubit leads \
to the measurement results (\[Minus]1, 1), (\[Minus]1, \[Minus]1), and (1, \
\[Minus]1), respectively, with an outcome that will be (1,1) if no error \
occurs. Once the error syndrome is diagnosed, the error can be fixed by \
applying the recovery operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], 
   TraditionalForm]],ExpressionUUID->"7e4ae337-1071-49f0-8027-f16b9adb46ec"],
 " (doing nothing), ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], 
   TraditionalForm]],ExpressionUUID->"92d93503-4048-41d7-a6a0-e106f1a0f128"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "\[CircleTimes]", "Z", "\[CircleTimes]", "I"}], 
   TraditionalForm]],ExpressionUUID->"b80ee800-a4ee-4f63-b838-4bdd7238e334"],
 ", or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "Z"}], 
   TraditionalForm]],ExpressionUUID->"7165c131-60c8-408a-93dc-71332d8a5f9f"],
 " as ",
 Cell[BoxData[
