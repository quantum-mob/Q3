        TemplateBox[{"111"},
         "Ket"]}], ")"}]}], 
     SqrtBox["8"]]}], TraditionalForm]],ExpressionUUID->
  "e17a67c1-5b7e-4a7e-b542-155f4fa6feea"],
 " ,"
}], "TechNoteText",
 CellID->1756075865,ExpressionUUID->"b9ab00a3-062c-43cf-8108-1286af0414f1"],

