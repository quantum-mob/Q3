        StripOnInput->False,
        FontSize->Scaled[0.10666666666666667`],
        FontWeight->"Light"], {-0.1, -2}, ImageScaled[{1, 0.5}]], InsetBox[
       StyleBox[
        TemplateBox[{"0"},
         "Ket"],
        StripOnInput->False,
        FontSize->Scaled[0.10666666666666667`],
        FontWeight->"Light"], {-0.1, -3}, ImageScaled[{1, 0.5}]]}}, {
     LineBox[{{1, -1}, {1, -2}}], 
     DiskBox[{1, -1}, 0.09], {CircleBox[{1, -2}, 0.26666666666666666], 
      LineBox[{{{0.7333333333333334, -2}, {1.2666666666666666`, -2}}, {{
         1, -2.2666666666666666`}, {1, -1.7333333333333334`}}}]}}, {
     LineBox[{{2, -2}, {2, -3}}], 
     DiskBox[{2, -2}, 0.09], {CircleBox[{2, -3}, 0.26666666666666666], 
      LineBox[{{{1.7333333333333334`, -3}, {2.2666666666666666`, -3}}, {{
         2, -3.2666666666666666`}, {2, -2.7333333333333334`}}}]}}},
   AxesStyle->Automatic,
   FrameStyle->Automatic,
   ImagePadding->{{23.400000000000002`, 23.400000000000002`}, {5, 5}},
   ImageSize->154.79999999999998`,
   PlotRangePadding->Scaled[0.025]]}]], "Picture",
 TextAlignment->Center,
 CellID->1172229480,ExpressionUUID->"c9e37c1d-5e10-4f58-8005-6b9dfdbb00a5"],

Cell[TextData[{
 StyleBox["Figure 1",
  FontWeight->"Bold"],
 ". Equivalent quantum circuits that can correct single-qubit bit-flip errors."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->871014217,ExpressionUUID->"c222943f-ce64-494d-ac75-bfaa2e3fe840"],

Cell[TextData[{
 "\tTo see how this encoding protects against the bit-flip error, suppose \
that the error occurs on the first qubit, whereby the error is described by \
the operator, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], 
   TraditionalForm]],ExpressionUUID->"61de6da1-85a1-4be0-88dc-6b752b5a0606"],
 ". Then, the encoded state changes to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox[
       OverscriptBox["\[Psi]", "_"], "1"]},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"100"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"011"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "2e3212b6-7ef3-45ce-a12a-11b81594604d"],
 ". This state is orthogonal to the original state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["\[Psi]", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8e8f3b32-cb0e-4191-93d7-9ec8af6de5e7"],
 ", and in principle can be discriminated through a proper measurement. \
Indeed, the measurement associated with the projection "
}], "TechNoteText",
 CellID->645892782,ExpressionUUID->"96f69bba-b18a-472a-8e36-77e7f3d1120b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "1"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"100"},
       "Ket"], 
      TemplateBox[{"100"},
       "Bra"]}], "+", 
     RowBox[{
      TemplateBox[{"011"},
       "Ket"], 
      TemplateBox[{"011"},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "5736bf6b-c830-4bac-9d49-ee348d7c73a2"]
}], "TechNoteText",
 CellID->2137635136,ExpressionUUID->"34ec4ca0-f3fb-4bd6-b1c1-7d7a68262493"],

Cell[TextData[{
 "can do it. Similarly, bit flips on the second and third qubit modify the \
encoded state into ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox[
       OverscriptBox["\[Psi]", "_"], "3"]},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"010"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"101"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "b5c5a0ed-ec48-4b8a-8bf0-50e32f0c79a3"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox[
       OverscriptBox["\[Psi]", "_"], "3"]},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"001"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"110"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "c97f08c5-8922-40ca-8b8d-0bb119d48536"],
 ", respectively. These states reside in the subspaces corresponding to the \
projection operators"
}], "TechNoteText",
 CellID->1979800089,ExpressionUUID->"5b2f7d94-2bd1-4b05-9451-d1a1383fa9ab"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "2"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"010"},
       "Ket"], 
      TemplateBox[{"010"},
       "Bra"]}], "+", 
     RowBox[{
      TemplateBox[{"101"},
       "Ket"], 
      TemplateBox[{"101"},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "bba3a5b9-651f-4b08-b49b-6862797c7c01"]
}], "TechNoteText",
 CellID->1388469205,ExpressionUUID->"70c1766e-b7e9-4e1e-9e44-ea399a0e8e89"],

Cell["and", "TechNoteText",
 CellID->1444620133,ExpressionUUID->"7bd452e3-48d0-461b-b3db-4096b904f6e4"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "3"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"001"},
       "Ket"], 
      TemplateBox[{"001"},
       "Bra"]}], "+", 
     RowBox[{
      TemplateBox[{"110"},
       "Ket"], 
      TemplateBox[{"110"},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "2c3a7079-6b07-41ed-b7a4-815f1bb7bbfe"],
 ","
}], "TechNoteText",
 CellID->280462349,ExpressionUUID->"be85da42-fa47-4dde-959a-cb0b08a5cb8f"],

Cell[TextData[{
 " respectively. As the bit-flip errors on individual qubits bring the \
encoded state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["\[Psi]", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "cc9b3627-8f3e-4831-9721-dbacb6590b1b"],
 " to mutually orthogonal subspaces, or equivalently, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["P", "i"], 
     SubscriptBox["P", "j"]}], "=", 
    RowBox[{
     SubscriptBox["\[Delta]", 
      RowBox[{"i", " ", "j"}]], 
     SubscriptBox["P", "j"]}]}], TraditionalForm]],ExpressionUUID->
  "dc84f1a3-5c20-4f34-97c2-b2c228310bcb"],
 ", one can set up a projection measurement that is described by projectors \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], ",", 
    SubscriptBox["P", "1"], ",", 
    SubscriptBox["P", "2"], ",", 
    SubscriptBox["P", "3"]}], TraditionalForm]],ExpressionUUID->
  "141f6bd2-734c-4e74-b463-1e87a90a2ac8"],
 " to determine the qubit on which the error has actually occurred (if at \
all). The measurement result is referred to as the ",
 StyleBox["error syndrome",
  FontSlant->"Italic"],
 ", and its measurement is referred to as the ",
 StyleBox["error-detection procedure",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->4094478,ExpressionUUID->"5dd8a0bc-2afa-4fbd-bff9-aa1b3886ae18"],

Cell[TextData[{
 "\tIt is interesting to note that the states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["\[Psi]", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "58365f13-6839-49dd-9aed-74fb83f09924"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox[
      OverscriptBox["\[Psi]", "_"], "1"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "3226e36a-30cf-4c1f-8652-c43d814b0113"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox[
      OverscriptBox["\[Psi]", "_"], "2"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "eb4d0c62-7af1-4bb4-a647-f39091770ab9"],
 ", and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox[
      OverscriptBox["\[Psi]", "_"], "3"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "f8c0eb1c-39fa-4887-982f-5b1d86e1dd4c"],
 " are all simultaneous eigenstates of the two observables"
}], "TechNoteText",
 CellID->96415042,ExpressionUUID->"a3f81971-f82f-4d93-961f-c0b8b17760bc"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "1"], ":=", 
    RowBox[{"Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "I"}]}], 
   TraditionalForm]],ExpressionUUID->"43cf405c-351c-4e6b-a243-e41d07359c9e"],
 " ,     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["M", "2"], ":=", 
    RowBox[{"I", "\[CircleTimes]", "Z", "\[CircleTimes]", "Z"}]}], 
   TraditionalForm]],ExpressionUUID->"2bc67d35-b8b3-4e18-9d4e-9d0e19ce3b45"],
 " ."
}], "TechNoteText",
 CellID->1244941056,ExpressionUUID->"fb78ac6a-f86a-461d-8e01-56e85ad491ab"],

Cell[TextData[{
 "Furthermore, since they are mutually orthogonal, they must belong to \
different pairs of eigenvalues of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "1"], TraditionalForm]],ExpressionUUID->
  "10ba59e4-3cb9-4d4f-a34c-1a2cbd62a8fa"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "2"], TraditionalForm]],ExpressionUUID->
  "45ef278e-e9a3-4d1b-9076-63e98df670ee"],
 ". Indeed, we see by inspection that they belong to pairs of eigenvalues (1, \
1), (\[Minus]1, 1), (\[Minus]1, \[Minus]1) and (1, \[Minus]1), respectively. \
Therefore, the measurements of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "1"], TraditionalForm]],ExpressionUUID->
  "9184063a-ce64-4a48-b57c-4a5e836db024"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "2"], TraditionalForm]],ExpressionUUID->
  "e0d0fe8f-0468-4bbd-962c-8f95deae3594"],
 " produce exactly the same information regarding the error syndrome as the \
projection measurement associated with ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "j"], TraditionalForm]],ExpressionUUID->
  "ef94a152-815a-41bf-8c65-3f7771cc3dd0"],
 " outlined above. Although less obvious at this stage, this method of \
error-detection is easier to extend\[LongDash]and more closely related to the \
",
 StyleBox[ButtonBox["stabilizer formalism",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/StabilizerFormalism"],
  FontSlant->"Italic"],
 "\[LongDash]than the above measurement in terms of the projectors ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "j"], TraditionalForm]],ExpressionUUID->
  "45458595-baf3-45c0-ad1c-6b882e4232da"],
 ", so we will focus mainly on this method from now on."
}], "TechNoteText",
 CellID->791155471,ExpressionUUID->"26e196f6-d6ea-410d-9fd8-5bf68b50d1af"],

Cell[TextData[{
 "\tIt is crucial for the error-detection procedure to not reveal the details \
of the encoding, i.e., the amplitudes ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "0"], TraditionalForm]],ExpressionUUID->
  "ad724323-826b-486e-b82a-a1de16b2440d"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "1"], TraditionalForm]],ExpressionUUID->
  "e8c137c9-8b7b-4ba6-bf19-70c3b05bca75"],
 " in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["\[Psi]", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "dba59d6e-f308-4fd1-b43c-8c006f3a8e26"],
 ". Otherwise, measuring the error syndrome would destroy the superposition \
in the quantum states. For example, the measurement of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "1"], TraditionalForm]],ExpressionUUID->
  "511f5de3-8bb3-4e62-91aa-ada420e0db47"],
 " just compares the values for the first and second qubit, giving +1 if the \
values are the same and \[Minus]1 if they are different, without revealing \
the individual values. Similarly, measuring ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["M", "2"], TraditionalForm]],ExpressionUUID->
  "043a7e80-d9ef-4c61-ac01-b393161c53af"],
 " only compares the values of the second and third qubit, but it does not \
disclose the individual values. Nevertheless, it is still possible to \
determine where the error occurs. For example, suppose that the quantum noise \
flips the first qubit. Comparing the values of the first two qubits \
determines that the error has occurred on either of the first qubits, but not \
on exact which. Comparing the second and third qubit indicates that the error \
has occurred on neither (or both) of the qubits. Assuming that the error rate \
is sufficiently low, the two comparisons can successfully predict that the \
error occurred on the first qubit."
}], "TechNoteText",
 CellID->1878742520,ExpressionUUID->"bb14d9e0-04d7-43df-b37c-0f4faf551b1b"],

Cell[TextData[{
 "\tOnce the error-detection procedure identifies the error syndrome, the \
next step is to correct the error and recover the original encoded state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["\[Psi]", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "710c999d-2c68-4f90-a87b-cb1d16b2457c"],
 ". This step is called the recovery procedure. For the bit-flip error, the \
recovery procedure is quite simple. Depending on the qubit that has an error, \
one just has to apply the gate operation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"X", " ", "\[CircleTimes]", "I", " ", "\[CircleTimes]", "I"}], 
   TraditionalForm]],ExpressionUUID->"6ba39910-4146-433c-b51e-62ec64a39106"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", " ", "\[CircleTimes]", "X", " ", "\[CircleTimes]", "I"}], 
   TraditionalForm]],ExpressionUUID->"cef992c7-2973-47a1-8dee-58d79680f8a1"],
 ", or ",
 Cell[BoxData[
  FormBox[
   RowBox[{"I", " ", "\[CircleTimes]", "I", " ", "\[CircleTimes]", "X"}], 
   TraditionalForm]],ExpressionUUID->"ab9b7c35-dc70-4674-acca-97341e2f470e"],
 "; or, of course, just do nothing if the measurement indicates that no error \
has occurred."
}], "TechNoteText",
 CellID->1573471799,ExpressionUUID->"b2b28dd8-d06d-4495-89ad-31baab50dfe2"],

Cell[TextData[{
 "\tFollowing the error-correction procedure shown above, the original state \
is successfully recovered as long as either no error occurs at all or the \
bit-flip error occurs on only one of the three qubits. The probability for \
successful recovery is thus given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", " ", "\[Minus]", " ", "p"}], ")"}], "3"], " ", "+", " ", 
     RowBox[{"3", "p", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", " ", "\[Minus]", " ", "p"}], ")"}], "2"]}]}], " ", "=", 
    " ", 
    RowBox[{"1", " ", "\[Minus]", " ", 
     RowBox[{"3", "p"}], " ", "+", " ", 
     RowBox[{"2", 
      SuperscriptBox["p", "2"]}]}]}], TraditionalForm]],ExpressionUUID->
  "131806e0-ffdb-4cc3-b1f1-37f06a845bb7"],
 ". Compared to a probability of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"1", "\[Minus]", "p"}], TraditionalForm]],ExpressionUUID->
  "03b4fe04-dbba-42bc-b7ff-617ef0772178"],
 " for a bare state, i.e., a non-encoded state, to remain uncorrupted, the \
encoding and subsequent error-correction procedure improves the reliability \
of the storage of the quantum state as long as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"p", "<", 
    RowBox[{"1", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "a06d3c92-129a-4238-b52c-5c6daa425f40"],
 ". This rather crude estimation of the quality of the quantum \
error-correction procedure provides a first impression how the quantum \
error-correction code works, and a more complete analysis will follow later."
}], "TechNoteText",
 CellID->1226896635,ExpressionUUID->"b80a2a9e-619c-42cb-90b7-f83e071f3d82"],

Cell[CellGroupData[{

Cell["Demonstration", "Subsection",
 CellTags->"Section32",
 CellID->313765951,ExpressionUUID->"f41e376e-c2b1-47d7-9f4d-998743e0009b"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[515]:=",
 CellID->1163788193,ExpressionUUID->"edb88bc0-08a6-4f3d-93f2-74b713ed567f"],

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"Let", "[", 
  RowBox[{"Complex", ",", "c"}], "]"}]}], "Input",
 CellLabel->"In[516]:=",
 CellID->83645848,ExpressionUUID->"f2e925b2-a05e-4c76-9857-44b77e0142db"],

Cell["\<\
Suppose that we want to encode a single-qubit state to protect it against the \
bit-flip error.\
\>", "TechNoteText",
 CellID->1215234929,ExpressionUUID->"0286e7fb-c02b-48b6-827e-04af1e331521"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"in", "=", 
  RowBox[{"ProductState", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"S", "[", "1", "]"}], "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c", "[", "0", "]"}], ",", 
       RowBox[{"c", "[", "1", "]"}]}], "}"}]}], ",", 
    RowBox[{"\"\<Label\>\"", "->", 
     RowBox[{"Ket", "[", 
      RowBox[{"{", "\[Psi]", "}"}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[518]:=",
 CellID->214412648,ExpressionUUID->"b5776081-3879-4f7f-abce-ddbcb0f39b37"],

Cell[BoxData[
 InterpretationBox[
  TagBox[
   SubscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       InterpretationBox[
        SubscriptBox["c", 
         TemplateBox[{",", "\",\"", "0"},
          "RowWithSeparators"]],
        $CellContext`c[0]], " ", 
       TemplateBox[{"0"},
        "Ket"]}], "+", 
      RowBox[{
       InterpretationBox[
        SubscriptBox["c", 
         TemplateBox[{",", "\",\"", "1"},
          "RowWithSeparators"]],
        $CellContext`c[1]], " ", 
       TemplateBox[{"1"},
        "Ket"]}]}], ")"}], 
    InterpretationBox[
     SubscriptBox["S", 
      TemplateBox[{",", "\",\"", "1"},
       "RowWithSeparators"]],
     $CellContext`S[1, QuantumMob`Q3`$]]],
   DisplayForm],
  QuantumMob`Q3`ProductState[<|$CellContext`S[1, QuantumMob`Q3`$] -> {
      $CellContext`c[0], 
      $CellContext`c[1]}|>, "Label" -> Ket[{$CellContext`\[Psi]}]]]], "Output",\

 CellLabel->"Out[518]=",
 CellID->886954887,ExpressionUUID->"7d974e09-0ce1-43fd-b53d-26c54c0f8d3d"]
}, Open  ]],

Cell["\<\
The encoding is achieved by a quantum circuit model of the form.\
\>", "TechNoteMathCaption",
 CellID->1937844675,ExpressionUUID->"7f7cd4b3-75e6-45b1-b94d-8bd726cb4eef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"qc", "=", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{"in", ",", 
    RowBox[{"Ket", "[", 
     RowBox[{"S", "@", 
      RowBox[{"{", 
       RowBox[{"2", ",", "3"}], "}"}]}], "]"}], ",", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "]"}], ",", 
    RowBox[{"CNOT", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "3", "]"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[519]:=",
 CellID->971605280,ExpressionUUID->"582a6c77-8562-4799-85c6-e7ff5ed65255"],

Cell[BoxData[
 InterpretationBox[
  GraphicsBox[{
    {Dashing[{Small, Small}], LineBox[{}]}, 
    LineBox[{{{0, -1}, {3, -1}}, {{0, -2}, {3, -2}}, {{0, -3}, {3, -3}}}], 
    InsetBox[
     TemplateBox[{"\[Psi]"},
      "Ket"], {-0.2, -1.}, NCache[
     ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1, 
     0}], {InsetBox[
      TemplateBox[{"0"},
       "Ket"], {-0.2, -2.}, NCache[
      ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1,
       0}], InsetBox[
      TemplateBox[{"0"},
       "Ket"], {-0.2, -3.}, NCache[
      ImageScaled[{1, Rational[1, 2]}], ImageScaled[{1, 0.5}]], Automatic, {1,
       0}]}, {LineBox[{{1, -1}, {1, -2}}], 
     DiskBox[{1, -1}, 0.09], {CircleBox[{1, -2}, 0.26666666666666666], 
      LineBox[{{{0.7333333333333334, -2}, {1.2666666666666666`, -2}}, {{
         1, -2.2666666666666666`}, {1, -1.7333333333333334`}}}]}}, {
     LineBox[{{2, -1}, {2, -3}}], 
     DiskBox[{2, -1}, 0.09], {CircleBox[{2, -3}, 0.26666666666666666], 
      LineBox[{{{1.7333333333333334`, -3}, {2.2666666666666666`, -3}}, {{
         2, -3.2666666666666666`}, {2, -2.7333333333333334`}}}]}}},
   ImagePadding->{{25.56, 25.56}, {7.2, 7.2}},
   ImageSize->154.79999999999998`,
   PlotRange->{{0, 3}, {-3.5, -0.5}},
   PlotRangePadding->Scaled[0.025]],
  QuantumMob`Q3`QuantumCircuit[
   QuantumMob`Q3`PortIn[
    QuantumMob`Q3`ProductState[<|$CellContext`S[1, QuantumMob`Q3`$] -> {
        $CellContext`c[0], 
        $CellContext`c[1]}|>, "Label" -> Ket[{$CellContext`\[Psi]}]], 
    Ket[<|$CellContext`S[2, QuantumMob`Q3`$] -> 
      0, $CellContext`S[3, QuantumMob`Q3`$] -> 0|>]], 
