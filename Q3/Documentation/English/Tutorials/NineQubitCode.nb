      "RowWithSeparators"]],
    $CellContext`S[2, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "3"},
      "RowWithSeparators"]],
    $CellContext`S[3, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "4"},
      "RowWithSeparators"]],
    $CellContext`S[4, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "5"},
      "RowWithSeparators"]],
    $CellContext`S[5, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "6"},
      "RowWithSeparators"]],
    $CellContext`S[6, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "7"},
      "RowWithSeparators"]],
    $CellContext`S[7, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "8"},
      "RowWithSeparators"]],
    $CellContext`S[8, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "9"},
      "RowWithSeparators"]],
    $CellContext`S[9, QuantumMob`Q3`$]]}], "}"}]], "Output",
 CellLabel->"Out[551]=",
 CellID->1044508692,ExpressionUUID->"4abec553-cfd1-46f6-923d-43a016d059a5"]
}, Open  ]],

Cell["\<\
Let us define functions to encode the bit-flip and phase-flip codes.\
\>", "TechNoteMathCaption",
 CellID->103039677,ExpressionUUID->"a2e79e26-db1e-4652-b0f3-3d97442d5599"],

Cell[BoxData[
 RowBox[{
  RowBox[{"BitFlipEncoding", "[", 
   RowBox[{"ss", ":", 
    RowBox[{"{", 
     RowBox[{"__", "?", "QubitQ"}], "}"}]}], "]"}], ":=", 
  RowBox[{"Apply", "[", 
   RowBox[{"QuantumCircuit", ",", 
    RowBox[{"CNOT", "@@@", 
     RowBox[{"Thread", "[", 
      RowBox[{"List", "[", 
       RowBox[{
        RowBox[{"First", "@", "ss"}], ",", 
        RowBox[{"Rest", "@", "ss"}]}], "]"}], "]"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[552]:=",
 CellID->771514597,ExpressionUUID->"68c579cc-277a-4ca4-a7c5-e9048292bf87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"PhaseFlipEncoding", "[", 
   RowBox[{"ss", ":", 
    RowBox[{"{", 
     RowBox[{"__", "?", "QubitQ"}], "}"}]}], "]"}], ":=", 
  "\[IndentingNewLine]", 
  RowBox[{"QuantumCircuit", "[", 
   RowBox[{
    RowBox[{"BitFlipEncoding", "@", "ss"}], ",", 
    RowBox[{"Through", "[", 
     RowBox[{"ss", "[", "6", "]"}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[553]:=",
 CellID->115271807,ExpressionUUID->"b9d5d598-6321-4a08-9413-e3664f858aab"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"BitFlipEncoding", "[", 
