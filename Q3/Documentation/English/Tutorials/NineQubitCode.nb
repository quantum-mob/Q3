        4, -11.5}, {4, -0.5}}]]}, {{LineBox[{{5, -1}, {5, -2}}], 
      DiskBox[{5, -1}, 0.09], {CircleBox[{5, -2}, 0.26666666666666666], 
       LineBox[{{{4.733333333333333, -2}, {5.266666666666667, -2}}, {{
          5, -2.2666666666666666`}, {5, -1.7333333333333334`}}}]}}, {
      LineBox[{{5, -5}, {5, -6}}], 
      DiskBox[{5, -5}, 0.09], {CircleBox[{5, -6}, 0.26666666666666666], 
       LineBox[{{{4.733333333333333, -6}, {5.266666666666667, -6}}, {{
          5, -6.266666666666667}, {5, -5.733333333333333}}}]}}, {
      LineBox[{{5, -9}, {5, -10}}], 
      DiskBox[{5, -9}, 0.09], {CircleBox[{5, -10}, 0.26666666666666666], 
       LineBox[{{{4.733333333333333, -10}, {5.266666666666667, -10}}, {{
          5, -10.266666666666667`}, {5, -9.733333333333333}}}]}}}, {{
      LineBox[{{6, -2}, {6, -3}}], 
      DiskBox[{6, -2}, 0.09], {CircleBox[{6, -3}, 0.26666666666666666], 
       LineBox[{{{5.733333333333333, -3}, {6.266666666666667, -3}}, {{
          6, -3.2666666666666666`}, {6, -2.7333333333333334`}}}]}}, {
      LineBox[{{6, -6}, {6, -7}}], 
      DiskBox[{6, -6}, 0.09], {CircleBox[{6, -7}, 0.26666666666666666], 
       LineBox[{{{5.733333333333333, -7}, {6.266666666666667, -7}}, {{
          6, -7.266666666666667}, {6, -6.733333333333333}}}]}}, {
      LineBox[{{6, -10}, {6, -11}}], 
      DiskBox[{6, -10}, 0.09], {CircleBox[{6, -11}, 0.26666666666666666], 
       LineBox[{{{5.733333333333333, -11}, {6.266666666666667, -11}}, {{
          6, -11.266666666666667`}, {6, -10.733333333333333`}}}]}}}},
   AxesStyle->Automatic,
   FrameStyle->Automatic,
   ImagePadding->{{23.400000000000002`, 23.400000000000002`}, {5, 5}},
   ImageSize->298.8,
   PlotRangePadding->Scaled[0.025]]}]], "Picture",
 TextAlignment->Center,
 CellID->1658387102,ExpressionUUID->"7be36691-90b5-49a5-96f2-5d52bd526dc5"],

Cell[TextData[{
 StyleBox["Figure 3",
  FontWeight->"Bold"],
 ". Equivalent quantum circuits that can correct single-qubit bit-flip or \
phase-flip errors."
}], "TechNoteCaption",
 TextAlignment->Center,
 CellID->682128018,ExpressionUUID->"38f86bbf-dcff-4c97-bc25-d2473d4abb0d"],

Cell["\<\
\tThe syndrome of the bit-flip error on the first block can be diagnosed by \
measuring the following two observables\
\>", "TechNoteText",
 CellID->606095961,ExpressionUUID->"e5ed8772-6e94-49f2-8584-d1a0d12e7831"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"28a04933-f7e4-4225-a63f-6d629f9584e8"],
 " ,"
}], "TechNoteText",
 CellID->1139878806,ExpressionUUID->"0a819a65-ae06-4fb5-86f5-bbfd31dd02e6"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "Z", "\[CircleTimes]", "Z"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"9779eadf-c130-4c17-990b-db553d83603e"],
 " ."
}], "TechNoteText",
 CellID->241477555,ExpressionUUID->"7683e1c7-96af-4975-9f39-fdc84250f771"],

Cell["\<\
This is the way in which the bit-flip error is detected for a state encoded \
in three qubits. Similarly, the bit-flip errors on the rest of the blocks are \
diagnosed by measurement of the observables\
\>", "TechNoteText",
 CellID->1916657702,ExpressionUUID->"603898c7-93cf-4361-994c-10201f0a49bd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"96298505-cf1d-4a1c-ad4f-d3e89b117ab8"],
 " ,"
}], "TechNoteText",
 CellID->1011292514,ExpressionUUID->"b6a45dbd-b318-4306-b6ca-936137d407ac"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "Z", "\[CircleTimes]", "Z"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"c91b6e15-4caa-4a39-9f16-56cd10e8c5f0"],
 " ,"
}], "TechNoteText",
 CellID->1607700440,ExpressionUUID->"d8ea064b-e821-4f10-affc-46d905c945cd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "I"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"4c4a4fe7-3ce2-4b3c-8115-2dc8ee314e6c"],
 " ,"
}], "TechNoteText",
 CellID->982048526,ExpressionUUID->"3a303532-f1d7-4641-bbf1-c30e4ef035a1"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "Z", "\[CircleTimes]", "Z"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"4c9865f6-f780-40c8-8301-d78cb078f4f1"],
 " ."
}], "TechNoteText",
 CellID->1877749287,ExpressionUUID->"3f8116da-9ee3-4e0d-9341-449e1797e5de"],

Cell[TextData[{
 "Once the qubit with the bit-flip error has been identified, the error can \
be corrected by applying ",
 Cell[BoxData[
  FormBox["X", TraditionalForm]],ExpressionUUID->
  "3147fb22-30d7-472a-8b82-be73ed627298"],
 " on the qubit."
}], "TechNoteText",
 CellID->2060073944,ExpressionUUID->"be72dccd-e898-4cc5-aa50-bc7ed6e28216"],

Cell["\<\
\tThe phase-slip error on any single qubit switches the relative sign in the \
encoded state of the whole block that it belongs to. Following the phase-flip \
correction code, it is thus sufficient to compare the signs of different \
blocks. The observable to compare signs of the first two blocks is\
\>", "TechNoteText",
 CellID->1931419874,ExpressionUUID->"a067fda9-5a82-45a5-b905-3e13dcb07e05"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"X", "\[CircleTimes]", "X", "\[CircleTimes]", "X"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"X", "\[CircleTimes]", "X", "\[CircleTimes]", "X"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"7dd4ce5c-3a30-495f-b9d1-f9250e9ef7c2"],
 " ."
}], "TechNoteText",
 CellID->11014266,ExpressionUUID->"a81d9ba5-f8fd-4cb4-9cde-35c7fe87c585"],

Cell["\<\
Similarly, the signs of the second and third blocks can be compared through \
the measurement of the observable\
\>", "TechNoteText",
 CellID->433175020,ExpressionUUID->"fa105cc6-1f71-4e7f-9c65-b787093b8a19"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{"I", "\[CircleTimes]", "I", "\[CircleTimes]", "I"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"X", "\[CircleTimes]", "X", "\[CircleTimes]", "X"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{"X", "\[CircleTimes]", "X", "\[CircleTimes]", "X"}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"77c56141-02d2-407c-a44b-3fe537fe940c"],
 " ."
}], "TechNoteText",
 CellID->402997810,ExpressionUUID->"58701cbc-6385-48fc-a03c-871b5dc212db"],

Cell[TextData[{
 "Once the block affected by a phase-flip error has been identified, applying \
the operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Z", "\[CircleTimes]", "Z", "\[CircleTimes]", "Z"}], 
   TraditionalForm]],ExpressionUUID->"cfd7fe94-49f0-4ac9-906f-a95e7ace126c"],
 " on the block recovers the original state."
}], "TechNoteText",
 CellID->20770032,ExpressionUUID->"7ed9df4b-3cd8-4d1a-b920-c131646e8c3c"],

Cell[TextData[{
 "\tSo far, we have seen that the bit-flip and phase-flip errors on single \
qubits can be successfully detected and corrected as expected by constructing \
the code. Now the crucial point is that the same code can correct completely \
arbitrary errors as long as the error occurs in single qubits. Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      OverscriptBox["\[Psi]", "_"]},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"000"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"111"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "cc475b78-0942-4971-8aa8-346cc0af911f"],
 " be the initial state of the encoded qubits. Suppose that an error occurs \
in one of the qubits. The error can be efficiently described by a quantum \
operation ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "c0149517-0ac2-4433-986f-e4fc24337f5f"],
 ". Suppose that ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "16c98802-c5d7-4cee-b0a0-528f2b570e2b"],
 " is specified by the Kraus elements ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "9223350b-70f9-495a-ad05-01a9c4ebf1b9"],
 ". Then, the state corrupted by the error is given by"
}], "TechNoteText",
 CellID->1189577010,ExpressionUUID->"469651b9-bdc0-42c0-952a-54cd7308095d"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[ScriptCapitalF]", "(", 
     RowBox[{
      TemplateBox[{
        OverscriptBox["\[Psi]", "_"]},
       "Ket"], 
      TemplateBox[{
        OverscriptBox["\[Psi]", "_"]},
       "Bra"]}], ")"}], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "\[Mu]"], 
     RowBox[{
      SubscriptBox["F", "\[Mu]"], 
      TemplateBox[{
        OverscriptBox["\[Psi]", "_"]},
       "Ket"], 
      TemplateBox[{
        OverscriptBox["\[Psi]", "_"]},
       "Bra"], 
      SubsuperscriptBox["F", "\[Mu]", "\[Dagger]"]}]}]}], TraditionalForm]],
  ExpressionUUID->"110be523-dee2-451b-8604-65f3fd2a0200"],
 " ."
}], "TechNoteText",
 CellID->148053500,ExpressionUUID->"230c5a50-36f6-4e6f-901a-b69c0336c15e"],

Cell[TextData[{
 "It is a statistical mixture of various pure states. Let us focus on one of \
them, say, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "\[Mu]"], 
    TemplateBox[{
      OverscriptBox["\[Psi]", "_"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "94c1b715-c82e-4862-90ad-4bfdb10ffbb2"],
 ". As the Kraus element ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "ee0c707d-1aff-47b6-a29f-83146648a7b0"],
 " is an operator on a single qubit ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "79984efb-e7bd-480c-a862-840476af38c2"],
 ", it can be expanded in the Pauli operators,"
}], "TechNoteText",
 CellID->1549111274,ExpressionUUID->"c3b2f47b-7f43-4a28-b34a-74d953a76723"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "\[Mu]"], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["I", "j"], 
      SubscriptBox["C", 
       RowBox[{"0", "\[Mu]"}]]}], "+", 
     RowBox[{
      SubscriptBox["X", "j"], 
      SubscriptBox["C", 
       RowBox[{"1", "\[Mu]"}]]}], "+", 
     RowBox[{
      SubscriptBox["Y", "j"], 
      SubscriptBox["C", 
       RowBox[{"2", "\[Mu]"}]]}], "+", 
     RowBox[{
      SubscriptBox["Z", "j"], 
      SubscriptBox["C", 
       RowBox[{"3", "\[Mu]"}]]}]}]}], TraditionalForm]],ExpressionUUID->
  "8e0ab592-fcae-4022-9b49-9ba02855b63c"],
 " ,"
}], "TechNoteText",
 CellID->1968929537,ExpressionUUID->"a108b177-4da4-4427-bb3e-2a7620c8309c"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "\[Lambda]\[Mu]"], TraditionalForm]],ExpressionUUID->
  "28263dac-31e8-4b82-81ef-bb6d0ee748c5"],
 " are complex coefficients and the subscript ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "5abceb57-6da3-4235-9807-3125ed7e9bcb"],
 " attached to the Pauli operators indicate that the operators act on the \
particular qubit ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "ece6384d-1ea1-4390-af71-153220bb9f16"],
 ". Thus, the corrupted state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["F", "\[Mu]"], 
    TemplateBox[{
      OverscriptBox["\[Psi]", "_"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "07375fc9-1349-4bb5-94e7-b79795abca84"],
 " is a superposition of the initial state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     OverscriptBox["\[Psi]", "_"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "efdadb81-0fb5-431c-a2b3-996dfeeac0a7"],
 " without error, the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["X", "j"], 
    TemplateBox[{
      OverscriptBox["\[Psi]", "_"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "6c48a3f6-304c-4d2c-bae9-bcc25f4dda58"],
 " affected by the bit-flip error, the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["Z", "j"], 
    TemplateBox[{
      OverscriptBox["\[Psi]", "_"]},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "d87b4a0c-19af-44f0-8b6f-b2aa50360908"],
 " affected by the phase-flip error, and the state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["Y", "j"], 
     TemplateBox[{
       OverscriptBox["\[Psi]", "_"]},
      "Ket"]}], "=", 
    RowBox[{"\[ImaginaryI]", " ", 
     SubscriptBox["X", "j"], 
     SubscriptBox["Z", "j"], 
     TemplateBox[{
       OverscriptBox["\[Psi]", "_"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "0361a0d2-7ac0-44bd-838e-e787227b36fc"],
 " affected by both. When the error syndrome is diagnosed, the state \
collapses to the corresponding state, and the proper recovery operation \
discussed above brings back the initial state. The same procedure then \
applies to all other Kraus elements of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalF]", TraditionalForm]],ExpressionUUID->
  "0bc5a5bf-9170-47ae-a59e-6aeef10d5cf3"],
 "."
}], "TechNoteText",
 CellID->1223211736,ExpressionUUID->"7e1f0974-bd97-4801-b6c5-6c1c3c671ec8"],

Cell[TextData[{
 "\tThis example clearly demonstrates that once the code can correct just \
bit-flip and phase-flip errors, then it can correct any arbitrary error. In \
other words, even though the errors in the qubits form a continuum, the fate \
of a quantum error-correction code is determined by its ability to correct a \
discrete set of errors. This is more rigorously established in the ",
 StyleBox["discretization theorem of quantum errors",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->658694221,ExpressionUUID->"25731ef1-84d9-4c36-a931-c94b15f2b2eb"],

Cell[CellGroupData[{

Cell["Demonstration", "Subsection",
 CellTags->"Section34",
 CellID->395572062,ExpressionUUID->"260be554-78d7-4e74-a4c9-81bbaf7f98f0"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<QuantumMob`Q3`\>\"", "]"}]], "Input",
 CellLabel->"In[547]:=",
 CellID->12539733,ExpressionUUID->"5ecc259a-62a2-4e9e-9847-2ae33af5c1e1"],

Cell[BoxData[
 RowBox[{"Let", "[", 
  RowBox[{"Qubit", ",", "S"}], "]"}]], "Input",
 CellLabel->"In[548]:=",
 CellID->301895125,ExpressionUUID->"edb6685e-a344-4ed0-80d5-14286f3a8f89"],

Cell["We encode a physical single-qubit state into 9 qubits.", \
"TechNoteMathCaption",
 CellID->447557299,ExpressionUUID->"77d5b51b-9b32-47f0-bb9b-3832f7f117b8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"$n", "=", "9"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kk", "=", 
   RowBox[{"Range", "[", "$n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"SS", "=", 
  RowBox[{"S", "[", 
   RowBox[{"kk", ",", "$"}], "]"}]}]}], "Input",
 CellLabel->"In[549]:=",
 CellID->793700193,ExpressionUUID->"b864f964-3bfb-4d20-8e29-45eb9166e716"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["S", 
     TemplateBox[{",", "\",\"", "1"},
      "RowWithSeparators"]],
    $CellContext`S[1, QuantumMob`Q3`$]], ",", 
   InterpretationBox[
