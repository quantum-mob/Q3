Cell[CellGroupData[{

Cell["Bit-Flip Errors", "TechNoteSection",
 CellTags->"Section11",
 CellID->818099018,ExpressionUUID->"350776d7-5573-4a1b-9e4d-79c36c10afd1"],

Cell[TextData[{
 "Suppose that the quantum computer is subjected to quantum noise that flips \
the the basis states of the individual qubits, |0\:27e9 \[LeftRightArrow] |1\
\:27e9, with probability ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "f52156a1-529d-4388-a29b-29638ce30b13"],
 ". The error is called the ",
 StyleBox["bit-flip error",
  FontSlant->"Italic"],
 ", and we are to examine the code to correct it."
}], "TechNoteText",
 CellID->1599887432,ExpressionUUID->"17f21a06-19b8-463e-b2ea-a157558d1a53"],

Cell[TextData[{
 "\tTo protect a single-qubit state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "16c5d1b1-94df-478e-9d03-fa41e3e3d1f3"],
 " against the bit-flip error, one has to encode it to multiple qubits. For \
example, one encodes ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Psi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "cb078c26-9a8c-4b80-ac69-5db7454529ea"],
 " to the three-qubit state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      OverscriptBox["\[Psi]", "_"]},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"000"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"111"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "08346b2d-d0b5-40f2-878a-e8e120364f9f"],
 ". In this encoding, the logical basis states are"
}], "TechNoteText",
 CellID->665325537,ExpressionUUID->"0651a8f8-3f83-4a8e-a63a-b47c76531b01"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      OverscriptBox["0", "_"]},
     "Ket"], ":=", 
    TemplateBox[{"000"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "31803b00-47fb-4e6e-b087-2a4845cddbca"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      OverscriptBox["1", "_"]},
     "Ket"], ":=", 
    TemplateBox[{"111"},
     "Ket"]}], TraditionalForm]],ExpressionUUID->
  "900f3c63-4ff3-41c1-90fe-e1c19b23e07c"],
 " ,"
}], "TechNoteText",
 CellID->178950430,ExpressionUUID->"f0904b10-a8b5-46a2-98d2-856c2db29ca4"],

Cell[TextData[{
 "and these are distinguished from the physical basis states ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"0"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "73f9e13a-6332-4f50-802e-c22d393082ee"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"1"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "5abed13e-a103-495b-bd8d-b8bfc4ef44e2"],
 " of each qubit. Therefore, the subspace spanned by the two logical basis \
states is the ",
 StyleBox["code space",
  FontSlant->"Italic"],
 ". The projection onto the code space is given by"
}], "TechNoteText",
 CellID->1142771210,ExpressionUUID->"637e9c24-63cc-48d9-8fd2-2d0471d44cb3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "0"], ":=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"000"},
       "Ket"], 
      TemplateBox[{"000"},
       "Bra"]}], "+", 
     RowBox[{
      TemplateBox[{"111"},
       "Ket"], 
      TemplateBox[{"111"},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "9f33713e-1b3e-4f39-83b5-2f210076ae09"],
 " ."
}], "TechNoteText",
 CellID->1609471349,ExpressionUUID->"f290aec9-6f20-4703-988a-3ea9c39a5132"],

Cell["\<\
The encoding procedure can be achieved through quantum circuits such as in \
Figure 1.\
\>", "TechNoteText",
 CellID->680945031,ExpressionUUID->"3abb3077-30ec-4a74-ac72-b8dff9cb09c6"],

