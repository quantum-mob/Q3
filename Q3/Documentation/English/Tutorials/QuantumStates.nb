Cell[CellGroupData[{

Cell["System+Environment Model", "Subsection",
 CellTags->"Section18",
 CellID->225732466,ExpressionUUID->"c2b8621f-70ac-4b40-99d7-e66362f9b736"],

Cell[TextData[{
 "A mixed state arises naturally when the system interacts with its \
environment. As a closed system, the total system is described by a pure \
state ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], " ", "\[Element]", " ", 
    RowBox[{"\[ScriptCapitalH]", "\[CircleTimes]", "\[ScriptCapitalE]"}]}], 
   TraditionalForm]],ExpressionUUID->"41c714ec-1318-46ca-8d39-5a2e81a7882e"],
 ", where ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "47f2c9b2-2e13-4621-832a-756700d72cc2"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "7f4f8d97-8b7a-4ac8-9a77-2c6f20212375"],
 " are the Hilbert spaces respectively associated with the system and the \
environment. In accordance with the ",
 ButtonBox["Schmidt decomposition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchmidtDecomposition"],
 ", one can always express |\[CapitalPsi]\:27e9 in the form"
}], "TechNoteText",
 CellID->1429435460,ExpressionUUID->"faff0c60-85f4-4c49-a86c-a6a4fd2faee3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "=", "1"}], "R"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[Alpha]", "\[Mu]"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["\[Beta]", "\[Mu]"]},
       "Ket"]}], 
     SqrtBox[
      SubscriptBox["p", "\[Mu]"]]}]}], TraditionalForm]],ExpressionUUID->
  "c5cfab45-8d90-4be4-89bc-aea90f1ad235"],
 " ,"
}], "TechNoteText",
 CellID->622217231,ExpressionUUID->"7ad1d6d6-0a35-4837-a8db-49cd6ce258bd"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Alpha]", "\[Mu]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "44f4b26f-3c60-4a38-8521-a328e87a90ac"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Beta]", "\[Nu]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "87702c01-2af4-4753-81e9-5e2cc2d6f650"],
 " are orthonormal states in ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "eb389aba-ed9f-4c28-a0f0-185dbbdded5d"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "9abf3df4-a1b0-413c-bdb4-07db39844ba1"],
 ", respectively, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<=", 
    SubscriptBox["p", "\[Mu]"], "<", "1"}], TraditionalForm]],ExpressionUUID->
  "9dc8c81a-1de2-405d-bb5c-8dceb2835e34"],
 ", and ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "ea1bba45-8356-447d-b914-b0337ad79dad"],
 " is the Schmidt rank of state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "cdc8f0d3-0762-4803-889b-7662b41d77ef"],
 ".\nWithout access to the environment, one cannot tell which state among ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Alpha]", "\[Mu]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "98649a1f-0d39-4277-a084-9502cdd10cc1"],
 " the system is in. One can only tell the chances. The probability for the \
system to be found in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Alpha]", "\[Mu]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "32170206-a807-4ebd-9b43-ba6cb4fa98a4"],
 " is equal to ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Beta]", "\[Mu]"], 
      SubscriptBox["\[Beta]", "\[Mu]"]},
     "BraKet"], "=", 
    SubscriptBox["p", "\[Mu]"]}], TraditionalForm]],ExpressionUUID->
  "16596120-2a7c-4650-9b01-da34e5c3d63c"],
 ". Therefore, the density operator that describes the situation is given by"
}], "TechNoteText",
 CellID->1507124174,ExpressionUUID->"6b83bd76-cded-4608-88e4-aef61f680d88"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "=", "1"}], "R"], 
     TemplateBox[{
       SubscriptBox["\[Alpha]", "\[Mu]"]},
      "Ket"], 
     SubscriptBox["p", "\[Mu]"], 
     TemplateBox[{
       SubscriptBox["\[Alpha]", "\[Mu]"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "26d5d815-0afd-4a39-8c4b-beb9e6dba8aa"],
 "."
}], "TechNoteText",
 CellID->666376053,ExpressionUUID->"8b6475f3-58cd-4e0f-b2d7-598e9fbb01a1"],

Cell[TextData[{
 "Now noting that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Beta]", "\[Mu]"], 
      SubscriptBox["\[Beta]", "\[Nu]"]},
     "BraKet"], "=", 
    SubscriptBox["\[Delta]", "\[Mu]\[Nu]"]}], TraditionalForm]],
  ExpressionUUID->"98fc3293-fc19-4de7-9da3-8462b503611d"],
 " and"
}], "TechNoteText",
 CellID->655103666,ExpressionUUID->"d3507704-7bdf-4744-bf05-3e9f042acc1b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"], 
     TemplateBox[{"\[CapitalPsi]"},
      "Bra"]}], "=", 
    RowBox[{
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Mu]", "=", "1"}], "R"], 
     UnderoverscriptBox["\[CapitalSigma]", 
      RowBox[{"\[Nu]", "=", "1"}], "R"], 
     TemplateBox[{
       SubscriptBox["\[Alpha]", "\[Mu]"]},
      "Ket"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[Alpha]", "\[Nu]"]},
       "Bra"], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["\[Beta]", "\[Mu]"]},
       "Ket"]}], 
     TemplateBox[{
       SubscriptBox["\[Beta]", "\[Nu]"]},
      "Bra"], 
     SqrtBox[
      RowBox[{
       SubscriptBox["p", "\[Mu]"], 
       SubscriptBox["p", "\[Nu]"]}]]}]}], TraditionalForm]],ExpressionUUID->
  "37966a68-0a6d-4fa4-bdd7-3a5be97a9c93"],
 " ,"
}], "TechNoteText",
 CellID->178656293,ExpressionUUID->"ac58c334-958d-4174-b00e-a951698ae4c4"],

Cell[TextData[{
 "one can see that the previous expression for ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "1ab21d10-52a1-4a7f-a40b-1f1b43927a49"],
 " is equivalent to taking a ",
 ButtonBox["partial trace",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PartialTrace"],
 " over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "c17f623a-98ba-4224-8c40-5d424c273cfa"],
 ","
}], "TechNoteText",
 CellID->494177945,ExpressionUUID->"7a600818-c0c0-44fb-bd95-c1e25bcca2f7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     UnderscriptBox["Tr", "\[ScriptCapitalE]"], 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"], 
     TemplateBox[{"\[CapitalPsi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "103f0d3c-ee9e-432c-8bd1-fab448dd551b"],
 " ."
}], "TechNoteText",
 CellID->1329458666,ExpressionUUID->"f2fe4f3e-c38b-4698-b28e-8d38234d774b"],

Cell["\<\
In this sense, taking a partial trace over a particular part of the total \
system physically corresponds to \[OpenCurlyDoubleQuote]ignoring\
\[CloseCurlyDoubleQuote] that part.\
\>", "TechNoteText",
 CellID->1791936074,ExpressionUUID->"80dd511e-11ce-49f8-8dff-be16adaf7d43"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Purification", "Subsection",
 CellTags->"Section19",
 CellID->758930190,ExpressionUUID->"9c35ecab-d37a-49d1-beab-5581d1f8c1b5"],

Cell[TextData[{
 "We have seen that the ",
 ButtonBox["partial trace",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PartialTrace"],
 " of a pure state over a part of the total system results in a mixed state \
for the rest. The converse is also possible: Given a mixed state, one can \
find a pure state in an enlarged system that leads to the mixed state upon \
the ",
 ButtonBox["partial trace",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/PartialTrace"],
 ". A normalized pure state |\[CapitalPsi]\:27e9 in an extended Hilbert space \
",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalH]", "\[CircleTimes]", "\[ScriptCapitalE]"}], 
   TraditionalForm]],ExpressionUUID->"dd36f4b4-d2fc-4806-9490-991c3514fc9f"],
 " is called a ",
 ButtonBox["purification",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Purification"],
 " of the mixed state \[Rho] into ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalH]", "\[CircleTimes]", "\[ScriptCapitalE]"}], 
   TraditionalForm]],ExpressionUUID->"ef5c3079-3f5a-4262-bcb2-60838c2b84e1"],
 " if it gives \[Rho] upon the partial trace over ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "91428e55-c132-49c6-9870-3306cb454e01"],
 ","
}], "TechNoteText",
 CellID->1434323797,ExpressionUUID->"0bb90a8f-0c65-4f01-9f18-686f633a5c3c"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     UnderscriptBox["Tr", "\[ScriptCapitalE]"], 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"], 
     TemplateBox[{"\[CapitalPsi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "61632ce2-8137-4144-9b61-d28e392d53fa"],
 " ."
}], "TechNoteText",
 CellID->1176118604,ExpressionUUID->"67ce7e62-b1b1-4002-adbb-23858d5ac06f"],

Cell[TextData[{
 "To construct a ",
 ButtonBox["purification",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/Purification"],
 " of a mixed state \[Rho], take the spectral decomposition,"
}], "TechNoteText",
 CellID->1585890440,ExpressionUUID->"3ed7cebd-9bd5-4a83-b7ba-561a4d0f7833"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     TemplateBox[{
       SubscriptBox["r", "j"]},
      "Ket"], 
     SubscriptBox["r", "j"], 
     TemplateBox[{
       SubscriptBox["r", "j"]},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "4c9544dd-fec8-472a-8af6-a6d1b3d51895"],
 ","
}], "TechNoteText",
 CellID->1641082163,ExpressionUUID->"4612c33b-a411-42da-9f4f-a9c4c9338790"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "j"], TraditionalForm]],ExpressionUUID->
  "d7834087-e0ef-413a-b6c0-93cf94143b68"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["r", "j"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "a58f6002-e6ef-46b8-bd4e-8e7fc0bdf639"],
 " are the eigenvalues and corresponding eigenvectors of \[Rho]. Since \[Rho] \
is positive, all the eigenvalues ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "j"], TraditionalForm]],ExpressionUUID->
  "cb0d9159-7300-4107-b786-0e3ef6bb26c0"],
 " are non-negative. Then, by taking an orthonormal subset ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["\[Epsilon]", "j"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "e69b2179-e48f-4b5c-a523-1b002c5400aa"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalE]", TraditionalForm]],ExpressionUUID->
  "c3f1f65c-fa9e-4eb7-a0d9-95f801170044"],
 ", one can define a state"
}], "TechNoteText",
 CellID->1535435120,ExpressionUUID->"d1291e87-3fbf-4c10-a1dc-e07e74c484bd"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "j"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["r", "j"]},
       "Ket"], "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["\[Epsilon]", "j"]},
       "Ket"]}], 
     SqrtBox[
      SubscriptBox["r", "j"]]}]}], TraditionalForm]],ExpressionUUID->
  "15f4487d-6430-44b2-8e18-c2d3ba3e3d3e"],
 " ."
}], "TechNoteText",
 CellID->1894559488,ExpressionUUID->"efe25a25-52c6-49de-b809-3b6e61bddbb5"],

Cell[TextData[{
 "It is straightforward to check that the above state is a purification of \
\[Rho]. In other words, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     SubscriptBox["Tr", "\[ScriptCapitalE]"], 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"], 
     TemplateBox[{"\[CapitalPsi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "9f1fc1b0-413c-45c3-b10b-ca4157573324"],
 " ."
}], "TechNoteText",
 CellID->1121280747,ExpressionUUID->"a700aef4-6577-4002-a9be-3e6bf6857705"],

Cell[TextData[{
 "Purification is not unique. Different ",
 StyleBox["purifications",
  IgnoreSpellCheck->True],
 " give rise to the same mixed state \[Rho],"
}], "TechNoteText",
 CellID->1196512404,ExpressionUUID->"a829dd65-605a-4b85-ac17-4dcccfe19aa3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["Tr", "\[ScriptCapitalE]"], 
      TemplateBox[{"\[CapitalPsi]"},
       "Ket"], 
      TemplateBox[{"\[CapitalPsi]"},
       "Bra"]}], "=", 
     RowBox[{
      SubscriptBox["Tr", "\[ScriptCapitalE]"], 
      TemplateBox[{"\[CapitalPhi]"},
       "Ket"], 
      TemplateBox[{"\[CapitalPhi]"},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "492fec18-d78d-47b1-9871-85f8e39f4010"],
 " ,"
}], "TechNoteText",
 CellID->747103520,ExpressionUUID->"7491ad19-8cfe-4751-a0e3-ac2ca9ea7b04"],

Cell["as long as ", "TechNoteText",
 CellID->231976631,ExpressionUUID->"c1375919-59df-4386-bfcd-a20892dc8e67"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPhi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"I", "\[CircleTimes]", "U"}], ")"}], 
     TemplateBox[{"\[CapitalPsi]"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "2aba4be1-3375-495f-b36c-2698c78f17a7"]
}], "TechNoteText",
 CellID->1148417912,ExpressionUUID->"78bcd48a-bb91-4302-9654-d62180294180"],

Cell[TextData[{
 "for some unitary operator ",
 Cell[BoxData[
  FormBox["U", TraditionalForm]],ExpressionUUID->
  "7cb30610-28de-44ec-9cf5-af2f56c14dc6"],
 " on \[ScriptCapitalE]. This is known as the Gisin-Hughston-Jozsa-Wooters \
(GHJW) theorem after Gisin (1989) and Hughston et al. (1993). The unitary \
freedom in purification is closely related to the unitary freedom in the \
specification of ensembles of a mixed state that we have discussed earlier."
}], "TechNoteText",
 CellID->2024311395,ExpressionUUID->"da3f5632-d0cb-4865-81e5-5c8d85841dbb"],

Cell["\<\
A simple yet important aspect of the above observation is that when |\
\[CapitalPsi]\:27e9 of the total system is a separable state, |\[CapitalPsi]\
\:27e9 = |\[Alpha]\:27e9 \[CircleTimes] |\[Beta]\:27e9, the reduced state\
\>", "TechNoteText",
 CellID->18196344,ExpressionUUID->"35488644-6280-4db7-918a-28a7d65d742e"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     RowBox[{
      UnderscriptBox["Tr", "\[ScriptCapitalE]"], 
      TemplateBox[{"\[Alpha]"},
       "Ket"], 
      RowBox[{
       TemplateBox[{"\[Alpha]"},
        "Bra"], "\[CircleTimes]", 
       TemplateBox[{"\[Beta]"},
        "Ket"]}], 
      TemplateBox[{"\[Beta]"},
       "Bra"]}], "=", 
     RowBox[{
      TemplateBox[{"\[Alpha]"},
       "Ket"], 
      TemplateBox[{"\[Alpha]"},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "ddaea919-50d9-4585-9ca2-d6672cb57ae1"]
}], "TechNoteText",
 CellID->883275734,ExpressionUUID->"600bb160-0ec3-4032-b5bc-96085e840311"],

Cell[TextData[{
 "remains a pure state, retaining full coherence. This means that the \
entanglement between the system and the environment is responsible for the \
decoherence. In the history of quantum physics, it has been a mystery why \
quantum effects can be observed only in microscopic systems and not in \
macroscopic systems. Entanglement has provided a key clue to resolve this \
mystery. Entanglement also provides valuable resources for quantum \
information processing and quantum communications (see, e.g., ",
 ButtonBox["quantum teleportation",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/QuantumTeleportation"],
 ")."
}], "TechNoteText",
 CellID->1808293274,ExpressionUUID->"35c8a1d0-fce3-47c0-9fe8-1f587478e7d6"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1264373352,ExpressionUUID->"b84d5907-56cf-4c38-a59b-7e9d196cda98"],

Cell["\<\
For demonstration, suppose that Suppose that two qubits are coupled and that \
the total system is in the following state. We can regard the first qubit as \
the \[OpenCurlyDoubleQuote]system\[CloseCurlyDoubleQuote] and the second as \
the \[OpenCurlyDoubleQuote]environment\[CloseCurlyDoubleQuote].\
\>", "TechNoteMathCaption",
 CellID->796483774,ExpressionUUID->"0091a31e-0927-455c-821a-54ef50c48339"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"total", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Ket", "[", "]"}], "-", 
      RowBox[{"Ket", "[", 
       RowBox[{
        RowBox[{"S", "[", "1", "]"}], "\[Rule]", "1"}], "]"}], "+", 
      RowBox[{"Ket", "[", 
       RowBox[{
        RowBox[{"S", "[", "2", "]"}], "\[Rule]", "1"}], "]"}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", "3", "]"}]}], "//", "KetRegulate"}]}]], "Input",
 CellLabel->"In[129]:=",
 CellID->1237217867,ExpressionUUID->"346ff57b-2593-4057-8608-00ad4a155351"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox["0", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"1"}, "RowDefault"]], 
          $CellContext`S[1, Q3`$]]], 
        SubscriptBox["0", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"2"}, "RowDefault"]], 
          $CellContext`S[2, Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 0, $CellContext`S[2, Q3`$] -> 0|>]], "+", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox["0", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"1"}, "RowDefault"]], 
          $CellContext`S[1, Q3`$]]], 
        SubscriptBox["1", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"2"}, "RowDefault"]], 
          $CellContext`S[2, Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 0, $CellContext`S[2, Q3`$] -> 1|>]], "-", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox["1", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"1"}, "RowDefault"]], 
          $CellContext`S[1, Q3`$]]], 
        SubscriptBox["0", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"2"}, "RowDefault"]], 
          $CellContext`S[2, Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 1, $CellContext`S[2, Q3`$] -> 0|>]]}], 
  SqrtBox["3"]]], "Output",
 CellLabel->"Out[129]=",
 CellID->1713763349,ExpressionUUID->"39c90d96-cca7-4ac2-ae00-a4f3c232d93f"]
}, Open  ]],

Cell["\<\
The first qubit is in a mixed state. The density operator is given by the \
partial trace over the second qubit.\
\>", "TechNoteMathCaption",
 CellID->1452527936,ExpressionUUID->"3ea17091-d7da-4966-884c-5b69a1e0edf7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rho", "=", 
  RowBox[{"Elaborate", "@", 
   RowBox[{"PartialTrace", "[", 
    RowBox[{
     RowBox[{"total", "**", 
      RowBox[{"Dagger", "[", "total", "]"}]}], ",", 
     RowBox[{"S", "[", "2", "]"}]}], "]"}]}]}]], "Input",
 CellLabel->"In[130]:=",
 CellID->42921256,ExpressionUUID->"720779a4-006f-452a-97cd-d2323364a3e7"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], "-", 
  FractionBox[
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"S"}, "RowDefault"], 
      TemplateBox[{"1"}, "RowDefault"], 
      TemplateBox[{"\"x\""}, "RowDefault"]},
     "Subsuperscript"],
    $CellContext`S[1, 1]], "3"], "+", 
  FractionBox[
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"S"}, "RowDefault"], 
      TemplateBox[{"1"}, "RowDefault"], 
      TemplateBox[{"\"z\""}, "RowDefault"]},
     "Subsuperscript"],
    $CellContext`S[1, 3]], "6"]}]], "Output",
 CellLabel->"Out[130]=",
 CellID->980265470,ExpressionUUID->"f9d15720-e16f-4b53-9a10-34c3c3ceaab5"]
}, Open  ]],

Cell["\<\
This is the matrix representation of the density operator in the logical \
basis.\
\>", "TechNoteMathCaption",
 CellID->168720495,ExpressionUUID->"c7411c1f-10b1-4d8f-935a-040f04a011fb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MatrixForm", "@", 
  RowBox[{"Matrix", "@", "rho"}]}]], "Input",
 CellLabel->"In[131]:=",
 CellID->1006945425,ExpressionUUID->"41cf884a-a04d-41ce-b6f4-306f0a38a1ff"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["2", "3"], 
      RowBox[{"-", 
       FractionBox["1", "3"]}]},
     {
      RowBox[{"-", 
       FractionBox["1", "3"]}], 
      FractionBox["1", "3"]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {2, 2}, 0, {
     1, {{0, 2, 4}, {{1}, {2}, {2}, {1}}}, {
      Rational[2, 3], Rational[-1, 3], Rational[1, 3], 
       Rational[-1, 3]}}]]]]], "Output",
 CellLabel->"Out[131]//MatrixForm=",
 CellID->1152634740,ExpressionUUID->"837c7213-6f89-4136-b289-c911a50e6fbc"]
}, Open  ]],

Cell[TextData[{
 "A purification is a pure state of an extended system composed of the \
\[OpenCurlyDoubleQuote]system\[CloseCurlyDoubleQuote] and the \
\[OpenCurlyDoubleQuote]environment\[CloseCurlyDoubleQuote]. Here ",
 StyleBox["S[2,$]", "Input"],
 " is regarded as the environment."
}], "TechNoteMathCaption",
 CellID->1449642531,ExpressionUUID->"5dac5542-3e68-47aa-8df9-ea98b2b21dbd"],

Cell[CellGroupData[{

