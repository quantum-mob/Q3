      TemplateBox[{"S"}, "RowDefault"], 
      TemplateBox[{"1"}, "RowDefault"], 
      TemplateBox[{"\"x\""}, "RowDefault"]},
     "Subsuperscript"],
    $CellContext`S[1, 1]], "3"], "+", 
  FractionBox[
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"S"}, "RowDefault"], 
      TemplateBox[{"1"}, "RowDefault"], 
      TemplateBox[{"\"z\""}, "RowDefault"]},
     "Subsuperscript"],
    $CellContext`S[1, 3]], "6"]}]], "Output",
 CellLabel->"Out[133]=",
 CellID->1812709779,ExpressionUUID->"1ec44696-7aea-48b9-ab35-0ed654f16392"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Von Neumann Entropy", "Subsection",
 CellTags->"Section20",
 CellID->34281806,ExpressionUUID->"8446d61e-8de7-4125-9568-22c55a6891f4"],

Cell[TextData[{
 "When the system is in a pure state |\[Psi]\:27e9, the density operator is \
simply given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     TemplateBox[{"\[Psi]"},
      "Ket"], 
     TemplateBox[{"\[Psi]"},
      "Bra"]}]}], TraditionalForm]],ExpressionUUID->
  "572d1b0b-4253-4209-be19-23c1f0d9b759"],
 ". This suggests that for any pure state \[Rho], one has ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Rho]", "2"], "=", "\[Rho]"}], TraditionalForm]],
  ExpressionUUID->"57f2ea96-1af5-4ee5-8f05-3734fbacff44"],
 ". Indeed, given a density operator \[Rho], there is a simple test to \
determine whether the corresponding state is a pure state or a mixed state. \
It is a pure state ",
 StyleBox["if and only if",
  FontSlant->"Italic"],
 "  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", " ", "\[Rho]"}], " ", "=", "1"}], TraditionalForm]],
  ExpressionUUID->"3165a951-247d-485c-b1f5-874c1c28ca3a"],
 ". If it is a mixed state, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Tr", " ", 
    SuperscriptBox["\[Rho]", "2"]}], TraditionalForm]],ExpressionUUID->
  "a8e86fad-5d0e-470d-b48d-17d36acc95d0"],
 " is strictly smaller than 1."
}], "TechNoteText",
 CellID->648696046,ExpressionUUID->"b2405085-0c5d-4598-a5da-ec433985c8b6"],

Cell[TextData[{
 "The ",
 StyleBox[ButtonBox["von Neumann entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/VonNeumannEntropy"],
  FontSlant->"Italic"],
 " offers a far more general way to characterize a mixed state \[Rho]. The ",
 ButtonBox["von Neumann entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/VonNeumannEntropy"],
 " of a density operator \[Rho] is defined by"
}], "TechNoteText",
 CellID->2007452950,ExpressionUUID->"f7226e7e-1302-40cf-8dc1-03ce9357538f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"S", "(", "\[Rho]", ")"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "Tr"}], " ", "\[Rho]", " ", 
      SubscriptBox["log", "2"], "\[Rho]"}], "=", 
     RowBox[{
      RowBox[{"-", 
       UnderscriptBox["\[CapitalSigma]", "j"]}], 
      SubscriptBox["\[Lambda]", "j"], 
      SubscriptBox["log", "2"], 
      SubscriptBox["\[Lambda]", "j"]}]}]}], TraditionalForm]],ExpressionUUID->
  "7f48c6b3-4d3b-4798-b5f5-14f89f6aa0b8"],
 " ,"
}], "TechNoteText",
 CellID->146152633,ExpressionUUID->"311ea277-51a7-4875-8883-25fe82852659"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "j"], TraditionalForm]],ExpressionUUID->
  "193096f8-e1b1-4262-82aa-7a46cd6aedae"],
 " are the non-vanishing eigenvalues of \[Rho]. It is an extension of the \
notion of classical ",
 ButtonBox["Shannon entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/ShannonEntropy"],
 ". The base of the logarithm in the above expression is arbitrary. It is \
customary and convenient to take the logarithm of base 2 in quantum \
information theory."
}], "TechNoteText",
 CellID->1813494310,ExpressionUUID->"dfcba2e3-52d8-4fa1-80c8-85797dd276c4"],

Cell[TextData[{
 "The ",
 ButtonBox["von Neumann entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/VonNeumannEntropy"],
 " of any pure state is zero because the only eigenvalue of the density \
operator representing a pure state is 1. It is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["log", "2"], "N"}], TraditionalForm]],ExpressionUUID->
  "328cd903-33cd-44de-a6c2-87474ee10823"],
 " for the completely random state, ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{"I", "/", "N"}]}], TraditionalForm]],ExpressionUUID->
  "fe6b8ec7-2ad9-4844-89e7-35da2e2fc5a6"],
 ", where ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "5382c3c2-9f09-486e-9738-dc0b473bc6cf"],
 " is the dimension of the Hilbert space. In fact, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["log", "2"], "N"}], TraditionalForm]],ExpressionUUID->
  "0100d804-88cf-4e03-9330-6e54b379f075"],
 " is the maximum that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"S", 
    RowBox[{"(", "\[Rho]", ")"}]}], TraditionalForm]],ExpressionUUID->
  "63c72020-9676-44cb-8d52-30145bc610bb"],
 " can take for any \[Rho]. The ",
 ButtonBox["von Neumann entropy",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/VonNeumannEntropy"],
 " measures the uncertainty about the quantum states in the statistical \
mixture associated with the density operator."
}], "TechNoteText",
 CellID->1890044965,ExpressionUUID->"03092c5a-5fa4-4851-9f49-de855f6aaeb5"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1807392991,ExpressionUUID->"902ae2b4-17a6-4b2c-be60-233ab34d064e"],

Cell["\<\
For demonstration, consider again the same density operator discussed above.\
\>", "TechNoteMathCaption",
 CellID->452832917,ExpressionUUID->"48b1f244-4c56-4af4-9260-b06832b280be"],

