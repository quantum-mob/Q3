Cell["The mixture leads to the same density operator.", "TechNoteMathCaption",
 CellID->1601303862,ExpressionUUID->"392d7a85-2a06-4939-b31a-f2d9c8386fe9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Sigma]", "=", 
  RowBox[{"Total", "@", 
