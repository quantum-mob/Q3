Cell[CellGroupData[{

Cell["Separability of Mixed States", "Subsection",
 CellID->296444997,ExpressionUUID->"6295b944-8474-45e4-a3db-e6d5c95d2b1e"],

Cell["\<\
As an object describing a mixed state, one can ask whether a density operator \
is separable or not. Consider a system consisting of two subsystems A and B. \
A density operator \[Rho] (and the associated mixed state) is said to be \
separable if it can be written as a convex linear combination\
\>", "TechNoteText",
 CellID->163466299,ExpressionUUID->"41e387da-d838-4761-b2db-e32aab91eaf8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     RowBox[{
      SubscriptBox["\[Sigma]", "k"], "\[CircleTimes]", 
      SubscriptBox["\[Tau]", "k"]}], 
     SubscriptBox["p", "k"]}]}], TraditionalForm]],ExpressionUUID->
  "06a3242e-c07f-416c-9913-2be164207aa2"],
 ", \t",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "\[LessEqual]", 
    SubscriptBox["p", "k"], "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"446cb48c-f44c-4b60-9083-71ce5ea51426"],
 ", \t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     UnderscriptBox["\[CapitalSigma]", "k"], 
     SubscriptBox["p", "k"]}], "=", "1"}], TraditionalForm]],ExpressionUUID->
  "19712b97-722e-4e61-815e-1c271853cfa2"],
 " ,"
}], "TechNoteText",
 CellID->746502780,ExpressionUUID->"4b333a5f-a0df-4398-8b25-d285e84d2e3b"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "k"], TraditionalForm]],ExpressionUUID->
  "5f1c1c0d-def8-4f17-8fea-bf3807f31794"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Tau]", "k"], TraditionalForm]],ExpressionUUID->
  "fa2cc079-1e39-4e9d-8920-26c036e50ab6"],
 " are the density operators of subsystems A and B, respectively."
}], "TechNoteText",
 CellID->872757686,ExpressionUUID->"01b8f33a-eba3-48be-ac3d-b2895c554b7d"],

Cell[TextData[{
 "Unlike pure states, for which the ",
 ButtonBox["Schmidt decomposition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchmidtDecomposition"],
 " provides a simple test of entanglement, it is generally hard to tell \
whether a given mixed state is separable or entangled, and this remains an \
open question."
}], "TechNoteText",
 CellID->2009578454,ExpressionUUID->"6bf71712-09ee-4122-855b-aec37cd9acda"]
}, Open  ]]
}, Open  ]],

