   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "78cc762e-2717-47e9-be0e-25333a78a51c"],
 "."
}], "TechNoteText",
 CellID->1308734266,ExpressionUUID->"f9a40934-b519-4dea-9707-45670a3cadf7"],

