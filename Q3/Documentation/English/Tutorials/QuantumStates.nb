     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 0, $CellContext`S[2, Q3`$] -> 1|>]]}], "+", 
  RowBox[{
   SqrtBox[
    RowBox[{
     FractionBox["1", "30"], " ", 
     RowBox[{"(", 
