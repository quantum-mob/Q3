          $CellContext`S[1, Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 1|>]]}], "}"}]], "Output",
 CellLabel->"Out[80]=",
 CellID->378586847,ExpressionUUID->"037fb838-d137-46f2-8d19-e67c02075dee"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
