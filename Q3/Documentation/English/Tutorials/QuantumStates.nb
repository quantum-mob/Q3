Cell["\<\
Each state in the logical basis can also be specified manually.\
\>", "TechNoteMathCaption",
 CellID->68578318,ExpressionUUID->"9324b585-2d01-4078-9f1a-62b5d44cf64c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"vec", "=", 
  RowBox[{"Ket", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"S", "[", "1", "]"}], "\[Rule]", "1"}], ",", 
    RowBox[{
     RowBox[{"S", "[", "2", "]"}], "\[Rule]", "0"}]}], "]"}]}]], "Input",
 CellLabel->"In[84]:=",
 CellID->1544555834,ExpressionUUID->"231f0d09-ac2d-4072-b0a2-a112d35a0372"],

Cell[BoxData[
 InterpretationBox[
  TemplateBox[{
    TemplateBox[{
      SubscriptBox["1", 
       InterpretationBox[
        SubscriptBox[
         TemplateBox[{"S"}, "RowDefault"], 
         TemplateBox[{"1"}, "RowDefault"]], 
        $CellContext`S[1, Q3`$]]], 
      SubscriptBox["0", 
       InterpretationBox[
        SubscriptBox[
         TemplateBox[{"S"}, "RowDefault"], 
         TemplateBox[{"2"}, "RowDefault"]], 
        $CellContext`S[2, Q3`$]]]}, "RowDefault"]},
   "Ket"],
  Ket[<|$CellContext`S[1, Q3`$] -> 1, $CellContext`S[2, Q3`$] -> 
    0|>]]], "Output",
 CellLabel->"Out[84]=",
 CellID->505978922,ExpressionUUID->"bbf4e8ad-ee7c-4073-8f7e-71b3409f3584"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"vec", "=", 
  RowBox[{"Ket", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], ",", 
      RowBox[{"S", "[", "2", "]"}]}], "}"}], "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[85]:=",
 CellID->567577102,ExpressionUUID->"3c234ece-6376-4118-a9b0-7c0c79e6378d"],

Cell[BoxData[
 InterpretationBox[
  TemplateBox[{
    TemplateBox[{
      SubscriptBox["1", 
       InterpretationBox[
        SubscriptBox[
         TemplateBox[{"S"}, "RowDefault"], 
         TemplateBox[{"1"}, "RowDefault"]], 
        $CellContext`S[1, Q3`$]]], 
      SubscriptBox["0", 
       InterpretationBox[
        SubscriptBox[
         TemplateBox[{"S"}, "RowDefault"], 
         TemplateBox[{"2"}, "RowDefault"]], 
        $CellContext`S[2, Q3`$]]]}, "RowDefault"]},
