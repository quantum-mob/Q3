             FractionBox["1", "4"], " ", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"1", "+", 
                SqrtBox["5"]}], ")"}], "2"]}]}]]}]], "+", 
        FractionBox[
         InterpretationBox[
          TemplateBox[{
            TemplateBox[{
              SubscriptBox["1", 
               InterpretationBox[
                SubscriptBox[
                 TemplateBox[{"S"}, "RowDefault"], 
                 TemplateBox[{"2"}, "RowDefault"]], 
                $CellContext`S[2, Q3`$]]]}, "RowDefault"]},
           "Ket"],
          Ket[<|$CellContext`S[2, Q3`$] -> 1|>]], 
         SqrtBox[
          RowBox[{"1", "+", 
           RowBox[{
            FractionBox["1", "4"], " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "+", 
               SqrtBox["5"]}], ")"}], "2"]}]}]]]}], ")"}]}],
     HoldForm],
    Q3`OTimes[((1 + 
        Rational[1, 2] (1 + 5^Rational[1, 2])) (
         Rational[1, 4] (1 + 5^Rational[1, 2])^2 + (1 + 
           Rational[1, 2] (1 + 5^Rational[1, 2]))^2)^Rational[-1, 2]) 
      Ket[<|$CellContext`S[1, Q3`$] -> 0|>] + ((
        Rational[1, 2] (1 + 5^Rational[1, 2])) (
         Rational[1, 4] (1 + 5^Rational[1, 2])^2 + (1 + 
           Rational[1, 2] (1 + 5^Rational[1, 2]))^2)^Rational[-1, 2]) 
      Ket[<|$CellContext`S[1, Q3`$] -> 1|>], ((
        Rational[1, 2] (1 + 5^Rational[1, 2])) (1 + 
         Rational[1, 4] (1 + 5^Rational[1, 2])^2)^Rational[-1, 2]) 
      Ket[<|$CellContext`S[2, Q3`$] -> 0|>] + (1 + 
        Rational[1, 4] (1 + 5^Rational[1, 2])^2)^Rational[-1, 2] 
      Ket[<|$CellContext`S[2, Q3`$] -> 1|>]]]}]}]], "Output",
 CellLabel->"Out[94]=",
 CellID->1953682925,ExpressionUUID->"18754a42-bb84-4c94-b374-b99d1f574a37"]
}, Open  ]],

Cell[TextData[{
 "The ",
 ButtonBox["Schmidt decomposition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchmidtDecomposition"],
 " is incredibly complicated for such a simple-looking system. Let us take an \
approximation to get an impression of how the state is entangled."
}], "TechNoteMathCaption",
 CellID->729361797,ExpressionUUID->"464f6ab9-dfa8-480e-a8f4-fbd308ee6c23"],

