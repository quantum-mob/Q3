Cell["The two sets are related by the following unitary matrix", \
"TechNoteMathCaption",
 CellID->1242665086,ExpressionUUID->"79711484-b58c-4e6d-9409-1de8d00d9e38"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"U", "=", 
   RowBox[{"Topple", "@", 
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "1", ",", "2"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "6", "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"-", "1"}], ",", "0"}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "2", "]"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "1", ",", 
         RowBox[{"-", "1"}]}], "}"}], "/", 
       RowBox[{"Sqrt", "[", "3", "]"}]}]}], "\[IndentingNewLine]", "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"U", "//", "MatrixForm"}]}], "Input",
 CellLabel->"In[122]:=",
 CellID->1193633327,ExpressionUUID->"1ebb1121-646c-4549-a755-2a3d020a1e71"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox["1", 
       SqrtBox["6"]], 
      FractionBox["1", 
       SqrtBox["2"]], 
      FractionBox["1", 
       SqrtBox["3"]]},
     {
      FractionBox["1", 
       SqrtBox["6"]], 
      RowBox[{"-", 
       FractionBox["1", 
        SqrtBox["2"]]}], 
      FractionBox["1", 
       SqrtBox["3"]]},
     {
      SqrtBox[
       FractionBox["2", "3"]], "0", 
      RowBox[{"-", 
       FractionBox["1", 
        SqrtBox["3"]]}]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellLabel->"Out[123]//MatrixForm=",
 CellID->1328026429,ExpressionUUID->"0cac2b61-df32-48a7-b4a7-bde64e2722a5"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Bloch-Sphere Representation", "Subsection",
 CellTags->"Section16",
 CellID->1476499534,ExpressionUUID->"325c66ca-6096-4419-91d5-a05b3a8edb60"],

Cell[TextData[{
 "Recall that two-dimensional pure states are visualized on a Bloch sphere. A \
mixed state \[Rho]\:02c6 for a qubit can be similarly visualized, but in \
general the representing point resides inside the Bloch sphere. As for a pure \
state, the Bloch vector ",
 StyleBox["b",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 " corresponding to a mixed state \[Rho] is defined by"
}], "TechNoteText",
 CellID->1354126853,ExpressionUUID->"7967672a-fe9e-434f-b696-8a73fc70a78a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["b",
     FontWeight->"Bold"], "=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\:27e8\[Sigma]", "x"], "\:27e9"}], ",", 
      RowBox[{
       SuperscriptBox["\:27e8\[Sigma]", "y"], "\:27e9"}], ",", 
      RowBox[{
       SuperscriptBox["\:27e8\[Sigma]", "z"], "\:27e9"}]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"6244ec80-6373-44e4-90fe-2960cf7d0c18"],
 "."
}], "TechNoteText",
 CellID->2029085295,ExpressionUUID->"0b967346-f5af-4586-855c-afe7f63ecf68"],

Cell["\<\
Recalling that any operator on a two-dimensional vector space is a linear \
superposition of the Pauli operators, we decompose a density operator into \
the form\
\>", "TechNoteText",
 CellID->278058092,ExpressionUUID->"17a70d80-3351-491f-9f34-b6b1cf0d25b7"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Rho]", "=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{"I", "+", 
       RowBox[{"x", " ", 
        SuperscriptBox["\[Sigma]", "x"]}], "+", 
       RowBox[{"y", " ", 
        SuperscriptBox["\[Sigma]", "y"]}], "+", 
       RowBox[{"z", " ", 
        SuperscriptBox["\[Sigma]", "z"]}]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"84531559-9335-4da7-8c97-65a01a093c69"]
}], "TechNoteText",
 CellID->1925811112,ExpressionUUID->"b754485f-2961-4d8e-8df0-20a9e1db9f39"],

Cell[TextData[{
 "with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"x", ",", "y", ",", 
    RowBox[{"z", "\[Element]", "\[DoubleStruckCapitalR]"}]}], 
   TraditionalForm]],ExpressionUUID->"0738b25f-4d0c-4bfc-b076-098437e4efe3"],
 ". By evaluating the averages,"
}], "TechNoteText",
 CellID->233831800,ExpressionUUID->"d1fdfec3-ab7f-4e3a-98c9-b69236e27549"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     SuperscriptBox["\[Sigma]", "\[Mu]"], "\[RightAngleBracket]"}], "=", 
    RowBox[{"Tr", " ", "\[Rho]", " ", 
     SuperscriptBox["\[Sigma]", "\[Mu]"]}]}], TraditionalForm]],
  ExpressionUUID->"a9f7cc2f-0990-45cc-9b74-51c280de5465"],
 " ,"
}], "TechNoteText",
 CellID->115988590,ExpressionUUID->"e4a87d32-ad57-4687-8c2e-95bef0ca857e"],

Cell[TextData[{
 "of the Pauli operators with respect to \[Rho], one can see that the Bloch \
vector corresponding to \[Rho] is just given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["b",
     FontWeight->"Bold"], "=", 
    RowBox[{"(", 
     RowBox[{"x", ",", "y", ",", "z"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"84eb40a3-8303-490e-ad96-2775307699be"],
 ". Clearly, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox["x", "2"], "+", 
      SuperscriptBox["y", "2"], "+", 
      SuperscriptBox["z", "2"]}]], "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"d40b145a-406d-4c14-8ea6-dc4af0e48001"],
 ", and it may in general lie inside the Bloch sphere."
}], "TechNoteText",
 CellID->1652564301,ExpressionUUID->"a47493ac-0cf3-4df3-972d-8d3154b191ce"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->2105990533,ExpressionUUID->"10d7db39-d7a2-40cc-bd48-e3c7ddda4bbc"],

