           SubscriptBox["0", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Bra"], 
       Bra[<|$CellContext`S[Q3`$] -> 0|>]]},
     "RowDefault"],
    Q3`Dyad[<|$CellContext`S[Q3`$] -> 1|>, <|$CellContext`S[Q3`$] -> 0|>]]}], 
  "+", 
  FractionBox[
   InterpretationBox[
    TemplateBox[{
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["1", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Ket"], 
