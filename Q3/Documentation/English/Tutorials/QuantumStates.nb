   RowBox[{"PartialTrace", "[", 
    RowBox[{"ket", ",", 
     RowBox[{"S", "[", "2", "]"}]}], "]"}], "//", "Elaborate"}]}]], "Input",
 CellLabel->"In[133]:=",
 CellID->763851449,ExpressionUUID->"1a83fe06-b419-4e0a-8629-a566f00ad3a8"],

