Cell[CellGroupData[{

Cell["Entanglement", "Subsection",
 CellTags->"Section13",
 CellID->70176320,ExpressionUUID->"d3e30552-d7a3-4d32-8b53-71c25ed0f205"],

Cell[TextData[{
 "Many quantum systems, especially of many particles, are composed of several \
parts with independent degrees of freedom. For such a system, the overall \
Hilbert space is built up from the Hilbert spaces of individual parts by \
means of the tensor product. For example, consider a system of two parts and \
suppose that they are associated with the vector spaces V and W, \
respectively. The total Hilbert space is given by the tensor product ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", "\[CircleTimes]", "\[ScriptCapitalW]"}], 
   TraditionalForm]],ExpressionUUID->"8c9eaf90-080a-4427-b6a9-76bb4cc6623d"],
 ", which is defined to be the vector space spanned by the tensor-product \
basis"
}], "TechNoteText",
 CellID->484888037,ExpressionUUID->"22aa6ab5-c929-4173-9adc-e6e68cc2dc6b"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "i"]},
        "Ket"], "\[CircleTimes]", 
       RowBox[{
        TemplateBox[{
          SubscriptBox["w", "j"]},
         "Ket"], ":", "i"}]}], "=", "0"}], ",", "1", ",", "2", ",", 
     "\[Ellipsis]", ",", 
     RowBox[{
      RowBox[{"m", "-", "1"}], ";", " ", 
      RowBox[{"j", "=", "0"}]}], ",", "1", ",", "2", ",", "\[Ellipsis]", ",", 
     
     RowBox[{"n", "-", "1"}]}], "}"}], TraditionalForm]],ExpressionUUID->
  "10b6b4e2-375a-4f3f-92dd-b438cacfa2a4"],
 " ,"
}], "TechNoteText",
 CellID->1960281141,ExpressionUUID->"ba43cee3-ccf4-448b-b04a-ad786794a1ea"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["v", "i"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "492fd771-3317-49dc-ae56-66dad9da5f64"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["w", "j"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "b18f6f5a-c4ac-4d51-833a-fca3b56c2541"],
 " are bases of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "37f74c00-731a-46fb-84ee-1bfa8febb559"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "5aca9c85-6396-41bc-b83b-ba0c1f7aeafd"],
 " of dimensions ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "24c92c94-6e69-419a-a777-44d615215e30"],
 " and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "1c68a94d-477a-49e5-9194-ea41c283ab5e"],
 ", respectively. The dimension of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalV]", "\[CircleTimes]", "\[ScriptCapitalW]"}], 
   TraditionalForm]],ExpressionUUID->"20c77677-3246-4e49-8b5e-eaa7a9fdfece"],
 " for the total system is obviously given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", " ", "n"}], TraditionalForm]],ExpressionUUID->
  "1fa20e75-a00a-4342-b213-714966cfbc6e"],
 ", and in general a state vector of the total system is a linear \
superposition consisting of ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[VeryThinSpace]", "n"}], TraditionalForm]],ExpressionUUID->
  "cd65bf04-c9fd-4d1d-86b0-788ba4d87fc3"],
 " terms"
}], "TechNoteText",
 CellID->1898508160,ExpressionUUID->"821d6d95-8058-4611-a5e0-ddca05189be3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"i", "=", "0"}], 
      RowBox[{"m", "-", "1"}]], 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"j", "=", "0"}], 
       RowBox[{"n", "-", "1"}]], 
      RowBox[{
       RowBox[{
        TemplateBox[{
          SubscriptBox["v", "i"]},
         "Ket"], "\[CircleTimes]", 
        TemplateBox[{
          SubscriptBox["w", "j"]},
         "Ket"]}], 
       SubscriptBox["c", 
        RowBox[{"i", " ", "j"}]]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "6fff8b9c-48f7-4a89-a5a9-64169d8eae46"],
 " ."
}], "TechNoteText",
 CellID->914617994,ExpressionUUID->"f97f9654-0a57-451f-8914-1dbd50f862df"],

Cell["\tSome state vectors are factored into the form", "TechNoteText",
 CellID->296679932,ExpressionUUID->"fd2aa2a3-2068-4785-b032-e03589819568"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{
        SubscriptBox["v", "0"]},
       "Ket"], "+", 
      TemplateBox[{
        SubscriptBox["v", "1"]},
       "Ket"], "+", 
      TemplateBox[{
        SubscriptBox["v", "2"]},
       "Ket"], "+", "\[CenterEllipsis]"}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{
        SubscriptBox["w", "0"]},
       "Ket"], "+", 
      TemplateBox[{
        SubscriptBox["w", "1"]},
       "Ket"], "+", 
      TemplateBox[{
        SubscriptBox["w", "2"]},
       "Ket"], "+", "\[CenterEllipsis]"}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"7ef4bd77-4121-4436-8088-57a6db73bb87"],
 " ."
}], "TechNoteText",
 CellID->1990072437,ExpressionUUID->"0c25394b-1a59-4c86-b10c-2c2515a8e919"],

Cell[TextData[{
 "Such a state is said to be ",
 StyleBox["separable",
  FontSlant->"Italic"],
 ". For example, the superposition of all the logical basis states of two \
qubits"
}], "TechNoteText",
 CellID->89646634,ExpressionUUID->"f637c8a3-7432-4100-932e-e8b3355f93be"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], "+", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"1"},
      "Ket"]}], "+", 
    RowBox[{
     TemplateBox[{"1"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], "+", 
    RowBox[{
     TemplateBox[{"1"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"1"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "3f075276-76f2-42d4-8515-7a30ced937e0"],
 " ."
}], "TechNoteText",
 CellID->1304941091,ExpressionUUID->"01495b6f-0333-4fdb-b343-86798bd4a79c"],

Cell["is factored into", "TechNoteText",
 CellID->2041913273,ExpressionUUID->"50fd9e4a-30db-486d-8896-dafa0b7a909a"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}], "\[CircleTimes]", 
    RowBox[{"(", 
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], "+", 
      TemplateBox[{"1"},
       "Ket"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "3828606c-7de5-416d-857b-081dfdd9dd67"],
 " ."
}], "TechNoteText",
 CellID->1647700251,ExpressionUUID->"d41034b5-6116-4ec6-8d72-d94a81497a6a"],

Cell["and is a separable state. On the other hand, the state", "TechNoteText",
 CellID->1096490492,ExpressionUUID->"b471dca1-cb27-4325-bb53-5002142b20a3"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}], "+", 
    RowBox[{
     TemplateBox[{"0"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"1"},
      "Ket"]}], "+", 
    RowBox[{
     TemplateBox[{"1"},
      "Ket"], "\[CircleTimes]", 
     TemplateBox[{"0"},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "10b57020-595b-4344-b109-684e1f9a3a23"],
 " ."
}], "TechNoteText",
 CellID->1158524137,ExpressionUUID->"756bde5e-64cf-4f6b-ab8b-b09fc597d736"],

Cell[TextData[{
 "can never be factored. Such a state is said to be ",
 StyleBox["entangled",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->80943210,ExpressionUUID->"3f3e6bc3-5e15-4a34-9783-60d1ffa639e1"],

Cell[TextData[{
 "\tThe ",
 StyleBox[ButtonBox["Schmidt decomposition",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/SchmidtDecomposition"],
  FontSlant->"Italic"],
 " is a systematic way to test whether a given quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "1823ae14-f099-48e7-83a8-a465181fe5b8"],
 " in a tensor-product space is separable or not. The Schmidt decomposition \
is a method to choose proper bases ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubsuperscriptBox["v", "i", "\[Prime]"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "be6f802f-4ae8-4c87-bda8-9907420873f5"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubsuperscriptBox["w", "j", "\[Prime]"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "3205f7a1-bd33-467d-88a8-f729409cfaaf"],
 " of ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalV]", TraditionalForm]],ExpressionUUID->
  "0ab6db27-226e-41aa-89d8-bf0a8941871c"],
 " and ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalW]", TraditionalForm]],ExpressionUUID->
  "acd7f1af-0c95-46b4-8385-e3a447cd55e2"],
 ", respectively, to rewrite the given state vector ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "536f4046-9b9b-490e-a278-b0d5c8689132"],
 " in the least number of terms of the form"
}], "TechNoteText",
 CellID->1250869630,ExpressionUUID->"7db2810b-13ff-472e-919f-2249b502f7c8"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket"], "=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], 
      RowBox[{"R", "-", "1"}]], 
     RowBox[{
      RowBox[{
       TemplateBox[{
         SubsuperscriptBox["v", "k", "\[Prime]"]},
        "Ket"], "\[CircleTimes]", 
       TemplateBox[{
         SubsuperscriptBox["w", "k", "\[Prime]"]},
        "Ket"]}], 
      SubscriptBox["s", "k"]}]}]}], TraditionalForm]],ExpressionUUID->
  "48329321-b993-440a-bf61-defa72862fea"],
 " ,"
}], "TechNoteText",
 CellID->1055381919,ExpressionUUID->"7c0658ae-2428-431e-b118-7ba24b36be05"],

Cell[TextData[{
 "where the coefficients sk are all definitely positive. Here, the so-called ",
 StyleBox["Schmidt rank",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]],ExpressionUUID->
  "e9ec3974-59b7-402e-b926-7ad93c63b2f3"],
 " of the quantum state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "83e904df-0e02-4d40-a258-bd4eebdbd55b"],
 " cannot be larger than the smaller of ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "15737fba-88b1-4a15-b522-a7ee1ea35100"],
 " and ",
 Cell[BoxData[
  FormBox["n", TraditionalForm]],ExpressionUUID->
  "6f09e9ec-cb8e-4e65-8361-63f0f5d26cd6"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", " ", "\[LessEqual]", " ", 
    RowBox[{"min", 
     RowBox[{"(", 
      RowBox[{"m", ",", " ", "n"}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"ef29836b-d512-4801-a794-d3b98c0059fd"],
 ". If the Schmidt rank is 2 or larger, then the state is entangled."
}], "TechNoteText",
 CellID->1736472060,ExpressionUUID->"c883ba08-fd16-49b7-a904-dd4a91daf1a4"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->862357793,ExpressionUUID->"068b07a2-8994-45bf-9438-d3f8bca8ffb1"],

Cell["\<\
For demonstration, consider the following state of a two-qubit state.\
\>", "TechNoteMathCaption",
 CellID->1672556258,ExpressionUUID->"4811861b-7e79-4fb3-8236-e41d9a04d27c"],

