 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"ww", ",", "uu", ",", "vv"}], "}"}], "=", 
   RowBox[{"SchmidtDecomposition", "[", 
    RowBox[{"ket", ",", 
     RowBox[{"S", "[", "1", "]"}], ",", 
