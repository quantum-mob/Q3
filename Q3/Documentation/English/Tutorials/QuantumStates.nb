      RowBox[{"-", 
       FractionBox["\[ImaginaryI]", "3"]}], 
      FractionBox["1", "3"]}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[
   SparseArray[
    Automatic, {2, 2}, 0, {
     1, {{0, 2, 4}, {{1}, {2}, {1}, {2}}}, {
      Rational[2, 3], Complex[0, Rational[1, 3]], Complex[0, Rational[-1, 3]],
        Rational[1, 3]}}]]]]], "Output",
 CellLabel->"Out[104]//MatrixForm=",
 CellID->1022964092,ExpressionUUID->"31751976-a6e3-4c04-a644-7c4f278ae22f"]
}, Open  ]],

Cell["\<\
This gives the expression of the density operator in terms of the Pauli \
operators.\
\>", "TechNoteMathCaption",
 CellID->1208854682,ExpressionUUID->"fefd1e8e-0ed0-4507-be51-96a8585c186d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Elaborate", "@", 
  RowBox[{"ExpressionFor", "[", 
   RowBox[{
    RowBox[{"Matrix", "@", "\[Rho]"}], ",", 
    RowBox[{"S", "[", "1", "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[105]:=",
 CellID->2025339754,ExpressionUUID->"d0012738-f7bf-4b4c-a328-1e983e53eff0"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], "-", 
  FractionBox[
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"S"}, "RowDefault"], 
      TemplateBox[{"1"}, "RowDefault"], 
      TemplateBox[{"\"y\""}, "RowDefault"]},
     "Subsuperscript"],
    $CellContext`S[1, 2]], "3"], "+", 
  FractionBox[
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{"S"}, "RowDefault"], 
      TemplateBox[{"1"}, "RowDefault"], 
      TemplateBox[{"\"z\""}, "RowDefault"]},
     "Subsuperscript"],
    $CellContext`S[1, 3]], "6"]}]], "Output",
 CellLabel->"Out[105]=",
 CellID->1029777942,ExpressionUUID->"401ab894-f5ea-4ebe-a38e-3581cbfb303a"]
}, Open  ]],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->1026651925,ExpressionUUID->"ef658e35-65c9-4472-ab38-d93c0d6446a4"],

Cell[TextData[{
 "By construction, any density operator ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "8817dfff-ae01-44f8-9b91-8c8c703b6fe0"],
 " is Hermitian, that is, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Rho]", "\[Dagger]"], "=", "\[Rho]"}], TraditionalForm]],
  ExpressionUUID->"f322be7d-13a7-4e6c-aa4a-2912e6caf52b"],
 ". Obviously, a density operator is an operator acting on the state vectors \
in the vector space ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "edc93aba-9cd6-48b6-af2c-c0bd489f28d6"],
 ". However, it is more appropriate to regard it as a \"vector\" in the \
vector space ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "(", "\[ScriptCapitalH]", ")"}], 
   TraditionalForm]],ExpressionUUID->"af32c0ba-b837-4ff3-817c-6f6006eeef2b"],
 " of all linear operators on ",
 Cell[BoxData[
  FormBox["\[ScriptCapitalH]", TraditionalForm]],ExpressionUUID->
  "9685d4e8-52c5-4cee-ab53-4bac49ea4fb0"],
 ". "
}], "TechNoteText",
 CellID->1034517134,ExpressionUUID->"ac62af62-85df-4b78-bc1b-ea130ebce095"],

Cell[TextData[{
 "Each diagonal element ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Rho]", 
     RowBox[{"j", " ", "j"}]], ":=", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["v", "j"]},
      "Bra"], "\[Rho]", 
     TemplateBox[{
       SubscriptBox["v", "j"]},
      "Ket"]}]}], TraditionalForm]],ExpressionUUID->
  "ec301ed2-a880-49d6-961b-2c1ea13ad523"],
 " in a given basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      SubscriptBox["v", "j"]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "16036032-fec4-4aa1-a51a-f218df55ab20"],
 " carries an important physical meaning.  ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Rho]", 
    RowBox[{"j", " ", "j"}]], TraditionalForm]],ExpressionUUID->
  "5c5bc672-1e6c-4568-941d-a70bd3cdf729"],
 " gives the probability ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "j"], TraditionalForm]],ExpressionUUID->
  "676ec636-397e-4e80-a6d1-4785c7a1e5b9"],
 " to find the system in the basis state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["v", "j"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "2e974280-88db-425e-9443-8936199e275e"],
 ". To see it, note that that the probability to find the system in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["v", "j"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "8fe37551-7af8-45af-adc8-1a453eb7953a"],
 " is ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"\[LeftBracketingBar]", 
     TemplateBox[{
       SubscriptBox["v", "j"], 
       SubscriptBox["\[Psi]", "\[Mu]"]},
      "BraKet"], "\[RightBracketingBar]"}], "2"], TraditionalForm]],
  ExpressionUUID->"8102c4f5-c739-4437-a520-ecf0246028be"],
 " under the condition that the state is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     SubscriptBox["\[Psi]", "\[Mu]"]},
    "Ket"], TraditionalForm]],ExpressionUUID->
  "d097a488-66b3-4beb-968f-4d6b1da86f8e"],
 ". The latter has the chance of probability ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "\[Mu]"], TraditionalForm]],ExpressionUUID->
  "ba6f0650-df00-47e7-8aad-1fda8c9893d1"],
 ". Therefore the overall probability ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["P", "j"], TraditionalForm]],ExpressionUUID->
  "de6d27dd-a869-4ca7-a044-4727295b9f0f"],
 " is given by"
}], "TechNoteText",
 CellID->1101865026,ExpressionUUID->"6835c511-ea13-4aab-9578-587005386138"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["P", "j"], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Sum]", "\[Mu]"], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"\[LeftBracketingBar]", 
         TemplateBox[{
           SubscriptBox["v", "j"], 
           SubscriptBox["\[Psi]", "\[Mu]"]},
          "BraKet"], "\[RightBracketingBar]"}], "2"], 
       SubscriptBox["p", "\[Mu]"]}]}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Sum]", "\[Mu]"], 
       RowBox[{
        RowBox[{"\[LeftBracketingBar]", 
         RowBox[{
          TemplateBox[{
            SubscriptBox["\[Psi]", "\[Mu]"], 
            SubscriptBox["v", "j"]},
           "BraKet"], 
          SubscriptBox["p", "\[Mu]"], 
          TemplateBox[{
            SubscriptBox["v", "j"], 
            SubscriptBox["\[Psi]", "\[Mu]"]},
           "BraKet"]}], "\[RightBracketingBar]"}], 
        SubscriptBox["p", "\[Mu]"]}]}], "=", 
      RowBox[{
       TemplateBox[{
         SubscriptBox["v", "j"]},
        "Bra"], "\[Rho]", 
       TemplateBox[{
         SubscriptBox["v", "j"]},
        "Ket"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "3be82939-9794-4f85-bf08-c72b81453e8e"]
}], "TechNoteText",
 CellID->1294003901,ExpressionUUID->"105403ce-e3e1-4638-9e4e-ccb0ce1d6d96"],

Cell["\<\
as expected. The physical meaning of diagonal elements further implies \
several basic yet important properties of density operator:\
\>", "TechNoteText",
 CellID->756670938,ExpressionUUID->"3eb77adb-d9b2-4589-b453-95fc2cf36a2d"],

Cell[TextData[{
 "\t(a) A density operator is not only Hermitian but also ",
 StyleBox["positive",
  FontSlant->"Italic"],
 "."
}], "TechNoteText",
 CellID->1541743128,ExpressionUUID->"b373346c-9c6a-41cf-a423-5f86684d34d5"],

Cell[TextData[{
 "\t(b) A density operator has the unit trace, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"Tr", " ", "\[Rho]"}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"e84e2a0f-e303-40ba-9b9a-05e5eae02889"],
 "."
}], "TechNoteText",
 CellID->2092547480,ExpressionUUID->"de1a925f-a534-42df-bcf8-37c91ccb1c22"],

Cell[TextData[{
 "\t(c) Any eigenvalue of a density operator ",
 Cell[BoxData[
  FormBox["\[Rho]", TraditionalForm]],ExpressionUUID->
  "395a623d-d05f-431a-b05c-cfb75bc270fb"],
 " lies between 0 and 1. It is often said that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"0", "<", "\[Rho]", "\[LessEqual]", "1"}], TraditionalForm]],
  ExpressionUUID->"7650d718-441d-417d-8048-1cddec4c8fe9"],
 "."
}], "TechNoteText",
 CellID->1790582276,ExpressionUUID->"a5d6cfd4-f35c-4551-94af-7706f8ef3e37"],

Cell["\<\
\tOn the other hand, the off-diagonal elements of a density operator are \
responsible for the coherence effects, as we will observe later in various \
interference experiments. Note that coherence is a basis-dependent effect.\
\>", "TechNoteText",
 CellID->2117781079,ExpressionUUID->"d7d564e0-d968-44e0-8592-73a10089bc9c"],

Cell[CellGroupData[{

Cell["Unitary Freedom in Mixture", "Subsection",
 CellTags->"Section15",
 CellID->1152629375,ExpressionUUID->"835fa87f-66a0-4fa2-a5ca-c891e204007d"],

Cell["\<\
It is also interesting to note that the density operator and the relevant \
physical properties do not depend on all the details in the specification of \
the statistical ensemble, which in some sense makes the description of mixed \
states in terms of the density operator so powerful and efficient.\
\>", "TechNoteText",
 CellID->1939409685,ExpressionUUID->"9ac88dbe-6d59-46e6-84ae-14869a6f16f8"],

Cell[TextData[{
 "Suppose that two statistical ensembles be specified by the sets ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{
        RowBox[{
          RowBox[{
            SubscriptBox["\[Alpha]", "\[Mu]"], ":", "\[Mu]"}], "=", "1"}], 
        ",", "2", ",", "\[Ellipsis]", ",", "m"}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "4ed868ef-16ec-4e91-8009-ada50ee3e47b"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    TemplateBox[{
      RowBox[{
        RowBox[{
          RowBox[{
            SubscriptBox["\[Beta]", "\[Nu]"], ":", "\[Nu]"}], "=", "1"}], ",",
         "2", ",", "\[Ellipsis]", ",", "n"}]},
     "Ket"], "}"}], TraditionalForm]],ExpressionUUID->
  "e9d0108e-1a12-457d-9461-0bc52a8b010e"],
 ", respectively, of unnormalized vectors. Without loss of generality, assume \
that ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "\[LessEqual]", "n"}], TraditionalForm]],ExpressionUUID->
  "b1320f83-7f01-4bf2-a543-4cba8ed91115"],
 ". Then, the density operators describing the ensembles are identical,"
}], "TechNoteText",
 CellID->1151781629,ExpressionUUID->"d2bd956d-7963-4660-96f1-a39269fb7f40"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"\[Mu]", "=", "1"}], "m"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[Alpha]", "\[Mu]"]},
       "Ket"], 
      TemplateBox[{
        SubscriptBox["\[Alpha]", "\[Mu]"]},
       "Bra"]}]}], "=", 
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"\[Nu]", "=", "1"}], "n"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[Beta]", "\[Nu]"]},
       "Ket"], 
      TemplateBox[{
        SubscriptBox["\[Beta]", "\[Nu]"]},
       "Bra"]}]}]}], TraditionalForm]],ExpressionUUID->
  "eec94dbf-159a-4566-a1e2-20ccba84fdd4"]
}], "TechNoteText",
 CellID->576244545,ExpressionUUID->"d9c7f50e-d207-4e62-bd31-d63ffe9b4339"],

Cell[TextData[{
 "if and only if there exists an ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[Times]", "n"}], TraditionalForm]],ExpressionUUID->
  "2b08777a-6542-4c39-99bf-70fd31d2c1b8"],
 " unitary matrix ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["U", "\[Mu]\[Nu]"], TraditionalForm]],ExpressionUUID->
  "07f3ba6d-23e5-4f2a-9a92-a28127b522ac"],
 " such that"
}], "TechNoteText",
 CellID->1938303492,ExpressionUUID->"8ec15487-645b-4459-bf89-89338f118591"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Beta]", "\[Nu]"]},
     "Ket"], "=", 
    RowBox[{
     SubscriptBox["\[Sum]", "\[Mu]"], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[Alpha]", "\[Mu]"]},
       "Ket"], 
      SubscriptBox["U", "\[Mu]\[Nu]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "15c1f9c2-143a-4edd-aac9-994c2493135d"]
}], "TechNoteText",
 CellID->1887348701,ExpressionUUID->"d1a0d41d-713f-422b-93a6-85637142a2f2"],

Cell[TextData[{
 "for all ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Nu]", " ", "=", " ", "1"}], ",", " ", "2", ",", "\[Ellipsis]", 
    " ", ",", " ", "n"}], TraditionalForm]],ExpressionUUID->
  "81f7e66f-d855-4018-9cd0-64957d49a4f2"],
 ". Although a rigorous proof is beyond the main scope of the book, the \
impact of unitary freedom\[LongDash]or ambiguity\[LongDash]in the \
specification of mixed states is wide spread. Furthermore, a similar unitary \
freedom is observed in the description of decoherence."
}], "TechNoteText",
 CellID->188667870,ExpressionUUID->"9c9c819c-36a2-4d6b-91f9-d0eb9f3f8d9e"],

Cell[TextData[{
 "For a proof, interested readers are referred to Section 1.1 in the ",
 Cell[BoxData[
  TemplateBox[{
    Cell[
     TextData["Quantum Workbook (2022)"]], 
    "https://doi.org/10.1007/978-3-030-91214-7"},
   "WebLink",
   BaseStyle->{"TechNoteText"}]],ExpressionUUID->
  "52de2c4c-b62b-4f5c-a14e-4f3239516648"],
 "."
}], "TechNoteText",
 CellID->1255028118,ExpressionUUID->"1babd94c-3b9f-4daf-8733-7e2117762963"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->2055283477,ExpressionUUID->"42715356-80c1-4718-95fa-8fb1d3c64023"],

Cell["\<\
For demonstration, consider a statistical mixture of the following three pure \
states.\
\>", "TechNoteMathCaption",
 CellID->673198392,ExpressionUUID->"b3a16cc2-e696-4313-8200-c7779cc2db71"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"v1", "=", 
   RowBox[{"Ket", "[", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v2", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Ket", "[", "]"}], "+", 
      RowBox[{"I", " ", 
       RowBox[{"Ket", "[", 
        RowBox[{"S", "\[Rule]", "1"}], "]"}]}]}], ")"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v3", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Ket", "[", "]"}], "2"}], "+", 
      RowBox[{
       RowBox[{"Ket", "[", 
        RowBox[{"S", "\[Rule]", "1"}], "]"}], "I"}]}], ")"}], " ", "/", 
    RowBox[{"Sqrt", "[", "5", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"KetRegulate", "@", 
  RowBox[{"{", 
   RowBox[{"v1", ",", "v2", ",", "v3"}], "}"}]}]}], "Input",
 CellLabel->"In[106]:=",
 CellID->1501521948,ExpressionUUID->"22f4f2b3-6f6b-48d4-b926-d7d4ecd389ea"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox["0", 
         InterpretationBox["S", 
          $CellContext`S[Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[Q3`$] -> 0|>]], ",", 
   FractionBox[
    RowBox[{
     InterpretationBox[
      TemplateBox[{
        TemplateBox[{
          SubscriptBox["0", 
           InterpretationBox["S", 
            $CellContext`S[Q3`$]]]}, "RowDefault"]},
       "Ket"],
      Ket[<|$CellContext`S[Q3`$] -> 0|>]], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["1", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]},
        "Ket"],
       Ket[<|$CellContext`S[Q3`$] -> 1|>]]}]}], 
    SqrtBox["2"]], ",", 
   FractionBox[
    RowBox[{
     RowBox[{"2", " ", 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["0", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]},
        "Ket"],
       Ket[<|$CellContext`S[Q3`$] -> 0|>]]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["1", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]},
        "Ket"],
       Ket[<|$CellContext`S[Q3`$] -> 1|>]]}]}], 
    SqrtBox["5"]]}], "}"}]], "Output",
 CellLabel->"Out[109]=",
 CellID->1099739790,ExpressionUUID->"5e9d89ee-ff72-43a4-a3ff-d8453d6f336f"]
}, Open  ]],

Cell["These are the associated probabilities.", "TechNoteMathCaption",
 CellID->1907691927,ExpressionUUID->"eb48cee1-4b16-445a-8f95-e8e619a2c1c3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p1", "=", 
   RowBox[{"1", "/", "8"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p2", "=", 
   RowBox[{"1", "/", "4"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p3", "=", 
   RowBox[{"5", "/", "8"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"{", 
  RowBox[{"p1", ",", "p2", ",", "p3"}], "}"}]}], "Input",
 CellLabel->"In[110]:=",
 CellID->647367379,ExpressionUUID->"07171e05-a64f-452d-8fbc-94adfb5ffd9b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "8"], ",", 
   FractionBox["1", "4"], ",", 
   FractionBox["5", "8"]}], "}"}]], "Output",
 CellLabel->"Out[113]=",
 CellID->1508630128,ExpressionUUID->"0d77e060-32ee-49d4-9038-074e9b76168a"]
}, Open  ]],

Cell["The mixed state is described by the density operator.", \
"TechNoteMathCaption",
 CellID->321475740,ExpressionUUID->"96a8aa63-a830-4555-982f-d61bd58477e2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Rho]", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Dyad", "[", 
        RowBox[{"#", ",", "#", ",", "S"}], "]"}], "&"}], ",", 
      RowBox[{"{", 
       RowBox[{"v1", ",", "v2", ",", "v3"}], "}"}]}], "]"}], ".", 
    RowBox[{"{", 
     RowBox[{"p1", ",", "p2", ",", "p3"}], "}"}]}], "//", 
   "Garner"}]}]], "Input",
 CellLabel->"In[114]:=",
 CellID->660865806,ExpressionUUID->"4e7c0e8a-5f44-4cf4-a918-821531827d6f"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"3", " ", 
    InterpretationBox[
     TemplateBox[{
       InterpretationBox[
        TemplateBox[{
          TemplateBox[{
            SubscriptBox["0", 
             InterpretationBox["S", 
              $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Ket"], 
        Ket[<|$CellContext`S[Q3`$] -> 0|>]], 
       InterpretationBox[
        TemplateBox[{
          TemplateBox[{
            SubscriptBox["0", 
             InterpretationBox["S", 
              $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Bra"], 
        Bra[<|$CellContext`S[Q3`$] -> 0|>]]},
      "RowDefault"],
     Q3`Dyad[<|$CellContext`S[Q3`$] -> 0|>, <|$CellContext`S[Q3`$] -> 0|>]]}],
    "4"], "-", 
  RowBox[{
   FractionBox["3", "8"], " ", "\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["0", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Ket"], 
       Ket[<|$CellContext`S[Q3`$] -> 0|>]], 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["1", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Bra"], 
       Bra[<|$CellContext`S[Q3`$] -> 1|>]]},
     "RowDefault"],
    Q3`Dyad[<|$CellContext`S[Q3`$] -> 0|>, <|$CellContext`S[Q3`$] -> 1|>]]}], 
  "+", 
  RowBox[{
   FractionBox["3", "8"], " ", "\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["1", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Ket"], 
       Ket[<|$CellContext`S[Q3`$] -> 1|>]], 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["0", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Bra"], 
       Bra[<|$CellContext`S[Q3`$] -> 0|>]]},
     "RowDefault"],
    Q3`Dyad[<|$CellContext`S[Q3`$] -> 1|>, <|$CellContext`S[Q3`$] -> 0|>]]}], 
  "+", 
  FractionBox[
   InterpretationBox[
    TemplateBox[{
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["1", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Ket"], 
       Ket[<|$CellContext`S[Q3`$] -> 1|>]], 
      InterpretationBox[
       TemplateBox[{
         TemplateBox[{
           SubscriptBox["1", 
            InterpretationBox["S", 
             $CellContext`S[Q3`$]]]}, "RowDefault"]}, "Bra"], 
       Bra[<|$CellContext`S[Q3`$] -> 1|>]]},
     "RowDefault"],
    Q3`Dyad[<|$CellContext`S[Q3`$] -> 1|>, <|$CellContext`S[Q3`$] -> 1|>]], 
   "4"]}]], "Output",
 CellLabel->"Out[114]=",
 CellID->1475811263,ExpressionUUID->"f05edd6e-3bc9-4381-8bac-43243307e60b"]
}, Open  ]],

Cell["Next consider another set of pure states.", "TechNoteMathCaption",
 CellID->216008360,ExpressionUUID->"9e0c7e48-d949-4635-80c7-e897c29aabb8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
