     "RowDefault"],
    Q3`Dyad[<|$CellContext`S[Q3`$] -> 1|>, <|$CellContext`S[Q3`$] -> 1|>]], 
   "4"]}]], "Output",
 CellLabel->"Out[134]=",
 CellID->1868404833,ExpressionUUID->"5dbe7086-52de-429b-8202-6d7ce7383bd7"]
