}, Open  ]],

Cell[TextData[{
 "A general quantum state of ",
 StyleBox["S[1,$]", "Input"],
 " is a linear combination of the two basis states with two complex \
coefficients ",
 StyleBox["c[0]", "Input"],
 " and ",
 StyleBox["c[1]", "Input"],
 "."
}], "TechNoteMathCaption",
 CellID->1612912112,ExpressionUUID->"3072c28b-c3b2-4ed6-bb68-cebe017725ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Let", "[", 
  RowBox[{"Complex", ",", "c"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"vec", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], "\[Rule]", "0"}], "]"}], 
    RowBox[{"c", "[", "0", "]"}]}], "+", 
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], "\[Rule]", "1"}], "]"}], 
    RowBox[{"c", "[", "1", "]"}]}]}]}]}], "Input",
 CellLabel->"In[86]:=",
 CellID->1862888414,ExpressionUUID->"8789449e-99f0-449b-8951-ff47ca3fd845"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox[
     TemplateBox[{"c"},
      "RowDefault"], 
     TemplateBox[{"0"},
      "RowDefault"]],
    $CellContext`c[0]], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox["0", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"1"}, "RowDefault"]], 
          $CellContext`S[1, Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 0|>]]}], "+", 
  RowBox[{
   InterpretationBox[
    SubscriptBox[
     TemplateBox[{"c"},
      "RowDefault"], 
     TemplateBox[{"1"},
      "RowDefault"]],
    $CellContext`c[1]], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox["1", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"1"}, "RowDefault"]], 
          $CellContext`S[1, Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 1|>]]}]}]], "Output",
 CellLabel->"Out[87]=",
 CellID->1637822325,ExpressionUUID->"e6004439-6dda-43dc-b64a-a65c5a50f575"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Bloch-Sphere Representation", "Subsection",
 CellTags->"Section12",
 CellID->11593658,ExpressionUUID->"a0d145e9-bbef-414e-ba53-eae2b1c012fd"],

Cell["\<\
For a qubit\[LongDash]an idealistic two-level quantum system\[LongDash]the \
Hilbert space is two-dimensional. A basis of two logical states |0\:27e9 and \
|1\:27e9 is assumed, and it is called the logical basis of the qubit.\
\>", "TechNoteText",
 CellID->1581081776,ExpressionUUID->"e330c7f5-d814-4d55-8103-841b16611ff3"],

Cell[TextData[{
 "A two-dimensional state vector is often visualized as a point, called a ",
 StyleBox[ButtonBox["Bloch vector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BlochVector"],
  FontSlant->"Italic"],
 ", on the Bloch sphere. The ",
 StyleBox[ButtonBox["Bloch sphere",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BlochSphere"],
  FontSlant->"Italic"],
 " is a geometrical representation of a two-dimensional vector space. Any \
state vector |\[Psi]\:27e9 is expanded in the logical basis as"
}], "TechNoteText",
 CellID->278761254,ExpressionUUID->"17ffb2d5-d497-4c78-935c-8d0f1a749ecb"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], 
      SubscriptBox["c", "0"]}], "+", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], 
      SubscriptBox["c", "1"]}]}]}], TraditionalForm]],ExpressionUUID->
  "884088ca-96f5-46db-a5c5-e6039515702b"]
}], "TechNoteText",
 CellID->1478561871,ExpressionUUID->"1338db23-b7a2-4800-ba2f-0ed741cca54b"],

Cell[TextData[{
 "with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "0"], ",", 
    RowBox[{
     SubscriptBox["c", "1"], "\[Element]", "\[DoubleStruckCapitalC]"}]}], 
   TraditionalForm]],ExpressionUUID->"12077cad-8938-4a41-b9a7-ce78252f4cd4"],
 ". The normalization condition, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"|", 
     SubscriptBox["c", "0"], 
     SuperscriptBox["|", "2"], 
     RowBox[{"+", 
      RowBox[{"|", 
       SubscriptBox["c", "1"], 
       SuperscriptBox["|", "2"]}]}]}], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"1799f262-b302-4b4b-9b19-8dfee2c9b84f"],
 ", tells us that the state vector can be expressed up to a global phase \
factor by"
}], "TechNoteText",
 CellID->1656086460,ExpressionUUID->"be2e9c69-88ec-4711-bb06-8260987af645"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    TemplateBox[{"\[Psi]"},
     "Ket"], "=", 
    RowBox[{
     RowBox[{
      TemplateBox[{"0"},
       "Ket"], 
      RowBox[{"cos", "(", 
       RowBox[{"\[Theta]", "/", "2"}], ")"}]}], "+", 
     RowBox[{
      TemplateBox[{"1"},
       "Ket"], 
      RowBox[{"sin", "(", 
       RowBox[{"\[Theta]", "/", "2"}], ")"}], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[ImaginaryI]", " ", "\[Phi]"}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"bb52b357-1681-4c7a-b27f-af15214731f6"]
}], "TechNoteText",
 CellID->309584453,ExpressionUUID->"598a7ebc-40ef-4258-bb00-5143ac295a48"],

Cell[TextData[{
 "with \[Theta] and \[Phi] respectively specifying the magnitude and phase, \
of the expansion coefficients (",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Theta]", ",", 
    RowBox[{"\[Phi]", "\[Element]", "\[DoubleStruckCapitalR]"}]}], 
   TraditionalForm]],ExpressionUUID->"5c2cee9a-e50d-40b2-954f-0d9c538f3b03"],
 "). The ",
 StyleBox["Bloch vector",
  FontSlant->"Italic"],
 " associated with the state vector |\[Psi]\:27e9 is defined by"
}], "TechNoteText",
 CellID->1980508537,ExpressionUUID->"acdb239a-8e7a-452d-9265-50f49573d704"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["b",
     FontWeight->"Bold"], ":=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"sin\[Theta]", " ", "cos\[Phi]"}], ",", 
      RowBox[{"sin\[Theta]", " ", "sin\[Phi]"}], ",", "cos\[Theta]"}], 
     ")"}]}], TraditionalForm]],ExpressionUUID->
  "b210af39-cb58-4b47-8e30-f79a1fca93d8"],
 "."
}], "TechNoteText",
 CellID->410452859,ExpressionUUID->"4a6e05ae-91f3-4110-8990-8d567fa14d09"],

Cell["\<\
This way, any state vector in a two-dimensional Hilbert space corresponds \
uniquely (up to a global phase factor) to a point on the sphere with unit \
radius, i.e., the Bloch sphere.\
\>", "TechNoteText",
 CellID->181162647,ExpressionUUID->"fd164706-469f-4035-a0e2-c2cef7a93ecd"],

Cell[TextData[{
 "The Bloch vector can equivalently be obtained in terms of the expectation \
values of the ",
 ButtonBox["Pauli operators",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/tutorial/SingleQubitGates#1574772109"],
 ", "
}], "TechNoteText",
 CellID->763727049,ExpressionUUID->"2ba983c4-7fab-4f42-af26-2b6bfae3ea3f"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["b",
     FontWeight->"Bold"], ":=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[LeftAngleBracket]", 
       SuperscriptBox["\[Sigma]", "x"], "\[RightAngleBracket]"}], ",", 
      RowBox[{"\[LeftAngleBracket]", 
       SuperscriptBox["\[Sigma]", "y"], "\[RightAngleBracket]"}], ",", 
      RowBox[{"\[LeftAngleBracket]", 
       SuperscriptBox["\[Sigma]", "z"], "\[RightAngleBracket]"}]}], ")"}]}], 
   TraditionalForm]],ExpressionUUID->"0fa24804-ef4d-4e89-be42-6757bd7585e4"],
 "."
}], "TechNoteText",
 CellID->450754424,ExpressionUUID->"fe2d824e-b585-472e-9239-195a5625180e"],

Cell["Indeed, with |\[Psi]\:27e9 in the above form, one can show that", \
"TechNoteText",
 CellID->1654781199,ExpressionUUID->"cba775c7-8ce7-47c2-8202-fd749de26979"],

Cell[TextData[{
 "\t",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     SuperscriptBox["\[Sigma]", "x"], "\[RightAngleBracket]"}], "=", 
    RowBox[{"sin\[Theta]", " ", "cos\[Phi]"}]}], TraditionalForm]],
  ExpressionUUID->"5f85b892-63aa-47ba-848f-f990d5da7993"],
 " ,     ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     SuperscriptBox["\[Sigma]", "y"], "\[RightAngleBracket]"}], "=", 
    RowBox[{"sin\[Theta]", " ", "sin\[Phi]"}]}], TraditionalForm]],
  ExpressionUUID->"c9683347-ad13-46d2-8153-8fa66b9e7618"],
 " ,    ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[LeftAngleBracket]", 
     SuperscriptBox["\[Sigma]", "z"], "\[RightAngleBracket]"}], "=", 
    "cos\[Theta]"}], TraditionalForm]],ExpressionUUID->
  "1e647d73-4174-4db7-b2ee-a2e3f2d087d2"],
 " ."
}], "TechNoteText",
 CellID->1994382943,ExpressionUUID->"9106e0c3-5538-4968-8fed-9c35da32ae30"],

Cell["\<\
An important point is that a state can be characterized by expectation values \
of the Pauli operators which are directly observed in experiments.\
\>", "TechNoteText",
 CellID->1669360625,ExpressionUUID->"797184ba-d6f1-4fba-9f97-546c4cb65633"],

Cell["\t", "TechNoteText",
 TabFilling->"\[LongDash]\[NegativeThickSpace]",
 TabSpacings->Scaled[1],
 FontColor->GrayLevel[0.85],
 CellID->2055419608,ExpressionUUID->"ed555652-8f40-4d6d-96b2-5122ba53ad13"],

Cell["For demonstration, consider a state vector for a qubit.", \
"TechNoteMathCaption",
 CellID->1589467211,ExpressionUUID->"e8f93fe4-167a-44ce-a14b-389746b837f7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"vec", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Ket", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], "\[Rule]", "0"}], "]"}], 
    RowBox[{"Sqrt", "[", "2", "]"}]}], "-", 
   RowBox[{"I", " ", 
    RowBox[{"Ket", "[", 
     RowBox[{
      RowBox[{"S", "[", "1", "]"}], "\[Rule]", "1"}], "]"}]}]}]}]], "Input",
 CellLabel->"In[128]:=",
 CellID->2082365803,ExpressionUUID->"2b3d8257-fa70-434b-a57a-2f350b743b7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   SqrtBox["2"], " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox["0", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"1"}, "RowDefault"]], 
          $CellContext`S[1, Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 0|>]]}], "-", 
  RowBox[{"\[ImaginaryI]", " ", 
   InterpretationBox[
    TemplateBox[{
      TemplateBox[{
        SubscriptBox["1", 
         InterpretationBox[
          SubscriptBox[
           TemplateBox[{"S"}, "RowDefault"], 
           TemplateBox[{"1"}, "RowDefault"]], 
          $CellContext`S[1, Q3`$]]]}, "RowDefault"]},
     "Ket"],
    Ket[<|$CellContext`S[1, Q3`$] -> 1|>]]}]}]], "Output",
 CellLabel->"Out[128]=",
 CellID->1776475780,ExpressionUUID->"9cffe19f-d1df-4021-b600-7127f06fe171"]
}, Open  ]],

Cell[TextData[{
 "Convert it to the ",
 ButtonBox["Bloch vector",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BlochVector"],
 ", i.e., the corresponding point on the ",
 ButtonBox["Bloch sphere",
  BaseStyle->"Link",
  ButtonData->"paclet:QuantumMob/Q3/ref/BlochSphere"],
 "."
}], "TechNoteMathCaption",
 CellID->1616515947,ExpressionUUID->"7dfe0661-ac1f-4708-ad26-60d9ad66e285"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"pnt", "=", 
  RowBox[{"BlochVector", "[", "vec", "]"}]}]], "Input",
