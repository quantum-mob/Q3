    RowBox[{
     RowBox[{"{", 
      RowBox[{"w1", ",", "w2"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"q1", ",", "q2"}], "}"}], ",", 
     RowBox[{"Dagger", "@", 
      RowBox[{"{", 
       RowBox[{"w1", ",", "w2"}], "}"}]}]}], "]"}]}]}]], "Input",
 CellLabel->"In[121]:=",
